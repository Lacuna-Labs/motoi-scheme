#!/usr/bin/env node
// motoi CLI shebang stub.
// Dispatches to src/cli.js. Node ≥ 20.16 required.

import { main } from '../src/cli.js'

main(process.argv.slice(2))
  .then((code) => process.exit(code ?? 0))
  .catch((err) => {
    process.stderr.write(`motoi: ${err.stack || err.message}\n`)
    process.exit(1)
  })
