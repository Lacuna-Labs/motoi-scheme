#!/usr/bin/env node
// motoi CLI shebang stub.
// Dispatches to src/cli.js. Node ≥ 20.16 required.

import { main } from '../src/cli.js'
import { basename } from 'node:path'

// Two binaries land on PATH — 'motoi' (the fantasy console tool) and
// 'motoi-scheme' (the language REPL). We pass the invocation name to
// main() so it can pick the right default when no subcommand is given.
const invokedAs = basename(process.argv[1] || 'motoi')

main(process.argv.slice(2), { invokedAs })
  .then((code) => process.exit(code ?? 0))
  .catch((err) => {
    process.stderr.write(`motoi: ${err.stack || err.message}\n`)
    process.exit(1)
  })
