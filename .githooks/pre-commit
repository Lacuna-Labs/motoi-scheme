#!/usr/bin/env bash
#
# pre-commit — Motoi Scheme network-abstinence guard
#
# ENFORCES Alfred's durable doctrine (2026-07-17):
#
#   "Motoi cannot connect to networks. Ever."
#
#   (see: project_motoi_no_tools_no_internet_2026_07_17,
#         project_sakura_internet_business_posture_2026_07_17)
#
# WHY THIS HOOK EXISTS
#   On 2026-07-17 an agent authored motoi-scheme/lib/net/loam-client.js
#   despite explicit guards. That code was archived to
#     _archive-doctrine-violation-loam-client-2026-07-17/
#   and this hook exists so it cannot happen again — even by a well-meaning
#   future agent who reads the archive as a "template."
#
# WHAT IT REJECTS
#   1. Any new/modified file under lib/net/ other than the single allowed
#      server file: lib/net/http-serve.js
#      Files that pattern-match lib/net/*-client.* get a specialized
#      "loam-flavored" rejection message referencing the archive.
#   2. Source lines under lib/ or src/ that shape like an HTTP CLIENT:
#      fetch("http... / axios / node-fetch / http.request / net.createConnection
#      / new WebSocket / remote-URL string literals, etc.
#      EXCEPTIONS:
#        - lib/ai/llm.js  (approved local-LLM curl exception, see memory
#          project_motoi_no_tools_no_internet_2026_07_17)
#        - Comments (// # /* */)
#        - Loopback URLs (127.0.0.1, localhost, 0.0.0.0)
#
# OVERRIDE
#   git commit --no-verify bypasses this hook.
#   Alfred's CLAUDE.md is explicit: "No --force, no --no-verify."
#   Agents that reach for --no-verify are violating repo doctrine.
#   (Git offers no reliable way for a pre-commit hook to detect --no-verify;
#    it is simply not invoked in that case. This comment is the only warning
#    we can leave.)
#
# PERFORMANCE
#   Fast path: if no staged file matches lib/net/, lib/, or src/, the hook
#   exits in a single `git diff --cached --name-only` call. Well under 500ms
#   on a normal commit.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ---------- fast path ---------------------------------------------------------

# Only care about Added / Copied / Modified.
STAGED="$(git diff --cached --name-only --diff-filter=ACM || true)"

if [ -z "$STAGED" ]; then
  exit 0
fi

# Trim to files under lib/ or src/ — everything else is out of scope.
RELEVANT="$(printf '%s\n' "$STAGED" | grep -E '^(lib|src)/' || true)"

if [ -z "$RELEVANT" ]; then
  exit 0
fi

# ---------- shared error preamble --------------------------------------------

VIOLATIONS=()

# reject_general FILE PATTERN
#
# Called once per (file, pattern) violation. Accumulates into VIOLATIONS[].
reject_general() {
  local file="$1" pattern="$2"
  VIOLATIONS+=("  $file  ->  $pattern")
}

# ---------- guard 1: lib/net/ allow-list --------------------------------------

NET_ALLOW=("http-serve.js")

is_net_allowed() {
  local basename="$1"
  local allowed
  for allowed in "${NET_ALLOW[@]}"; do
    if [ "$basename" = "$allowed" ]; then
      return 0
    fi
  done
  return 1
}

NET_FILES="$(printf '%s\n' "$RELEVANT" | grep -E '^lib/net/' || true)"
LOAM_FLAVORED=()
GENERIC_NET=()

if [ -n "$NET_FILES" ]; then
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    base="$(basename "$f")"
    if is_net_allowed "$base"; then
      continue
    fi
    # *-client.* pattern — flag with loam-flavored message
    if printf '%s' "$base" | grep -Eq '^[^/]*-client\.[A-Za-z0-9]+$'; then
      LOAM_FLAVORED+=("$f")
    else
      GENERIC_NET+=("$f")
    fi
  done <<<"$NET_FILES"
fi

# ---------- guard 2: source-line HTTP-client patterns -------------------------

# Files exempt from source-line scan.
SRC_SCAN_EXEMPT=("lib/ai/llm.js")

is_src_scan_exempt() {
  local file="$1"
  local exempt
  for exempt in "${SRC_SCAN_EXEMPT[@]}"; do
    if [ "$file" = "$exempt" ]; then
      return 0
    fi
  done
  return 1
}

# Patterns that shape like a remote network client.
# Each pattern gets a human-friendly label used in the rejection report.
#
# Held as parallel arrays: PAT[i] is the extended-regex, LABEL[i] its label.
PAT=(
  'fetch\s*\(\s*(["'\''`])https?://'
  'axios\s*[.(]'
  '(require\s*\(\s*["'\'']node-fetch["'\'']\s*\))|(from\s+["'\'']node-fetch["'\''])'
  '(https?|http|https)\.(request|get|post)\s*\('
  'net\.(createConnection|Socket)\s*\('
  'new\s+WebSocket\s*\('
  '(["'\''`])https?://(127\.0\.0\.1|localhost|0\.0\.0\.0)'  # sentinel: matched loopback, ALLOWED
  '(["'\''`])https?://[^"'\''`\s]+'
)

LABEL=(
  'fetch("http...) — remote HTTP fetch'
  'axios — HTTP client library'
  "node-fetch import — HTTP client library"
  'http/https .request/.get/.post — Node core HTTP client'
  'net.createConnection / net.Socket — raw TCP client'
  'new WebSocket(...) — WebSocket client'
  '__LOOPBACK_ALLOWED__'
  'remote URL string literal (http:// or https://)'
)

# strip_comment_prefix LINE
#   Returns 0 if LINE (with the leading '+' already trimmed) is a comment-only
#   line: starts with //, #, *, or /* — we skip these.
is_comment_line() {
  local body="$1"
  # trim leading whitespace
  local trimmed
  trimmed="$(printf '%s' "$body" | sed -E 's/^[[:space:]]+//')"
  case "$trimmed" in
    '//'*|'#'*|'/*'*|'*'*|'*/'*) return 0 ;;
  esac
  return 1
}

SRC_LINE_HITS=()

# Files to scan for source-line patterns.
SCAN_FILES="$(printf '%s\n' "$RELEVANT" | grep -E '\.(m?js|cjs|ts|mts|cts)$' || true)"

if [ -n "$SCAN_FILES" ]; then
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    if is_src_scan_exempt "$f"; then
      continue
    fi

    # Get ADDED lines only from the staged diff for this file.
    # -U0 keeps context minimal; we filter with awk to '^\+' non-header lines.
    ADDED="$(git diff --cached -U0 -- "$f" 2>/dev/null | \
             awk '/^\+\+\+ /{next} /^\+/{ sub(/^\+/, ""); print }' || true)"

    [ -z "$ADDED" ] && continue

    # For each pattern (except the loopback sentinel), scan added lines.
    n=${#PAT[@]}
    i=0
    while [ $i -lt $n ]; do
      pat="${PAT[$i]}"
      lbl="${LABEL[$i]}"

      if [ "$lbl" = "__LOOPBACK_ALLOWED__" ]; then
        i=$((i + 1))
        continue
      fi

      # match, case-insensitive, drop comment-only lines
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        if is_comment_line "$line"; then
          continue
        fi

        # loopback-URL exception for the string-literal patterns:
        # if the line contains ONLY loopback URLs and no other remote URL,
        # skip it. Cheap check: does the loopback sentinel match?
        if printf '%s' "$line" | grep -iEq "${PAT[6]}"; then
          # Strip loopback URL substrings then re-check the current pattern.
          stripped="$(printf '%s' "$line" | \
            sed -E 's#https?://(127\.0\.0\.1|localhost|0\.0\.0\.0)[^"'"'"'`[:space:]]*##gI')"
          if ! printf '%s' "$stripped" | grep -iEq "$pat"; then
            continue
          fi
        fi

        SRC_LINE_HITS+=("  $f  ->  $lbl")
        # first hit per (file, pattern) is enough
        break
      done < <(printf '%s\n' "$ADDED" | grep -iE "$pat" || true)

      i=$((i + 1))
    done
  done <<<"$SCAN_FILES"
fi

# ---------- report / exit -----------------------------------------------------

if [ ${#LOAM_FLAVORED[@]} -eq 0 ] && \
   [ ${#GENERIC_NET[@]}    -eq 0 ] && \
   [ ${#SRC_LINE_HITS[@]}  -eq 0 ]; then
  exit 0
fi

# Something matched. Refuse and explain.

cat >&2 <<'EOF'

  pre-commit — Motoi network-abstinence guard REJECTED this commit

  Alfred's durable doctrine (2026-07-17):

      "Motoi cannot connect to networks. Ever."

      Motoi is HERMETIC. No fetch. No shell out to the network. No function
      calls to external services. Local only. `http/serve` is fine — that's
      a SERVER, not a client. `lib/ai/llm.js` uses curl to a LOCAL model
      endpoint only and is the single approved exception.

      If this network capability truly belongs somewhere, it belongs in
      Sakura, not Motoi. Author it in ~/code/sakura-scheme/ instead.

  Prior art — the last time this doctrine was violated:

      _archive-doctrine-violation-loam-client-2026-07-17/MANIFEST.slat

      An agent authored lib/net/loam-client.js despite explicit guards.
      The file was archived (no-deletes doctrine) and this hook was written
      so it cannot happen again silently.

EOF

if [ ${#LOAM_FLAVORED[@]} -gt 0 ]; then
  cat >&2 <<'EOF'
  --- lib/net/*-client.* files (LOAM-flavored violation) --------------------

  A file matching `lib/net/*-client.*` was staged. This is EXACTLY the
  shape of the 2026-07-17 loam-client violation. Move this to Sakura or
  delete it before committing.

EOF
  printf '    %s\n' "${LOAM_FLAVORED[@]}" >&2
  printf '\n' >&2
fi

if [ ${#GENERIC_NET[@]} -gt 0 ]; then
  cat >&2 <<'EOF'
  --- new file under lib/net/ (not on allow-list) --------------------------

  Only lib/net/http-serve.js is allowed under lib/net/ — it is the HTTP
  SERVER, not a client. Motoi serves; Motoi does not fetch.

EOF
  printf '    %s\n' "${GENERIC_NET[@]}" >&2
  printf '\n' >&2
fi

if [ ${#SRC_LINE_HITS[@]} -gt 0 ]; then
  cat >&2 <<'EOF'
  --- source lines that shape like an HTTP client --------------------------

  These added lines look like network-client code. If the URL is a loopback
  (127.0.0.1 / localhost / 0.0.0.0) the guard would have skipped it. If this
  is a legitimate local-service call, extend the allow-list intentionally
  rather than working around the hook.

EOF
  printf '  %s\n' "${SRC_LINE_HITS[@]}" >&2
  printf '\n' >&2
fi

cat >&2 <<'EOF'
  If you truly must bypass this hook, --no-verify is available — but Alfred's
  CLAUDE.md is explicit: "No --force, no --no-verify." Agents that reach for
  --no-verify are violating repo doctrine.

EOF

exit 1
