;; MOTOI-FIRST-PASS.slat
;;
;; The first pass at Motoi Scheme — extracted from ~/code/sakura-scheme/ on 2026-07-16.
;; Alfred picked "Option (b)": copy the core engine files from sakura-scheme/src/
;; into motoi-scheme/, treat scheme-lang as a legacy staging area to migrate
;; from over multiple passes. Sakura-scheme keeps running (it's the AppStore-
;; bound app); no source has been removed from it. Extraction wiring
;; (sakura-scheme consuming motoi-scheme via SemVer pin) is a later pass.

(first-pass
  :date "2026-07-16"
  :extracted-from "~/code/sakura-scheme/"
  :extraction-mode "copy-not-move"
  :sakura-scheme-status "unchanged; still builds; still ships"
  :directed-by "Alfred, in-conversation 2026-07-16")

(layout
  :note "The 4-doc-type layout is the fork template — every Motoi fork inherits this shape."
  :subdirs
    (("Engineering" :purpose "architecture, decisions, adapter engine, telemetry, security, integration")
     ("Scheme"      :purpose "language reference, book, tutorial, style guide")
     ("Words"       :purpose "vocabulary, glossary, naming conventions, canonical taxonomy")
     ("Spec"        :purpose "formal specs — dialect.slat, SLAT format, protocol contracts")))

(files-copied
  :source "sakura-scheme/src/"
  :target "motoi-scheme/src/"
  :files
    (("base.js"          846 :role "R7RS base library + 80+ primitives")
     ("cli.js"           159 :role "bash CLI entry point (renamed bin/sakura-scheme -> bin/motoi)")
     ("dispatch.js"      857 :role "five-gate dispatcher, contract enforcement")
     ("docs-emitter.js"   96 :role "verb-registry -> MD doc pages")
     ("index.js"         107 :role "public API surface — the export sheet")
     ("interp.js"        532 :role "evaluator, Env, Closure, TCO trampoline, fuel budget")
     ("introspect.js"     97 :role "help, describe, type-of, arity-of, doc-of, source-of")
     ("macro.js"         414 :role "hygienic syntax-rules + define-macro")
     ("reader.js"        197 :role "tokenizer + parser + source positions + LRU AST cache")
     ("repl.js"          218 :role "REPL machinery + meta-commands")
     ("slat.js"            5 :role "SLAT reader/writer facade (imports from bindings/js/slat.js)")
     ("slat-verbs.js"    500 :role "SLAT verbs bridged into the base env")
     ("verbRegistry.js"  289 :role "verb metadata format + validation + snapshot")))

(bindings-copied
  :source "sakura-scheme/bindings/"
  :target "motoi-scheme/bindings/"
  :notes
    ("bindings/js/         — canonical JS slat reader/writer + fixtures + tests"
     "bindings/python/     — Python slat binding for downstream Python consumers"))

(scheme-copied
  :source "sakura-scheme/docs/ AND scheme-lang/docs/"
  :target "motoi-scheme/Scheme/"
  :files
    (("MOTOI-SCHEME-REFERENCE.slat" :from "scheme-lang/docs/SAKURA-SCHEME-REFERENCE.slat"
                                    :note "1,167 verbs + 70 core forms per E2 audit; renamed to Motoi.")
     ("TUTORIAL.html"               :from "sakura-scheme/docs/TUTORIAL.html")
     ("STYLE-GUIDE.md"              :from "sakura-scheme/docs/STYLE-GUIDE.md")))

(what-is-NOT-yet-here
  :note "The first pass is scaffolding. These are TBD next-pass work."
  :items
    ("Engineering/*.ENG.slat  — engineering docs still under sakura-scheme/docs/engineering/. Six of them are broken flat-slats (LOAM, MARIONETTE, SAKURA-AUTOMATIONS, SAKURA-SCHEME, TELEMETRY-MEDIAN, LACUNA-INTEGRATION, HELLO-SURFACE — from 2026-07-13 crew). Only CORTEX and FORGE have the correct E1-shape. Repair job pending Alfred's call."
     "Words/*                 — Motoi's vocabulary/taxonomy layer is empty. Populate from ~/code/curator/scheme-books/book-of-words/ marketplace primers + naming-conventions doc."
     "Spec/dialect.slat        — schema written; needs the actual Motoi refuses/modifies/adopts/adds baseline (Motoi is the base, so most fields are empty until forks appear)."
     "Spec/SLAT.slat          — SLAT 1.0 format spec should live here as the canonical copy; currently in ~/code/scheme-lang/docs/CONVENTION.slat and elsewhere."
     "tests/                  — did not copy tests; sakura-scheme's tests are Sakura-flavored and should be re-shaped or replaced with Motoi-only tests."
     "training-data/          — Motoi hosts the corpus that trains Motoi Copilot (per doctrine). Not created yet; corpus lives at ~/code/sakura-corpus/ today."))

(next-passes
  :note "Sequenced work to complete the extraction. Each is destructive; each waits for Alfred's go."
  :sequence
    ((pass-2 :name "sakura-scheme consumes motoi-scheme"
             :description "Add motoi-scheme as SemVer dependency in sakura-scheme/package.json (path override for local dev). Rewrite sakura-scheme/src/index.js to re-export from motoi-scheme. Remove duplicated engine code from sakura-scheme/src/ (archive to _archive-2026-07-16-extraction/); leave only Sakura-dialect verbs. Verify sakura-scheme tests pass + AppStore build still works.")
     (pass-3 :name "scheme-lang → motoi-scheme migration"
             :description "The bulk of the language work happened in scheme-lang. Migrate: adapters, ai, alg, animation, audio-driver, base (compare vs Motoi base — likely superset), cine, commercial, dispatch, framebuffer, game/*, ide, launcher, macro, media, ops, prefab, r7rs-small, r7rs-types, reader, reference-*, registry. Some are Motoi-base material; some are Sakura-dialect (belong in Curator/sakura-scheme); some are Lacuna-dialect (belong in Lacuna repo).")
     (pass-4 :name "Curator consumes sakura-scheme dialect (not motoi directly)"
             :description "Update Curator's package.json to depend on sakura-scheme (the dialect layer); sakura-scheme in turn depends on motoi-scheme. Preserves the closed-source Sakura dialect while Curator only knows about the Sakura API.")
     (pass-5 :name "Lacuna authors its dialect layer"
             :description "New repo ~/code/lacuna-scheme/ (or subdirectory of ~/code/lacuna/) with sys/, net/, docker/, deploy/ verbs. Depends on motoi-scheme. Consumers are Lacuna's SRE apps.")
     (pass-6 :name "Rename sweep across corpus + memory"
             :description "The rename Sakura Scheme → Motoi Scheme is not yet propagated. Reference docs, training corpus, memory files, README, CHANGELOG all say 'Sakura Scheme.' A sweep replaces 'Sakura Scheme (the language)' with 'Motoi Scheme' while keeping 'Sakura (the character)' intact. Alfred flagged this rename NOT autonomous — awaits his go per project_motoi_scheme_naming_and_dialects_2026_07_14 memory.")))

(seal-test
  :note "How we know Motoi is properly hermetic once extraction is done."
  :test-1 "rm -rf ~/code/sakura-scheme/ — Motoi still builds and tests pass (Motoi has no upward knowledge of Sakura)."
  :test-2 "rm -rf ~/code/curator/    — Motoi still builds and tests pass."
  :test-3 "Motoi's README + Reference stand on their own without referencing Curator or Sakura by URL.")

(open-questions-for-alfred
  :note "Decisions worth surfacing before pass-2."
  :q1 "Motoi's license: Apache 2.0 (open-permissive, chosen here as first-pass default). Confirm or swap for MIT / BUSL 1.1 / other."
  :q2 "Where does Motoi's training corpus live? sakura-corpus/ today. Move to motoi-scheme/training-data/? Or stay separate?"
  :q3 "The 6 broken flat-slat engineering docs in sakura-scheme/docs/engineering/. Repair job scope: dispatch a foreground pass to fix them (they're the doc source Motoi's Engineering/ inherits eventually)."
  :q4 "The rename sweep — flip Sakura Scheme (language) → Motoi Scheme (language) across all reference/training/memory. When?"
  :q5 "Motoi Copilot (the tiny savant LLM per doctrine) — this is training-time work; not extraction-time. Timeline separate.")
