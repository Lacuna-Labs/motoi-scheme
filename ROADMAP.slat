;;; motoi-scheme/ROADMAP.slat
;;; Motoi repo's own work-tracking. Every gap that stands between
;;; today's first-pass extraction and near-Sakura-parity.
;;;
;;; Alfred 2026-07-16 hour-9c: "1-8 needs to be in the Motoi repo. It's Motoi stuff."
;;; Prior misplacement in ~/code/lacuna-labs/mailboxes/doc-completion-lane-2026-07-16.mailbox.slat
;;; is superseded by this file. That mailbox addendum stays as a pointer here.

(roadmap
  :repo         "motoi-scheme"
  :extracted-from "sakura-scheme"
  :first-pass-date "2026-07-16"
  :owner        "Alfred"
  :state        "first-pass landed; parity work not yet dispatched"
  :companion    "MOTOI-FIRST-PASS.slat — the extraction manifest")

;; ---------------------------------------------------------------------------
;; Gaps between first-pass and near-Sakura-parity
;; ---------------------------------------------------------------------------

(gap
  :n 1
  :title "Pass-3 migration — scheme-lang modules → motoi-scheme/src/"
  :priority :BLOCKS-PARITY
  :description
  "The scheme-lang modules that make the language DO things — adapters, ai,
   alg, animation, audio-driver, cine, commercial, framebuffer, game/*, ide,
   launcher, media, ops, prefab, r7rs-small, r7rs-types, reference-* — all
   still in ~/code/scheme-lang/. Motoi has the interpreter but nothing to
   interpret against for the L1-L4 stack. This is the biggest single gap."
  :status :pending
  :classification "Some belong in Motoi base (framebuffer/sound/animation).
                   Some belong in Sakura dialect (card/*, shop/*, sprite/*).
                   Some belong in Lacuna dialect (sys/*, net/*, docker/*).
                   Migration requires per-module classification pass first.")

(gap
  :n 2
  :title "Motoi's own tests"
  :priority :HIGH
  :description
  "sakura-scheme's tests are Sakura-flavored. Motoi needs re-shaped or fresh
   tests exercising only Motoi's public API surface. Parity isn't verifiable
   without them."
  :status :pending
  :depends-on '(1 3))

(gap
  :n 3
  :title "Pass-2 wiring — sakura-scheme consumes motoi-scheme via SemVer pin"
  :priority :HIGH
  :description
  "Add motoi-scheme as SemVer dependency in sakura-scheme/package.json (path
   override for local dev). Rewrite sakura-scheme/src/index.js to re-export
   from motoi-scheme. Archive duplicated engine code from sakura-scheme/src/
   to _archive-2026-07-16-extraction/. Verify sakura-scheme tests + AppStore
   build still work. Seal-tests: rm -rf ~/code/sakura-scheme/ → Motoi still
   builds; and reverse."
  :status :pending
  :depends-on '(1))

;; Terminology lock (Alfred 2026-07-16 hour-12b): "modules" not "extensions".
;; Rationale: matches Scheme R6RS `module`, Racket's `module`, Python/Ruby.
;; First-class part of the language, not optional add-ons. Folder path is
;; motoi-scheme/modules/{math-advanced,science-*,ai,game-advanced,...}/ NOT
;; motoi-scheme/extensions/. All follow-on lanes MUST use "module" terminology.

(gap
  :n 4
  :title "words/ layer — vocabulary/glossary/naming-conventions"
  :priority :MEDIUM
  :description
  "Populate motoi-scheme/words/ from ~/code/curator/word-books/book-of-words/
   marketplace primers + naming-conventions doc. Language works; docs +
   discoverability lag without this."
  :status :pending)

(gap
  :n 5
  :title "spec/dialect.slat — Motoi's baseline refuses/modifies/adopts/adds"
  :priority :MEDIUM
  :description
  "Schema exists at motoi-scheme/spec/dialect.slat but Motoi's actual
   refuses/modifies/adopts/adds baseline is empty. Fork protocol needs this
   filled to work. Most fields empty since Motoi IS the base."
  :status :pending)

(gap
  :n 6
  :title "spec/SLAT.slat — canonical SLAT 1.0 format spec"
  :priority :HIGH
  :description
  "Currently at ~/code/scheme-lang/docs/CONVENTION.slat. Canonical copy
   MUST live at motoi-scheme/spec/SLAT.slat. Bindings + Rosetta consumers
   point here.

   Alfred 2026-07-16 hour-9f: 'Motoi supports slat.'
   SLAT is FIRST-CLASS in Motoi, not an adapter or optional. The slat
   reader/writer (src/slat.js + src/slat-verbs.js) is already in the
   first-pass extraction — those are core verbs. The FORMAT SPEC itself
   just needs to move here so bindings + docs cite the canonical location."
  :status :pending
  :implications
  ("slat/* verbs are Motoi base verbs (not dialect-specific)"
   "Every Motoi program can read/write SLAT natively"
   "Motoi Copilot training MUST include SLAT reading/writing/transformation examples"
   "SLAT bindings (bindings/js/ + bindings/python/) ship with Motoi, not with dialects"
   "Fork protocol expects fork docs authored in SLAT"))

(gap
  :n 7
  :title "6 broken flat-slat eng-docs in sakura-scheme/docs/engineering/"
  :priority :COSMETIC-BUT-LOAD-BEARING
  :description
  "LOAM, MARIONETTE, SAKURA-AUTOMATIONS, SAKURA-SCHEME, TELEMETRY-MEDIAN,
   LACUNA-INTEGRATION, HELLO-SURFACE (from 2026-07-13 crew). Only CORTEX +
   FORGE have correct E1-shape. These docs are the source Motoi's
   engineering/ inherits eventually. Repair before pass-3."
  :status :pending)

(gap
  :n 8
  :title "Rename sweep — 'Sakura Scheme' (language) → 'Motoi Scheme' — IN MOTOI REPO ONLY"
  :priority :COMPLETED
  :description
  "Motoi 2026-07-16 hour-9h: Alfred approved this rename WITHIN motoi-scheme
   repo only (NOT in the sakura-scheme repo where 'Sakura Scheme' remains
   the naming). Sed sweep executed same fire: 178 files in motoi-scheme/
   changed 'Sakura Scheme' → 'Motoi Scheme'. Excluded _archive/ and
   scratch/ per no-deletes doctrine. Zero remaining occurrences verified.

   Note: the sweep also replaced the text of this gap's own description
   ('Sakura Scheme' → 'Motoi Scheme') — this edit restores meaningful
   history of what was renamed.

   Sakura (the character) still named 'Sakura' throughout — the sweep
   targeted only the two-word phrase 'Sakura Scheme' (language name)."
  :status :completed
  :executed "2026-07-16-hour-9h"
  :files-changed 178)

;; ---------------------------------------------------------------------------
;; Repo layout for training + book ownership (Alfred 2026-07-16 hour-9d)
;; ---------------------------------------------------------------------------

(repo-layout
  :direction "Alfred: 'motoi/training-data · motoi/scheme-books · etc.' (original transcript had misspelling; corrected 2026-07-16 sweep)"
  :note "Books that teach the LANGUAGE live under motoi-scheme/. Sakura's
         world-knowledge material (philosophers/graphs/hellosurface-scenarios/
         etc.) stays in curator/. Motoi is self-contained for its own training."
  :folders
  ((:folder "motoi-scheme/scheme-books/"
            :purpose "16 scheme-teaching books moved from curator/scheme-books/"
            :contents "book-of-scheme, book-of-math, book-of-sound, book-of-animation,
                       book-of-motion, book-of-music, book-of-instruments, book-of-slat,
                       book-of-modules, book-of-reason-code, book-of-one-shot,
                       book-of-systems, book-of-hellosurface, book-of-marionette,
                       book-of-jesse, book-of-arcade-games, book-of-simulation-games,
                       book-of-narrative-games. Language + Motoi Scheme teaching material.")
   (:folder "motoi-scheme/word-books/"
            :purpose "16 word-teaching books moved from curator/word-books/"
            :contents "book-of-words + vocabulary/glossary/naming-conventions/
                       marketplace-primers + poetry-forms + paired-scenarios etc.")
   (:folder "motoi-scheme/training-data/"
            :purpose "Generated JSONL pairs (SFT format) from the books"
            :contents "One JSONL per book + combined training set. Reuses Forge's
                       {\"messages\": [...]} shape.")
   (:folder "motoi-scheme/words/"
            :purpose "Runtime-facing vocabulary layer (gap 4) — distinct from
                      word-books/ which is the teaching corpus")))

(migration-decision-locked
  :n "move-vs-copy"
  :decision "COPY — Alfred 2026-07-16 hour-9h: 'Copy the books.'"
  :executed "2026-07-16-hour-9h"
  :result
  ("motoi-scheme/scheme-books/  ← 71 books, 34 MB (hidden mistake-archives excluded)"
   "motoi-scheme/word-books/    ← 5 books, 1.6 MB (full copy)"
   "motoi-scheme/training-data/ ← empty, ready for JSONL output"
   "curator/scheme-books/ + curator/word-books/ unchanged (still 2.0 GB with archives)")
  :sync-strategy
  "Manual re-run of rsync when curator's books update. No automation yet.
   Copy command used:
     rsync -a --exclude=\".*\" curator/scheme-books/ motoi-scheme/scheme-books/
     rsync -a curator/word-books/ motoi-scheme/word-books/"
  :excluded
  "Hidden .* dirs in curator/scheme-books/ (.consolidated-wrong-2026-07-13 1.8G,
   .wrong-attribution-2026-07-13 153M, .dupes-2026-07-14 12M, and smaller) — these
   are prior-lane mistake-archives per no-deletes doctrine in curator. Not needed
   in Motoi.")

;; ---------------------------------------------------------------------------
;; Discussed separately from 1-8 per Alfred 2026-07-16 hour-9b
;; ---------------------------------------------------------------------------

(item
  :n 9
  :title "Motoi Copilot — dedicated coder LLM trained on Motoi corpus"
  :status :spec-locked
  :character-name "Motoi Copilot"
  :short-name     "Copilot"
  :name-decided-by "Alfred 2026-07-16 hour-9i: 'Motoi Copilot is Motoi Copilot — Copilot for short.'"
  :spec-from-alfred
  ("Latest queen coder (interpreted as Qwen3-Coder line)"
   "Size big enough to hold Motoi language"
   "Dedicated coder — NOT general-purpose"
   "Fun and jokes personality (not Sakura's persona)"
   "No products or world knowledge like Sakura"
   "16 scheme-books + 16 word-books converted for training"
   "Trained FIRST as a test before Sakura's next run"
   "Small enough for rapid training")
  :base-model-locked "Qwen2.5-Coder-1.5B-Instruct — Alfred 2026-07-16 hour-12: 'Let's do 1.5B'"
  :hf-model-id       "Qwen/Qwen2.5-Coder-1.5B-Instruct"
  :base-model-previous "Qwen2.5-Coder-7B-Instruct (superseded — was hour-9h default; downgraded because kids need to download <1GB, and dense Motoi code multiplies small-model capability)"
  :backup-model      "Qwen2.5-Coder-3B-Instruct — if 1.5B fails to hold corpus"
  :why-this-choice
  ("Small (7B) — fast to iterate, comfortable fit for author rig"
   "Coder-Instruct — Coder pretrain (~5T tokens of code incl. some Lisp/Scheme)
    + Instruct fine-tune. Right substrate for Motoi Scheme dialect fine-tune.
    General Instruct would leave coder-substrate on the table."
   "Enough capacity to memorize 1,217 verbs + generalize to compositions.
    3B might drop verbs; 30B too slow to iterate as test rig.")
  :open-decisions
  ("Character name?"
   "Corpus scope — 32 books only, or include reference + carts + Scheme literature?"
   "training-data/ location — motoi-scheme/training-data/ or sakura-corpus/?"
   "Format conversion — JSONL pairs like Sakura training?"
   "Trainer — reuse Forge pipeline?")

  :pure-training-data-loose-ends
  ("~500-1k persona/voice pairs (fun+jokes register)"
   "~3-5k verb-signature drills (1,217 verbs × few pairs each)"
   "~2-3k error → fix pairs (broken Motoi programs paired with corrections)"
   "~1k REPL-shaped multi-turn coding sessions"
   "~500 refusal-shape pairs (drier than Sakura, coder-flavored)"
   "~1k reference-lookup pairs (speak the reference format naturally)")

  :cortex-wire-up-training
  ("Direction: Alfred 2026-07-16 hour-9e — 'Add the cortex to it for it to be wired up.'"
   "Motoi Copilot is not stateless — it USES Cortex to persist across sessions."
   ""
   "~1-2k pairs on WHEN to write Cortex (project context, user preferences,"
   "  session state, learned idioms, error patterns)"
   "~1-2k pairs on RETRIEVAL + composition (cortex/read, cortex/query,"
   "  chain-of-reference walks in coding context)"
   "~500 pairs on schema + tagging (confidentiality, training-eligible,"
   "  provenance for Copilot-persisted records)"
   "~1k pairs on abduction over Cortex records (this operator's style →"
   "  suggest matching idioms)")

  :slat-training-first-class
  ("Direction: Alfred 2026-07-16 hour-9f — 'Motoi supports slat.'"
   "SLAT is first-class Motoi. Motoi Copilot must speak it fluently."
   ""
   "~1-2k pairs on slat/read + slat/parse (how to consume a SLAT file)"
   "~1-2k pairs on slat/write + slat/emit (how to author SLAT records with"
   "  proper tagging: :dialect / :audience / :content-rating / :training-eligible /"
   "  :provenance / :book-version)"
   "~500 pairs on SLAT transformation (JSONL ↔ SLAT, filter/reduce over records)"
   "~500 pairs on SLAT-as-configuration (how Motoi programs use SLAT for state)"
   "  → adds ~3-5k more pairs to corpus")

  :total-corpus-target
  ("~32k book-derived pairs (16 scheme-books + 16 word-books)"
   "+ ~8-11k pure training pairs (loose ends)"
   "+ ~3.5-5.5k Cortex-wire-up pairs"
   "+ ~3-5k SLAT-fluency pairs"
   "= ~47k-54k pairs total"
   "Still comfortable fit for Qwen2.5-Coder-7B or Qwen3-Coder-30B-A3B"
   "Same order-of-magnitude as Sakura's SFT set."))

;; ---------------------------------------------------------------------------
;; Execution order (Alfred's implied priority)
;; ---------------------------------------------------------------------------

(execution-order
  :first "gap 1 (pass-3 migration) — biggest single move; unblocks everything"
  :then  "gap 3 (pass-2 wiring)"
  :then  "gap 4 + 5 + 6 (parallel-safe, small-medium)"
  :then  "gap 2 (tests)"
  :then  "gap 7 (eng-docs repair)"
  :last  "gap 8 (rename sweep) — awaits Alfred's explicit go")

;; End of roadmap.
