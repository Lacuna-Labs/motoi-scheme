;;; motoi-scheme/scratch/README.slat
;;; Ephemeral working directory. Keeps the top-level tree clean.
;;;
;;; Alfred 2026-07-16 hour-9g: "Keep the dirs clean. Make a dir called
;;; scratch and put all the working work in there so we don't pollute
;;; the tree."

(scratch
  :purpose
  "Everything that isn't a first-class deliverable lives here:
   - WIP drafts before promotion into the main tree
   - Intermediate artifacts from agent runs
   - Experimental scripts and one-off tools
   - Generated JSONL / SLAT batches before they land in training-data/
   - Cache directories, test scratch, temporary conversion output
   - Anything an agent authors that's not yet final"

  :gitignore-rule
  "Root .gitignore has:  scratch/*
   with exception:       !scratch/README.slat
   Everything else in scratch/ is local-only; nothing gets committed
   unless explicitly promoted OUT of scratch/ into the main tree."

  :convention-for-agents
  "When dispatched to work in motoi-scheme, agents write working files
   under scratch/ NEVER at the repo root. Only promote to first-class
   paths (engineering/, spec/, scheme/, words/, scheme-books/, word-books/,
   training-data/, src/, tests/) once the artifact is final."

  :examples-of-what-goes-here
  ("scratch/dispatch-2026-07-17-copilot-corpus-first-pass.jsonl"
   "scratch/experiments/qwen-tokenizer-benchmark/"
   "scratch/one-off/count-verbs-per-book.py"
   "scratch/wip-drafts/pass-3-migration-classification.slat"
   "scratch/pytest_cache/  ← moved from repo root")

  :examples-of-what-does-NOT-go-here
  ("README.md, LICENSE, ROADMAP.slat — first-class docs"
   "src/*.js — production interpreter"
   "engineering/*.slat — canonical eng docs"
   "training-data/*.jsonl — final training corpus (after promotion from scratch/)")

  :promotion-shape
  "When a scratch artifact is ready:
   1. Move it to its first-class path with git mv
   2. Commit with a real message
   3. Leave no dangling references in scratch/")

;; End of scratch README.
