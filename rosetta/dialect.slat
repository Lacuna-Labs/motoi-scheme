;; dialect.slat — the schema every Motoi fork declares itself against.
;;
;; A dialect is a variant of Motoi Scheme that opts to refuse / modify /
;; adopt / add verbs and semantics relative to the base language.
;;
;; Motoi itself is the base — this dialect.slat is the ANCHOR. Forks
;; reference Motoi's dialect declaration to compute their delta.
;;
;; The schema is deterministic — adapters translate between dialects without
;; needing an LLM. See Engineering/ADAPTER-ENGINE-1.0.ENG.slat once written.

(dialect
  :name          "motoi"
  :display-name  "Motoi Scheme"
  :version       "0.1.0"
  :parent        nil                    ; Motoi has no parent — it IS the base.
  :governance    "open-source, community RFCs, Lacuna-Labs stewardship"
  :repo          "git@github.com:Lacuna-Labs/motoi-scheme.git"
  :license       "Apache-2.0")

;; --- The 4 dialect operations ---
;;
;; refuses:  verbs / primitives the dialect explicitly does NOT expose.
;;           Motoi refuses nothing — it's the base.
;; modifies: verbs / primitives the dialect exposes with DIFFERENT semantics.
;;           Motoi modifies nothing — it's the base.
;; adopts:   verbs / primitives the dialect inherits UNCHANGED from parent.
;;           Motoi has no parent, so "adopts" is not meaningful here.
;; adds:     verbs / primitives the dialect INTRODUCES beyond parent.
;;           Motoi's :adds is effectively "the entire base library."

(refuses)                                ; explicitly empty for Motoi
(modifies)                               ; explicitly empty for Motoi
(adopts)                                 ; not applicable — no parent
(adds
  :note "The Motoi base library — the union of every :verb in MOTOI-SCHEME-REFERENCE.slat."
  :source-of-truth "Scheme/MOTOI-SCHEME-REFERENCE.slat")

;; --- Schema for forks ---
;;
;; A fork's dialect.slat MUST include:
;;
;; (dialect
;;   :name          "<lowercase-slug>"
;;   :display-name  "<Human Name>"
;;   :version       "<semver>"
;;   :parent        "motoi"           ; or another dialect's :name
;;   :governance    "<who decides>"
;;   :repo          "<git-url>"
;;   :license       "<spdx-id>")
;;
;; (refuses  (:verb <name>) (:verb <name>) ...)
;; (modifies (:verb <name> :new-contract "..." :new-doc "...") ...)
;; (adopts   (:verb <name>) ...)          ; usually implicit — list only exceptions
;; (adds     (:verb <name> :contract "..." :doc "..." :impl-file "...") ...)
;;
;; Every :verb SHOULD carry :atom, :namespace, :arity, :contract, :doc,
;; :examples, :tier, :perm — matching the Motoi verb-registry schema.
;;
;; Adapters read two dialect.slats and produce a translation table:
;;
;;   (translate '(from "sakura") '(to "lacuna") '(card/open 'welcome))
;;   => (translate-error :kind "no-adapter"
;;                       :from-verb "card/open"
;;                       :reason "Lacuna dialect refuses card/*")
;;
;;   (translate '(from "motoi") '(to "sakura") '(display "hi"))
;;   => (display "hi")                    ; adopted unchanged
;;
;; See Engineering/ADAPTER-ENGINE-1.0.ENG.slat (TBD) for the deterministic
;; translation algorithm and the trust model.

(schema-version "1.0.0")
(schema-date    "2026-07-16")
(schema-notes
  "This is the first-pass shape; the schema will settle after Sakura and"
  "Lacuna each author their dialect.slats and we test round-trip translation.")
