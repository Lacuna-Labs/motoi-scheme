                   "when" "unless" "cond" "case" "and" "or")
      :pre-sakura ("quote" "if" "define" "set!" "lambda" "begin" "let" "let*" "letrec" "quasiquote"
                    "when" "unless" "cond" "case" "and" "or")
      :added ("define-record-type" "guard" "do" "delay")
      :post-motoi 20
      :post-sakura 20
      :notes "R7RS §5.5, §6.11, §4.2.4, §4.2.5 — special-form gaps closed in both interpreters.")

    (:arithmetic-comparison
      :pre-motoi ("+" "-" "*" "/" "modulo" "quotient" "remainder" "max" "min" "abs"
                   "=" "<" ">" "<=" ">=" "zero?" "positive?" "negative?" "even?" "odd?")
      :added-in-appendix-z ("gcd" "lcm" "numerator" "denominator" "truncate" "atan-2arg" "square"
                              "exact" "inexact" "exact->inexact" "inexact->exact"
                              "exact?" "inexact?" "exact-integer?"
                              "integer?" "rational?" "real?" "complex?" "finite?" "infinite?" "nan?")
