                   "append" "reverse" "first" "last" "nth" "list-ref" "member" "assoc"
                   "make-list" "list-set" "take" "drop" "zip" "sort" "argmin"
                   "for-each" "map" "filter" "reduce" "any" "every" "count" "list-index")
