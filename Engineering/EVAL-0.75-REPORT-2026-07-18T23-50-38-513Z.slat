    :9-book-reader (
      :book-list-ok #t
      :book-read-ok #t
      :ship-block? #f
      :list_excerpt "(\"animation\" \"arcade-games\" \"challenges\" \"composition\" \"computing\" \"cs-curriculum\" \"instruments\" \"introspection\" \"jesse\" \"language-ancestors\" \"limits\" \"logic\" \"math\" \"modules\" \"motion\" \"music\" \"narrative-games\" \"one-shot\" \"reminded\" \"scheme\" \"sick-composition\" \"simulation-games\" \"slat\" \"sound\" \"syst"
      :read_excerpt "\"# Chapter 1 — What is introspection\\n\\nA program that only computes is a black box. You put input in, you take output\\nout, and everything between is invisible. Most programs are shaped this way.\\nMost languages are content to leave them shaped this way. You get an answer or\\nyou get an error, and if the error is opaque you go read the source in a text\\neditor and hope you find the line.\\n\\nMotoi is not shaped this way.\\n\\nEvery verb in Motoi carries its own documentation. Every value has a run"
    )
    :10-composer (
      :scaffold-ok #t
      :identity-ok #t
      :ship-block? #f
      :note "identity via equal? on scaffolded record; save/load path deferred to composer verbs when stable"
      :excerpt "\"/Users/alfred/code/motoi-scheme/scratch/scaffold/unnamed-_kind.slat\""
    )
  )
