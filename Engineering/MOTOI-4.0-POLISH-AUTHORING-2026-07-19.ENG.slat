(slat-set
  :doc-id            "MOTOI-4.0-POLISH-AUTHORING-2026-07-19"
  :title             "Motoi 4.0 Polish Set Candidate Authoring — Phase 1 of the Finishing Move"
  :author            "Ada (Lacuna Eng, docs + books lane)"
  :date              #inst "2026-07-19T00:00:00Z"
  :status            "APPROVED — candidates on disk, awaits fold + Priya safety cosign + Alfred final approval"
  :audience          (":alfred" ":lacuna-eng" ":training-pipeline" ":priya" ":future-on-call")
  :dialect           ":lacuna-eng"
  :training-eligible false
  :confidentiality   ":internal-eng"
  :version           "1.0"
  :composes-with (
    "WEAVE-ENGINEERING-METHOD-2026-07-18.ENG.md §5 (7-technique fold), §7.1-7.4 (mechanism)"
    "GRAND-WEAVE-RECIPE-2026-07-17.ENG.slat"
    "grand-weave-full-mechanical-procedure-2026-07-17 (memory)"
    "no-contaminants-provenance-rule-2026-07-17 (memory)"
    "lima-is-a-lens-not-a-fix-2026-07-17 (memory)"
    "motoi-safety-refusals (memory)"
    "manifest-2026-07-19-v6.slat (v6 corpus)"
  )

  :context (
    (:motoi-generation 4.0)
    (:v6-corpus-rows 100496)
    (:sft-adapter "~/.forge/runs/motoi-4.0/adapter/  (finished, DO NOT TOUCH)")
    (:mk-eval "Mk E firing (PID 94716) — DO NOT TOUCH")
    (:polish-target 2000)
    (:overauthor-factor 2.77)
    (:candidates-authored 5537)
    (:phase "Phase 1 — polish authoring; Phase 2 = fold, Phase 3 = resume-train, Phase 4 = reveal")
  )

  :method (
    :extraction-only #t
    :fabrication-forbidden #t
    :rule "Every candidate mechanically extracted from v6 substrate. No LLM invention."
    :quality-filter "LIMA curation floor (length window, banned-token scan, register check, dedup by user-turn prefix, hedge/walk-back penalty)"
    :selection "Rank by quality_score per bucket; take top N proportional to substrate share"
    :safety-handling "LIFT-exempt tag set; preserve-verbatim; Priya cosign block below"
    :provenance-chain "v6-substrate → polish-extract, all rows carry chain terminating at book/graph"
  )

  :v6-bucket-distribution-summary (
    (:top-10-categories (
      (:cat "A composition-mix"                          :rows 34627 :pct 34.46)
      (:cat "B vocab-and-relationship-graphs"            :rows 21133 :pct 21.03)
      (:cat "C marcus-code-teaching"                     :rows 13301 :pct 13.24)
      (:cat "LIFT ada-coverage-8858+r7rs-recipes"        :rows  8858 :pct  8.81)
      (:cat "D wave-2-chapter-books"                     :rows  6011 :pct  5.98)
      (:cat "G reference-CORE-335"                       :rows  2832 :pct  2.82)
      (:cat "J persona-waves"                            :rows  2798 :pct  2.78)
      (:cat "E book-of-math"                             :rows  2739 :pct  2.73)
      (:cat "L SLAT-and-modules"                         :rows  2010 :pct  2.00)
      (:cat "K persona-algo-variations"                  :rows  1438 :pct  1.43)
    ))
    (:key-observations (
      "34% composition-mix — motoi-copilot-final-corpus dominates as expected."
      "21% vocabulary/relationship/code-teaching graphs — the substrate anchor per no-contaminants doctrine."
      "8.8% is the NEW Ada LIFT coverage (100% CORE-335 verb example coverage + 254 Appendix Z examples + Book of R7RS Recipes 9 chapters)."
      "Safety category is 0.28% (285 rows) — small but authored source-first by Priya from book-of-self ch3-8."
      "Persona (J+I+K+H) sums to ~5.5% — speech-efficient per Grand Weave §3.3 density-law exception."
      "Subsystem-limit at 0.21% (207 rows) — new v4 addition, doctrine-anchored."
    ))
  )

  :polish-set-allocation (
    :target-pairs 2000
    :corpus-proportional-basis "fine-bucket % of v6 substrate"
    :adjustments (
      (:min-per-safety-bucket 4  :reason "guarantee density-per-bucket safety canonical template presence")
      (:min-per-substrate-present-tail 2 :reason "avoid zero-authored buckets that have real substrate")
    )
    :top-buckets-by-allocation (
      (:bucket "A-copilot-composition"    :substrate 34120 :candidates-authored 1867)
      (:bucket "graph-synonym"            :substrate 10332 :candidates-authored  565)
      (:bucket "C-marcus-code-teaching"   :substrate  9158 :candidates-authored  501)
      (:bucket "LIFT-scheme-coverage"     :substrate  8858 :candidates-authored  485)
      (:bucket "graph-vocab"              :substrate  4660 :candidates-authored  255)
      (:bucket "graph-relationship"       :substrate  3131 :candidates-authored  171)
      (:bucket "C-marcus-word-books"      :substrate  2832 :candidates-authored  155)
      (:bucket "G-reference-examples"     :substrate  2832 :candidates-authored  155)
      (:bucket "E-book-of-math"           :substrate  2739 :candidates-authored  150)
      (:bucket "D-book-of-motion"         :substrate  2366 :candidates-authored  129)
    )
    :proportionality-check "verified — deviations <5% within tail; ~2.77× overauthor for LIMR+LASER selection headroom"
  )

  :lima-premise-gate (
    :buckets-checked 67
    :buckets-with-substrate 67
    :buckets-skipped 0
    :note "Every fine bucket has substrate ≥6 rows in v6. No bucket falls under the LIMO no-substrate premise gate. sick-composition-ch1..ch8 sit at 6 rows each — thin but non-empty; 2 candidates each preserves shape."
  )

  :safety-subset (
    :priya-cosign-required #t
    :priya-cosign-status APPROVED
    :priya-cosign-block (
      :author "priya (safety-adversarial, cosigning ada's polish extraction of safety subset)"
      :date "2026-07-19"
      :subset-size 37
      :buckets-covered (
        (:bucket "safety-crisis-refusal"     :count 4  :template "I cannot directly help with these sorts of things..." :source "book-of-self/04-how-i-answer-crisis.book.slatl")
        (:bucket "safety-emergency-refusal"  :count 4  :template "I cannot directly help with these sorts of things..." :source "book-of-self/03-how-i-answer-emergencies.book.slatl")
        (:bucket "safety-personal-refusal"   :count 4  :template "I don't know things about you the way Sakura would..." :source "book-of-self/05-how-i-handle-personal-questions.book.slatl")
        (:bucket "safety-selfmod-refusal"    :count 4  :template "I can't change myself. The people who made me can..." :source "book-of-self/06-why-i-wont-modify-myself.book.slatl")
        (:bucket "safety-lookup-refusal"     :count 4  :template "I don't fetch things from the world. Claude does. I do Scheme." :source "book-of-self/07-why-i-wont-look-things-up.book.slatl")
        (:bucket "safety-circular-trap"      :count 4  :template "Counting how many times you tried, so you could see if it's working." :source "book-of-self/08-the-counting.book.slatl")
        (:bucket "N-safety-wave6"            :count 5  :template "I don't know how to help with that. I can't..." :source "motoi-persona-wave6-safety-0.75-2026-07-17.jsonl")
        (:bucket "N-safety-sakura-dip"       :count 4  :template "various — no. / I won't. / local app." :source "sakura-dip-refusal-2026-07-16.jsonl")
        (:bucket "M-circular-trap-wave8"     :count 4  :template "clean-exit code responses (map/factorial/closure)" :source "motoi-persona-wave8-circular-trap-0.75-2026-07-17.jsonl")
      )
      :all-lift-exempt-tag-set #t
      :preserve-verbatim-method #t
      :canonical-templates-match-v6 #t
      :no-modification-applied #t
      :verdict APPROVED
      :notes (
        "Every safety pair in the polish set is a verbatim extract of the v6 substrate — no rewriting, no register normalization, no LIFT-touch. The v6 substrate itself was Priya's source-first reshape from Book of Self ch3-8 (see manifest v6-changes)."
        "Density is proportional to v6 substrate (safety = 0.28%), which is small but Grand Weave doctrine says corpus-proportional. Safety density lift is a NEXT-substrate concern, not a polish concern."
        "The single-template-per-bucket shape is preserved. Consistency IS the safety property per §2.4 of the Weave Engineering Method."
        "M-circular-trap-wave8 exemplars are the CLEAN-EXIT half of the counting trap (post-reset code responses). Preserving these as polish reinforces the exit gesture that returns Motoi to helpful mode after the counting deflect."
      )
    )
  )

  :fold-instructions-for-next-phase (
    :seven-technique-fold-recipe (
      (:step "1. LIMO premise gate"    :status "PASSED — 67/67 buckets have substrate")
      (:step "2. LIMA candidate pool"  :status "5537 candidates on disk, 2.77x overauthored")
      (:step "3. MIG label graph"      :note "Build over _bucket × _kind × _register × _source_book_chapter_paragraph; use existing verb-IDs from CORE 335 reference")
      (:step "4. LASER stratified"     :note "Stratify by _bucket; preserve per-bucket proportions; DEITA 3-axis embedded")
      (:step "5. LIMR"                 :note "Score each candidate as one-step loss delta on FROZEN-1001 held probe suite via Motoi 4.0 raw-SFT adapter. Load-bearing selection step.")
      (:step "6. LIFT refine"          :note "REFUSAL PAIRS AUTO-EXCLUDED (_lift_exempt=true set on 37 candidates). Non-refusal pairs get instruction-clarity rewrite and cosine>0.92 dedup.")
      (:step "7. LIMO overlay"         :note "Composition + introspection buckets: target 40%/60% cognitive-process demo shape. Apply during LIFT.")
      (:step "8. Polish training"      :note "Resume from ~/.forge/runs/motoi-4.0/adapter/adapters.safetensors, LR 5e-5 (half substrate LR), 1 epoch, seed rotated (13/17/23/31/47/61 next unused), max_seq 4096.")
      (:step "9. Spectral Surgery"     :note "Optional post-polish SVD reweight, ~30 min, +1-4pt. RECOMMEND for 4.0 candidate.")
      (:step "10. Reveal probe"        :note "Run AUDIT-9 suite against polished adapter. Compare to Mk E raw-SFT baseline. Findings drive next-generation authoring.")
    )
    :expected-selection-count "target 2000 selected from 5537 candidates via LASER+LIMR"
    :expected-training-wall "30-60 min on Mac Studio"
    :adapter-output-location "~/.forge/runs/motoi-4.0-polish-mkE/adapter/"
  )

