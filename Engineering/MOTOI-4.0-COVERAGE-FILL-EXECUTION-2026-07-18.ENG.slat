; NEEDS-ALFRED
; ─────────────────────────────────────────────────────────────────────

(needs-alfred
  :items
    (((:id 1)
      :urgency low
      :item "audio-perceptual-bands intermediate example has an extra `)`. Reference defect, not lane-caused."
      :verb "audio-perceptual-bands"
      :file "scheme/MOTOI-SCHEME-REFERENCE.slat"
      :example-index 1
      :fix "delete one `)` from the malformed `(let ((pbands (audio-perceptual-bands))))` — should be `(let ((pbands (audio-perceptual-bands))))` with one fewer close paren")
     ((:id 2)
      :urgency info
      :item "Should verb-contrast pair density (2514 pairs = 3 per verb average) be trimmed further for training balance?"
      :context "The related-verb cross-summary shape may over-emphasize contrast at the expense of recall+use. Priya's fold LIMR pass will re-select; this note surfaces the density for that step.")
     ((:id 3)
      :urgency info
      :item "Book of R7RS Recipes chapter numbering — should chapters use 1-9 (my convention here) or 1-16 with 7 empty appendices to hold 16-chapter invariant?"
      :context "16-chapter invariant applies to canonical scheme-books; unclear whether Book of R7RS Recipes counts as canonical or as a companion reference. Fine either way; noted for later decision.")))

