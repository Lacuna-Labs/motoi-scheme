     (01-numbers-and-tensors.book.slatl :status "shipped-verified")
     (02-vectors-and-dot-product.book.slatl :status "shipped-verified")
     (03-matrices-and-matvec.book.slatl :status "shipped-verified")
     (04-functions-of-functions.book.slatl :status "shipped")
     (05-what-is-a-model.book.slatl :status "shipped-verified")
     (06-gradient-descent.book.slatl :status "shipped-verified")
     (07-single-neuron.book.slatl :status "shipped-verified")
     (08-a-layer-then-two.book.slatl :status "shipped")
     (09-backpropagation.book.slatl :status "shipped")
     (10-training-loop.book.slatl :status "shipped-p1-verified")
     (11-tokens-and-embeddings.book.slatl :status "shipped")
