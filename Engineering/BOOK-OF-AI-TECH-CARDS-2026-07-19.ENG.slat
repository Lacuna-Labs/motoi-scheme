  :ranking-language-audit
  ((:target "0 affirmative ranking hits across cards + pairs")
   (:cards-scan "grep -nE 'is the best|is the leader|leader in|ahead of|behind on|is ahead|is behind|the best at|superior to|inferior to|outperforms|dominates|leads the|beat the competition|number one|#1'")
   (:cards-hits 12 :all-inside-refusal-blocks-i-do-not-say true
                :sample "01-anthropic.book.slatl:107: `I do not say Anthropic is the leader in AI safety. That is a ranking.`")
   (:pairs-scan "same regex + winning|wins-the-race, contextually filtered")
   (:pairs-affirmative-hits 0
                :false-positives 3
                :false-positive-source "phrase `methodology behind ChatGPT` — behind meaning underneath, not ranked-behind")
   (:conclusion "Zero affirmative ranking language. All negation-audit hits are the 'I do not say X' pattern the doctrine requires."))

  :ranking-language-safeguards
  ((:cards "Every card has a `What Motoi does not say` section listing the ranking language explicitly, so the model learns the refusal shape.")
