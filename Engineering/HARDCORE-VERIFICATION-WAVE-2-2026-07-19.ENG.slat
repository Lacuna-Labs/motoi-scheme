      :fix-remaining "either add scheme tag to every bare fence OR relax the regex to accept bare fences")

    (HARDBLOCK-04
      :verdict STILL-BROKEN
      :owner "ada"
      :evidence "scheme-books/book-of-ml/09-backpropagation.book.slatl:398-399 prose still says `-4.0` and `-3.9998`; verified REPL run shows -8 and -7.9996 (2x off)"
      :kid-impact MEDIUM
      :fix-remaining "one-line prose edit: change -4.0 → -8.0, -3.9998 → -7.9996")

    (HARDBLOCK-06
      :verdict STILL-BROKEN
