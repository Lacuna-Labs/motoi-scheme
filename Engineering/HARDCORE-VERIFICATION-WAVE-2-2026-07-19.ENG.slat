    (HARDBLOCK-07
      :verdict RESOLVED
      :owner "marcus"
      :evidence "curl localhost:3739/ide.js confirms editorMode 'basic'/'vim'/'emacs', :pair-on / :pair-off vim commands, M-e emacs binding, Settings panel with palette description, tabbed editor, tree/editor/repl/cpu 4-region grid"
      :note "shipped as JS-driven (settings panel populates via ide.js on click). All Wave 2 UI claims land.")

    (HARDBLOCK-14
      :verdict STILL-BROKEN
      :owner "marcus"
      :evidence "(motoi/mark-read! 'ml 6 'sum-matrix) followed by (motoi/reading-progress 'ml 6 7) returns ((:book \"ml\") (:chapter 0) ...); lib/system/reading-state.js:407-419 unchanged from Wave 1 — Sym+number fall-through still ignores number arg"
      :kid-impact MEDIUM
      :fix-remaining "one-line: when Sym+number, use Sym as book and number as chapter (not fall-through)")

    (HARDBLOCK-15
      :verdict PARTIALLY-RESOLVED
      :owner "marcus"
      :evidence "ambientComplete now hits verb-registry snapshot; (motoi/ambient-complete \"cpu/\") returns 8 matches; (motoi/ambient-complete \"vec/\") returns 8 matches; BUT (motoi/ambient-complete \"(defi\") still returns () because startsWith requires prefix at name start and leading ( is not stripped"
      :remaining-fix "strip leading ( or split on last token before startsWith")

    (HARDBLOCK-16
      :verdict PARTIALLY-RESOLVED
      :owner "marcus"
      :evidence "refactor rules exist for car-cdr, geom→math, vec/make wrapper. (car (cdr xs)) → (cadr xs) works. BUT tautology (if #t (foo) (foo)) still reports :changed? #f — duplicate-branch rule not shipped. (if cond #t #f) rule uses [^)]+ which fails on nested parens like (> x 0)."
      :remaining-fix "add duplicate-branch rule + widen (if cond #t #f) regex to handle nested parens")

    (HARDBLOCK-17
      :verdict PARTIALLY-RESOLVED
      :owner "marcus"
      :evidence "bug-spot now sub-evals via bugSpotSync; catches parse errors (missing paren → :ok? #f with fix hint) and unbound symbols. HOWEVER Motoi's (car '()) is lenient (silent), so bug-spot reports :ok? #t — the Wave 1 repro. This is a runtime issue not a bug-spot issue."
      :remaining-fix "either tighten Motoi's car/cdr to error on nil, or add a static pre-check for classic error patterns")

    (HARDBLOCK-18
      :verdict STILL-BROKEN
      :owner "marcus"
      :evidence "(book/toc \"code\") returns (); (book/toc \"ml\") returns ()"
      :kid-impact LOW
      :fix-remaining "wire book/toc to same chapter-file enumeration as book-of-code/table-of-contents")

    (HARDBLOCK-19
      :verdict STILL-BROKEN
      :owner "marcus"
      :evidence "(book/read \"code\" 6) still returns the wall of usage text starting with `usage: (book/read :book 'name [:chapter N] [:section M])`"
      :kid-impact HIGH
      :fix-remaining "add positional overload OR raise proper error instead of returning usage-string as value")

    (HARDBLOCK-20
      :verdict STILL-BROKEN
      :owner "ada"
      :evidence "grep 'cpu/boot\\|cpu/load-program\\|cpu/run!\\|cpu/step\\|cpu/display' scheme-books/book-of-code/12-*.slatl → 0"
