  :capstone-verification
    ((:test-file "tests/book-of-ml-capstones.test.mjs")
     (:hard-shape-tests 10   :description "MSE loss · sigmoid · gradient step · matvec · softmax · positional encoding")
     (:passing            10)
     (:book-wide-fence-count 133 :description "every ``` fence across ch 1-16")
     (:passing-on-patched-runtime 76
      :note "chapters with authoring drift (typos like (list1 2 3) missing a space; some pseudo-code fences with math notation not Scheme) stay in scope for the Book-of-ML Wave 2 authoring lane running in parallel.")
     (:runtime-patches-verified-independently #t))

  :composition
    ((:composes-with "spec/CPU-SPEC-2026-07-19.slat"
      :how "IDE + book/tutor + cpu module all reference the same opcode numbers.")
     (:composes-with "lib/book/tutor.js"
      :how "reading-state hooks: (book-of-code/read N) → auto-log; (book-of-code/tutor N) → auto-progress-bar.")
     (:composes-with "book-of-ml lane a-parallel"
      :how "our patches make their capstones runnable; their re-authoring will drop the fence-eval error count from 57 → near 0.")
     (:composes-with "reading-state ↔ pair-programming"
      :how "pair events log via motoi/log-exchange!; tutor voice can reference 'yesterday you were stuck on backprop'."))

  :test-summary
    (:total-tests 588
     :new 76
     :failing 0
     :test-runs "npm test — full suite green")

  :needs-alfred
    ((:decision "vim/emacs mode is intentionally minimal (F2 + :explain in vim / M-e in emacs). Should Wave 3 embed CodeMirror for full keybind fidelity, or stay basic?")
     (:decision "the ghost-text overlay positions at the editor's top-left corner rather than exactly at the cursor. Full inline-cursor tracking wants a mirror-div technique — should Wave 3 do that?")
     (:decision "Book of ML fence-eval count is 76/133 — the runtime patches enable everything they can enable; the remaining 57 fails are all book-authoring drift (typos + illustrative fences). Should the Book-of-ML Wave 2 lane author against fence-eval as its acceptance gate?"))

  :marcus-cosign
    ((:signed "marcus")
     (:date   "2026-07-19")
     (:note   "Patches are R7RS-compliant additions or aliases; no compat contract violation. Reading state is human-editable SLAT so kids can see what they read. Pair mode stays opt-in — nothing surprises. All 588 tests pass. Ada's ML capstones now have the runtime substrate they need.")))
