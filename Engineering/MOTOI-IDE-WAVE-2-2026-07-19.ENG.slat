     (:feature "pink/mint/earth palette" :status "locked" :note "pink dominant, green mint, brown earth per Alfred 2026-07-17")
     (:feature "meta-awareness — read editor + selection" :status "present" :note "motoi/explain-selection + F2 wired to selection")
     (:feature "meta-awareness — add code" :status "present" :note "runSelectionOrAll + ghost-completion Tab-accept")
     (:feature "meta-awareness — teach IDE" :status "present" :note "book-of-code/tutor renders progress-bar-augmented preview"))

  :book-of-ml-cover-changes
    ((:removed "the 'vec/make double-wrap NaN' warning paragraph")
     (:removed "the geom/sin geom/cos substitution note")
