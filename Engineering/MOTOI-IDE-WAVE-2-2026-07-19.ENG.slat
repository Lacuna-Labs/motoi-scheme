    ((:file "lib/system/pair-programming.js"                    :status :authored :verbs 11)
     (:file "lib/system/reading-state.js"                       :status :authored :verbs 13)
     (:file "lib/math/matrix.js"                                :status :authored :verbs 14)
     (:file "src/base.js"                                       :status :patched  :patches ("map multi-arg" "for-each multi-arg"))
