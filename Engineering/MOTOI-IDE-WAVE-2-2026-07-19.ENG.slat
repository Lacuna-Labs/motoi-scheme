     (:file "src/ide-server.js"                                 :status :patched  :endpoints 9)
     (:file "lib/graphics/vec.js"                               :status :patched  :patches ("vec/make list-arg"))
     (:file "lib/graphics/geom.js"                              :status :patched  :patches ("math/sin math/cos math/tan math/atan math/asin math/acos math/atan2 aliases"))
     (:file "lib/book/tutor.js"                                 :status :patched  :patches ("progress bar in tutor voice" "reading-state hooks on read + block-run"))
     (:file "site/ide-assets/index.html"                        :status :patched)
     (:file "site/ide-assets/ide.js"                            :status :patched)
     (:file "site/ide-assets/ide.css"                           :status :patched)
     (:file "core/index.js"                                     :status :patched  :installers-added 4)
     (:file "scheme-books/book-of-ml/cover.book.slatl"          :status :patched  :change "papercut warnings removed")
     (:file "tests/base.test.mjs"                               :status :authored :tests 18)
     (:file "tests/reader.test.mjs"                             :status :authored :tests 16)
     (:file "tests/matrix.test.mjs"                             :status :authored :tests 14)
     (:file "tests/reading-state.test.mjs"                      :status :authored :tests 12)
     (:file "tests/pair-programming.test.mjs"                   :status :authored :tests 22)
     (:file "tests/book-of-ml-capstones.test.mjs"               :status :authored :tests 11)
     (:file "tests/tui/ide-server-wave-2.test.mjs"              :status :authored :tests 7)
     (:file "tests/wave-2-lib-loader.test.mjs"                  :status :patched  :change "installer count 44 → 49"))

  :runtime-patches
    ((:patch "vec/make list-arg"
      :file "lib/graphics/vec.js"
      :before "(vec/make (list 1 2 3)) → NaN"
      :after  "(vec/make (list 1 2 3)) → (1 2 3)"
      :backwards-compatible? #t
      :r7rs? "n/a — vec/make is Motoi-only")

     (:patch "map multi-arg"
      :file "src/base.js"
      :before "(map + xs ys) → error 'wrong number of args'"
      :after  "(map + xs ys) → pairwise sum"
      :backwards-compatible? #t
      :r7rs? "R7RS §6.10 — map/for-each SHALL accept multiple lists"
      :also-patched "for-each")

     (:patch "math/* trig aliases"
      :file "lib/graphics/geom.js"
      :before "(math/sin x) → unbound"
      :after  "(math/sin x) works; (geom/sin x) still works as alias"
      :backwards-compatible? #t
      :new-verbs ("math/sin" "math/cos" "math/tan" "math/atan2" "math/asin" "math/acos" "math/atan"))

     (:patch "scientific notation"
      :file "src/reader.js"
      :before "1e-5 → symbol 'Sym{name:1e-5}'"
      :after  "1e-5 → number 0.00001"
      :backwards-compatible? #t
      :r7rs? "R7RS §6.2 — the reader SHALL accept exponent notation on real numbers"))

  :new-verbs
    ((:namespace "motoi/pair-*"
      :verbs ("motoi/pair-on!" "motoi/pair-off!" "motoi/pair-mode?"
              "motoi/pair-set-mode!" "motoi/explain" "motoi/explain-selection"
              "motoi/refactor-suggest" "motoi/bug-spot"
              "motoi/ambient-complete" "motoi/pair-narrate!" "motoi/pair-state"))

     (:namespace "motoi/reading-state (+ bookmarks/highlights/log)"
      :verbs ("motoi/reading-state" "motoi/mark-read!" "motoi/mark-block-run!"
              "motoi/reading-progress" "motoi/bookmark!" "motoi/bookmarks"
              "motoi/bookmark-delete!" "motoi/highlight!" "motoi/highlights"
              "motoi/log-exchange!" "motoi/session-log"
              "motoi/reading-state/reset!" "motoi/reading-state/path"))

     (:namespace "matrix/*"
      :verbs ("matrix/make" "matrix/rows" "matrix/cols" "matrix/ref"
              "matrix/row" "matrix/col" "matrix/transpose" "matrix/identity"
              "matrix/zero" "matrix/scale" "matrix/add" "matrix/sub"
              "matrix/multiply" "matrix/matvec")))

  :ide-endpoints
    ((:method "POST" :path "/api/pair/mode"      :body "{mode: string}")
     (:method "GET"  :path "/api/pair/state"     :returns "{mode, last-narration, ...}")
     (:method "POST" :path "/api/pair/explain"   :body "{source: string}")
     (:method "POST" :path "/api/pair/complete"  :body "{prefix: string}")
     (:method "POST" :path "/api/pair/refactor"  :body "{source: string}")
     (:method "POST" :path "/api/pair/bug-spot"  :body "{source: string}")
     (:method "GET"  :path "/api/reading-state"  :returns "whole snapshot")
     (:method "GET"  :path "/api/reading-progress?book=code&n=1&total=N")
     (:method "POST" :path "/api/bookmark"       :body "{name, context}")
     (:method "POST" :path "/api/highlight"      :body "{text, context}"))

