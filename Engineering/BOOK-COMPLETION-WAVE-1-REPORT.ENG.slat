    :book-c-curator-flower-stories
      (:path "curator/scheme-books/book-of-flower-stories/"
       :was-empty "MANIFEST.slat existed with 30-story index; no stories authored"
       :files-authored 26  ;; 00-manifest + 00-outline + 16 chapters + 8 appendices
       :existing-file-preserved "MANIFEST.slat (original 30-story index) untouched — kept as reference/aspirational"
       :total-files 27
       :word-count 28968
       :target 60000
       :under-by 31032
       :status "STRUCTURE-COMPLETE COVERAGE-COMPLETE WORDS-UNDER"
       :note "Story-style forced shorter word counts. Each story is a full
              short story (1200-2500 words). 16 stories authored — one per
              chapter — following manifest cast (cherry blossom Sakura,
              daffodil, iris, hosta, dahlia, weed, wildflowers, bee,
              sparrow, rain, wind, sun, snow, gardener, child, old man,
