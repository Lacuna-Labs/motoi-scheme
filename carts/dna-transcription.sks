;; dna-transcription.sks
;; Motoi Cart — Wave 1
;;
;; (cart
;;   :name            "dna-transcription"
;;   :category        :science
;;   :sub-category    :biology
;;   :audience        :hobbyist
;;   :complexity      2
;;   :runtime-tier    :runs-on-core
;;   :one-line        "DNA → mRNA → amino-acid chain; type a strand, watch it translate."
;;   :verbs-used      ("display" "newline" "for-each" "range" "string-ref"
;;                     "string-length" "string-append" "assoc" "quotient"
;;                     "modulo")
;;   :inspiration     "The codon table your biology teacher hand-drew.")
;;
;; HOW TO RUN:
;;   motoi run carts/dna-transcription.sks
;;
;; Pipeline:
;;   1. DNA:    the template strand (letters A T C G)
;;   2. mRNA:   each letter maps A->U, T->A, C->G, G->C (transcription)
;;   3. Codons: mRNA read three letters at a time
;;   4. Protein: each codon maps to an amino acid (translation)
;;
;; Edit STRANDS at the bottom to try your own sequences.

;; ------- DNA -> mRNA transcription -------

(define (transcribe-base c)
  (cond
    ((string=? c "A") "U")
    ((string=? c "T") "A")
    ((string=? c "C") "G")
    ((string=? c "G") "C")
    (else c)))

(define (transcribe-strand dna)
  (let loop ((i 0) (acc ""))
    (if (>= i (string-length dna)) acc
        (loop (+ i 1)
              (string-append acc (transcribe-base (string-ref dna i)))))))

;; ------- codon table (mRNA triplets -> amino acid) -------
;; A compressed but real subset of the standard genetic code. Stop = *.

(define CODON-TABLE
  '(("AUG" "Met/START")
    ("UUU" "Phe") ("UUC" "Phe")
    ("UUA" "Leu") ("UUG" "Leu") ("CUU" "Leu") ("CUC" "Leu")
    ("CUA" "Leu") ("CUG" "Leu")
    ("AUU" "Ile") ("AUC" "Ile") ("AUA" "Ile")
    ("GUU" "Val") ("GUC" "Val") ("GUA" "Val") ("GUG" "Val")
    ("UCU" "Ser") ("UCC" "Ser") ("UCA" "Ser") ("UCG" "Ser")
    ("AGU" "Ser") ("AGC" "Ser")
    ("CCU" "Pro") ("CCC" "Pro") ("CCA" "Pro") ("CCG" "Pro")
    ("ACU" "Thr") ("ACC" "Thr") ("ACA" "Thr") ("ACG" "Thr")
    ("GCU" "Ala") ("GCC" "Ala") ("GCA" "Ala") ("GCG" "Ala")
    ("UAU" "Tyr") ("UAC" "Tyr")
    ("CAU" "His") ("CAC" "His")
    ("CAA" "Gln") ("CAG" "Gln")
    ("AAU" "Asn") ("AAC" "Asn")
    ("AAA" "Lys") ("AAG" "Lys")
    ("GAU" "Asp") ("GAC" "Asp")
    ("GAA" "Glu") ("GAG" "Glu")
    ("UGU" "Cys") ("UGC" "Cys")
    ("UGG" "Trp")
    ("CGU" "Arg") ("CGC" "Arg") ("CGA" "Arg") ("CGG" "Arg")
    ("AGA" "Arg") ("AGG" "Arg")
    ("GGU" "Gly") ("GGC" "Gly") ("GGA" "Gly") ("GGG" "Gly")
    ("UAA" "*STOP*") ("UAG" "*STOP*") ("UGA" "*STOP*")))

(define (codon->amino codon)
  (let ((pair (assoc codon CODON-TABLE)))
    (if pair (nth pair 1) "???")))

;; ------- split mRNA into codons -------

(define (codons mrna)
  (let loop ((i 0) (acc '()))
    (if (> (+ i 3) (string-length mrna))
        (reverse acc)
        (loop (+ i 3)
              (cons (string-append
                     (string-ref mrna i)
                     (string-ref mrna (+ i 1))
                     (string-ref mrna (+ i 2)))
                    acc)))))

;; ------- pretty print -------

(define (join-space xs)
  (cond ((null? xs) "")
        ((null? (cdr xs)) (car xs))
        (else (string-append (car xs) " " (join-space (cdr xs))))))

(define (transcribe-and-translate dna label)
  (display "----------------------------------------------------")
  (newline)
  (display "  ") (display label) (newline)
  (display "  DNA   : ") (display dna) (newline)
  (let* ((mrna (transcribe-strand dna))
         (codon-list (codons mrna))
         (protein (map codon->amino codon-list)))
    (display "  mRNA  : ") (display mrna) (newline)
    (display "  codons: ") (display (join-space codon-list)) (newline)
    (display "  amino : ")
    (display (join-space protein))
    (newline)
    (let ((stopped? (any (lambda (a) (string=? a "*STOP*")) protein)))
      (display "  stops?: ")
      (display (if stopped? "yes — translation halts at *STOP*"
                   "no  — chain continues past the strand"))
      (newline))))

;; ------- driver -------

(display "DNA TRANSCRIPTION + TRANSLATION")
(newline)
(display "  transcribes A->U, T->A, C->G, G->C, then reads codons in triplets")
(newline)
(newline)

(transcribe-and-translate "TACGTAATC" "example 1 — short strand")
(transcribe-and-translate "TACGGGAAACCCTTT" "example 2 — five codons")
(transcribe-and-translate "TACAAATTTGGGATC" "example 3 — contains a stop")
(transcribe-and-translate "TACCCCCCCCCCCCC" "example 4 — glycine chain")
