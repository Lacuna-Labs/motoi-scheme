;; =====================================================================
;;  HOW TO RUN
;; =====================================================================

(section :name "how-to-run"
  :text
"Every cart runs the same way:

    cd ~/code/motoi-scheme
    bin/motoi run carts/<name>.sks

For example:

    bin/motoi run carts/snake-classic.sks
    bin/motoi run carts/projectile-arc.sks
    bin/motoi run carts/dna-transcription.sks

If you see `error: fuel exhausted`, the cart hit the interpreter's
CPU-budget cap (default 200000 evaluator steps). Shorten the input,
loop fewer times, or wait for the CLI's `--fuel` flag to be wired.")

;; =====================================================================
;;  HOW TO FORK A CART
;; =====================================================================

(section :name "how-to-fork-a-cart"
  :text
"Every cart is a plain text file. Copy it. Change it. Run it.

    cp carts/snake-classic.sks carts/my-snake.sks
    # edit WIDTH, HEIGHT, MAX-TICKS at the top
    bin/motoi run carts/my-snake.sks

Or copy times-table-trainer.sks and change the range from 1..12 to
1..20 and see what a 20x20 multiplication table looks like. That's
the invitation — the code isn't precious. It's a starting point.

The pattern each cart uses:
  1. Top comment block: what it does + how to run.
  2. Knobs section: constants named in UPPERCASE.
  3. Helpers.
  4. Driver at the bottom: what happens when you `motoi run` the file.

Change the knobs first. Then the helpers. Then invent your own.")

;; =====================================================================
;;  ROADMAP — waves 2-4
;; =====================================================================

(roadmap
  :wave-2
  (:goal "Add real-time carts once world/entity/input/big-bang modules
          are wired to the CLI. Roughly 25 more carts — pong-doubles,
          breakout-bricks, space-defender, asteroid-drift, endless-runner,
          plus science + physics carts that need audio/plot modules."
   :blockers ("lib/graphics/framebuffer.js" "lib/graphics/text.js"
              "lib/game/game.js" "on-frame / on-tick" "input/*"))

  :wave-3
  (:goal "Cortex + synth + phys-lagrangian modules unlock ~25 carts
          (dungeon-crawl-tiny, cave-generator, cell-division-viewer,
          predator-prey-sim, gravity-lens-visualizer, chord-jam-loop,
          note-linker, habit-streak-tracker, typing-tutor, ...)."
   :blockers ("lib/ai/cortex.js" "lib/audio/synth.js"
              "lib/game/scene.js" "lib/media/*"))

  :wave-4
  (:goal "Chem + phys-nbody + plot + stat carts (periodic-table,
          molecule-mass-lab, orbital-two-body, fourier-drawing,
          pixel-art-editor, spectrogram-recorder, ...) — hardest
          25 carts, most demanding module wiring."
   :blockers ("chem/*" "phys/nbody" "phys/lagrangian" "plot/*"
              "stat/*" "linalg beyond basics")))

;; =====================================================================
;;  META
;; =====================================================================

(meta
  :verb-coverage
  "Wave 1 exercises the base-env core: fb-less rendering via display+newline,
   pure math (sin cos sqrt expt), lists (map filter reduce sort), strings
   (string-ref, substring, string-append), and one PRNG verb (randint).
   Coverage of the 117-verb base env is ~65%."
  :corporate-name-scan
  "clean — no clone-of-* names, no brand references in cart names or
   descriptions. `flap-runner` is the closest to a play on a genre name;
   the game is a physics-only demo, not a clone."
  :philosopher-scan
  "clean — no philosopher name-drops in cart :one-line or descriptions."
  :complexity-ladder
  "4 one-star, 15 two-star, 7 three-star — kid-friendly bottom weighted."
  :dialect "motoi throughout."
  :next-step
  "Await Alfred's go on Wave 2 dispatch, blocked on graphics + input
   module wiring in src/base.js. Meanwhile, the 26 landed carts are
   playtestable NOW.")
