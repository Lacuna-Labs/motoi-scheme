;; CATALOGUE.slat
;; The Motoi Cart Catalogue — Wave 1
;;
;; Alfred said: "Make the 100 carts. BEST FUN GAMES."
;; This catalogue tracks what's landed, what runs today, and what's on deck.
;;
;; Cross-reference: /Users/alfred/code/lacuna-labs/design-docs/architect-100-motoi-carts-2026-07-16.slat
;;                  for the full 100-cart roadmap.

(dialect :applies ("motoi") :note "Motoi carts — public, kid-facing, runnable.")

(catalogue
  :name             "Motoi Cart Catalogue"
  :wave             1
  :maintainer       "The Engineer"
  :date             "2026-07-16"
  :total-designed   100
  :landed-so-far    26
  :cart-file-ext    ".sks"
  :location         "motoi-scheme/carts/"
  :provenance       "Wave-1 authoring lane 2026-07-16 against the 117-verb base env.
                     Full lib module wiring lands in later runtime passes; every cart
                     in this catalogue runs on today's motoi CLI."
  :audience         ("kid" "hobbyist" "adult" "operator" "author")
  :training-eligible #t
  :confidentiality  "public")

;; =====================================================================
;;  PROLOGUE
;; =====================================================================

(section :name "prologue"
  :text
"What is this?
  Twenty-six small programs. Each fits in one file. Each does one thing.
  Each is meant to be read, run, and forked — take it, change it, run it again.

How to run one
  cd ~/code/motoi-scheme
  bin/motoi run carts/snake-classic.sks

How to fork one
  cp carts/snake-classic.sks carts/my-snake.sks
  vi carts/my-snake.sks               ;; edit the numbers at the top
  bin/motoi run carts/my-snake.sks    ;; run your version

Why so much text output?
  Today's motoi runtime is the plain interpreter: numbers, lists,
  strings, print. The graphics/game modules (framebuffer, sprites,
  input, big-bang, world/entity) are in lib/ but not yet wired to
  the CLI. Every cart in Wave 1 was authored against the 117 verbs
  live TODAY. When the module runtime lands, Wave 2 & 3 unlock the
  real-time carts (pong, breakout, asteroids, tank-duel, etc.).

Kid-facing invitation
  You can change any number in any file and run it again. Nothing
  breaks. The worst that happens is `error: fuel exhausted` — that
  means you asked for too many computations. Turn some number down
  and try again.")

;; =====================================================================
;;  CATEGORY INDEX
;; =====================================================================

(section :name "category-index"
  :counts
  ((:category :game    :landed 6  :total-wave-1 8)
   (:category :science :landed 5  :total-wave-1 5)
   (:category :physics :landed 5  :total-wave-1 5)
   (:category :utility :landed 10 :total-wave-1 7))
  :note
"Utility overshot the 7-cart target because most cart designs from
 Wave 1's utility list ran cleanly on today's core. Two Wave-1 games
 (snake, block-drop, match-three, flap-runner) landed as
 physics-only or scripted-demo variants — full interactivity waits
 on input/game-loop module wiring.")

;; =====================================================================
;;  AUDIENCE INDEX
;; =====================================================================

(section :name "audience-index"
  :by-audience
  ((:audience :kid
    :carts ("snake-classic" "block-drop" "match-three-jewels" "sokoban-boxes"
            "peg-solitaire" "memory-flip" "flap-runner" "reaction-race"
            "ph-scale-visualizer" "dna-transcription" "biome-explorer"
            "projectile-arc" "friction-race" "pendulum-simple" "tidal-forces"
            "fraction-visualizer" "times-table-trainer" "haiku-syllable-checker"))
   (:audience :hobbyist
    :carts ("gas-law-sandbox" "food-web-builder" "inclined-plane"
            "word-frequency-counter" "cipher-lab"))
   (:audience :adult
    :carts ("pomodoro-timer" "password-generator" "unit-converter"))))

;; =====================================================================
;;  RUNTIME-TIER INDEX
;; =====================================================================

(section :name "runtime-tier-index"
  :note
"Wave 1 is 100% runs-on-core. Every cart runs via `motoi run carts/<name>.sks`
 today with no module wiring, no imports, no external deps. Simulation +
 ASCII rendering; the graphics/input modules unlock Wave 2's real-time carts."
  :tiers
  ((:tier :runs-on-core                :count 26)
   (:tier :runs-on-core-plus-modules   :count 0)
   (:tier :requires-future-module      :count 0)))

;; =====================================================================
;;  COMPLEXITY INDEX  (1-star = tiny, 5-star = meaty)
;; =====================================================================

(section :name "complexity-index"
  :by-stars
  ((:stars 1 :carts ("password-generator" "friction-race" "reaction-race" "flap-runner"))
   (:stars 2 :carts ("times-table-trainer" "fraction-visualizer" "unit-converter"
                     "ph-scale-visualizer" "dna-transcription" "biome-explorer"
                     "projectile-arc" "pendulum-simple" "sokoban-boxes"
                     "peg-solitaire" "memory-flip" "haiku-syllable-checker"
                     "word-frequency-counter" "snake-classic" "pomodoro-timer"))
   (:stars 3 :carts ("gas-law-sandbox" "food-web-builder" "inclined-plane"
                     "tidal-forces" "cipher-lab" "block-drop" "match-three-jewels"))))

