;;; CROSS-REFS.slat — cross-graph edges from graph-of-science.
;;; Every (cross-edge ...) record links a science node to a
;;; node in another graph. Resolution failures return
;;; :ref-unresolved gracefully.

(dialect :applies ("motoi" "sakura"))

(header
  :edge-types
  ((:type :first-described-by
    :from-graph "graph-of-science"
    :to-graph   "graph-of-person"
    :semantics  "the person(s) first credited with describing this concept")
   (:type :hosted-at
    :from-graph "graph-of-science"
    :to-graph   "graph-of-institution"
    :semantics  "institution where discovery / formalization work was hosted")
   (:type :first-described-in
    :from-graph "graph-of-science"
    :to-graph   "graph-of-cultural-work"
    :semantics  "the paper / book / lecture that first cleanly described the concept")
   (:type :appears-in-event
    :from-graph "graph-of-science"
    :to-graph   "graph-of-event"
    :semantics  "historical event where this concept was pivotal")
   (:type :in-place
    :from-graph "graph-of-science"
    :to-graph   "graph-of-world"
    :semantics  "geographic place uniquely associated with this concept")
   (:type :used-in-store
    :from-graph "graph-of-science"
    :to-graph   "graph-of-store"
    :semantics  "store-object category where this science concept appears as raw material or working principle"))
  :weight-scale "0.0 (peripheral) .. 1.0 (defining)"
  :cross-edge-count 494)

