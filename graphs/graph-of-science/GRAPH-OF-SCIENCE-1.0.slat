(science
  :id "science-doppler-effect"
  :canonical "Doppler Effect"
  :synonyms ("Doppler shift" "DOPPLER EFFECT" "doppler effect" "Doppler Effect (concept)")
  :discipline (:physics)
  :kind (:phenomenon :law)
  :heritage-narrative "The apparent frequency of a wave changes when the source and observer are in relative motion; approaching bodies appear blue-shifted, receding ones red-shifted."
  :everyday-example "An ambulance siren sounds higher-pitched as it approaches and lower as it recedes."
  :mathematical-form "f_observed = f_source · (v ± v_o) / (v ∓ v_s)"
  :first-described-by-ref ((:ref-graph "graph-of-person" :ref-id "person-doppler-christian"))
  :first-described-in-year 1842
  :applies-in (:classical-regime :astrophysical :everyday)
