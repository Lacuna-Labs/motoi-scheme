(science
  :id "science-snells-law"
  :canonical "Snell's Law"
  :synonyms ("Snell-Descartes law" "law of refraction" "SNELL'S LAW" "snell's law" "Snells Law")
  :discipline (:physics)
  :kind (:law)
  :heritage-narrative "When light passes from one medium to another the ratio of the sines of the incident and refracted angles equals the inverse ratio of refractive indices."
  :everyday-example "A straight straw in a glass of water looks bent at the water line."
  :mathematical-form "n₁·sin(θ₁) = n₂·sin(θ₂)"
  :first-described-by-ref ((:ref-graph "graph-of-person" :ref-id "person-snell-willebrord"))
  :first-described-in-year 1621
  :applies-in (:classical-regime :everyday :engineering)
  :subsumed-by "science-optics"
  :related-to-ref ((:ref-id "science-refraction" :weight 0.95) (:ref-id "science-refractive-index" :weight 0.95) (:ref-id "science-fermats-principle" :weight 0.85))
  :provenance ((:source "wikidata" :qid "Q170955") (:source "wikipedia" :url "https://en.wikipedia.org/wiki/Snell's_law") (:source "wikipedia" :url "https://en.wikipedia.org/wiki/Snells_Law") (:merged_from "science-snells-law") (:authored-by "graph-of-science-lane") (:date "2026-07-16") (:book-version "1.0.0"))
