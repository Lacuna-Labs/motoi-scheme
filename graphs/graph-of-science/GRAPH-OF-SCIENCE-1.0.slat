  :id "science-newtons-first-law"
  :canonical "Newton's First Law of Motion"
  :synonyms ("law of inertia" "first law of motion" "Newton I" "prima lex" "NEWTON'S FIRST LAW OF MOTION" "newton's first law of motion" "Newtons First Law of Motion")
  :discipline (:physics)
