(science
  :id "science-closure"
  :canonical "Closure (computer programming)"
  :synonyms ("closure" "CLOSURE" "lexical closure" "function closure")
  :discipline (:computing :programming-languages)
  :kind (:abstraction)
  :heritage-narrative "A function paired with an environment of variable bindings — the function captures its lexical scope so it can be invoked outside that scope while still referring to the captured variables."
  :first-described-by-ref "person-landin-peter"
  :first-described-in-year 1964
  :provenance ((:source "wikipedia" :url "https://en.wikipedia.org/wiki/Closure_(computer_programming)")
