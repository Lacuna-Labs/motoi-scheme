(science
  :id "science-tail-call-optimization"
  :canonical "Tail call"
  :synonyms ("tail call" "tail-call optimization" "TCO" "proper tail calls")
  :discipline (:computing :programming-languages)
  :kind (:optimization :abstraction)
  :heritage-narrative "A function call performed as the last action of a procedure; a language with proper tail-call handling reuses the calling procedure's stack frame, allowing recursion to run in constant space."
  :provenance ((:source "wikipedia" :url "https://en.wikipedia.org/wiki/Tail_call")
               (:authored-by "lane-2026-07-17-motoi-substrate"))
