(science
  :id "science-quantum-entanglement"
  :canonical "Quantum entanglement"
  :synonyms ("entanglement" "quantum entanglement" "QUANTUM ENTANGLEMENT")
  :discipline (:physics :quantum)
  :kind (:phenomenon)
  :heritage-narrative "A quantum phenomenon in which the states of two or more particles are correlated in ways that cannot be explained by classical physics; measurements on one particle instantly determine the state of the other."
  :provenance ((:source "wikipedia" :url "https://en.wikipedia.org/wiki/Quantum_entanglement")
               (:authored-by "lane-2026-07-17-motoi-substrate"))
  :dialect "motoi" :audience :any :content-rating :G
  :training-eligible #t :confidentiality :public)

(science
  :id "science-quantum-superposition"
  :canonical "Quantum superposition"
  :synonyms ("superposition" "quantum superposition" "SUPERPOSITION")
  :discipline (:physics :quantum)
  :kind (:principle)
  :heritage-narrative "The principle that any two (or more) quantum states can be added together, or superposed, to produce another valid quantum state; a qubit can be in a linear combination of |0⟩ and |1⟩ simultaneously until measured."
  :provenance ((:source "wikipedia" :url "https://en.wikipedia.org/wiki/Quantum_superposition")
               (:authored-by "lane-2026-07-17-motoi-substrate"))
  :dialect "motoi" :audience :any :content-rating :G
  :training-eligible #t :confidentiality :public)

(science
  :id "science-decoherence"
  :canonical "Quantum decoherence"
  :synonyms ("decoherence" "quantum decoherence" "DECOHERENCE")
  :discipline (:physics :quantum)
  :kind (:phenomenon)
  :heritage-narrative "Loss of quantum coherence when a system interacts with its environment; a major obstacle to building large-scale quantum computers."
  :provenance ((:source "wikipedia" :url "https://en.wikipedia.org/wiki/Quantum_decoherence")
