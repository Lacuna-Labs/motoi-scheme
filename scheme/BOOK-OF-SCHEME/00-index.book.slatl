  :prose
"; Grammar via philosophical sentence dissection
; Written 2026-07-13
;
; Format per pair:
;   :sentence — real PD sentence
;   :source — attribution
;   :grammar — noun/verb/mod analysis
;   :scheme — S-expression representation
;   :lens — one of: Grice/Wittgenstein/Searle/Peirce/Derrida
;   :note — small close-reading
;
; This batch: 100 dissections. Scaffold for extension to 1500.
; Sources: Shakespeare (PD), Grimms (PD), Aesop (PD),
;   George MacDonald (PD), E. Nesbit (PD), Sei Shōnagon (PD via Waley).

(grammar-dissections-index
  :batch 1
  :count 100
  :files
  (\"01-shakespeare.slat\"     ; 20 pairs
   \"02-grimms.slat\"          ; 20 pairs
   \"03-aesop.slat\"           ; 20 pairs
   \"04-macdonald-nesbit.slat\" ; 20 pairs
   \"05-sei-shonagon.slat\"    ; 20 pairs
   )
  :doctrine
  (\"no conjured themes\"
   \"prefer plain text over invention\"
   \"philosopher names permitted in analysis frame only\"))
")
