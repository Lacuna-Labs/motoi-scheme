; tests/vectors.slat — shared round-trip fixtures for slat bindings.
;
; Every non-comment line is ONE canonical slat form. Both the Python
; binding (bindings/python/slat/) and JS binding (bindings/js/slat.js)
; parse each line, emit it back, and reparse — the reparsed value must
; deep-equal the first parse.
;
; Coverage: form heads with keyword args, nested lists, strings with
; escape sequences, numeric literals (int/float/negative/scientific),
; booleans, nil, rationals, characters. Keep lines short and single-line.
;
; Created 2026-07-17 to unblock bindings/python/tests/test_slat.py.

(motoi :version "0.1.0" :verbs 335)
(pair :from "who" :to "why" :type :test)
(nested (a b (c d)) :k :v)
(strings "hello world" "tab\there" "newline\nhere")
(nums :int 1 :neg -3 :float 2.5 :sci -1.5e2)
(bools :yes #t :no #f)
(nils :bare nil :in-list (a nil b))
(rats :half 1/2 :neg -3/4)
(deep :outer (a :inner (b :leaf 42)))
(escape :quote "she said \"hi\"" :back "path\\to")
(mixed :flag #t :items (1 2 3) :name "kit")
(empty :list () :none nil)
(kw-only :a :sym-a :b :sym-b :c :sym-c)
(record :id "r-001" :ts 1721000000 :kind :log :from "zane" :to "alfred")
