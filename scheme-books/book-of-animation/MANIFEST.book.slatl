;; MANIFEST.book.slatl
;; Book of Animation — canonical book-level manifest
;; Authored 2026-07-15 by nighttime lane S1
;; Enforces 16-chapter invariant + training-ready tagging

(book-manifest
  :book              "Book of Animation"
  :slug              "book-of-animation"
  :dialect           "motoi"
  :audience          "kid"
  :arc               "kid-teaching"
  :chapter-count     16
  :appendix-count    5
  :status            "authored"
  :date-authored     "2026-07-15"
  :training-eligible #t
  :confidentiality   "public"
  :voice             "teaching"
  ;; Scoured 2026-07-17 (Jess): dialect -> motoi, voice de-personified,
  ;; reserved-for-claude appendix entries B/C dropped (files archived).
  :sicp-bar          #t
  :chapters
    ((:number  1 :file "ch01-surface.book.slatl"          :title "The Surface"       :arc "kid-teaching")
     (:number  2 :file "ch02-language.book.slatl"         :title "The Language"      :arc "kid-teaching")
     (:number  3 :file "ch03-flower.book.slatl"           :title "The Flower"        :arc "kid-teaching")
     (:number  4 :file "ch04-vectors.book.slatl"          :title "Vectors"           :arc "kid-teaching")
     (:number  5 :file "ch05-forces.book.slatl"           :title "Forces"            :arc "kid-teaching")
     (:number  6 :file "ch06-oscillation.book.slatl"      :title "Oscillation"       :arc "kid-teaching")
     (:number  7 :file "ch07-particles.book.slatl"        :title "Particles"         :arc "kid-teaching")
     (:number  8 :file "ch08-bodies.book.slatl"           :title "Bodies"            :arc "kid-teaching")
     (:number  9 :file "ch09-locomotion.book.slatl"       :title "Locomotion"        :arc "kid-teaching")
     (:number 10 :file "ch10-steering.book.slatl"         :title "Steering"          :arc "kid-teaching")
     (:number 11 :file "ch11-flocking.book.slatl"         :title "Flocking"          :arc "kid-teaching")
     (:number 12 :file "ch12-wayfinding.book.slatl"       :title "Wayfinding"        :arc "kid-teaching")
     (:number 13 :file "ch13-scenes.book.slatl"           :title "Scenes"            :arc "kid-teaching")
     (:number 14 :file "ch14-camera.book.slatl"           :title "The Camera"        :arc "kid-teaching")
     (:number 15 :file "ch15-director.book.slatl"         :title "The Director"      :arc "kid-teaching")
     (:number 16 :file "ch16-living-garden.book.slatl"    :title "The Living Garden" :arc "kid-teaching"))

  :appendices
    ((:letter "A" :file "appendix-07-norman-mclaren.book.slatl"           :title "Norman McLaren — animation without a camera")
     ;; Appendix B/C reserved-for-claude placeholders archived 2026-07-17 (Jess).
     (:letter "D" :file "appendix-d-emoji-and-text.book.slatl"              :title "Animating Emoji, Text, and Composed Motion" :status "authored-2026-07-16")
     (:letter "X" :file "appendix-x-emoji-easing-cheatsheet.book.slatl"      :title "Emoji + Easing Cheat-Sheet" :status "authored-2026-07-16" :mirrors "book-of-motion/appendix-j-emoji-easing-cheatsheet.book.slatl"))

  :provenance
    (:merged-from ()
     :source-path "book-of-animation/"
     :notes "ch17/ch18 originally named as chapters are RESTRUCTURED as appendices B/C to hold the 16-chapter invariant. Files remain in place per no-deletes; appendix status recorded here.")

  :reading-order
    ("Start with ch01 to establish the surface and time."
     "Chapters 4-8 build the physics vocabulary vector-by-vector."
     "Chapters 9-12 add agency: things that move themselves."
     "Chapters 13-16 turn a garden of moving things into a scene with a director."
     "Appendices are optional wanderings.")

  :related
    (book-of-hellosurface   ;; the surface Animation paints onto
     book-of-instruments    ;; sound and motion often compose
     book-of-flower-stories ;; the flower as protagonist
     book-of-games-preserved)) ;; motion in the service of play
