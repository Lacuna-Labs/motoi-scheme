(chapter
  :book "Book of R7RS Recipes"
  :chapter-number 0
  :title "Cover — what this book is and how to read it"
  :audience "kid-and-adult operators"
  :dialect "motoi"
  :voice "motoi-copilot"
  :training-eligible #t
  :confidentiality "public"
  :provenance
    (:authored-at "2026-07-18"
     :sources ((:reference "MOTOI-SCHEME-REFERENCE.slat" :section "Appendix Z"
                :verbs (define-record-type guard raise make-hash-table hash-table-ref
                        string-split string-trim char-alphabetic? make-bytevector
