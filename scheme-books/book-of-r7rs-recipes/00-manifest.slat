(book-manifest
  :book             "Book of R7RS Recipes"
  :short-name       "book-of-r7rs-recipes"
  :chapter-count    9
  :audience         "kid-and-adult operators, Motoi copilot"
  :dialect          "motoi"
  :voice            "motoi-copilot"
  :training-eligible #t
  :confidentiality  "public"
  :date-created     "2026-07-18"
  :provenance
    ((:authored-at "2026-07-18"
      :authored-by "ada motoi-4.0 example-coverage lane"
      :edit-source "MOTOI-4.0-COVERAGE-FILL-EXECUTION-2026-07-18"
      :sources
        ((:reference "scheme/MOTOI-SCHEME-REFERENCE.slat" :scope "Appendix Z R7RS-small + SRFI-1/13/125 additions")
         (:doc "engineering/MOTOI-SCHEME-FINALIZATION-2026-07-18.ENG.slat" :scope "Zane's finalization audit — the 120-verb FILL PASS")
         (:code "src/r7rs-completions.js" :scope "canonical implementation — semantics ground truth")
         (:standard "R7RS-small" :sections "§4.2.4 §4.2.5 §5.5 §6.2 §6.6 §6.7 §6.8 §6.9 §6.10 §6.11")
         (:srfi "SRFI-1" :scope "list library — iota, fold, partition, filter-map, etc.")
         (:srfi "SRFI-13" :scope "string library — string-split, string-join, string-trim, etc.")
         (:srfi "SRFI-125" :scope "hash tables — make-hash-table, hash-table-ref/set!, etc.")
         (:doctrine "project_no_contaminants_provenance_rule_2026_07_17"
          :scope "no LLM invention; every verb traces to R7RS or SRFI; every recipe authored under intent")))
  :scope
"The Book of R7RS Recipes teaches the R7RS-small standard library +
the common SRFI-1/13/125 conveniences a working Scheme author reaches
for every day. Each chapter takes one FAMILY of verbs — records,
exceptions, hash tables, strings, characters, bytevectors, string
ports, the numeric tower, and lazy/iteration forms — and walks from
nothing to something. Every line of code is a real Motoi verb from
Appendix Z of MOTOI-SCHEME-REFERENCE.slat.

The book was authored for the Motoi 4.0 example-coverage lane: Mk D
of Motoi 3.5 showed verb-recall crashing from 62% to 34% because
safety density crowded out verb density. Alfred said to lift the
Scheme content back up. The 120 Appendix Z additions had been landed
into the reference thin on examples — this book fills that gap with
worked recipes so Motoi 4.0 can be trained on real usage of every
verb, not just names."
  :chapters
    ((:number 1 :title "Records — define-record-type and the shape of a struct")
     (:number 2 :title "Exceptions — guard, raise, and staying alive when things break")
     (:number 3 :title "Hash Tables — make-hash-table and the joy of lookup")
     (:number 4 :title "The String Library — split, join, trim, and everything you meant to say")
     (:number 5 :title "Character Predicates — char-alphabetic?, char-upcase, and the ASCII neighborhood")
     (:number 6 :title "Bytevectors — the raw byte and when you actually need one")
     (:number 7 :title "String Ports — capturing output and replaying input")
     (:number 8 :title "The Numeric Tower — exact, inexact, and the story of one-half")
     (:number 9 :title "Lazy and Iteration — delay, force, do, and doing something many times"))
  :composes-with
    ((:doctrine "project_no_contaminants_provenance_rule_2026_07_17")
     (:doctrine "project_motoi_personality_2026_07_17")
     (:doctrine "project_motoi_is_the_new_speak_and_spell_2026_07_17")
     (:doctrine "project_sakura_scheme_lock_post_audit_2026_07_18")
     (:book "book-of-sick-composition" :note "the model for chapter shape: overview → problems → capstone")
     (:book "book-of-composition")
     (:book "book-of-scheme")))
