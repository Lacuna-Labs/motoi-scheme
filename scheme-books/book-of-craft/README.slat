;;; README.slat — Book Of Craft · folder README
;;;
;;; This file lives at the root of the book-of-craft/ folder so any reader
;;; (human, LLM, Rosetta, GitHub visitor) can figure out what this book IS
;;; and how to use it. Same pattern as every other book folder in Motoi.
;;; Pure SLAT — Rosetta renders it to Markdown/HTML when it walks the tree.

(dialect :applies ("motoi") :note "Folder README for book-of-craft.")

(readme
  :name          "book-of-craft-readme"
  :folder        "scheme-books/book-of-craft/"
  :book-title    "Book Of Craft"
  :book-kind     "scheme-book"
  :written       "2026-07-19"
  :for           ("human-reader" "motoi-copilot-training" "motoi-copilot-inference"
                  "sakura-training" "rosetta-render-target" "returning-collaborator")
  :training-eligible #t
  :confidentiality "public"

  :what-this-is
  "This folder is a book — a chapter-based teaching text for Motoi Scheme
   that is meant to be read by humans AND used as training data for LLMs.
   The book teaches a specific area of the language via runnable Scheme
   examples and prose. Each chapter is a .book.slatl file."

  :how-to-use
  ("Read MANIFEST.slat first to see the chapter order + purpose"
   "Chapters are named NN-slug.book.slatl and are meant to be read in order"
   "Every code block runs through ./bin/motoi — verify with runbin if unsure"
   "Use ,help at the REPL to inspect verbs the book introduces")

  :what-is-in-here
  ("Numbered chapter files (NN-slug.book.slatl or ch NN)"
   "Appendix files (appendix-X-slug.book.slatl) for supplementary material"
   "MANIFEST.slat — the machine-readable index"
   "This README.slat — folder-level orientation")

  :the-rules
  "Chapter invariant: canonical books carry 16 chapters. Overflow becomes
   appendices (letter-indexed). Every book: MANIFEST.slat + README.slat +
   NN-slug.book.slatl chapters. See scheme-books/RULES.slat for the full
   collection-level doctrine."

  :for-rosetta
  "This folder is a book. Detect via: this README.slat + MANIFEST + numbered
   chapters. Render README as landing page, MANIFEST as TOC, each chapter as
   its own page. Cross-link via :name across chapters."

  :format-lock
  "This README pattern is the SAME pattern in every book folder in Motoi
   and Sakura. Same five sections: what-this-is · how-to-use · what-is-in-
   here · the-rules · for-Rosetta. Do not drift.")
