         (t-straight (math/pow (/ (* 2 (math/pow (+ (* h h) (* L L)) 0.5))
                                  (* 9.8 (/ h (math/pow (+ (* h h) (* L L)) 0.5))))
                               0.5))
         (t-brach (curve/descent-time h)))
    (list 'straight-line-time t-straight
          'brachistochrone-time t-brach)))
```

