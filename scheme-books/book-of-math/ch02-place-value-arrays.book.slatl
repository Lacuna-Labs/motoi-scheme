### Example 31: Labeling Each Row's Count

<!-- BUILD: Draw a 4×5 array; beside each row, print how many dots are in that row (always 5). -->

```scheme
(define rows 4)
(define cols 5)

(display \"Each row has \")
(display cols)
(display \" dots:\")
(newline)

(let loop ((r 0))
  (if (< r rows)
      (begin
        (display \"Row \")
        (display r)
        (display \": \")
        (display cols)
        (display \" dots\")
        (newline)
        (loop (+ r 1)))))

(define (make-grid r c)
  (let loop-r ((row 0) (acc '()))
    (if (>= row r)
        acc
        (let loop-c ((col 0) (acc2 acc))
          (if (>= col c)
              (loop-r (+ row 1) acc2)
              (loop-c (+ col 1) (cons (list (* col 25) (* row 25)) acc2)))))))

(define points (make-grid rows cols))
(plot/scatter points
              '((title \"4×5 Array with Row Labels\")
                (x-label \"column\")
                (y-label \"row\")
                (width 180)
                (height 150)))
```

[VISUAL: A 4×5 grid of dots; printed output listing \"Row 0: 5 dots\", \"Row 1: 5 dots\", ..., \"Row 3: 5 dots\".]

