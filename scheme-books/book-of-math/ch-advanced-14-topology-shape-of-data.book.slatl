(define cloud (list (list 0 0) (list 3 0) (list 1.5 1.5)))

(define rips-small (topo/vietoris-rips cloud 2.0))
(define rips-large (topo/vietoris-rips cloud 4.0))

(list \"r=2.0\" (topo/f-vector rips-small)
