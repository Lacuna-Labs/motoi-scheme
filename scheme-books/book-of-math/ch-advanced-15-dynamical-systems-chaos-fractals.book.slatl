  (let loop ((x x0) (sum 0) (i 0))
    (if (>= i n)
        (/ sum n)
        (let ((deriv-val (df x)))
          (loop (f x)
                (+ sum (math/log (abs deriv-val)))
                (+ i 1))))))

(define (logistic r)
  (lambda (x) (* r x (- 1 x))))

(define (logistic-deriv r)
  (lambda (x) (* r (- 1 (* 2 x)))))

