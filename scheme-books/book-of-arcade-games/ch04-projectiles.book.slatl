  (on-frame
   (lambda ()
     (when (input/down? 'up)   (set! angle-deg (min 89 (+ angle-deg 1))))
     (when (input/down? 'down) (set! angle-deg (max  1 (- angle-deg 1))))
     (when (input/pressed? 'a)
