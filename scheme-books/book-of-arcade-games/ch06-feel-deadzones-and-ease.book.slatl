"(define ship-angle 0)
(define rot-vel 0)
(define thrust-charge 0)
(define (feel-anchor)
  (world/reset!)
  (let ((ship (world/spawn 'ship 160 120)))
    (entity/shape! ship 'triangle 12)
    (entity/drag! ship 0.01)
    (on-frame
     (lambda ()
       (cond
         ((input/down? 'left)  (set! rot-vel (max -0.08 (- rot-vel 0.01))))
         ((input/down? 'right) (set! rot-vel (min  0.08 (+ rot-vel 0.01))))
         (else (set! rot-vel (* rot-vel 0.85))))
       (set! ship-angle (+ ship-angle rot-vel))
       (if (input/down? 'a)
           (set! thrust-charge (min 1.0 (+ thrust-charge 0.08)))
           (set! thrust-charge (* thrust-charge 0.90)))
       (when (> thrust-charge 0.02)
         (let ((vx (car (entity/vel ship)))
               (vy (cadr (entity/vel ship)))
               (thrust (* 0.20 (tick/ease thrust-charge))))
           (entity/set-vel! ship
                            (+ vx (* thrust (geom/cos ship-angle)))
                            (+ vy (* thrust (geom/sin ship-angle))))))
       (world/step)
       (world/camera-follow! ship 0.08 40 30)
       (paint-clear)
       (paint-cell 'ship (entity/x ship) (entity/y ship) 12 12)))))
(big-bang feel-anchor)")
