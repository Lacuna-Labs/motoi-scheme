  (world/gravity! 0 0.5)
  (world/floor! 240)
  (let ((ball (world/spawn 'ball 160 40)))
    (entity/bounce! ball 0.85)
    (entity/shape! ball 'circle 8)
    (on-frame
     (lambda ()
       (world/step)
       (paint-clear)
       (paint-cell 'ball (entity/x ball) (entity/y ball) 8 8)))))
(big-bang bouncing-ball-anchor)")
