## 8. Snake (adapted)

Grid snake — turn to grow.

```scheme
(define snake-cells '((5 5) (4 5) (3 5)))
(define snake-dir '(1 0))
(define (snake)
  (world/reset!)
  (on-frame
   (lambda ()
     (when (input/pressed? 'up)    (set! snake-dir '(0 -1)))
     (when (input/pressed? 'down)  (set! snake-dir '(0 1)))
     (when (input/pressed? 'left)  (set! snake-dir '(-1 0)))
     (when (input/pressed? 'right) (set! snake-dir '(1 0)))
     (when (= (modulo (world/frame) 10) 0)
       (let* ((head (car snake-cells))
              (new-head (list (+ (car head) (car snake-dir))
                              (+ (cadr head) (cadr snake-dir)))))
         (set! snake-cells (cons new-head (reverse (cdr (reverse snake-cells)))))))
     (paint-clear)
     (for-each (lambda (cell)
                 (paint-cell 'snake (* (car cell) 8) (* (cadr cell) 8) 8 8))
               snake-cells))))
(big-bang snake)
```

