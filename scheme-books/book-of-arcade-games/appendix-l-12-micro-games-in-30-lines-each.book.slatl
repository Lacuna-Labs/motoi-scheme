## 7. Coin-grab (chapter 11)

Grab coins in 30 seconds.

```scheme
(define sc 0)
(define (coin-grab)
  (world/reset!)
  (let ((p (world/spawn 'player 160 120)))
    (entity/shape! p 'triangle 8) (entity/solid! p #t)
    (let loop ((i 0))
      (when (< i 20)
        (let ((c (world/spawn 'coin (modulo (* i 47) 300)
                              (modulo (* i 71) 200))))
          (entity/shape! c 'circle 5) (entity/sensor! c #t))
        (loop (+ i 1))))
    (on-frame
     (lambda ()
       (when (input/down? 'left)  (entity/move! p -3 0))
       (when (input/down? 'right) (entity/move! p 3 0))
       (when (input/down? 'up)    (entity/move! p 0 -3))
       (when (input/down? 'down)  (entity/move! p 0 3))
       (world/step)
       (for-each (lambda (pair)
                   (let ((a (car pair)) (b (cadr pair)))
                     (let ((c (cond ((eq? (entity/kind a) 'coin) a)
                                    ((eq? (entity/kind b) 'coin) b)
                                    (else #f))))
                       (when (and c (entity/alive? c))
                         (entity/despawn! c) (set! sc (+ sc 1))))))
                 (world/collisions))
       (paint-clear)
       (world/each 'coin (lambda (c) (paint-cell 'coin (entity/x c) (entity/y c) 5 5)))
       (paint-cell 'player (entity/x p) (entity/y p) 8 8)
       (paint-text (string-append \"Coins: \" (number->string sc)) 10 10)))))
(big-bang coin-grab)
```

