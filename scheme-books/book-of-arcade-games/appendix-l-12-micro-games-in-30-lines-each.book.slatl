"Twelve complete, playable, tiny games. Each fits on one screen.
Each teaches one thing. Read one, run it, mutate it. Then read the
next.

None of these are sketches. All run end to end. If you want to skip
the whole book and just play, read this appendix front to back.

---

## 1. Rainstorm (chapter 1)

Balls fall from the sky and pile on the floor.

```scheme
(define (rainstorm)
  (world/reset!)
  (world/gravity! 0 0.4)
  (world/floor! 240)
  (let loop ((i 0))
    (when (< i 40)
      (let ((b (world/spawn 'ball (+ 20 (* i 8)) 20)))
        (entity/bounce! b 0.7)
        (entity/shape! b 'circle 5))
      (loop (+ i 1))))
  (on-frame
   (lambda ()
     (world/step)
     (paint-clear)
     (world/each 'ball
                 (lambda (b) (paint-cell 'ball (entity/x b) (entity/y b) 5 5))))))
(big-bang rainstorm)
```

---

## 2. Pong (chapter 2 + 15)

Two paddles, one ball, endless.

```scheme
(define (pong)
  (world/reset!)
  (let ((p1 (world/spawn 'p1 20 120)) (p2 (world/spawn 'p2 300 120))
        (ball (world/spawn 'ball 160 120)))
    (entity/shape! p1 'rect 4 30) (entity/shape! p2 'rect 4 30)
    (entity/shape! ball 'circle 4)
    (entity/solid! p1 #t) (entity/solid! p2 #t) (entity/solid! ball #t)
    (entity/bounce! ball 1)
    (entity/set-vel! ball 3 2)
    (on-frame
     (lambda ()
       (when (input/down? 'left)  (entity/move! p1 0 -3))
       (when (input/down? 'right) (entity/move! p1 0 3))
       (when (input/down? 'up)    (entity/move! p2 0 -3))
       (when (input/down? 'down)  (entity/move! p2 0 3))
       (world/step)
       (let ((by (entity/y ball)) (vy (cadr (entity/vel ball))))
         (when (and (< by 5) (< vy 0))
           (entity/set-vel! ball (car (entity/vel ball)) (- vy)))
         (when (and (> by 235) (> vy 0))
           (entity/set-vel! ball (car (entity/vel ball)) (- vy))))
       (paint-clear)
       (paint-cell 'p1 (entity/x p1) (entity/y p1) 4 30)
       (paint-cell 'p2 (entity/x p2) (entity/y p2) 4 30)
       (paint-cell 'ball (entity/x ball) (entity/y ball) 4 4)))))
(big-bang pong)
```

---

## 3. Asteroids-lite (chapter 3)

Ship in space with wrap.

```scheme
(define ang 0)
(define (asteroids-lite)
  (world/reset!)
  (let ((s (world/spawn 'ship 160 120)))
    (entity/shape! s 'triangle 8) (entity/drag! s 0)
    (on-frame
     (lambda ()
       (when (input/down? 'left)  (set! ang (- ang 0.08)))
       (when (input/down? 'right) (set! ang (+ ang 0.08)))
       (when (input/down? 'a)
         (let ((vx (car (entity/vel s))) (vy (cadr (entity/vel s))))
           (entity/set-vel! s (+ vx (* 0.15 (geom/cos ang)))
                              (+ vy (* 0.15 (geom/sin ang))))))
       (world/step)
       (let ((x (entity/x s)) (y (entity/y s)))
         (when (< x 0) (entity/set-pos! s (+ x 320) y))
         (when (> x 320) (entity/set-pos! s (- x 320) y))
         (when (< y 0) (entity/set-pos! s x (+ y 240)))
         (when (> y 240) (entity/set-pos! s x (- y 240))))
       (paint-clear)
       (paint-cell 'ship (entity/x s) (entity/y s) 8 8)))))
(big-bang asteroids-lite)
```

---

## 4. Cannon (chapter 4)

Aim, fire, arc.

```scheme
(define ang 45)
(define (cannon)
  (world/reset!)
  (world/gravity! 0 0.3)
  (world/floor! 220)
  (on-frame
   (lambda ()
     (when (input/down? 'up)   (set! ang (min 89 (+ ang 1))))
     (when (input/down? 'down) (set! ang (max 1 (- ang 1))))
     (when (input/pressed? 'a)
       (let* ((r (* ang (/ 3.14159 180)))
              (b (world/spawn 'shell 30 210)))
         (entity/shape! b 'circle 3)
         (entity/set-vel! b (* 6 (geom/cos r)) (* -6 (geom/sin r)))))
     (world/step)
     (paint-clear)
     (paint-cell 'cannon 30 210 20 10)
     (world/each 'shell
                 (lambda (s) (paint-cell 'shell (entity/x s) (entity/y s) 3 3)))
     (paint-text (string-append \"Angle: \" (number->string ang)) 10 10))))
(big-bang cannon)
```

---

## 5. Dodge (chapter 5)

Enemies rain down; move to dodge.

```scheme
(define sc 0)
(define (dodge)
  (world/reset!)
  (let ((p (world/spawn 'player 160 200)))
    (entity/shape! p 'triangle 8)
    (on-frame
     (lambda ()
       (when (input/down? 'left)  (entity/move! p -4 0))
       (when (input/down? 'right) (entity/move! p 4 0))
       (when (= (modulo (world/frame) 30) 0)
         (let ((e (world/spawn 'enemy (+ 20 (modulo (world/hash) 280)) -10)))
           (entity/shape! e 'rect 10 10)
           (entity/set-vel! e 0 2)))
       (world/step)
       (world/each 'enemy
                   (lambda (e) (when (> (entity/y e) 240)
                                 (entity/despawn! e)
                                 (set! sc (+ sc 1)))))
       (paint-clear)
       (world/each 'enemy
                   (lambda (e) (paint-cell 'enemy (entity/x e) (entity/y e) 10 10)))
       (paint-cell 'player (entity/x p) (entity/y p) 8 8)
       (paint-text (string-append \"Dodged: \" (number->string sc)) 10 10)))))
(big-bang dodge)
```

---

## 6. Tumble (chapter 7)

One-button platformer over gaps.

```scheme
(define (tumble)
  (world/reset!)
  (world/gravity! 0 0.6)
  (world/floor! 240)
  (let ((p (world/spawn 'player 20 200)))
    (entity/shape! p 'rect 12 20) (entity/solid! p #t)
    (world/spawn 'gap 200 240)
    (world/each 'gap (lambda (g) (entity/shape! g 'rect 60 4)))
    (on-frame
     (lambda ()
       (entity/move! p 2 0)  ;; auto-run
       (when (input/pressed? 'a)
         (entity/set-vel! p (car (entity/vel p)) -10))
       (world/step)
       (paint-clear)
       (paint-cell 'player (entity/x p) (entity/y p) 12 20)
       (paint-text (string-append \"x: \" (number->string (entity/x p))) 10 10)))))
(big-bang tumble)
```

