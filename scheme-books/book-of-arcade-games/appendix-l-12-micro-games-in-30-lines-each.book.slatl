## 9. Bat and ball (chapter 2)

Just paddle-catches-ball, no bricks.

```scheme
(define (bat-ball)
  (world/reset!)
  (world/gravity! 0 0.3)
  (let ((p (world/spawn 'paddle 160 230))
        (b (world/spawn 'ball 160 30)))
    (entity/shape! p 'rect 40 6) (entity/solid! p #t)
    (entity/shape! b 'circle 5) (entity/solid! b #t) (entity/bounce! b 0.9)
    (entity/set-vel! b 2 -3)
    (on-frame
     (lambda ()
       (when (input/down? 'left)  (entity/move! p -5 0))
       (when (input/down? 'right) (entity/move! p 5 0))
       (world/step)
       (let ((x (entity/x b)) (vx (car (entity/vel b))))
         (when (and (< x 5) (< vx 0))
           (entity/set-vel! b (- vx) (cadr (entity/vel b))))
         (when (and (> x 315) (> vx 0))
           (entity/set-vel! b (- vx) (cadr (entity/vel b))))
         (when (< (entity/y b) 5)
           (entity/set-vel! b vx (- (cadr (entity/vel b))))))
       (paint-clear)
       (paint-cell 'paddle (entity/x p) (entity/y p) 40 6)
       (paint-cell 'ball (entity/x b) (entity/y b) 5 5)))))
(big-bang bat-ball)
```

