## 11. Follow-the-dot

An enemy chases; survive as long as possible.

```scheme
(define t 0)
(define (survive)
  (world/reset!)
  (let ((p (world/spawn 'player 160 120))
        (e (world/spawn 'enemy 20 20)))
    (entity/shape! p 'triangle 8)
    (entity/shape! e 'circle 6)
    (entity/max-speed! e 1.5)
    (on-frame
     (lambda ()
       (set! t (+ t 1))
       (when (input/down? 'left)  (entity/move! p -3 0))
       (when (input/down? 'right) (entity/move! p 3 0))
       (when (input/down? 'up)    (entity/move! p 0 -3))
       (when (input/down? 'down)  (entity/move! p 0 3))
       (ai/seek e p)
       (world/step)
       (when (< (entity/distance e p) 10)
         (paint-text \"CAUGHT!\" 130 100))
       (paint-clear)
       (paint-cell 'player (entity/x p) (entity/y p) 8 8)
       (paint-cell 'enemy (entity/x e) (entity/y e) 6 6)
       (paint-text (string-append \"Survived: \" (number->string t))
                   10 10)))))
(big-bang survive)
```

