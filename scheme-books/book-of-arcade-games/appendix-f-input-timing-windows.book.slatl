  :title "Input Timing Windows"
  :dialect "motoi"
  :audience :kid
  :also-for :adult
  :content-rating :G
  :author-lane "arcade-games-engineer-lane-2026-07-16"
  :training-eligible #t
  :confidentiality "public"
