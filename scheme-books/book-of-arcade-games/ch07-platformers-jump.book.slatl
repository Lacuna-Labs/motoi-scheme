"(define grounded? #t)
(define was-grounded? #t)
(define coyote-frames 0)
(define buffered-jump 0)
(define (platformer-jump-anchor)
  (world/reset!)
  (world/gravity! 0 0.6)
  (world/floor! 220)
  (let ((p (world/spawn 'player 160 200)))
    (entity/shape! p 'rect 12 16)
    (entity/bounce! p 0)
    (entity/solid! p #t)
    (on-frame
     (lambda ()
       (when (input/down? 'left)  (entity/move! p -3 0))
       (when (input/down? 'right) (entity/move! p 3 0))
       (set! grounded? (>= (entity/y p) 212))
       (when (and was-grounded? (not grounded?))
         (set! coyote-frames 6))
       (when (> coyote-frames 0) (set! coyote-frames (- coyote-frames 1)))
       (when (input/pressed? 'a)
         (if (or grounded? (> coyote-frames 0))
             (begin (entity/set-vel! p (car (entity/vel p)) -12)
                    (set! coyote-frames 0))
             (set! buffered-jump 8)))
       (when (and grounded? (> buffered-jump 0))
         (entity/set-vel! p (car (entity/vel p)) -12)
         (set! buffered-jump 0))
       (when (> buffered-jump 0) (set! buffered-jump (- buffered-jump 1)))
       (when (and (not (input/down? 'a)) (< (cadr (entity/vel p)) 0))
         (entity/set-vel! p (car (entity/vel p)) (* (cadr (entity/vel p)) 0.5)))
       (cond ((< (cadr (entity/vel p)) -3) (entity/gravity-scale! p 0.7))
             ((< (cadr (entity/vel p)) 1)  (entity/gravity-scale! p 0.4))
             (else                          (entity/gravity-scale! p 1.2)))
       (when (and (not was-grounded?) grounded?)
         (world/camera-shake! (max 2 (* (cadr (entity/vel p)) 0.3)) 0.9))
       (set! was-grounded? grounded?)
       (world/step)
       (paint-clear)
       (paint-cell 'player (entity/x p) (entity/y p) 12 16)))))
(big-bang platformer-jump-anchor)")
