(book-manifest
  :book "Book of Code"
  :subtitle "A 20,000-year super-run from tally sticks to language models, in Motoi Scheme"
  :chapters 16
  :appendices 8
  :dialect "motoi"
  :voice "motoi-copilot"
  :audience "kid-and-adult operators, curious programmers, 11-year-olds and up"
  :training-eligible #t
  :confidentiality "public"
  :status "wave-1-authored-2026-07-19"
  :inspired-by
    "Charles Petzold — Code: The Hidden Language of Computer Hardware and Software
     (Microsoft Press, 1999). We do not copy it. We take its shape:
     build from nothing, explain everything, respect the reader."
  :provenance
    (:authored-at "2026-07-19"
     :authored-by "book-of-code-author-agent"
     :spec-source "self — first-principles derivation from historical + engineering primary sources"
     :runtime-source ("src/base.js" "src/interp.js" "src/reader.js")
     :verifier "node bin/motoi eval '<expr>'")
  :verb-surface
    (define lambda let let* letrec if cond when case begin
     and or not
     cons car cdr list length map filter reduce fold
     iota reverse append
     eq? equal? = < > <= >= zero? odd? even?
     + - * / quotient remainder modulo expt
     display newline
     make-hash-table hash-set! hash-ref
     define-record-type)
  :chapters-listing
    (("01-before-writing-there-were-tallies.book.slatl"       "Before writing there were tallies — Ishango, quipus, abacus")
     ("02-boolean-logic.book.slatl"                            "Boolean logic and the algebra of yes and no")
     ("03-electricity-and-the-switch.book.slatl"               "Electricity: from Volta to the switch")
     ("04-from-switch-to-gate.book.slatl"                      "From switch to gate — relays, tubes, transistors, chips")
     ("05-logic-gates-in-scheme.book.slatl"                    "Logic gates as first-class Scheme functions")
     ("06-half-adder-and-full-adder.book.slatl"                "The half adder and the full adder")
     ("07-the-4-bit-adder.book.slatl"                          "The 4-bit adder")
     ("08-memory-latches-and-flip-flops.book.slatl"            "Memory — latches and flip-flops")
     ("09-registers-counters-and-the-birth-of-state.book.slatl" "Registers, counters, and the birth of state")
     ("10-state-machines-mealy-and-moore.book.slatl"           "State machines — Mealy and Moore")
     ("11-the-alu.book.slatl"                                  "The ALU — combining adders and logic")
     ("12-the-cpu-fetch-decode-execute.book.slatl"             "The CPU — fetch, decode, execute, and loop forever")
     ("13-memory-hierarchy.book.slatl"                         "Memory — RAM, cache, disk, and why locality matters")
     ("14-assembly-then-higher.book.slatl"                     "Assembly, then higher — from opcodes to Scheme")
     ("15-operating-systems-and-networks.book.slatl"           "Operating systems and networks — machines cooperating")
     ("16-cloud-llms-and-the-loop-that-closes.book.slatl"      "Cloud, LLMs, and the loop that closes"))
  :appendices-listing
    (("appendix-a-ascii-diagram-library.book.slatl"            "ASCII diagram library — every gate, adder, flip-flop, ALU block")
     ("appendix-b-20000-year-timeline.book.slatl"              "Compressed 20,000-year timeline")
     ("appendix-c-state-machine-deep-dive.book.slatl"          "State machine deep dive — Mealy, Moore, real protocols")
     ("appendix-d-modern-llm-ecosystem.book.slatl"             "The modern LLM ecosystem — neutrally described")
     ("appendix-e-loops-underpin-everything.book.slatl"        "Loops, and why they underpin everything")
     ("appendix-f-map-to-book-of-ml.book.slatl"                "How this book maps to Book of ML")
     ("appendix-g-reading-list.book.slatl"                     "Reading list")
     ("appendix-h-runnable-demos-consolidated.book.slatl"      "Runnable Scheme demos consolidated"))
  :one-line
"Sixteen chapters plus eight appendices. A single arc from the Ishango bone
 through electricity, gates, adders, memory, state machines, CPUs, and
 operating systems, ending at the modern landscape of Claude, Gemini,
 OpenAI, and DeepSeek. Every chapter has ASCII diagrams and runnable Motoi
 Scheme code. Every claim is dated and sourced. No LLM provider is ranked;
 all four majors get equal descriptive treatment. Motoi is small and Scheme.
 They are big and general. Different jobs.")
