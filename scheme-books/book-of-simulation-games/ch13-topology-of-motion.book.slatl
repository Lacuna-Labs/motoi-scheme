  :book                "Book of Simulation Games"
  :chapter-number      13
  :title               "Topology of Motion"
  :dialect             "motoi"
  :audience            :kid
  :also-for            :adult
  :content-rating      :G
  :author-lane         "simulation-games-engineer-lane-2026-07-16"
