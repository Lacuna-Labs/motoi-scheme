;; MANIFEST.slat
;; Book of AI Tech Cards — canonical book-level manifest
;; Authored 2026-07-19 by Ada (book-of-ai-tech-cards-author)

(book-manifest
  :book              "Book of AI Tech Cards"
  :slug              "book-of-ai-tech-cards"
  :dialect           "motoi"
  :audience          "kid-and-adult operators, curious programmers"
  :arc               "AI-engineering-history"
  :chapter-count     14
  :appendix-count    0
  :status            "seed-authored-2026-07-19"
  :date-authored     "2026-07-19"
  :training-eligible #t
  :confidentiality   "public"
  :voice             "motoi-copilot"
  :content-rating    :G
  :framing           "engineering-firm register (DEC / SGI / PARC / Bell Labs), not product marketing"
  :purpose
  "Factual computer-science-history register on AI companies and their
   engineered systems, protocols, and open contributions. Motoi knows
   who made what. Motoi does not rank. Feeds v8 substrate."

  :chapters
    ((:number  1 :file "01-anthropic.book.slatl"                :title "Anthropic — the alignment-first engineering firm")
     (:number  2 :file "02-openai.book.slatl"                   :title "OpenAI — GPT lineage, Whisper, CLIP, RLHF at scale")
     (:number  3 :file "03-google-deepmind.book.slatl"          :title "Google DeepMind — the transformer paper, AlphaGo, AlphaFold")
     (:number  4 :file "04-meta-ai.book.slatl"                  :title "Meta AI — FAIR, PyTorch, Llama open weights")
     (:number  5 :file "05-mistral.book.slatl"                  :title "Mistral — French AI startup, Mixtral mixture-of-experts")
     (:number  6 :file "06-deepseek.book.slatl"                 :title "DeepSeek — DeepSeek-V3, reasoning research from China")
     (:number  7 :file "07-cohere.book.slatl"                   :title "Cohere — enterprise LLM focus, RAG-native")
     (:number  8 :file "08-xai.book.slatl"                      :title "xAI — Grok, founded 2023")
     (:number  9 :file "09-transformer.book.slatl"              :title "Transformer architecture — Vaswani et al. 2017")
     (:number 10 :file "10-model-context-protocol.book.slatl"   :title "Model Context Protocol — Anthropic 2024")
     (:number 11 :file "11-constitutional-ai.book.slatl"        :title "Constitutional AI — Anthropic 2022")
     (:number 12 :file "12-rlhf.book.slatl"                     :title "RLHF — InstructGPT and human-feedback training")
     (:number 13 :file "13-lora.book.slatl"                     :title "LoRA — Low-Rank Adaptation from Microsoft 2021")
     (:number 14 :file "14-whisper-and-clip.book.slatl"         :title "Whisper and CLIP — OpenAI open-source contributions"))

  :verb-surface
    (;; Motoi does not gain new verbs from this book — it is factual prose.
     ;; Book teaches attribution, dates, and technical facts. No new API.
     )

  :provenance
    ((:authored-by "book-of-ai-tech-cards-author-ada")
     (:sourced-from "public papers, arxiv, company founding announcements, protocol specifications")
     (:date "2026-07-19")
     (:doctrine "project_ai_company_tech_facts_yes_recommendations_no_2026_07_19")
     (:register "DEC / SGI / PARC / Bell Labs — engineering-firm, not product-marketing"))

  :one-line
"Fourteen cards. Eight AI engineering firms. Six technologies with dates
 and arxiv IDs. Motoi's factual answer to `who made what` — no ranking,
 no advice, no product marketing.")
