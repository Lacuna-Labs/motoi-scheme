;; 00-index-and-approach.slat
;; Book of CS Curriculum — 00-index-and-approach

(chapter
  :book             "Book of CS Curriculum"
  :chapter-number   null
  :title            "00-index-and-approach"
  :source-path      "/Users/alfred/code/curator/BOOK/A-branch-scheme-books/cs-curriculum/00-index-and-approach.slat"
  :size             2725
  :sha256           "7eef9fe36dff9b14"
  :prose
"(book-of-cs-curriculum
  :working-title \"Book of Computer Science (Alfred to pick final)\"
  :date \"2026-07-13\"
  :status \"authored — S08 mega-lane\"
  :audience \"CS majors + kids who want the real thing\"
  :bar \"SICP-readable + kids-can-read + CS-majors-won't-get-bored\"

  :per-topic-shape
  (\"WHAT IT IS\"
   \"WHY IT EXISTS\"
   \"HOW IT WORKS\"
   \"WHERE YOU MEET IT IN THE WORLD\"
   \"SCHEME CODE\"
   \"PHILOSOPHY LENS where fit is genuine (abduce, don't force)\")

  :hard-rules
  (\"no invented benchmark numbers\"
   \"no fake papers\"
   \"no fabricated researcher quotes\"
   \"historical figures (Turing, McCarthy, Minsky, Newell/Simon, Knuth, Dijkstra,
    Church, Hoare, Codd, Backus, Karp, Cook, Levin) OK by name\"
   \"no living corporate researchers named at institutional-branding-level\")

  :chapters
  ((01 \"arrays and lists — the two simplest sequences\")
   (02 \"stacks and queues — order in and order out\")
   (03 \"hash tables — the trick of the good address\")
   (04 \"trees — nesting that finds things fast\")
   (05 \"heaps — always know the biggest thing\")
   (06 \"graphs — everything that connects to everything else\")
   (07 \"bloom filters — probably-not-and-definitely-maybe\")
   (08 \"search — how to find something in a lot of things\")
   (09 \"sorting — putting things in order\")
   (10 \"dynamic programming — remembering what you figured out\")
   (11 \"greedy algorithms — take the best-looking piece now\")
   (12 \"divide and conquer — split the problem, solve the parts\")
   (13 \"backtracking — try, fail, try again\")
   (14 \"randomized algorithms — luck, honestly used\")
   (15 \"complexity — how big is 'big'\")
   (16 \"P vs NP and halting — where 'know' runs out\")
   (17 \"discrete math — the shape of counting-and-not-counting\")
   (18 \"systems — memory, processes, files, networks\")
   (19 \"concurrency — many things at once\")
   (20 \"PL theory — lambda calculus, types, closures, tails\")
   (21 \"compilers — how a program becomes a program\")
   (22 \"databases — the shape of remembering at scale\")
   (23 \"distributed systems — many computers with a shared story\")
   (24 \"security fundamentals — hashing, encryption, trust\")
   (25 \"ML/AI general — what learns and how\"))

  :composition-notes
  (\"Every chapter opens with a small scene — a kid, a shop, a garden, a
    telephone book. The scene is the intuition. Then the WHAT/WHY/HOW/
    WHERE/SCHEME/LENS in prose that reads.\"
   \"Philosophy shows up where it fits. If the fit is forced, we leave it
    out. Peirce abduction — notice, don't confabulate.\"
   \"The Scheme is not decorative. It runs, at the level of pseudo-code
    that a reader could type into a REPL and expect to work.\"))
")
