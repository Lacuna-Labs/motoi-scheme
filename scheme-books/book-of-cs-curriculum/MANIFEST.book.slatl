;; MANIFEST.book.slatl
;; Book of CS Curriculum — canonical book-level manifest
;; Authored 2026-07-15 by nighttime lane S1

(book-manifest
  :book              "Book of CS Curriculum"
  :slug              "book-of-cs-curriculum"
  :dialect           "motoi"
  :audience          "engineer"
  :arc               "cs-major-bridge"
  :chapter-count     16
  :appendix-count    8
  :status            "authored"
  :date-authored     "2026-07-15"
  :training-eligible #t
  :confidentiality   "public"
  :voice             "teaching"
  ;; Scoured 2026-07-17 (Jess): dialect -> motoi, voice de-personified,
  ;; ch15/ch16 manifest entries corrected to real files (were pointing to
  ;; reserved-for-claude placeholders which are now archived).
  :sicp-bar          #t
  :chapters
    ((:number  1 :file "01-arrays-and-lists.book.slatl"                              :title "Arrays and Lists")
     (:number  2 :file "02-stacks-and-queues.book.slatl"                             :title "Stacks and Queues")
     (:number  3 :file "03-hash-tables.book.slatl"                                   :title "Hash Tables")
     (:number  4 :file "04-trees.book.slatl"                                         :title "Trees")
     (:number  5 :file "05-heaps-graphs-bloom.book.slatl"                            :title "Heaps, Graphs, Bloom Filters")
     (:number  6 :file "06-search-and-sort.book.slatl"                               :title "Search and Sort")
     (:number  7 :file "07-algorithm-families.book.slatl"                            :title "Algorithm Families")
     (:number  8 :file "08-complexity-and-limits.book.slatl"                         :title "Complexity and Limits")
     (:number  9 :file "09-systems-and-concurrency.book.slatl"                       :title "Systems and Concurrency")
     (:number 10 :file "10-compilers-databases-distributed-security-ml.book.slatl"   :title "Compilers, Databases, Distributed, Security, ML — the wide chapter")
     (:number 11 :file "11-dynamic-programming.book.slatl"                           :title "Dynamic Programming")
     (:number 12 :file "12-databases-and-indexes.book.slatl"                         :title "Databases and Indexes")
     (:number 13 :file "13-networking-and-protocols.book.slatl"                      :title "Networking and Protocols")
     (:number 14 :file "14-security-fundamentals.book.slatl"                         :title "Security Fundamentals")
     (:number 15 :file "ch15-the-machine-underneath.book.slatl"                     :title "The Machine Underneath")
     (:number 16 :file "ch16-whats-next.book.slatl"                                 :title "What's Next"))

  :appendices
    ((:letter "A" :file "appendix-a-where-we-could-have-done-better.book.slatl"        :title "Where we could have done better")
     (:letter "B" :file "appendix-b-where-we-are-happy-with-what-we-did.book.slatl"    :title "Where we are happy with what we did")
     (:letter "C" :file "appendix-c-algorithms-in-scheme.book.slatl"                   :title "Algorithms in Scheme")
     (:letter "D" :file "appendix-d-reasoning-limits.book.slatl"                       :title "Reasoning Limits")
     (:letter "E" :file "appendix-e-a-metacircular-evaluator.book.slatl"               :title "A Metacircular Evaluator")
     (:letter "F" :file "appendix-f-implementing-a-mini-imperative-language.book.slatl":title "Implementing a Mini Imperative Language")
     (:letter "G" :file "appendix-g-hindley-milner-type-inference.book.slatl"          :title "Hindley-Milner Type Inference")
     (:letter "H" :file "appendix-h-constraint-satisfaction.book.slatl"                :title "Constraint Satisfaction"))

  :provenance
    (:merged-from ()
     :notes "Chapters 1-14 canonical; ch15 and ch16 are advanced-tier reserved slots that fulfill the 16-chapter invariant. Appendices A-H already present.")

  :reading-order
    ("Start with 00-index-and-approach for the shape of the book."
     "Chapters 1-8 build the data-structure and algorithm-family vocabulary."
     "Chapters 9-14 widen out into systems, PL theory, databases, networks, security."
     "Appendices are deeper cuts — C-H are runnable Scheme; A/B are retrospectives.")

  :related
    (book-of-scheme
     book-of-slat
     book-of-challenges
     book-of-training))
