(chapter
  :book             "Book of CS Curriculum"
  :chapter-number   10
  :title            "10-compilers-databases-distributed-security-ml"
  :source-path      "/Users/alfred/code/curator/BOOK/A-branch-scheme-books/cs-curriculum/10-compilers-databases-distributed-security-ml.slat"
  :size             15855
