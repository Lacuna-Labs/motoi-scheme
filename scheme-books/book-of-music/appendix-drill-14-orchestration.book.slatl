(note/place-at basses-voice    'C1 0 'half 40)
(note/place-at cellos-voice    'C2 0 'half 42)
(note/place-at violas-voice    'G3 0 'half 44)
(note/place-at woodwinds-voice 'E4 0 'half 46)
(note/place-at brass-voice     'G4 0 'half 48)
(note/place-at violins-voice   'C5 0 'half 50)

;; Iteration 2 (beats 2–4, mp, velocity ~55).
(note/place-at basses-voice    'C1 2 'half 52)
(note/place-at cellos-voice    'C2 2 'half 54)
(note/place-at violas-voice    'G3 2 'half 56)
(note/place-at woodwinds-voice 'E4 2 'half 58)
(note/place-at brass-voice     'G4 2 'half 60)
(note/place-at violins-voice   'C5 2 'half 62)

;; Iteration 3 (beats 4–6, mf, velocity ~70).
(note/place-at basses-voice    'C1 4 'half 66)
(note/place-at cellos-voice    'C2 4 'half 68)
(note/place-at violas-voice    'G3 4 'half 70)
(note/place-at woodwinds-voice 'E4 4 'half 72)
(note/place-at brass-voice     'G4 4 'half 74)
(note/place-at violins-voice   'C5 4 'half 76)

;; Iteration 4 (beats 6–8, ff, velocity ~90).
(note/place-at basses-voice    'C1 6 'half 85)
(note/place-at cellos-voice    'C2 6 'half 87)
(note/place-at violas-voice    'G3 6 'half 89)
(note/place-at woodwinds-voice 'E4 6 'half 91)
(note/place-at brass-voice     'G4 6 'half 93)
