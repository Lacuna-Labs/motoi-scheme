(at-beat 5 (note/strike 'A2 'quarter 0.65 jazz-bass))
(at-beat 6 (note/strike 'G2 'quarter 0.65 jazz-bass))
(at-beat 7 (note/strike 'G2 'quarter 0.65 jazz-bass))

(at-beat 8 (note/strike 'F2 'quarter 0.65 jazz-bass))
(at-beat 9 (note/strike 'F2 'quarter 0.65 jazz-bass))
(at-beat 10 (note/strike 'E2 'quarter 0.65 jazz-bass))
(at-beat 11 (note/strike 'E2 'quarter 0.65 jazz-bass))

(at-beat 12 (note/strike 'D2 'quarter 0.65 jazz-bass))
(at-beat 13 (note/strike 'D2 'quarter 0.65 jazz-bass))
(at-beat 14 (note/strike 'C2 'quarter 0.65 jazz-bass))
(at-beat 15 (note/strike 'C2 'quarter 0.65 jazz-bass))
