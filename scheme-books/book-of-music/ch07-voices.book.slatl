  (note 76 'sixteenth 70)
  (note 77 'sixteenth 70)
  (note 79 'sixteenth 70)
  (note 81 'sixteenth 70)
  (note 83 'sixteenth 70)
  (note 84 'sixteenth 70))

(flute-run)
```

