(define simple-four-profile
  '(0.0 1.0 0.5 0.33 0.25 0.0 0.0 0.0 0.0))

;; *[needs: GAP-6]*
;; (define-voice 'simple-four (simple-four-profile '(0 0 0 0 0 0 0 0 0)))

(define (simple-four-scale)
  (note 60 'quarter 80)
  (note 62 'quarter 80)
  (note 64 'quarter 80)
  (note 65 'quarter 80))

(simple-four-scale)
```

