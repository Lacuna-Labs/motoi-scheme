(example :ref "ch9-money-eq-yes"
         :code "(begin (define (money c m) (list 'money c m)) (define (money-currency x) (cadr x)) (define (money-minor x) (caddr x)) (define (money? x) (and (pair? x) (eq? (car x) 'money))) (define (money=? a b) (and (money? a) (money? b) (eq? (money-currency a) (money-currency b)) (= (money-minor a) (money-minor b)))) (money=? (money 'usd 100) (money 'usd 100)))"
         :expected #t)
(example :ref "ch9-money-eq-no"
         :code "(begin (define (money c m) (list 'money c m)) (define (money-currency x) (cadr x)) (define (money-minor x) (caddr x)) (define (money? x) (and (pair? x) (eq? (car x) 'money))) (define (money=? a b) (and (money? a) (money? b) (eq? (money-currency a) (money-currency b)) (= (money-minor a) (money-minor b)))) (money=? (money 'usd 100) (money 'eur 100)))"
         :expected #f)
(example :ref "ch9-float-eq-yes"
         :code "(begin (define (float=? a b eps) (< (- (max a b) (min a b)) eps)) (float=? 0.1 0.10000001 0.0001))"
         :expected #t)
(example :ref "ch9-float-eq-no"
