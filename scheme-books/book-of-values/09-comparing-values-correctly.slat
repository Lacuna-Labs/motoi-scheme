         :expected #f)
(example :ref "ch9-false-not-nil"   :code "(eq? #f '())"             :expected #f)
(example :ref "ch9-zero-not-false"  :code "(equal? 0 #f)"            :expected #f)
(example :ref "ch9-money-lt"
