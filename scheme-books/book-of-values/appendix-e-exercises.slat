(chapter
  :book              "Book of Values"
  :chapter-number    "E"
  :title             "Appendix E — Runnable Exercises"
  :audience          :engineer
  :dialect           "motoi"
  :book-version      "1.0"
  :provenance        "book-of-values-author-2026-07-16"
