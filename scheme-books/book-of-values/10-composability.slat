         :code "(math/sum (list 100 200 300))"
         :expected 600)
(example :ref "ch10-money-sum-ok"
         :code "(begin (define (mls lst) (let* ((first (car lst)) (cur (cadr first))) (let loop ((rest (cdr lst)) (total (caddr first))) (cond ((null? rest) (list 'money cur total)) ((not (eq? (cadr (car rest)) cur)) (list 'error 'currency-mismatch cur (cadr (car rest)))) (else (loop (cdr rest) (+ total (caddr (car rest))))))))) (mls (list (list 'money 'usd 100) (list 'money 'usd 200) (list 'money 'usd 300))))"
         :expected "(money usd 600)")
(example :ref "ch10-money-sum-refuse"
         :code "(begin (define (mls lst) (let* ((first (car lst)) (cur (cadr first))) (let loop ((rest (cdr lst)) (total (caddr first))) (cond ((null? rest) (list 'money cur total)) ((not (eq? (cadr (car rest)) cur)) (list 'error 'currency-mismatch cur (cadr (car rest)))) (else (loop (cdr rest) (+ total (caddr (car rest))))))))) (mls (list (list 'money 'usd 100) (list 'money 'eur 200))))"
         :expected "(error currency-mismatch usd eur)")
(example :ref "ch10-money-avg"
         :code "(quotient (+ 100 200 300 400) 4)"
         :expected 250)
(example :ref "ch10-money-avg-uneven"
         :code "(quotient (+ 100 200 400) 3)"
         :expected 233)
(example :ref "ch10-allocate"
         :code "(begin (define (allocate T n) (let* ((base (quotient T n)) (rem (remainder T n))) (let loop ((i 0) (out '())) (cond ((= i n) (reverse out)) ((< i rem) (loop (+ i 1) (cons (+ base 1) out))) (else (loop (+ i 1) (cons base out))))))) (allocate 100 3))"
         :expected "(34 33 33)")
(example :ref "ch10-allocate-sums"
         :code "(begin (define (allocate T n) (let* ((base (quotient T n)) (rem (remainder T n))) (let loop ((i 0) (out '())) (cond ((= i n) (reverse out)) ((< i rem) (loop (+ i 1) (cons (+ base 1) out))) (else (loop (+ i 1) (cons base out))))))) (math/sum (allocate 100 3)))"
         :expected 100
         :teaching "The invariant: allocation sums back to the total.")
(example :ref "ch10-vec-add-displacement"
         :code "(vec/add (vec/make 100 50) (vec/make 3 4))"
         :expected "(103 54)")
(example :ref "ch10-color-lerp"
         :code "(vec/lerp (vec/make 255 0 0) (vec/make 0 0 255) 0.5)"
         :expected "(127.5 0 127.5)")
