(chapter
  :book              "Book of Values"
  :chapter-number    10
  :title             "Composability"
  :audience          :engineer
  :dialect           "motoi"
  :book-version      "1.1"
  :provenance        "book-of-values-author-2026-07-16 book-of-values-expander-2026-07-17"
