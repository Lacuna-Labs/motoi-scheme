         :expected "(money usd 200)")
(example :ref "ch16-contract-input-fail"
         :code "(begin (define (with-contract ip op f) (lambda (x) (cond ((not (ip x)) (list 'contract-violation 'input x)) (else (let ((r (f x))) (cond ((not (op r)) (list 'contract-violation 'output r)) (else r))))))) (define (money? x) (and (pair? x) (eq? (car x) 'money))) (define (pos? m) (and (money? m) (> (caddr m) 0))) (define dm (with-contract money? pos? (lambda (m) (list 'money (cadr m) (* 2 (caddr m)))))) (dm 42))"
         :expected "(contract-violation input 42)")
(example :ref "ch16-contract-output-fail"
         :code "(begin (define (with-contract ip op f) (lambda (x) (cond ((not (ip x)) (list 'contract-violation 'input x)) (else (let ((r (f x))) (cond ((not (op r)) (list 'contract-violation 'output r)) (else r))))))) (define (money? x) (and (pair? x) (eq? (car x) 'money))) (define (pos? m) (and (money? m) (> (caddr m) 0))) (define dm (with-contract money? pos? (lambda (m) (list 'money (cadr m) (* 2 (caddr m)))))) (dm (list 'money 'usd 0)))"
         :expected "(contract-violation output (money usd 0))")
(example :ref "ch16-property-allocate"
         :code "(begin (define (allocate T n) (let* ((base (quotient T n)) (rem (remainder T n))) (let loop ((i 0) (out '())) (cond ((= i n) (reverse out)) ((< i rem) (loop (+ i 1) (cons (+ base 1) out))) (else (loop (+ i 1) (cons base out))))))) (define (test-alloc N) (let loop ((i 0) (fails 0)) (cond ((= i N) (list ':trials N ':fails fails)) (else (let* ((total (+ 1 (random-int 100000))) (n (+ 1 (random-int 10))) (parts (allocate total n)) (sum (math/sum parts))) (if (= sum total) (loop (+ i 1) fails) (loop (+ i 1) (+ fails 1)))))))) (test-alloc 20))"
         :expected "(:trials 20 :fails 0)")
