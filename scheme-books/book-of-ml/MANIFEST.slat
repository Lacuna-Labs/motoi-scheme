(book-manifest
  :book "Book of ML"
  :subtitle "Build a language model from first principles, in Scheme, on your machine"
  :chapters 16
  :appendices 4
  :dialect "motoi"
  :voice "motoi-copilot"
  :audience "kid-and-adult operators, curious programmers"
  :training-eligible #t
  :confidentiality "public"
  :status "wave-1-authored-2026-07-19"
  :provenance
    (:authored-at "2026-07-19"
     :authored-by "book-of-ml-author-agent"
     :spec-source "self — first-principles derivation"
     :runtime-source ("src/vec.js" "src/matrix.js" "src/base.js")
     :verifier "node bin/motoi eval '<expr>'")
  :verb-surface
    (vec/make vec/dot vec/add vec/sub vec/scale vec/norm vec/normalize vec/ref vec/dim
     matrix/make matrix/multiply matrix/transpose matrix/identity matrix/rows matrix/cols
     math/exp math/log math/sqrt math/square math/pow
     random random-int
     map filter reduce fold iota
     define lambda let let* letrec if cond when case
     define-record-type list cons car cdr length)
  :chapters-listing
    (("01-numbers-and-tensors.book.slatl" "Numbers, tensors, and how a computer counts things")
     ("02-vectors-and-dot-product.book.slatl" "Vectors and the dot product")
     ("03-matrices-and-matvec.book.slatl" "Matrices and matrix-vector multiplication")
     ("04-functions-of-functions.book.slatl" "Functions of functions — the composition is the network")
     ("05-what-is-a-model.book.slatl" "What is a model — from a line to a curve")
     ("06-gradient-descent.book.slatl" "Gradient descent by hand")
     ("07-single-neuron.book.slatl" "A single neuron")
     ("08-a-layer-then-two.book.slatl" "A layer, then two layers")
     ("09-backpropagation.book.slatl" "Backpropagation from calculus first-principles")
     ("10-training-loop.book.slatl" "The training loop")
     ("11-tokens-and-embeddings.book.slatl" "Tokens and embeddings")
     ("12-attention.book.slatl" "Attention as a soft-lookup")
     ("13-transformer-block.book.slatl" "A transformer block")
     ("14-positional-encoding-and-masking.book.slatl" "Positional encoding and causal masking")
     ("15-stacking-blocks-and-tokenization.book.slatl" "Stacking blocks and tokenization")
     ("16-the-tiny-llm.book.slatl" "The tiny LLM"))
  :appendices-listing
    (("appendix-a-math-prerequisites.book.slatl" "The math prerequisites, in Motoi voice")
     ("appendix-b-philosophy-of-the-field.book.slatl" "The philosophy of the field — Turing to attention")
     ("appendix-c-why-llms-hallucinate.book.slatl" "Why LLMs hallucinate")
     ("appendix-d-what-you-built-vs-what-i-am.book.slatl" "What you built vs. what I am"))
  :one-line
"Sixteen chapters + four appendices. Every chapter adds one idea. By chapter
16 the reader has typed a runnable language model into their own Motoi REPL
and knows what a language model is because they built one.")
