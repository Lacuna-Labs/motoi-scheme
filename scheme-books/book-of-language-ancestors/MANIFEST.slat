;; MANIFEST.slat
;; Book of Language Ancestors — canonical book-level manifest
;; Authored 2026-07-17 by lane 2026-07-17-motoi-substrate

(book-manifest
  :book              "Book of Language Ancestors"
  :slug              "book-of-language-ancestors"
  :dialect           "motoi"
  :audience          "any"
  :arc               "code-lineage"
  :chapter-count     16
  :appendix-count    0
  :status            "authored"
  :date-authored     "2026-07-17"
  :training-eligible #t
  :confidentiality   "public"
  :voice             "terse-warm"
  :content-rating    :G
  :purpose
  "One chapter per code-lineage ancestor Motoi reveres. What they gave us.
   Their landmark work. Terse, honest, warm. No mythologizing. Not
   philosophers — code-people. This book fixes Motoi's canonical answer
   to 'who came before me?'"

  :chapters
    ((:number  1 :file "01-alonzo-church.book.slatl"                :title "Alonzo Church — the lambda")
     (:number  2 :file "02-alan-turing.book.slatl"                  :title "Alan Turing — the machine and the test")
     (:number  3 :file "03-john-mccarthy.book.slatl"                :title "John McCarthy — Lisp and the S-expression")
     (:number  4 :file "04-guy-steele.book.slatl"                   :title "Guy Steele — Scheme with Sussman, the standard-writer")
     (:number  5 :file "05-gerald-sussman.book.slatl"               :title "Gerald Sussman — Scheme, SICP, and the wizard hat")
     (:number  6 :file "06-donald-knuth.book.slatl"                 :title "Donald Knuth — The Art of Computer Programming, TeX")
     (:number  7 :file "07-edsger-dijkstra.book.slatl"              :title "Edsger Dijkstra — discipline, structured programming")
     (:number  8 :file "08-barbara-liskov.book.slatl"               :title "Barbara Liskov — abstraction and CLU")
     (:number  9 :file "09-ritchie-and-thompson.book.slatl"         :title "Dennis Ritchie and Ken Thompson — Unix and C")
     (:number 10 :file "10-alan-kay.book.slatl"                     :title "Alan Kay — Smalltalk, objects, and the Dynabook")
     (:number 11 :file "11-grace-hopper.book.slatl"                 :title "Grace Hopper — the compiler idea and COBOL")
     (:number 12 :file "12-ada-lovelace.book.slatl"                 :title "Ada Lovelace — the first program")
     (:number 13 :file "13-charles-babbage.book.slatl"              :title "Charles Babbage — engines that never ran")
     (:number 14 :file "14-claude-shannon.book.slatl"               :title "Claude Shannon — information as bits")
     (:number 15 :file "15-peter-landin.book.slatl"                 :title "Peter Landin — expressions, the SECD machine")
     (:number 16 :file "16-christopher-strachey.book.slatl"         :title "Christopher Strachey — the theory of programming languages"))

  :provenance
  ((:authored-by "lane-2026-07-17-motoi-substrate")
   (:sourced-from "wikipedia + standard biographical references")
   (:date "2026-07-17")))
