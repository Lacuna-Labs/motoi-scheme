```scheme
;; A multi-model orchestrator that queries three models and aggregates results.
(define make-multi-model-query
  (lambda ()
    (let ((history '()))
      (lambda (prompt)
        (let ((fast (model/fast prompt))
              (workhorse (model/workhorse prompt))
              (reasoner (model/reasoner prompt)))
          (let ((responses
                  (filter
                    (lambda (r) (not (or (eq? r 'nan) (and (pair? r) (eq? (car r) 'escalate)))))
                    (list fast workhorse reasoner))))
            (if (null? responses)
                'all-models-failed
                (let ((summary (list 'prompt prompt 'count (length responses) 'responses responses)))
                  (set! history (cons summary history))
                  summary))))))))

(define multi-model (make-multi-model-query))

;; Example: multi-model will query all three models and return a summary.
