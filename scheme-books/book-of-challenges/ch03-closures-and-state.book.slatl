  (lambda ()
    (let ((history '()))
      (lambda (query)
        (let ((results (web/search query)))
          (if (or (eq? results 'nan) (and (pair? results) (eq? (car results) 'escalate)))
              (list 'search-failed query)
              (let ((count (length results)))
                (set! history (cons (list 'query query 'count count) history))
                (list 'count count 'total-searches (length history)))))))))

(define search-tracker (make-search-tracker))

