          (if (or (eq? fetched 'nan) (and (pair? fetched) (eq? (car fetched) 'escalate)))
              (list 'fetch-failed url)
              (let ((text (if (string? fetched) fetched (car fetched))))
                (let ((count (text/word-count text)))
                  (if (eq? count 'nan)
                      (list 'count-failed url)
                      (begin
                        (set! history (cons (list 'url url 'words count) history))
                        (list 'words count 'total-fetched (length history))))))))))))

(define wc-pipeline (make-word-count-pipeline))

;; Example: wc-pipeline will fetch, count words, and log.
