    (let ((values '()))
      (lambda (new-values)
        (set! values (append values new-values))
        (let ((p50 (stats/percentile values 50))
              (p90 (stats/percentile values 90))
              (p99 (stats/percentile values 99)))
          (if (or (eq? p50 'nan) (eq? p90 'nan) (eq? p99 'nan))
              'percentile-failed
