(chapter
  :book                "Book of Narrative Games"
  :chapter-number      1
  :title               "A Room, a Door, a Choice"
  :dialect             "motoi"
  :audience            :kid
  :also-for            :adult
  :content-rating      :G
  :author-lane         "narrative-games-engineer-lane-2026-07-16"
  :training-eligible   #t
