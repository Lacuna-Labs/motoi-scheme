   (:number  5 :file "ch05-dialogue-trees.book.slatl"             :title "Dialogue Trees")
   (:number  6 :file "ch06-camera-tells-the-story.book.slatl"     :title "The Camera Tells the Story")
   (:number  7 :file "ch07-puzzle-in-prose.book.slatl"            :title "Puzzle in Prose")
   (:number  8 :file "ch08-inventory-and-world-state.book.slatl"  :title "Inventory and World-State")
   (:number  9 :file "ch09-sound-and-silence.book.slatl"          :title "Sound and Silence")
   (:number 10 :file "ch10-villain-and-their-face.book.slatl"     :title "The Villain and Their Face")
   (:number 11 :file "ch11-branching-that-matters.book.slatl"     :title "Branching That Matters")
   (:number 12 :file "ch12-deep-think-companion.book.slatl"       :title "The Deep-Think Companion")
   (:number 13 :file "ch13-multi-character-scenes.book.slatl"     :title "Multi-Character Scenes")
   (:number 14 :file "ch14-playable-poetry.book.slatl"            :title "Playable Poetry")
   (:number 15 :file "ch15-long-story.book.slatl"                 :title "The Long Story")
   (:number 16 :file "ch16-whole-adventure.book.slatl"            :title "The Whole Adventure")
