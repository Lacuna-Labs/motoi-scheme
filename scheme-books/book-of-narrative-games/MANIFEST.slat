(dialect :applies ("motoi") :note "Story-branching-dialogue-memory book.")

(book-manifest
  :book                 "Book of Narrative Games"
  :slug                 "book-of-narrative-games"
  :chapter-count        16
  :appendix-count       12
  :audience             :kid
  :also-for             :adult
  :dialect              "motoi"
  :dialects-applies     ("motoi")
  :content-rating       :PG
  :training-eligible    #t
  :confidentiality      "public"
  :voice                "teaching + narrative-craft"
  :book-version         "1.0.0"
  :status               "16-chapter-invariant-satisfied-2026-07-16"
  :generated-at         "2026-07-16"
  :generator            "narrative-games-engineer-lane"
  :architect-design-slat
    "/Users/alfred/code/lacuna-labs/design-docs/architect-3-game-books-2026-07-16.slat"
  :anchor
    "A room, a door, a choice. Words as world, memory as physics. The story remembers who you were last time. Characters breathe and lean and nod. The camera tells the story. Puzzles live in prose. A branch that changes nothing is a lie; we do not lie in this book."
  :composes-with
    (:16-chapter-invariant
     :publishable-prose-doctrine
     :reference-manual-is-the-language
     :kid-from-north-georgia-floor
     :book-fix-it-part-three-rosetta-dewey
     :merge-not-throw-doctrine)
  :migration-source     "book-of-games-preserved (archived 2026-07-16)"
  :chapters
