;; MANIFEST.book.slatl
;; Book of Sound — canonical manifest
;; Authored under 16-chapter-invariant directive (2026-07-15).

(book-manifest
  :book              "Book of Sound"
  :slug              "book-of-sound"
  :version           "1"
  :chapter-count     16
  :appendix-count    4
  :audience          "kid"
  :dialect           "motoi"
  :training-eligible #t
  :confidentiality   "public"
  :status            "canonical"
  :invariant         "16-chapter, overflow-to-appendix"
  :last-review       "2026-07-15"

  :structure
  "Sixteen chapters climbing from the raw waveform to the beat machine.
   The path: waveform → harmonics → soundboard → filter → envelope →
   noise → the body → building an instrument → physical models → roster
   → timing → sequencing → decomposing sound → transcription → voice
   → the beat machine (composition summit). Two reserved advanced slots
   plus vocabulary and tone-table appendices."

  :chapters
  ((:n 1  :title "The Waveform"             :file "ch01-the-waveform.book.slatl")
   (:n 2  :title "Harmonics & Harmony"      :file "ch02-harmonics-and-harmony.book.slatl")
   (:n 3  :title "The Soundboard"           :file "ch03-the-soundboard.book.slatl")
   (:n 4  :title "The Filter"               :file "ch04-the-filter.book.slatl")
   (:n 5  :title "The Envelope"             :file "ch05-the-envelope.book.slatl")
   (:n 6  :title "Noise & Texture"          :file "ch06-noise-and-texture.book.slatl")
   (:n 7  :title "The Body"                 :file "ch07-the-body.book.slatl")
   (:n 8  :title "Building an Instrument"   :file "ch08-building-an-instrument.book.slatl")
   (:n 9  :title "Physical Models"          :file "ch09-physical-models.book.slatl")
   (:n 10 :title "The Roster"               :file "ch10-the-roster.book.slatl")
   (:n 11 :title "Timing"                   :file "ch11-timing.book.slatl")
   (:n 12 :title "Sequencing & Chiptune"    :file "ch12-sequencing-and-chiptune.book.slatl")
   (:n 13 :title "Decomposing Sound"        :file "ch13-decomposing-sound.book.slatl")
   (:n 14 :title "Transcription"            :file "ch14-transcription.book.slatl")
   (:n 15 :title "Voice & Speech"           :file "ch15-voice-and-speech.book.slatl")
   (:n 16 :title "The Beat Machine"         :file "ch16-the-beat-machine.book.slatl"))

  :appendices
  ;; Appendices a/b reserved-for-claude placeholders archived 2026-07-17 (Jess).
  ((:tag "c" :title "Instrument/synth vocabulary" :file "appendix-c-instrument-vocabulary.book.slatl"  :status :authored-2026-07-15)
   (:tag "d" :title "Tone table"                  :file "appendix-d-tone-table.book.slatl"             :status :authored-2026-07-15))

  :tagging
  (:audience "kid"
   :dialect "sakura"
   :training-eligible #t
   :confidentiality "public")

  :doctrine
  (:publishable-prose :16-chapter-invariant :no-fabrication)

  :closing
  "Kid-audience: a first synth book that runs from wave to song without
   condescension.")
