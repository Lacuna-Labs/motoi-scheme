```scheme
(call-with-world
 (make-world width: 400 height: 400 background: '(250 248 240))
 (lambda (w)
   (let ((frame 0))
     (define (draw)
       (world-clear w)
       (let* ((t (/ frame 60.0))
              (squash (+ 0.7 (* 0.3 (sin (* t 3.5)))))
              (shift (* 10 (- 1.0 squash)))
              (y (+ 250 shift))
              (h-scale (/ 1.0 (sqrt squash)))
              (v-scale (sqrt squash)))
         (world-draw-ellipse w 200 y
                             (* 45 h-scale)
                             (* 45 v-scale)
                             '(200 140 80) 'fill)
         (set! frame (+ frame 1))))
     (world-on-tick w draw 60)
     (world-show w)
     (world-wait w))))
