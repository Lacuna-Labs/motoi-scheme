### Chain reaction: delayed squash on multiple objects

Three circles squashing in sequence.

```scheme
(call-with-world
 (make-world width: 600 height: 300 background: '(245 245 250))
 (lambda (w)
   (let ((frame 0))
     (define (squash-at-phase p)
       (let ((local-t (modulo p 1.0)))
         (if (< local-t 0.2)
             (- 1.0 (* 0.6 (/ local-t 0.2)))
             (if (< local-t 0.4)
                 (+ 0.4 (* 0.6 (/ (- local-t 0.2) 0.2)))
                 1.0))))
     (define (draw)
       (world-clear w)
       (let* ((t (/ frame 90.0))
              (s1 (squash-at-phase t))
              (s2 (squash-at-phase (- t 0.15)))
              (s3 (squash-at-phase (- t 0.3))))
         (world-draw-ellipse w 150 150 (* 35 (/ 1.0 (sqrt s1))) (* 35 (sqrt s1)) '(200 100 100) 'fill)
         (world-draw-ellipse w 300 150 (* 35 (/ 1.0 (sqrt s2))) (* 35 (sqrt s2)) '(100 200 100) 'fill)
         (world-draw-ellipse w 450 150 (* 35 (/ 1.0 (sqrt s3))) (* 35 (sqrt s3)) '(100 100 200) 'fill)
         (set! frame (+ frame 1))))
     (world-on-tick w draw 60)
     (world-show w)
     (world-wait w))))
```

