### Squash with trailing ghost images

Showing squash history via fading copies.

```scheme
(call-with-world
 (make-world width: 400 height: 300 background: '(250 250 245))
 (lambda (w)
   (let ((frame 0)
         (history '()))
     (define (draw)
       (world-clear w)
       (let* ((t (/ frame 60.0))
              (squash (+ 0.6 (* 0.4 (sin (* t 4.0)))))
              (h-scale (/ 1.0 (sqrt squash)))
              (v-scale (sqrt squash)))
         (set! history (cons (list h-scale v-scale) history))
         (when (> (length history) 8)
           (set! history (reverse (cdr (reverse history)))))
         (let loop ((h history) (i 0))
           (when (not (null? h))
             (let* ((entry (car h))
                    (alpha (inexact->exact (floor (* 30 (/ (- 8 i) 8.0)))))
                    (color (list 200 100 100 alpha)))
               (world-draw-ellipse w 200 150
                                   (* 50 (car entry))
                                   (* 50 (cadr entry))
                                   color 'fill))
             (loop (cdr h) (+ i 1))))
         (world-draw-ellipse w 200 150
                             (* 50 h-scale)
                             (* 50 v-scale)
                             '(200 100 100) 'fill)
         (set! frame (+ frame 1))))
     (world-on-tick w draw 60)
     (world-show w)
     (world-wait w))))
