              (impact-t (max 0 (- 1.0 cycle)))
              (squash (cond
                       ((< impact-t 0.0) 1.0)
                       ((< impact-t 0.15) (- 1.0 (* 0.7 (/ impact-t 0.15))))
                       ((< impact-t 0.35) (+ 0.3 (* 0.8 (/ (- impact-t 0.15) 0.2))))
                       (else 1.0)))
              (h-scale (/ 1.0 (sqrt squash)))
              (v-scale (sqrt squash)))
         (world-draw-ellipse w 200 320
                             (* 45 h-scale)
                             (* 45 v-scale)
                             '(100 160 200) 'fill)
         (set! frame (+ frame 1))))
