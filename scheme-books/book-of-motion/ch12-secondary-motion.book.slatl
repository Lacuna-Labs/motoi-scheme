      (when (= time 100)
        (set! root-angle 0))
      (let ((spring1 (* (- root-angle s1-angle) 0.2))
            (damp1 (* s1-v 0.9))
            (spring2 (* (- s1-angle s2-angle) 0.15))
            (damp2 (* s2-v 0.85)))
        (set! s1-v (+ damp1

")
