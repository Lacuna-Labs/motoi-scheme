        (set! s2-y (+ s2-y (* (- s1-y s2-y) 0.15)))
        (set! s3-x (+ s3-x (* (- (+ s2-x 30) s3-x) 0.12)))
        (set! s3-y (+ s3-y (* (- s2-y s3-y) 0.12)))
        (set! s4-x (+ s4-x (* (- (+ s3-x 30) s4-x) 0.1)))
        (set! s4-y (+ s4-y (* (- s3-y s4-y) 0.1))))
