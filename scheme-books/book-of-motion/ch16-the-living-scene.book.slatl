      (position 80 (drop-y 120 t))
      (radius 3)
      (color 150 150 200))
    (entity 'circle
      (position 200 (drop-y 140 (+ t 0.3)))
      (radius 3)
      (color 150 150 200))
    (entity 'circle
      (position 320 (drop-y 130 (+ t 0.6)))
      (radius 3)
      (color 150 150 200))
    ;; puddle
