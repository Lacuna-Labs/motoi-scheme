  (+ 1.0 (* 0.5 (sin (* 4.0 t)))))

(define (shear-x t)
  (* 0.3 (sin (* 6.0 t))))

(define (blend-x ax bx w)
  (+ (* ax (- 1.0 w))
     (* bx w)))

(motion
 (at 0.0
     (pose
      (entity 'cloth
              (transform
               100.0
               100.0
               0.0
               (blend-x (stretch-scale-y 0.0) 1.0 0.5)
               1.0
               (blend-x 0.0 (shear-x 0.0) 0.5)))))
 (at 1.0
     (pose
      (entity 'cloth
              (transform
               100.0
               100.0
               0.0
               (blend-x (stretch-scale-y 1.0) 1.0 0.5)
