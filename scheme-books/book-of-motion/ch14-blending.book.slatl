### Blend Eye-Blink Timing

Blink A is fast (0.1 seconds). Blink B is slow (0.4 seconds). Blend the duration.

```scheme
(define (blink-open-a t)
  (cond
   ((< t 0.05) (* 20.0 t))
   ((< t 0.1) (* 20.0 (- 0.1 t)))
   (else 0.0)))

(define (blink-open-b t)
  (cond
   ((< t 0.2) (* 5.0 t))
   ((< t 0.4) (* 5.0 (- 0.4 t)))
   (else 0.0)))

(define (blend-x ax bx w)
  (+ (* ax (- 1.0 w))
     (* bx w)))

(motion
 (at 0.0
     (pose
      (entity 'eyelid
              (transform
               100.0
               (+ 100.0 (blend-x (blink-open-a 0.0) (blink-open-b 0.0) 0.5))
               0.0))))
 (at 0.2
     (pose
      (entity 'eyelid
              (transform
               100.0
               (+ 100.0 (blend-x (blink-open-a 0.2) (blink-open-b 0.2) 0.5))
               0.0))))
 (at 0.4
     (pose
      (entity 'eyelid
              (transform
               100.0
               (+ 100.0 (blend-x (blink-open-a 0.4) (blink-open-b 0.4) 0.5))
