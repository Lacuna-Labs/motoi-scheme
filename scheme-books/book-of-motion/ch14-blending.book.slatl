(define (pos-x t ax)
  (* 0.5 ax t t))

(motion
 (at 0.0
     (pose
      (entity 'particle
              (transform
               (pos-x 0.0 (blend-x 0.0 magnet-ax 0.4))
               (pos-y 0.0 (blend-x gravity-ay magnet-ay 0.4))
               0.0))))
 (at 1.0
     (pose
      (entity 'particle
              (transform
               (pos-x 1.0 (blend-x 0.0 magnet-ax 0.4))
               (pos-y 1.0 (blend-x gravity-ay magnet-ay 0.4))
               0.0)))))
```

