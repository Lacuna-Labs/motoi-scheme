### Crossfade Two Camera Paths

Camera A orbits clockwise. Camera B orbits counterclockwise. Blend their angular positions.

```scheme
(define (camera-a-angle t)
  (* 90.0 t))

(define (camera-b-angle t)
  (* -90.0 t))

(define (angle-diff a b)
  (let ((d (- b a)))
    (cond
     ((> d 180.0) (- d 360.0))
     ((< d -180.0) (+ d 360.0))
     (else d))))

(define (blend-angle ax bx w)
  (+ ax (* (angle-diff ax bx) w)))

(motion
 (at 0.0
     (pose
      (entity 'camera
              (transform
               (* 200.0 (cos (* 0.0174533 (blend-angle (camera-a-angle 0.0)
                                                         (camera-b-angle 0.0)
                                                         0.5))))
               (* 200.0 (sin (* 0.0174533 (blend-angle (camera-a-angle 0.0)
                                                         (camera-b-angle 0.0)
                                                         0.5))))
               0.0))))
 (at 2.0
     (pose
      (entity 'camera
              (transform
               (* 200.0 (cos (* 0.0174533 (blend-angle (camera-a-angle 2.0)
                                                         (camera-b-angle 2.0)
                                                         0.5))))
               (* 200.0 (sin (* 0.0174533 (blend-angle (camera-a-angle 2.0)
                                                         (camera-b-angle 2.0)
                                                         0.5))))
               0.0)))))
```

[VISUAL: Camera orbit slows to a stop as the two opposing velocities cancel at w=0.5.]

