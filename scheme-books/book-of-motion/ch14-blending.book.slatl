### Crossfade with Overlap Offset

Start the second animation early so there's a \"preview\" before the blend weight rises.

```scheme
(define (idle-x t)
  100.0)

(define (walk-x t)
  (+ 100.0 (* 50.0 t)))

(define (blend-x ax bx w)
  (+ (* ax (- 1.0 w))
     (* bx w)))

(motion
 (at 0.0
     (pose
      (entity 'figure
              (transform
               (blend-x (idle-x 0.0) (walk-x -0.3) 0.0)
               100.0
               0.0))))
 (at 0.5
     (pose
      (entity 'figure
              (transform
               (blend-x (idle-x 0.5) (walk-x 0.2) 0.5)
               100.0
               0.0))))
 (at 1.0
     (pose
      (entity 'figure
              (transform
               (blend-x (idle-x 1.0) (walk-x 0.7) 1.0)
               100.0
               0.0)))))
```

