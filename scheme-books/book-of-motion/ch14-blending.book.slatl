  (* style 15.0 (abs (sin (* 6.28 t)))))

(define (walk-smooth-y t)
  (* 3.0 (sin (* 6.28 t))))

(define (blend-x ax bx w)
  (+ (* ax (- 1.0 w))
     (* bx w)))

(define (blend-style sa sb w)
  (+ (* sa (- 1.0 w))
     (* sb w)))

(motion
 (at 0.0
     (pose
      (entity 'torso
              (transform
               100.0
               (blend-x (walk-bounce-y 0.0 1.0) (walk-smooth-y 0.0) 0.0)
               0.0))))
 (at 1.0
     (pose
      (entity 'torso
              (transform
               100.0
               (blend-x (walk-bounce-y 1.0 0.5) (walk-smooth-y 1.0) 0.5)
               0.0))))
 (at 2.0
     (pose
      (entity 'torso
              (transform
               100.0
               (blend-x (walk-bounce-y 2.0 0.0) (walk-smooth-y 2.0) 1.0)
               0.0)))))
```

[VISUAL: Torso vertical motion smooths out as bounce amplitude fades.]

