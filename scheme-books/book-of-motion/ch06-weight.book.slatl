      (radius 10)
      (color 200 100 100))
    (entity trailer-light
      (pos (+ 130 (* 2.4 t)) 200)
      (radius 8)
      (color 180 180 200))
    (until (> t 120))))
```

[VISUAL: Car and light trailer — trailer lags slightly, but both move nearly together.]

```scheme
(motion
  (beat 70)
  (let ((t (frame)))
    (entity car
      (pos (+ 150 (* 2 t)) 240)
      (radius 10)
      (color 200 100 100))
    (entity trailer-heavy
      (pos (+ 120 (* 1.6 t)) 240)
      (radius 16)
      (color 100 100 100))
