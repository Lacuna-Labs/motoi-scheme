    (take 0.15 (shift (vec 28 3) (vec 45 -2)))
    (take 0.15 (shift (vec 45 -2) (vec 62 -8)))
    (take 0.15 (shift (vec 62 -8) (vec 78 1)))
    (take 0.15 (shift (vec 78 1) (vec 100 0)))))
