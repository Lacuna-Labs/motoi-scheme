### Ripple from center

Same grid, but the delay depends on distance from the center.

```scheme
(motion
  (define (rippler row col)
    (sprite
      (shape 'circle 10)
      (color 0.5 0.4 0.6 1.0)
      (route
        (let* ((x (+ 80 (* col 50)))
               (y (+ 80 (* row 50)))
               (cx 230)
               (cy 230)
               (dx (- x cx))
               (dy (- y cy))
               (dist (sqrt (+ (* dx dx) (* dy dy))))
               (delay (* dist 0.005)))
          (from (xy x y))
          (wait delay)
          (to (xy x (- y 20)) 0.2 'ease-out)
          (to (xy x y) 0.2 'ease-in)))))
  
  (world
    (spawn (rippler 0 0))
    (spawn (rippler 0 1))
    (spawn (rippler 0 2))
    (spawn (rippler 0 3))
    (spawn (rippler 1 0))
    (spawn (rippler 1 1))
    (spawn (rippler 1 2))
