### Crossroads

Four groups approaching from the cardinal directions, meeting at the center, then continuing.

```scheme
(motion
  (define (crosser direction idx)
    (sprite
      (shape 'circle 12)
      (color 0.5 0.5 0.6 1.0)
      (route
        (let ((offset (* idx 35)))
          (cond
            ((eq? direction 'north)
             (from (xy 300 500))
             (to (xy 300 (- 100 offset)) 2.5 'ease-in-out))
            ((eq? direction 'south)
             (from (xy 300 0))
             (to (xy 300 (+ 400 offset)) 2.5 'ease-in-out))
            ((eq? direction 'east)
             (from (xy 0 250))
             (to (xy (+ 500 offset) 250) 2.5 'ease-in-out))
            ((eq? direction 'west)
             (from (xy 600 250))
             (to (xy (- 100 offset) 250) 2.5 'ease-in-out)))))))
  
  (world
    (spawn (crosser 'north 0))
    (spawn (crosser 'north 1))
    (spawn (crosser 'south 0))
    (spawn (crosser 'south 1))
    (spawn (crosser 'east 0))
    (spawn (crosser 'east 1))
    (spawn (crosser 'west 0))
    (spawn (crosser 'west 1))))
```

