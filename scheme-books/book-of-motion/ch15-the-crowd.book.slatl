               (y-start (+ y-center (* (- row 1) spacing)))
               (x-end (+ x-center (* (- col 1) spacing 2)))
               (y-end (+ y-center (* (- row 1) spacing 2))))
          (from (xy x-start y-start))
          (to (xy x-end y-end) 1.5 'ease-out)))))
  
  (world
