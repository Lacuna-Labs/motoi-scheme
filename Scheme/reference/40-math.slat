(verb :name "truncate"        :library "math" :tier "core" :kind "pure" :signature "(truncate x) -> integer"
  :summary "Round toward zero. R7RS §6.2.6."
  :provenance "R7RS §6.2.6; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(truncate 3.7)" :note "3.0 — toward zero.")
    (:dialect "motoi" :tier "intermediate" :code "(truncate -3.7)" :note "-3.0 — toward zero, not down.")
  )
  :row-2-audit (
    (:problem "A trip-cost tracker rounds toward zero to get the integer dollar count." :program "(truncate 3.7)" :explanation "Returns 3.0." :meta "truncate is the correct verb (R7RS) for round-toward-zero. math/floor rounds toward -∞ — different at negatives.")
