(verb
  :name "math/lerp"
  :library "math"
  :kind "pure"
  :dialect "motoi"
  :signature "(math/lerp a b t) -> number"
  :arity "3"
  :contract "a and b real, t real (usually in [0,1] but not enforced) → number"
  :summary "Linear interpolation between a and b by parameter t. Returns a + (b-a)*t."
  :doc "At t=0 returns a; at t=1 returns b. Values of t outside [0,1] extrapolate (the function is affine in t). No clamping — use math/clamp on t first for a smoothed limit."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/lerp 0 100 0.25)" :note "Quarter of the way from 0 to 100. Returns 25.")
    (:dialect "motoi" :tier "intermediate" :code "(math/lerp 10 20 0.5)" :note "Midpoint. Returns 15.")
    (:dialect "motoi" :tier "expert" :code "(define (ease-in-out t) (let ((tt (* t t))) (/ tt (+ tt (* (- 1 t) (- 1 t))))))\n(math/lerp 0 200 (ease-in-out 0.3))" :note "Compose lerp with a nonlinear easing curve for animation. Returns about 32.7.")
  )
  :related ("math/clamp" "vec/lerp" "motion/lerp" "motion/ease")
  :row-2-audit (
    (:problem "An animation moves a slider from 0 to 100 over the middle of a frame." :program "(math/lerp 0 100 0.5)" :explanation "Linear interp between endpoints." :meta "math/lerp is the correct verb because linear interpolation names the intent. (+ a (* t (- b a))) works but is more error-prone.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
