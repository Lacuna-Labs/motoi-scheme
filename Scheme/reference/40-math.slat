(verb
  :name "math/pi"
  :library "math"
  :kind "value"
  :dialect "motoi"
  :signature "math/pi -> number"
  :arity "0 (constant)"
  :contract "Math.PI (approximately 3.141592653589793)"
  :summary "The mathematical constant π — the ratio of a circle's circumference to its diameter."
  :doc "A bound value, not a procedure. Use directly in numeric expressions. Rendered as an IEEE-754 double so 15-16 digits of precision are guaranteed. Equivalent to (* 2 (asin 1)) but faster."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "math/pi" :note "Evaluates to 3.141592653589793.")
    (:dialect "motoi" :tier "intermediate" :code "(* 2 math/pi 5)" :note "Circumference of a circle with radius 5: about 31.4159.")
    (:dialect "motoi" :tier "expert" :code "(define (deg->rad d) (* d (/ math/pi 180)))\n(deg->rad 90)" :note "Convert 90 degrees to radians: about 1.5708 (= π/2).")
  )
  :related ("math/tau" "math/e" "const/pi" "geom/->radians")
  :row-2-audit (
    (:problem "A geometry lesson needs π to compute a circle circumference." :program "(define (circ r) (* 2 math/pi r))
(circ 5)" :explanation "Multiply by 2r." :meta "math/pi is the correct verb because it names the constant. Hardcoding 3.14159 is a common source of magic-number bugs.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: named mathematical constant."
     :rungs (
       (:domain "math/*" :code "math/pi")
       (:domain "gravity constant (a metaphor domain — named physical constant g)" :code "(define g 9.81)")
       (:domain "math — π as the ratio C/D of any circle" :code "(define pi-def 3.14159)")
     )
     :explanation "Each rung binds a well-known ratio to a name."
     :meta "The shape transfers because named universal constants are universal in scientific code.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "math/pi is between 3 and 4." :program "(and (< 3 math/pi) (< math/pi 4))" :invariant "3 < π < 4" :meta "Value bracket. If broken, the constant is corrupt. See book-of-math ch 4.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
