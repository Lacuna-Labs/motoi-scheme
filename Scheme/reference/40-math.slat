(verb
  :name "math/floor"
  :library "math"
  :kind "pure"
  :dialect "motoi"
  :signature "(math/floor x) -> integer"
  :arity "1"
  :contract "any real → largest integer ≤ x"
  :summary "The greatest integer less than or equal to x."
  :doc "Rounds toward negative infinity, not toward zero. (math/floor -2.3) is -3, NOT -2. Use math/truncate for round-toward-zero."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/floor 3.7)" :note "Returns 3.")
    (:dialect "motoi" :tier "intermediate" :code "(math/floor -2.3)" :note "Returns -3 (down toward -∞, not toward zero).")
    (:dialect "motoi" :tier "expert" :code "(define (bin x width) (* width (math/floor (/ x width))))\n(bin 17 5)" :note "Snap x to the largest multiple of width ≤ x. Returns 15.")
  )
  :related ("math/ceil" "math/round" "math/truncate" "math/mod")
  :row-2-audit (
    (:problem "A pagination system needs to know which page an item lands on: item 47, 10 per page → page 4 (0-indexed)." :program "(define (page item per) (math/floor (/ item per)))
(page 47 10)" :explanation "Divide and round down." :meta "math/floor is the correct verb because pagination rounds down. math/round would give 5 for item 45.")
