(verb
  :name "math/tau"
  :library "math"
  :kind "value"
  :dialect "motoi"
  :signature "math/tau -> number"
  :arity "0 (constant)"
  :contract "2 * Math.PI (approximately 6.283185307179586)"
  :summary "The circle constant τ = 2π — the ratio of a circle's circumference to its radius."
  :doc "A bound value, not a procedure. Preferred over 2π when a full-turn factor makes intent clearer (e.g. (* freq math/tau) for angular frequency)."
