;;; 40-math.slat — Motoi Scheme Reference · Chapter 40 · library math
;;;
;;; 49 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library math — 49 verbs.")

(chapter :number "40" :library "math" :verb-count 49 :training-eligible #t)

;; ═══ 49 verbs in library math ═══

(verb
  :name "math/area-model"
  :library "math"
  :kind "meta"
  :signature "(math/area-model a b) -> spec-object"
  :summary "Generate a partial-products (area-model) spec for visualizing 2-digit × 2-digit multiplication."
  :explanation "The area model is a foundational math-teaching tool: it breaks a two-digit multiplication (like 23 × 45) into four smaller rectangles (20×40, 20×5, 3×40, 3×5), showing that multiplication is really just combining areas. This builds intuition for the distributive property and algorithmic multiplication. The spec returned is an object that a rendering system can display as a grid of rectangles with labels and partial products."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/area-model 10 10)\n;; => spec for 10×10 = 100 in four equal rectangles of 25" :note "Simplest case: 10 × 10 breaks into 10×10 (since both are single digit when split)")
    (:dialect "motoi" :tier "intermediate" :code "(math/area-model 23 45)\n;; => spec with four boxes:\n;;   20×40=800, 20×5=100, 3×40=120, 3×5=15\n;;   Total: 800+100+120+15 = 1035" :note "Classic two-digit case: 23 × 45 shown as partial products that sum to 1035")
    (:dialect "motoi" :tier "expert" :code "(define spec (math/area-model 37 82))\n;; spec is a rendering spec; pass it to a visualization system:\n;; (display spec)  ;; or render it in a card/canvas\n;; Students see 30×80, 30×2, 7×80, 7×2 as visual rectangles\n;; and confirm: 2400 + 60 + 560 + 14 = 3034" :note "Used in elementary-school instruction to build place-value intuition; the visual rectangle model makes distributive property concrete")
  )
  :caveats ("Input must be positive integers (typically 10–99 for 2-digit); behavior on 1-digit or 3-digit numbers is unspecified (*[verify]*)" "The spec format is opaque; it is meant for rendering, not for arithmetic computation" "Does not perform the actual multiplication; only generates a visualization spec")
  :drawbacks ("Only works for 2-digit × 2-digit; no generalization to 3-digit or mixed-size" "Spec object is not human-readable; requires a rendering system to visualize" "Not suitable for actual computation; use `*` for that")
  :usecases ("Elementary mathematics education: teaching multi-digit multiplication conceptually" "Tutoring systems: showing worked examples of the area model" "Interactive whiteboards or learning cards: rendering visual multiplication models" "Checking student understanding of place value and distributive property")
  :related ("math/array" "math/expanded-form" "math/fraction-bar" "math/integer-line" "*")
  :learn (:concept "Area model visualizes multiplication as combining rectangular regions, concretizing the distributive property" :prerequisites ("math/expanded-form" "math/place-value") :progression "Start with math/array, then math/expanded-form, then math/area-model; these build from concrete to abstract multiplication models")
  :row-2-audit (
    (:problem "A tutor needs to show a student how 23×45 = 1035 is really four partial products." :program "(define spec (math/area-model 23 45))
(display spec)" :explanation "Build the area-model spec once; render it on a card. Student sees 20×40=800, 20×5=100, 3×40=120, 3×5=15 → 1035." :meta "math/area-model is the correct verb because it emits a rendering spec, not a numeric result. Multiplication would just give 1035; the pedagogy is in the four partial products.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: distributive-law expansion — a product-of-sums broken into a grid."
     :rungs (
       (:domain "math/*" :code "(math/area-model 23 45)")
       (:domain "packing boxes (a metaphor domain — split a big box into small ones by dividing a shelf)" :code "(define (grid rows cols) (list rows cols)))")
       (:domain "math — (a+b)(c+d) = ac + ad + bc + bd" :code "(define (distribute a b c d) (list a b c d)))")
     )
     :explanation "Each rung expands a product into a sum of four smaller products."
     :meta "The shape transfers because the distributive law is a universal ring identity.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "The four partial products always sum to the true product." :program "(define t1 (* 23 45))
(define t2 (+ (* 20 40) (* 20 5) (* 3 40) (* 3 5)))
(= t1 t2)" :invariant "∀ (a1a0), (b1b0) two-digit. product = a1·b1·100 + a1·b0·10 + a0·b1·10 + a0·b0" :meta "Distributivity of multiplication over addition. If broken, the model would show an inconsistent product. See book-of-math ch 3 (place value and distribution).")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain area-model with student work to grade correctness." :composition "(define (grade-area-model a b student-total)
  (list 'model (math/area-model a b) 'correct (= student-total (* a b))))
(grade-area-model 23 45 1035)" :emergent "spec-plus-grader: visualization and correctness check side-by-side." :meta "Belongs to the family of pedagogical scaffolding patterns. See book-of-composition ch 15.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "math/array"
  :library "math"
  :kind "meta"
  :signature "(math/array rows cols) -> spec-object"
  :summary "Generate an array model spec: a rectangular grid of rows × cols cells, useful for visualizing multiplication and division."
  :explanation "The array model (or multiplication array) is one of the earliest multiplication visuals: a rectangular arrangement of dots or cells that makes the commutative property (3×4 = 4×3) visible. A 3×4 array has the same 12 cells whether arranged as 3 rows of 4 or 4 rows of 3. This spec generates the description; a rendering system displays the actual grid. Arrays also support division (12 cells in a 3-wide array = 4 rows) and repeated addition intuition."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/array 2 3)\n;; => spec for a 2-row, 3-column grid (6 cells total)" :note "Smallest non-trivial case: 2×3 array shows 6 cells; 2+2+2 = 6 or 3+3 = 6")
    (:dialect "motoi" :tier "intermediate" :code "(math/array 4 5)\n;; => spec for a 4×5 grid (20 cells)\n;; Visualizes 4×5 = 20 and also 5×4 = 20 (same cells, different orientation)" :note "Demonstrates commutativity: rotating the grid doesn't change the total")
    (:dialect "motoi" :tier "expert" :code "(define grid-spec (math/array 6 7))\n;; grid-spec describes a 6×7 array with 42 cells\n;; Pass to rendering: students see 6 rows of 7, or equivalently 7 rows of 6\n;; Also useful for division: \"How many rows of 7 cells fill 42?\" → 6" :note "Foundation for both multiplication and division instruction; same model, different questions")
  )
  :caveats ("Both rows and cols must be positive integers; zero or negative values are unspecified (*[verify]*)" "Spec is for visualization only; the verb does not compute the total (use `*` for that)" "Large arrays (e.g., 100×100) may produce heavy specs; no optimization for sparse or factored rendering")
  :drawbacks ("No direct way to highlight or label partial products (use math/area-model for that)" "Does not support non-rectangular arrangements" "Spec format is opaque and tool-dependent")
  :usecases ("Early childhood and elementary education: introducing multiplication as repeated rows/columns" "Teaching commutativity: showing 3×4 and 4×3 as the same cells rearranged" "Division intuition: 'How many rows of 5 make 20?' → 4" "Interactive learning cards or worksheets")
  :related ("math/area-model" "math/skip-count" "math/expanded-form" "*" "/")
  :learn (:concept "Arrays model multiplication as a rectangular grid, making commutativity and grouping visible" :prerequisites ("math/skip-count" "*") :progression "Start with math/array for concrete multiplication; advance to math/area-model for multi-digit, then to symbolic algebra")
  :row-2-audit (
    (:problem "A tutor needs to show 3×4=12 as a rectangular grid to introduce multiplication." :program "(define spec (math/array 3 4))
spec" :explanation "Emit a grid spec that renders as 3 rows of 4 dots." :meta "math/array is the correct verb because it emits a spec, not a number. The learning is in seeing the grid; * would just show 12.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: rectangular arrangement of a count."
     :rungs (
       (:domain "math/*" :code "(math/array 3 4)")
       (:domain "egg carton (a metaphor domain — 3 rows of 4 slots = 12 eggs)" :code "(define (carton rows slots) (list rows slots)))")
       (:domain "math — Cartesian product |A × B| = |A|·|B|" :code "(define (cart-count na nb) (* na nb))")
     )
     :explanation "Each rung shows a count as rows times columns."
     :meta "The shape transfers because the arithmetic identity |A × B| = |A|·|B| is universal.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "A rows×cols array visualizes the same count regardless of orientation." :program "(define t1 (* 3 4))
(define t2 (* 4 3))
(= t1 t2)" :invariant "∀ m n ∈ ℕ. m·n = n·m" :meta "Commutativity of multiplication. If broken, the model fails to teach that flipping the array does not change the count. See book-of-math ch 3.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain array with skip-count to reveal the connection to repeated addition." :composition "(define (array-with-skip rows cols)
  (list 'array (math/array rows cols)
        'skip (math/skip-count 0 cols rows)))
(array-with-skip 3 4)" :emergent "dual-representation: same count, two forms." :meta "Belongs to the family of parallel-representation patterns. See book-of-composition ch 15.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "math/avg"
  :library "math"
  :kind "pure"
  :signature "(math/avg lst) -> number | 'nan"
  :summary "Compute the arithmetic mean of a list of numbers."
  :explanation "Returns the sum of all numbers in lst divided by the list length. An empty list returns 'nan (a Scheme symbol, not a floating-point NaN). This is a pure function: the same input always produces the same output. Use it for averaging measurements, smoothing data, or computing center-of-mass. It is a common building block for statistics and physics simulations."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/avg (list 1 2 3 4 5))" :note "Average of 1..5 is 3.")
    (:dialect "motoi" :tier "intermediate" :code "(define (smooth-positions positions)\n  (let ((x-vals (map (lambda (p) (list-ref p 'x)) positions))\n        (y-vals (map (lambda (p) (list-ref p 'y)) positions)))\n    (list 'x (math/avg x-vals) 'y (math/avg y-vals))))\n(smooth-positions (list (list 'x 10 'y 20) (list 'x 30 'y 40)))" :note "Extract coordinates, average them separately, and return a center point.")
    (:dialect "motoi" :tier "expert" :code "(define (take xs n)\n  (let loop ((xs xs) (n n) (acc '()))\n    (if (or (zero? n) (null? xs))\n        (reverse acc)\n        (loop (cdr xs) (- n 1) (cons (car xs) acc)))))\n(define (adaptive-threshold readings window-size)\n  (let loop ((readings readings)\n            (window (list))\n            (thresholds (list)))\n    (if (null? readings)\n      (math/avg thresholds)\n      (let* ((new-window (cons (car readings) (if (>= (length window) window-size)\n                                                   (take window (- window-size 1))\n                                                   window)))\n             (threshold (math/avg new-window)))\n        (loop (cdr readings) new-window (cons threshold thresholds))))))\n(adaptive-threshold (list 10 12 11 9 8 15 14 13) 3)" :note "Use math/avg in a rolling window to compute adaptive thresholds.")
  )
  :caveats ("Empty list returns 'nan (not an error); always check for this in downstream code." "Does not distinguish between integer and floating-point inputs; result is always a number." "Very large lists or very large numbers may lose precision (IEEE 754 limits)." "No trimming or outlier removal; use a filter if you need to exclude extremes.")
  :drawbacks ("Sensitive to outliers; a single very large or small value skews the result." "Cannot average mixed types; all list members must be numbers." "No weighted average variant in this verb; use map + fold for custom weighting.")
  :usecases ("Computing average position in physics (center of mass)." "Smoothing sensor data or audio samples." "Calculating mean response time or score across multiple runs." "Determining a default or baseline value from measurements.")
  :related ("math/sum" "math/pct" "math/round" "fold-left" "map")
  :learn (:concept "Fold-based aggregation: reducing a list to a single summary value." :prerequisites ("fold-left" "list") :progression "Master math/avg, then learn math/pct and stat/mode for richer aggregations.")
  :row-2-audit (
    (:problem "A game samples the player's position each frame; the operator needs the average x to plot a heat-map center." :program "(define (avg-x positions)
  (math/avg (map car positions)))
(avg-x '((10 5) (20 7) (30 9)))" :explanation "Extract x-coords, then average. If empty, get 'nan — check downstream." :meta "math/avg is the correct verb because it's a named aggregation with explicit nan-on-empty semantics. Manually summing and dividing loses the safety check.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: aggregate — reduce a list to a summary scalar."
     :rungs (
       (:domain "math/*" :code "(math/avg '(1 2 3 4 5))")
       (:domain "class average (a metaphor domain — mean of student scores)" :code "(define (class-mean scores) (list 'mean scores))")
       (:domain "math — arithmetic mean (Σx)/n" :code "(define (mean-of xs) (/ (apply + xs) (length xs)))")
     )
     :explanation "Each rung folds a list into one scalar."
     :meta "The shape transfers because arithmetic mean is universal.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "Average is invariant under permutation of the list." :program "(< (abs (- (math/avg '(1 2 3 4 5)) (math/avg '(5 4 3 2 1)))) 1e-9)" :invariant "∀ list xs. avg(xs) = avg(perm(xs))" :meta "Symmetry of the arithmetic mean. If broken, the fold is not commutative. See book-of-math ch 8 (statistics).")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "Chain avg with map for a moving average." :composition "(define (moving-avg data window)
  (list 'window-mean (math/avg (list-head data window))))
(moving-avg '(1 2 3 4 5 6) 3)" :emergent "moving-summary: mean over a sliding window." :meta "Belongs to the family of window-aggregation patterns: same family as SQL window functions. See book-of-composition ch 7.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "math/compare"
  :library "math"
  :kind "meta"
  :signature "(math/compare x y) -> symbol"
  :summary "Returns the ordering symbol '< '= or '> indicating the relationship between two numbers."
  :explanation "Compares two numbers and returns a quoted symbol representing their order. This is a foundational tool for teaching relational thinking: when you need to know not just whether numbers differ, but *how* they differ. Use this when building number-sense lessons or decision trees that branch on magnitude. The return value is always one of the three symbols, never a boolean."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/compare 5 8)" :note "Returns '< because 5 is less than 8")
    (:dialect "motoi" :tier "intermediate" :code "(define y 'y)\n(define x 0)\n(cond ((equal? (math/compare x y) '<) (display \"x is smaller\"))\n      ((equal? (math/compare x y) '=) (display \"equal\"))\n      (else (display \"x is larger\")))" :note "Dispatch lesson logic based on the comparison result")
    (:dialect "motoi" :tier "expert" :code "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (order-numbers lst)\n  (if (null? (cdr lst))\n    lst\n    (let ((pivot (car lst))\n          (rest (cdr lst)))\n      (let ((smaller (filter (lambda (x) (equal? (math/compare x pivot) '<)) rest))\n            (larger (filter (lambda (x) (equal? (math/compare x pivot) '>)) rest)))\n        (append (order-numbers smaller) (list pivot) (order-numbers larger))))))" :note "Partition-based sort using compare as the ordering relation")
  )
  :caveats ("Returns a symbol, not a boolean—use equal? to test the result, not if/then directly" "Requires both arguments to be numbers; non-numeric input escalates" "Floating-point equality may exhibit IEEE rounding artifacts at extreme precision")
  :drawbacks ("Three-way result is more verbose than a boolean < or ≥; use bare < > = operators if you only need true/false" "Useful mainly in pedagogical contexts; production code typically uses native comparators")
  :usecases ("Teaching number comparison and ordering in elementary contexts" "Building decision trees that classify numbers into bins" "Constructing visual representations (number lines, bar charts) that show relative magnitude")
  :related ("math/digit-at" "math/number-line" "math/integer-line")
  :learn (:concept "Three-way relational comparison as a symbolic operation" :prerequisites ("core forms: equal?, cond") :progression "After mastering compare, move to math/integer-line to visualize those relationships on a number-line model")
  :row-2-audit (
    (:problem "A tutorial lesson branches based on the relative size of two student answers." :program "(define (feedback x y)
  (cond ((equal? (math/compare x y) '<) 'too-small)
        ((equal? (math/compare x y) '=) 'exact)
        (else 'too-big)))
(feedback 5 8)" :explanation "Dispatch on the symbolic comparison result." :meta "math/compare is the correct verb for three-way branching. Using two < comparisons is possible but math/compare captures the pedagogy: relations are three-way.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: three-way ordering."
     :rungs (
       (:domain "math/*" :code "(math/compare 5 8)")
       (:domain "tournament (a metaphor domain — team A vs team B: win, tie, or lose)" :code "(define (result a b) (cond ((> a b) 'win) ((= a b) 'tie) (else 'lose))))")
       (:domain "math — trichotomy: for any two reals x, y exactly one of x < y, x = y, x > y" :code "(define (trichotomy x y) (list x y))")
     )
     :explanation "Each rung classifies a pair into three exhaustive categories."
     :meta "The shape transfers because trichotomy is a fundamental order-theoretic property.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "compare is antisymmetric: compare(x,y) inverts under argument swap." :program "(define c1 (math/compare 3 7))
(define c2 (math/compare 7 3))
(and (equal? c1 '<) (equal? c2 '>))" :invariant "∀ x y ∈ ℝ. compare(x,y) = '< ⇔ compare(y,x) = '>" :meta "Antisymmetry of the order relation. If broken, the ordering is being conflated. See book-of-math ch 8.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain compare with equality dispatch for a quicksort partition." :composition "(define (partition pivot xs)
  (let loop ((xs xs) (less '()) (more '()))
    (if (null? xs) (list less more)
        (if (equal? (math/compare (car xs) pivot) '<)
            (loop (cdr xs) (cons (car xs) less) more)
            (loop (cdr xs) less (cons (car xs) more))))))
(partition 5 '(3 8 1 9 4))" :emergent "ordering-partition: compare drives a bipartition." :meta "Belongs to the family of divide-and-conquer partition patterns. See book-of-composition ch 7.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "math/count-on"
  :library "math"
  :kind "meta"
  :signature "(math/count-on start n) -> list"
  :summary "Returns a list of n consecutive integers starting from start."
  :explanation "Generates a finite arithmetic sequence by counting forward from a starting point. This is a teaching verb for building number sense and understanding successor relationships. Where a loop or range-builder might hide the structure, count-on makes the sequence explicit and visible. Perfect for scaffolding exercises where learners see all the numbers they're counting, or for building lookup tables and reference lists."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/count-on 3 5)" :note "Returns (3 4 5 6 7)—five numbers starting at 3")
    (:dialect "motoi" :tier "intermediate" :code "(define (addition-table start rows)\n  (map (lambda (n) (+ n start))\n       (math/count-on 0 rows)))" :note "Build a column of an addition table by mapping +start over a count")
    (:dialect "motoi" :tier "expert" :code "(define (skip-count-tableau base limit)\n  (let ((steps (math/count-on 1 (quotient limit base))))\n    (map (lambda (k) (* k base)) steps)))" :note "Generate skip-count sequences (multiples) for different bases in a multiplication tableau")
  )
  :caveats ("n is the length of the list, not the endpoint; (math/count-on 5 3) gives (5 6 7), not (5 6 7 8)" "Negative n or zero n returns an empty list (honest behavior, not an error)" "Large n values may consume significant memory; avoid count-on for tens of thousands of elements")
  :drawbacks ("Not a general range tool; use for pedagogy and small-scale sequences" "Strictly ascending; to count backward, negate the result or use math/skip-count with negative step")
  :usecases ("Generating a visible counting sequence for early-numeracy lessons" "Building lookup tables and reference grids in math-teaching contexts" "Creating scaffolding lists for guided practice (e.g., 'count these numbers aloud')")
  :related ("math/skip-count" "math/integer-line" "seq/arithmetic")
  :learn (:concept "Sequence generation as a transparent, teachable operation" :prerequisites ("core forms: map, lambda") :progression "Graduate to math/skip-count to explore non-unit steps; then seq/arithmetic for symbolic arithmetic progressions")
  :row-2-audit (
    (:problem "A first-grade lesson needs to display '3, 4, 5, 6, 7' — counting on by 1 from 3." :program "(define (skip-forward start n) (math/count-on start n))
(skip-forward 3 5)" :explanation "Produce the five consecutive integers as a list." :meta "math/count-on is the correct verb because it names the pedagogy 'counting on'. iota+offset works but the named verb is auditable.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
