  :examples (
    (:dialect "motoi" :tier "novice" :code "math/tau" :note "Evaluates to 6.283185307179586.")
    (:dialect "motoi" :tier "intermediate" :code "(= math/tau (* 2 math/pi))" :note "By definition τ = 2π. Returns #t.")
    (:dialect "motoi" :tier "expert" :code "(define (rotate-full-turn theta) (modulo (+ theta math/tau) math/tau))" :note "Wrap an angle into [0, τ) — the canonical positive-radian range.")
  )
  :related ("math/pi" "math/e" "const/tau")
