(verb
  :name "math/clamp"
  :library "math"
  :kind "pure"
  :dialect "motoi"
  :signature "(math/clamp x lo hi) -> number"
  :arity "3"
  :contract "x, lo, hi real with lo <= hi → number in [lo,hi]"
  :summary "Clip x into the closed interval [lo, hi]."
  :doc "Returns lo if x < lo, hi if x > hi, else x. If lo > hi the behavior is Math.min(hi, Math.max(lo, x)) which returns hi."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/clamp 15 0 10)" :note "15 exceeds the upper bound, clamped to 10.")
    (:dialect "motoi" :tier "intermediate" :code "(math/clamp -3 0 100)" :note "-3 below the lower bound, clamped to 0.")
    (:dialect "motoi" :tier "expert" :code "(define (health-percent hp) (math/clamp (/ hp 100.0) 0 1))\n(health-percent 137)" :note "Normalize a health value into [0,1] for a UI bar. Returns 1.")
  )
  :related ("math/lerp" "math/min" "math/max")
  :row-2-audit (
    (:problem "A slider input must stay within [0, 100] regardless of user drag." :program "(math/clamp 137 0 100)" :explanation "Clip to the range → 100." :meta "math/clamp is the correct verb. Manual (max lo (min hi x)) works but the named verb is auditable.")
