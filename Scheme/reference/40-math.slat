       (:domain "calendar days (a metaphor domain — five days starting Monday)" :code "(define (days-from monday n) (list monday n)))")
       (:domain "math — arithmetic progression with step 1" :code "(define (ap-1 start n) (list start n))")
     )
     :explanation "Each rung generates n consecutive successors from a start."
     :meta "The shape transfers because successor iteration is the primitive of counting.")
