(verb
  :name "math/sqrt"
  :library "math"
  :kind "pure"
  :dialect "motoi"
  :signature "(math/sqrt x) -> number"
  :arity "1"
  :contract "x >= 0 → real; x < 0 → NaN (no complex support at this layer)"
  :summary "Principal square root of x."
  :doc "Delegates to Math.sqrt. For negative inputs the result is NaN, not a complex number — use complex/sqrt if you need complex results. Exact-arithmetic fallback is NOT provided here; use nt/isqrt for integer roots."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/sqrt 16)" :note "Returns 4.")
    (:dialect "motoi" :tier "intermediate" :code "(math/sqrt 2)" :note "Returns 1.4142135623730951 — an irrational, so IEEE-754 rounded.")
    (:dialect "motoi" :tier "expert" :code "(define (pythag a b) (math/sqrt (+ (* a a) (* b b))))\n(pythag 3 4)" :note "Hypotenuse of a 3-4-? right triangle: 5. Consider math/hypot for numerical stability with tiny/huge inputs.")
  )
  :related ("math/cbrt" "math/hypot" "nt/isqrt" "complex/sqrt")
  :row-2-audit (
    (:problem "The operator needs the length of the diagonal of a 3×4 rectangle." :program "(define (diag a b) (math/sqrt (+ (* a a) (* b b))))
(diag 3 4)" :explanation "Sum of squares, then sqrt." :meta "math/sqrt is the correct verb. math/pow(x, 0.5) works but sqrt is direct and often faster.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: principal inverse of squaring."
     :rungs (
       (:domain "math/*" :code "(math/sqrt 16)")
       (:domain "standard deviation (a metaphor domain — sqrt of variance)" :code "(define (std v) (math/sqrt v)))")
       (:domain "math — non-negative principal square root" :code "(define (sqrt-def x) (list x))")
     )
     :explanation "Each rung inverts squaring on the non-negative branch."
     :meta "The shape transfers because principal-inverse-of-x² is universal.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "sqrt(x)² = x for x ≥ 0." :program "(< (abs (- (* (math/sqrt 7) (math/sqrt 7)) 7)) 1e-9)" :invariant "∀ x ≥ 0. sqrt(x)² = x" :meta "Right inverse of squaring. If broken, precision drift. See book-of-math ch 10.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain sqrt with sum-of-squares for a distance." :composition "(define (dist a b) (math/sqrt (+ (* a a) (* b b))))
