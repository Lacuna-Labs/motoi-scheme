(verb
  :name "math/round"
  :library "math"
  :kind "meta"
  :signature "(math/round n decimals) -> number"
  :summary "Round n to a given number of decimal places using half-away-from-zero rule."
  :explanation "Rounding is essential for display and comparison. This verb rounds to a fixed number of decimal places using the half-away-from-zero strategy: if the digit to be discarded is 5 or greater, round away from zero (up for positive, down for negative). For example, 2.345 rounded to 2 decimal places is 2.35, and -2.345 rounded to 2 places is -2.35. This is more predictable for teaching than banker's rounding (round-to-even)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/round 3.14159 2)" :note "Returns 3.14 — truncated and rounded to two decimal places.")
    (:dialect "motoi" :tier "intermediate" :code "(define (format-price cents)\n  (math/round (/ cents 100) 2))\n(display (format-price 1049))" :note "Convert cents to dollars and round; common in e-commerce or shoppe contexts.")
    (:dialect "motoi" :tier "expert" :code "(define (grade-with-curve raw-score scale factor)\n  (let ((adjusted (+ raw-score (* scale factor))))\n    (math/round adjusted 1)))\n(grade-with-curve 87 0.5 2)" :note "Apply a formula, then round to one decimal place for consistent display.")
  )
  :caveats ("Rounds half away from zero, not toward even (banker's rounding); -2.5 rounds to -3, not -2." "If decimals is 0, rounds to the nearest integer." "If decimals is negative, *[verify]* rounding behavior (e.g., (math/round 1234 -1) may round to nearest 10)." "Floating-point precision issues may arise with very large numbers or many decimal places.")
  :drawbacks ("Does not truncate; use (floor n) or (quotient n) if you need strict truncation." "Does not format as a string; compose with (display) or (format) for string output." "Expensive for many rounding operations in a tight loop; cache if possible.")
  :usecases ("Price formatting and currency display." "Grade reporting and score display." "Scientific or statistical output (confidence intervals, p-values)." "UI labels and dashboards requiring fixed precision.")
  :related ("math/pct" "math/round-to-place" "math/avg")
  :learn (:concept "Decimal rounding and half-away-from-zero rule." :prerequisites ("(core)/number?" "(core)/expt" "(core)/quotient") :progression "After learning math/round, study math/round-to-place to understand place-magnitude rounding (10s, 100s), then explore exact/float->rat for exact rational arithmetic.")
  :row-2-audit (
    (:problem "A price display needs π rounded to 2 decimal places." :program "(math/round 3.14159 2)" :explanation "Round to 2 decimals." :meta "math/round is the correct verb because it rounds half-away-from-zero, which is the intuitive rule. Banker's rounding would flip on 0.5 boundaries.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: precision truncation with rounding."
     :rungs (
       (:domain "math/*" :code "(math/round 3.14159 2)")
       (:domain "supermarket prices (a metaphor domain — items priced to two decimal cents)" :code "(define (price cents) (list cents)))")
       (:domain "math — approximation to a fixed precision" :code "(define (approx x p) (list x p))")
     )
     :explanation "Each rung truncates precision to a fixed number of digits."
     :meta "The shape transfers because 'to N places' is a universal presentation operation.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "The error is bounded by half the place unit." :program "(< (abs (- (math/round 3.14159 2) 3.14159)) 0.005)" :invariant "∀ x ∈ ℝ, k ∈ ℕ. |round(x, k) − x| ≤ 0.5·10^(-k)" :meta "Rounding error bound. If broken, precision guarantee is wrong. See book-of-math ch 10.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain round with a formatter for currency display." :composition "(define (dollar-format cents)
  (string-append \"$\" (number->string (math/round (/ cents 100) 2))))
(dollar-format 1049)" :emergent "round-then-format." :meta "Belongs to the family of presentation pipelines. See book-of-composition ch 15.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "math/round-half-up"
  :library "math"
  :kind "meta"
  :signature "(math/round-half-up x places) -> number"
  :summary "Rounds x to the specified number of decimal places using round-half-up (classical rounding)."
  :explanation "Rounding approximates a number to a simpler form with fewer decimal places. Round-half-up (also called 'commercial rounding' or 'round half away from zero') rounds .5 up: 2.5 becomes 3, 2.4 becomes 2, 2.6 becomes 3. This is the most intuitive rounding for most people. The places argument specifies the number of decimal places: places=0 rounds to an integer, places=1 rounds to one decimal place, places=−1 rounds to the nearest ten, etc. Returns an inexact floating-point number."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/round-half-up 3.7 0)" :note "Rounds 3.7 to 0 decimal places (nearest integer) = 4.")
    (:dialect "motoi" :tier "intermediate" :code "(define cost 'cost)\n(define (price-from-cost markup-pct)\n  (let ((gross (* cost (+ 1 (/ markup-pct 100)))))\n    (math/round-half-up gross 2)))\n(price-from-cost 10 15)" :note "Commerce: compute price with markup, then round to 2 decimal places (cents).")
    (:dialect "motoi" :tier "expert" :code "(define (summarize-measurements measurements)\n  (let ((mean (/ (apply + measurements) (length measurements))))\n    (list 'mean-exact mean\n          'mean-rounded (math/round-half-up mean 3))))\n(summarize-measurements (list 2.3456 2.3461 2.3454))" :note "Statistics: compute exact mean, then round for reporting.")
  )
  :caveats ("places can be negative (round to tens, hundreds, etc.); places=−1 rounds to nearest 10." "Rounding .5 always rounds away from zero (up for positive, down for negative)." "Floating-point representation errors may cause subtle rounding artifacts." "This is inexact: suitable for presentation, not for exact financial or critical calculations." "Successive rounding can accumulate error; round once at the end, not at intermediate steps.")
  :drawbacks ("Does not use banker's rounding (round-half-to-even), which some contexts prefer." "Floating-point precision limits effectiveness for very precise values." "Not suitable for exact rational arithmetic (use exact/* for precise fractional results)." "Rounding .5 away from zero can introduce upward bias in large datasets.")
  :usecases ("Formatting prices and monetary values to 2 decimal places." "Rounding measurements and scientific data for presentation." "Computing averages and summaries from noisy data." "Preparing output for display in user interfaces or reports.")
  :related ("math/round" "math/exp" "math/log" "math/pow" "exact/->float" "exact/->mixed")
  :learn (:concept "Round-half-up: classical rounding where .5 rounds away from zero." :prerequisites () :progression "Use math/round-half-up for basic rounding, then explore exact/* for precise fractional arithmetic, then consider banker's rounding or truncation for specialized contexts.")
  :row-2-audit (
    (:problem "A financial rounding needs to round 2.5 to 3 (not banker's 2)." :program "(math/round-half-up 2.5 0)" :explanation "Half rounds up (away from zero)." :meta "math/round-half-up is the correct verb when the domain demands commercial rounding. Banker's rounding is unpredictable in currency contexts.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: rounding rule variant."
     :rungs (
       (:domain "math/*" :code "(math/round-half-up 2.5 0)")
       (:domain "classroom grading (a metaphor domain — 89.5% rounds up to 90%)" :code "(define (grade-round g) (list g))")
       (:domain "math — round half away from zero" :code "(define (round-hu x) (list x))")
     )
     :explanation "Each rung specifies a rule for the .5 boundary."
     :meta "The shape transfers because rounding rules are a class of policy choices.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "Applied at places=0, half-up rounds 0.5 to 1, -0.5 to -1." :program "(and (= (math/round-half-up 0.5 0) 1) (= (math/round-half-up -0.5 0) -1))" :invariant "round-half-up(0.5, 0) = 1 ∧ round-half-up(-0.5, 0) = -1" :meta "Rule anchor. If broken, the sign handling is wrong. See book-of-math ch 10.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain half-up with markup for pricing." :composition "(define (price cost markup)
  (math/round-half-up (* cost (+ 1 (/ markup 100))) 2))
(price 10 15)" :emergent "commerce-rounding." :meta "Belongs to the family of policy-round pipelines. See book-of-composition ch 15.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "math/round-to-place"
  :library "math"
  :kind "meta"
  :signature "(math/round-to-place n place-magnitude) -> number"
  :summary "Round n to the nearest place magnitude (10, 100, 1000, etc.); not decimal places."
  :explanation "Place-magnitude rounding rounds to the nearest power of ten, rather than decimal places. For example, rounding 1234 to the nearest 100 gives 1200; rounding to the nearest 10 gives 1230. This is distinct from math/round, which rounds by decimal places. Place-magnitude rounding is useful for estimation, order-of-magnitude thinking, and student exercises in which the concept of place value is central."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/round-to-place 1234 100)" :note "Returns 1200 — rounded to the nearest hundred.")
    (:dialect "motoi" :tier "intermediate" :code "(define (estimate-population city-count)\n  (math/round-to-place (* city-count 50000) 100000))\n(estimate-population 12)" :note "Estimate total population, then round to nearest hundred-thousand for a rough figure.")
    (:dialect "motoi" :tier "expert" :code "(define (budget-line-item cost magnitude)\n  (let ((rounded (math/round-to-place cost magnitude)))\n    (cond ((equal? rounded 'nan) 'error)\n          ((> rounded cost) (list 'over rounded))\n          (else (list 'under rounded)))))\n(budget-line-item 1567 1000)" :note "Round a cost to a place magnitude, then classify as over or under the original cost.")
  )
  :caveats ("Expects a place magnitude (10, 100, 1000, …); passing arbitrary numbers yields *[verify]* results." "Returns 'nan if the magnitude is zero or invalid." "Negative magnitudes: behavior is *[verify]*." "Very large magnitudes may cause precision loss in floating-point representation.")
  :drawbacks ("More specialized than math/round; if you need decimal-place rounding, use math/round instead." "Does not handle bases other than 10; binary or hexadecimal rounding requires custom code." "Not suitable for fine-grained precision; use math/round if you need 0.01-unit accuracy.")
  :usecases ("Order-of-magnitude estimation exercises (how many students in the school?)." "Budget or cost approximation (round salaries to nearest 1000)." "Population, survey, or demographic reporting." "Simplifying large numbers for mental math and student intuition-building.")
  :related ("math/place-value" "math/round" "math/avg")
  :learn (:concept "Place-magnitude rounding vs. decimal rounding." :prerequisites ("(core)/number?" "math/place-value") :progression "Learn math/place-value first to understand place magnitudes, then study math/round-to-place for rounding by magnitude, and finally math/round for decimal-place precision.")
  :row-2-audit (
    (:problem "An estimator rounds a cost of 1567 to the nearest 100 for a rough budget." :program "(math/round-to-place 1567 100)" :explanation "Round to the nearest 100 → 1600." :meta "math/round-to-place is the correct verb for magnitude rounding. math/round handles decimals; this handles powers of 10.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: coarse-grained rounding."
     :rungs (
       (:domain "math/*" :code "(math/round-to-place 1567 100)")
       (:domain "estimating (a metaphor domain — nearest ten-thousand for a population)" :code "(define (est n place) (list n place))")
       (:domain "math — rounding on a lattice" :code "(define (round-lattice x k) (list x k))")
     )
     :explanation "Each rung snaps a value to a coarser grid."
     :meta "The shape transfers because 'snap to a lattice' is universal.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "The result is always a multiple of the magnitude." :program "(zero? (modulo (math/round-to-place 1567 100) 100))" :invariant "∀ n ∈ ℝ, m > 0. round-to-place(n, m) mod m = 0" :meta "Divisibility invariant. If broken, the impl is not truly snapping. See book-of-math ch 3.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain round-to-place with a category label." :composition "(define (bucket cost)
  (list 'bucket (math/round-to-place cost 1000)))
(bucket 1567)" :emergent "coarse-classifier." :meta "Belongs to the family of bucketization patterns. See book-of-composition ch 7.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "math/skip-count"
  :library "math"
  :kind "meta"
  :signature "(math/skip-count start step count) -> list"
  :summary "Produces a list of count multiples of step, starting from start: [start, start+step, start+2·step, …]."
  :explanation "Skip-counting is a foundational numeracy skill: counting forward in equal jumps. For instance, skip-counting by 5 from 0 gives [0, 5, 10, 15, 20, …]. This teaches multiplication as repeated addition and reinforces the number sequence. The verb returns a list of count terms, each step apart. It is a building block for understanding multiplication, multiples, and arithmetic sequences."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/skip-count 0 5 4)" :note "Count by 5s from 0: [0, 5, 10, 15]. Four terms, each incremented by 5.")
    (:dialect "motoi" :tier "intermediate" :code "(define (multiples-of n limit)\n  (let ((max-count (quotient limit n)))\n    (math/skip-count n n max-count)))\n(multiples-of 3 20)" :note "Generate multiples of 3 up to about 20: [3, 6, 9, 12, 15, 18].")
    (:dialect "motoi" :tier "expert" :code "(define (arithmetic-sequence first diff num-terms)\n  (math/skip-count first diff num-terms))\n(define (sum-arithmetic-sequence first diff num-terms)\n  (let ((sequence (arithmetic-sequence first diff num-terms)))\n    (apply + sequence)))\n(sum-arithmetic-sequence 2 3 5)" :note "Using skip-count to generate an arithmetic sequence, then summing. Sequence is [2, 5, 8, 11, 14]; sum is 40.")
  )
  :caveats ("step should be nonzero; step=0 produces an infinite loop or undefined behavior." "count must be non-negative; negative count produces an empty list or error." "start and step need not be integers; fractional skip-counts are valid but less common." "Large count values produce long lists; memory and computation time scale linearly.")
  :drawbacks ("Not efficient for very large count; produces the entire list in memory." "If used for very large sequences, memory usage can be prohibitive." "Returns concrete list; if only a few terms are needed, computing the entire sequence is wasteful.")
  :usecases ("Teaching multiplication and multiples in elementary mathematics." "Generating sequences for pattern recognition and arithmetic progression problems." "Building tables of multiples (e.g., times tables)." "Illustrating arithmetic sequences in algebra.")
  :related ("math/count-on" "math/number-line" "math/compare" "seq/arithmetic")
  :learn (:concept "Skip-counting: repeated addition in equal steps; foundation for multiplication and sequences." :prerequisites () :progression "Start with math/skip-count for concrete sequences, then explore seq/arithmetic for abstract arithmetic sequences, then move to multiplication and division.")
  :row-2-audit (
    (:problem "A multiplication-tables lesson needs the sequence 5, 10, 15, 20 (fives from 5)." :program "(math/skip-count 5 5 4)" :explanation "Generate the four multiples." :meta "math/skip-count is the correct verb because it names the 'skip by k' pedagogy. count-on with step=1 wouldn't help.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: arithmetic progression."
     :rungs (
       (:domain "math/*" :code "(math/skip-count 0 5 5)")
       (:domain "timetable (a metaphor domain — buses every 15 min from 9:00)" :code "(define (schedule start step count) (list start step count))")
       (:domain "math — arithmetic sequence a, a+d, a+2d, ..." :code "(define (ap a d n) (list a d n))")
     )
     :explanation "Each rung produces n terms of an arithmetic progression."
     :meta "The shape transfers because AP is a universal linear sequence generator.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "Difference between successive terms equals step." :program "(define terms (math/skip-count 0 5 5))
(define diffs (map - (cdr terms) terms))
(every? (lambda (d) (= d 5)) diffs)" :invariant "∀ start step count. adjacent diffs of skip-count(start, step, count) = step" :meta "Constant-first-difference. If broken, the impl introduces variance. See book-of-math ch 2.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain skip-count with map to build a multiplication row." :composition "(define (times-row base count) (math/skip-count base base count))
(times-row 7 5)" :emergent "sequence-generator: seeds a lesson row." :meta "Belongs to the family of arithmetic-sequence generators. See book-of-composition ch 7.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "math/sum"
  :library "math"
  :kind "meta"
  :signature "(math/sum lst) -> number | 'nan"
  :summary "Sum a list of numbers; empty lists or non-numeric elements return 'nan."
  :explanation "Summing a list is a frequent operation in data aggregation, scoring, and statistics. This verb folds addition over a list, starting from 0. If the list is empty, it returns 'nan. If any element is not a number, it returns 'nan, so you can trust that a non-'nan result is the sum of all numeric elements. This design makes it safe for untrusted or user-provided data."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(math/sum (list 1 2 3 4 5))" :note "Returns 15 — the sum of the first five positive integers.")
    (:dialect "motoi" :tier "intermediate" :code "(define (total-score cards)\n  (let ((scores (map (lambda (card) (card-get card 'points)) cards)))\n    (math/sum scores)))\n(total-score (list (list 'points 10) (list 'points 20) (list 'points 5)))" :note "Extract a field from each card, collect into a list, and sum; common in game or leaderboard logic.")
    (:dialect "motoi" :tier "expert" :code "(define t-get (lambda args (list \"t-get\" args)))\n(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (safe-revenue-sum transactions)\n  (let ((amounts (filter number? (map (lambda (t) (t-get 'amount t)) transactions))))\n    (let ((total (math/sum amounts)))\n      (cond ((equal? total 'nan) 0) (else total)))))\n(safe-revenue-sum (list (list 'amount 100) (list 'amount 200) (list 'amount 'pending)))" :note "Filter out non-numeric values before summing; if the filtered list is empty, return 0 instead of 'nan.")
  )
  :caveats ("Empty list returns 'nan, not 0; always check for 'nan before using the result." "Non-numeric elements cause 'nan; use (filter number? lst) to sanitize first." "Order of addition does not affect the result (addition is associative), but floating-point rounding may differ slightly depending on grouping." "Very long lists may accumulate floating-point rounding errors.")
  :drawbacks ("Does not provide a default value for empty lists; use (if (equal? (math/sum lst) 'nan) 0 (math/sum lst)) to substitute 0." "Slower for very large lists than a hand-written accumulator." "Does not filter; if you want only positive numbers or only above a threshold, filter before summing.")
  :usecases ("Totaling scores, points, or rewards in a game." "Aggregating revenues or expenses in a transaction log." "Computing total time spent across multiple tasks." "Summing sensor readings or measurements from multiple sources.")
  :related ("math/avg" "math/pct" "(core)/fold-left")
  :learn (:concept "Aggregation and folding over lists; handling undefined (empty) cases." :prerequisites ("(core)/list?" "(core)/number?" "(core)/fold-left") :progression "Learn math/sum for simple aggregation, then move to math/avg for averages, and finally to stat/mode for distribution analysis.")
  :row-2-audit (
    (:problem "A leaderboard totals scores across a game session." :program "(math/sum '(10 20 5 30))" :explanation "Sum the numbers." :meta "math/sum is the correct verb because it returns 'nan on empty or non-numeric, which is safer than (apply + xs). Silent bad data would go unnoticed with raw +.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: fold aggregation."
     :rungs (
       (:domain "math/*" :code "(math/sum '(1 2 3 4 5))")
       (:domain "expenses (a metaphor domain — sum monthly expenses to a total)" :code "(define (total xs) (list xs))")
       (:domain "math — Σx over a finite list" :code "(define (sigma xs) (apply + xs))")
     )
     :explanation "Each rung folds a list to a scalar via addition."
     :meta "The shape transfers because addition is the monoid operation of ℝ.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
