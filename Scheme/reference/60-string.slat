;;; 60-string.slat — Motoi Scheme Reference · Chapter 60 · library string
;;;
;;; 30 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library string — 30 verbs.")

(chapter :number "60" :library "string" :verb-count 30 :training-eligible #t)

;; ═══ 30 verbs in library string ═══

(verb
  :name "string-contains"
  :library "string"
  :tier "core"
  :kind "pure"
  :signature "(string-contains hay needle) -> integer | #f"
  :summary "Index of the first occurrence of needle in hay, or #f."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-contains \"hello world\" \"world\")" :note "6.")
    (:dialect "motoi" :tier "intermediate" :code "(if (string-contains msg \"URGENT\") (alert msg) (log msg))" :note "Branch on presence.")
  )
  :caveats ("Returns #f (not -1) on miss — Scheme convention.")
  :usecases ("Substring detection." "Prefix / infix tests.")
  :related ("string-index" "string-split")
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :row-2-audit (
    (:problem "The operator is filtering incoming log lines: those containing the substring 'URGENT' need to route to a pager. Candidates: string-contains (returns index or #f), string-index (returns index of a character), a regex library (overkill). For substring presence, string-contains is honest — one call, one boolean-shaped answer via truthiness of the return."
     :program "(define msg \"System stable. URGENT: disk 95%. Continue.\")\n(display (if (string-contains msg \"URGENT\") 'page 'ok))\n(newline)\n(display (string-contains msg \"URGENT\"))\n(newline)"
     :explanation "Line 1 defines a log line. Lines 2-3 branch on presence. Lines 4-5 print the actual index (14). The audit tape shows: one substring probe, one branch on truthiness."
     :meta "Why string-contains and not string-index: string-index takes a char or predicate, not a substring.")
    (:eng "Log the substring used and the reading; index makes downstream slicing easy."
     :math "The return is either an integer i such that s[i..i+|needle|] = needle, or #f."
     :cs "Related patterns: str.find in Python (returns -1 on miss), String.indexOf in Java. Scheme uses #f to distinguish 'not found' from a valid index 0."))
  :row-3-dimension (
    (:setup "A substring probe: search a haystack for a needle and report the position of the first match, or a not-found sentinel."
     :rungs ((:domain "string" :code "(string-contains msg \"URGENT\")")
             (:domain "shelf scan for a barcode prefix" :code "(scan-shelf shelf 'sku-42)")
             (:domain "prefix membership in a language" :code "(define (find-prefix s pfx) (if (string-prefix? pfx s) 0 #f))"))
     :explanation "In string, string-contains finds a substring. On a shelf, a scanner checks for a barcode match. In formal languages, prefix membership is a positional test. All three share: locate a smaller pattern inside a larger container, return a position or a not-found."
     :meta "The shape transfers wherever a substrate contains searchable subunits and clients need to locate the first hit."))
  :row-4-proof (
    (:claim "string-contains returns an integer i or #f; if i is an integer, then the substring of length |needle| starting at i equals needle."
     :program "(define hay \"hello world\")\n(define idx (string-contains hay \"world\"))\n(display (list 'idx idx))\n(newline)\n(display (equal? (substring hay idx (+ idx (string-length \"world\"))) \"world\"))\n(newline)\n(display (string-contains hay \"missing\"))\n(newline)"
     :invariant "∀ hay needle. let i = string-contains(hay, needle) in i = #f OR (i ∈ ℤ ∧ substring(hay, i, i+|needle|) = needle)"
     :meta "The pattern is match-position witness. CS pattern name: substring search. What would falsify: an index whose substring does not equal needle. See book-of-code ch05 on string algorithms."
     :eng "The engineering payoff is that the return value is either a slicing anchor or a definite no-match."
     :math "The relation is 'needle is a substring of hay starting at i.'"
     :cs "Naive substring search is O(|hay|·|needle|); efficient implementations use KMP or Boyer-Moore."))
  :row-5-emergence (
    (:base "string-contains locates a substring."
     :composition "(define (extract-after msg tag)\n  (let ((i (string-contains msg tag)))\n    (if i\n      (string-drop msg (+ i (string-length tag)))\n      #f)))\n(display (extract-after \"tag=42; more\" \"tag=\"))\n(newline)"
     :emergent "tag extractor — a routine that finds a tag and returns the content following it, or #f if not present"
     :meta "The composition chains string-contains with string-drop. What emerges is the extract-after-marker family: header parsing, protocol dissection, log-line field extraction. See book-of-composition ch04 on parser primitives."))
)

(verb :name "string-index" :library "string" :tier "core" :kind "pure" :signature "(string-index s char-or-pred) -> integer | #f"
  :summary "Index of the first character matching char-or-pred, or #f."
  :examples ((:dialect "motoi" :tier "novice" :code "(string-index \"hello\" \"l\")" :note "2."))
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :row-2-audit (
    (:problem "The operator has a URL-shaped string and needs the index of the first '=' to split the key from the value. Candidates: string-index (char probe), string-contains (substring probe — overkill here), a manual loop. For character-level position search, string-index is the honest verb."
     :program "(define kv \"key=42\")\n(define i (string-index kv \"=\"))\n(display (list 'key (string-take kv i) 'value (string-drop kv (+ i 1))))\n(newline)"
     :explanation "Line 1 defines a key=value string. Line 2 finds the '=' position (3). Lines 3-4 split by that index. The audit tape shows: one position probe, one take, one drop, no re-parse."
     :meta "Why string-index and not string-contains: string-index specializes to characters, avoiding a substring search when a char suffices.")
    (:eng "String-index is the primitive for character-boundary parsing."
     :math "Returns the smallest i such that pred(s[i]) is truthy, or #f."
     :cs "Related patterns: str.index in Python (raises on miss), String.indexOf(int) in Java."))
  :row-3-dimension (
    (:setup "A first-match probe with a predicate: scan a sequence, return the position of the first element matching, or a not-found sentinel."
     :rungs ((:domain "string" :code "(string-index s \" \")")
             (:domain "find first taxi with light on" :code "(first-taxi-with-light row)")
             (:domain "∃-first witness" :code "(define (find-first pred xs) (let loop ((i 0) (rest xs)) (cond ((null? rest) #f) ((pred (car rest)) i) (else (loop (+ i 1) (cdr rest))))))"))
     :explanation "In string, string-index probes characters. On a curb, finding the first available taxi is a predicate-first-match. In math, finding an existential witness returns a position. All three share: scan, first-match, return position."
     :meta "The shape transfers wherever an ordered container needs a predicate-based first-match witness."))
  :row-4-proof (
    (:claim "string-index returns the smallest i such that s[i] matches the predicate, or #f if no such i exists."
     :program "(define s \"hello\")\n(display (string-index s \"l\"))\n(newline)\n(display (string-index s \"z\"))\n(newline)\n(define i (string-index s \"l\"))\n(display (equal? (string-take (string-drop s i) 1) \"l\"))\n(newline)"
     :invariant "∀ s pred. let i = string-index(s, pred). i = #f OR (i is the smallest index with pred(s[i]))"
     :meta "The pattern is minimal-witness. CS pattern name: linear first-match. What would falsify: a larger-than-necessary index, or missing an earlier match. See book-of-code ch05."
     :eng "The engineering payoff is a definite anchor for downstream slicing."
     :math "The result is min{i | pred(s[i])} or ⊥."
     :cs "O(|s|) in the worst case; short-circuits on the first match."))
  :row-5-emergence (
    (:base "string-index finds the first character matching a predicate."
     :composition "(define (split-first s sep)\n  (let ((i (string-index s sep)))\n    (if i\n      (list (string-take s i) (string-drop s (+ i 1)))\n      (list s \"\"))))\n(display (split-first \"key=42=extra\" \"=\"))\n(newline)"
     :emergent "split-on-first — a routine that splits a string at the first occurrence of a separator, returning the two halves"
     :meta "The composition chains string-index with string-take and string-drop. What emerges is the first-split family: header/rest splits. Same shape as String.split(sep, 1) in Python. See book-of-composition ch04."))
)

(verb :name "string-split" :library "string" :tier "core" :kind "pure" :signature "(string-split s [sep]) -> list-of-string"
  :summary "Split s into parts on sep (default: whitespace)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-split \"a,b,c\" \",\")" :note "(\"a\" \"b\" \"c\").")
    (:dialect "motoi" :tier "intermediate" :code "(string-split \"one two three\")" :note "Default whitespace split: (\"one\" \"two\" \"three\").")
  )
  :related ("string-join" "string-contains")
  :provenance "SRFI-13-adjacent (Racket convention); added 2026-07-18 finalization"
  :row-2-audit (
    (:problem "The operator is parsing a comma-separated line from a CSV feed. Candidates: string-split (returns a list of fields), a manual loop with string-index (correct but noisier), string-contains (probe not slice). For CSV-like decomposition, string-split is the honest verb — one call, one list of fields."
     :program "(define row \"alice,38,seattle\")\n(define fields (string-split row \",\"))\n(display fields)\n(newline)\n(display (length fields))\n(newline)"
     :explanation "Line 1 defines a comma-separated row. Line 2 splits into three fields. Lines 3-4 print the fields and count. The audit tape shows one split, three fields."
     :meta "Why string-split and not a manual loop: split is one call and reads as intent, not as parser plumbing.")
    (:eng "Prefer string-split for delimiter-based row parsing; for complex quoting rules use a proper CSV library."
     :math "string-split partitions s into maximal non-separator runs."
     :cs "Related patterns: str.split in Python, String.split in Java, cut in Unix."))
  :row-3-dimension (
    (:setup "A delimiter-based partition: divide a sequence by a marker into maximal separator-free runs."
     :rungs ((:domain "string" :code "(string-split \"a,b,c\" \",\")")
             (:domain "chop a rope at knots" :code "(chop-at rope 'knot)")
             (:domain "equivalence-class partition" :code "(define (chunk pred xs) (fold-right (lambda (x acc) (if (pred x) (cons (list) acc) (cons (cons x (car acc)) (cdr acc)))) (list (list)) xs))"))
     :explanation "In string, split partitions on delimiters. Chopping a rope at knots yields rope-segments. In math, partitioning a sequence at markers yields equivalence-class-like chunks. All three share: a sequence divided by markers into runs."
     :meta "The shape transfers wherever a sequence with in-band delimiters must be reduced to its data-carrying runs."))
  :row-4-proof (
    (:claim "string-split with separator sep produces a list whose join by sep equals the original string; the count of parts equals count of separators + 1 (for one-char sep on non-empty input)."
     :program "(define src \"a,b,c\")\n(define parts (string-split src \",\"))\n(display (list 'parts parts 'joined (string-join parts \",\") 'roundtrip? (equal? src (string-join parts \",\"))))\n(newline)"
     :invariant "∀ s sep. string-join(string-split(s, sep), sep) = s"
     :meta "The pattern is split-join round-trip. CS pattern name: reversible partition. What would falsify: joining the split does not reconstruct the original. See book-of-code ch05."
     :eng "The engineering payoff is that split and join form a lossless round-trip for well-behaved inputs."
     :math "split and join are mutual inverses on non-empty separator-free-content."
     :cs "The count invariant is: parts = separators + 1 for non-empty input."))
  :row-5-emergence (
    (:base "string-split partitions on a separator."
     :composition "(define (parse-headers header-block)\n  (map (lambda (line) (string-split line \":\")) (string-split header-block \"\\n\")))\n(display (parse-headers \"host:example.com\\ncontent-type:text/html\"))\n(newline)"
     :emergent "line-then-field parser — two nested splits produce a list of (key value) pairs from a text block"
     :meta "The composition nests string-split twice. What emerges is the 2D-parser family: outer separator (lines) and inner separator (fields). Same shape as CSV parsing, as HTTP header parsing. See book-of-composition ch04."))
)

(verb :name "string-join" :library "string" :tier "core" :kind "pure" :signature "(string-join lst [sep]) -> string"
  :summary "Glue lst with sep (default space). Inverse of string-split."
  :examples ((:dialect "motoi" :tier "novice" :code "(string-join (list \"a\" \"b\" \"c\") \"-\")" :note "\"a-b-c\"."))
  :related ("string-split")
  :provenance "SRFI-13-adjacent; added 2026-07-18 finalization"
  :row-2-audit (
    (:problem "The operator has a list of strings and wants to combine them with a separator (like commas for CSV or slashes for URL paths). Candidates: string-join (single call with sep), (fold-right string-append init lst) (equivalent but noisier, and needs care not to put a leading separator), manual loop. For 'stitch with sep,' string-join is the honest verb."
     :program "(define parts (list \"api\" \"v2\" \"users\"))\n(display (string-join parts \"/\"))\n(newline)"
     :explanation "Line 1 defines the URL parts. Lines 2-3 join with slash: api/v2/users. The audit tape shows one join, sep between parts, no leading/trailing sep."
     :meta "Why string-join and not fold-right: fold-right can leak a leading separator on empty lists or need special-case guards; string-join handles the empty and single-element cases correctly.")
    (:eng "Prefer string-join for delimiter-joined output; use string-append for two-string concatenation without a separator."
     :math "string-join is the inverse of string-split for well-behaved inputs."
     :cs "Related patterns: sep.join(list) in Python, String.join in Java, implode in PHP."))
  :row-3-dimension (
    (:setup "A delimiter-interspersed concatenation: fold a list of strings into one string, placing a separator between adjacent elements but not at the ends."
     :rungs ((:domain "string" :code "(string-join xs \",\")")
             (:domain "beading with separators" :code "(bead necklace beads 'spacer)")
             (:domain "monoid fold with insertion" :code "(define (join xs s) (if (null? xs) \"\" (fold-left (lambda (acc x) (string-append acc s x)) (car xs) (cdr xs))))"))
     :explanation "In string, join stitches with sep. Beading a necklace places spacers between beads but not at the clasp. In math, a fold with insertion between elements is the categorical form. All three share: elements interspersed with separators, no separator at the boundaries."
     :meta "The shape transfers wherever elements need to be combined with an in-between marker."))
  :row-4-proof (
    (:claim "string-join with sep produces a string of length Σ|parts| + (n-1)·|sep| for n parts; for a length-1 list it equals the sole element; for an empty list it is the empty string."
     :program "(display (string-join (list) \",\"))\n(newline)\n(display (string-join (list \"a\") \",\"))\n(newline)\n(display (string-join (list \"a\" \"b\" \"c\") \",\"))\n(newline)\n(define parts (list \"api\" \"v2\" \"users\"))\n(display (string-length (string-join parts \"/\")))\n(newline)"
     :invariant "∀ xs sep. |string-join(xs, sep)| = Σ|xs_i| + max(0, |xs|-1)·|sep|"
     :meta "The pattern is length-additive join. CS pattern name: intercalate. What would falsify: an extra or missing separator at the boundaries. See book-of-code ch05."
     :eng "The engineering payoff is a predictable length formula that lets the caller pre-size buffers."
     :math "join is the inverse of split modulo edge cases."
     :cs "Related to Haskell's intercalate."))
  :row-5-emergence (
    (:base "string-join stitches strings with a separator."
     :composition "(define (build-url scheme host path-parts)\n  (string-append scheme \"://\" host \"/\" (string-join path-parts \"/\")))\n(display (build-url \"https\" \"example.com\" (list \"api\" \"v2\" \"users\")))\n(newline)"
     :emergent "URL builder — a routine that assembles a structured URL from typed pieces"
     :meta "The composition chains string-join with string-append. What emerges is the URL-builder family: safe assembly from parts. Same shape as URI builders in every language. See book-of-composition ch07."))
)

(verb :name "string-upcase"   :library "string" :tier "core" :kind "pure" :signature "(string-upcase s) -> string"
  :summary "Uppercase a string. R7RS §6.7."
  :examples ((:dialect "motoi" :tier "novice" :code "(string-upcase \"hi\")" :note "\"HI\"."))
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :row-2-audit (
    (:problem "The operator is normalizing user input for a case-insensitive lookup: convert to uppercase before comparing to a canonical key. Candidates: string-upcase (all uppercase), string-titlecase (wrong shape — only first letters), or a hash keyed by lowercase (equivalent but the audit question is 'was the input normalized?'). For consistent uppercase normalization, string-upcase is honest."
     :program "(define input \"YeS\")\n(define normalized (string-upcase input))\n(display (list 'input input 'normalized normalized 'match? (equal? normalized \"YES\")))\n(newline)"
     :explanation "Line 1 defines mixed-case input. Line 2 uppercases. Lines 3-4 confirm match to canonical YES. The audit tape shows one normalization step and one equality check."
     :meta "Why string-upcase and not case-insensitive equality (string-ci=?): normalizing at the boundary keeps downstream code case-agnostic without repeated conversions.")
    (:eng "Normalize once at ingress, not on every compare."
     :math "The operation is a per-character map through the uppercase function."
     :cs "Related patterns: str.upper() in Python, String.toUpperCase in Java, upper in SQL."))
  :row-3-dimension (
    (:setup "A per-element normalization: map every unit of a sequence through the same transformation."
     :rungs ((:domain "string" :code "(string-upcase s)")
             (:domain "capitalize a nameplate" :code "(engrave nameplate 'all-caps)")
             (:domain "pointwise function map" :code "(define (up s) (list->string (map char-upcase (string->list s))))"))
     :explanation "In string, upcase transforms every character. On a nameplate, engraving in all-caps applies the transform uniformly. In math, pointwise mapping applies the same function to each element. All three share: a uniform pointwise transform."
     :meta "The shape transfers wherever a sequence needs a uniform per-element transformation."))
  :row-4-proof (
    (:claim "string-upcase preserves length; applied twice to an already-uppercase string yields the same string; the operation is idempotent."
     :program "(define s \"Hello\")\n(define up1 (string-upcase s))\n(define up2 (string-upcase up1))\n(display (list 'len-same? (= (string-length s) (string-length up1)) 'idempotent? (equal? up1 up2)))\n(newline)"
     :invariant "∀ s. |string-upcase(s)| = |s| ∧ string-upcase(string-upcase(s)) = string-upcase(s)"
     :meta "The pattern is length-preserving idempotent map. CS pattern name: pointwise idempotent transform. What would falsify: a length change or a non-fixed-point on a second application. See book-of-code ch05 on string algebra."
     :eng "The engineering payoff is that upcase can be applied without concern about over-application."
     :math "Idempotent: f(f(x)) = f(x); length-preserving: |f(x)| = |x|."
     :cs "Idempotence is a useful property for cache-key normalization: same-input-same-output."))
  :row-5-emergence (
    (:base "string-upcase uppercases a string."
     :composition "(define legal-inputs (list \"YES\" \"NO\" \"MAYBE\"))\n(define (canonicalize inp) (string-upcase (string-trim inp)))\n(define (accept? inp) (member (canonicalize inp) legal-inputs))\n(display (accept? \" yes \"))\n(newline)\n(display (accept? \"nope\"))\n(newline)"
     :emergent "input normalizer — a pipeline that trims and upcases before comparing to a canonical set, absorbing whitespace and case variations"
     :meta "The composition chains string-trim with string-upcase before a membership test. What emerges is the input-normalizer family: user-input hardening. Same shape as sanitize-then-match in form validators. See book-of-composition ch06."))
)

(verb :name "string-downcase" :library "string" :tier "core" :kind "pure" :signature "(string-downcase s) -> string"
  :summary "Lowercase a string. R7RS §6.7."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-downcase \"HELLO\")" :note "\"hello\".")
    (:dialect "motoi" :tier "intermediate" :code "(string-downcase \"Motoi Scheme\")" :note "\"motoi scheme\".")
  )
  :row-2-audit (
    (:problem "The operator is normalizing usernames to lowercase before storing them, so 'Alice' and 'alice' hash to the same account. Candidates: string-downcase (all lower), string-upcase (equivalent normalization form — either is fine but choose one and stick), string-ci=? (skips normalization but scatters the case-insensitivity concern). For canonicalization to lowercase, downcase is honest."
     :program "(define input \"Alice\")\n(define canon (string-downcase input))\n(display (list 'input input 'canon canon 'eq? (equal? canon \"alice\")))\n(newline)"
     :explanation "Line 1 defines mixed-case input. Line 2 lowercases. Lines 3-4 confirm match. The audit tape shows one normalization step."
     :meta "Why string-downcase and not string-ci=?: downcase concentrates the normalization at one point; ci=? spreads it into every compare.")
    (:eng "Choose one direction of case normalization for the whole codebase; log the choice in the CLAUDE-style doctrine."
     :math "Per-character map through the lowercase function."
     :cs "Related patterns: str.lower() in Python, String.toLowerCase in Java."))
  :row-3-dimension (
    (:setup "A per-element normalization to lowercase form."
     :rungs ((:domain "string" :code "(string-downcase s)")
             (:domain "typewriter shift-lock release" :code "(release-shift text)")
             (:domain "pointwise function map" :code "(define (down s) (list->string (map char-downcase (string->list s))))"))
     :explanation "In string, downcase transforms every character. Releasing shift-lock uniformly lowercases subsequent typing. In math, pointwise mapping applies the function to each element. All three share: uniform pointwise transform."
     :meta "The shape transfers wherever a sequence needs uniform per-element lowercasing."))
  :row-4-proof (
    (:claim "string-downcase preserves length and is idempotent."
     :program "(define s \"Motoi\")\n(define d1 (string-downcase s))\n(define d2 (string-downcase d1))\n(display (list 'len? (= (string-length s) (string-length d1)) 'idem? (equal? d1 d2)))\n(newline)"
     :invariant "∀ s. |string-downcase(s)| = |s| ∧ string-downcase(string-downcase(s)) = string-downcase(s)"
     :meta "The pattern is length-preserving idempotent map. CS pattern name: pointwise idempotent transform. What would falsify: length change or non-idempotence. See book-of-code ch05."
     :eng "Idempotence lets downcase be applied without over-application concerns."
     :math "Idempotent map."
     :cs "Useful for cache-key normalization."))
  :row-5-emergence (
    (:base "string-downcase lowercases a string."
     :composition "(define usernames (make-hash-table))\n(define (register! name) (hash-set! usernames (string-downcase name) #t))\n(define (registered? name) (hash-ref usernames (string-downcase name) #f))\n(register! \"Alice\")\n(display (registered? \"alice\"))\n(newline)\n(display (registered? \"ALICE\"))\n(newline)"
     :emergent "case-insensitive registry — a hash keyed by lowercased identifiers, absorbing input casing at both write and read"
     :meta "The composition chains string-downcase with hash-set/hash-ref. What emerges is the case-insensitive-index family: canonical-form lookup. Same shape as case-insensitive domain-name resolution. See book-of-composition ch06."))
)

(verb :name "string-titlecase" :library "string" :tier "core" :kind "pure" :signature "(string-titlecase s) -> string"
  :summary "Titlecase (uppercase first letter of every word)."
  :examples ((:dialect "motoi" :tier "novice" :code "(string-titlecase \"hello world\")" :note "\"Hello World\"."))
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :row-2-audit (
    (:problem "The operator is preparing a display label from a downcased database field. Candidates: string-titlecase (first letter of each word), string-upcase (all caps — wrong for display), manual per-word treatment. For 'Title Case Display,' titlecase is honest."
     :program "(define raw \"motoi scheme reference\")\n(display (string-titlecase raw))\n(newline)"
     :explanation "Line 1 defines a raw phrase. Lines 2-3 print in title case: Motoi Scheme Reference. The audit tape shows one title-cased output ready for display."
     :meta "Why titlecase and not upcase: display labels usually want title case, not all caps.")
    (:eng "Prefer titlecase at display boundaries; do not store title-cased data (harder to search)."
     :math "Titlecase capitalizes the first character of each maximal alphabetic run."
     :cs "Related patterns: str.title() in Python, TextInfo.ToTitleCase in .NET."))
  :row-3-dimension (
    (:setup "A word-boundary-aware capitalization: uppercase the first character of each word, lowercase the rest."
     :rungs ((:domain "string" :code "(string-titlecase \"foo bar\")")
             (:domain "book cover typesetter" :code "(typeset-title text 'title-case)")
             (:domain "word-boundary map" :code "(define (title s) (string-join (map (lambda (w) (string-append (string-upcase (string-take w 1)) (string-downcase (string-drop w 1)))) (string-split s)) \" \"))"))
     :explanation "In string, titlecase does word-boundary uppercase. In typesetting, a book title is set in title case as a display convention. In construction, a word-boundary map builds the same shape. All three share: word-boundary uppercase pattern."
     :meta "The shape transfers wherever a phrase-level display convention is needed."))
  :row-4-proof (
    (:claim "string-titlecase preserves length and is idempotent on properly title-cased strings."
     :program "(define s \"hello world\")\n(define t1 (string-titlecase s))\n(define t2 (string-titlecase t1))\n(display (list 'len? (= (string-length s) (string-length t1)) 'idem? (equal? t1 t2)))\n(newline)"
     :invariant "∀ s. |string-titlecase(s)| = |s| ∧ string-titlecase(string-titlecase(s)) = string-titlecase(s)"
     :meta "The pattern is length-preserving idempotent map. CS pattern name: idempotent transform. What would falsify: length change or non-idempotence. See book-of-code ch05."
     :eng "Idempotence lets titlecase be applied at multiple layers without corruption."
     :math "Idempotent map on well-formed inputs."
     :cs "Useful for display normalization."))
  :row-5-emergence (
    (:base "string-titlecase capitalizes each word."
     :composition "(define (display-name first last)\n  (string-titlecase (string-append first \" \" last)))\n(display (display-name \"alice\" \"BAKER\"))\n(newline)"
     :emergent "display-name formatter — a helper that assembles and formats a person's name for UI display"
     :meta "The composition chains string-append with string-titlecase. What emerges is the display-formatter family: user-facing string normalization. See book-of-composition ch07."))
)

(verb :name "string-take"  :library "string" :tier "core" :kind "pure" :signature "(string-take s n) -> string"
  :summary "First n characters of s."
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-take \"hello\" 3)" :note "\"hel\".")
    (:dialect "motoi" :tier "intermediate" :code "(string-take \"motoi-scheme\" 5)" :note "\"motoi\".")
  )
  :row-2-audit (
    (:problem "The operator has parsed a key=value pair via string-index and needs the prefix up to the '='. Candidates: string-take (first n), substring with 0 as start (equivalent, more verbose), a manual character loop. For 'first n,' string-take is honest."
     :program "(define kv \"key=42\")\n(define i (string-index kv \"=\"))\n(display (string-take kv i))\n(newline)"
     :explanation "Line 1 defines a key=value. Line 2 finds '=' position. Lines 3-4 print the prefix key. The audit tape shows: locate delimiter, take prefix."
     :meta "Why string-take and not substring: string-take reads directly for 'first n' intent.")
    (:eng "Prefer string-take for 'first n' semantics; use substring for arbitrary [start, end)."
     :math "string-take(s, n) = s[0..n]."
     :cs "Related patterns: s[:n] in Python, take in Haskell."))
  :row-3-dimension (
    (:setup "A prefix take: extract the first n units of a sequence."
     :rungs ((:domain "string" :code "(string-take s 3)")
             (:domain "top of a stack of pancakes" :code "(take-from-top stack 3)")
             (:domain "restriction to initial segment" :code "(define (take n xs) (if (or (= n 0) (null? xs)) (list) (cons (car xs) (take (- n 1) (cdr xs)))))"))
     :explanation "In string, take extracts the prefix. Taking pancakes from the top of a stack takes the last-added units. In math, restricting a sequence to its initial segment is the same shape. All three share: extract the first n."
     :meta "The shape transfers wherever a sequence has an order and clients want the first n."))
  :row-4-proof (
    (:claim "string-take returns a string of length n such that the returned string equals the first n characters of s."
     :program "(define s \"hello\")\n(display (string-take s 0))\n(newline)\n(display (string-take s 3))\n(newline)\n(display (string-take s 5))\n(newline)\n(display (list 'len? (= 3 (string-length (string-take s 3)))))\n(newline)"
     :invariant "∀ s n. 0 ≤ n ≤ |s| ⇒ string-take(s, n) = s[0..n] ∧ |string-take(s, n)| = n"
     :meta "The pattern is prefix extract. CS pattern name: prefix. What would falsify: a length mismatch or a non-prefix result. See book-of-code ch05."
     :eng "Predictable length and content."
     :math "Restriction to initial segment."
     :cs "O(n) time, O(n) space (fresh string)."))
  :row-5-emergence (
    (:base "string-take extracts the first n characters."
     :composition "(define (short-uuid full-uuid)\n  (string-take full-uuid 8))\n(display (short-uuid \"abcdef01-2345-6789\"))\n(newline)"
     :emergent "short-id truncator — extract a display-friendly prefix of a long identifier"
     :meta "The composition wraps string-take in a helper. What emerges is the truncator family: display-safe id shortening. Same shape as git short-sha, as npm's short-hash. See book-of-composition ch07."))
)

(verb :name "string-drop"  :library "string" :tier "core" :kind "pure" :signature "(string-drop s n) -> string"
  :summary "Everything after the first n characters."
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-drop \"hello\" 3)" :note "\"lo\".")
    (:dialect "motoi" :tier "intermediate" :code "(string-drop \"motoi-scheme\" 6)" :note "\"scheme\".")
  )
  :row-2-audit (
    (:problem "The operator has a key=value pair and needs the value part (after the '='). Candidates: string-drop (skip first n), substring with n and |s| (equivalent, more verbose). For 'skip first n,' string-drop is honest."
     :program "(define kv \"key=42\")\n(define i (string-index kv \"=\"))\n(display (string-drop kv (+ i 1)))\n(newline)"
     :explanation "Line 1 defines a key=value. Line 2 finds '='. Lines 3-4 print the suffix after '='. The audit tape shows: locate delimiter, drop up to and including it."
     :meta "Why string-drop and not substring: string-drop reads directly for 'skip first n' intent.")
    (:eng "Prefer string-drop for suffix-after semantics; use substring for arbitrary ranges."
     :math "string-drop(s, n) = s[n..]."
     :cs "Related patterns: s[n:] in Python, drop in Haskell."))
  :row-3-dimension (
    (:setup "A prefix skip: return the suffix of a sequence starting at position n."
     :rungs ((:domain "string" :code "(string-drop s 3)")
             (:domain "cut off leash length" :code "(after-first-n leash 6)")
             (:domain "restriction to tail segment" :code "(define (drop n xs) (if (or (= n 0) (null? xs)) xs (drop (- n 1) (cdr xs))))"))
     :explanation "In string, drop returns the suffix. Cutting a leash after n links leaves the remainder. In math, restricting a sequence past position n is the same shape. All three share: skip prefix, return suffix."
     :meta "The shape transfers wherever a sequence is bisected and the tail is needed."))
  :row-4-proof (
    (:claim "string-drop returns a string of length |s|-n such that its content equals s[n..]."
     :program "(define s \"hello\")\n(display (string-drop s 0))\n(newline)\n(display (string-drop s 3))\n(newline)\n(display (string-drop s 5))\n(newline)\n(display (list 'len? (= 2 (string-length (string-drop s 3)))))\n(newline)"
     :invariant "∀ s n. 0 ≤ n ≤ |s| ⇒ string-drop(s, n) = s[n..] ∧ |string-drop(s, n)| = |s|-n"
     :meta "The pattern is suffix extract. CS pattern name: drop. What would falsify: a length mismatch or a non-suffix result. See book-of-code ch05."
     :eng "Predictable length and content."
     :math "Restriction to tail segment."
     :cs "O(|s|-n) time, O(|s|-n) space."))
  :row-5-emergence (
    (:base "string-drop skips the first n characters."
     :composition "(define (parse-http-status line)\n  (let ((i (string-index line \" \")))\n    (string-take (string-drop line (+ i 1)) 3)))\n(display (parse-http-status \"HTTP/1.1 200 OK\"))\n(newline)"
     :emergent "field-slicer — a routine that combines drop and take to extract a middle field bounded by delimiters"
     :meta "The composition chains string-drop with string-take. What emerges is the middle-field-slicer family: drop-then-take. Same shape as protocol parsers, as sscanf-like extraction. See book-of-composition ch04."))
)

(verb :name "string-pad"       :library "string" :tier "core" :kind "pure" :signature "(string-pad s len [char]) -> string"
  :summary "Left-pad s to length len with char (default space)."
  :examples ((:dialect "motoi" :tier "novice" :code "(string-pad \"7\" 3 \"0\")" :note "\"007\" — zero-padded."))
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :row-2-audit (
    (:problem "The operator is formatting numeric IDs to a fixed width for a report — turning 7 into 007. Candidates: string-pad (left-pad, right-align), string-pad-right (right-pad, left-align — wrong for numbers), string-append with a manual prefix (works but width-fragile). For right-aligned zero-padded numbers, string-pad is honest."
     :program "(define ids (list 7 42 100))\n(define padded (map (lambda (n) (string-pad (number->string n) 4 \"0\")) ids))\n(display padded)\n(newline)"
     :explanation "Line 1 defines numeric ids. Line 2 formats each as a 4-wide zero-padded string. Lines 3-4 print: (0007 0042 0100). The audit tape shows uniform-width output."
     :meta "Why string-pad and not string-pad-right: numbers align right; pad-right would left-align (wrong for numbers).")
    (:eng "Zero-padded numeric fields are a common report format; log the pad char if the report will be machine-parsed."
     :math "The operation prepends (len - |s|) copies of char to s if |s| < len; otherwise truncates from the left."
     :cs "Related patterns: str.rjust(n, ch) in Python, printf %0Nd in C."))
  :row-3-dimension (
    (:setup "A left-pad: right-align a value within a fixed-width field by prepending filler characters."
     :rungs ((:domain "string" :code "(string-pad \"7\" 3 \"0\")")
             (:domain "column-aligned table" :code "(right-align field width)")
             (:domain "canonical numeric encoding" :code "(define (rjust s w c) (if (>= (string-length s) w) s (string-append (make-string (- w (string-length s)) c) s)))"))
     :explanation "In string, pad left-pads. In a table, right-aligning numbers is the standard convention. In canonical encoding, fixed-width numeric fields are prefixed with zeros. All three share: right-align in a fixed width by left-padding."
     :meta "The shape transfers wherever a fixed-width right-aligned field is required."))
  :row-4-proof (
    (:claim "string-pad(s, len, c) returns a string whose length equals max(|s|, len); if |s| < len, the result is (make-string (len-|s|) c) followed by s."
     :program "(display (string-pad \"7\" 3 \"0\"))\n(newline)\n(display (string-pad \"77\" 3 \"0\"))\n(newline)\n(display (string-pad \"777\" 3 \"0\"))\n(newline)\n(display (list 'len? (= 3 (string-length (string-pad \"7\" 3 \"0\")))))\n(newline)"
     :invariant "∀ s len c. |string-pad(s, len, c)| = max(|s|, len); if |s| ≤ len, string-pad ends with s"
     :meta "The pattern is right-align with fixed width. CS pattern name: rjust. What would falsify: a length not matching max(|s|, len). See book-of-code ch05."
     :eng "Predictable width for tabular output."
     :math "Idempotent when |s| ≥ len (returns s unchanged)."
     :cs "Related to printf field width specifiers."))
  :row-5-emergence (
    (:base "string-pad left-pads to a width."
     :composition "(define (format-row cols widths)\n  (string-join\n    (map (lambda (c w) (string-pad (if (string? c) c (number->string c)) w \" \")) cols widths)\n    \" | \"))\n(display (format-row (list 1 \"alice\" 3.14) (list 5 8 6)))\n(newline)"
     :emergent "table row formatter — a routine that formats a row of mixed-type values into a columnar layout"
     :meta "The composition chains string-pad with string-join. What emerges is the table-formatter family: columnar output. Same shape as printf column specifiers, as `column` in Unix. See book-of-composition ch07."))
)

(verb :name "string-pad-right" :library "string" :tier "core" :kind "pure" :signature "(string-pad-right s len [char]) -> string"
  :summary "Right-pad s to length len."
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-pad-right \"7\" 3 \"0\")" :note "\"700\" — zero-padded on the right.")
    (:dialect "motoi" :tier "intermediate" :code "(string-pad-right \"hi\" 5)" :note "\"hi   \" — space-padded to 5 chars.")
  )
  :row-2-audit (
    (:problem "The operator is formatting a table of names left-aligned in a 20-character column. Candidates: string-pad-right (right-pad, left-align), string-pad (left-pad, right-align — wrong for text). For left-aligned text columns, string-pad-right is honest."
     :program "(define names (list \"alice\" \"bob\" \"catherine\"))\n(define col (map (lambda (n) (string-pad-right n 12 \" \")) names))\n(display col)\n(newline)"
     :explanation "Line 1 defines names. Line 2 pads each to width 12 with spaces on the right. Lines 3-4 print left-aligned columns. The audit tape shows uniform-width left-aligned rows."
     :meta "Why string-pad-right and not string-pad: text left-aligns; padding on the right achieves that.")
    (:eng "Text-column padding is right; numeric-column padding is left; convention matters for readability."
     :math "The operation appends filler characters to bring the result to the target width."
     :cs "Related patterns: str.ljust in Python, printf %-Ns in C."))
  :row-3-dimension (
    (:setup "A right-pad: left-align a value within a fixed-width field by appending filler characters."
     :rungs ((:domain "string" :code "(string-pad-right s 20 \" \")")
             (:domain "name badge printing" :code "(left-align badge width)")
             (:domain "canonical text encoding" :code "(define (ljust s w c) (if (>= (string-length s) w) s (string-append s (make-string (- w (string-length s)) c))))"))
     :explanation "In string, pad-right left-aligns. Name badges left-align text with trailing space. In canonical text encoding, left-alignment is standard for readability. All three share: left-align within a fixed width by right-padding."
     :meta "The shape transfers wherever a fixed-width left-aligned field is required."))
  :row-4-proof (
    (:claim "string-pad-right(s, len, c) returns a string of length max(|s|, len); if |s| < len, the result starts with s."
     :program "(display (string-pad-right \"hi\" 5 \".\"))\n(newline)\n(display (string-pad-right \"hello\" 3 \".\"))\n(newline)\n(display (list 'len? (= 5 (string-length (string-pad-right \"hi\" 5 \".\")))))\n(newline)"
     :invariant "∀ s len c. |string-pad-right(s, len, c)| = max(|s|, len); if |s| ≤ len, string-pad-right starts with s"
     :meta "The pattern is left-align with fixed width. CS pattern name: ljust. What would falsify: length not matching max(|s|, len). See book-of-code ch05."
     :eng "Predictable width for tabular text output."
     :math "Idempotent when |s| ≥ len."
     :cs "Related to printf's %- flag."))
  :row-5-emergence (
    (:base "string-pad-right left-aligns to a width."
     :composition "(define (labeled-progress label pct)\n  (string-append (string-pad-right label 20 \" \") \"[\" (string-pad-right (make-string (quotient pct 5) \"=\") 20 \" \") \"]\"))\n(display (labeled-progress \"loading data\" 40))\n(newline)"
     :emergent "progress bar — a left-aligned label followed by a bar of proportional width"
     :meta "The composition chains string-pad-right with string-append. What emerges is the progress-bar family: aligned label + variable-length gauge. Same shape as tqdm, as npm progress. See book-of-composition ch07."))
)

(verb :name "string-trim"       :library "string" :tier "core" :kind "pure" :signature "(string-trim s) -> string"
  :summary "Trim whitespace from both ends."
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-trim \"   hello   \")" :note "\"hello\".")
    (:dialect "motoi" :tier "intermediate" :code "(string-trim \"\\t\\nmotoi\\n\")" :note "\"motoi\" — trims tabs and newlines too.")
  )
  :row-2-audit (
    (:problem "The operator is normalizing user input from a form field: leading/trailing whitespace is noise. Candidates: string-trim (both ends), string-trim-left (start only), string-trim-right (end only). For both-end normalization, string-trim is honest."
     :program "(define raw \"  motoi  \")\n(display (list 'raw raw 'trimmed (string-trim raw)))\n(newline)"
     :explanation "Line 1 defines noisy input. Lines 2-3 print raw and trimmed. The audit tape shows trimmed content with both-end whitespace removed."
     :meta "Why string-trim and not one-sided variants: user input typically has whitespace on both sides.")
    (:eng "Trim once at ingress; downstream code assumes clean strings."
     :math "The operation removes the maximal leading and trailing whitespace runs."
     :cs "Related patterns: str.strip in Python, String.trim in Java."))
  :row-3-dimension (
    (:setup "A boundary strip: remove noise characters from both ends of a sequence."
     :rungs ((:domain "string" :code "(string-trim s)")
             (:domain "peel banana from both ends" :code "(peel banana 'both-ends)")
             (:domain "maximal middle segment" :code "(define (strip pred s) (let* ((i (find-first (lambda (c) (not (pred c))) (string->list s))) (j (find-last (lambda (c) (not (pred c))) (string->list s)))) (substring s (or i 0) (if j (+ j 1) 0))))"))
     :explanation "In string, trim strips whitespace ends. Peeling a banana removes both-end noise. In math, the maximal middle segment is the trimmed core. All three share: strip boundary noise, keep interior."
     :meta "The shape transfers wherever a sequence has boundary noise to discard."))
  :row-4-proof (
    (:claim "string-trim is idempotent; length is monotone non-increasing; content preserves interior."
     :program "(define s \"  hello  \")\n(define t1 (string-trim s))\n(define t2 (string-trim t1))\n(display (list 'idem? (equal? t1 t2) 'shorter? (<= (string-length t1) (string-length s))))\n(newline)"
     :invariant "∀ s. string-trim(string-trim(s)) = string-trim(s) ∧ |string-trim(s)| ≤ |s|"
     :meta "The pattern is idempotent boundary strip. CS pattern name: strip. What would falsify: a change in the second application, or a length increase. See book-of-code ch05."
     :eng "Idempotence lets trim be applied at multiple layers without corruption."
     :math "Idempotent contraction."
     :cs "Used for input hardening, key normalization."))
  :row-5-emergence (
    (:base "string-trim strips whitespace from both ends."
     :composition "(define (canonical-input s) (string-downcase (string-trim s)))\n(define store (make-hash-table))\n(define (register! s) (hash-set! store (canonical-input s) #t))\n(register! \"  Alice  \")\n(display (hash-ref store (canonical-input \"alice\") #f))\n(newline)"
     :emergent "canonicalization pipeline — trim + downcase produces a stable normalized form for equality checks"
     :meta "The composition chains string-trim with string-downcase. What emerges is the canonicalization family: apply invariant normalizations before comparison. See book-of-composition ch06."))
)

(verb :name "string-trim-left"  :library "string" :tier "core" :kind "pure" :signature "(string-trim-left s) -> string"
  :summary "Trim leading whitespace."
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-trim-left \"   hello   \")" :note "\"hello   \".")
    (:dialect "motoi" :tier "intermediate" :code "(string-trim-left \"\\n\\n\\nmotoi\")" :note "\"motoi\".")
  )
  :row-2-audit (
    (:problem "The operator is parsing an indented line, wanting to skip the indentation but preserving trailing content. Candidates: string-trim-left (strip leading only), string-trim (both ends — wrong: loses trailing whitespace that might be intentional). For leading-only stripping, string-trim-left is honest."
     :program "(define line \"    code line with trailing space   \")\n(display (string-trim-left line))\n(newline)"
     :explanation "Line 1 defines an indented line. Lines 2-3 print with leading indentation removed but trailing spaces preserved. The audit tape shows one-sided strip."
     :meta "Why string-trim-left and not string-trim: preserves trailing content that might be significant (e.g., markdown line-ending double-space).")
    (:eng "One-sided trim preserves significant content on the other side."
     :math "Removes the maximal leading whitespace run."
     :cs "Related patterns: str.lstrip in Python, ltrim in PHP."))
  :row-3-dimension (
    (:setup "A leading strip: remove noise from the front of a sequence."
     :rungs ((:domain "string" :code "(string-trim-left s)")
             (:domain "peel banana top" :code "(peel banana 'top-only)")
             (:domain "drop-while pred" :code "(define (dropw pred xs) (cond ((null? xs) xs) ((pred (car xs)) (dropw pred (cdr xs))) (else xs)))"))
     :explanation "In string, trim-left strips leading whitespace. Peeling only the top of a banana removes leading noise. In math, drop-while is the generic front-strip. All three share: front strip, tail preserved."
     :meta "The shape transfers wherever a sequence has leading noise to discard."))
  :row-4-proof (
    (:claim "string-trim-left is idempotent; the result ends with the same suffix as s."
     :program "(define s \"  hello  \")\n(define t1 (string-trim-left s))\n(define t2 (string-trim-left t1))\n(display (list 'idem? (equal? t1 t2)))\n(newline)"
     :invariant "∀ s. string-trim-left(string-trim-left(s)) = string-trim-left(s); the trailing part of s is unchanged"
     :meta "The pattern is idempotent front-strip. CS pattern name: lstrip. What would falsify: change in the second application. See book-of-code ch05."
     :eng "Preserves trailing significance."
     :math "Idempotent."
     :cs "Used when only leading noise is present."))
  :row-5-emergence (
    (:base "string-trim-left strips leading whitespace."
     :composition "(define (dedent lines)\n  (map string-trim-left lines))\n(display (dedent (list \"    a\" \"    b\" \"    c\")))\n(newline)"
     :emergent "dedenter — a routine that removes leading indentation from every line uniformly"
     :meta "The composition maps string-trim-left over lines. What emerges is the dedent family: uniform indentation stripping. Same shape as textwrap.dedent in Python. See book-of-composition ch10."))
)

(verb :name "string-trim-right" :library "string" :tier "core" :kind "pure" :signature "(string-trim-right s) -> string"
  :summary "Trim trailing whitespace."
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-trim-right \"   hello   \")" :note "\"   hello\".")
    (:dialect "motoi" :tier "intermediate" :code "(string-trim-right \"motoi\\n\\n\")" :note "\"motoi\".")
  )
  :row-2-audit (
    (:problem "The operator is normalizing lines from a file where trailing newlines and spaces are noise but leading indentation is significant (source code). Candidates: string-trim-right, string-trim (loses significant leading indent). For trailing-only stripping, string-trim-right is honest."
     :program "(define line \"    print(x)   \\n\")\n(display (string-trim-right line))\n(newline)"
     :explanation "Line 1 defines a source line with leading indent and trailing whitespace. Lines 2-3 print with leading preserved and trailing stripped. The audit tape shows one-sided strip."
     :meta "Why string-trim-right: keeps significant leading indentation.")
    (:eng "One-sided trim preserves significant content."
     :math "Removes the maximal trailing whitespace run."
     :cs "Related patterns: str.rstrip in Python, rtrim in PHP."))
  :row-3-dimension (
    (:setup "A trailing strip: remove noise from the tail of a sequence."
     :rungs ((:domain "string" :code "(string-trim-right s)")
             (:domain "cut the excess wire" :code "(cut-excess wire)")
             (:domain "take-while inverse" :code "(define (rstrip s p) (list->string (reverse (dropw p (reverse (string->list s))))))"))
     :explanation "In string, trim-right strips trailing whitespace. Cutting excess wire removes tail noise. In math, the inverse of drop-while from the tail. All three share: tail strip, head preserved."
     :meta "The shape transfers wherever a sequence has trailing noise to discard."))
  :row-4-proof (
    (:claim "string-trim-right is idempotent; the result begins with the same prefix as s."
     :program "(define s \"  hello  \")\n(define t1 (string-trim-right s))\n(define t2 (string-trim-right t1))\n(display (list 'idem? (equal? t1 t2)))\n(newline)"
     :invariant "∀ s. string-trim-right(string-trim-right(s)) = string-trim-right(s); leading part is unchanged"
     :meta "The pattern is idempotent tail-strip. CS pattern name: rstrip. What would falsify: change in the second application. See book-of-code ch05."
     :eng "Preserves leading significance."
     :math "Idempotent."
     :cs "Used when only trailing noise is present."))
  :row-5-emergence (
    (:base "string-trim-right strips trailing whitespace."
     :composition "(define (chomp-line line) (string-trim-right line))\n(define (read-file-lines port)\n  (let loop ((acc (list)))\n    (let ((l (read-line port)))\n      (if (eof-object? l)\n        (reverse acc)\n        (loop (cons (chomp-line l) acc))))))\n(display (read-file-lines (open-input-string \"a  \\nb\\nc  \\n\")))\n(newline)"
     :emergent "chomp-and-drain — a line reader that strips trailing whitespace from every line before collecting"
     :meta "The composition chains read-line with string-trim-right. What emerges is the chomp family: line-by-line cleanup while reading. Same shape as chomp in Perl, as file-object iteration in Python with rstrip. See book-of-composition ch10."))
)

(verb :name "string-replace"    :library "string" :tier "core" :kind "pure" :signature "(string-replace s from to) -> string"
  :summary "Replace every occurrence of from in s with to."
  :examples ((:dialect "motoi" :tier "novice" :code "(string-replace \"hello\" \"l\" \"L\")" :note "\"heLLo\"."))
  :provenance "SRFI-13-adjacent; added 2026-07-18 finalization"
  :row-2-audit (
    (:problem "The operator is normalizing paths — converting Windows-style backslashes to forward slashes. Candidates: string-replace (all occurrences), a manual loop with string-index+substring (works but noisier), regex (overkill for a literal substring). For 'replace all,' string-replace is honest."
     :program "(define winpath \"a\\\\b\\\\c\\\\d\")\n(display (string-replace winpath \"\\\\\" \"/\"))\n(newline)"
     :explanation "Line 1 defines a Windows-style path. Lines 2-3 print the POSIX form. The audit tape shows one replace, three substitutions."
     :meta "Why string-replace and not a manual loop: single call, clear intent.")
    (:eng "Log the from/to pair; a wrong pair silently corrupts data."
     :math "Iterated point substitution."
     :cs "Related patterns: str.replace in Python, String.replace in Java."))
  :row-3-dimension (
    (:setup "A global substitution: replace every occurrence of a pattern with a replacement."
     :rungs ((:domain "string" :code "(string-replace s \"foo\" \"bar\")")
             (:domain "search and replace in a document" :code "(replace-all doc old new)")
             (:domain "term rewriting" :code "(define (rewrite t l r) (if (equal? t l) r t))"))
     :explanation "In string, replace substitutes globally. In a document editor, search-and-replace applies globally. In term rewriting, applying a rule everywhere is the same shape. All three share: pattern → replacement, applied to every match."
     :meta "The shape transfers wherever a substrate has occurrences of a pattern that need to be uniformly transformed."))
  :row-4-proof (
    (:claim "string-replace substitutes every occurrence of from with to; if from does not occur, the result equals s."
     :program "(display (string-replace \"aaa\" \"a\" \"b\"))\n(newline)\n(display (string-replace \"hello\" \"z\" \"Z\"))\n(newline)\n(display (equal? (string-replace \"x\" \"y\" \"z\") \"x\"))\n(newline)"
     :invariant "∀ s from to. from ∉ s ⇒ string-replace(s, from, to) = s"
     :meta "The pattern is global substitution. CS pattern name: rewrite. What would falsify: a change when from is absent. See book-of-code ch05."
     :eng "No-op when from is absent, safe to call speculatively."
     :math "Idempotent when from ≠ to and to does not contain from."
     :cs "Naive replace is O(|s|·|from|); efficient uses KMP-adjacent."))
  :row-5-emergence (
    (:base "string-replace substitutes globally."
     :composition "(define (path->posix p) (string-replace p \"\\\\\" \"/\"))\n(define (path->windows p) (string-replace p \"/\" \"\\\\\"))\n(display (path->posix \"a\\\\b\\\\c\"))\n(newline)\n(display (path->windows (path->posix \"a\\\\b\\\\c\")))\n(newline)"
     :emergent "path normalizer — a routine that converts between path conventions via character substitution"
     :meta "The composition uses string-replace as the primitive for cross-platform normalization. What emerges is the platform-adapter family: path/url/newline normalization. See book-of-composition ch06."))
)

(verb :name "string-reverse" :library "string" :tier "core" :kind "pure" :signature "(string-reverse s) -> string"
  :summary "Reverse a string."
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-reverse \"hello\")" :note "\"olleh\".")
    (:dialect "motoi" :tier "intermediate" :code "(string-reverse \"motoi\")" :note "\"iotom\".")
  )
  :row-2-audit (
    (:problem "The operator is checking whether a string is a palindrome. Candidates: string-reverse (reverse then compare), a two-index loop from both ends (efficient but noisier). For simple palindrome checks, reverse-and-compare is honest."
     :program "(define (palindrome? s) (equal? s (string-reverse s)))\n(display (palindrome? \"racecar\"))\n(newline)\n(display (palindrome? \"hello\"))\n(newline)"
     :explanation "Line 1 defines the check. Lines 2-3 test racecar (#t). Lines 4-5 test hello (#f). The audit tape shows one reverse and one equality per check."
     :meta "Why string-reverse and not a two-index loop: readability at small string sizes; use two-index for very large strings.")
    (:eng "Reverse is O(n); acceptable for short strings."
     :math "The result is s with characters in reversed order."
     :cs "Related patterns: str[::-1] in Python, StringBuilder.reverse in Java."))
  :row-3-dimension (
    (:setup "A sequence reversal: reorder the elements to appear in the opposite of their original sequence."
     :rungs ((:domain "string" :code "(string-reverse s)")
             (:domain "read a shelf back to front" :code "(back-to-front shelf)")
             (:domain "involution: f(f(x)) = x" :code "(define (reverse-list xs) (fold-left (lambda (acc x) (cons x acc)) (list) xs))"))
     :explanation "In string, reverse reorders. Reading a shelf back to front is the same shape. In math, an involution — applying it twice returns the original — is the algebraic characterization. All three share: reorder, and doing it twice is identity."
     :meta "The shape transfers wherever a sequence has direction and clients want the opposite direction."))
  :row-4-proof (
    (:claim "string-reverse is an involution: applied twice, it returns the original; length is preserved."
     :program "(define s \"motoi\")\n(display (equal? s (string-reverse (string-reverse s))))\n(newline)\n(display (= (string-length s) (string-length (string-reverse s))))\n(newline)"
     :invariant "∀ s. string-reverse(string-reverse(s)) = s ∧ |string-reverse(s)| = |s|"
     :meta "The pattern is involution. CS pattern name: reversible transform. What would falsify: double-reverse not equal to original, or length change. See book-of-math ch12 on involutions."
     :eng "Involution is safe to compose: applying twice cancels."
     :math "reverse ∘ reverse = id."
     :cs "Reverse is O(n); the involution property is the key algebraic identity."))
  :row-5-emergence (
    (:base "string-reverse reverses a string."
     :composition "(define (palindromes-in-list ss)\n  (filter (lambda (s) (equal? s (string-reverse s))) ss))\n(display (palindromes-in-list (list \"racecar\" \"motoi\" \"level\" \"hello\")))\n(newline)"
     :emergent "palindrome filter — a routine that selects palindromes from a list"
     :meta "The composition chains string-reverse with equal? inside filter. What emerges is the palindrome-detector family: symmetric-string selection. See book-of-composition ch06."))
)

(verb :name "string-count"   :library "string" :tier "core" :kind "pure" :signature "(string-count s char-or-pred) -> integer"
  :summary "Count characters matching char-or-pred."
  :provenance "SRFI-13; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-count \"hello\" \"l\")" :note "2.")
    (:dialect "motoi" :tier "intermediate" :code "(string-count \"mississippi\" \"s\")" :note "4.")
  )
  :row-2-audit (
    (:problem "The operator is measuring a passphrase's strength by counting occurrences of specific character classes. Candidates: string-count (predicate count), a fold with a manual counter (equivalent, more code). For character-count queries, string-count is honest."
     :program "(define pw \"Hello123World\")\n(display (list 'digits (string-count pw char-numeric?) 'letters (string-count pw char-alphabetic?)))\n(newline)"
     :explanation "Line 1 defines a password. Lines 2-3 count digits (3) and letters (10). The audit tape shows two counts, one pass per predicate."
     :meta "Why string-count and not a fold: the specialized verb reads for intent.")
    (:eng "Log the predicate class and count for input-validation metrics."
     :math "The result is |{i | pred(s[i])}|."
     :cs "Related patterns: sum(1 for c in s if pred(c)) in Python."))
  :row-3-dimension (
    (:setup "A predicate tally: count elements of a sequence that satisfy a predicate."
     :rungs ((:domain "string" :code "(string-count s pred)")
             (:domain "count red beads on a string" :code "(count-red-beads necklace)")
             (:domain "cardinality of {x | pred(x)}" :code "(define (count pred xs) (fold-left (lambda (n x) (if (pred x) (+ n 1) n)) 0 xs))"))
     :explanation "In string, count tallies matching characters. On a necklace, counting reds is the same shape. In math, cardinality of a predicate-satisfying subset is the same operation. All three share: pred, sequence, count."
     :meta "The shape transfers wherever an ordered collection has clients counting predicate matches."))
  :row-4-proof (
    (:claim "string-count returns a nonnegative integer ≤ |s|; the sum of counts over disjoint predicates equals |s| if the predicates cover the domain."
     :program "(define s \"Hello123\")\n(define digits (string-count s char-numeric?))\n(define letters (string-count s char-alphabetic?))\n(define others (string-count s (lambda (c) (and (not (char-numeric? c)) (not (char-alphabetic? c))))))\n(display (list digits letters others 'total (+ digits letters others) 'len (string-length s)))\n(newline)"
     :invariant "∀ s pred. 0 ≤ string-count(s, pred) ≤ |s|"
     :meta "The pattern is bounded tally. CS pattern name: predicate count. What would falsify: negative count or count exceeding length. See book-of-math ch07."
     :eng "Bounded output type."
     :math "Cardinality of predicate-satisfying subset."
     :cs "O(|s|) time."))
  :row-5-emergence (
    (:base "string-count tallies matching characters."
     :composition "(define (strength pw)\n  (let ((d (string-count pw char-numeric?))\n        (a (string-count pw char-alphabetic?))\n        (l (string-length pw)))\n    (list 'len l 'digits d 'letters a 'strong? (and (>= l 8) (> d 0) (> a 0)))))\n(display (strength \"Hello123\"))\n(newline)\n(display (strength \"weak\"))\n(newline)"
     :emergent "password-strength rubric — combine multiple counts into a composite judgment"
     :meta "The composition chains multiple string-count calls into a composite check. What emerges is the multi-criterion evaluator family: policy checks over an artifact. See book-of-composition ch11."))
)

(verb :name "string->list"  :library "string" :tier "core" :kind "pure" :signature "(string->list s) -> list-of-char"
  :summary "Explode a string into a list of 1-char strings. R7RS §6.7."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string->list \"abc\")" :note "(\"a\" \"b\" \"c\").")
    (:dialect "motoi" :tier "intermediate" :code "(map string-upcase (string->list \"hi\"))" :note "(\"H\" \"I\") — upper-case each character.")
  )
  :row-2-audit (
    (:problem "The operator wants to apply list operations (map, filter, fold) to characters. Candidates: string->list (convert once, then use list ops), a manual character index loop (works but noisier). For applying list-based higher-order primitives to characters, string->list is honest."
     :program "(define s \"Hello\")\n(display (filter char-upper-case? (string->list s)))\n(newline)"
     :explanation "Line 1 defines s. Lines 2-3 convert to a char list and filter uppercase-only: (H). The audit tape shows one conversion and one filter."
     :meta "Why string->list and not a manual loop: enables use of the whole higher-order primitive family (map/filter/fold).")
    (:eng "One-time conversion is cheap; the payoff is idiomatic list ops downstream."
     :math "The result is the character sequence of s as a list."
     :cs "Related patterns: list(string) in Python."))
  :row-3-dimension (
    (:setup "A representation switch: convert a compact sequence (string) into a walkable form (list) so higher-order operations can be applied."
     :rungs ((:domain "string" :code "(string->list s)")
             (:domain "unspool a ribbon" :code "(unspool ribbon)")
             (:domain "sequence coercion" :code "(define (chars s) (map (lambda (i) (substring s i (+ i 1))) (iota (string-length s))))"))
     :explanation "In string, string->list unrolls into a per-character list. Unspooling a ribbon separates units for individual handling. In sequence coercion, converting one representation to another is the same shape. All three share: compact form → walkable form."
     :meta "The shape transfers wherever compact representations need walkable list access."))
  :row-4-proof (
    (:claim "string->list preserves length and content: |string->list(s)| = |s|; joining the result via list->string yields s."
     :program "(define s \"motoi\")\n(define cs (string->list s))\n(display (list 'len? (= (string-length s) (length cs)) 'roundtrip? (equal? s (list->string cs))))\n(newline)"
     :invariant "∀ s. |string->list(s)| = |s| ∧ list->string(string->list(s)) = s"
     :meta "The pattern is representation round-trip. CS pattern name: reification. What would falsify: length mismatch or content change on roundtrip. See book-of-code ch05."
     :eng "Lossless conversion."
     :math "string->list and list->string are mutual inverses."
     :cs "Reification."))
  :row-5-emergence (
    (:base "string->list turns a string into a character list."
     :composition "(define (has-digit? s) (not (null? (filter char-numeric? (string->list s)))))\n(display (has-digit? \"abc1\"))\n(newline)\n(display (has-digit? \"abcd\"))\n(newline)"
     :emergent "string-level predicate — apply a character predicate as a string predicate via string->list and filter"
     :meta "The composition chains string->list with filter. What emerges is the string-level-predicate family: lifting character predicates to strings. See book-of-composition ch06."))
)

(verb :name "list->string"  :library "string" :tier "core" :kind "pure" :signature "(list->string lst) -> string"
  :summary "Concatenate a list of chars into a string. R7RS §6.7."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(list->string (list \"a\" \"b\" \"c\"))" :note "\"abc\".")
    (:dialect "motoi" :tier "intermediate" :code "(list->string (map string-upcase (string->list \"hi\")))" :note "\"HI\" — round-trip through a list.")
  )
  :row-2-audit (
    (:problem "The operator has manipulated a list of characters and needs the string. Candidates: list->string (single call), string-join with empty sep (works but noisier), apply string (works for small lists). For 'list of chars → string,' list->string is honest."
     :program "(define chars (list \"h\" \"i\"))\n(display (list->string chars))\n(newline)"
     :explanation "Line 1 defines chars. Lines 2-3 concat to string: hi. The audit tape shows one concat."
     :meta "Why list->string and not string-join with empty sep: list->string is one-verb clarity.")
    (:eng "Prefer list->string as the inverse of string->list."
     :math "Inverse of string->list."
     :cs "Related patterns: ''.join(list) in Python."))
  :row-3-dimension (
    (:setup "A representation switch back: reassemble a walkable form into a compact form."
     :rungs ((:domain "string" :code "(list->string chars)")
             (:domain "respool a ribbon" :code "(respool ribbon-pieces)")
             (:domain "sequence coercion" :code "(define (from-chars cs) (fold-right string-append \"\" cs))"))
     :explanation "In string, list->string reassembles. Respooling a ribbon restores its compact form. In sequence coercion, converting back to the compact representation is the inverse. All three share: walkable form → compact form."
     :meta "The shape transfers wherever the inverse of string->list is required."))
  :row-4-proof (
    (:claim "list->string is the inverse of string->list on characters; length equals list length."
     :program "(define cs (list \"m\" \"o\" \"t\" \"o\" \"i\"))\n(define s (list->string cs))\n(display (list 'len? (= (length cs) (string-length s)) 'roundtrip? (equal? cs (string->list s))))\n(newline)"
     :invariant "∀ char list cs. string->list(list->string(cs)) = cs ∧ |list->string(cs)| = |cs|"
     :meta "The pattern is inverse pairing. CS pattern name: reification-inverse. What would falsify: non-inverse behavior. See book-of-code ch05."
     :eng "Lossless conversion."
     :math "Mutual inverses with string->list."
     :cs "Same complexity considerations."))
  :row-5-emergence (
    (:base "list->string reassembles a character list into a string."
     :composition "(define (retain-alphanumeric s)\n  (list->string (filter (lambda (c) (or (char-alphabetic? c) (char-numeric? c))) (string->list s))))\n(display (retain-alphanumeric \"Hello, World! 42.\"))\n(newline)"
     :emergent "sanitize-by-predicate — filter characters by a predicate and reassemble the string"
     :meta "The composition chains string->list, filter, and list->string. What emerges is the sanitize family: character-level filtering. Same shape as re.sub for character classes, as slugification. See book-of-composition ch06."))
)

(verb :name "string"        :library "string" :tier "core" :kind "pure" :signature "(string char ...) -> string"
  :summary "Build a string from character arguments. R7RS §6.7."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string \"h\" \"i\")" :note "\"hi\" — join char-strings.")
    (:dialect "motoi" :tier "intermediate" :code "(string \"a\" \"b\" \"c\" \"d\")" :note "\"abcd\".")
  )
  :row-2-audit (
    (:problem "The operator wants to construct a string from a few known character values without building a list first. Candidates: string (variadic constructor), list->string with a list literal (works but requires a list allocation). For 'know these characters, want a string,' string is honest."
     :program "(display (string \"h\" \"i\"))\n(newline)\n(display (string \"a\" \"b\" \"c\"))\n(newline)"
     :explanation "Line 1 builds hi from two chars. Line 2 builds abc from three. The audit tape shows one call per string, no intermediate list."
     :meta "Why string and not list->string: variadic call is direct.")
    (:eng "Prefer variadic string when char count is small and known."
     :math "Constructor: (h, i) → hi."
     :cs "Related patterns: String.valueOf(char[]) in Java, ''.join([c1, c2, ...]) in Python."))
  :row-3-dimension (
    (:setup "A variadic constructor: assemble a value from a fixed number of atomic parts."
     :rungs ((:domain "string" :code "(string \"h\" \"i\")")
             (:domain "sandwich stacking" :code "(sandwich 'bread 'cheese 'bread)")
             (:domain "n-ary constructor" :code "(define (mk-str . cs) (list->string cs))"))
     :explanation "In string, the constructor builds from chars. In assembly, layering physical items produces a stack. In math, an n-ary constructor takes n parts. All three share: variadic assembly from atomic parts."
     :meta "The shape transfers wherever a compound value is assembled from a fixed set of parts."))
  :row-4-proof (
    (:claim "string constructor produces a string whose length equals the number of char arguments and whose characters are those args in order."
     :program "(display (string-length (string \"a\" \"b\" \"c\")))\n(newline)\n(display (equal? (string \"a\" \"b\" \"c\") \"abc\"))\n(newline)"
     :invariant "∀ c_1..c_n. |string(c_1..c_n)| = n ∧ string(c_1..c_n)[i] = c_{i+1}"
     :meta "The pattern is order-preserving n-ary construction. CS pattern name: variadic constructor. What would falsify: length mismatch or reorder. See book-of-code ch05."
     :eng "Predictable output shape."
     :math "String is the free monoid generator."
     :cs "Constructor idiom."))
  :row-5-emergence (
    (:base "string variadically constructs a string."
     :composition "(define (bracket-triplet a b c) (string \"[\" a b c \"]\"))\n(display (bracket-triplet \"a\" \"b\" \"c\"))\n(newline)"
     :emergent "framed-string builder — a routine that wraps content between fixed frame characters"
     :meta "The composition uses string as the framing constructor. What emerges is the frame-content family: bracketed strings. See book-of-composition ch07."))
)

(verb :name "make-string"   :library "string" :tier "core" :kind "pure" :signature "(make-string k [char]) -> string"
  :summary "A string of k copies of char (default space). R7RS §6.7."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(make-string 5 \"x\")" :note "\"xxxxx\".")
    (:dialect "motoi" :tier "intermediate" :code "(make-string 3 \"-\")" :note "\"---\" — a separator.")
  )
  :row-2-audit (
    (:problem "The operator wants a horizontal rule for a report — a string of 40 dashes. Candidates: make-string (k copies of a char), string-pad on an empty string (works but reads oddly), a manual loop. For 'k copies of char,' make-string is honest."
     :program "(display (make-string 40 \"-\"))\n(newline)"
     :explanation "Line 1 makes 40 dashes. Line 2 prints the horizontal rule. The audit tape shows one make-string call."
     :meta "Why make-string and not string-pad: the intent is 'k copies,' not padding.")
    (:eng "Prefer make-string for filler generation."
     :math "The result is char^k."
     :cs "Related patterns: 'x' * n in Python, StringBuilder append loop, str_repeat in PHP."))
  :row-3-dimension (
    (:setup "A repeat: produce n copies of a single element as a sequence."
     :rungs ((:domain "string" :code "(make-string 40 \"-\")")
             (:domain "a row of identical soldiers" :code "(muster-row 10 'soldier)")
             (:domain "monoid power a^n" :code "(define (power a n) (if (= n 0) \"\" (string-append a (power a (- n 1)))))"))
     :explanation "In string, make-string produces k copies. Mustering identical units is the same shape. In math, monoid exponentiation is repeated concatenation. All three share: repeat element k times."
     :meta "The shape transfers wherever k copies of one atom must become one collection."))
  :row-4-proof (
    (:claim "make-string(k, c) returns a string of length k where every character equals c; make-string(0, c) is the empty string."
     :program "(display (make-string 0 \"x\"))\n(newline)\n(display (make-string 5 \"a\"))\n(newline)\n(display (list 'len? (= 5 (string-length (make-string 5 \"a\")))))\n(newline)"
     :invariant "∀ k ≥ 0 c. |make-string(k, c)| = k ∧ ∀ i. make-string(k, c)[i] = c"
     :meta "The pattern is uniform repeat. CS pattern name: repeat. What would falsify: length mismatch or nonuniform content. See book-of-code ch05."
     :eng "Predictable output."
     :math "Monoid power a^k."
     :cs "Fill idiom."))
  :row-5-emergence (
    (:base "make-string produces k copies of a char."
     :composition "(define (indent-block text n)\n  (let ((prefix (make-string n \" \")))\n    (string-join (map (lambda (line) (string-append prefix line)) (string-split text \"\\n\")) \"\\n\")))\n(display (indent-block \"line1\\nline2\" 4))\n(newline)"
     :emergent "block indenter — a routine that prepends a uniform indentation to every line"
     :meta "The composition uses make-string to build the indent, then maps prepend over lines. What emerges is the indent family: uniform block indentation. See book-of-composition ch10."))
)

(verb :name "string-copy"   :library "string" :tier "core" :kind "pure" :signature "(string-copy s [start [end]]) -> string"
  :summary "Copy a substring. R7RS §6.7."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-copy \"hello\")" :note "\"hello\" — a fresh copy.")
    (:dialect "motoi" :tier "intermediate" :code "(define a \"hi\")\n(define b (string-copy a))\n(equal? a b)" :note "#t — same content.")
  )
  :row-2-audit (
    (:problem "The operator wants a fresh copy of a string or a substring for boundary handoff. Candidates: string-copy (fresh copy with optional bounds), substring (also a fresh copy), string-take + string-drop (works but more calls). For explicit copy semantics, string-copy is honest."
     :program "(define original \"hello world\")\n(define fresh (string-copy original))\n(define part (string-copy original 6 11))\n(display (list 'fresh fresh 'part part))\n(newline)"
     :explanation "Line 1 defines original. Line 2 fresh copy. Line 3 substring copy 6..11 = world. Lines 4-5 print. The audit tape shows two copies, one bounded."
     :meta "Why string-copy and not substring: string-copy without bounds returns a whole fresh copy; substring requires bounds.")
    (:eng "In Motoi strings are immutable, so string-copy is mostly about intent-signaling; useful when interfacing with runtimes where strings are mutable."
     :math "The result equals s[start..end]."
     :cs "Related patterns: str[:] in Python, String::clone in Rust."))
  :row-3-dimension (
    (:setup "A copy: produce an independent handle to the same (or partial) content."
     :rungs ((:domain "string" :code "(string-copy s)")
             (:domain "photocopy a page" :code "(photocopy page)")
             (:domain "identity map with distinct output" :code "(define (twin s) (string-append s \"\"))"))
     :explanation "In string, copy produces an independent handle. Photocopying makes an independent duplicate. In math, an identity map that guarantees fresh output is the same shape. All three share: same content, new container."
     :meta "The shape transfers wherever a defensive copy is needed."))
  :row-4-proof (
    (:claim "string-copy returns a string equal to s (or to s[start..end] with bounds); length matches the bounds; equal? is #t on the content."
     :program "(define s \"hello\")\n(define c1 (string-copy s))\n(define c2 (string-copy s 1 4))\n(display (list 'full-eq? (equal? c1 s) 'partial? c2 'len (string-length c2)))\n(newline)"
     :invariant "∀ s. string-copy(s) equal? s ∧ ∀ start end. string-copy(s, start, end) equal? substring(s, start, end)"
     :meta "The pattern is content-preserving copy. CS pattern name: shallow copy. What would falsify: an inequal-equal? result. See book-of-code ch05."
     :eng "Predictable content and length."
     :math "Identity on content, distinct on reference."
     :cs "In Motoi Scheme immutable-string semantics, string-copy is a hygiene primitive; in mutable-string runtimes it is a defensive-copy operation."))
  :row-5-emergence (
    (:base "string-copy makes a fresh copy of a string or substring."
     :composition "(define (extract-and-log s tag start end)\n  (let ((piece (string-copy s start end)))\n    (display (list 'tag tag 'piece piece))\n    (newline)\n    piece))\n(display (extract-and-log \"header:body:footer\" 'body 7 11))\n(newline)"
     :emergent "log-and-return — a routine that extracts a piece, logs the extraction, and returns the piece"
     :meta "The composition wraps string-copy in a logging shell. What emerges is the audit-log family: extraction with provenance. See book-of-composition ch14."))
)

(verb :name "string<?"      :library "string" :tier "core" :kind "pure" :signature "(string<? a b) -> boolean"
  :summary "Lexicographic less-than. R7RS §6.7."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string<? \"apple\" \"banana\")" :note "#t — lexicographic order.")
    (:dialect "motoi" :tier "intermediate" :code "(string<? \"z\" \"a\")" :note "#f.")
  )
  :row-2-audit (
    (:problem "The operator is sorting a list of strings alphabetically. Candidates: string<? (case-sensitive), string-ci<? (case-insensitive — sometimes wanted, sometimes not), a custom comparator. For strict alphabetical order, string<? is honest."
     :program "(define fruits (list \"banana\" \"apple\" \"cherry\"))\n(display (sort fruits string<?))\n(newline)"
     :explanation "Line 1 defines an unsorted list. Lines 2-3 sort ascending by string<?. The audit tape shows one sort with an explicit comparator."
     :meta "Why string<? and not string-ci<?: string<? distinguishes 'Apple' from 'apple' (uppercase sorts before lowercase in ASCII).")
    (:eng "Choose the comparator that matches the user-facing sort convention; log the choice."
     :math "Lexicographic order on the character sequence."
     :cs "Related patterns: str1 < str2 in Python, compareTo in Java."))
  :row-3-dimension (
    (:setup "A strict order predicate: does the first argument precede the second in a total order?"
     :rungs ((:domain "string" :code "(string<? a b)")
             (:domain "dictionary lookup order" :code "(comes-first-in-dict? a b)")
             (:domain "total order relation" :code "(define (lt? a b) (compare a b))"))
     :explanation "In string, <? is lexicographic. Dictionary lookup order is the same lexicographic principle. In math, a total order is the abstract shape. All three share: strict precedence in a total order."
     :meta "The shape transfers wherever a total order over strings is required."))
  :row-4-proof (
    (:claim "string<? is transitive, irreflexive, and asymmetric: a<b ∧ b<c ⇒ a<c; NOT a<a; a<b ⇒ NOT b<a."
     :program "(display (string<? \"a\" \"b\"))\n(newline)\n(display (string<? \"a\" \"a\"))\n(newline)\n(display (and (string<? \"a\" \"b\") (string<? \"b\" \"c\") (string<? \"a\" \"c\")))\n(newline)"
     :invariant "∀ a b c. (string<?(a,b) ∧ string<?(b,c)) ⇒ string<?(a,c); NOT string<?(a,a); string<?(a,b) ⇒ NOT string<?(b,a)"
     :meta "The pattern is strict total order. CS pattern name: total-order predicate. What would falsify: reflexivity or asymmetry violation. See book-of-math ch07."
     :eng "Reliable for sort input."
     :math "Strict total order on strings."
     :cs "Comparator idiom."))
  :row-5-emergence (
    (:base "string<? is lexicographic less-than."
     :composition "(define (sorted-index xs)\n  (map (lambda (p) (list (car p) (cdr p))) (sort (map cons xs (iota (length xs))) (lambda (a b) (string<? (car a) (car b))))))\n(display (sorted-index (list \"banana\" \"apple\" \"cherry\")))\n(newline)"
     :emergent "sorted index — a routine that sorts and reports original positions"
     :meta "The composition uses string<? in a sort comparator. What emerges is the argsort family: return positions in sorted order. Same shape as np.argsort. See book-of-composition ch09."))
)

(verb :name "string>?"      :library "string" :tier "core" :kind "pure" :signature "(string>? a b) -> boolean"
  :summary "Lexicographic greater-than. R7RS §6.7."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string>? \"banana\" \"apple\")" :note "#t.")
    (:dialect "motoi" :tier "intermediate" :code "(string>? \"a\" \"z\")" :note "#f.")
  )
  :row-2-audit (
    (:problem "The operator is sorting a list of strings descending. Candidates: string>?, or string<? with reversed arguments. For descending sort, string>? is direct."
     :program "(define fruits (list \"banana\" \"apple\" \"cherry\"))\n(display (sort fruits string>?))\n(newline)"
     :explanation "Line 1 defines an unsorted list. Lines 2-3 sort descending. The audit tape shows the descending comparator by name."
     :meta "Why string>? and not (lambda (a b) (string<? b a)): named descending comparator reads directly.")
    (:eng "Prefer the named comparator over an argument-swap lambda."
     :math "Inverse relation of string<?."
     :cs "Related patterns: str1 > str2 in Python."))
  :row-3-dimension (
    (:setup "The opposite strict order predicate: does the first argument come after the second?"
     :rungs ((:domain "string" :code "(string>? a b)")
             (:domain "reverse alphabetical shelf" :code "(comes-later-than? a b)")
             (:domain "converse of <" :code "(define (gt? a b) (lt? b a))"))
     :explanation "In string, >? is the reverse of <?. Reverse alphabetical shelving is the same shape. In math, the converse of a total order. All three share: strict succession in the reversed order."
     :meta "The shape transfers wherever the reversed total order is required."))
  :row-4-proof (
    (:claim "string>? is the converse of string<?: a>b iff b<a."
     :program "(display (equal? (string>? \"b\" \"a\") (string<? \"a\" \"b\")))\n(newline)\n(display (string>? \"a\" \"a\"))\n(newline)"
     :invariant "∀ a b. string>?(a, b) = string<?(b, a); NOT string>?(a, a)"
     :meta "The pattern is converse-of-strict-order. CS pattern name: comparator converse. What would falsify: string>?(a,b) ≠ string<?(b,a). See book-of-math ch07."
     :eng "Reliable descending sort."
     :math "Converse relation."
     :cs "Comparator converse."))
  :row-5-emergence (
    (:base "string>? is lexicographic greater-than."
     :composition "(define (top-n xs n) (list-take-safe (sort xs string>?) n))\n(define (list-take-safe xs n) (if (or (null? xs) (= n 0)) (list) (cons (car xs) (list-take-safe (cdr xs) (- n 1)))))\n(display (top-n (list \"banana\" \"apple\" \"cherry\" \"date\") 2))\n(newline)"
     :emergent "top-N by string order — the N greatest strings by lexicographic order"
     :meta "The composition chains sort with string>? and a take. What emerges is the top-N family: partial sort of descending order. See book-of-composition ch09."))
)

(verb :name "string<=?"     :library "string" :tier "core" :kind "pure" :signature "(string<=? a b) -> boolean"
  :summary "Lexicographic less-than-or-equal."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string<=? \"apple\" \"apple\")" :note "#t.")
    (:dialect "motoi" :tier "intermediate" :code "(string<=? \"a\" \"b\")" :note "#t.")
  )
  :row-2-audit (
    (:problem "The operator wants to check whether a candidate string falls within a lower-bounded range. Candidates: string<=? (allows equality), string<? (strict — wrong for inclusive bounds). For inclusive lower bound, string<=? is honest."
     :program "(define (in-range? s lo hi) (and (string<=? lo s) (string<=? s hi)))\n(display (in-range? \"cat\" \"c\" \"d\"))\n(newline)\n(display (in-range? \"d\" \"c\" \"d\"))\n(newline)"
     :explanation "Line 1 defines an inclusive-range check. Lines 2-3 test 'cat' between 'c' and 'd' (#t). Lines 4-5 test 'd' at the boundary (#t, inclusive). The audit tape shows inclusive membership."
     :meta "Why string<=? and not string<?: <=? gives boundary-inclusive semantics.")
    (:eng "Inclusive bounds match user expectations for range queries."
     :math "Non-strict total order."
     :cs "Related patterns: str1 <= str2 in Python."))
  :row-3-dimension (
    (:setup "A non-strict order predicate: precede or equal."
     :rungs ((:domain "string" :code "(string<=? a b)")
             (:domain "inclusive shelf range" :code "(in-inclusive-range shelf a b)")
             (:domain "reflexive total order ≤" :code "(define (le? a b) (or (equal? a b) (lt? a b)))"))
     :explanation "In string, <=? is inclusive. Inclusive shelf ranges are the same shape. In math, ≤ is the reflexive closure of <. All three share: precede or equal."
     :meta "The shape transfers wherever inclusive bounds are needed."))
  :row-4-proof (
    (:claim "string<=? is reflexive, transitive, and antisymmetric: a<=a; (a<=b ∧ b<=c) ⇒ a<=c; (a<=b ∧ b<=a) ⇒ a=b."
     :program "(display (string<=? \"a\" \"a\"))\n(newline)\n(display (and (string<=? \"a\" \"b\") (string<=? \"b\" \"c\") (string<=? \"a\" \"c\")))\n(newline)\n(display (and (string<=? \"a\" \"a\") (string<=? \"a\" \"a\") (equal? \"a\" \"a\")))\n(newline)"
     :invariant "∀ a b c. string<=?(a,a); (string<=?(a,b) ∧ string<=?(b,c)) ⇒ string<=?(a,c); (string<=?(a,b) ∧ string<=?(b,a)) ⇒ a = b"
     :meta "The pattern is total order (non-strict). CS pattern name: partial-order-plus-totality. What would falsify: irreflexivity or antisymmetry violation. See book-of-math ch07."
     :eng "Reliable inclusive comparison."
     :math "Total order with reflexivity."
     :cs "Comparator idiom."))
  :row-5-emergence (
    (:base "string<=? is non-strict lexicographic order."
     :composition "(define (bounded-slice xs lo hi)\n  (filter (lambda (x) (and (string<=? lo x) (string<=? x hi))) xs))\n(display (bounded-slice (list \"apple\" \"banana\" \"cherry\" \"date\") \"b\" \"c\"))\n(newline)"
     :emergent "range-slice — a filter that retains strings within an inclusive range"
     :meta "The composition uses string<=? twice in a range filter. What emerges is the range-slice family: SQL WHERE k BETWEEN a AND b. See book-of-composition ch08."))
)

(verb :name "string>=?"     :library "string" :tier "core" :kind "pure" :signature "(string>=? a b) -> boolean"
  :summary "Lexicographic greater-than-or-equal."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string>=? \"banana\" \"banana\")" :note "#t.")
    (:dialect "motoi" :tier "intermediate" :code "(string>=? \"b\" \"a\")" :note "#t.")
  )
  :row-2-audit (
    (:problem "The operator wants an inclusive-upper-bound test. Candidates: string>=?, string>? (strict), string<=? with swapped args (equivalent but noisier). For inclusive upper bound, string>=? is honest."
     :program "(display (string>=? \"cat\" \"c\"))\n(newline)\n(display (string>=? \"c\" \"c\"))\n(newline)"
     :explanation "Line 1 tests 'cat' ≥ 'c' (#t). Line 2 tests 'c' ≥ 'c' (#t, inclusive). The audit tape confirms inclusive bound."
     :meta "Why string>=?: reads as 'at least,' matches user semantic.")
    (:eng "Inclusive-upper-bound named comparator."
     :math "Reflexive closure of >."
     :cs "Related patterns: str1 >= str2 in Python."))
  :row-3-dimension (
    (:setup "A non-strict reverse order predicate: succeed or equal."
     :rungs ((:domain "string" :code "(string>=? a b)")
             (:domain "inclusive-upper-bound shelf" :code "(at-or-later-than? a b)")
             (:domain "≥ relation" :code "(define (ge? a b) (or (equal? a b) (gt? a b)))"))
     :explanation "In string, >=? is inclusive. Shelf semantics 'this letter or later' matches. In math, ≥ is the reflexive closure of >. All three share: succeed or equal."
     :meta "The shape transfers wherever an inclusive succession bound is needed."))
  :row-4-proof (
    (:claim "string>=? is the converse of string<=?: a>=b iff b<=a."
     :program "(display (equal? (string>=? \"b\" \"a\") (string<=? \"a\" \"b\")))\n(newline)\n(display (string>=? \"a\" \"a\"))\n(newline)"
     :invariant "∀ a b. string>=?(a, b) = string<=?(b, a); string>=?(a, a) = #t"
     :meta "The pattern is converse-of-non-strict-order. CS pattern name: comparator converse. What would falsify: converse mismatch. See book-of-math ch07."
     :eng "Reliable comparison."
     :math "Converse of ≤."
     :cs "Comparator converse."))
  :row-5-emergence (
    (:base "string>=? is non-strict reverse lexicographic order."
     :composition "(define (from-letter xs c)\n  (filter (lambda (x) (string>=? x c)) xs))\n(display (from-letter (list \"apple\" \"banana\" \"cherry\" \"date\") \"c\"))\n(newline)"
     :emergent "letter-cutoff filter — retain strings at or after a given letter"
     :meta "The composition uses string>=? in a filter. What emerges is the cutoff filter family: SQL WHERE k >= threshold. See book-of-composition ch08."))
)

(verb :name "string-ci=?"   :library "string" :tier "core" :kind "pure" :signature "(string-ci=? a b) -> boolean"
  :summary "Case-insensitive string equality. R7RS §6.7."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-ci=? \"Hello\" \"hello\")" :note "#t — case-insensitive equal.")
    (:dialect "motoi" :tier "intermediate" :code "(string-ci=? \"MOTOI\" \"motoi\")" :note "#t.")
  )
  :row-2-audit (
    (:problem "The operator is comparing user input against a canonical option list where case is not significant (e.g., yes/YES/Yes should all match). Candidates: string-ci=? (direct), normalizing both sides with string-downcase then equal? (equivalent but two normalizations per compare). For single-shot case-insensitive equality, string-ci=? is honest."
     :program "(define legal (list \"YES\" \"NO\" \"MAYBE\"))\n(define (accept? inp) (any? (lambda (o) (string-ci=? inp o)) legal))\n(define (any? pred xs) (cond ((null? xs) #f) ((pred (car xs)) #t) (else (any? pred (cdr xs)))))\n(display (accept? \"yes\"))\n(newline)\n(display (accept? \"maybe not\"))\n(newline)"
     :explanation "Line 1 defines legal answers in canonical form. Line 2 wraps a case-insensitive membership check. Line 4-5 test 'yes' (#t). Lines 6-7 test invalid (#f). The audit tape shows case-agnostic membership."
     :meta "Why string-ci=? and not downcase+equal?: one call vs two normalizations per compare.")
    (:eng "Prefer case-insensitive equality where user-facing matching is expected."
     :math "Equality on the case-normalized form."
     :cs "Related patterns: str1.lower() == str2.lower() in Python, equalsIgnoreCase in Java."))
  :row-3-dimension (
    (:setup "A case-agnostic equality: two strings match if they differ only in case."
     :rungs ((:domain "string" :code "(string-ci=? a b)")
             (:domain "verbal match regardless of pronunciation stress" :code "(same-word? a b)")
             (:domain "equivalence up to a relation" :code "(define (eq-up-to f a b) (equal? (f a) (f b)))"))
     :explanation "In string, ci=? is equality up to case. In language, matching regardless of pronunciation nuance is the same shape. In math, equivalence up to a normalization is the abstract form. All three share: equality modulo a normalization."
     :meta "The shape transfers wherever equivalence is up to a canonical form."))
  :row-4-proof (
    (:claim "string-ci=? is an equivalence relation: reflexive, symmetric, transitive; equal? implies string-ci=?."
     :program "(display (string-ci=? \"a\" \"a\"))\n(newline)\n(display (equal? (string-ci=? \"a\" \"A\") (string-ci=? \"A\" \"a\")))\n(newline)\n(display (and (string-ci=? \"a\" \"A\") (string-ci=? \"A\" \"a\") #t))\n(newline)\n(display (if (equal? \"foo\" \"foo\") (string-ci=? \"foo\" \"foo\") #f))\n(newline)"
     :invariant "∀ a b c. string-ci=?(a,a); string-ci=?(a,b) ⇒ string-ci=?(b,a); (string-ci=?(a,b) ∧ string-ci=?(b,c)) ⇒ string-ci=?(a,c); equal?(a,b) ⇒ string-ci=?(a,b)"
     :meta "The pattern is equivalence relation. CS pattern name: equality with normalization. What would falsify: symmetry or transitivity violation. See book-of-math ch07 on equivalences."
     :eng "Reliable membership tests when case does not matter."
     :math "Equivalence relation."
     :cs "Equality up to a canonical form."))
  :row-5-emergence (
    (:base "string-ci=? is case-insensitive equality."
     :composition "(define (member-ci x xs) (any? (lambda (y) (string-ci=? x y)) xs))\n(define (any? pred xs) (cond ((null? xs) #f) ((pred (car xs)) #t) (else (any? pred (cdr xs)))))\n(display (member-ci \"MOTOI\" (list \"scheme\" \"motoi\" \"sakura\")))\n(newline)"
     :emergent "case-insensitive membership — a case-agnostic version of member"
     :meta "The composition wraps string-ci=? in a membership loop. What emerges is the case-insensitive-index family: hash lookup + downcase, or explicit ci compare. See book-of-composition ch06."))
)

(verb :name "string-ci<?"   :library "string" :tier "core" :kind "pure" :signature "(string-ci<? a b) -> boolean"
  :summary "Case-insensitive lexicographic less-than."
  :provenance "R7RS §6.7; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string-ci<? \"apple\" \"BANANA\")" :note "#t — case-insensitive compare.")
    (:dialect "motoi" :tier "intermediate" :code "(string-ci<? \"Z\" \"a\")" :note "#f — 'z' > 'a' case-insensitive.")
  )
  :row-2-audit (
    (:problem "The operator is sorting strings alphabetically for a user-facing display where mixed-case data should sort as if all lowercase (or all uppercase — same result). Candidates: string-ci<? (case-insensitive), string<? (case-sensitive — 'Z' sorts before 'a' in ASCII which surprises users). For user-facing alphabetical sort, string-ci<? is honest."
     :program "(define names (list \"alice\" \"BOB\" \"Carol\" \"dave\"))\n(display (sort names string-ci<?))\n(newline)"
     :explanation "Line 1 defines names in mixed case. Lines 2-3 sort case-insensitively. The audit tape shows a case-agnostic sort."
     :meta "Why string-ci<? and not string<?: string<? would put 'BOB' before 'alice' by ASCII, surprising users.")
    (:eng "Prefer case-insensitive comparators for user-facing alphabetical order."
     :math "Lexicographic order on the case-normalized form."
     :cs "Related patterns: str1.lower() < str2.lower() in Python."))
  :row-3-dimension (
    (:setup "A case-insensitive strict order predicate."
     :rungs ((:domain "string" :code "(string-ci<? a b)")
             (:domain "phone-book order (case-agnostic)" :code "(comes-first-phonebook? a b)")
             (:domain "order up to normalization" :code "(define (ci-lt a b) (string<? (string-downcase a) (string-downcase b)))"))
     :explanation "In string, ci<? is case-agnostic. Phone-book order treats case uniformly. In math, order after normalization is the same shape. All three share: strict order modulo case."
     :meta "The shape transfers wherever a user-facing sort is required."))
  :row-4-proof (
    (:claim "string-ci<? is a strict total order on the case-normalized forms: transitive, irreflexive, asymmetric."
     :program "(display (string-ci<? \"a\" \"A\"))\n(newline)\n(display (string-ci<? \"a\" \"b\"))\n(newline)\n(display (and (string-ci<? \"a\" \"B\") (string-ci<? \"B\" \"c\") (string-ci<? \"a\" \"c\")))\n(newline)"
     :invariant "∀ a b c. (string-ci<?(a,b) ∧ string-ci<?(b,c)) ⇒ string-ci<?(a,c); NOT string-ci<?(a, upcase(a))"
     :meta "The pattern is strict total order after normalization. CS pattern name: normalized comparator. What would falsify: transitivity or asymmetry violation. See book-of-math ch07."
     :eng "Reliable case-insensitive sort."
     :math "Strict total order on the case-normalized class."
     :cs "Equivalent to string<? on downcased inputs."))
  :row-5-emergence (
    (:base "string-ci<? is case-insensitive less-than."
     :composition "(define (dedupe-and-sort xs)\n  (delete-duplicates (sort xs string-ci<?)))\n(display (dedupe-and-sort (list \"alice\" \"BOB\" \"Alice\" \"carol\" \"bob\")))\n(newline)"
     :emergent "user-facing directory — sorted and deduplicated in a case-insensitive manner"
     :meta "The composition chains sort with string-ci<? and delete-duplicates. What emerges is the directory family: user-facing alphabetical + unique. See book-of-composition ch09."))
)

(verb :name "symbol->string" :library "string" :tier "core" :kind "pure" :signature "(symbol->string sym) -> string"
  :summary "Convert a symbol to its printable name. R7RS §6.5."
  :examples ((:dialect "motoi" :tier "novice" :code "(symbol->string 'foo)" :note "\"foo\"."))
  :provenance "R7RS §6.5; added 2026-07-18 finalization"
  :row-2-audit (
    (:problem "The operator has a symbol identifying a config key and wants its textual form for display or logging. Candidates: symbol->string (canonical), write-to-string (works but includes quoting for non-symbol values). For 'symbol as text,' symbol->string is honest."
     :program "(define k 'log-level)\n(display (list 'key-name (symbol->string k)))\n(newline)"
     :explanation "Line 1 defines a symbol. Lines 2-3 print its name as a string. The audit tape shows one conversion."
     :meta "Why symbol->string and not write-to-string: symbol->string commits to the type and returns the bare name.")
    (:eng "Convert at logging boundaries; keep symbols as internal handles."
     :math "The symbol's printable name."
     :cs "Related patterns: Symbol.description in JS, __name__ on symbols."))
  :row-3-dimension (
    (:setup "A representation switch: from an interned identity value (symbol) to its printable name (string)."
     :rungs ((:domain "string" :code "(symbol->string 'foo)")
             (:domain "read a person's ID badge name" :code "(badge-name person)")
             (:domain "identity → label" :code "(define (name x) x)"))
     :explanation "In string, symbol->string exposes the name of the symbol. Reading a badge exposes a person's display name. In math, the naming map from identity to label is the same shape. All three share: identity → its printable form."
     :meta "The shape transfers wherever an internal identity needs a printable projection."))
  :row-4-proof (
    (:claim "symbol->string returns a string with the symbol's canonical name; the round-trip through string->symbol recovers an equivalent symbol."
     :program "(define k 'motoi)\n(define s (symbol->string k))\n(display (list 'name s 'roundtrip? (eq? k (string->symbol s))))\n(newline)"
     :invariant "∀ sym. string->symbol(symbol->string(sym)) eq? sym"
     :meta "The pattern is round-trip identity. CS pattern name: reification. What would falsify: a non-eq? recovery. See book-of-code ch05."
     :eng "Reliable identity round-trip."
     :math "symbol->string is a bijection on interned symbols."
     :cs "Interning ensures eq? equality on round-trip."))
  :row-5-emergence (
    (:base "symbol->string exposes a symbol's name."
     :composition "(define (config->text cfg)\n  (string-join\n    (map (lambda (p) (string-append (symbol->string (car p)) \"=\" (symbol->string (cadr p)))) cfg)\n    \"; \"))\n(display (config->text (list (list 'theme 'dark) (list 'font 'sans))))\n(newline)"
     :emergent "config serializer — a routine that renders a symbolic config as a key=value text string"
     :meta "The composition chains symbol->string with string-append and string-join. What emerges is the serializer family: symbolic-to-textual conversion. See book-of-composition ch07."))
)

(verb :name "string->symbol" :library "string" :tier "core" :kind "pure" :signature "(string->symbol s) -> symbol"
  :summary "Intern a string as a symbol. R7RS §6.5."
  :provenance "R7RS §6.5; added 2026-07-18 finalization"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(string->symbol \"hello\")" :note "hello — the symbol.")
    (:dialect "motoi" :tier "intermediate" :code "(define name \"count\")\n(string->symbol name)" :note "count — build symbols at runtime.")
  )
  :row-2-audit (
    (:problem "The operator has parsed a config file: keys arrive as strings but internal code uses symbols as hash-table keys for cheaper equality checks. Candidates: string->symbol (intern), keeping strings (works but eq? never applies), (read (open-input-string s)) (over-general — parses arbitrary Scheme). For 'string → interned symbol,' string->symbol is honest."
     :program "(define config (make-hash-table))\n(define (set-config-line! kv)\n  (let* ((i (string-index kv \"=\"))\n         (k (string->symbol (string-take kv i)))\n         (v (string-drop kv (+ i 1))))\n    (hash-set! config k v)))\n(set-config-line! \"theme=dark\")\n(display (hash-ref config 'theme 'unknown))\n(newline)"
     :explanation "Line 1 constructs config. Lines 2-6 define a parser that interns the key as a symbol. Line 7 loads a line. Lines 8-9 read the key by its symbol form. The audit tape shows string→symbol at the boundary."
     :meta "Why string->symbol and not keeping strings: interned symbols enable eq? equality, which is faster than equal? for hash keys.")
    (:eng "Intern at the parse boundary; downstream code uses symbols exclusively."
     :math "The result is the symbol whose name equals s."
     :cs "Related patterns: Symbol.for(name) in JS, Ruby's :name.to_sym."))
  :row-3-dimension (
    (:setup "An interning: turn a printable name into a canonical identity value."
     :rungs ((:domain "string" :code "(string->symbol \"key\")")
             (:domain "name → assigned employee ID" :code "(assign-badge name)")
             (:domain "canonical representative" :code "(define (intern s) s)"))
     :explanation "In string, string->symbol interns. Assigning an employee ID canonicalizes a name. In math, choosing a canonical representative for a class is the same shape. All three share: name → identity handle."
     :meta "The shape transfers wherever a runtime prefers identity handles over textual names."))
  :row-4-proof (
    (:claim "string->symbol is inverse of symbol->string on strings that are legal symbol names; two calls with equal string args return eq? symbols."
     :program "(display (eq? (string->symbol \"foo\") (string->symbol \"foo\")))\n(newline)\n(define k (string->symbol \"bar\"))\n(display (equal? (symbol->string k) \"bar\"))\n(newline)"
     :invariant "∀ s legal-name. symbol->string(string->symbol(s)) = s ∧ (string->symbol(s) eq? string->symbol(s))"
     :meta "The pattern is interning identity. CS pattern name: canonical form. What would falsify: two calls returning non-eq? symbols. See book-of-code ch05."
     :eng "Interning guarantees eq? on subsequent calls."
     :math "Bijection with symbol->string on the legal-name subset."
     :cs "Interning is the standard identity mechanism for symbols."))
  :row-5-emergence (
    (:base "string->symbol interns a string."
     :composition "(define registry (make-hash-table))\n(define (register-verb! name)\n  (hash-set! registry (string->symbol name) #t))\n(define (has-verb? name)\n  (hash-ref registry (string->symbol name) #f))\n(register-verb! \"draw\")\n(display (has-verb? \"draw\"))\n(newline)"
     :emergent "verb registry — a runtime registration table keyed by interned symbols"
     :meta "The composition chains string->symbol with hash-set/hash-ref. What emerges is the interned-key-registry family: name-based lookups over interned symbols. Same shape as intern in Python for CPython small strings, as :name.to_sym.tap in Ruby. See book-of-composition ch11."))
)

