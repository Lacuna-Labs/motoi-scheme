;;; 29-geom.slat — Motoi Scheme Reference · Chapter 29 · library geom
;;;
;;; 57 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library geom — 57 verbs.")

(chapter :number "29" :library "geom" :verb-count 57 :training-eligible #t)

;; ═══ 57 verbs in library geom ═══

(verb
  :name "geom/->degrees"
  :library "geom"
  :kind "meta"
  :signature "(geom/->degrees radians) -> float"
  :summary "Converts an angle from radians to degrees."
  :explanation "Angles in mathematical computation are often stored in radians (a pure ratio of arc length to radius). User-facing geometry and graphics sometimes use degrees (360 per circle). `geom/->degrees` multiplies the radian input by 180/π to convert to degrees. The result is a floating-point value, so conversion introduces device-level rounding; use it only when communicating with graphics or I/O."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/->degrees const/pi)\n;; => 180.0" :note "π radians is 180 degrees; a half circle")
    (:dialect "motoi" :tier "intermediate" :code "(geom/->degrees (/ const/pi 2))\n;; => 90.0" :note "π/2 radians is 90 degrees; a quarter circle")
    (:dialect "motoi" :tier "expert" :code "(define (compass-bearing radians)\n  (let ((deg (geom/->degrees radians)))\n    (modulo deg 360.0)))\n(compass-bearing (/ const/pi 4))\n;; => 45.0" :note "Convert math radians to compass degrees (0–360); useful for graphics or UI display")
  )
  :caveats ("The result is a device-float, subject to floating-point rounding." "Negative radians produce negative degrees (no wrapping applied)." "Very large radian values may lose precision when converted to float.")
  :drawbacks ("One-way conversion; converting back with `geom/->radians` may not recover the original due to rounding." "Not suitable for high-precision scientific computation; exact rationals should be used if precision is critical.")
  :usecases ("Displaying angles in a user interface (protractor, compass, rotation widget)." "Converting math library output (often in radians) to graphics API angles (often in degrees)." "Angle arithmetic for UI animation (rotate a card by N degrees).")
  :related ("geom/->radians" "geom/sin" "geom/cos" "geom/tan" "geom/angle-between" "const/pi")
  :learn (:concept "Radians and degrees are two units for the same angular quantity; 180° = π rad. Conversion is a scalar multiplication." :prerequisites ("const/pi") :progression "Learn geom/->degrees and geom/->radians together for unit conversion, then geom/sin, geom/cos for trigonometry.")
  :row-2-audit (
    (:problem "A UI needs to display a rotation angle in degrees but the game stores it in radians." :program "(define (display-angle rad) (string-append (number->string (geom/->degrees rad)) \" deg\"))
(display-angle (/ math/pi 2))" :explanation "Wrap the radian value in geom/->degrees so the UI layer sees degrees. Concat with a unit label. The math stays in radians internally; only the display crosses the boundary." :meta "geom/->degrees is the correct verb because degrees and radians are the same physical angle in different units. Using (* rad 57.2958) would work numerically but hides intent and the magic number is easy to typo. The named verb makes the conversion auditable.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: unit conversion — a value stays semantically identical but changes the numeric label used to talk about it."
     :rungs (
       (:domain "geom/*" :code "(geom/->degrees x)")
       (:domain "units of temperature (a metaphor domain — degrees Celsius from Kelvin, no chem/* verbs used)" :code "(define (k->c k) (- k 273.15))")
       (:domain "math — scaling a ratio by a fixed constant to change its unit basis" :code "(define (scale x k) (* x k))")
     )
     :explanation "All three rungs multiply an input by a fixed constant to reinterpret its unit. The underlying quantity is unchanged; only the label changes."
     :meta "The shape transfers because the operation is a linear isomorphism between two representations of the same set. Any two units of a scalar quantity are related this way.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "The conversion round-trips: converting radians to degrees and back returns the original value (up to float rounding)." :program "(define (round-trip r) (geom/->radians (geom/->degrees r)))
(< (abs (- (round-trip 1.234) 1.234)) 1e-10)" :invariant "∀ r ∈ ℝ. |geom/->radians(geom/->degrees(r)) − r| < ε" :meta "This is an involution up to rounding: the pair (->degrees, ->radians) forms an isomorphism between the radian and degree representations of the angle group. If the invariant fails, the constant π/180 is wrong. See book-of-math ch 4 (angles and units).")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Convert a radian angle to a degree value for user-facing display." :composition "(define (angle-badge rad)
  (let ((deg (geom/->degrees rad)))
    (list 'label (string-append (number->string deg) \"°\") 'raw rad)))
(angle-badge (/ math/pi 3))" :emergent "display-decorator: raw internal value paired with a formatted user-facing string." :meta "Belongs to the pattern family of view-model projections: the same value is emitted twice — once for the machine (raw radians) and once for the human (degree string). See book-of-composition ch 9 for the projection-pair pattern.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/->radians"
  :library "geom"
  :kind "meta"
  :signature "(geom/->radians degrees) -> float"
  :summary "Converts an angle from degrees to radians."
  :explanation "Angles in user input and graphics (rotation, heading, bearing) are often expressed in degrees (360 per circle). Mathematics functions expect radians (2π per circle). `geom/->radians` divides the degree input by 180/π (equivalently, multiplies by π/180) to convert to radians. The result is a floating-point value, so conversion introduces device-level rounding; use it when converting user input or graphics angles to math functions."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/->radians 180)\n;; => 3.141592653589793" :note "180 degrees equals π radians; approximately const/pi (within float rounding)")
    (:dialect "motoi" :tier "intermediate" :code "(geom/sin (geom/->radians 90))\n;; => 1.0" :note "Convert 90 degrees to radians, then compute sine; result is 1.0")
    (:dialect "motoi" :tier "expert" :code "(define my-card 'my-card)\n(define (rotate-card-by-degrees card angle-deg)\n  (let ((angle-rad (geom/->radians angle-deg)))\n    (rotate-card card angle-rad)))\n(rotate-card-by-degrees my-card 45)\n;; => card rotated by π/4 radians" :note "Wrap geom/->radians to accept user-facing degree input and convert for internal radian-based rotation")
  )
  :caveats ("The result is a device-float, subject to floating-point rounding." "Negative degrees produce negative radians." "Very large degree values may lose precision when converted to float.")
  :drawbacks ("One-way conversion; converting back with `geom/->degrees` may not recover the original due to rounding." "Not suitable for high-precision scientific computation; exact arithmetic should be used if precision is critical.")
  :usecases ("Converting user input (e.g., rotation slider in degrees) to math functions expecting radians." "Converting graphics angles (heading, bearing, compass direction) to trigonometric functions." "Bridging UI layer (degrees) and math layer (radians).")
  :related ("geom/->degrees" "geom/sin" "geom/cos" "geom/tan" "geom/angle-between" "const/pi")
  :learn (:concept "Degrees (360 per circle) and radians (2π per circle) are two units for the same angular quantity; conversion is a scalar multiplication." :prerequisites ("const/pi") :progression "Learn geom/->radians and geom/->degrees together for unit conversion, then geom/sin, geom/cos for trigonometry applied to converted angles.")
  :row-2-audit (
    (:problem "A joystick sends heading in degrees but the physics loop needs radians for sin/cos math." :program "(define (heading->velocity heading-deg speed)
  (let ((rad (geom/->radians heading-deg)))
    (list (* speed (cos rad)) (* speed (sin rad)))))
(heading->velocity 90 10)" :explanation "Convert degrees to radians at the boundary, then use radians for all math. The physics loop stays consistent." :meta "geom/->radians is the correct verb because degrees are the user-input convention and radians are the math convention. Doing (* deg 0.0174533) inline scatters magic numbers; using a named verb centralizes the constant π/180.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape as ->degrees: unit conversion — a physical quantity keeps its identity while the numeric label changes basis."
     :rungs (
       (:domain "geom/*" :code "(geom/->radians x)")
       (:domain "distance units (a metaphor domain — meters from kilometers)" :code "(define (km->m k) (* k 1000))")
       (:domain "math — change of basis in a one-dimensional vector space" :code "(define (rescale x k) (* x k))")
     )
     :explanation "Each rung multiplies by a fixed scalar to move between two labels of the same underlying quantity."
     :meta "The shape transfers because the domain is a scalar and the codomain is the same scalar in a different metric. Both metrics agree on which two values are equal.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "Converting degrees to radians and back is the identity up to rounding." :program "(define (round-trip d) (geom/->degrees (geom/->radians d)))
(< (abs (- (round-trip 45) 45)) 1e-10)" :invariant "∀ d ∈ ℝ. |geom/->degrees(geom/->radians(d)) − d| < ε" :meta "Involution up to float noise. The invariant fails if the constant 180/π is misapplied. See book-of-math ch 4 (angles) for the closed-form derivation.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Convert a user-supplied degree to radians so it can drive a trig call." :composition "(define (spin-deg deg)
  (let ((rad (geom/->radians deg)))
    (list 'x (cos rad) 'y (sin rad))))
(spin-deg 30)" :emergent "adapter: an input in one convention drives a computation in another." :meta "This is a boundary-adapter pattern: at the edge of the system, incoming values are translated into the internal convention. See book-of-composition ch 11 for the adapter/edge pattern.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/angle-between"
  :library "geom"
  :kind "meta"
  :signature "(geom/angle-between p1 p2 p3 p4) -> degrees"
  :summary "Angle in degrees between two line segments or vectors."
  :explanation "Given four coordinates representing two segments (p1→p2 and p3→p4) or two vectors, computes the angle between them in degrees. Internally uses atan2 for robust angle calculation. Returns a value in [0, 180]. Useful for collision response, aiming, and geometric queries where you need to know how two directions relate."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/angle-between 0 0 1 0   0 0 0 1)" :note "Angle between horizontal (0→1,0→0) and vertical (0→0,0→1) vectors is 90°.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((angle (geom/angle-between 10 10 20 10   10 10 10 20)))\n  (if (< angle 45) 'acute 'obtuse))" :note "Angle between rightward and upward segments is 90°; check if acute or obtuse.")
    (:dialect "motoi" :tier "expert" :code "(define my-sprite 'my-sprite)\n(define (face-toward entity target-x target-y)\n  (let ((ex (entity/x entity))\n        (ey (entity/y entity)))\n    (let ((angle (geom/angle-between ex ey target-x target-y   ex ey (+ ex 1) ey)))\n      (if (> angle 90) 'left 'right))))\n(face-toward my-sprite 50 50)" :note "Determine which side of entity the target lies on by comparing direction vectors.")
  )
  :caveats ("Returns degrees, not radians; use geom/->radians if you need to convert." "Order of arguments matters: first four values are p1 and p2 (first segment), last four are p3 and p4 (second segment)." "Result is always non-negative and ≤ 180°; reflects the smaller of the two possible angles.")
  :drawbacks ("Slightly slower than raw dot-product if you only need a relative measure (not exact angle)." "Degree output requires conversion to radians for use with other trig functions.")
  :usecases ("Checking if an entity is facing another entity." "Determining steering angles for AI or pathfinding." "Collision response: compute deflection angle." "Constraint satisfaction: verify angle constraints between geometric objects.")
  :related ("geom/sin" "geom/cos" "geom/tan" "geom/->radians" "geom/->degrees" "geom/distance" "geom/atan2")
  :learn (:concept "Angle measurement between directions using inverse tangent." :prerequisites ("geom/->degrees" "geom/atan2") :progression "After mastering angle-between, learn geom/sin and geom/cos to rotate or project along that angle; then geom/solve-right for full triangle resolution.")
  :row-2-audit (
    (:problem "A sprite must turn to face the mouse cursor; the operator needs the angle between the sprite's forward direction and the cursor direction." :program "(define (turn-to-face fx fy cx cy)
  (geom/angle-between fx fy (+ fx 1) fy   fx fy cx cy))
(turn-to-face 0 0 3 4)" :explanation "Build a horizontal reference segment from the sprite's origin, then measure the angle between it and the segment from the sprite to the cursor. The result is degrees in [0, 180]." :meta "geom/angle-between is the correct verb because it uses atan2 internally — quadrant-safe. Using (arccos (dot / (mag*mag))) would fail near ±1 due to float noise; angle-between is the audited path.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: relative angle — the angle two directions make with each other."
     :rungs (
       (:domain "geom/*" :code "(geom/angle-between 0 0 1 0 0 0 0 1)")
       (:domain "clocks (a metaphor domain — hour hand vs minute hand)" :code "(define (clock-angle h m) (abs (- (* 30 h) (* 6 m))))")
       (:domain "math — the inner-angle formula in a two-vector inner product" :code "(define (inner u v) (+ (* (car u) (car v)) (* (cadr u) (cadr v))))")
     )
     :explanation "Each rung answers 'what is the angle from A to B?' A pair of directions goes in; one angular value comes out."
     :meta "The shape transfers because 'angle between two directions' is a metric property of unit-length representatives, independent of substrate.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "Angle-between is symmetric: swapping the two segments gives the same angle." :program "(define a (geom/angle-between 0 0 1 0 0 0 0 1))
(define b (geom/angle-between 0 0 0 1 0 0 1 0))
(< (abs (- a b)) 1e-6)" :invariant "∀ p1 p2 p3 p4. angle-between(p1,p2,p3,p4) = angle-between(p3,p4,p1,p2)" :meta "Symmetry of the metric: the angle from A to B equals the angle from B to A. If broken, the underlying atan2 was called with swapped signs. See book-of-math ch 5 (trigonometry, dot product).")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Compute the angle between two segments to gate a decision." :composition "(define (in-cone-of-vision viewer-x viewer-y forward-x forward-y target-x target-y)
  (let ((ang (geom/angle-between viewer-x viewer-y forward-x forward-y   viewer-x viewer-y target-x target-y)))
    (< ang 45)))
(in-cone-of-vision 0 0 1 0 3 1)" :emergent "predicate: a numeric measurement becomes a boolean decision via a threshold." :meta "Belongs to the family of gated observers: a scalar measurement crosses a threshold to become an event. Same family as CPU temperature triggering a throttle. See book-of-composition ch 12 (threshold/gate pattern).")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/arc-length"
  :library "geom"
  :kind "meta"
  :signature "(geom/arc-length radius angle-radians) -> length"
  :summary "Arc length of a circular arc from radius and angle."
  :explanation "Computes s = r·θ, where r is the radius and θ is the angle in radians. Arc length is the distance you travel along a circle's edge. Essential for animations along circular paths, measuring travel distance on arcs, and parametric motion. The angle must be in radians; convert with geom/->radians if you have degrees."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/arc-length 10 (geom/->radians 90))" :note "Arc of radius 10 with 90° central angle: length ≈ 15.71 (quarter of a circle).")
    (:dialect "motoi" :tier "intermediate" :code "(define (travel-on-arc start-angle end-angle radius)\n  (let ((delta (- end-angle start-angle)))\n    (geom/arc-length radius (geom/->radians delta))))\n(travel-on-arc 0 45 8)" :note "Calculate distance traveled from start to end angle on a circular arc of radius 8.")
    (:dialect "motoi" :tier "expert" :code "(define (animate-along-arc center-x center-y radius start-deg end-deg t)\n  (let* ((total-arc (geom/arc-length radius (geom/->radians (- end-deg start-deg))))\n         (distance-traveled (* total-arc t))\n         (angle-traveled (/ distance-traveled radius))\n         (current-angle (+ (geom/->radians start-deg) angle-traveled)))\n    (list (+ center-x (* radius (geom/cos (geom/->degrees current-angle))))\n          (+ center-y (* radius (geom/sin (geom/->degrees current-angle)))))))\n(animate-along-arc 100 100 50 0 180 0.5)" :note "Parametric arc motion: compute position at time t (0–1) along a circular arc using arc length to maintain constant speed.")
  )
  :caveats ("Angle must be in radians; if you have degrees, convert with geom/->radians first." "Formula assumes a positive radius and angle; behavior with negative inputs is undefined." "For full circumference, use angle = 2π radians (geom/->radians 360).")
  :drawbacks ("Only gives arc length; does not return the path coordinates—use geom/cos and geom/sin with the angle to find positions on the arc." "No built-in way to invert: given arc length, find angle. Requires division: θ = s / r.")
  :usecases ("Animating sprites along circular paths at constant speed." "Computing the perimeter of circular arcs for physics or layout." "Parametrizing motion: convert arc length to angle to find position." "Measuring travel distance in games with curved tracks or orbits.")
  :related ("geom/->radians" "geom/->degrees" "geom/sin" "geom/cos" "geom/circle-circumference" "geom/sector-area")
  :learn (:concept "Linear relationship between arc length, radius, and angle in radians." :prerequisites ("geom/->radians") :progression "After geom/arc-length, study geom/sin and geom/cos to find coordinates on the arc; then curve/spline-resample for more complex parametric paths.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "An animator needs to move a sprite at constant speed around a circular track; they must know the total distance along the arc to pace the motion." :program "(define (pace-arc radius sweep-rad speed)
  (let ((total (geom/arc-length radius sweep-rad)))
    (/ total speed)))
(pace-arc 50 math/pi 20)" :explanation "Compute the arc length from radius and sweep angle. Divide by the desired linear speed to get the animation duration." :meta "geom/arc-length is the correct verb because it uses the closed-form s = rθ; any other approach (numerical integration, chord approximation) is either wrong or wasteful for a circular arc.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: measured length along a curved path — a scalar span given by an angle and a radius."
     :rungs (
       (:domain "geom/*" :code "(geom/arc-length 10 math/pi)")
       (:domain "running-track (a metaphor domain — inside vs outside lane length)" :code "(define (lane-length inside-r extra-r sweep) (* (+ inside-r extra-r) sweep))")
       (:domain "math — polar coordinates: arc length s = ∫ r dθ over the swept angle" :code "(define (polar-arc r sweep) (* r sweep))")
     )
     :explanation "All three rungs multiply a radius by a swept angle to produce a scalar distance along the arc."
     :meta "The shape transfers because in any measure of a circular path, distance is linear in both radius and central angle.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Arc length scales linearly with the sweep angle at fixed radius." :program "(define r 10)
(define one (geom/arc-length r 1.0))
(define two (geom/arc-length r 2.0))
(< (abs (- two (* 2 one))) 1e-9)" :invariant "∀ r > 0, θ₁, θ₂. arc-length(r, θ₁ + θ₂) = arc-length(r, θ₁) + arc-length(r, θ₂)" :meta "Additivity in the angle: this is a linear (in fact monoid-homomorphism) map from the angle group to the reals. If broken, the impl inserted a nonlinearity. See book-of-math ch 4 (arc length and angle).")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "Turn arc-length into a step-per-frame value for parametric motion." :composition "(define (arc-step radius sweep frames)
  (let ((total (geom/arc-length radius sweep)))
    (/ total frames)))
(arc-step 50 (/ math/pi 2) 60)" :emergent "parametric-motion: a total distance is divided into equal frame steps to produce constant-speed motion." :meta "Belongs to the family of resampled trajectories: same family as easing generators and spline resamplers. See book-of-motion ch 7 (constant-speed arc motion).")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/arccos"
  :library "geom"
  :kind "meta"
  :signature "(geom/arccos x) -> radians"
  :summary "Inverse cosine (arccos) of x in radians, domain |x| ≤ 1."
  :explanation "Given a cosine value x in [−1, 1], returns the angle in radians in [0, π] whose cosine is x. Arccos is the inverse of the cosine function and is essential for recovering angles from projections or dot products. The result is always in the range [0, π] radians (0° to 180°). Convert to degrees with geom/->degrees if needed."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/arccos 0)" :note "arccos(0) = π/2 ≈ 1.57 radians (90°).")
    (:dialect "motoi" :tier "intermediate" :code "(let ((angle-rad (geom/arccos 0.5)))\n  (geom/->degrees angle-rad))" :note "arccos(0.5) = π/3 radians; convert to degrees to get 60°.")
    (:dialect "motoi" :tier "expert" :code "(define (angle-from-dot-product v1 v2 mag1 mag2)\n  (let ((dot-prod (+ (* (car v1) (car v2)) (* (cadr v1) (cadr v2)))))\n    (let ((cos-angle (/ dot-prod (* mag1 mag2))))\n      (geom/->degrees (geom/arccos (max -1 (min 1 cos-angle)))))))\n(angle-from-dot-product '(1 0) '(0.707 0.707) 1 1)" :note "Recover angle between two vectors from their dot product; clamp to valid domain to avoid domain errors from floating-point error.")
  )
  :caveats ("Domain is strictly [−1, 1]; inputs outside this range produce undefined behavior or NaN." "Output is always in [0, π] radians; arccos does not distinguish between angles and their supplements." "Floating-point precision may cause clamping errors; always clamp inputs to [−1, 1] before calling.")
  :drawbacks ("Slower than direct angle computation via atan2 in many cases." "Cannot distinguish between an angle and its negative; use geom/atan2 if you need signed angles." "Result is in radians; must convert to degrees for display or use with degree-based functions.")
  :usecases ("Computing angle between two vectors from their normalized dot product." "Recovering angle in a law-of-cosines triangle solution." "Finding the angle subtended by a chord in a circle." "Physics: computing angle of incidence or reflection from component ratios.")
  :related ("geom/arcsin" "geom/arctan" "geom/atan2" "geom/cos" "geom/->degrees" "geom/law-of-cosines-angle")
  :learn (:concept "Inverse trigonometric function: recover angle from cosine value." :prerequisites ("geom/cos" "geom/->degrees") :progression "After arccos, learn geom/arcsin and geom/arctan to invert the other trig functions; then study geom/law-of-cosines-angle to solve triangles.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "Two unit vectors are given via their dot product; the operator needs the angle between them." :program "(define (angle-from-dot d)
  (geom/arccos (max -1 (min 1 d))))
(geom/->degrees (angle-from-dot 0.5))" :explanation "Clamp the dot product to [-1, 1] to avoid float noise pushing the input outside arccos's domain, then apply arccos." :meta "geom/arccos is the correct verb because the input is a cosine value. Using atan2 requires separating x and y — we don't have them, only the ratio. arccos is the direct inverse.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: inverse function — undoing a many-to-one map by restricting to a principal branch."
     :rungs (
       (:domain "geom/*" :code "(geom/arccos 0)")
       (:domain "keyed locks (a metaphor domain — the key that undoes a specific lock)" :code "(define (open-lock lock-val) (list 'principal-key lock-val))")
       (:domain "math — principal-branch inverse of a periodic function" :code "(define (principal x) (min (max x -1) 1))")
     )
     :explanation "Each rung takes an output and recovers the canonical input, given that the underlying function is many-to-one and needs a branch choice."
     :meta "The shape transfers because any inverse of a many-to-one function must pick a canonical preimage. arccos picks [0, π].")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Composed with cos on its domain, arccos is the identity." :program "(define (test x) (< (abs (- (cos (geom/arccos x)) x)) 1e-9))
(and (test 0.5) (test -0.7) (test 1.0))" :invariant "∀ x ∈ [-1, 1]. cos(arccos(x)) = x" :meta "Left inverse on the principal branch. If broken, the branch selection is wrong. See book-of-math ch 5 (inverse trigonometric functions).")
