    :runs "spec-only"
   
    (:base "Chain sphere-surface with heat-loss coefficient for thermal analysis." :composition "(define (heat-loss r coeff) (* (geom/sphere-surface r) coeff))
(heat-loss 5 0.4)" :emergent "measure-times-coefficient: area × per-area-rate → total loss." :meta "Belongs to the family of extensive-property pipelines. See book-of-composition ch 10.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/sphere-volume"
  :library "geom"
  :kind "meta"
  :signature "(geom/sphere-volume radius) -> number"
  :summary "Computes the volume of a sphere given its radius."
  :explanation "The volume of a sphere is (4/3)πr³. Given the radius, this returns the amount of space enclosed by the sphere's surface. This is a pure calculation with no side effects. Useful for capacity, mass, and density estimates."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/sphere-volume 1)" :note "Unit sphere; returns (4/3)π ≈ 4.19")
    (:dialect "motoi" :tier "intermediate" :code "(geom/sphere-volume 3)" :note "Sphere of radius 3; returns (4/3)π·27 ≈ 113.1")
    (:dialect "motoi" :tier "expert" :code "(let ((radius 10) (density 1) (mass 0))\n  (let ((vol (geom/sphere-volume radius)))\n    (set! mass (* vol density))\n    mass))" :note "Computes mass of a sphere given radius and material density")
  )
  :caveats ("Radius must be positive; zero or negative radius is valid mathematically but meaningless" "Returns a floating-point number; use exact/* for symbolic answers" "Volume grows as the cube of radius; even small rounding errors in radius can significantly affect volume")
  :drawbacks ("Does not support ellipsoids (three unequal semi-axes); only spheres" "No built-in function for weight or buoyancy; caller must multiply by density and gravity")
  :usecases ("Calculating liquid capacity of a spherical tank or container" "Computing mass of a spherical object (volume × density)" "Fluid dynamics: drag and buoyant force on a sphere" "Astronomy: planet mass estimation from radius and density")
  :related ("geom/sphere-surface" "geom/circle-area" "geom/cylinder-volume" "geom/cone-volume" "geom/prism-volume")
  :learn (:concept "How volume scales with the cube of radius (doubling radius multiplies volume by 8); relationship between 2D circle area and 3D sphere volume" :prerequisites ("const/pi" "geom/circle-area") :progression "Pair with geom/sphere-surface to understand surface-area-to-volume ratio; then explore geom/cylinder-volume and geom/cone-volume to compare shapes, then move to calc/volume-revolution for solids of revolution")
