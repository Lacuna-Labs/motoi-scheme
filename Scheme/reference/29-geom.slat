       (:domain "photocopier zoom (a metaphor domain — enlarge everything relative to a fixed corner)" :code "(define (zoom pt scale) (list (* (car pt) scale) (* (cadr pt) scale))))")
       (:domain "math — homothety in Euclidean geometry" :code "(define (homothety p c k) (list (+ (car c) (* k (- (car p) (car c)))) (+ (cadr c) (* k (- (cadr p) (cadr c))))))")
     )
