(verb
  :name "geom/cylinder-surface"
  :library "geom"
  :kind "pure"
  :signature "(geom/cylinder-surface radius height) -> device-float"
  :summary "Compute the surface area of a cylinder given radius and height."
  :explanation "A cylinder's surface area includes two circular bases and the lateral (side) surface. Given the radius and height, this verb returns the total surface area as 2πr² + 2πrh, or 2πr(r + h). This is useful for computing material, heat-transfer area, and geometric comparisons. Note this is the total surface area; if you need only the lateral surface, subtract 2πr² from the result."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/cylinder-surface 3 10)" :note "Cylinder with radius 3 and height 10 has surface area ≈ 245.044")
    (:dialect "motoi" :tier "intermediate" :code "(let ((r 5) (h 12))\n  (let ((total (geom/cylinder-surface r h))\n        (base (* 2 (geom/circle-area r))))\n    (list 'total total 'bases base 'lateral (- total base))))" :note "Break down total surface area into bases and lateral components")
    (:dialect "motoi" :tier "expert" :code "(define (cylinder-pack radius height surface-target)\n  (define (adjust-height h)\n    (let ((area (geom/cylinder-surface radius h)))\n      (if (< area surface-target) (adjust-height (+ h 0.1)) h)))\n  (adjust-height 1))\n(cylinder-pack 4 1 200)" :note "Iteratively find height needed to reach a target surface area")
  )
  :caveats ("Both radius and height must be non-negative" "Height is the perpendicular distance between the two circular bases, not a slant or arc length" "Uses device-float precision; very large dimensions may lose precision" "A cylinder with zero height (degenerate disk) has surface area 2πr²")
  :drawbacks ("Result includes both bases; if you need only the lateral surface, subtract (geom/circle-area radius) × 2" "Does not give volume; use geom/cylinder-volume separately")
  :usecases ("Manufacturing: material needed for cylindrical containers (cans, pipes, drums)" "Thermal engineering: heat-transfer surface area for cylindrical cooling systems" "Geometry: comparing cylinders, cones, and spheres by surface area" "Packaging: label area needed to wrap around a cylindrical product")
  :related ("geom/cylinder-volume" "geom/cone-surface" "geom/sphere-surface" "geom/circle-area")
  :learn (:concept "Surface area formula for cylinders; decomposition into bases and lateral surface" :prerequisites ("geom/circle-area" "const/pi") :progression "After this, learn geom/cylinder-volume (volume), then geom/cone-surface and geom/sphere-surface (other solids)")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A pipe fabricator needs the total surface for painting a cylindrical pipe of given radius and length." :program "(define (paint-area r len)
  (geom/cylinder-surface r len))
(paint-area 0.5 10)" :explanation "Direct application. The result covers ends and side." :meta "geom/cylinder-surface is the correct verb because it returns total (2πr² + 2πrh). Using only the side undercounts by two circles.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: composite area — top plus bottom plus wraparound."
     :rungs (
       (:domain "geom/*" :code "(geom/cylinder-surface 3 5)")
       (:domain "wrapping paper (a metaphor domain — around a can plus its two lids)" :code "(define (wrap-area top-a side-a) (+ (* 2 top-a) side-a))")
       (:domain "math — surface area of a right prism = 2·B + P·h" :code "(define (prism-surface b p h) (+ (* 2 b) (* p h))))")
     )
     :explanation "Each rung sums a top face, a bottom face, and a wrapping face."
     :meta "The shape transfers because prisms decompose the same way regardless of the base shape.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Cylinder surface = 2·(base area) + (circumference · height)." :program "(define r 3) (define h 5)
(define total (geom/cylinder-surface r h))
(define pieces (+ (* 2 (* math/pi r r)) (* (* 2 math/pi r) h)))
(< (abs (- total pieces)) 1e-9)" :invariant "∀ r > 0, h > 0. cylinder-surface(r,h) = 2·π·r² + 2·π·r·h" :meta "Additive decomposition into cap and wall. If broken, one summand is missing. See book-of-math ch 4.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "Compute cylinder surface as one component of a manufacturing bill." :composition "(define (parts-list r h)
  (list 'material (geom/cylinder-surface r h)
        'volume (geom/cylinder-volume r h)))
(parts-list 3 5)" :emergent "measurement-bundle: geometric properties assembled into a manifest." :meta "Belongs to the family of bill-of-materials manifests. See book-of-composition ch 10.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/cylinder-volume"
  :library "geom"
  :kind "pure"
  :signature "(geom/cylinder-volume radius height) -> device-float"
  :summary "Compute the volume of a cylinder given base radius and height."
  :explanation "The volume of a cylinder is the area of its circular base times its height: V = πr²h. This verb takes the base radius and perpendicular height and returns the volume as a device-float. Cylinders are among the most common geometric shapes in engineering and manufacturing, making this verb essential for capacity, packing, and comparison problems."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/cylinder-volume 4 10)" :note "Cylinder with radius 4 and height 10 has volume ≈ 502.655")
    (:dialect "motoi" :tier "intermediate" :code "(let ((radius 3) (height 7))\n  (let ((vol (geom/cylinder-volume radius height))\n        (surf (geom/cylinder-surface radius height)))\n    (/ vol surf)))" :note "Compute volume-to-surface-area ratio for efficient packing analysis")
    (:dialect "motoi" :tier "expert" :code "(define (fill-cylinders-to-target total-volume radius target-height)\n  (define (num-cylinders vol r h)\n    (let ((per-cyl (geom/cylinder-volume r h)))\n      (ceiling (/ vol per-cyl))))\n  (num-cylinders total-volume radius target-height))\n(fill-cylinders-to-target 5000 5 20)" :note "Determine how many cylinders are needed to reach a total volume target")
  )
  :caveats ("Height must be the perpendicular distance between bases, not a slant or arc length" "Both radius and height must be non-negative" "Uses device-float precision; very large dimensions may overflow or lose precision" "A cylinder with zero height has zero volume (degenerate case)")
  :drawbacks ("Does not give surface area; use geom/cylinder-surface for that" "If you need volume of a tapered cylinder (cone), use geom/cone-volume instead")
  :usecases ("Fluid capacity: volume of tanks, pipes, and reservoirs" "Manufacturing: packing and logistics (how many cylindrical items fit in a space)" "Physics: mass and inertia calculations for cylindrical objects" "Geometry: comparing volumes across different shapes and dimensions")
  :related ("geom/cylinder-surface" "geom/cone-volume" "geom/prism-volume" "geom/sphere-volume")
  :learn (:concept "Cylinder volume as base area × height; relationship to cone volume (cone is 1/3 of cylinder)" :prerequisites ("geom/circle-area" "const/pi") :progression "After this, learn geom/cone-volume (cone is 1/3 of cylinder), then geom/pyramid-volume (pyramid analogue), then geom/prism-volume (generalized)")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A tank operator needs the fluid capacity of a cylindrical tank of given radius and height." :program "(define (tank-liters r h)
  (* (geom/cylinder-volume r h) 1000))
(tank-liters 1 2)" :explanation "Compute V in m³, multiply by 1000 to get liters." :meta "geom/cylinder-volume is the correct verb because it's the closed-form πr²h. Slicing or integrating is wasteful for a right cylinder.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: extruded 2D area — a base area sweeps a linear distance."
     :rungs (
       (:domain "geom/*" :code "(geom/cylinder-volume 2 3)")
       (:domain "printing (a metaphor domain — a page area times the number of pages = total ink)" :code "(define (ink page-a pages) (* page-a pages)))")
       (:domain "math — volume = base area × height for any right prism" :code "(define (prism-vol area h) (* area h))")
     )
     :explanation "Each rung multiplies an area by a length to get a volume."
     :meta "The shape transfers because integration of a constant cross-section is multiplication.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Cylinder volume equals its base area times its height." :program "(define r 3) (define h 4)
(define v (geom/cylinder-volume r h))
(< (abs (- v (* (geom/circle-area r) h))) 1e-9)" :invariant "∀ r > 0, h > 0. cylinder-volume(r,h) = circle-area(r) · h" :meta "Prism-decomposition invariant. If broken, the coefficient or the base formula drifted. See book-of-math ch 4.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
