(verb
  :name "geom/sector-area"
  :library "geom"
  :kind "meta"
  :signature "(geom/sector-area radius angle) -> number"
  :summary "Computes the area of a circular sector given radius and central angle in degrees."
  :explanation "A sector is a 'pie slice' of a circle. Given the radius and the central angle in degrees, this returns the area swept by that sector. The formula is (angle/360) × π × r². This is purely computational with no side effects. The angle is measured in degrees for consistency with other geom functions."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/sector-area 10 90)" :note "A quarter-circle (90°) of radius 10; area ≈ 78.5")
    (:dialect "motoi" :tier "intermediate" :code "(let ((radius 5) (angle 60))\n  (geom/sector-area radius angle))" :note "Sector of radius 5 and 60° (one-sixth of the circle); area ≈ 13.1")
    (:dialect "motoi" :tier "expert" :code "(let ((total-pizza-area (geom/circle-area 12))\n      (one-slice-angle 30))\n  (/ (geom/sector-area 12 one-slice-angle) total-pizza-area))" :note "Computes what fraction of a 12-inch pizza is one 30° slice")
  )
  :caveats ("Angle is in degrees, not radians" "Radius must be positive" "Returns 0 for angle = 0 and full circle area for angle = 360" "Floating-point result; use exact arithmetic if needed for symbolic geometry")
  :drawbacks ("Does not validate that angle is in [0, 360]; accepts any non-negative value" "No built-in support for annulus sectors (rings); must compute difference of two sector areas")
  :usecases ("Computing the painted area of a pie chart segment" "Calculating land area of a wedge-shaped region in a map" "Physics: work done by a torque over an angular range" "Game design: size of a cone of vision or attack area")
  :related ("geom/circle-area" "geom/arc-length" "geom/inscribed-angle" "geom/circle")
  :learn (:concept "How a sector relates to the full circle as an angular fraction" :prerequisites ("const/pi" "geom/circle-area") :progression "Pair with geom/arc-length to measure both the perimeter and area of a sector, then explore geom/inscribed-angle for angle relationships in circles")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A pizza chart must render a 60° slice of a 12-inch radius pizza; the operator needs the sector area for weighting the slice." :program "(define (slice-area radius angle) (geom/sector-area radius angle))
(slice-area 12 60)" :explanation "Apply the fraction (angle/360) × π r²." :meta "geom/sector-area is the correct verb because it takes degrees directly (Motoi geom convention) and applies the angle-fraction × circle-area formula.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: fractional-share — a portion of a whole scaled by an angle-fraction."
     :rungs (
       (:domain "geom/*" :code "(geom/sector-area 12 60)")
       (:domain "pie chart (a metaphor domain — this slice is 1/6 of the whole pie)" :code "(define (share pct total) (* pct total)))")
       (:domain "math — measure-preserving proportional split" :code "(define (split total frac) (* total frac))")
     )
     :explanation "Each rung takes a whole and returns a fixed fractional share."
     :meta "The shape transfers because 'this fraction of that whole' is a universal share operation.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Sector area with angle 360° equals the full circle area." :program "(define full (geom/sector-area 10 360))
(< (abs (- full (geom/circle-area 10))) 1e-9)" :invariant "∀ r > 0. sector-area(r, 360) = circle-area(r)" :meta "Full-sweep consistency. If broken, the fraction denominator is wrong. See book-of-math ch 4.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "Chain sector-area with a total-area to compute a fractional share." :composition "(define (slice-fraction radius angle)
  (/ (geom/sector-area radius angle) (geom/circle-area radius)))
(slice-fraction 12 60)" :emergent "share-computation: sector as a fraction of the whole." :meta "Belongs to the family of proportional-share patterns. See book-of-composition ch 10.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/segment"
  :library "geom"
  :kind "meta"
  :signature "(geom/segment point1 point2) -> segment"
  :summary "Creates a line segment between two points."
  :explanation "A segment is a straight line bounded by two endpoints. This verb constructs a segment object from two points. The result is a bitwise-compact representation suitable for geometric queries and transformations. Segments are immutable and can be passed to distance, collision, or rasterization functions."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/segment (list 0 0) (list 3 4))" :note "Creates a segment from origin to (3,4); length is 5")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p1 (list 1 1)) (p2 (list 4 5)))\n  (geom/distance p1 p2))" :note "Once two points are defined, geom/distance measures the segment's length directly")
    (:dialect "motoi" :tier "expert" :code "(let ((vertices (list (list 0 0) (list 1 0) (list 1 1) (list 0 1))))\n  (map (lambda (i)\n         (geom/segment (list-ref vertices i)\n                       (list-ref vertices (modulo (+ i 1) (length vertices)))))\n       (list 0 1 2 3)))" :note "Builds all four edges of a unit square as segments, forming a closed loop")
  )
  :caveats ("Both endpoints must be 2-element lists [x y]" "A degenerate segment (both points identical) is valid but has zero length" "Segment is immutable; use geom/translate to move both endpoints" "Bitwise encoding means coordinates are subject to machine precision")
  :drawbacks ("No built-in intersection test; use lower-level distance/collision verbs for that" "Segment is not directly drawable; use paint-coin or similar to render")
  :usecases ("Defining edges of a polygon or wireframe shape" "Line-of-sight queries in pathfinding (check if segment is passable)" "Representing a path segment in trajectory planning" "Collision detection between a moving object and a fixed boundary")
  :related ("geom/triangle" "geom/distance" "geom/midpoint" "geom/point")
  :learn (:concept "How segments are the building blocks of polylines and how two points define an infinite line, of which the segment is the bounded part" :prerequisites ("geom/point" "geom/distance") :progression "Combine segments into geom/triangle and geom/polygon-perimeter; study collision and ray-casting for higher-level geometric reasoning")
  :row-2-audit (
    (:problem "A collision check needs a segment representing a laser beam from origin to a target." :program "(define (beam origin target)
  (geom/segment origin target))
(beam '(0 0) '(3 4))" :explanation "Construct the segment as a first-class value." :meta "geom/segment is the correct verb because it packages the two endpoints as a segment object. Two bare points work for distance queries but not for segment-typed dispatch.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: constructor bundling two endpoints as a single value."
     :rungs (
       (:domain "geom/*" :code "(geom/segment '(0 0) '(3 4))")
       (:domain "rope (a metaphor domain — two knots at the ends define the length)" :code "(define (rope k1 k2) (list k1 k2))")
       (:domain "math — interval [a, b] in ℝ, generalized to ℝ²" :code "(define (interval a b) (list a b))")
     )
     :explanation "Each rung packages two endpoints as one referenceable value."
     :meta "The shape transfers because 'bounded 1D subset' extends to any dimension via endpoints.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "Segments constructed with the same endpoints are equal." :program "(equal? (geom/segment '(0 0) '(3 4)) (geom/segment '(0 0) '(3 4)))" :invariant "∀ p1 p2. equal?(segment(p1,p2), segment(p1,p2))" :meta "Constructor referential transparency. If broken, the impl inserts nondeterminism. See book-of-math ch 6.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain segment with distance to get its length." :composition "(define (seg-length p1 p2)
  (geom/segment p1 p2)
  (geom/distance (car p1) (cadr p1) (car p2) (cadr p2)))
(seg-length '(0 0) '(3 4))" :emergent "construct-then-measure: segment created, then its length queried." :meta "Belongs to the family of value-plus-query patterns. See book-of-composition ch 8.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/similar?"
  :library "geom"
  :kind "meta"
  :signature "(geom/similar? tri1-sides tri2-sides) -> number-or-false"
  :summary "Tests whether two triangles are similar and returns their scaling ratio, or #f if not similar."
  :explanation "Two triangles are similar if their corresponding angles are equal (which implies their sides are proportional). This verb accepts two triangles (each given as a list of three side lengths) and returns the scale factor (ratio of corresponding sides) if they are similar, or #f if they are not. Similarity is detected via side-angle relationships using the law of cosines."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/similar? (list 3 4 5) (list 6 8 10))" :note "Two right triangles with sides 3-4-5 and 6-8-10; returns 2 (the scale factor)")
    (:dialect "motoi" :tier "intermediate" :code "(geom/similar? (list 2 3 4) (list 4 6 8))" :note "Exact 2× scale; returns 2")
    (:dialect "motoi" :tier "expert" :code "(let ((small (list 5 5 6))\n      (large (list 10 10 12)))\n  (if (geom/similar? small large)\n      (display (string-append \"Scale: \" (number->string (geom/similar? small large))))\n      (display \"Not similar\")))" :note "Checks similarity of isosceles triangles and prints the scale if they match")
  )
  :caveats ("Input is three side lengths per triangle, not coordinates" "Sides must satisfy the triangle inequality (sum of any two > third)" "Returns a number (the ratio) on success, #f on failure; caller must check type" "Comparison uses floating-point tolerance; extremely close ratios may fail due to rounding")
  :drawbacks ("No way to specify which sides correspond; always assumes order 1, 2, 3" "Does not detect when triangles are congruent (ratio 1); that requires an additional test" "Degenerate inputs (collinear or invalid side lists) may crash or return NAN")
  :usecases ("Validating that scaled copies of a shape preserve angles (e.g., in CAD or drafting)" "Geometric proofs involving proportional triangles" "Scale-invariant pattern matching (e.g., recognizing similar objects at different sizes)" "Testing whether a shrunk/enlarged triangle remains the same shape")
  :related ("geom/triangle" "geom/triangle-area" "geom/law-of-cosines-angle" "geom/law-of-cosines-side")
  :learn (:concept "Similarity as angle preservation under scaling; how the law of cosines bridges side lengths to angles" :prerequisites ("geom/triangle" "geom/law-of-cosines-angle") :progression "After similarity, study geom/law-of-cosines-side to solve for missing sides, then move to topo/euler-char for higher-order shape relationships")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A CAD tool must check whether two triangular parts are similar to determine if they can share a manufacturing template." :program "(define (compatible? sides1 sides2)
  (geom/similar? sides1 sides2))
(compatible? '(3 4 5) '(6 8 10))" :explanation "Returns the scale factor if similar, #f otherwise." :meta "geom/similar? is the correct verb because it compares triangles via side-ratios. Comparing angles requires solving with law-of-cosines first — this is more direct.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: equivalence-class test with a witness (the scale factor)."
     :rungs (
       (:domain "geom/*" :code "(geom/similar? '(3 4 5) '(6 8 10))")
       (:domain "photocopies (a metaphor domain — two documents scaled — is one an enlargement of the other?)" :code "(define (photocopy? a b scale) (list a b scale))")
       (:domain "math — projective equivalence up to scalar multiplication" :code "(define (proj-eq a b) (list a b))")
     )
     :explanation "Each rung checks if two items belong to the same equivalence class under scaling."
     :meta "The shape transfers because 'equivalent up to scale' is universal.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Two identical triangles are similar with ratio 1." :program "(define r (geom/similar? '(3 4 5) '(3 4 5)))
(and r (< (abs (- r 1)) 1e-9))" :invariant "∀ triangle t. similar?(t, t) = 1" :meta "Reflexivity of the similarity relation. If broken, the ratio computation is misordered. See book-of-math ch 6 (equivalence classes).")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "Chain similar? with a template lookup for CAD manufacturing." :composition "(define (find-template part templates)
  (filter (lambda (t) (geom/similar? part t)) templates))
(find-template '(3 4 5) '((6 8 10) (5 12 13)))" :emergent "equivalence-filter: match by similarity class." :meta "Belongs to the family of equivalence-class filter patterns. See book-of-composition ch 7.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/sin"
  :library "geom"
  :kind "meta"
  :signature "(geom/sin angle-degrees) -> number"
  :summary "Computes the sine of an angle given in degrees."
  :explanation "Sine relates the opposite side of a right triangle to its hypotenuse. Given an angle in degrees (not radians), returns the sine ratio. Values range from −1 to 1. This is a pure mathematical function with no side effects. Internally converts degrees to radians and calls the device-level sin function."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/sin 90)" :note "Sine of 90°; returns 1")
    (:dialect "motoi" :tier "intermediate" :code "(let ((angle 30))\n  (* 10 (geom/sin angle)))" :note "Opposite side of a right triangle with hypotenuse 10 and 30° angle; returns 5")
    (:dialect "motoi" :tier "expert" :code "(let ((angles (list 0 30 45 60 90)))\n  (map geom/sin angles))" :note "Computes sine of common angles; produces (0 0.5 0.707... 0.866... 1)")
  )
  :caveats ("Input angle is in degrees, not radians (unlike some Scheme math libraries)" "Returns a floating-point number; use exact/* for rational arithmetic if needed" "Very large angles (e.g., 1000000°) may lose precision due to floating-point rounding")
  :drawbacks ("No inverse sine (geom/arcsin) for solving angle from sine ratio; use geom/right-triangle-angle instead" "Device-level sin has about 32-bit precision; not suitable for high-precision surveying")
  :usecases ("Solving right triangles when one angle and the hypotenuse are known" "Computing the y-component of a unit vector at a given angle" "Wave and oscillation math (phase, frequency, amplitude)" "Game physics: projectile trajectory angle to velocity components")
  :related ("geom/cos" "geom/tan" "geom/arcsin" "geom/right-triangle-angle")
  :learn (:concept "Sine as the ratio opposite/hypotenuse in a right triangle, and how it extends to all angles via the unit circle" :prerequisites ("geom/right-triangle-angle") :progression "Pair geom/sin with geom/cos and geom/tan to solve arbitrary right triangles; then move to curve/velocity and curve/tangent for calculus on trigonometric curves")
  :row-2-audit (
    (:problem "A bouncing character oscillates vertically over time; the operator needs the y offset at time t." :program "(define (bounce t amplitude freq)
  (* amplitude (geom/sin (* freq t))))
(bounce 0.5 100 180)" :explanation "Take sin(freq·t) in degrees, scale by amplitude." :meta "geom/sin is the correct verb because Motoi convention is degrees. Using base cos+phase-shift is an alternative but less direct.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape as cos: bounded periodic response."
     :rungs (
       (:domain "geom/*" :code "(geom/sin 30)")
       (:domain "swing (a metaphor domain — pendulum height oscillates over time)" :code "(define (swing-y t amp) (* amp (sin t))))")
       (:domain "math — sinusoid periodic function" :code "(define (sinusoid t) (sin t))")
     )
     :explanation "Each rung produces a bounded periodic scalar output."
     :meta "The shape transfers to any oscillating system.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "sin is odd: sin(-θ) = -sin(θ)." :program "(< (abs (+ (geom/sin 47) (geom/sin -47))) 1e-9)" :invariant "∀ θ. sin(-θ) = -sin(θ)" :meta "Odd-function symmetry. If broken, the impl loses the negative branch. See book-of-math ch 5.")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain sin with cos to trace a circle." :composition "(define (unit-circle t)
  (list (geom/cos t) (geom/sin t)))
(unit-circle 45)" :emergent "parametric-circle: time drives sin+cos to yield a unit-circle point." :meta "Belongs to the family of parametric-curve patterns: same family as spline traces. See book-of-motion ch 8.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/slope"
  :library "geom"
  :kind "meta"
  :signature "(geom/slope x1 y1 x2 y2) -> number | nan"
  :summary "Compute the slope between two points; vertical lines return NaN (undefined, not infinity)."
  :explanation "The slope of a line through (x1, y1) and (x2, y2) is (y2 − y1) / (x2 − x1). If x2 = x1 (vertical line), the slope is undefined; this verb returns NaN rather than infinity to avoid floating-point singularities. Use this in geometry, regression, or rasterization to find line direction or steepness. The NaN convention is canonical in Motoi Scheme: undefined algebraic operations escalate or return NaN, never Inf."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/slope 0 0 1 1)" :note "A 45° line has slope 1")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p1 '(2 3)) (p2 '(5 9))) (geom/slope (car p1) (cadr p1) (car p2) (cadr p2)))" :note "Extract coordinates from point pairs and compute slope: (9-3)/(5-2) = 2")
    (:dialect "motoi" :tier "expert" :code "(define (line-family center slope) (lambda (x) (+ (cadr center) (* slope (- x (car center)))))) (let* ((m (geom/slope 1 2 4 8)) (line (line-family '(1 2) m))) (line 4))" :note "Compute slope, build a line function via point-slope form y − y₀ = m(x − x₀), evaluate it")
  )
  :caveats ("Returns NaN for vertical lines (x2 = x1), not infinity" "Does not validate input types; non-numeric inputs cause undefined behavior" "Floating-point precision limits accuracy for very small x-differences")
  :drawbacks ("Does not return an equation or intercept; only the slope" "No built-in handling of parallel or coincident points (both return the same slope)")
  :usecases ("Checking line direction in geometry algorithms" "Line-fitting and regression (compute slopes between data points)" "Rasterization and anti-aliasing (DDA algorithm uses slope)" "Collision detection (separating-axis theorem uses normal slopes)")
  :related ("math/round" "geom/slope")
  :learn (:concept "Slope as a ratio; undefined geometric states encoded as NaN (not infinity)." :prerequisites ("Basic arithmetic (-, /)") :progression "Build line equations with slope; use slope in differential geometry (tangent lines, derivatives).")
  :row-2-audit (
    (:problem "A player draws a line segment; the operator needs its slope to classify the drawing." :program "(define (line-slope x1 y1 x2 y2)
  (geom/slope x1 y1 x2 y2))
(line-slope 0 0 4 3)" :explanation "Direct (y2-y1)/(x2-x1). Returns NaN for vertical." :meta "geom/slope is the correct verb because the NaN-for-vertical convention is Motoi-standard. Manually catching x2==x1 duplicates safety logic.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: rise-over-run — a derivative-like ratio."
     :rungs (
       (:domain "geom/*" :code "(geom/slope 0 0 4 3)")
       (:domain "stairs (a metaphor domain — riser height over tread depth = step angle)" :code "(define (step-slope rise tread) (/ rise tread))")
       (:domain "math — discrete difference quotient (f(b)-f(a))/(b-a)" :code "(define (diff-quot a b fa fb) (/ (- fb fa) (- b a))))")
     )
     :explanation "Each rung computes a rate of change between two points."
     :meta "The shape transfers to any first-order rate.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
  :row-4-proof (
    (:claim "The slope from (x1,y1) to (x2,y2) equals the slope from (x2,y2) to (x1,y1) (negated numerator and denominator)." :program "(define s1 (geom/slope 1 2 4 8))
(define s2 (geom/slope 4 8 1 2))
(< (abs (- s1 s2)) 1e-9)" :invariant "∀ non-vertical (x1,y1),(x2,y2). slope(x1,y1,x2,y2) = slope(x2,y2,x1,y1)" :meta "Direction-independent slope. If broken, sign leakage. See book-of-math ch 5 (linear equations).")
    (:eng "If the invariant fails at runtime, that is a fault log line — the pure algebra should hold; a break implies the impl regressed." :math "The invariant is the closed-form algebraic identity that defines the verb's essence; falsification by counterexample is what makes it engineering-grade math." :cs "The runnable check is a property test in the sense of QuickCheck; make it a smoke test in CI so regressions are caught before ship."))
  :row-5-emergence (
    (:base "Chain slope with line-equation building." :composition "(define (line-of-two a b)
  (let ((m (geom/slope (car a) (cadr a) (car b) (cadr b))))
    (lambda (x) (+ (cadr a) (* m (- x (car a)))))))
((line-of-two '(1 2) '(4 8)) 3)" :emergent "line-builder: slope becomes a function." :meta "Belongs to the family of parameter-to-function builders. See book-of-composition ch 5.")
    (:eng "Emergent patterns bring known operational discipline (retry, throttle, cache) into the verb chain; the operator inherits the pattern's diagnostics." :math "Composition preserves the algebraic properties of each verb; the emergent structure has its own (usually monoid) invariants worth naming." :cs "The named emergent (cache, throttle, sequencer, adapter, pipeline, projection) is the CS pattern-family label; reach for known-idiom debuggers when it appears.")))

(verb
  :name "geom/solve-right"
  :library "geom"
  :kind "meta"
  :signature "(geom/solve-right param1 param2) -> {hyp: number opp: number adj: number angle: number}"
  :summary "Solves a right triangle given any two of: hypotenuse, opposite, adjacent, or acute angle."
  :explanation "Right triangles have exactly three degrees of freedom: the two legs and one acute angle (the other is 90°). If you know any two of {hypotenuse, opposite, adjacent, angle}, this verb computes the other two and returns all four values. Use keyword arguments or a list to specify which two are given. The angle is returned in degrees."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/solve-right (list ':hyp 10 ':angle 30))" :note "Hypotenuse 10 and 30° angle; returns opposite ≈ 5, adjacent ≈ 8.66")
    (:dialect "motoi" :tier "intermediate" :code "(geom/solve-right (list ':opp 3 ':adj 4))" :note "Opposite 3 and adjacent 4; returns hypotenuse 5 and angle ≈ 36.87°")
    (:dialect "motoi" :tier "expert" :code "(let ((ladder-length 13) (angle-to-ground 75))\n  (geom/solve-right (list ':hyp ladder-length ':angle angle-to-ground)))" :note "Ladder (hypotenuse 13) leans at 75°; returns how high it reaches and how far from wall")
  )
  :caveats ("Input format is a list of keyword-value pairs (':key value ...)" "Must provide exactly two constraints; fewer or more causes an error" "Angle must be between 0° and 90° (exclusive of endpoints)" "Does not validate that the constraints are consistent; garbage in may produce garbage out")
  :drawbacks ("No error message for invalid input; fails silently or returns NAN" "Does not support obtuse triangles; only right triangles with acute angles" "Output format is opaque; must know which key to extract (e.g., ':hyp)")
  :usecases ("Navigation: bearing and distance to reach a waypoint" "Construction: ladder height and angle to the wall" "Optics: reflection and refraction angles in fiber-optic design" "Game physics: projectile range and launch angle")
  :related ("geom/right-triangle-angle" "geom/sin" "geom/cos" "geom/tan" "geom/pythagoras-hypotenuse" "geom/pythagoras-leg")
  :learn (:concept "A right triangle as a fully-determined system once any two independent parameters are known; using Pythagorean theorem and SOHCAHTOA to bridge sides and angles" :prerequisites ("geom/sin" "geom/cos" "geom/pythagoras-hypotenuse") :progression "After solving right triangles, use geom/law-of-cosines-angle and geom/law-of-cosines-side to solve arbitrary triangles, then move to curve/velocity for calculus-level rate-of-change problems")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A ladder leans at 75° with length 13; the operator needs its reach and its base distance." :program "(define (ladder-config len angle)
  (geom/solve-right (list ':hyp len ':angle angle)))
(ladder-config 13 75)" :explanation "Pass the two known parameters as a keyed list; get back all four fields." :meta "geom/solve-right is the correct verb when you have any two right-triangle parameters. Calling sin/cos individually works but you handle the keyword-dispatch yourself.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: solver — given constraints, fill in the missing fields."
     :rungs (
       (:domain "geom/*" :code "(geom/solve-right '(:hyp 13 :angle 75))")
       (:domain "solving Sudoku (a metaphor domain — given constraints, fill remaining cells)" :code "(define (sudoku givens) (list 'givens givens)))")
       (:domain "math — constraint satisfaction over a variable set" :code "(define (csp constraints) (list constraints))")
     )
     :explanation "Each rung fills unknowns from a partial set of constraints."
     :meta "The shape transfers because constraint-solving is a universal computation.")
    (:eng "Reuse of shape across substrates keeps the operator's mental model portable; the same debugging heuristics apply." :math "Cross-domain shape sharing is category-theoretic: the same universal property holds in every domain that satisfies the axioms." :cs "Cross-substrate reuse informs typeclass and trait design: the same shape becomes a shared interface across implementations."))
