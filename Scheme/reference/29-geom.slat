(verb
  :name "geom/regular-polygon-area"
  :library "geom"
  :kind "meta"
  :signature "(geom/regular-polygon-area n s) -> number"
  :summary "Compute the area of a regular n-sided polygon given its side length."
  :explanation "A regular polygon has all sides equal and all angles equal. The area depends on the number of sides n and the side length s. The formula uses the apothem (the distance from center to the midpoint of a side) and the perimeter. This is useful for geometry problems, tile design, and understanding how area scales with side count for fixed side length."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/regular-polygon-area 4 2)" :note "Area of a square with side length 2; expect 4.")
    (:dialect "motoi" :tier "intermediate" :code "(geom/regular-polygon-area 6 1)" :note "Area of a regular hexagon with side length 1; expect (3√3)/2 ≈ 2.598.")
    (:dialect "motoi" :tier "expert" :code "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(define (polygon-area-per-side n)\n  (geom/regular-polygon-area n 1))\n(let ((areas (map polygon-area-per-side (list 3 4 5 6 8))))\n  (fold-left (lambda (acc a) (+ acc a)) 0 areas))" :note "Compute the unit-side area of several regular polygons and sum them; demonstrates how area increases as side count rises (approaching a circle).")
  )
  :caveats ("n must be at least 3 (a triangle); n < 3 is undefined." "s must be positive." "The formula becomes increasingly accurate (as a circle approximation) as n grows.")
  :drawbacks ("Requires side length, not radius or apothem; use geom/regular-polygon-vertices if you need to position the polygon." "Floating-point rounding may affect results for very large n.")
  :usecases ("Comparing areas of regular polygons in geometry problems." "Estimating the area of a circle by computing regular polygon areas with increasing side counts." "Designing game tiles or symmetric art with known area constraints.")
  :related ("geom/regular-polygon-vertices" "geom/interior-angle" "geom/polygon-area" "geom/sector-area" "geom/circle-area")
  :learn (:concept "area of regular polygons and limit relationships" :prerequisites ("geom/polygon-area" "geom/interior-angle") :progression "Start with irregular polygon area (geom/polygon-area), then learn the formula for regular polygons; compare to circle area (geom/circle-area) as n → ∞.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A landscaper needs the area of a hexagonal patio of given side length." :program "(define (patio-area side) (geom/regular-polygon-area 6 side))
(patio-area 2)" :explanation "Apply the closed-form formula." :meta "geom/regular-polygon-area is the correct verb because it uses the apothem-based closed form. Polygon-area with generated vertices works but does more work.")
    (:eng "Log the operator's stated problem and the code path chosen; audits catch cases where a sibling verb would silently succeed with wrong answers." :math "The audit lens fixes the mathematical function class (unary, binary, inverse, aggregate) and gates on argument-domain checks stated in the caveats." :cs "Row 2 emphasizes single-call, single-effect: pure functions may be replaced by their memoized result; audits check that no impure sibling was substituted."))
  :row-3-dimension (
    (:setup "Same shape: closed-form combinatorial formula."
     :rungs (
       (:domain "geom/*" :code "(geom/regular-polygon-area 6 2)")
       (:domain "standard tile (a metaphor domain — surface a of a standard shape of standard size)" :code "(define (std-tile n side) (list n side)))")
       (:domain "math — area = (1/4)·n·s²·cot(π/n)" :code "(define (rp-area n s) (list n s))")
     )
     :explanation "Each rung applies a closed-form parametrized by count and size."
     :meta "The shape transfers because 'formula from two parameters' is a universal shape.")
