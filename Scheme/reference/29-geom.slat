(verb
  :name "geom/regular-polygon-vertices"
  :library "geom"
  :kind "meta"
  :signature "(geom/regular-polygon-vertices n r [start-angle]) -> list-of-points"
  :summary "Generate the vertices of a regular n-sided polygon with circumradius r, optionally rotated by start-angle."
  :explanation "A regular polygon inscribed in a circle has vertices evenly spaced around that circle. Given the number of sides n and the circumradius r (distance from center to vertex), this verb computes the Cartesian coordinates of all vertices. The optional start-angle (in radians) allows you to rotate the polygon. This is essential for procedurally generating regular polygon shapes for rendering, collision detection, and geometric reasoning."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/regular-polygon-vertices 4 1)" :note "Vertices of a square inscribed in a unit circle; expect points at (1,0), (0,1), (-1,0), (0,-1).")
    (:dialect "motoi" :tier "intermediate" :code "(geom/regular-polygon-vertices 6 2 0)" :note "Vertices of a regular hexagon with circumradius 2, starting at angle 0; returns 6 points forming a hexagon.")
    (:dialect "motoi" :tier "expert" :code "(define (star-polygon n r)\n  (let ((vertices (geom/regular-polygon-vertices n r 0)))\n    (map (lambda (pt) (list (car pt) (cadr pt))) vertices)))\n(let ((hex-points (star-polygon 6 1)))\n  (map (lambda (p) (geom/distance (geom/point 0 0) (apply geom/point p))) hex-points))" :note "Extract vertices of a hexagon and verify that all are at distance r from the origin (the circumradius property).")
  )
  :caveats ("n must be at least 3." "r must be positive (circumradius, not side length)." "Vertices are returned in order around the polygon, counter-clockwise by convention." "The result is a list of geom/point objects; use car/cdr or other list operations to access them.")
  :drawbacks ("Circumradius is less intuitive than side length for some users; use geom/regular-polygon-area if you have side length and just need the area." "No built-in way to specify a specific center point other than origin (manually translate if needed).")
  :usecases ("Rendering regular polygon shapes (triangles, squares, hexagons, etc.)." "Procedural generation of symmetric game elements." "Constructing collision meshes for regular shapes.")
  :related ("geom/regular-polygon-area" "geom/interior-angle" "geom/point" "geom/circle" "geom/polygon-area")
  :learn (:concept "inscribed regular polygons and parametric point generation" :prerequisites ("geom/point" "geom/sin" "geom/cos" "geom/->radians") :progression "Learn polar coordinates first; then understand how vertices are evenly distributed around a circle; use the result to render or analyze polygons.")
  :row-2-audit (
