(verb
  :name "geom/translate"
  :library "geom"
  :kind "meta"
  :signature "(geom/translate point dx dy) -> point"
  :summary "Translate (shift) a point by a displacement vector (dx, dy)."
  :explanation "Adds the displacement (dx, dy) to a point's coordinates, moving it in the Cartesian plane. This is the simplest affine transformation. Useful for shifting shapes, adjusting positions, or implementing relative positioning in geometry problems or graphics."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(geom/translate '(1 2) 3 4)" :note "Point (1, 2) moves right 3 and up 4 → result is (4, 6)")
    (:dialect "motoi" :tier "intermediate" :code "(define (center-shape points cx cy)\n  (let ((bounds (geom/polygon-perimeter points)))\n    (geom/transform-polygon points 'geom/translate (- cx) (- cy))))\n(center-shape '((0 0) (10 0) (10 10)) 5 5)" :note "Translate points to center them around (5, 5) for symmetric rendering")
    (:dialect "motoi" :tier "expert" :code "(define (chase-target from-pt to-pt speed)\n  (let* ((dx (- (car to-pt) (car from-pt)))\n         (dy (- (cadr to-pt) (cadr from-pt)))\n         (dist (geom/distance from-pt to-pt))\n         (step-x (* (/ dx dist) speed))\n         (step-y (* (/ dy dist) speed)))\n    (geom/translate from-pt step-x step-y)))\n(chase-target '(0 0) '(10 10) 1.4)" :note "Move one point towards another by a fixed step; normalize the displacement vector and scale by speed")
  )
  :caveats ("Translation preserves distance and angles; it does not scale or rotate." "dx and dy are interpreted as Cartesian offsets; positive x goes right, positive y goes up." "If the point is represented as a list (x y), the result is also a list; if it is a vector or object, behavior may differ.")
  :drawbacks ("For chained translations, manual addition accumulates; use geom/transform-polygon for batch operations." "No validation that dx and dy are numbers; invalid inputs will silently fail or produce NaN.")
  :usecases ("Offsetting a shape or sprite for animation or layout." "Implementing relative motion (e.g., \"move 5 pixels up\")." "Centering or aligning shapes in a coordinate system." "Simulating camera pans or viewport shifts.")
  :related ("geom/transform-polygon" "geom/rotate" "geom/dilate" "geom/distance" "geom/midpoint")
  :learn (:concept "Vector addition as translation: adding (dx, dy) to a point's coordinates." :prerequisites ("2D Cartesian coordinates" "Basic vector arithmetic") :progression "After geom/translate, learn geom/rotate and geom/dilate to master scaling; then explore geom/reflect-* for symmetry operations, and finally geom/transform-polygon to apply multiple transforms in sequence.")
