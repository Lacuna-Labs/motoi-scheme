    (:dialect "motoi" :tier "expert" :code "(define (mirror-horizontally pts)\n  (map geom/reflect-y pts))\n(let ((right-half (list (geom/point 1 0) (geom/point 2 1) (geom/point 1 2))))\n  (append right-half (mirror-horizontally right-half)))" :note "Create a full symmetric shape by mirroring the right half across the y-axis and concatenating with the original.")
  )
  :caveats ("Points on the y-axis (x = 0) map to themselves." "This only reflects horizontally; use geom/reflect-x for vertical reflection.")
  :drawbacks ("Very limited scope; only useful for horizontal mirroring." "For arbitrary-axis reflection, use geom/reflect-line instead.")
