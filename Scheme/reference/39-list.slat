    (:claim "sixth returns exactly the sixth element of a list of length ≥ 6."
     :program "(display (sixth (list 1 2 3 4 5 6 7)))\n(newline)\n(display (equal? (sixth (iota 10)) (list-ref (iota 10) 5)))\n(newline)"
     :invariant "∀ list xs with |xs| ≥ 6. sixth(xs) = xs[5]"
     :meta "The pattern is index-equivalent named access. CS pattern name: named accessor. What would falsify: off-by-one. See book-of-code ch07."
     :eng "Stable named form of index 5."
     :math "sixth = π_6 on 6+ tuples."
     :cs "Named accessor idiom."))
  :row-5-emergence (
    (:base "sixth returns the sixth element."
     :composition "(define (pick-days days idxs) (map (lambda (get) (get days)) idxs))\n(display (pick-days (list 'mon 'tue 'wed 'thu 'fri 'sat 'sun) (list first fourth sixth)))\n(newline)"
     :emergent "position-selector table — a list of accessor procedures used to project multiple fields at named positions"
     :meta "The composition treats first/fourth/sixth as first-class functions. What emerges is the accessor-as-value family: procedural projection. Same shape as pluck in various libraries. See book-of-composition ch08."))
)

