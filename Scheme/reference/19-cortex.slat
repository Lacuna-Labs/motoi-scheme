;;; 19-cortex.slat — Motoi Scheme Reference · Chapter 19 · library cortex
;;;
;;; 9 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library cortex — 9 verbs.")

(chapter :number "19" :library "cortex" :verb-count 9 :training-eligible #t)

;; ═══ 9 verbs in library cortex ═══

(verb
  :name "cortex/read"
  :library "cortex"
  :kind "read"
  :signature "(cortex/read key) → value | '()"
  :summary "Read a value from Cortex by key. Returns the nil sentinel if the key is absent."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Wraps getCortex().recall(String(key)). The default in-memory Cortex is a JS Map; production hosts swap in a persistent backend via setAiProvider. Absent keys return the runtime's nil sentinel — test with (nil? v), not (null? v)."
  :explanation "Cortex/read is the first-class Scheme wrapper for a Cortex lookup. It looks up the given key in the active Cortex memory store (per-user, per-cart-context) and returns the stored value. When the key is absent, it returns the runtime's nil sentinel — a distinct absence value that prints like `nil` and matches under (nil? v). The key can be a string or a symbol; both are coerced to strings before lookup. This is one of three first-class Cortex wrappers (read, write, topk); the act-dispatched variants (cortex/recall, cortex/remember, cortex/forget) route through the driver for provenance capture, but cortex/read short-circuits directly to the store for interactive use in the REPL and IDE."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(cortex/read \"favorite-color\")" :note "Read the value stored under 'favorite-color'. Returns nil if never set.")
    (:dialect "motoi" :tier "apprentice" :code "(cortex/write \"pet\" \"koi\")\n(cortex/read \"pet\")" :note "Round-trip: write then read. First call returns #t, second returns the stored value \"koi\".")
    (:dialect "motoi" :tier "intermediate" :code "(define c (cortex/read \"customer/last-order\"))\n(if (nil? c) 'no-orders-yet c)" :note "Guard against a missing key by testing with nil?.")
    (:dialect "motoi" :tier "expert" :code "(define (pref key default)\n  (let ((v (cortex/read (string-append \"pref/\" key))))\n    (if (nil? v) default v)))\n(pref \"theme\" \"midnight\")" :note "Small preference-lookup helper with defaults. Cortex reads are cheap enough to call per-render.")
    (:dialect "motoi" :tier "master" :code "(define (decide-greeting)\n  (let ((name (cortex/read \"user/name\")))\n    (cond ((nil? name) \"hello, friend\")\n          ((string? name) (string-append \"hello, \" name))\n          (else \"hello\"))))\n(decide-greeting)" :note "A decision routine reads user state from Cortex and branches on both presence AND shape. Motoi uses this pattern to personalize without asking the user twice — no name yet → hello friend; name known → hello Alice.")
    (:dialect "motoi" :tier "novice" :code "(cortex/remember 'hero-name \"Nova\")\n(display (cortex/read 'hero-name))" :note "Store a name, then read it back.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((val (cortex/read 'missing)))\n  (if (null? val)\n      (display \"not stored\")\n      (display val)))" :note "cortex/read returns nil for missing keys. Guard against it.")
  )
  :caveats ("Missing keys return the nil sentinel, NOT the empty list and NOT #f. Test with (nil? v) — (null? nil) is #f and (if nil …) takes the truthy branch." "Keys are coerced to strings; symbols and strings with the same characters hit the same slot." "Reads are not audited — for provenance capture, prefer (act 'cortex/recall …)." "The Cortex instance is a per-process default; carts run in isolated stores if the host sets one up.")
  :drawbacks ("No versioning — a later cortex/write with the same key overwrites silently." "No expiration or decay in the direct wrapper; use cortex/forget (act-dispatched) for cleanup." "Not suitable for large binary blobs — Cortex is optimized for small facts, not media.")
  :usecases ("Interactive lookup in the REPL or IDE while exploring what's been stored." "Quick default-with-fallback patterns in operator scripts." "Test scaffolding that seeds a Cortex fixture then reads it back." "Feature toggles or user prefs stored per session.")
  :related ("cortex/write" "cortex/topk" "cortex/recall" "cortex/remember" "cortex/forget" "act")
  :learn (:concept "Cortex is Motoi's persistent memory graph. Read is the get half of a key-value store, with a nil sentinel for absent keys." :prerequisites ("nil?" "string?" "let") :progression "After cortex/read, learn cortex/write to store values; then cortex/topk to search by pattern; then the act-dispatched forms for provenance.")
  :ai (:raises () :pipes-into ("nil?" "cond" "let" "cortex/write") :consumes-from ("string" "symbol" "string-append") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Testing with (null? v) or (not v) instead of (nil? v). The Cortex miss-sentinel is nil, which is neither null nor #f — (if (cortex/read \"nope\") 'yes 'no) returns 'yes." :when-not-to-use "Reading provenance-critical facts — use (act 'cortex/recall …) instead so the driver captures who read what when." :returns-confidence #f)
  :commerce (:cost "free" :fuel-cost "1" :needs-consent #f :idempotent #t :cortex-touch "read")
  :row-2-audit (
    (:problem "A running cart needs to remember whether it has seen this user before, and greet accordingly. The operator asks: 'when the greeter routine fires and the user is unknown, what does it do?' The audit answer must be: it produces a safe default without a network call and without asking a sibling verb that would have opened a can of worms."
     :program "(cortex/write \"user/state\" \"returning\")\n(define (greet)\n  (let ((state (cortex/read \"user/state\")))\n    (if state\n        (string-append \"welcome back, \" state)\n        \"welcome, friend\")))\n(display (greet)) (newline)\n(cortex/write \"user/state\" #f)\n(display (greet)) (newline)"
     :explanation "Line 1 seeds a fact. Line 2 defines a greeter that reads the fact and branches on presence. Line 3 exercises the greeter with the fact present — the operator sees 'welcome back, returning'. Lines 5-6 clear the fact and re-run; because cortex/read miss returns #f, the falsy branch fires and the greeter falls back to 'welcome, friend'. The audit lane logs one read per invocation and zero external calls."
     :meta "cortex/read is the honest verb here because it is a plain get with a documented miss-return; a sibling like cortex/query would have opened a search (many candidates, ranked, empty-list-on-miss shape) and the greeter would have had to destructure a list to answer one question. Reaching for the search verb when you want a lookup is the classic audit finding — cheaper verb, wrong shape.")
    (:eng "Operator's log reads one Cortex touch per greeter fire; no network, no rank, no scoring. Failure mode is a single miss return (#f), not an exception. Cross-reference: this is the read-through pattern the operator's dashboard graphs as 'hits vs. misses' per key."
     :math "Total function ρ: K → V ∪ {⊥} where K is the string-coerced key space and ⊥ is the runtime's miss-return. Domain is closed under (symbol→string); codomain is the union of all previously-written values plus the miss token."
     :cs "Point-lookup on a hash-backed store. O(1) expected. No provenance frame is pushed on the stack; contrast the act-dispatched (act 'cortex/recall …) which pushes a caller frame with who/when/why for the auditor."))
  :row-3-dimension (
    (:setup "Lookup-with-fallback: give me the value at this address, or tell me it's missing so I can decide what to do next."
     :rungs (
       (:domain "cortex (this verb)"    :code "(cortex/write \"pref/theme\" \"paper\")\n(display (or (cortex/read \"pref/theme\") \"midnight\")) (newline)")
       (:domain "hash table (data structure)" :code "(define h (make-hash-table))\n(hash-table-set! h 'theme \"paper\")\n(display (hash-table-ref h 'theme (lambda () \"midnight\"))) (newline)")
       (:domain "partial function (math)"   :code "(define (f x) (case x ((1) 'red) ((2) 'green) (else #f)))\n(display (or (f 3) 'unknown)) (newline)"))
     :explanation "Rung 1 shows the verb in its own store: key-string → value or miss-token, and the caller supplies a default via the surrounding (or …). Rung 2 shows the exact same shape one substrate down — a hash table's ref-with-default is structurally identical to a Cortex read wrapped in a fallback. Rung 3 lifts to the mathematical shape: a partial function is a function that returns ⊥ (undefined) outside its domain, and the caller composes it with a total-completion (⊥ → default) to make a total function. The three rungs are the same shape wearing three different clothes."
     :meta "The shape transfers because all three substrates share the same signature: input → value ∪ ⊥, plus an ambient way to spell 'if ⊥ then default'. Once you see cortex/read as a partial function, you can port the pattern to any store that lets misses be observable — SQL SELECT WHERE returning zero rows, DNS resolution returning NXDOMAIN, a git rev-parse on a missing branch. Same shape.")
    (:eng "Every fallback-capable lookup in a running system is one of these three rungs in disguise. When SRE reads the greeter's dashboard they are literally watching the miss-side of this shape."
     :math "Partial functions form a category; total completions (adding ⊥ + a default) is a functor from partial to total. cortex/read is a partial function whose completion is (or (cortex/read k) default)."
     :cs "The lookup-with-default idiom lives in every associative container in every language: HashMap.getOrDefault (Java), dict.get(k, default) (Python), map[k] || default (JS)."))
  :row-4-proof (
    (:claim "cortex/read is a right-inverse of cortex/write on the same key within a session: writing v under k and then reading k returns v. Two consecutive writes to the same key are absorbed into the last-writer-wins invariant — the second write's value is what a subsequent read returns."
     :program "(define (rt k v)\n  (cortex/write k v)\n  (equal? (cortex/read k) v))\n(display (rt \"a\" 1))            (newline)  ; round-trip on integer\n(display (rt \"b\" \"pink\"))       (newline)  ; on string\n(display (rt \"c\" (list 1 2 3))) (newline)  ; on list\n\n;; last-writer-wins\n(cortex/write \"k\" \"first\")\n(cortex/write \"k\" \"second\")\n(display (equal? (cortex/read \"k\") \"second\")) (newline)\n\n;; determinism inside a session (two reads agree)\n(cortex/write \"det\" 'same)\n(display (eq? (cortex/read \"det\") (cortex/read \"det\"))) (newline)"
     :invariant "∀ k ∈ K, ∀ v ∈ V.  read(after(write(k,v))) = v.   ∀ k, ∀ v₁ v₂.  read(after(write(k,v₁); write(k,v₂))) = v₂."
     :meta "This is the classical get-after-set contract of a mutable map. A single counter-example — one k, one v, one round-trip that came back different — would falsify the store's guarantee. The pattern name is 'last-writer-wins map' (LWW), a monoid on Vᴋ with the second-argument-wins operator. Grounded in book-of-code ch 8 (memory latches: the flip-flop is the hardware ancestor of a one-cell LWW register) and book-of-code ch 13 (memory hierarchy: the same LWW rule holds for L1 cache lines and DRAM cells alike).")
    (:eng "The invariant is what the operator implicitly relies on when they write a preference and expect the next render to see it. If read-after-write ever diverged, every UI in the system would flicker; the fact that they don't is this invariant holding."
     :math "The pair (write, read) forms a section-retraction: read ∘ write_v = id_V on the singleton chain. The full store is the coequalizer of the write-then-write sequence quotiented by last-writer-wins."
     :cs "Idempotent-on-value writes ((write k v); (write k v)) do not change the observable state; last-writer-wins is not commutative in general (write(k,a);write(k,b) ≠ write(k,b);write(k,a)). Standard content-addressed/key-addressed store semantics."))
  :row-5-emergence (
    (:base "cortex/read is a point-lookup with a miss-return."
     :composition "(define (read-through k thunk)\n  (let ((cached (cortex/read k)))\n    (if cached\n        cached\n        (let ((fresh (thunk)))\n          (cortex/write k fresh)\n          fresh))))\n\n(define (expensive-color)\n  (display \"computing…\") (newline)\n  \"petal-pink\")\n\n(display (read-through \"color\" expensive-color)) (newline)  ; computes, stores\n(display (read-through \"color\" expensive-color)) (newline)  ; hit — no compute"
     :emergent "A read-through cache. The pair (cortex/read + cortex/write + a thunk) becomes a caching layer: first call misses and stores; second call hits and skips the work. Neither read nor write carries caching in itself — the pattern emerges from packing them next to a computation."
     :meta "This is the standard read-through cache pattern from the family of caching topologies (read-through, write-through, write-behind, cache-aside). Familiar analogs: Redis GET-then-SET-on-miss, HTTP caching with a validator, memoize decorators. Cross-reference: book-of-composition ch 13 (save-load, which builds the same shape over a file); book-of-computing ch 13 (databases and storage, where the same cache emerges over a slow backend).")
    (:eng "The emergent cache is the atom of most production performance work. The operator sees it in the dashboard as a rising hit-rate curve after warm-up. Failure mode of the pattern is stale data — no invalidation is present in the two-verb pair, and the operator adds cortex/forget or a TTL to close the loop."
     :math "Read-through is a fixed point of the state transition (state, k) → (state', v) where state' = state ∪ {k↦v} on miss and state on hit. The cache converges to a partial memoization of thunk over the keyspace touched so far."
     :cs "Composition of a pure computation with a mutable store yielding a memoized function. This is the same construction as classical memoize but split across two verbs so the store is inspectable, resettable, and shareable across callers.")))

(verb
  :name "cortex/write"
  :library "cortex"
  :kind "mut"
  :signature "(cortex/write key value) → #t"
  :summary "Store a value in Cortex under key. Overwrites any prior value at that key."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Wraps getCortex().remember(String(key), value). In-memory Map by default; value is stored by reference — mutating it after write mutates Cortex too. Production hosts serialize on flush."
  :explanation "Cortex/write is the first-class Scheme wrapper for a Cortex store. It writes the given value to the active Cortex memory store under the given key and returns #t. The key can be a string or a symbol (both coerced to string). The value can be any Scheme value — number, string, list, symbol, or a nested structure. Cortex stores the value as-is; readers get back the same shape. This is the write half of the direct-access pair (with cortex/read); use it in the REPL and IDE for quick teaching and in operator scripts that don't need provenance capture. Carts building on the reasoning-and-remember loop should still prefer (act 'cortex/remember …) so the driver captures the full audit trail."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(cortex/write \"favorite-color\" \"petal-pink\")" :note "Store a single fact. Returns #t.")
    (:dialect "motoi" :tier "apprentice" :code "(cortex/write \"session/id\" \"abc-123\")\n(cortex/write \"session/started\" 1720000000)\n(list (cortex/read \"session/id\") (cortex/read \"session/started\"))" :note "Write two facts and read them back. Returns (\"abc-123\" 1720000000).")
    (:dialect "motoi" :tier "intermediate" :code "(cortex/write \"customer/last-order\"\n  (list ':id 4132 ':total 49.99 ':when 'today))" :note "Store a small structured fact under a namespaced key. Later, cortex/read retrieves the same list shape.")
    (:dialect "motoi" :tier "expert" :code "(define (remember-many pairs)\n  (for-each\n    (lambda (kv)\n      (cortex/write (car kv) (cadr kv)))\n    pairs))\n(remember-many\n  (list (list \"pref/theme\"      \"paper\")\n        (list \"pref/font-size\"  14)\n        (list \"pref/vim-mode\"   #t)))" :note "Bulk-store a batch of preferences from a list of (key value) pairs. for-each returns () after applying the writer.")
    (:dialect "motoi" :tier "master" :code "(define (upsert-count key)\n  (let ((n (cortex/read key)))\n    (cortex/write key\n                  (if (nil? n) 1 (+ n 1)))))\n(upsert-count \"clicks\")\n(upsert-count \"clicks\")\n(upsert-count \"clicks\")\n(cortex/read \"clicks\")" :note "A cart-style read-modify-write cycle: read the current value, default to 1 on absence, otherwise increment. After three calls, (cortex/read \"clicks\") returns 3. Motoi uses this shape for counters, tallies, and lightweight state accumulation.")
  )
  :caveats ("Overwrites silently — no versioning in the direct wrapper." "For persistence and provenance, use (act 'cortex/remember …) instead." "Keys are strings; namespacing is by convention (e.g., 'pref/theme', 'customer/id')." "Cortex may serialize the value on flush; keep values Scheme-simple (no closures, no host objects).")
  :drawbacks ("No transaction — a partial batch can leave Cortex in a mixed state on error." "No size limit is enforced client-side; a huge value can bloat storage." "Concurrent writers from multiple carts to the same key have last-write-wins semantics.")
  :usecases ("Teaching Motoi a fact interactively via the REPL." "Persisting user preferences from an IDE settings dialog." "Seeding fixtures in tests before exercising cortex/read." "Operator scripts that record ambient state (last-cursor, last-file, session-id).")
  :related ("cortex/read" "cortex/topk" "cortex/remember" "cortex/forget" "act")
  :learn (:concept "Cortex is Motoi's persistent memory graph. Write is the set half of a key-value store; the wrapper short-circuits act-dispatch for interactive use." :prerequisites ("list" "cons" "for-each" "cortex/read") :progression "After cortex/write, learn cortex/topk to search across many keys; then act 'cortex/remember for provenance-captured writes.")
  :ai (:raises () :pipes-into ("cortex/read" "cortex/topk" "cortex/forget") :consumes-from ("list" "string" "number" "symbol") :cardinality "void" :deterministic #t :cacheable #f :common-mistakes "Passing a mutable structure and then mutating it — the Cortex holds the same reference and observes the mutation. Copy before storing if you need a snapshot." :when-not-to-use "Provenance-critical writes (audit, billing, legal) — use (act 'cortex/remember …) so the driver captures who wrote what when." :returns-confidence #f)
  :commerce (:cost "free" :fuel-cost "1" :needs-consent #f :idempotent #t :cortex-touch "write")
  :row-2-audit (
    (:problem "A settings dialog wants to persist the user's chosen theme so the next render, and the next session, come up in the same theme. The operator asks: 'the click handler fires once — what verb do I call, and can I defend the choice under an audit lane that scans for silent failure?'"
     :program "(define (on-theme-picked theme)\n  (let ((ok (cortex/write \"pref/theme\" theme)))\n    (if ok\n        'stored\n        'failed)))\n(display (on-theme-picked \"midnight\")) (newline)\n(display (cortex/read \"pref/theme\")) (newline)"
     :explanation "Line 1 declares the handler. Line 2 calls cortex/write with a namespaced key and the picked value; the wrapper returns #t on success and (in a persistent-backed host) #f if the store rejects the write. Line 3-4 branch on that boolean so the caller sees a symbolic result instead of the raw success flag. Line 6 exercises the handler; line 7 reads the value back to confirm the persistence. The audit lane sees one write per click, and — if the store ever refuses — the handler surfaces a distinguishable 'failed rather than pretending nothing happened."
     :meta "cortex/write is the honest verb because it is the direct set-half of the same key-value store cortex/read consults. A sibling — cortex/remember — would have opened a provenance frame, called into the driver, and cost a fuel unit; that is right when the WHO/WHEN matters (billing, legal, audit-critical writes), but for a theme pick it would be over-instrumented and slower. The audit finding when you see cortex/remember on a preferences key is 'right verb family, wrong urgency.'")
    (:eng "Operator's log reads one Cortex touch per click; no dispatch frame, no llm/provider round trip. The failure mode is a boolean return, not an exception — the caller stays responsible for reacting."
     :math "State transition τ: (K, V) × (S) → S where S is the store, sending (k, v) × s → s[k ↦ v]. Left-total on K × V; the codomain always includes the updated store."
     :cs "Constant-time set on a hash-backed map; last-writer-wins under concurrent writers. Idempotent on same value: applying (write k v) twice leaves observable state identical to applying it once."))
  :row-3-dimension (
    (:setup "Point-store: put this value at this address, overwrite whatever was there, tell the caller it landed."
     :rungs (
       (:domain "cortex (this verb)"  :code "(cortex/write \"score/high\" 9001)\n(display (cortex/read \"score/high\")) (newline)")
       (:domain "mailbox (metaphor)"  :code "(define mailbox (make-vector 1 '()))\n(define (mailbox-put! v) (vector-set! mailbox 0 v))\n(define (mailbox-get) (vector-ref mailbox 0))\n(mailbox-put! 9001)\n(display (mailbox-get)) (newline)")
       (:domain "assignment (math)"   :code "(define env (list (list 'x 0)))\n(define (env-set env k v) (cons (list k v) env))\n(define env2 (env-set env 'x 9001))\n(display (cadr (assoc 'x env2))) (newline)"))
     :explanation "Rung 1 shows the verb: a keyed write into a mutable store, followed by a read to confirm. Rung 2 shows the same shape one substrate down — a one-cell mailbox with put! and get functions; the store is a single vector cell instead of a hash, but the (write, read) contract is the same. Rung 3 lifts to a math/CS shape: an environment is an association list, and 'assigning' x by consing a new binding is the immutable version of the same shape, where read follows the most-recent binding. Same shape, three substrates."
     :meta "The shape transfers because store-a-value-under-a-name is a universal building block. Once you see cortex/write as one leaf of that family, you can port the pattern to any store that supports keyed put: JSON writes to a file, PUT to a REST endpoint, INSERT ON CONFLICT UPDATE in SQL, git add + commit. Same shape.")
    (:eng "Every keyed persistence action in a running system is one of these three rungs. When SRE watches the store's write-per-second graph, they are watching this shape's frequency."
     :math "A store update is a right-action of (K × V) on the semilattice S of stores; last-writer-wins gives the composition (k, v₁) · (k, v₂) = (k, v₂)."
     :cs "The put half of a key-value protocol; classical since Symbol tables and environments in Lisp 1.5. Modern echoes: HashMap.put, Redis SET, PUT /keys/{k}."))
  :row-4-proof (
    (:claim "cortex/write is idempotent on identical value and last-writer-wins on differing values. Applying (write k v) twice is observationally equal to applying it once; applying (write k v₁) then (write k v₂) leaves the store observationally equal to just (write k v₂)."
     :program "(cortex/write \"i\" 42)\n(cortex/write \"i\" 42)\n(display (equal? (cortex/read \"i\") 42)) (newline)  ; idempotence on same value\n\n(cortex/write \"j\" \"a\")\n(cortex/write \"j\" \"b\")\n(display (equal? (cortex/read \"j\") \"b\")) (newline)  ; last-writer-wins\n\n;; the return value is always #t on a successful write\n(display (eq? #t (cortex/write \"r\" 1))) (newline)\n(display (eq? #t (cortex/write \"r\" 2))) (newline)"
     :invariant "∀ k, v.  write(k, v); write(k, v)  ≡  write(k, v).   ∀ k, v₁, v₂.  write(k, v₁); write(k, v₂)  ≡  write(k, v₂).   ∀ k, v.  result(write(k, v)) = #t."
     :meta "Idempotence-on-value is the property that keeps retry loops safe: a network re-drive of a cortex/write cannot corrupt state as long as the payload is identical. Last-writer-wins is the composition rule; together they form a semigroup on writes-per-key with the second-argument-wins operator. Grounded in book-of-code ch 9 (registers-counters-and-the-birth-of-state, where a D-flip-flop is the hardware LWW cell) and book-of-code ch 10 (state-machines-mealy-and-moore, where a write is a labeled transition of the store).")
    (:eng "The invariant is why every settings-save button works after the user clicks it twice by accident, and why retry-with-same-payload does not double-count anything. If idempotence-on-value ever broke, form submissions would corrupt state on refresh."
     :math "Writes form a monoid action on S: identity is the no-op write (never issued directly), composition is sequential and absorbs on same-key by taking the right operand. Modding out by that absorption gives the LWW quotient."
     :cs "The absorption law makes cortex/write safe under at-least-once delivery — a required property for any store that participates in a retry loop. Compare with counter-increment (NOT idempotent) and set-union (idempotent but commutative)."))
  :row-5-emergence (
    (:base "cortex/write is a point-store: value in, boolean out, key overwritten."
     :composition "(define (write-through k v disk-writer)\n  (cortex/write k v)          ; hot store, synchronous\n  (disk-writer k v)           ; slow store, best-effort\n  #t)\n\n(define log '())\n(define (fake-disk k v)\n  (set! log (cons (list 'disk k v) log)))\n\n(write-through \"pref/theme\" \"paper\" fake-disk)\n(write-through \"pref/font\"  14 fake-disk)\n(display (cortex/read \"pref/theme\")) (newline)\n(display log) (newline)"
     :emergent "A write-through cache. Chaining cortex/write with a slower persistence sink produces the second classical caching topology: hot store is always current, cold store is updated on every write, reads are cheap because they hit the hot store first. The shape emerges from packing cortex/write next to another writer."
     :meta "This is the write-through cache pattern from the same family as cortex/read's read-through cache. Familiar analogs: Redis SET plus RDB snapshot, HTTP PUT plus CDN invalidation, git commit plus git push. Cross-reference: book-of-composition ch 13 (save-load, which is the disk half of exactly this pattern) and book-of-computing ch 13 (databases and storage, where write-through is the classical topology named).")
    (:eng "Write-through gives the operator the invariant 'the hot store never lies about what will survive a restart'; the failure mode is that the cold sink's failure is visible only in its own log, so the operator adds a monitor on the disk-writer's error path."
     :math "Write-through is the pushout of the write into two parallel stores; the invariant is that reads from the hot store are a section of the reads from the cold store, up to eventual consistency."
     :cs "Composition of a synchronous write with a best-effort side-effect. This is the same construction as the transactional 'outbox pattern' but simpler — no delivery guarantee is added, just symmetry between the hot and cold stores."))
    )

(verb
  :name "cortex/topk"
  :library "cortex"
  :kind "read"
  :signature "(cortex/topk pattern [k]) → (hit …)"
  :summary "Return up to k Cortex entries matching a query pattern. Default k is 10."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Wraps getCortex().query(pattern).slice(0, k). In the standalone in-memory Cortex the query engine is a substring match over keys; production hosts route the same call through cosine-similarity over embeddings. Each hit is a two-element list (key value)."
  :explanation "Cortex/topk searches the Cortex memory graph for entries relevant to the given pattern and returns up to k hits, ordered by relevance. The pattern is a string or symbol interpreted by the Cortex query engine — plain-text substring in the standalone REPL, cosine-similarity over embeddings in the production host. Each hit is a two-element list (key value). When no hits match, the result is the empty list (). The wrapper caps the result count for use in ranked lists (e.g., 'give me the 5 most-similar customer facts'). Unlike cortex/read, misses ARE proper empty-list null — you can safely test with (null? hits)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(cortex/write \"favorite/color\" \"pink\")\n(cortex/write \"favorite/food\" \"sushi\")\n(cortex/topk \"favorite\" 3)" :note "Write two keyed facts, then fetch up to 3 entries whose key contains 'favorite'. Returns ((\"favorite/color\" \"pink\") (\"favorite/food\" \"sushi\")).")
    (:dialect "motoi" :tier "apprentice" :code "(cortex/topk \"no-such-key\")" :note "No matches → returns the empty list (). Default k is 10 when omitted.")
    (:dialect "motoi" :tier "intermediate" :code "(cortex/write \"customer/1\" \"Alice\")\n(cortex/write \"customer/2\" \"Bob\")\n(define recent (cortex/topk \"customer/\" 10))\n(map car recent)" :note "Take the 10 most-relevant customer facts, project just the keys. Returns (\"customer/1\" \"customer/2\").")
    (:dialect "motoi" :tier "expert" :code "(define (suggest-similar-listings query)\n  (let ((hits (cortex/topk query 5)))\n    (if (null? hits)\n        'no-similar-listings\n        (map (lambda (hit)\n               (list ':key (car hit)))\n             hits))))\n(cortex/write \"jewelry/vintage-silver\" \"ring-1\")\n(cortex/write \"jewelry/gold\" \"chain-2\")\n(suggest-similar-listings \"jewelry/\")" :note "Small recommender: query Cortex, extract just the keys for downstream ranking. Empty result becomes a sentinel symbol.")
    (:dialect "motoi" :tier "master" :code "(define (recommend-next-action user-id k)\n  (let ((hits (cortex/topk (string-append \"user/\" user-id \"/\") k)))\n    (cond ((null? hits) '(prompt-onboarding))\n          ((< (length hits) 3) '(prompt-fill-profile))\n          (else (map car hits)))))\n(cortex/write \"user/alice/pref\" \"paper\")\n(cortex/write \"user/alice/theme\" \"garden\")\n(cortex/write \"user/alice/lang\" \"en\")\n(cortex/write \"user/alice/tz\" \"est\")\n(recommend-next-action \"alice\" 10)" :note "A cart-style decision routine: search Cortex for what the user has told us, branch on cardinality (nothing → onboard; sparse → fill profile; enough → return the keys for next-action ranking). Motoi uses this shape to decide when to ask vs. when to act.")
    (:dialect "motoi" :tier "novice" :code "(display (cortex/topk '(hero *)))" :note "Best 10 matches for the pattern, ranked by relevance.")
    (:dialect "motoi" :tier "intermediate" :code "(display (cortex/topk '(item *) 3))" :note "Just the top 3 item matches. Bounded results for tight UIs.")
  )
  :caveats ("Result shape depends on the underlying Cortex store — always guard with pair? / null? before destructuring." "k defaults to 10 when omitted; pass explicitly for reproducible tests." "Ranking is by the Cortex similarity function — cosine over embeddings in the production host, substring match in the standalone REPL." "Returns () not #f when there are no hits — (null? hits) is the right test.")
  :drawbacks ("Not a full-text search — precision depends on how the writer namespaced keys." "No pagination in the direct wrapper — request k explicitly." "Large k values may be slow; prefer k ≤ 50 for interactive latency.")
  :usecases ("Building small recommenders on top of stored customer or listing facts." "Interactive exploration in the IDE — 'what have I stored under this prefix?'" "Ranked candidate lists for downstream reasoning (feed the topk into an act 'lacuna/ask)." "Debugging Cortex state during a session — inspect what's been remembered.")
  :related ("cortex/read" "cortex/write" "cortex/recall" "cortex/query" "act")
  :learn (:concept "Topk is the ranked-search variant of Cortex read — return the k most-relevant entries for a pattern, empty list on miss." :prerequisites ("cortex/read" "cortex/write" "map" "car" "null?") :progression "After cortex/topk, learn (act 'cortex/recall …) for provenance-captured queries and (act 'cortex/multi-store-publish …) for cross-store search when hosts wire it.")
  :ai (:raises () :pipes-into ("map" "car" "cond" "length" "filter") :consumes-from ("string" "symbol") :cardinality "many" :deterministic #t :cacheable #t :common-mistakes "Assuming (null? hit) — hit is a (key value) LIST. Use (null? hits) at the top level, then (car hit) / (cadr hit) once you know hits is non-empty." :when-not-to-use "Cross-store or provenance-captured search — use (act 'cortex/query …) or (act 'cortex/multi-store-publish …) instead." :returns-confidence #f)
  :commerce (:cost "free" :fuel-cost "2" :needs-consent #f :idempotent #t :cortex-touch "read")
  :author-note "Row-2 through Row-5 use cortex/read+cortex/keys stand-ins in :program blocks where a topk call would appear at runtime, because as of authoring cortex/topk is spec'd in this chapter but not yet registered in the runtime (see :impl-status). The invariants and shapes below hold for the intended semantics; when topk lands, the proxies collapse to a single topk call."
  :row-2-audit (
    (:problem "An operator building a small recommender wants the k most-relevant customer facts to feed into a downstream ranker. The question: 'if I ask for k=5 and only 2 facts exist, does the code get a bounded list I can iterate, or a rank error I have to catch?' The audit lane wants a verb that returns a list — always — regardless of how sparse Cortex is."
     :program "(cortex/remember 'customer/1 \"Alice\")\n(cortex/remember 'customer/2 \"Bob\")\n\n;; Stand-in for (cortex/topk \"customer/\" 5), using cortex/keys + a filter.\n(define (topk-proxy prefix k)\n  (let ((all (cortex/keys)))\n    (define matches\n      (filter (lambda (key)\n                (let ((s (symbol->string key)))\n                  (>= (string-length s) (string-length prefix))))\n              all))\n    (if (> (length matches) k)\n        (take matches k)\n        matches)))\n\n(define hits (topk-proxy \"customer/\" 5))\n(display (list? hits)) (newline)\n(display (<= (length hits) 5)) (newline)"
     :explanation "Lines 1-2 seed two customer facts. Lines 4-13 stand in for (cortex/topk 'customer/ 5) using a proxy over cortex/keys — the proxy filters keys by prefix and caps at k. Line 15 exercises it; lines 16-17 verify two invariants the recommender's caller relies on: (a) hits is always a list, so map/filter can iterate; (b) length ≤ k, so downstream bounded loops terminate. The audit lane sees exactly those two propositions as the verb's contract."
     :meta "cortex/topk is the honest verb because it caps the result count at the source; a sibling like cortex/query returns everything matching and forces the caller to (take hits k) — a step the operator will forget under time pressure, letting a giant result flow into a UI. The audit finding when you see cortex/query where topk was intended is 'right family, missing cap.'")
    (:eng "Operator's log shows one Cortex touch per call and one bounded list out. Failure mode when Cortex is empty: hits = (), null? guard catches it before any (car hits)."
     :math "Total function ρ: (pattern, k) → list(V) with |ρ(p, k)| ≤ k for all p, k."
     :cs "Bounded search over a key-value store; the cap is enforced by the verb, not the caller. Contrast with cortex/query, which is unbounded and forces the caller to trim."))
  :row-3-dimension (
    (:setup "Bounded ranked-search: give me the top k matches for this query, ordered by relevance, capped at k."
     :rungs (
       (:domain "cortex (this verb)"    :code "(cortex/remember 'a 1) (cortex/remember 'b 2) (cortex/remember 'c 3)\n(define (topk-proxy _ k)\n  (let ((ks (cortex/keys)))\n    (if (> (length ks) k) (take ks k) ks)))\n(display (topk-proxy 'any 2)) (newline)")
       (:domain "sorted queue (data structure)" :code "(define scores (list 8 3 10 1 6))\n(define (topk lst k)\n  (let ((sorted (sort lst >)))\n    (if (> (length sorted) k) (take sorted k) sorted)))\n(display (topk scores 2)) (newline)")
       (:domain "ordered relation (math)"   :code "(define (top-2 xs)\n  (let ((sorted (sort xs >)))\n    (if (< (length sorted) 2) sorted (take sorted 2))))\n(display (top-2 (list 5 2 8 1 9 3))) (newline)"))
     :explanation "Rung 1 shows the verb in its own domain: cortex/topk (stood in by a keys+cap proxy) returns up to k matches from the store. Rung 2 shows the same shape one substrate down — a sorted-queue topk that orders by score then takes the first k. Rung 3 lifts to the pure math shape: given a total order on a set, take the k greatest. All three are the same shape: an ordered subset of size at most k."
     :meta "The shape transfers because 'ranked and bounded' is one primitive. Once you see cortex/topk as a heap-top-k, you can port the pattern to any ordered store: SQL SELECT ... ORDER BY ... LIMIT k, Redis ZREVRANGEBYSCORE, a max-heap's k-pops. Same shape.")
    (:eng "Every 'top matches' surface in a running system is one of these three rungs in disguise: 'first page of search', 'most similar customers', 'top 3 recommended tracks'. The bound is the pagination frontier."
     :math "A projection from the (finite) subset of matches onto the initial segment of length min(k, |matches|) under the ranking order."
     :cs "Classical k-selection over a ranked stream. When k is small and matches is large, a bounded heap gives O(n log k). When the store is embedding-backed, ANN indices give O(log n) with k as a factor."))
  :row-4-proof (
    (:claim "cortex/topk is bounded and empty-safe: for any pattern and any k, the result is a list of length at most k, and when no keys match the pattern the result is the empty list ()."
     :program "(cortex/remember 'q/1 1) (cortex/remember 'q/2 2) (cortex/remember 'q/3 3)\n\n;; Proxy that models topk's cap.\n(define (topk-proxy prefix k)\n  (let ((all (cortex/keys)))\n    (if (> (length all) k) (take all k) all)))\n\n;; ∀ k. |topk k| ≤ k\n(display (<= (length (topk-proxy 'any 0)) 0)) (newline)\n(display (<= (length (topk-proxy 'any 2)) 2)) (newline)\n(display (<= (length (topk-proxy 'any 99)) 99)) (newline)\n\n;; Empty-safe: on an empty store the result is ()\n(map cortex/forget (cortex/keys))\n(display (equal? (topk-proxy 'any 5) '())) (newline)"
     :invariant "∀ p, k.  |topk(p, k)| ≤ k.   ∀ p, k.  topk(p, k) = () when no key matches p.   ∀ p.  topk(p, 0) = ()."
     :meta "Boundedness is what makes topk safe to place next to a UI: the caller's paging logic never has to defensively trim. Empty-safety is what makes it composable: null? is the miss-test, no sentinels. The pattern name is 'bounded selection'; the counter-example that would falsify it is any (p, k) call returning a list longer than k. Grounded in book-of-code ch 13 (memory hierarchy: cache-set associativity is the hardware analog of a bounded-k selection) and book-of-computing ch 13 (databases and storage, where LIMIT k names the same law).")
    (:eng "Boundedness makes the failure mode benign: the worst outcome of a bad pattern is an empty list, not a runaway allocation. Operators do not need a circuit breaker around topk."
     :math "A monotone-decreasing function on |matches|: as the store shrinks, |topk| shrinks weakly. As k grows, |topk| grows weakly to |matches|."
     :cs "The cap is enforced by the verb, not by post-processing. This is the same design principle as SQL's LIMIT clause — pushing bounds down to the store rather than trusting the caller to trim."))
  :row-5-emergence (
    (:base "cortex/topk is a bounded ranked search over the store."
     :composition "(cortex/remember 'song/A 'blues) (cortex/remember 'song/B 'jazz)\n(cortex/remember 'song/C 'blues) (cortex/remember 'song/D 'rock)\n\n;; Recommender = (topk over user's history) + (rank by frequency) + (return best k).\n(define (topk-proxy _ k)\n  (let ((all (cortex/keys)))\n    (if (> (length all) k) (take all k) all)))\n\n(define (recommend k)\n  (let* ((candidates (topk-proxy 'song 100))\n         (with-tag  (map (lambda (key)\n                           (list key (cortex/recall key)))\n                         candidates)))\n    (if (> (length with-tag) k) (take with-tag k) with-tag)))\n\n(display (recommend 2)) (newline)"
     :emergent "A recommender pipeline. Chaining cortex/topk with cortex/recall and a ranker turns a store search into a 'best k songs for this user' pipeline — a shape neither verb carries alone. The bounded search hands the pipeline a manageable candidate set; the recall pass enriches each candidate with its stored value; the final cap bounds the result for the UI."
     :meta "This is the classical retrieval-plus-rerank pattern from the family of recommender topologies (topk-retrieval → feature-lookup → rerank → present). Familiar analogs: Elasticsearch's search + doc_values pipeline, a vector DB's ANN → doc lookup, SQL SELECT + JOIN + LIMIT. Cross-reference: book-of-composition ch 13 (save-load, where the same retrieval + present shape lives over a file); book-of-computing ch 13 (databases and storage, where retrieval + rerank is the named topology).")
    (:eng "The pipeline is inspectable at each stage: the operator can log the topk candidates, the enriched set, and the final cut, and diagnose 'the wrong song surfaced' as a stage-by-stage regression."
     :math "The composition is a natural transformation from (keyspace bounded by k) → (keyspace × valuespace bounded by k), stable under refinement of the ranker."
     :cs "This is the retrieval-plus-rerank contract; it is the same construction as a two-stage ANN pipeline (fast approximate topk, slow exact reranker) but over a small in-memory store."))
    )

(verb
  :name "cortex/remember"
  :library "cortex"
  :kind "mut"
  :dialect "motoi"
  :signature "(cortex/remember key value) -> #t"
  :arity "2"
  :contract "key is symbol or string, value is any → #t"
  :summary "Store a fact in Cortex (Motoi's persistent memory) under the given key."
  :doc "Key is coerced to a string before storage. Overwrites any prior value at that key. Cortex is per-operator memory, not per-session — facts persist across REPL restarts. Perm: personal-data."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(cortex/remember 'greeting \"hello\")" :note "Store the string \"hello\" under key 'greeting. Returns #t.")
    (:dialect "motoi" :tier "intermediate" :code "(cortex/remember 'user-age 42)" :note "Values can be any Scheme value — numbers, lists, symbols.")
    (:dialect "motoi" :tier "expert" :code "(define (learn key value)\n  (if (cortex/recall key)\n      (list 'already-known key)\n      (begin (cortex/remember key value) (list 'learned key value))))\n(learn 'favorite-color 'blue)" :note "Learn only if not already known. Returns (learned favorite-color blue) or (already-known ...).")
    (:dialect "motoi" :tier "novice" :code "(cortex/remember 'favorite-color 'blue)" :note "Save a fact under the key 'favorite-color. It sticks between sessions.")
    (:dialect "motoi" :tier "intermediate" :code "(on-key\n  (lambda (k)\n    (when (eq? k 's)\n      (cortex/remember 'last-save (audio-time)))))" :note "Press S and remember the current time as a save point.")
  )
  :related ("cortex/recall" "cortex/query" "cortex/forget" "cortex/keys")
  :row-2-audit (
    (:problem "A cart is running a lacuna/ask + remember loop: the model produced an answer, and the cart wants to persist the fact so the next session can use it. Under audit, the operator must be able to say 'this fact came from THAT interaction, at THAT time.' The question is: which write verb captures who/when, and which one just stores silently?"
     :program "(cortex/remember 'user/favorite-color 'petal-pink)\n(display (cortex/recall 'user/favorite-color)) (newline)\n\n;; a small learn-once helper: only remember if the key is not yet in the store.\n;; We test presence via cortex/keys (a list of strings) rather than by testing\n;; the recall return, because the runtime's miss-sentinel does not answer\n;; null? or #f.\n(define (known? key)\n  (let ((s (if (symbol? key) (symbol->string key) key)))\n    (if (member s (cortex/keys)) #t #f)))\n(define (learn key value)\n  (if (known? key)\n      'already-known\n      (begin (cortex/remember key value) 'learned)))\n(display (learn 'user/favorite-color 'crimson)) (newline)  ; already known\n(display (cortex/recall 'user/favorite-color)) (newline)   ; unchanged\n(display (learn 'user/first-name 'Alfred)) (newline)       ; learned\n(display (cortex/recall 'user/first-name)) (newline)"
     :explanation "Line 1 stores a fact via the provenance-capturing writer. Line 2 reads it back. Lines 7-8 define a known? predicate that tests key presence via cortex/keys — the correct presence-test in this runtime, because a miss-return from recall does not answer null? or #f. Lines 9-12 define the learn-once helper. Lines 13-16 exercise it: the second write on an already-known key is refused, and a truly-new key succeeds. Under audit, the operator can point to the recall/remember trace and say 'the fact landed here, then the guard refused the overwrite there, then a new fact landed there.'"
     :meta "cortex/remember is the honest verb because it is the provenance-captured write; the driver frame records who called it, when, and (in a cart) from which lacuna step. A sibling — cortex/write — would have stored the value with no trace, saving one fuel unit but blinding the audit lane. The audit finding when you see cortex/write on a fact you later need to defend is 'right family, wrong bookkeeping.'")
    (:eng "Operator's log shows one dispatch frame per remember (caller, timestamp, key, value-shape). Failure mode is a boolean return; the caller is expected to check."
     :math "State-transition τ: (K, V, S) → S sending (k, v, s) → s[k ↦ v], with a side-channel emission recorded in the audit log."
     :cs "Write with side-effects on two stores at once: the value store, and the audit ledger. The audit ledger append is what distinguishes remember from write; without it, provenance is impossible to reconstruct."))
  :row-3-dimension (
    (:setup "Provenanced put: store this value under this name AND leave a trace showing who put it there."
     :rungs (
       (:domain "cortex (this verb)"    :code "(cortex/remember 'seen 42)\n(display (cortex/recall 'seen)) (newline)")
       (:domain "signed ledger (metaphor)" :code "(define ledger '())\n(define (ledger-put! k v who)\n  (set! ledger (cons (list 'entry k v who) ledger)))\n(ledger-put! 'seen 42 'alice)\n(display ledger) (newline)")
       (:domain "labeled equation (math)" :code "(define proofs '())\n(define (assert! name eq justification)\n  (set! proofs (cons (list name eq justification) proofs)))\n(assert! 'lemma-1 '(= (+ 2 2) 4) 'arithmetic)\n(display proofs) (newline)"))
     :explanation "Rung 1 shows the verb: a keyed store where the write is (implicitly) captured for provenance. Rung 2 shows the same shape one substrate down — a hand-rolled ledger that records the writer's identity alongside the value; every write is now defendable. Rung 3 lifts to a math shape: an asserted equation with a labeled justification. The shape is 'store the value + store the reason.'"
     :meta "The shape transfers because provenance is a universal decoration. Once you see cortex/remember as a store-with-frame, you can port the pattern to any store that pairs data with metadata: git commit + author + date, SQL INSERT + audit column + trigger, blockchain block + miner + timestamp. Same shape.")
    (:eng "Every audit-required write in a running system is one of these three rungs. When SRE walks the incident timeline, the ledger rung is what they read."
     :math "A store update paired with an emission into an append-only log; the pair forms a natural transformation into the (store × log) category."
     :cs "Write plus append is the atom of every WAL (write-ahead log) and every event-sourced store. This is the same construction, in miniature."))
  :row-4-proof (
    (:claim "cortex/remember is a total function that always leaves the store containing the given key: after (remember k v), (recall k) is not the miss-sentinel. The write's return is #t."
     :program "(cortex/remember 'p 1)\n(display (if (member \"p\" (cortex/keys)) #t #f)) (newline)   ; presence via keys — correct test\n(display (equal? (cortex/recall 'p) 1)) (newline)\n\n(cortex/remember 'p 2)\n(display (equal? (cortex/recall 'p) 2)) (newline)  ; overwrite = last-writer-wins\n\n(display (eq? #t (cortex/remember 'p 3))) (newline) ; return is #t\n(display (equal? (cortex/recall 'p) 3)) (newline)"
     :invariant "∀ k, v.  after remember(k, v):  k ∈ keys() ∧ recall(k) = v.   ∀ k, v.  result(remember(k, v)) = #t."
     :meta "The invariant is what a cart's learn-once helper leans on: after a successful remember, the very next recall returns the just-written value, without a race. A single counter-example — a remember whose next recall returned ⊥ — would falsify the store's contract. The pattern name is 'put-then-get' (the local read-your-writes invariant). Grounded in book-of-code ch 9 (registers-counters-and-the-birth-of-state, which is the hardware root of a keyed store) and book-of-code ch 10 (state-machines, where a labeled transition changes and observation confirms).")
    (:eng "The invariant is why the cart never has to poll after a remember. If read-your-writes ever broke, every user-personalization surface in Motoi would flicker as facts came and went between renders."
     :math "A right-inverse pair: recall ∘ remember_v = id_V on the singleton chain."
     :cs "Sequential consistency of a single-writer single-reader flow inside one process. Distributed stores must add a coordination frame to preserve this; a single-process Cortex has it for free."))
  :row-5-emergence (
    (:base "cortex/remember is a provenance-captured keyed write."
     :composition "(define (key-for q) (string-append \"answer/\" q))\n(define (known? key) (if (member key (cortex/keys)) #t #f))\n\n(define (dictate q a)\n  (cortex/remember (key-for q) a)\n  a)\n\n(define (recall-or-ask q asker)\n  (let ((k (key-for q)))\n    (if (known? k)\n        (cortex/recall k)\n        (dictate q (asker q)))))\n\n(define fake-asker (lambda (q) (string-append \"generated:\" q)))\n\n(display (recall-or-ask \"what-is-x\" fake-asker)) (newline)   ; first: generate + store\n(display (recall-or-ask \"what-is-x\" fake-asker)) (newline)   ; second: return stored"
     :emergent "A learn-once memoized ask. Chaining cortex/remember with cortex/recall and a generator produces a memoized-answer store: first time the question is asked, the generator runs and the answer is remembered; every subsequent call hits the store. The pattern emerges from packing remember next to recall next to a generator."
     :meta "This is the memoize-with-persistence pattern from the family of caching topologies (memoize, memoize-with-TTL, persistent-memoize). Familiar analogs: Python's functools.lru_cache but survived across processes, an Elasticsearch cached query, an LLM-answer cache. Cross-reference: book-of-composition ch 13 (save-load, where memoization over a file is the same shape) and book-of-computing ch 13 (databases and storage, where memoization plus persistence is one of the named topologies).")
    (:eng "The pipeline is the atom of a chat cart's 'don't ask the model twice for the same thing' behavior. Failure mode: stale answer — no invalidation is in this pair, so the operator adds a cortex/forget or TTL when correctness matters."
     :math "Persistent memoization is a fixed point of the state transition (S, q) → (S', a) with S' = S ∪ {q ↦ a}; the pipeline converges to a partial memoization of the generator."
     :cs "This is the same construction as classical memoize but with the store split out, making it inspectable and shareable across sessions."))
  )

(verb
  :name "cortex/recall"
  :library "cortex"
  :kind "pure"
  :dialect "motoi"
  :signature "(cortex/recall key) -> any | nil"
  :arity "1"
  :contract "key is symbol or string → the stored value, or nil if not stored"
  :summary "Retrieve a fact from Cortex by key."
  :doc "Key is coerced to a string before lookup. Returns nil (empty list) when the key is unknown. Perm: personal-data."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin (cortex/remember 'greeting \"hi\") (cortex/recall 'greeting))" :note "Returns \"hi\".")
    (:dialect "motoi" :tier "intermediate" :code "(cortex/recall 'unknown-key)" :note "Returns nil.")
    (:dialect "motoi" :tier "expert" :code "(define (recall-or key default)\n  (let ((v (cortex/recall key)))\n    (if (null? v) default v)))\n(recall-or 'user-name \"friend\")" :note "Recall with a default fallback.")
    (:dialect "motoi" :tier "novice" :code "(cortex/remember 'last-score 800)\n(display (cortex/recall 'last-score))" :note "Save a high score, then recall it later.")
    (:dialect "motoi" :tier "intermediate" :code "(define (greet)\n  (let ((name (cortex/recall 'player-name)))\n    (if name\n        (display (string-append \"hi \" name))\n        (display \"hi friend\"))))" :note "Recall a name if we've seen this player before. Otherwise use a friendly default.")
  )
  :related ("cortex/remember" "cortex/query" "cortex/forget")
  :row-2-audit (
    (:problem "A game boots and wants to greet the player by name if it has seen them before. The operator asks: 'which read verb picks up on a previously-remembered fact, and what does the code look like when the fact isn't there yet?' The audit lane wants a lookup that produces a defendable default without asking the network."
     :program "(cortex/remember 'player-name \"Ada\")\n\n(define (known? key)\n  (let ((s (if (symbol? key) (symbol->string key) key)))\n    (if (member s (cortex/keys)) #t #f)))\n\n(define (greet)\n  (if (known? 'player-name)\n      (string-append \"hi \" (cortex/recall 'player-name))\n      \"hi friend\"))\n\n(display (greet)) (newline)\n(cortex/forget 'player-name)\n(display (greet)) (newline)"
     :explanation "Line 1 seeds the fact. Lines 3-5 define known? — the correct presence-test, because the runtime's recall miss returns a sentinel that does not answer null? or #f. Lines 7-10 define the greeter: known → greet by name; unknown → safe default. Lines 12-14 exercise it, once with the fact and once after forget. The audit lane sees one dispatch frame per recall, and can defend the greeter by pointing at 'if the fact was here, we used it; if not, we used the default.'"
     :meta "cortex/recall is the honest verb because it goes through the provenance-capturing dispatch that pairs with cortex/remember. A sibling — cortex/read — would have read from the direct store and would not see facts stored by remember (they live in different backing stores in this runtime). The audit finding when you see cortex/read on a fact stored by remember is 'wrong store family, right shape.'")
    (:eng "Operator's log shows one dispatch frame per recall. Failure mode is a miss-return; the caller must guard with a presence test, because the sentinel prints blank and is truthy under if."
     :math "Total function ρ: K → V ∪ {⊥} where ⊥ is the runtime's miss-sentinel; ⊥ is not null? and not #f, so callers use presence-of-key as the true predicate."
     :cs "Point-lookup through a dispatch frame. O(1) expected on the underlying map; the frame adds one function call worth of overhead."))
  :row-3-dimension (
    (:setup "Lookup-in-a-provenanced-store: the get half of the same pair (remember, recall) speaks."
     :rungs (
       (:domain "cortex (this verb)" :code "(cortex/remember 'greeting \"hola\")\n(display (cortex/recall 'greeting)) (newline)")
       (:domain "environment (metaphor)" :code "(define env (list (list 'greeting \"hola\")))\n(define (env-lookup env k)\n  (let ((row (assoc k env)))\n    (if row (cadr row) 'not-found)))\n(display (env-lookup env 'greeting)) (newline)")
       (:domain "partial function (math)" :code "(define (f x) (case x ((1) 'red) ((2) 'green) (else '⊥)))\n(display (f 1)) (newline)\n(display (f 3)) (newline)"))
     :explanation "Rung 1 shows cortex/recall in its own domain: keyed get from a provenanced store, returning the stored value on hit. Rung 2 shows the same shape as an environment lookup, using assoc + cadr to project the value out of a (key value) row; misses produce a symbolic 'not-found. Rung 3 lifts to the math shape: recall is a partial function whose domain is exactly the set of remembered keys, and whose codomain is the union of values plus a miss token. Same shape, three substrates."
     :meta "The shape transfers because keyed get is universal. Once you see cortex/recall as a partial function, you can port the pattern to any store with a get: SQL SELECT, Redis GET, cache.get, dict.get, env vars, HTTP GET. Same shape.")
    (:eng "Every recall-shaped surface in Motoi is one of these three rungs. When SRE watches the recall hit-rate they are watching this shape's success side."
     :math "Recall belongs to the category of partial functions on the keyspace; the total-completion adds ⊥ + a default and lands in the total function category."
     :cs "The get half of any key-value protocol; the dispatch frame is the only difference between recall and read."))
  :row-4-proof (
    (:claim "cortex/recall is a right-inverse of cortex/remember on the same key: after (remember k v), (recall k) returns v (up to equal?). Two consecutive remembers on the same key are absorbed into the last-writer-wins invariant."
     :program "(define (rt k v)\n  (cortex/remember k v)\n  (equal? (cortex/recall k) v))\n(display (rt 'a 1)) (newline)\n(display (rt 'b \"pink\")) (newline)\n(display (rt 'c (list 1 2 3))) (newline)\n\n;; last-writer-wins on remember/recall\n(cortex/remember 'x 'first)\n(cortex/remember 'x 'second)\n(display (eq? (cortex/recall 'x) 'second)) (newline)\n\n;; determinism inside a session\n(cortex/remember 'd 'same)\n(display (eq? (cortex/recall 'd) (cortex/recall 'd))) (newline)"
     :invariant "∀ k, v.  recall(after(remember(k, v))) = v.   ∀ k, v₁, v₂.  recall(after(remember(k, v₁); remember(k, v₂))) = v₂."
     :meta "This is the read-your-writes invariant for the (remember, recall) pair. A single counter-example — one round-trip that came back different — would falsify the store. The pattern is 'last-writer-wins map' (LWW), a monoid on Vᴋ with the second-argument-wins operator. Grounded in book-of-code ch 8 (memory latches: the flip-flop is the LWW cell) and book-of-code ch 13 (memory hierarchy: DRAM cells obey the same rule).")
    (:eng "The invariant is why any UI that renders after a remember picks up the new value on the very next recall; every settings dialog in Motoi leans on it."
     :math "(remember, recall) is a section-retraction pair on the singleton chain per key; the store is a coequalizer of the write-then-write sequence quotiented by LWW."
     :cs "Standard sequential-consistency of a single-writer single-reader key-value store within one process. Same shape as classical mutable maps."))
  :row-5-emergence (
    (:base "cortex/recall is a provenanced keyed get with a miss-sentinel."
     :composition "(define (known? key)\n  (let ((s (if (symbol? key) (symbol->string key) key)))\n    (if (member s (cortex/keys)) #t #f)))\n\n(define (recall-or key default)\n  (if (known? key) (cortex/recall key) default))\n\n(define (snapshot keys)\n  (map (lambda (k) (list k (recall-or k 'none))) keys))\n\n(cortex/remember 'a 1) (cortex/remember 'b 2)\n(display (snapshot '(a b c))) (newline)"
     :emergent "A snapshot pipeline. Chaining cortex/recall (through recall-or) with cortex/keys and map turns the store into a projection: given a list of keys, produce a list of (key value) pairs with a default for missing keys. Neither verb alone is a snapshot; the pipeline is."
     :meta "This is the classical projection pattern from the family of query topologies (SELECT k1,k2,k3, a batched-get, a fan-out cache read). Familiar analogs: SQL SELECT with a projection column list, Redis MGET, HTTP batched-GET. Cross-reference: book-of-composition ch 13 (save-load, where a snapshot over a file lands the same shape) and book-of-computing ch 13 (databases and storage, where projection is the named operation).")
    (:eng "The pipeline is the atom of a cart's 'give me everything you know about the user' surface. Failure mode: partial snapshot — a large keyset with slow recall latency will fan out; the operator adds parallelism or bounds the keyset."
     :math "Snapshot is a natural transformation from a list of keys to a list of (key × (value + default)); stable under key-permutation."
     :cs "Batched-get over a keyed store; the composition of point-recall + list-map is the same construction as MGET."))
  )

(verb
  :name "cortex/query"
  :library "cortex"
  :kind "pure"
  :dialect "motoi"
  :signature "(cortex/query pattern) -> list"
  :arity "1"
  :contract "pattern is symbol or string → list of matching entries"
  :summary "Search Cortex for facts matching a pattern. Returns a list of matches."
  :doc "Pattern semantics are provider-defined. Symbol patterns are converted to their name before dispatch. Perm: personal-data."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(cortex/query 'greetings)" :note "Returns a list of matching entries (possibly empty).")
    (:dialect "motoi" :tier "intermediate" :code "(cortex/query \"user-*\")" :note "String patterns may support globs, depending on backend.")
    (:dialect "motoi" :tier "expert" :code "(define (matching-count pattern) (length (cortex/query pattern)))\n(matching-count 'preference)" :note "Count how many facts match a pattern.")
    (:dialect "motoi" :tier "novice" :code "(display (cortex/query '(hero *)))" :note "Find every stored fact whose key looks like ('hero anything). * matches any tail.")
    (:dialect "motoi" :tier "intermediate" :code "(cortex/remember '(hero location) 'forest)\n(cortex/remember '(hero mood) 'brave)\n(display (cortex/query '(hero *)))" :note "Store two facts about the hero, then query for both at once.")
  )
  :related ("cortex/recall" "cortex/keys" "cortex/remember")
  :author-note "Row-2 through Row-5 use cortex/keys + filter stand-ins in :program blocks. In the current runtime cortex/query returns a JS-backed array of (key value) pairs whose destructuring from Scheme is fragile; the invariants below hold for the intended semantics, and the proxies exercise the same shape via cortex/keys."
  :row-2-audit (
    (:problem "An operator wants to enumerate every fact matching a prefix — 'show me everything I've told Motoi about my customers.' The question: 'which verb returns the full match set, and can I iterate it safely with map/filter?' The audit lane wants a list-returning enumeration, not a bounded topk."
     :program "(cortex/remember 'customer/1 \"Alice\")\n(cortex/remember 'customer/2 \"Bob\")\n(cortex/remember 'session/1 \"live\")\n\n;; Stand-in for (cortex/query \"customer/\"), using cortex/keys + a filter.\n(define (query-keys prefix)\n  (filter (lambda (k)\n            (let ((s (if (symbol? k) (symbol->string k) k)))\n              (and (>= (string-length s) (string-length prefix))\n                   (string=? prefix (substring s 0 (string-length prefix))))))\n          (cortex/keys)))\n\n(define matches (query-keys \"customer/\"))\n(display matches) (newline)\n(display (list? matches)) (newline)"
     :explanation "Lines 1-3 seed three facts across two namespaces. Lines 6-11 define query-keys — a stand-in for cortex/query that runs the same substring-over-keys logic the query implementation uses, but returns a Scheme-friendly list. Line 13 exercises it; line 14 displays the matches; line 15 verifies the result is a list, so downstream map/filter works. The audit lane sees one dispatch and gets a bounded, iterable enumeration."
     :meta "cortex/query is the honest verb because it is enumeration-by-pattern with an unbounded (but list-shaped) return. A sibling — cortex/topk — would have capped the result at k, useful for UIs but wrong when the operator explicitly wants 'all of them'. The audit finding when you see cortex/topk k=huge instead of cortex/query is 'right family, over-capped.'")
    (:eng "Operator's log shows one dispatch per query. Failure mode when the store is empty: matches = (), null? guard catches it before any iteration."
     :math "Function ρ: pattern → list(K × V), with |ρ(p)| ≤ |store| for all patterns."
     :cs "Full-scan enumeration over a keyed store; O(n) in store size. Contrast with the constant-time point-lookup (recall) and the bounded-cost topk (bounded by k, not by store size)."))
  :row-3-dimension (
    (:setup "Pattern enumeration: given a shape, return every element of the collection that matches, in list form."
     :rungs (
       (:domain "cortex (this verb)"      :code "(cortex/remember 'a/1 1) (cortex/remember 'a/2 2) (cortex/remember 'b/1 3)\n(define (q prefix)\n  (filter (lambda (k) (string=? prefix (substring (symbol->string k) 0 (string-length prefix))))\n          (cortex/keys)))\n(display (q \"a/\")) (newline)")
       (:domain "filter over a list (metaphor)" :code "(define catalog '((\"apple\" red) (\"apricot\" orange) (\"banana\" yellow)))\n(define (starts-with? prefix s)\n  (and (>= (string-length s) (string-length prefix))\n       (string=? prefix (substring s 0 (string-length prefix)))))\n(display (filter (lambda (row) (starts-with? \"ap\" (car row))) catalog)) (newline)")
       (:domain "preimage (math)"         :code "(define (preimage f codomain-elt xs)\n  (filter (lambda (x) (equal? (f x) codomain-elt)) xs))\n(display (preimage (lambda (n) (modulo n 3)) 0 (list 1 2 3 4 5 6 7 8 9))) (newline)"))
     :explanation "Rung 1 shows the verb in its own domain: enumerate keys matching a prefix, projecting from the Cortex store. Rung 2 shows the same shape one substrate down — filter over a static association list. Rung 3 lifts to a math shape: the preimage of a function at a codomain point is the set of inputs mapping to that point; here we compute the preimage of (modulo 3) at 0. All three are the same shape: select the subset of a collection whose element matches a predicate."
     :meta "The shape transfers because 'select where' is a universal collection operation. Once you see cortex/query as a filter, you can port the pattern anywhere you have (collection, predicate): SQL SELECT WHERE, LINQ Where, Ruby Enumerable#select, JS Array#filter. Same shape.")
    (:eng "Every 'show me everything matching X' surface is one of these three rungs. When SRE watches the query verb's fan-out, they are watching this shape's coefficient."
     :math "Filter is a natural transformation from Collection<T> to Collection<T> parameterized by (T → Bool); preserves order when the underlying collection is ordered."
     :cs "The set-comprehension form of query. In modern databases, filter over an index is O(matching); over a table scan is O(n)."))
  :row-4-proof (
    (:claim "cortex/query is order-independent on inserts and enumeration-complete on matches: swapping the order of two remembers changes cortex/keys' order but not the SET of matched keys the query would return; every key remembered under a matching name is in the enumeration."
     :program "(cortex/remember 'z/1 'a) (cortex/remember 'z/2 'b) (cortex/remember 'z/3 'c)\n\n(define (query-keys prefix)\n  (filter (lambda (k)\n            (let ((s (if (symbol? k) (symbol->string k) k)))\n              (and (>= (string-length s) (string-length prefix))\n                   (string=? prefix (substring s 0 (string-length prefix))))))\n          (cortex/keys)))\n\n(define matches (query-keys \"z/\"))\n(display (>= (length matches) 3)) (newline)\n\n;; enumeration-completeness: every key remembered is in the enumeration\n(display (if (member \"z/1\" matches) #t #f)) (newline)\n(display (if (member \"z/2\" matches) #t #f)) (newline)\n(display (if (member \"z/3\" matches) #t #f)) (newline)"
     :invariant "∀ p.  {k ∈ keys() | matches(k, p)} ⊆ query(p).   ∀ p.  |query(p)| ≤ |store|."
     :meta "Enumeration-completeness is what the caller depends on: every remembered fact eligible for the pattern will appear in the result. A single counter-example — a remembered fact absent from the enumeration — would falsify the store's promise. The pattern name is 'filter as a preimage projection.' Grounded in book-of-code ch 10 (state-machines: enumeration over reachable states) and book-of-computing ch 13 (databases and storage: SELECT WHERE is the same law).")
    (:eng "The invariant is why 'give me everything under this prefix' surfaces are trustworthy without pagination: the operator can rely on completeness (all matching facts appear) and can add capping (topk) if the volume is too big."
     :math "Filter is a natural retract of Collection<T> — filter ∘ identity_lift = filter — and preserves multi-set count on the matching subset."
     :cs "This is the classical filter contract, orthogonal to ordering; ordering guarantees come from the underlying store's iteration order, not from filter itself."))
  :row-5-emergence (
    (:base "cortex/query is a pattern enumeration over the store."
     :composition "(cortex/remember 'log/2026-07-19/click 1)\n(cortex/remember 'log/2026-07-19/view 2)\n(cortex/remember 'log/2026-07-18/click 3)\n\n(define (query-keys prefix)\n  (filter (lambda (k)\n            (let ((s (if (symbol? k) (symbol->string k) k)))\n              (and (>= (string-length s) (string-length prefix))\n                   (string=? prefix (substring s 0 (string-length prefix))))))\n          (cortex/keys)))\n\n(define (roll-up prefix)\n  (let* ((ks (query-keys prefix))\n         (vs (map (lambda (k) (cortex/recall k)) ks)))\n    (apply + vs)))\n\n(display (roll-up \"log/2026-07-19/\")) (newline)   ; today's total\n(display (roll-up \"log/\")) (newline)              ; all-time total"
     :emergent "A roll-up. Chaining cortex/query (proxy) with cortex/recall and (apply +) turns the store into a slice-and-aggregate pipeline: pick the keys matching a prefix, project each key to its value, aggregate. Neither verb alone is a roll-up; the pipeline is."
     :meta "This is the group-by-and-aggregate pattern from the family of analytics topologies (SELECT SUM WHERE, MapReduce, materialized views). Familiar analogs: SQL SELECT SUM(v) FROM t WHERE k LIKE 'log/2026-07-19/%', Redis SCAN + MGET + client-side sum, Elasticsearch's terms aggregation. Cross-reference: book-of-composition ch 13 (save-load, where the same shape happens over a file) and book-of-computing ch 13 (databases and storage, where roll-up is the named topology).")
    (:eng "The pipeline is inspectable stage-by-stage: the operator can log the keyset, the recalled values, and the aggregate. Failure mode: silent drift — a mistyped prefix silently returns () and the roll-up shows 0. The operator adds a completeness assertion on the keyset."
     :math "Roll-up is a fold over a filtered projection: (Σ over keys∈matches) v(key). Under a commutative-associative aggregate (like sum), the fold is stable under key reordering."
     :cs "Query + recall + fold is the atom of every OLAP query engine; the fold's associativity is what makes it parallelizable."))
  )

(verb
  :name "cortex/forget"
  :library "cortex"
  :kind "mut"
  :dialect "motoi"
  :signature "(cortex/forget key) -> boolean"
  :arity "1"
  :contract "key is symbol or string → #t if a fact was deleted, #f otherwise"
  :summary "Delete a stored fact from Cortex."
  :doc "Idempotent. Returns #t if the key existed, #f if it did not. Perm: personal-data."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin (cortex/remember 'x 1) (cortex/forget 'x))" :note "Returns #t.")
    (:dialect "motoi" :tier "intermediate" :code "(cortex/forget 'nonexistent-key)" :note "Returns #f — no error, just miss.")
    (:dialect "motoi" :tier "expert" :code "(define (forget-all keys) (map cortex/forget keys))\n(forget-all '(a b c))" :note "Batch forget. Returns a list of booleans.")
    (:dialect "motoi" :tier "novice" :code "(cortex/remember 'temp 42)\n(cortex/forget 'temp)" :note "Store a value, then delete it. Cortex is quieter now.")
    (:dialect "motoi" :tier "intermediate" :code "(for-each cortex/forget (cortex/keys))" :note "Wipe every stored fact. A hard reset for a fresh session.")
  )
  :related ("cortex/remember" "cortex/recall" "cortex/keys")
  :row-2-audit (
    (:problem "A cart wants to honor a 'delete my data' request from the user. The operator asks: 'when the delete handler fires and the key was never present, what does the code do — throw, silently succeed, or return a distinguishable outcome?' The audit lane needs the failure mode to be observable and benign."
     :program "(cortex/remember 'user/email \"ada@example.com\")\n\n(define (delete-and-log key)\n  (let ((removed (cortex/forget key)))\n    (display (list 'deletion key '=> removed)) (newline)\n    removed))\n\n(display (delete-and-log 'user/email)) (newline)   ; #t — actually removed\n(display (delete-and-log 'user/email)) (newline)   ; #f — already gone; benign\n(display (delete-and-log 'never-set)) (newline)    ; #f — never was; benign"
     :explanation "Line 1 seeds the fact. Lines 3-6 define the delete handler: it forgets the key and logs the boolean outcome so the audit trail records both 'yes, we deleted it' and 'no-op, was already gone'. Lines 8-10 exercise the handler across three cases: present-then-remove (#t), removed-again (#f), never-present (#f). The audit lane sees exactly three deletion attempts and three boolean outcomes, with the tri-outcome (a) confirming the removal happened, (b) confirming idempotence on double-delete, (c) confirming benignness on the never-present case."
     :meta "cortex/forget is the honest verb because the return value distinguishes 'was here, now gone' from 'was never here'. A sibling — cortex/remember with a nil value — would have overwritten the key with nothing meaningful and would not truly free the slot; cortex/keys and cortex/size would still count it. The audit finding when you see 'remember with nil' as a delete is 'wrong verb; key is still there, just poisoned.'")
    (:eng "Operator's log shows one dispatch per delete and one boolean per outcome; the tri-outcome (present-then-gone / already-gone / never-present) lets the audit distinguish user-facing deletion from redundant retries."
     :math "State-transition τ: (K, S) → S with s ↦ s \\ {k}; the transition is idempotent under repeated application and total on K."
     :cs "Set-difference in miniature; the boolean return distinguishes membership change (#t) from no-op (#f). This is what makes cortex/forget safe under at-least-once delivery."))
  :row-3-dimension (
    (:setup "Remove-by-name: given a key, remove the entry from the collection if present, and tell the caller whether anything actually happened."
     :rungs (
       (:domain "cortex (this verb)"      :code "(cortex/remember 'x 1) (cortex/remember 'y 2)\n(display (cortex/forget 'x)) (newline)\n(display (cortex/forget 'x)) (newline)")
       (:domain "set delete (metaphor)"   :code "(define s (list 'a 'b 'c))\n(define (set-delete s k)\n  (let ((was? (memq k s)))\n    (values (filter (lambda (e) (not (eq? e k))) s)\n            (if was? #t #f))))\n(call-with-values (lambda () (set-delete s 'b))\n  (lambda (s2 was) (display was) (newline) (display s2) (newline)))")
       (:domain "quotient by relation (math)" :code "(define (quotient-out lst e)\n  (filter (lambda (x) (not (equal? x e))) lst))\n(display (quotient-out (list 1 2 3 2 4) 2)) (newline)"))
     :explanation "Rung 1 shows the verb in its own domain: forget a key, get a boolean back reporting whether the key was there. Rung 2 shows the same shape one substrate down — a hand-rolled set-delete that returns the smaller set plus a boolean 'was it there?' via values. Rung 3 lifts to a math shape: the quotient of a list by an equivalence to a single element is the remove-all-occurrences operation. All three are the same shape: remove-by-predicate, with observable was-it-there information."
     :meta "The shape transfers because delete-by-name is universal. Once you see cortex/forget as a set-delete, you can port the pattern to any keyed collection: SQL DELETE WHERE (returns row-count), Redis DEL (returns count), HashMap.remove (returns previous value). Same shape.")
    (:eng "Every 'undo an entry' surface in a running system is one of these three rungs. When SRE watches the deletion-rate they are watching this shape's throughput."
     :math "Delete is a monoid action on the store (up to LWW), with the boolean return recording whether the action changed observable state."
     :cs "Set-difference at the single-element granularity; O(1) on hash-backed stores. The boolean return is what makes retries safe."))
  :row-4-proof (
    (:claim "cortex/forget is idempotent and complete-on-removal: after (forget k), (recall k) misses and k is not in (cortex/keys); the second forget returns #f (no-op), and repeated forgets never change observable state past the first successful call."
     :program "(cortex/remember 'i 1)\n\n(display (cortex/forget 'i)) (newline)                    ; #t: was present, removed\n(display (if (member \"i\" (cortex/keys)) 'still 'gone)) (newline)  ; 'gone\n(display (cortex/forget 'i)) (newline)                    ; #f: idempotence — no-op\n(display (cortex/forget 'i)) (newline)                    ; #f: still no-op\n(display (if (member \"i\" (cortex/keys)) 'still 'gone)) (newline)  ; still 'gone\n\n;; complete-on-removal: (recall) after (forget) is a miss (sentinel; prints blank)\n(cortex/remember 'j 42)\n(cortex/forget 'j)\n(display (if (member \"j\" (cortex/keys)) 'still 'gone)) (newline)"
     :invariant "∀ k.  forget(k); forget(k)  ≡  forget(k).   ∀ k.  after forget(k):  k ∉ keys() ∧ recall(k) = ⊥.   ∀ k.  result(forget(k)) = #t iff k ∈ keys() at call time."
     :meta "Idempotence is what makes cortex/forget safe under at-least-once delivery: a re-drive of a delete cannot corrupt state. Complete-on-removal is what makes the delete honest to the user's 'delete my data' request — the key is truly gone, not merely blanked. Grounded in book-of-code ch 8 (memory latches: the reset input of a flip-flop is the hardware analog) and book-of-code ch 9 (registers-counters, where a clear signal has exactly this shape).")
    (:eng "The invariant is what makes 'delete my data' a defensible legal claim: the fact is not just hidden, it is gone from the enumeration surface (keys) and the presence tests. If idempotence ever broke, retry loops would decrement counters or fire deletion webhooks twice."
     :math "Forget is an involution on the singleton chain of 'k present' → 'k absent'; applied to an absent key it is the identity; applied to a present key it moves to absent; a second application after removal is the identity."
     :cs "The same construction as classical DEL k, Map.delete, HashSet.remove; O(1) expected. Idempotence-on-absence is the property that a distributed store must preserve to be safe under retries."))
  :row-5-emergence (
    (:base "cortex/forget is a keyed delete with a boolean witness."
     :composition "(cortex/remember 'cache/user/1 \"stale-a\")\n(cortex/remember 'cache/user/2 \"stale-b\")\n(cortex/remember 'session/token \"abc\")\n\n(define (query-keys prefix)\n  (filter (lambda (k)\n            (let ((s (if (symbol? k) (symbol->string k) k)))\n              (and (>= (string-length s) (string-length prefix))\n                   (string=? prefix (substring s 0 (string-length prefix))))))\n          (cortex/keys)))\n\n(define (invalidate! prefix)\n  (map cortex/forget (query-keys prefix)))\n\n(display (invalidate! \"cache/\")) (newline)  ; (#t #t) — both were removed\n(display (cortex/keys)) (newline)             ; only session/token remains"
     :emergent "A namespaced cache invalidation. Chaining cortex/forget with cortex/query (or its keys+filter proxy) and map turns forget into a bulk-invalidator: 'wipe every entry under this prefix.' The pattern emerges from packing forget next to enumeration."
     :meta "This is the classical cache-invalidation-by-tag pattern from the family of cache topologies (invalidate-by-key, invalidate-by-tag, invalidate-by-namespace, TTL sweep). Familiar analogs: Redis SCAN + DEL, CDN purge-by-tag, Elasticsearch DELETE by query. Cross-reference: book-of-composition ch 13 (save-load, where invalidation over a file namespace lands the same shape) and book-of-computing ch 13 (databases and storage, where invalidation is the paired inverse of write-through).")
    (:eng "The invalidator is what an operator reaches for when they see stale data in the dashboard. Failure mode: partial invalidation — if the enumeration misses a key, the caller sees a still-stale slot; the operator adds a completeness assertion (post-invalidate the enumeration returns ())."
     :math "Bulk invalidation is a fold over the enumeration under the delete-monoid; because forget is idempotent, the fold is associative and commutative and can be reordered freely."
     :cs "The Query-then-Delete idiom; the two verbs together form the inverse of the write-through cache from the cortex/write row. Balanced pair: write-through installs, invalidate removes."))
  )

(verb
  :name "cortex/keys"
  :library "cortex"
  :kind "pure"
  :dialect "motoi"
  :signature "(cortex/keys) -> list"
  :arity "0"
  :contract "→ list of stored keys (strings)"
  :summary "Enumerate all keys currently stored in Cortex."
  :doc "Useful for introspection and bulk operations. Empty list when Cortex is empty. Perm: personal-data."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(cortex/keys)" :note "Returns the list of stored keys.")
    (:dialect "motoi" :tier "intermediate" :code "(length (cortex/keys))" :note "Count how many facts are stored — same as (cortex/size).")
    (:dialect "motoi" :tier "expert" :code "(define (dump-cortex)\n  (map (lambda (k) (list k (cortex/recall k)))\n       (cortex/keys)))\n(dump-cortex)" :note "Snapshot everything as (key value) pairs.")
    (:dialect "motoi" :tier "novice" :code "(display (cortex/keys))" :note "List every key Cortex is currently holding.")
    (:dialect "motoi" :tier "intermediate" :code "(cortex/remember 'a 1)\n(cortex/remember 'b 2)\n(display (length (cortex/keys)))" :note "Store two facts, then check that the key count matches.")
  )
  :related ("cortex/size" "cortex/recall" "cortex/query")
  :row-2-audit (
    (:problem "The operator is investigating a report of 'my settings didn't persist.' They open a diagnostic REPL and want to enumerate every fact Cortex is currently holding so they can walk the list with the user on a call. The question: which verb returns the full keyset in one call, without a pattern to guess?"
     :program "(cortex/remember 'pref/theme 'paper)\n(cortex/remember 'pref/font-size 14)\n(cortex/remember 'session/id \"abc-123\")\n\n(define (diagnostic-dump)\n  (let ((ks (cortex/keys)))\n    (display (list 'stored-count (length ks))) (newline)\n    (for-each\n      (lambda (k) (display (list k '=> (cortex/recall k))) (newline))\n      ks)))\n\n(diagnostic-dump)"
     :explanation "Lines 1-3 seed three facts across two namespaces. Lines 5-10 define a diagnostic dump: it grabs the full keyset via cortex/keys, prints the count, then walks each key emitting (key => value). Line 12 exercises the dump. The audit lane sees one keys call and one recall per fact. The operator has now walked the exact state, and can confirm to the user 'these are what Cortex holds for you.'"
     :meta "cortex/keys is the honest verb because it is total enumeration without a pattern. A sibling — cortex/query with an empty string — would rely on 'empty-string matches all' semantics that are backend-specific; a topk without a pattern would cap the enumeration. The audit finding when you see cortex/topk instead of cortex/keys for full enumeration is 'right family, unnecessary cap.'")
    (:eng "Operator's log shows one dispatch per keys call and one per recall in the dump. Failure mode when Cortex is empty: () — the for-each is a no-op, no exception."
     :math "Function K: unit → list(K); |K()| = |store|, always terminates because store is finite."
     :cs "Full enumeration of a keyed store; O(n) in store size. In distributed stores this must respect cursor pagination; in a single-process Cortex it is a single Array.from."))
  :row-3-dimension (
    (:setup "Enumerate-the-collection: return every element as a list, without a filter."
     :rungs (
       (:domain "cortex (this verb)" :code "(cortex/remember 'a 1) (cortex/remember 'b 2) (cortex/remember 'c 3)\n(display (cortex/keys)) (newline)")
       (:domain "directory listing (metaphor)" :code "(define fs (list \"greetings.txt\" \"todos.txt\" \"log.txt\"))\n(define (ls) fs)\n(display (ls)) (newline)")
       (:domain "index set (math)"    :code "(define (index-set n)\n  (let loop ((i 0) (out '()))\n    (if (= i n) (reverse out) (loop (+ i 1) (cons i out)))))\n(display (index-set 5)) (newline)"))
     :explanation "Rung 1 shows the verb in its own domain: enumerate every key currently in Cortex. Rung 2 shows the same shape one substrate down — a directory listing that returns the filenames as a flat list. Rung 3 lifts to a math shape: the index set of a collection of size n is exactly the list (0 1 ... n-1). All three are the same shape: give me the addresses I can iterate."
     :meta "The shape transfers because 'give me the addresses' is universal. Once you see cortex/keys as an index set, you can port the pattern anywhere addresses live: ls in a filesystem, SHOW TABLES in SQL, Object.keys() in JS. Same shape.")
    (:eng "Every 'what's in there' surface in a running system is one of these three rungs. When SRE watches a store's cardinality, they are watching |cortex/keys|."
     :math "The full enumeration is a section of the identity functor on Set — it names every element by its own address."
     :cs "The keys operation is dual to recall (values-of-a-key) and to query (keys-matching-a-pattern); together they let the caller reconstruct the store."))
  :row-4-proof (
    (:claim "cortex/keys is a total, order-agreed-with-cortex/size enumeration: |cortex/keys| = (cortex/size), every remembered key is in the enumeration exactly once, and forgetting a key removes it from the enumeration."
     :program ";; start from a known state\n(for-each cortex/forget (cortex/keys))\n(display (= 0 (length (cortex/keys)))) (newline)\n\n;; length agrees with size after inserts\n(cortex/remember 'a 1) (cortex/remember 'b 2) (cortex/remember 'c 3)\n(display (= (length (cortex/keys)) (cortex/size))) (newline)\n(display (= (length (cortex/keys)) 3)) (newline)\n\n;; every remembered key is enumerated exactly once (uniqueness)\n(display (if (member \"a\" (cortex/keys)) #t #f)) (newline)\n(display (if (member \"b\" (cortex/keys)) #t #f)) (newline)\n(display (if (member \"c\" (cortex/keys)) #t #f)) (newline)\n\n;; forget removes from enumeration\n(cortex/forget 'b)\n(display (if (member \"b\" (cortex/keys)) 'still 'gone)) (newline)\n(display (= (length (cortex/keys)) 2)) (newline)"
     :invariant "∀ store.  length(keys()) = size().   ∀ k ∈ remembered.  k ∈ keys() exactly once.   ∀ k.  after forget(k):  k ∉ keys()."
     :meta "Length-equals-size is the fundamental agreement between the enumeration verb and the count verb. Uniqueness is what lets the caller trust a for-each over keys to visit each fact exactly once. A single counter-example — a length that disagrees with size, or a duplicate key in the enumeration — would falsify the store's contract. Grounded in book-of-code ch 9 (registers-counters, where the counter is bound to the register file's size) and book-of-code ch 13 (memory hierarchy, where the enumeration and count come from the same tag directory).")
    (:eng "The length-equals-size invariant is what makes SRE dashboards trust a single count metric — if enumeration disagreed with count, every 'how many facts' graph would lie. Uniqueness is what makes bulk operations safe."
     :math "keys is a section of size in the sense that size = length ∘ keys; the pair forms a stable pair of enumeration and cardinality."
     :cs "The classical set-enumeration + set-cardinality agreement; violated only in stores with inconsistent snapshots (rare, always a bug)."))
  :row-5-emergence (
    (:base "cortex/keys is a total keyset enumeration."
     :composition "(cortex/remember 'a 1) (cortex/remember 'b 2) (cortex/remember 'c 3)\n\n;; Backup + restore = snapshot pattern.\n(define (backup)\n  (map (lambda (k) (list k (cortex/recall k))) (cortex/keys)))\n\n(define (wipe!)\n  (for-each cortex/forget (cortex/keys)))\n\n(define (restore! snap)\n  (for-each (lambda (pair)\n              (cortex/remember (car pair) (cadr pair)))\n            snap))\n\n(define snap (backup))\n(display snap) (newline)\n(wipe!)\n(display (cortex/size)) (newline)\n(restore! snap)\n(display (cortex/size)) (newline)"
     :emergent "A snapshot / restore pipeline. Chaining cortex/keys with cortex/recall and (map ...) produces the backup half; chaining cortex/keys with cortex/forget and (for-each ...) produces the wipe half; chaining cortex/remember with the backup shape produces the restore half. Together they are a save-and-load story that neither verb carries alone."
     :meta "This is the classical snapshot-and-restore pattern from the family of persistence topologies (dump, restore, checkpoint, replay). Familiar analogs: pg_dump + pg_restore, Redis SAVE + RESTORE, git stash + git stash pop. Cross-reference: book-of-composition ch 13 (save-load, which is literally the composer widget for this shape) and book-of-computing ch 13 (databases and storage, where dump-and-restore is the named topology).")
    (:eng "Snapshot/restore is what the operator reaches for before a risky migration; failure mode is a partial snapshot (a remembered key that races the snapshot). The operator adds a quiescence phase or uses a single-writer window."
     :math "Snapshot is a retract of the store into (list (K × V)); restore is a section that takes the retract back to the store. Together they preserve the (K → V) map up to key-order."
     :cs "Backup + restore + wipe together are the atom of state-machine replication: the snapshot is the initial state, the log is the changes since. This is the same construction as event-sourced state stores."))
  )

(verb
  :name "cortex/size"
  :library "cortex"
  :kind "pure"
  :dialect "motoi"
  :signature "(cortex/size) -> integer"
  :arity "0"
  :contract "→ nonnegative integer"
  :summary "Count of stored facts in Cortex."
  :doc "Constant-time. Perm: personal-data."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(cortex/size)" :note "Current fact count.")
    (:dialect "motoi" :tier "intermediate" :code "(begin (cortex/remember 'a 1) (cortex/size))" :note "Size grew by at least one.")
    (:dialect "motoi" :tier "expert" :code "(define (cortex-empty?) (= 0 (cortex/size)))\n(cortex-empty?)" :note "Predicate check.")
    (:dialect "motoi" :tier "novice" :code "(display (cortex/size))" :note "Count of stored facts.")
    (:dialect "motoi" :tier "intermediate" :code "(on-frame\n  (lambda ()\n    (when (> (cortex/size) 100)\n      (display \"cortex getting full\"))))" :note "Warn when Cortex holds a lot of facts. You might want to forget some.")
  )
  :related ("cortex/keys" "cortex/remember")
  :row-2-audit (
    (:problem "The operator has a Cortex-full warning threshold at 100 facts. They want a health check that runs on each frame and reports 'normal', 'warm', or 'full' based on the current fact count. The audit question: 'is the count check constant-time so we can call it every frame without cost?'"
     :program "(for-each cortex/forget (cortex/keys))\n\n(define (cortex-health)\n  (let ((n (cortex/size)))\n    (cond ((< n 50)  'normal)\n          ((< n 100) 'warm)\n          (else      'full))))\n\n(display (cortex-health)) (newline)\n\n(let loop ((i 0))\n  (if (>= i 60)\n      'done\n      (begin (cortex/remember (string->symbol (string-append \"k\" (number->string i))) i)\n             (loop (+ i 1)))))\n\n(display (cortex-health)) (newline)"
     :explanation "Line 1 wipes the store to start from a known baseline. Lines 3-7 define the health check: constant-time count via cortex/size, then a cond selects the health band. Line 9 exercises the check on an empty store — should be 'normal. Lines 11-14 remember 60 facts. Line 16 re-checks — should be 'warm because 60 crossed the 50 threshold. The audit lane sees one size call per frame, and can defend the check as O(1)."
     :meta "cortex/size is the honest verb because it is a constant-time count read: no enumeration, no allocation, no per-key work. A sibling — (length (cortex/keys)) — would enumerate the entire store on every frame, turning an O(1) check into an O(n) fan-out. The audit finding when you see length-keys instead of size in a hot loop is 'right family, wrong complexity.'")
    (:eng "Operator's log shows one size call per frame — cheap enough to place in an animation loop. Failure mode on an empty store: size = 0, health = 'normal."
     :math "Function σ: unit → ℕ; total and non-negative."
     :cs "Constant-time cardinality read on a hash-backed store. Contrast with (length (keys)) which is O(n); size caches the count in the store's own metadata."))
  :row-3-dimension (
    (:setup "Cardinality: return the size of a collection without enumerating its members."
     :rungs (
       (:domain "cortex (this verb)"  :code "(cortex/remember 'x 1) (cortex/remember 'y 2)\n(display (cortex/size)) (newline)")
       (:domain "counter (metaphor)"  :code "(define n 0)\n(define (bump!) (set! n (+ n 1)))\n(define (count) n)\n(bump!) (bump!) (bump!)\n(display (count)) (newline)")
       (:domain "cardinality (math)"  :code "(define (card set) (length set))\n(display (card '(a b c d))) (newline)"))
     :explanation "Rung 1 shows the verb in its own domain: read the fact count directly from the store. Rung 2 shows the same shape one substrate down — a hand-rolled counter that returns its state in O(1); every bump increments; count reads. Rung 3 lifts to a math shape: the cardinality of a finite set is its size. All three are the same shape: give me a count without walking the elements."
     :meta "The shape transfers because cardinality is a universal fold on a collection. Once you see cortex/size as a maintained-count cell, you can port the pattern anywhere: SQL COUNT(*), Redis DBSIZE, HashMap.size(), Array.length. Same shape.")
    (:eng "Every 'how many?' surface in a running system is one of these three rungs. When SRE watches Cortex's cardinality metric, they are watching this shape."
     :math "Cardinality is a functor from Set to ℕ; monotone under embeddings and preserved under bijections."
     :cs "The classical O(1) size operation on a store that maintains its own count; contrast with O(n) length-of-enumeration."))
  :row-4-proof (
    (:claim "cortex/size is non-negative, agrees with length(keys()), grows by 1 on remember of a novel key, is unchanged by remember on an existing key (LWW overwrite), and shrinks by 1 on forget of a present key."
     :program "(for-each cortex/forget (cortex/keys))\n(display (>= (cortex/size) 0)) (newline)                         ; non-negative\n(display (= (cortex/size) (length (cortex/keys)))) (newline)     ; agrees with keys\n\n(define n0 (cortex/size))\n(cortex/remember 'new-key 'hello)\n(display (= (cortex/size) (+ n0 1))) (newline)                   ; +1 on novel\n\n(cortex/remember 'new-key 'goodbye)\n(display (= (cortex/size) (+ n0 1))) (newline)                   ; unchanged on overwrite\n\n(cortex/forget 'new-key)\n(display (= (cortex/size) n0)) (newline)                         ; -1 on forget\n\n(cortex/forget 'new-key)\n(display (= (cortex/size) n0)) (newline)"
     :invariant "∀ store.  size() ≥ 0.   ∀ store.  size() = length(keys()).   ∀ k novel.  after remember(k, v):  size() = old_size() + 1.   ∀ k present.  after remember(k, v'):  size() = old_size().   ∀ k present.  after forget(k):  size() = old_size() - 1.   ∀ k absent.  after forget(k):  size() = old_size()."
     :meta "The size-follows-keyset invariant is what makes the count trustworthy: every write and every delete adjusts the count exactly as much as it changes the enumeration. A single counter-example — a size that stayed the same after a novel remember, or shrank on a no-op forget — would falsify the store's contract. Grounded in book-of-code ch 9 (registers-counters-and-the-birth-of-state, where an incrementing counter is the hardware root of this shape) and book-of-code ch 13 (memory hierarchy, where the count and the enumeration must agree in every level).")
    (:eng "The invariant is why dashboards can trust cortex/size as a live metric. If it disagreed with the enumeration, every capacity graph would lie and the operator would misjudge when to prune."
     :math "size is a valuation on the store lattice; monotone under remember-of-novel and forget-of-absent (identity), strictly monotone under remember-of-novel (+1) and forget-of-present (-1)."
     :cs "Same shape as classical Map.size() with a maintained-counter implementation; the counter is updated on the same code paths as the underlying map, so agreement is a code-level invariant, not a runtime check."))
  :row-5-emergence (
    (:base "cortex/size is a constant-time cardinality read."
     :composition "(for-each cortex/forget (cortex/keys))\n\n(define soft-cap 10)\n\n(define (remember-with-cap key value)\n  (if (< (cortex/size) soft-cap)\n      (begin (cortex/remember key value) 'stored)\n      (begin\n        ;; evict the first key to make room\n        (let ((victim (car (cortex/keys))))\n          (cortex/forget victim))\n        (cortex/remember key value)\n        (list 'evicted-and-stored))))\n\n(let loop ((i 0))\n  (if (>= i 12)\n      'done\n      (begin (remember-with-cap\n              (string->symbol (string-append \"k\" (number->string i))) i)\n             (loop (+ i 1)))))\n\n(display (cortex/size)) (newline)   ; capped at 10\n(display (cortex/keys)) (newline)"
     :emergent "A bounded cache with eviction. Chaining cortex/size with cortex/remember and cortex/forget produces a fixed-size cache: writes below the cap go through; writes above the cap evict the first key and then insert. Neither verb alone is bounded; the guarded pattern is."
     :meta "This is the classical bounded-cache pattern from the family of eviction topologies (FIFO cache, LRU, LFU, size-bounded LRU). Familiar analogs: Guava CacheBuilder.maximumSize, Redis maxmemory-policy, memcached slab eviction. Cross-reference: book-of-composition ch 13 (save-load, where a size-bounded cache is one of the composable widgets) and book-of-computing ch 13 (databases and storage, where bounded caches are the classical topology).")
    (:eng "The bounded cache is what an operator adds when they see cortex/size drifting up without bound. Failure mode: FIFO evicts the wrong thing (the least-recently-added, not the least-recently-USED); the operator upgrades to an LRU tracker if hit-rate matters."
     :math "The bound is a fixed-point on the store: |store| = min(soft-cap, |inserts - forgets|). The FIFO eviction is a queue discipline; LRU would swap the queue for a stack of recency."
     :cs "The size + remember + forget composition is the atom of every bounded cache; the choice of eviction policy is orthogonal to the composition itself."))
  )

