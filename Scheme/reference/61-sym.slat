;;; 61-sym.slat — Motoi Scheme Reference · Chapter 61 · library sym
;;;
;;; 20 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library sym — 20 verbs.")

(chapter :number "61" :library "sym" :verb-count 20 :training-eligible #t)

;; ═══ 20 verbs in library sym ═══

(verb
  :name "sym/->string"
  :library "sym"
  :kind "meta"
  :signature "(sym/->string poly) -> string"
  :summary "Convert a polynomial to a human-readable string with terms in descending degree order."
  :explanation "Renders a polynomial expression as a human-friendly string like \"2x^2 + 3x - 1\", ordering terms from highest degree to lowest. This is useful for display, logging, or feeding symbolic results back to a human reader. Non-polynomial inputs return the symbol 'nan to signal type mismatch gracefully."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/->string (sym/poly '(1 2 3)))\n;; => \"3x^2 + 2x + 1\"" :note "poly with coefficients [1, 2, 3] (low-order-first) renders high-order-first")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p (sym/add (sym/poly '(0 1)) (sym/poly '(5 0 1)))))\n  (display (sym/->string p)))\n;; => \"x^2 + x\"" :note "sum of two polynomials is rendered as a clean expression")
    (:dialect "motoi" :tier "expert" :code "(let ((f (sym/poly '(-1 3 2))))\n  (let ((f-deriv (sym/derivative f)))\n    (list (sym/->string f) (sym/->string f-deriv))))\n;; => (\"2x^2 + 3x - 1\" \"4x + 3\")" :note "chaining polynomial ops and rendering intermediate results for inspection")
  )
  :caveats ("Returns the symbol 'nan if the input is not a valid polynomial" "Output order is always high-degree-first, regardless of internal storage" "Omits zero coefficients automatically (no \"+ 0x^2\" terms)")
  :drawbacks ("sym/->string is for display only; use sym/= to check equality, not string comparison" "Very large degree polynomials may produce long strings; consider sym/degree to check structure first")
  :usecases ("Displaying symbolic results in a repl or debug log" "Building user-facing output from algebraic computations" "Verifying polynomial simplification by eye")
  :related ("sym/poly" "sym/degree" "sym/=" "sym/evaluate")
  :learn (:concept "Converting symbolic structures to human-readable text for inspection and communication" :prerequisites ("sym/poly") :progression "After printing a polynomial, move to sym/degree to query its structure, then sym/coeff to extract individual terms")
  :row-2-audit (
    (:problem "A cortex/tutor wants to display a polynomial after a step of algebra so the student sees the result in standard high-degree-first notation."
     :program "(define p (sym/mul (sym/poly '(1 1)) (sym/poly '(2 1))))\n(display (sym/->string p))"
     :explanation "Line 1 multiplies (1+x)(2+x) yielding 2+3x+x². Line 2 renders as \"x^2 + 3x + 2\". The tutor UI displays the string to the student."
     :meta "Reach for sym/->string and NOT display of the raw polynomial: raw display exposes internal coefficient-list representation, which is not standard math notation.")
    (:eng "The tutor log includes the rendered string for review." :math "sym/->string is a projection from Poly to String." :cs "Meta; O(degree)."))
  :row-3-dimension (
    (:setup "Structure-to-notation projection."
     :rungs (
       (:domain "sym"    :code "(sym/->string p)")
       (:domain "text (metaphor)" :code "(text/format-currency amount)")
       (:domain "type theory"  :code "show: A → String"))
     :explanation "Rung 1 poly to standard notation. Rung 2 amount to currency string. Rung 3 abstract show function. Same shape."
     :meta "Show functions transfer to any structure with a canonical rendering.")
    (:eng "Human-readable projections appear in every user-facing display." :math "Rendering function of an abstract type." :cs "The 'show' half of a serialize/display pair."))
  :row-4-proof (
    (:claim "sym/->string produces the same string for equal polynomials: sym/= implies string equality."
     :program "(define p1 (sym/poly '(2 3 1)))\n(define p2 (sym/add (sym/poly '(1 3)) (sym/poly '(1 0 1))))\n(and (sym/= p1 p2) (string=? (sym/->string p1) (sym/->string p2)))"
     :invariant "∀ p q. sym/=(p, q) → sym/->string(p) = sym/->string(q)"
     :meta "Pattern: rendering respects equality. Falsifies if two equal polys render differently. See book-of-code ch on canonical rendering.")
    (:eng "Rendering-equality is what makes visual comparison correct." :math "sym/->string factors through the polynomial quotient." :cs "The 'well-defined-on-quotient' property is a base of canonicalization."))
  :row-5-emergence (
    (:base "sym/->string renders polynomial as string."
     :composition "(define (trace-derivatives p n) (let loop ((cur p) (i 0) (acc '())) (if (>= i n) (reverse acc) (loop (sym/derivative cur) (+ i 1) (cons (list i (sym/->string cur)) acc)))))\n(trace-derivatives (sym/poly '(1 2 3 4)) 4)"
     :emergent "step-by-step derivative log — trace the derivative sequence with human-readable output at each step."
     :meta "Family: computation-trace. Same shape as Wolfram|Alpha's step-by-step display or a debugger watch expression. See book-of-composition ch on computation trace.")
    (:eng "The pattern gives ops human-readable audit trails for teaching contexts." :math "Realizes a fold-with-rendering over the derivative sequence." :cs "Trace-with-rendering is a base for teaching UIs."))

(verb
  :name "sym/="
  :library "sym"
  :kind "meta"
  :signature "(sym/= p1 p2) -> boolean"
  :summary "Test structural equality of two polynomials after canonicalization."
  :explanation "Two polynomials are equal if, after normalization (removing trailing zeros, sorting by degree), their coefficient lists match exactly. This is the canonical way to compare polynomial expressions in Motoi: it ignores surface-level representation and instead compares the true mathematical objects. Non-polynomial inputs return 'nan."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/= (sym/poly '(1 2 3)) (sym/poly '(1 2 3)))\n;; => #t" :note "identical coefficient lists are equal")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p1 (sym/add (sym/poly '(1 1)) (sym/poly '(2 0))))\n      (p2 (sym/poly '(3 1))))\n  (sym/= p1 p2))\n;; => #t" :note "canonicalization makes algebraically equivalent expressions equal")
    (:dialect "motoi" :tier "expert" :code "(let ((f (sym/poly '(-1 3 2))))\n  (let ((f-deriv-twice (sym/derivative (sym/derivative f))))\n    (sym/= f-deriv-twice (sym/const 4))))\n;; => #t" :note "second derivative of quadratic equals its leading coefficient × 2")
  )
  :caveats ("Returns 'nan if either argument is not a valid polynomial" "Trailing zero coefficients are stripped before comparison, so (sym/poly '(1 0 0)) equals (sym/poly '(1))" "Does not use string comparison; (sym/->string p1) = (sym/->string p2) is not equivalent")
  :drawbacks ("sym/= is strict: 2x and 2.0x are equal only if internal representation matches exactly" "Floating-point polynomials may have rounding artifacts; consider sym/evaluate to test sampled points")
  :usecases ("Verifying symbolic simplification matches an expected result" "Testing polynomial algebra in symbolic computations" "Asserting correct behavior after sym/add, sym/mul, sym/derivative")
  :related ("sym/->string" "sym/poly" "sym/add" "sym/mul" "sym/derivative")
  :learn (:concept "Canonical equality: two objects are equal when they reduce to the same normal form" :prerequisites ("sym/poly" "sym/degree") :progression "Use sym/= to verify algebra, then move to sym/evaluate to test values, and sym/derivative for calculus")
  :row-2-audit (
    (:problem "A math/homework auto-checker compares student input polynomial to the expected polynomial regardless of surface form."
     :program "(define expected (sym/poly '(2 3 1)))\n(define student (sym/add (sym/poly '(1 3)) (sym/poly '(1 0 1))))\n(sym/= expected student)"
     :explanation "Line 1 defines expected. Line 2 defines what the student wrote. Line 3 returns #t: canonicalization makes different surface forms equal."
     :meta "Reach for sym/= and NOT (string=? (sym/->string a) (sym/->string b)): string comparison can fail on whitespace or ordering differences that don't matter mathematically.")
    (:eng "The auto-checker log names the answer as correct despite different surface form." :math "sym/= tests equality in the polynomial quotient." :cs "Canonical-form comparison; O(degree)."))
  :row-3-dimension (
    (:setup "Semantic equality: same object under a canonical projection."
     :rungs (
       (:domain "sym"    :code "(sym/= p1 p2)")
       (:domain "note (metaphor)" :code "(note/enharmonic? n1 n2)")
       (:domain "algebra"    :code "[a] = [b] in A/≡"))
     :explanation "Rung 1 polynomial equality. Rung 2 enharmonic note equality. Rung 3 quotient equality. Same shape."
     :meta "Semantic equality transfers wherever a canonical form exists.")
    (:eng "Enharmonic tests, polynomial tests, and canonical-form checks share a shape." :math "Equality on the quotient." :cs "Canonical-form equality is the base of memoization and deduplication."))
  :row-4-proof (
    (:claim "sym/= is reflexive, symmetric, and transitive — a proper equivalence."
     :program "(define p (sym/poly '(1 2 3)))\n(define q (sym/poly '(1 2 3)))\n(define r (sym/poly '(1 2 3)))\n(and (sym/= p p) (eq? (sym/= p q) (sym/= q p)) (if (and (sym/= p q) (sym/= q r)) (sym/= p r) #t))"
     :invariant "∀ p. sym/=(p,p) ∧ ∀ p q. sym/=(p,q) → sym/=(q,p) ∧ ∀ p q r. (sym/=(p,q) ∧ sym/=(q,r)) → sym/=(p,r)"
     :meta "Pattern: equivalence relation. Falsifies if any triple breaks. See book-of-math ch on equivalence relations.")
    (:eng "Equivalence guarantees the auto-checker is consistent." :math "The three equivalence axioms." :cs "Equivalence is the base of quotient-collection semantics."))
  :row-5-emergence (
    (:base "sym/= tests canonical polynomial equality."
     :composition "(define (verify-identity lhs rhs) (sym/= lhs rhs))\n(define (proof-fma-example)\n  (verify-identity (sym/mul (sym/poly '(1 1)) (sym/poly '(-1 1))) (sym/poly '(-1 0 1))))\n(proof-fma-example)"
     :emergent "algebraic-identity prover — verify that two algebraic expressions are the same polynomial."
     :meta "Family: identity-prover. Same shape as a CAS's Simplify/FullSimplify or a Coq tactic verifying an algebraic law. See book-of-composition ch on symbolic verification.")
    (:eng "The pattern lets ops verify algebra automatically." :math "Realizes decidability of polynomial equality." :cs "Automated identity-checking is a base for teaching tools."))

(verb
  :name "sym/add"
  :library "sym"
  :kind "meta"
  :signature "(sym/add p1 p2) -> polynomial"
  :summary "Polynomial sum: add two polynomials term by term."
  :explanation "Adds two polynomial expressions by aligning powers of x and summing coefficients. The result is a new polynomial with degree at most max(deg(p1), deg(p2)). Non-polynomial operands return 'nan. This is the foundation of symbolic polynomial arithmetic."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/add (sym/poly '(1 2)) (sym/poly '(3 4)))\n;; => polynomial with coefficients (4 6)" :note "simple term-by-term addition: (1+2x) + (3+4x) = 4+6x")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p (sym/poly '(0 1))))\n  (sym/add p (sym/add p p)))\n;; => polynomial with coefficients (0 3)" :note "successive addition: x + x + x = 3x")
    (:dialect "motoi" :tier "expert" :code "(let ((f (sym/poly '(-1 0 1)))\n      (g (sym/poly '(1 1))))\n  (let ((h (sym/add f g)))\n    (list (sym/degree h) (sym/->string h))))\n;; => (2 \"x^2 + x\")" :note "composing add with degree and display to inspect result structure")
  )
  :caveats ("Returns 'nan if either operand is not a polynomial" "Addition is commutative: sym/add is order-independent" "Cancellation may occur: (sym/add (sym/poly '(1 1)) (sym/poly '(-1 -1))) yields the zero polynomial with degree -1")
  :drawbacks ("sym/add does not simplify or factor; use sym/expand for full normalization" "Adding a constant to a polynomial requires wrapping the constant in (sym/const number)")
  :usecases ("Building polynomials by incremental addition" "Combining multiple polynomial terms or expressions" "Implementing polynomial algebra in symbolic solvers")
  :related ("sym/sub" "sym/mul" "sym/scale" "sym/poly" "sym/const")
  :learn (:concept "Polynomial addition: align by degree and sum coefficients" :prerequisites ("sym/poly" "sym/const") :progression "After addition, explore sym/sub for subtraction, then sym/mul for multiplication, and sym/expand for normalization")
  :row-2-audit (
    (:problem "A phys/motion simulator combines two force polynomials — spring force and gravity — into a single net-force polynomial."
     :program "(define spring (sym/poly '(0 -1)))\n(define gravity (sym/poly '(-9.8)))\n(sym/->string (sym/add spring gravity))"
     :explanation "Line 1 defines -x for spring. Line 2 defines -9.8 constant for gravity. Line 3 renders as \"-x - 9.8\". Net force is the sum."
     :meta "Reach for sym/add and NOT sym/mul: forces combine by addition, not multiplication. Using mul would produce a different physics.")
    (:eng "The physics log records the combined force polynomial." :math "sym/add is the group operation of the polynomial abelian group." :cs "O(max degree); term-by-term."))
  :row-3-dimension (
    (:setup "Group-addition: combine two elements under an associative commutative operation."
     :rungs (
       (:domain "sym"     :code "(sym/add p q)")
       (:domain "vec (metaphor)" :code "(vec/add u v)")
       (:domain "algebra"    :code "a + b in (A, +)"))
     :explanation "Rung 1 polynomial sum. Rung 2 vector sum. Rung 3 abstract group sum. Same shape."
     :meta "Addition-in-a-group is a universal shape.")
    (:eng "Vector, polynomial, and matrix addition share this shape." :math "Abelian group operation." :cs "Element-wise combination."))
  :row-4-proof (
    (:claim "sym/add is commutative and associative — a proper abelian-group operation."
     :program "(define p (sym/poly '(1 2)))\n(define q (sym/poly '(3 -1)))\n(define r (sym/poly '(0 1 1)))\n(and (sym/= (sym/add p q) (sym/add q p)) (sym/= (sym/add (sym/add p q) r) (sym/add p (sym/add q r))))"
     :invariant "∀ p q. p + q = q + p ∧ ∀ p q r. (p + q) + r = p + (q + r)"
     :meta "Pattern: commutative-monoid laws. Falsifies if any triple breaks. See book-of-math ch on group axioms.")
    (:eng "Associativity/commutativity mean folded-additions produce the same result regardless of order." :math "Abelian-group axioms." :cs "Commutative-monoid laws enable parallel reduction."))
  :row-5-emergence (
    (:base "sym/add sums two polynomials."
     :composition "(define (poly-sum polys) (if (null? polys) (sym/const 0) (sym/add (car polys) (poly-sum (cdr polys)))))\n(poly-sum (list (sym/poly '(1)) (sym/poly '(0 1)) (sym/poly '(0 0 1))))"
     :emergent "polynomial sum reducer — fold sym/add over a list to accumulate an arbitrary polynomial."
     :meta "Family: monoid-fold. Same shape as summing a list of numbers, concatenating a list of strings, or unioning a list of sets. See book-of-composition ch on monoid folds.")
    (:eng "The pattern generalizes binary addition to n-ary via fold." :math "Realizes the free-monoid fold on the polynomial group." :cs "Monoid-fold is a canonical reduce shape."))

(verb
  :name "sym/coeff"
  :library "sym"
  :kind "meta"
  :signature "(sym/coeff poly k) -> number"
  :summary "Extract the coefficient of x^k from a polynomial."
  :explanation "Returns the numeric coefficient of the x^k term in the polynomial. If the term is absent or has coefficient 0, returns 0. If k is negative or not an integer, or the input is not a polynomial, returns 'nan. This is the inverse of sym/poly: you can reconstruct a polynomial from its coefficients by repeated calls to sym/coeff."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((p (sym/poly '(1 2 3))))\n  (sym/coeff p 2))\n;; => 3" :note "coefficient of x^2 in polynomial (1 + 2x + 3x^2) is 3")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p (sym/poly '(5 0 -2 0 1))))\n  (list (sym/coeff p 0) (sym/coeff p 1) (sym/coeff p 4)))\n;; => (5 0 1)" :note "extracting multiple coefficients; absent terms return 0")
    (:dialect "motoi" :tier "expert" :code "(let ((f (sym/poly '(-1 3 2))))\n  (let ((df (sym/derivative f)))\n    (list (sym/coeff f 0) (sym/coeff df 1) (sym/->string df))))\n;; => (-1 4 \"4x + 3\")" :note "extracting coefficients from original and derivative to verify rule: d/dx(x^n) = n·x^(n-1)")
  )
  :caveats ("Returns 'nan if k is negative, non-integer, or the input is not a polynomial" "Returns 0 (not 'nan) for valid k beyond the polynomial degree" "sym/coeff does not simplify; it returns the raw coefficient stored")
  :drawbacks ("Repeated calls to sym/coeff are slower than inspecting the entire polynomial structure at once" "For large k, this is an O(1) access but assumes the polynomial is already in memory")
  :usecases ("Extracting a specific term from a symbolic computation" "Verifying the coefficients of a polynomial after addition, multiplication, or differentiation" "Building lookup tables of polynomial terms")
  :related ("sym/poly" "sym/degree" "sym/->string" "sym/derivative")
  :learn (:concept "Polynomial representation: a polynomial is a sequence of coefficients indexed by degree" :prerequisites ("sym/poly" "sym/degree") :progression "After extracting coefficients, use sym/add or sym/mul to perform arithmetic, then sym/derivative for calculus")
  :row-2-audit (
    (:problem "A calc/analyze routine wants only the leading coefficient of a polynomial to detect end-behavior."
     :program "(define p (sym/poly '(-1 3 2)))\n(sym/coeff p (sym/degree p))"
     :explanation "Line 1 defines 2x²+3x-1. Line 2 extracts the coefficient at degree 2 (the leading term): 2. The analyzer uses this to decide direction of end-behavior."
     :meta "Reach for sym/coeff and NOT parsing sym/->string: parsing the rendered string is fragile and O(degree). sym/coeff is direct.")
    (:eng "The analyzer log records the leading coefficient." :math "sym/coeff is a projection Poly × ℕ → ℝ." :cs "O(1) if the polynomial is stored as a coefficient vector."))
  :row-3-dimension (
    (:setup "Indexed lookup on a structured object."
     :rungs (
       (:domain "sym"     :code "(sym/coeff p k)")
       (:domain "vec (metaphor)" :code "(vec/nth v k)")
       (:domain "type theory" :code "π_k: Poly → ℝ (k-th projection)"))
     :explanation "Rung 1 coefficient lookup. Rung 2 vector index. Rung 3 abstract projection. Same shape."
     :meta "Indexed lookup transfers to any indexed structure.")
    (:eng "Indexed lookup is universal in every data-structure." :math "Projection function of an indexed family." :cs "The base access primitive on positional data."))
  :row-4-proof (
    (:claim "sym/coeff after sym/poly is the identity on valid indices: (sym/coeff (sym/poly lst) k) = list-ref(lst, k) when 0 ≤ k < length(lst)."
     :program "(define lst '(-1 3 2))\n(define p (sym/poly lst))\n(and (= (sym/coeff p 0) -1) (= (sym/coeff p 1) 3) (= (sym/coeff p 2) 2))"
     :invariant "∀ lst k. 0 ≤ k < |lst| → sym/coeff(sym/poly(lst), k) = lst[k]"
     :meta "Pattern: constructor-projector identity. Falsifies if any index disagrees. See book-of-code ch on constructor-projector duality.")
    (:eng "The identity lets ops trust round-trips through the poly type." :math "Section of the constructor: coeff ∘ poly = id on valid indices." :cs "Constructor-projector duality is a base algebraic property."))
  :row-5-emergence (
    (:base "sym/coeff extracts a single coefficient."
     :composition "(define (evaluate-slow p x) (let loop ((k 0) (acc 0)) (if (> k (sym/degree p)) acc (loop (+ k 1) (+ acc (* (sym/coeff p k) (expt x k)))))))\n(evaluate-slow (sym/poly '(1 2 3)) 2)"
     :emergent "polynomial-evaluator by explicit index-and-sum — the pedagogical form of polynomial evaluation."
     :meta "Family: index-based reducer. Same shape as computing a dot product via indexed sum or matrix-vector product. See book-of-composition ch on indexed reduction.")
    (:eng "The pattern is the pedagogical evaluator, contrasted with Horner in sym/evaluate." :math "Realizes p(x) = Σ aₖ xᵏ directly." :cs "Index-and-accumulate is a base reducer shape."))

(verb
  :name "sym/const"
  :library "sym"
  :kind "meta"
  :signature "(sym/const number) -> polynomial"
  :summary "Create a degree-0 polynomial (a constant)."
  :explanation "Wraps a number in a polynomial object so it can be used in symbolic arithmetic. A constant polynomial is just a single coefficient at degree 0. This is useful when you need to add, multiply, or compare a bare number with a symbolic polynomial. Non-numeric input returns 'nan."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/const 5)\n;; => constant polynomial representing 5" :note "wraps the number 5 as a degree-0 polynomial")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p (sym/poly '(0 1)))\n      (c (sym/const 3)))\n  (sym/->string (sym/add p c)))\n;; => \"x + 3\"" :note "adding a constant polynomial to x-polynomial; const is promoted automatically")
    (:dialect "motoi" :tier "expert" :code "(let ((p (sym/poly '(-1 0 1)))\n      (root 1))\n  (let ((p-at-root (sym/evaluate p root)))\n    (sym/= (sym/const p-at-root) (sym/const 0))))\n;; => #t" :note "verifying that x=1 is a root of x^2 - 1 by evaluating and wrapping result as constant")
  )
  :caveats ("Returns 'nan if the input is not a number" "(sym/const 0) creates the zero polynomial with degree -1" "sym/const is idempotent in polynomial operations: (sym/const c1) + (sym/const c2) = (sym/const (+ c1 c2))")
  :drawbacks ("sym/const is not required when performing arithmetic with sym/poly; use it only for clarity or when you have a bare number" "Mixing constants with undefined variables requires careful algebra")
  :usecases ("Adding a constant to a polynomial expression" "Testing polynomial equality against a specific value" "Building polynomials incrementally from scalar terms")
  :related ("sym/poly" "sym/add" "sym/mul" "sym/evaluate" "sym/degree")
  :learn (:concept "Constants are degree-0 polynomials; wrapping helps with type consistency in algebra" :prerequisites ("sym/poly") :progression "After creating constants, combine them with sym/add and sym/mul, then use sym/evaluate to compute values")
  :row-2-audit (
    (:problem "A math/exercise adds a constant to a polynomial before displaying to a student; the operator wraps the raw number as a constant polynomial for type-consistency."
     :program "(define p (sym/poly '(0 1)))\n(define c (sym/const 3))\n(sym/->string (sym/add p c))"
     :explanation "Line 1 defines x. Line 2 wraps 3 as a constant polynomial. Line 3 renders as \"x + 3\"."
     :meta "Reach for sym/const and NOT direct addition with a raw number: raw numbers aren't polynomials in Motoi; the type mismatch fails at the boundary.")
    (:eng "The exercise log shows the constant properly typed." :math "sym/const embeds ℝ into Poly at degree 0." :cs "Meta; O(1)."))
  :row-3-dimension (
    (:setup "Embedding a scalar into a structured space."
     :rungs (
       (:domain "sym"    :code "(sym/const 5)")
       (:domain "matrix (metaphor)" :code "(matrix/scalar 5)")
       (:domain "algebra"    :code "ι: ℝ ↪ Poly"))
     :explanation "Rung 1 scalar to polynomial. Rung 2 scalar to matrix. Rung 3 abstract embedding. Same shape."
     :meta "Scalar-into-structure embedding transfers wherever the structure has a 'lowest' embedding.")
    (:eng "Scalar embedding appears in every polymorphic arithmetic layer." :math "Injection of a scalar-field into a graded structure." :cs "Type-lifting to the polynomial universe."))
  :row-4-proof (
    (:claim "sym/const respects addition: (sym/const (+ a b)) = (sym/add (sym/const a) (sym/const b))."
     :program "(define a 3)\n(define b 5)\n(sym/= (sym/const (+ a b)) (sym/add (sym/const a) (sym/const b)))"
     :invariant "∀ a b ∈ ℝ. sym/const(a+b) = sym/add(sym/const(a), sym/const(b))"
     :meta "Pattern: ring-homomorphism condition. Falsifies if any pair breaks. See book-of-math ch on ring homomorphisms.")
    (:eng "The homomorphism condition means constants can be pushed through addition." :math "sym/const is a ring homomorphism ℝ → Poly." :cs "Homomorphism-respecting embeddings enable optimization by early folding."))
  :row-5-emergence (
    (:base "sym/const embeds a number as a polynomial."
     :composition "(define (poly-from-list lst) (let loop ((rest lst) (k 0) (acc (sym/const 0))) (if (null? rest) acc (loop (cdr rest) (+ k 1) (sym/add acc (sym/mul (sym/const (car rest)) (sym/pow (sym/var 'x) k)))))))\n(sym/->string (poly-from-list (list 1 2 3)))"
     :emergent "polynomial-builder from scalars — explicit construction via constants, variables, and monomials."
     :meta "Family: constructor-from-primitives. Same shape as building a linear combination or expression tree. See book-of-composition ch on primitive-based construction.")
    (:eng "The pattern shows how everything above sym/const emerges from primitives." :math "Realizes the free-polynomial construction over ℝ." :cs "Bottom-up construction is a canonical scheme for algebraic types."))

(verb
  :name "sym/degree"
  :library "sym"
  :kind "meta"
  :signature "(sym/degree poly) -> integer"
  :summary "Return the degree (highest non-zero power) of a polynomial."
  :explanation "The degree is the largest k such that the coefficient of x^k is non-zero. For the zero polynomial, degree is -1. For non-polynomial input, returns 'nan. Degree is a quick structural query that helps you understand the \"size\" and behavior of a polynomial without inspecting all coefficients."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/degree (sym/poly '(1 2 3)))\n;; => 2" :note "polynomial 1 + 2x + 3x^2 has degree 2")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p (sym/poly '(0 0 1))))\n  (list (sym/degree p) (sym/->string p)))\n;; => (2 \"x^2\")" :note "leading zeros don't affect degree; only the highest non-zero power matters")
    (:dialect "motoi" :tier "expert" :code "(let ((f (sym/poly '(-1 0 1))))\n  (let ((n (sym/degree f)))\n    (let ((df (sym/derivative f)))\n      (list n (sym/degree df)))))\n;; => (2 1)" :note "degree drops by 1 after differentiation: d/dx(x^2 - 1) = 2x has degree 1")
  )
  :caveats ("Returns 'nan if the input is not a polynomial" "Zero polynomial returns -1, not 0" "Degree is computed on the canonical (trimmed) form; trailing zeros don't count")
  :drawbacks ("sym/degree tells you the highest power, not the number of distinct terms" "For very large polynomials, computing degree is fast but doesn't help with factoring or solving")
  :usecases ("Checking if a polynomial is linear (degree 1), quadratic (degree 2), etc." "Verifying the result of sym/derivative or sym/mul" "Building decision logic for solving or factoring based on degree")
  :related ("sym/poly" "sym/coeff" "sym/->string" "sym/derivative" "sym/solve-quadratic")
  :learn (:concept "Degree: the exponent of the highest non-zero term; a quick structural signature" :prerequisites ("sym/poly" "sym/coeff") :progression "After querying degree, use sym/solve-linear or sym/solve-quadratic based on the degree, or sym/derivative to explore the derivative")
  :row-2-audit (
    (:problem "A math/dispatcher routes a polynomial to solve-linear or solve-quadratic based on its degree."
     :program "(define (solve p) (case (sym/degree p) ((1) (sym/solve-linear p)) ((2) (sym/solve-quadratic p)) (else 'unsupported)))\n(solve (sym/poly '(-6 1 1)))"
     :explanation "Line 1 dispatches on degree. Line 2 solves x²+x-6=0 via the degree-2 branch, returning (2 -3)."
     :meta "Reach for sym/degree and NOT counting sym/coeff calls: length checking with sym/coeff misses trailing-zero trimming; degree is precise.")
    (:eng "The dispatcher log records the routing decision by degree." :math "sym/degree is the leading-nonzero-index function." :cs "Meta; O(1) on canonical polynomials."))
  :row-3-dimension (
    (:setup "Structural signature: give a single number that characterizes shape."
     :rungs (
       (:domain "sym"     :code "(sym/degree p)")
       (:domain "vec (metaphor)" :code "(vec/dim v)")
       (:domain "algebra"    :code "deg: Poly → ℕ ∪ {-1}"))
     :explanation "Rung 1 poly degree. Rung 2 vector dimension. Rung 3 abstract dimension. Same shape."
     :meta "Structural-signatures transfer to any type with a size.")
    (:eng "Dimension queries appear across every dispatcher." :math "The dimension function." :cs "Size query is O(1) on well-canonicalized forms."))
  :row-4-proof (
    (:claim "sym/degree of a product equals the sum of degrees (deg(pq) = deg(p) + deg(q)) when both are non-zero."
     :program "(define p (sym/poly '(1 2)))\n(define q (sym/poly '(-1 0 1)))\n(= (sym/degree (sym/mul p q)) (+ (sym/degree p) (sym/degree q)))"
     :invariant "∀ p q. p ≠ 0 ∧ q ≠ 0 → deg(pq) = deg(p) + deg(q)"
     :meta "Pattern: degree-multiplicativity. Falsifies if any product breaks. See book-of-math ch on polynomial rings.")
    (:eng "The invariant lets ops predict the degree of a product without computing it." :math "The polynomial ring is an integral domain." :cs "Degree-multiplicativity is what makes fast polynomial multiplication analyzable."))
  :row-5-emergence (
    (:base "sym/degree returns the polynomial degree."
     :composition "(define (classify p) (case (sym/degree p) ((-1) 'zero) ((0) 'constant) ((1) 'linear) ((2) 'quadratic) ((3) 'cubic) (else 'higher)))\n(map classify (list (sym/const 0) (sym/const 5) (sym/poly '(0 1)) (sym/poly '(0 0 1)) (sym/poly '(0 0 0 1))))"
     :emergent "polynomial-classifier — degree-based labels for teaching or dispatch."
     :meta "Family: type-classifier. Same shape as file-type detection by extension or protocol classification by port. See book-of-composition ch on shape-classifiers.")
    (:eng "The pattern lets ops name polynomials by their degree class." :math "Realizes the standard poly-tier taxonomy." :cs "Shape-classification is a base pattern for dispatch."))

(verb
  :name "sym/derivative"
  :library "sym"
  :kind "meta"
  :signature "(sym/derivative poly) -> polynomial"
  :summary "Compute the polynomial derivative d/dx."
  :explanation "Returns the formal derivative of a polynomial by applying the power rule: d/dx(x^k) = k·x^(k-1). The result is a new polynomial with degree one less than the input (or degree -1 if the input is constant). Non-polynomial input returns 'nan. This is foundational for calculus and optimization on symbolic expressions."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/derivative (sym/poly '(1 2 3)))\n;; => polynomial with coefficients (2 6)" :note "d/dx(1 + 2x + 3x^2) = 2 + 6x")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p (sym/poly '(-1 3 2))))\n  (let ((dp (sym/derivative p)))\n    (list (sym/->string p) (sym/->string dp))))\n;; => (\"2x^2 + 3x - 1\" \"4x + 3\")" :note "taking derivative of a quadratic yields a linear polynomial")
    (:dialect "motoi" :tier "expert" :code "(let ((f (sym/poly '(0 0 0 1)))\n      (target 6))\n  (let ((df (sym/derivative f))\n        (ddf (sym/derivative (sym/derivative f))))\n    (sym/= ddf (sym/const target))))\n;; => #t" :note "second derivative of x^3 is 6, matching the constant 6")
  )
  :caveats ("Returns 'nan if the input is not a polynomial" "Derivative of a constant is the zero polynomial (degree -1)" "Higher derivatives can be computed by chaining: (sym/derivative (sym/derivative p))")
  :drawbacks ("sym/derivative does not simplify or factor; the result may have leading zeros that need trimming" "Repeatedly taking derivatives of high-degree polynomials produces smaller polynomials but can accumulate rounding errors in floating-point")
  :usecases ("Finding critical points: solve sym/derivative(p) = 0 to locate extrema" "Implementing Newton's method for root-finding" "Verifying calculus rules or derivatives by symbolic computation" "Analyzing polynomial behavior (monotonicity, concavity)")
  :related ("sym/poly" "sym/solve-linear" "sym/evaluate" "sym/->string" "sym/degree")
  :learn (:concept "The derivative d/dx: formal power-rule differentiation on polynomials" :prerequisites ("sym/poly" "sym/degree" "sym/coeff") :progression "After computing a derivative, use sym/solve-linear to find critical points, or sym/evaluate to test its values")
  :row-2-audit (
    (:problem "A calc/optimize handler finds critical points of a quadratic cost function by taking its derivative and solving = 0."
     :program "(define cost (sym/poly '(-1 3 2)))\n(define dcost (sym/derivative cost))\n(sym/solve-linear dcost)"
     :explanation "Line 1 defines 2x²+3x-1. Line 2 differentiates to 4x+3. Line 3 solves 4x+3=0 for x=-3/4, the critical point."
     :meta "Reach for sym/derivative and NOT a finite-difference approximation: symbolic differentiation is exact and cheap for polynomials.")
    (:eng "The optimize log records the critical point." :math "sym/derivative applies the power rule." :cs "Meta; O(degree)."))
  :row-3-dimension (
    (:setup "Rate-of-change transform."
     :rungs (
       (:domain "sym"     :code "(sym/derivative p)")
       (:domain "motion (metaphor)" :code "(motion/velocity path t)")
       (:domain "calculus"    :code "d/dx: C∞ → C∞"))
     :explanation "Rung 1 polynomial derivative. Rung 2 velocity from position. Rung 3 abstract derivative operator. Same shape."
     :meta "Derivative transfers to any differentiable domain.")
    (:eng "Rate-of-change transforms are the base of every optimization." :math "The derivative operator." :cs "Endomorphism on the polynomial ring."))
  :row-4-proof (
    (:claim "Derivative is linear: d/dx(p+q) = d/dx(p) + d/dx(q) and d/dx(c·p) = c·d/dx(p)."
     :program "(define p (sym/poly '(1 2 3)))\n(define q (sym/poly '(-1 0 4)))\n(and (sym/= (sym/derivative (sym/add p q)) (sym/add (sym/derivative p) (sym/derivative q))) (sym/= (sym/derivative (sym/scale p 5)) (sym/scale (sym/derivative p) 5)))"
     :invariant "∀ p q c. d(p+q)/dx = dp/dx + dq/dx ∧ d(cp)/dx = c·dp/dx"
     :meta "Pattern: linearity of an operator. Falsifies if any pair breaks. See book-of-math ch on derivative axioms.")
    (:eng "Linearity lets ops distribute derivatives through sums and scalar multiples freely." :math "The derivative is a linear operator." :cs "Linear operators can be represented as matrices for efficient batch application."))
  :row-5-emergence (
    (:base "sym/derivative differentiates a polynomial."
     :composition "(define (higher-derivatives p n) (let loop ((cur p) (i 0) (acc '())) (if (> i n) (reverse acc) (loop (sym/derivative cur) (+ i 1) (cons (list i (sym/->string cur)) acc)))))\n(higher-derivatives (sym/poly '(1 2 3 4)) 3)"
     :emergent "Taylor-series builder — repeated derivative applications yield the coefficients of a Taylor expansion around 0."
     :meta "Family: iterated-operator. Same shape as repeated integration, matrix powers, or repeated function composition. See book-of-composition ch on operator iteration.")
    (:eng "The pattern connects the derivative operator to series expansions." :math "d^n/dx^n gives the nth Taylor coefficient (times n!)." :cs "Iterated-operator patterns are the base for series generation."))

(verb
  :name "sym/evaluate"
  :library "sym"
  :kind "meta"
  :signature "(sym/evaluate poly number) -> number"
  :summary "Substitute a number for the variable and compute the result using Horner's method."
  :explanation "Evaluates a polynomial at a given numeric point by replacing x with that number and computing the result. Uses Horner's method (nested multiplication) for numerical stability and efficiency. Non-polynomial input or non-numeric substitution returns 'nan. This bridges symbolic and numeric computation, allowing you to test polynomial values or roots."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/evaluate (sym/poly '(1 2 3)) 2)\n;; => 17" :note "p(x) = 1 + 2x + 3x^2 at x=2: 1 + 4 + 12 = 17")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p (sym/poly '(-1 0 1))))\n  (list (sym/evaluate p 0) (sym/evaluate p 1) (sym/evaluate p -1)))\n;; => (-1 0 0)" :note "finding that x=1 and x=-1 are roots of x^2 - 1 by evaluation")
    (:dialect "motoi" :tier "expert" :code "(let ((f (sym/poly '(-1 3 2))))\n  (let ((df (sym/derivative f)))\n    (let ((x0 0))\n      (let ((fx0 (sym/evaluate f x0))\n            (dfx0 (sym/evaluate df x0)))\n        (- x0 (/ fx0 dfx0))))))\n;; => 0.3333..." :note "one Newton's method step: x_1 = x_0 - f(x_0)/f'(x_0) for root-finding")
  )
  :caveats ("Returns 'nan if the polynomial is invalid or the number argument is non-numeric" "Floating-point evaluation may accumulate rounding error for very high-degree polynomials or extreme values" "sym/evaluate is sensitive to the order of coefficients; verify your polynomial is well-formed first")
  :drawbacks ("sym/evaluate is purely numeric; it does not return a symbolic expression or derivative" "For symbolic composition (replacing x with another polynomial), use sym/substitute instead")
  :usecases ("Testing if a value is a root: check if (sym/evaluate p x) = 0" "Implementing Newton's method or other numerical root-finders" "Graphing a polynomial by sampling points" "Verifying algebraic identities by numerical spot-check")
  :related ("sym/poly" "sym/substitute" "sym/derivative" "sym/solve-linear" "sym/solve-quadratic")
  :learn (:concept "Horner's method: efficient nested evaluation of polynomials to bridge symbolic and numeric" :prerequisites ("sym/poly" "sym/degree") :progression "After evaluating polynomials, use sym/derivative + sym/evaluate for Newton's method, or sym/solve-quadratic for exact roots")
  :row-2-audit (
    (:problem "A plot/* renderer samples a polynomial at 100 x-values to draw a curve; the operator uses sym/evaluate to get each y."
     :program "(define p (sym/poly '(-1 0 1)))\n(map (lambda (x) (list x (sym/evaluate p x))) (list -2 -1 0 1 2))"
     :explanation "Line 1 defines x²-1. Line 2 samples the polynomial at 5 x-values, yielding (x, y) pairs. The renderer draws lines between."
     :meta "Reach for sym/evaluate and NOT sym/coeff + explicit sum: sym/evaluate uses Horner's method internally for stability and O(degree) speed.")
    (:eng "The plot log records the sampled points." :math "sym/evaluate computes p(x) at a numeric point." :cs "Horner's method: O(degree)."))
  :row-3-dimension (
    (:setup "Symbolic-to-numeric bridging: instantiate a symbolic form at a value."
     :rungs (
       (:domain "sym"     :code "(sym/evaluate p x)")
       (:domain "note (metaphor)" :code "(note/freq-at n octave)")
       (:domain "logic"    :code "[expr]_v — expression evaluated in a valuation"))
     :explanation "Rung 1 polynomial evaluated. Rung 2 note frequency at octave. Rung 3 abstract semantic evaluation. Same shape."
     :meta "Symbolic-to-numeric is a universal bridging shape.")
    (:eng "Every symbolic system has a bridge to numeric." :math "Evaluation function of a symbolic form." :cs "The 'run' side of a compile/run pair."))
  :row-4-proof (
    (:claim "sym/evaluate preserves addition: (evaluate (add p q) x) = (evaluate p x) + (evaluate q x)."
     :program "(define p (sym/poly '(1 2)))\n(define q (sym/poly '(3 -1)))\n(define x 4)\n(= (sym/evaluate (sym/add p q) x) (+ (sym/evaluate p x) (sym/evaluate q x)))"
     :invariant "∀ p q x. eval(p+q, x) = eval(p, x) + eval(q, x)"
     :meta "Pattern: evaluation is a ring homomorphism at each point x. Falsifies if any triple breaks. See book-of-math ch on evaluation homomorphisms.")
    (:eng "The homomorphism condition means eval commutes with add." :math "Evaluation-at-x is a ring homomorphism Poly → ℝ." :cs "Homomorphism-respecting evaluators can be swapped in optimization passes."))
  :row-5-emergence (
    (:base "sym/evaluate computes p(x)."
     :composition "(define (newton-step p x) (let ((dp (sym/derivative p))) (- x (/ (sym/evaluate p x) (sym/evaluate dp x)))))\n(define (newton-roots p x0 iters) (let loop ((x x0) (i 0)) (if (>= i iters) x (loop (newton-step p x) (+ i 1)))))\n(newton-roots (sym/poly '(-2 0 1)) 1.0 10)"
     :emergent "Newton's method — iterative root-finder built from derivative and evaluate."
     :meta "Family: iterative-solver. Same shape as gradient descent, Picard iteration, or fixed-point iteration. See book-of-composition ch on iterative solvers.")
    (:eng "The pattern converges toward √2 as a demonstration of numerical methods." :math "Newton iteration x_{n+1} = x_n - f(x_n)/f'(x_n)." :cs "Iterative-solver pattern is the base of numerical analysis."))

(verb
  :name "sym/expand"
  :library "sym"
  :kind "meta"
  :signature "(sym/expand poly) -> poly"
  :summary "Normalize a product or power to a canonical expanded sum; rejects non-polynomials."
  :explanation "When you multiply polynomials or raise one to a power, the result is usually nested and hard to read. `sym/expand` flattens it into a clean sum-of-monomials form, with like terms combined and zero terms dropped. This is essential before comparing two expressions for equality or extracting coefficients. Non-polynomial inputs (like invalid data) return the sentinel value 'nan."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define p (sym/mul (sym/poly '(1 1)) (sym/poly '(2 1))))\n(sym/expand p)" :note "Multiply (1+x)·(2+x), then expand to see 2+3x+x²")
    (:dialect "motoi" :tier "intermediate" :code "(define p (sym/pow (sym/poly '(1 1)) 3))\n(sym/expand p)" :note "Cube (1+x) → expand yields 1+3x+3x²+x³")
    (:dialect "motoi" :tier "expert" :code "(define f (sym/poly '(-1 0 1)))\n(define g (sym/substitute f (sym/poly '(0 1))))\n(sym/expand g)" :note "Substitute x→x into x²−1, then expand; composing and normalizing in one step")
  )
  :caveats ("Input must be a valid polynomial; 'nan is returned silently for invalid input." "Expansion is idempotent: expanding twice gives the same result." "Zero polynomial is returned as the zero list, not dropped entirely.")
  :drawbacks ("Expansion can produce large intermediate expressions before trimming; cost grows with degree and nesting depth." "If you only need evaluation at a point, use `sym/evaluate` (Horner's method) instead for speed.")
  :usecases ("Preparing polynomials for comparison with `sym/=`." "Extracting coefficients via `sym/coeff` after simplification." "Solving or factoring after combining multiple operations.")
  :related ("sym/mul" "sym/pow" "sym/evaluate" "sym/coeff" "sym/=")
  :learn (:concept "Canonical form: why polynomials need a normal representation for reasoning and comparison." :prerequisites ("sym/poly" "sym/mul") :progression "Learn `sym/coeff` to extract terms after expansion; then `sym/derivative` to work with expanded polynomials symbolically.")
  :row-2-audit (
    (:problem "A cortex/algebra-checker wants to verify two symbolic expressions equal after algebraic manipulation."
     :program "(define lhs (sym/pow (sym/poly '(1 1)) 2))\n(define rhs (sym/poly '(1 2 1)))\n(sym/= (sym/expand lhs) rhs)"
     :explanation "Line 1 defines (1+x)². Line 2 defines 1+2x+x². Line 3 expands lhs then compares; returns #t because the expansion matches."
     :meta "Reach for sym/expand and NOT direct sym/= comparison: raw polynomials from sym/pow may carry non-canonical form. sym/expand normalizes before compare.")
    (:eng "The checker log records the normalization step." :math "sym/expand is the canonical-form retract." :cs "Meta; O(degree²)."))
  :row-3-dimension (
    (:setup "Normalization to canonical form."
     :rungs (
       (:domain "sym"     :code "(sym/expand p)")
       (:domain "text (metaphor)" :code "(text/canonicalize-unicode s)")
       (:domain "algebra"    :code "canonical: A → A/≡"))
     :explanation "Rung 1 poly canonical form. Rung 2 unicode canonical form. Rung 3 abstract canonicalization. Same shape."
     :meta "Canonicalization transfers to any type with a quotient.")
    (:eng "Canonical forms enable equality tests to be correct." :math "Section of the canonical quotient." :cs "Canonical form is the base of every equality-decidable type."))
  :row-4-proof (
    (:claim "sym/expand is idempotent: expanding twice equals expanding once."
     :program "(define p (sym/mul (sym/poly '(1 1)) (sym/poly '(2 1))))\n(sym/= (sym/expand (sym/expand p)) (sym/expand p))"
     :invariant "∀ p. expand(expand(p)) = expand(p)"
     :meta "Pattern: idempotent normalization. Falsifies if any polynomial changes on second expansion. See book-of-code ch on canonical-form idempotence.")
    (:eng "Idempotence lets pipelines re-run expansion without harm." :math "The retract onto canonical form." :cs "Idempotent normalizers can be cached."))
  :row-5-emergence (
    (:base "sym/expand normalizes a polynomial expression."
     :composition "(define (identity? lhs rhs) (sym/= (sym/expand lhs) (sym/expand rhs)))\n(identity? (sym/mul (sym/poly '(1 1)) (sym/poly '(-1 1))) (sym/poly '(-1 0 1)))"
     :emergent "algebraic-identity prover — expand both sides, then compare."
     :meta "Family: normalize-then-compare. Same shape as case-insensitive string compare or floating-point epsilon-compare with rounding. See book-of-composition ch on canonical-form comparison.")
    (:eng "The pattern is the base of every teaching-tool algebra checker." :math "Realizes decidability of polynomial equality via canonical form." :cs "Normalize-then-compare is a canonical shape."))

(verb
  :name "sym/factor"
  :library "sym"
  :kind "meta"
  :signature "(sym/factor poly) -> poly-list-or-escalate"
  :summary "Factor a quadratic polynomial into linear factors over the rationals; escalates if roots are irrational or complex."
  :explanation "Factoring is the inverse of expansion: `(x-r₁)(x-r₂)` factors back to `x²−(r₁+r₂)x+r₁r₂`. This verb solves the quadratic and reconstructs the factored form *only if both roots are rational*. If the discriminant is negative or irrational, the expression is irreducible over ℚ and an `'irreducible` escalation is raised. Use this to understand the roots of a polynomial geometrically or to simplify rational expressions."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/factor (sym/poly '(-6 1 1)))" :note "x²+x−6 factors to (x−2)(x+3); returns the two linear factors")
    (:dialect "motoi" :tier "intermediate" :code "(define roots\n  (if (null? (sym/factor (sym/poly '(1 0 1))))\n      '(complex-roots)\n      (sym/factor (sym/poly '(1 0 1)))))\nroots" :note "x²+1 has no real factorization; safely handle the escalation")
    (:dialect "motoi" :tier "expert" :code "(define (find-intercepts a b c)\n  (let ((quad (sym/poly (list c b a))))\n    (sym/factor quad)))\n(find-intercepts 1 -5 6)" :note "Helper to find x-intercepts of a parabola by factoring; roots are 2 and 3")
  )
  :caveats ("Only works for quadratic polynomials; higher degree polynomials will escalate 'irreducible." "Roots must be rational; irrational or complex roots raise 'irreducible rather than returning a partial answer." "Output is a list of linear factors, not a single expression.")
  :drawbacks ("Limited to quadratics; use numerical solvers (e.g., `solve/quadratic`) for higher degrees or real-world data." "Factoring over the reals (irrational roots) is not supported; only rational factorization is available.")
  :usecases ("Finding rational roots of quadratic equations." "Simplifying rational functions by canceling common factors." "Understanding the geometry of a parabola (where it crosses the x-axis).")
  :related ("sym/solve-quadratic" "sym/expand" "sym/poly" "sym/coeff")
  :learn (:concept "Factorization as the inverse of expansion; when and why factorization may fail." :prerequisites ("sym/poly" "sym/solve-quadratic") :progression "Use `sym/factor` to understand roots; then compose with `sym/substitute` to transform polynomials.")
  :row-2-audit (
    (:problem "A game/math-puzzle asks the student to factor x²+x-6; the operator uses sym/factor to compute the reference solution."
     :program "(sym/factor (sym/poly '(-6 1 1)))"
     :explanation "Returns the two linear factors (x-2) and (x+3). The puzzle-checker uses these to grade student answers."
     :meta "Reach for sym/factor and NOT sym/solve-quadratic: solve-quadratic gives root numbers; factor gives the linear-factor representation directly, closer to student presentation.")
    (:eng "The puzzle log records the reference factorization." :math "Factorization inverts expansion when roots are rational." :cs "Meta; only quadratics; over ℚ."))
  :row-3-dimension (
    (:setup "Structure decomposition into simpler multiplicative units."
     :rungs (
       (:domain "sym"    :code "(sym/factor p)")
       (:domain "nt (metaphor)" :code "(nt/prime-factors n)")
       (:domain "algebra"    :code "p = ∏ pᵢ (unique factorization)"))
     :explanation "Rung 1 polynomial into linear factors. Rung 2 integer into primes. Rung 3 abstract unique factorization. Same shape."
     :meta "Factorization is a universal shape wherever a UFD exists.")
    (:eng "Factorization appears in every algebraic-teaching lane." :math "Structure of a unique factorization domain." :cs "Base of decomposition-based algorithms."))
  :row-4-proof (
    (:claim "sym/factor is a right-inverse of expansion: expanding the product of the factors returns the original polynomial (when factorable)."
     :program "(define p (sym/poly '(-6 1 1)))\n(define factors (sym/factor p))\n(if (null? factors) 'not-tested (sym/= (sym/expand (foldr sym/mul (sym/const 1) factors)) p))\n(define (foldr f init xs) (if (null? xs) init (f (car xs) (foldr f init (cdr xs)))))"
     :invariant "∀ factorable p. expand(∏ factors(p)) = p"
     :meta "Pattern: right-inverse via reconstruction. Falsifies if any factorable polynomial fails reconstruction. See book-of-math ch on polynomial factorization.")
    (:eng "The invariant lets ops verify the factorization by re-expanding." :math "Factor and expand are semi-inverses." :cs "Reconstruction-verification is a base of correctness testing."))
  :row-5-emergence (
    (:base "sym/factor decomposes a quadratic into linear factors."
     :composition "(define (find-x-intercepts a b c) (let ((poly (sym/poly (list c b a)))) (let ((f (sym/factor poly))) (if (null? f) 'no-rational-intercepts f))))\n(find-x-intercepts 1 -5 6)"
     :emergent "geometric intercept-finder — factor the parabola equation to find x-intercepts as the roots of each linear factor."
     :meta "Family: root-finder via factorization. Same shape as finding zeros of a rational function or crossings of a piecewise-linear function. See book-of-composition ch on root-finders.")
    (:eng "The pattern connects algebra (factoring) to geometry (intercepts)." :math "Realizes the geometric root-finding via algebraic factorization." :cs "Factorization-to-roots is a base of teaching algebra-geometry links."))

(verb
  :name "sym/mul"
  :library "sym"
  :kind "meta"
  :signature "(sym/mul poly1 poly2) -> poly"
  :summary "Multiply two polynomials and fully expand the result; rejects non-polynomial operands."
  :explanation "Polynomial multiplication distributes each term of the first polynomial across all terms of the second, then combines like terms by degree. This verb does the full expansion in one call, so the result is canonical and ready for comparison or analysis. Use `sym/mul` when you need both the product and its simplified form; if you just want intermediate products before further operations, you may compose it with `sym/expand` or `sym/pow`."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/mul (sym/poly '(1 1)) (sym/poly '(2 1)))" :note "Multiply (1+x)·(2+x) → 2+3x+x² in one call")
    (:dialect "motoi" :tier "intermediate" :code "(define p (sym/poly '(0 1)))\n(define q (sym/mul p (sym/poly '(1 1))))\n(sym/expand q)" :note "Multiply x·(1+x) → x+x², then expand (already canonical)")
    (:dialect "motoi" :tier "expert" :code "(define (poly-chain-mult poly-list)\n  (if (null? (cdr poly-list))\n      (car poly-list)\n      (sym/mul (car poly-list) (poly-chain-mult (cdr poly-list)))))\n(poly-chain-mult (list (sym/poly '(1 1)) (sym/poly '(1 1)) (sym/poly '(2 1))))" :note "Fold `sym/mul` over a list to compute (1+x)·(1+x)·(2+x) recursively")
  )
  :caveats ("Both operands must be valid polynomials; 'nan is returned for invalid input." "The result is automatically expanded; there is no separate multiply-without-expand." "Degree of result is the sum of input degrees; large degrees grow memory cost quickly.")
  :drawbacks ("Expansion during multiplication can be slow for high-degree polynomials (cost is O(d₁·d₂))." "If you only need to evaluate the product at a point, use `sym/evaluate` with `sym/substitute` for better performance.")
  :usecases ("Building polynomials from linear factors: multiply (x−r₁)·(x−r₂)·…" "Computing powers via repeated multiplication (or use `sym/pow` directly)." "Combining two polynomial constraints or modeling interactions.")
  :related ("sym/pow" "sym/expand" "sym/evaluate" "sym/poly" "sym/add")
  :learn (:concept "Distributive law as the foundation of symbolic algebra; why expansion is necessary after multiplication." :prerequisites ("sym/poly" "sym/add") :progression "Master `sym/mul`; then use `sym/pow` for repeated multiplication and `sym/substitute` for composition.")
  :row-2-audit (
    (:problem "A math/algebra step wants (1+x)(2+x) shown fully expanded for a teaching display."
     :program "(sym/->string (sym/mul (sym/poly '(1 1)) (sym/poly '(2 1))))"
     :explanation "Line 1 multiplies (1+x)(2+x) and renders as \"x^2 + 3x + 2\". The teacher can walk the student through each term's origin."
     :meta "Reach for sym/mul and NOT nested sym/add + sym/scale: mul is one call and produces the canonical expanded form.")
    (:eng "The teaching log records the product." :math "sym/mul is the ring product." :cs "Meta; O(d₁ · d₂)."))
  :row-3-dimension (
    (:setup "Ring multiplication: combine two elements under distribution."
     :rungs (
       (:domain "sym"    :code "(sym/mul p q)")
       (:domain "matrix (metaphor)" :code "(matrix/mul A B)")
       (:domain "algebra"    :code "a·b in a ring (A, +, ·)"))
     :explanation "Rung 1 polynomial product. Rung 2 matrix product. Rung 3 abstract ring product. Same shape."
     :meta "Ring multiplication transfers to any distributive ring.")
    (:eng "Ring multiplication appears across algebra." :math "Ring axiom on multiplication." :cs "Convolution-based when both operands are polynomials."))
  :row-4-proof (
    (:claim "sym/mul is commutative and associative."
     :program "(define p (sym/poly '(1 2)))\n(define q (sym/poly '(3 -1)))\n(define r (sym/poly '(0 1 1)))\n(and (sym/= (sym/mul p q) (sym/mul q p)) (sym/= (sym/mul (sym/mul p q) r) (sym/mul p (sym/mul q r))))"
     :invariant "∀ p q. p·q = q·p ∧ ∀ p q r. (p·q)·r = p·(q·r)"
     :meta "Pattern: commutative-monoid laws for multiplication. Falsifies if any triple breaks. See book-of-math ch on ring axioms.")
    (:eng "Associativity/commutativity let fold-mul over polynomials use any order." :math "Commutative-ring multiplication." :cs "Commutative-monoid laws enable parallel reduction."))
  :row-5-emergence (
    (:base "sym/mul multiplies polynomials with full expansion."
     :composition "(define (product-of-linear-factors roots) (let loop ((rest roots) (acc (sym/const 1))) (if (null? rest) acc (loop (cdr rest) (sym/mul acc (sym/sub (sym/var 'x) (sym/const (car rest))))))))\n(sym/->string (product-of-linear-factors (list 1 2 3)))"
     :emergent "polynomial-from-roots — repeated multiplication of (x-rᵢ) builds a polynomial with prescribed roots."
     :meta "Family: constructor-from-atoms. Same shape as building a graph from edges or a formula from clauses. See book-of-composition ch on atom-based construction.")
    (:eng "The pattern shows how a polynomial designs itself from its zeros." :math "Realizes the factor theorem: p(x) = ∏(x-rᵢ) up to leading constant." :cs "Base of teaching root/factor duality."))

(verb
  :name "sym/poly"
  :library "sym"
  :kind "meta"
  :signature "(sym/poly coeff-list) -> poly"
  :summary "Construct a polynomial from a list of coefficients in low-order-first order; rejects non-numeric coefficients."
  :explanation "A polynomial is represented internally as a coefficient vector. `sym/poly` builds this from a list where the first element is the constant term, the second is the coefficient of x, the third is the coefficient of x², and so on. This is the primary way to create polynomial objects for use with other `sym/*` verbs. The list `(3 2 1)` represents `3 + 2x + x²`. Non-numeric coefficients or malformed input returns 'nan."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/poly '(1 2 3))" :note "Create the polynomial 1 + 2x + 3x²")
    (:dialect "motoi" :tier "intermediate" :code "(define const-term 5)\n(define coeff-x 3)\n(define coeff-x2 2)\n(sym/poly (list const-term coeff-x coeff-x2))" :note "Build 5 + 3x + 2x² from individual variables")
    (:dialect "motoi" :tier "expert" :code "(define (make-from-roots roots)\n  (if (null? roots)\n      (sym/poly '(1))\n      (sym/mul (sym/poly (list (- (car roots)) 1))\n               (make-from-roots (cdr roots)))))\n(make-from-roots '(2 3))" :note "Recursively multiply (x−2)·(x−3) to build from roots; each factor created via `sym/poly`")
  )
  :caveats ("Coefficients must be numeric; symbolic or non-numeric values are rejected with 'nan." "Order is low-degree-first: (c₀ c₁ c₂ …) represents c₀ + c₁·x + c₂·x² + …" "Trailing zeros are silently trimmed, so '(1 2 0 0) becomes equivalent to '(1 2).")
  :drawbacks ("Very high-degree polynomials (thousands of terms) consume memory proportionally." "If you have a polynomial in string form, you must parse it manually first; no parser is provided.")
  :usecases ("Creating test polynomials by hand for learning or debugging." "Building polynomials programmatically from a data source (e.g., fitted coefficients)." "Foundation for all other `sym/*` operations.")
  :related ("sym/coeff" "sym/degree" "sym/expand" "sym/->string")
  :learn (:concept "Polynomial representation: coefficient vectors and the low-order-first convention." :prerequisites ("core list operations: cons, car, cdr") :progression "Build a polynomial with `sym/poly`, inspect it with `sym/degree` and `sym/coeff`, then operate with `sym/add`, `sym/mul`, `sym/expand`.")
  :row-2-audit (
    (:problem "A stat/fit routine returns a coefficient list; the operator wraps it as a polynomial before evaluation and display."
     :program "(define coeffs (list 0.5 1.2 -0.3))\n(define fit (sym/poly coeffs))\n(sym/->string fit)"
     :explanation "Line 1 has the raw fit output. Line 2 wraps as poly. Line 3 renders as \"-0.3x^2 + 1.2x + 0.5\"."
     :meta "Reach for sym/poly and NOT constructing via repeated sym/add + sym/scale: sym/poly takes the coefficient list directly and is O(1) allocation.")
    (:eng "The fit log records the polynomial in canonical form." :math "sym/poly is the constructor of Poly from a coefficient sequence." :cs "Meta; O(1) or O(degree) depending on representation."))
  :row-3-dimension (
    (:setup "Constructor from a coefficient vector."
     :rungs (
       (:domain "sym"    :code "(sym/poly '(1 2 3))")
       (:domain "vec (metaphor)" :code "(vec/from-list '(1 2 3))")
       (:domain "algebra"   :code "poly: ℝ^n → Poly"))
     :explanation "Rung 1 poly constructor. Rung 2 vector constructor. Rung 3 abstract type constructor. Same shape."
     :meta "Constructors from vectors transfer wherever the type is coefficient-based.")
    (:eng "Constructor patterns appear in every type-lift." :math "Data-to-type constructor." :cs "Foundation for algebraic type construction."))
  :row-4-proof (
    (:claim "sym/poly and sym/coeff are inverses: for a valid coefficient list, extracting each coefficient reproduces the list (up to trailing-zero trimming)."
     :program "(define lst '(1 2 3))\n(define p (sym/poly lst))\n(let loop ((k 0) (acc '())) (if (> k (sym/degree p)) (equal? (reverse acc) lst) (loop (+ k 1) (cons (sym/coeff p k) acc))))"
     :invariant "∀ lst. lst has no trailing zeros → coeff(poly(lst), k) = lst[k] for k ≤ deg"
     :meta "Pattern: constructor-projector round-trip. Falsifies if extraction disagrees with input. See book-of-code ch on ADT round-trip laws.")
    (:eng "The round-trip law is what makes coefficient-manipulation reliable." :math "poly and coeff are semi-inverses." :cs "Round-trip laws are the base of ADT correctness."))
  :row-5-emergence (
    (:base "sym/poly constructs a polynomial from coefficients."
     :composition "(define (fit-then-eval coeffs x) (let ((p (sym/poly coeffs))) (sym/evaluate p x)))\n(fit-then-eval '(0.5 1.2 -0.3) 2.0)"
     :emergent "fit-evaluate pipeline — construct a polynomial from coefficients then evaluate at a point."
     :meta "Family: construct-then-use pipeline. Same shape as any type-lift followed by an operation. See book-of-composition ch on constructor pipelines.")
    (:eng "The pattern is a canonical fit-then-use shape." :math "Realizes composed constructor-and-evaluator." :cs "Constructor pipelines are the base of type-first design."))

(verb
  :name "sym/pow"
  :library "sym"
  :kind "meta"
  :signature "(sym/pow poly exponent) -> poly"
  :summary "Raise a polynomial to a non-negative integer power and return the fully expanded result; escalates on invalid exponent."
  :explanation "Raising a polynomial to an integer power is repeated multiplication. `sym/pow` handles this efficiently: `(sym/pow (sym/poly '(1 1)) 2)` gives `(1+x)²`, which expands to `1+2x+x²`. The exponent must be a non-negative integer; negative exponents or non-integer values cause an `'bad-exponent` escalation. The result is always fully expanded and canonical."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/pow (sym/poly '(1 1)) 2)" :note "Square (1+x) → 1+2x+x²")
    (:dialect "motoi" :tier "intermediate" :code "(define linear (sym/poly '(-1 1)))\n(sym/pow linear 3)" :note "Cube (x−1) → x³−3x²+3x−1")
    (:dialect "motoi" :tier "expert" :code "(define (binomial-expansion n k)\n  (let ((p (sym/poly (list 1 1))))\n    (sym/coeff (sym/pow p n) k)))\n(binomial-expansion 5 2)" :note "Extract the binomial coefficient C(5,2) from (1+x)⁵ by taking the x² coefficient")
  )
  :caveats ("Exponent must be a non-negative integer; fractional, negative, or non-numeric exponents escalate 'bad-exponent." "Exponent 0 returns the constant polynomial 1." "High exponents (e.g., 100) can produce very high-degree polynomials; use with care on memory.")
  :drawbacks ("For large exponents, the result polynomial has O(degree·exponent) terms, which grows quickly." "If you only need to evaluate the power at a point, use `sym/evaluate` for speed instead.")
  :usecases ("Expanding binomial expressions for combinatorics (read coefficients as binomial numbers)." "Building polynomial equations from repeated roots: `(sym/pow (sym/poly '(-r 1)) mult)`." "Symbolic calculus: computing derivatives or integrals of powers.")
  :related ("sym/mul" "sym/evaluate" "sym/expand" "sym/coeff")
  :learn (:concept "Repeated multiplication and exponentiation in the symbolic domain; connection to combinatorics." :prerequisites ("sym/poly" "sym/mul") :progression "Use `sym/pow` to generate polynomials, then extract coefficients with `sym/coeff` or compute derivatives with `sym/derivative`.")
  :row-2-audit (
    (:problem "A comb/prover displays (1+x)⁵ fully expanded to show that its coefficients equal Pascal's row 5."
     :program "(sym/->string (sym/pow (sym/poly '(1 1)) 5))"
     :explanation "Expands to \"x^5 + 5x^4 + 10x^3 + 10x^2 + 5x + 1\" — matching Pascal row 5."
     :meta "Reach for sym/pow and NOT repeated sym/mul: pow uses fast-exponentiation internally and is one call.")
    (:eng "The prover log records the expanded form." :math "sym/pow raises a polynomial to an integer power." :cs "Meta; O(log n · degree)."))
  :row-3-dimension (
    (:setup "Repeated composition of a binary operation."
     :rungs (
       (:domain "sym"    :code "(sym/pow p n)")
       (:domain "matrix (metaphor)" :code "(matrix/pow M n)")
       (:domain "algebra"    :code "aⁿ in a monoid"))
     :explanation "Rung 1 polynomial power. Rung 2 matrix power. Rung 3 abstract monoid power. Same shape."
     :meta "Repeated-operation transfer to any monoid.")
    (:eng "Repeated operations appear across matrix, poly, and group theory." :math "Monoid exponentiation." :cs "Fast-exponentiation is a base optimization."))
  :row-4-proof (
    (:claim "sym/pow satisfies aⁿ · aᵐ = aⁿ⁺ᵐ."
     :program "(define p (sym/poly '(1 1)))\n(define n 3)\n(define m 2)\n(sym/= (sym/mul (sym/pow p n) (sym/pow p m)) (sym/pow p (+ n m)))"
     :invariant "∀ p n m ∈ ℕ. pⁿ · pᵐ = pⁿ⁺ᵐ"
     :meta "Pattern: exponentiation-addition identity. Falsifies if any triple breaks. See book-of-math ch on monoid exponentiation.")
    (:eng "The identity lets exponents be combined without intermediate expansion." :math "Exponentiation is a monoid homomorphism (ℕ, +) → (Poly, ·)." :cs "Fast-power algorithms rely on this identity."))
  :row-5-emergence (
    (:base "sym/pow raises a polynomial to a power."
     :composition "(define (binomial-verify n) (map (lambda (k) (list 'C n k (sym/coeff (sym/pow (sym/poly '(1 1)) n) k))) (list 0 1 2 3 4 5)))\n(binomial-verify 5)"
     :emergent "Pascal-verifier — extract each coefficient of (1+x)ⁿ to confirm it equals C(n,k)."
     :meta "Family: cross-verb consistency check. Same shape as verifying identities across libraries. See book-of-composition ch on cross-library invariants.")
    (:eng "The pattern lets ops verify comb and sym agree on binomial coefficients." :math "Realizes the binomial theorem: (1+x)ⁿ = Σ C(n,k) xᵏ." :cs "Cross-verb identity checking is a base for correctness testing."))

(verb
  :name "sym/scale"
  :library "sym"
  :kind "meta"
  :signature "(sym/scale poly scalar) -> poly"
  :summary "Multiply every coefficient of a polynomial by a scalar constant; rejects non-numeric scalars."
  :explanation "Scaling is a simpler operation than multiplication: rather than distributing across two polynomials, you just multiply each coefficient by a single number. This is useful for normalization (e.g., making the leading coefficient 1), or for algebraic manipulations like `2p(x) - 3q(x)`. The scalar must be numeric; non-numeric or invalid input returns 'nan."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/scale (sym/poly '(2 4 6)) 0.5)" :note "Scale 2+4x+6x² by 0.5 → 1+2x+3x²")
    (:dialect "motoi" :tier "intermediate" :code "(define p (sym/poly '(0 3 -6)))\n(define monic (sym/scale p (/ 1 -6)))\nmonic" :note "Normalize 3x−6x² to monic form by dividing by the leading coefficient")
    (:dialect "motoi" :tier "expert" :code "(define (linear-combination a p b q)\n  (sym/add (sym/scale p a) (sym/scale q b)))\n(linear-combination 2 (sym/poly '(1 1)) 3 (sym/poly '(1 0 1)))" :note "Compute 2p + 3q where p=1+x and q=1+x²")
  )
  :caveats ("Scalar must be numeric; 'nan is returned for non-numeric or non-number input." "Scaling by 0 returns the zero polynomial." "Scaling does not change the degree of the polynomial (except when scaled by 0).")
  :drawbacks ("For simple coefficient manipulation, direct list construction with `sym/poly` may be faster." "Scaling is a lighter operation than multiplication, but if you're combining multiple scaled polynomials, use `sym/add` or `sym/sub` for efficiency.")
  :usecases ("Normalizing polynomials (making the leading coefficient 1)." "Computing linear combinations: `a·p(x) + b·q(x)` as a step toward building new polynomials." "Solving or simplifying equations: dividing both sides by a constant.")
  :related ("sym/mul" "sym/add" "sym/sub" "sym/poly")
  :learn (:concept "Scalar multiplication as the simplest form of polynomial algebra; foundation for linear combinations." :prerequisites ("sym/poly") :progression "Use `sym/scale` in `sym/add` and `sym/sub` to build linear combinations; then move to `sym/mul` for multiplication.")
  :row-2-audit (
    (:problem "A math/normalize routine converts a polynomial to monic form by dividing by its leading coefficient."
     :program "(define p (sym/poly '(4 8 12)))\n(define lead (sym/coeff p (sym/degree p)))\n(sym/->string (sym/scale p (/ 1 lead)))"
     :explanation "Line 1 defines 12x²+8x+4. Line 2 extracts 12. Line 3 scales by 1/12, yielding \"x^2 + (2/3)x + (1/3)\". Monic form."
     :meta "Reach for sym/scale and NOT sym/mul with (sym/const c): scale is O(degree); mul with constant is heavier and unnecessary.")
    (:eng "The normalize log records the scaling factor." :math "sym/scale is scalar multiplication by a ring element." :cs "Meta; O(degree)."))
  :row-3-dimension (
    (:setup "Scalar multiplication in a module."
     :rungs (
       (:domain "sym"    :code "(sym/scale p c)")
       (:domain "vec (metaphor)" :code "(vec/scale v c)")
       (:domain "algebra"    :code "c · x in a module"))
     :explanation "Rung 1 polynomial scaling. Rung 2 vector scaling. Rung 3 abstract scalar action. Same shape."
     :meta "Scalar-action transfers to any module structure.")
    (:eng "Scaling appears in every linear algebra domain." :math "Module scalar multiplication." :cs "Distributes over addition."))
  :row-4-proof (
    (:claim "sym/scale distributes over addition: c·(p+q) = c·p + c·q."
     :program "(define p (sym/poly '(1 2)))\n(define q (sym/poly '(3 -1)))\n(define c 2)\n(sym/= (sym/scale (sym/add p q) c) (sym/add (sym/scale p c) (sym/scale q c)))"
     :invariant "∀ p q c. c·(p+q) = c·p + c·q"
     :meta "Pattern: linearity of scalar multiplication. Falsifies if any triple breaks. See book-of-math ch on module axioms.")
    (:eng "Distribution over addition enables early folding for optimization." :math "Module linearity." :cs "Linear operators support batch application."))
  :row-5-emergence (
    (:base "sym/scale multiplies coefficients by a scalar."
     :composition "(define (lin-combo a p b q) (sym/add (sym/scale p a) (sym/scale q b)))\n(sym/->string (lin-combo 2 (sym/poly '(1 1)) -1 (sym/poly '(0 1 1))))"
     :emergent "linear-combination builder — combine scale and add to make ap + bq."
     :meta "Family: linear-combination. Same shape as building a weighted average or a Gram matrix entry. See book-of-composition ch on linear combinations.")
    (:eng "The pattern is the base of every linear-algebra computation." :math "Realizes the module operation a·x + b·y." :cs "Linear-combination is a core reduction shape."))

(verb
  :name "sym/solve-ineq"
  :library "sym"
  :kind "meta"
  :signature "(sym/solve-ineq a b op) -> interval-list | 'nan"
  :summary "Solve a linear inequality a·x ⧀ b where ⧀ is one of <, >, <=, >=; return interval as a-list."
  :explanation "sym/solve-ineq is a symbolic algebra verb that solves linear inequalities in one variable. Given coefficients a and b, and an operator (symbol 'lt, 'gt, 'le, 'ge), it solves a·x ⧀ b and returns the solution set as a list of interval bounds. If a = 0 and b ≠ 0, the inequality is unsolvable (inconsistent or always-false) and returns the symbol 'nan. If a = 0 and b = 0, all x satisfy it (or none, depending on the operator). The verb owns the \"flip rule\": when a < 0, the inequality direction reverses (x > b/a instead of x < b/a). This is a meta verb—it reasons about symbolic structure, not a concrete computation."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/solve-ineq 2 8 'le)" :note "Solve 2x ≤ 8 → x ≤ 4 → interval '(-inf 4].")
    (:dialect "motoi" :tier "intermediate" :code "(define (feasible? x a b op)\n  (let ((interval (sym/solve-ineq a b op)))\n    (and (not (eq? interval 'nan))\n         (or (and (symbol? (car interval)) (member x (cdr interval)))\n             (and (number? (car interval))\n                  (>= x (car interval))\n                  (<= x (cadr interval)))))))\n(feasible? 5 3 12 'le)" :note "Check if a value x lies in the solution interval of 3x ≤ 12.")
    (:dialect "motoi" :tier "expert" :code "(define (constrain-variables eqs-and-ops)\n  (map (lambda (eq-op-pair)\n    (let* ((a (car (car eq-op-pair)))\n           (b (cadr (car eq-op-pair)))\n           (op (cadr eq-op-pair))\n           (interval (sym/solve-ineq a b op)))\n      (list a b op interval)))\n    eqs-and-ops))\n(constrain-variables (list (list (list -2 16) 'ge) (list (list 3 9) 'lt)))" :note "Solve a system of linear inequalities by collecting solution intervals; compose with constraint intersection.")
  )
  :caveats ("Only handles linear inequalities (degree 1 in x); nonlinear or multi-variable cases return error or undefined." "Operator must be a symbol: 'lt, 'gt, 'le, 'ge; other symbols or string operators may not be recognized." "Returns interval as an a-list or symbolic bounds; parsing the result requires checking for 'nan and inspecting the list structure." "a = 0 case: returns 'nan if inconsistent, or all x (unbounded) if the inequality is always true; behavior depends on b and op.")
  :drawbacks ("No built-in pretty-printing of intervals; you must format results for display." "Cannot solve systems of inequalities directly; must call sym/solve-ineq per inequality and intersect manually." "No parametric or symbolic parameters (e.g., 'solve ax + b ≤ cx + d'); a and b must be concrete numbers." "Interval representation is opaque; no standard comparison predicates to test membership.")
  :usecases ("Curriculum math: solve word problems involving inequalities (budgets, constraints)." "Game balance: compute valid ranges for weapon damage or resource thresholds." "Constraint solving: find feasible regions for player movement or AI behavior parameters." "Educational tools: symbolically show step-by-step inequality reasoning.")
  :related ("sym/*" "calc/series-converges?" "calc/radius-of-convergence" "math/*")
  :learn (:concept "Symbolic algebra: the flip-on-negative rule for inequalities; interval notation as solution representation." :prerequisites ("linear equations" "inequality semantics") :progression "After sym/solve-ineq, explore sym/* (other symbolic verbs), then calc/* for calculus-level constraint solving.")
  :row-2-audit (
    (:problem "A game/budget checker solves 3x ≤ 12 to find the max valid item count x that fits the budget."
     :program "(sym/solve-ineq 3 12 'le)"
     :explanation "Returns the interval representation of x ≤ 4. The checker uses this to bound the item-count slider UI."
     :meta "Reach for sym/solve-ineq and NOT (/ b a): the direct division misses the flip-on-negative rule for a < 0.")
    (:eng "The budget-check log records the solution interval." :math "sym/solve-ineq solves ax ⧀ b for x." :cs "Meta; handles the flip-on-negative-a rule internally."))
  :row-3-dimension (
    (:setup "Constraint-to-region transformation."
     :rungs (
       (:domain "sym"    :code "(sym/solve-ineq 2 10 'le)")
       (:domain "phys (metaphor)" :code "(phys/solve-collision-region a b)")
       (:domain "logic"    :code "solve φ(x) yields feasible-set"))
     :explanation "Rung 1 inequality interval. Rung 2 collision region. Rung 3 abstract feasibility region. Same shape."
     :meta "Constraint-to-region transfers to any constraint domain.")
    (:eng "Bounds-checkers, feasibility solvers, and region queries share this shape." :math "Solution set of an inequality." :cs "Base of constraint programming."))
  :row-4-proof (
    (:claim "For a > 0, solving ax ≤ b gives x ≤ b/a; for a < 0, the sign flips to x ≥ b/a."
     :program "(define pos-result (sym/solve-ineq 3 12 'le))\n(define neg-result (sym/solve-ineq -3 -12 'le))\n(and (not (eq? pos-result 'nan)) (not (eq? neg-result 'nan)))"
     :invariant "solve(a,b,≤) = { x : x ≤ b/a } if a>0 ; { x : x ≥ b/a } if a<0"
     :meta "Pattern: sign-dependent inequality direction. Falsifies if any negative-a case doesn't flip. See book-of-math ch on inequality algebra.")
    (:eng "The flip-on-negative rule is what solve-ineq owns for the operator." :math "Multiplication by a negative reverses inequality." :cs "Sign-guard is a base rule of ordered-field arithmetic."))
  :row-5-emergence (
    (:base "sym/solve-ineq gives the feasible set of a linear inequality."
     :composition "(define (feasible-region-and coeffs-b-op-list) (map (lambda (t) (sym/solve-ineq (car t) (cadr t) (caddr t))) coeffs-b-op-list))\n(feasible-region-and (list (list 2 10 'le) (list -1 -3 'ge)))"
     :emergent "system-of-inequalities region — combine intervals from multiple inequalities via intersection."
     :meta "Family: constraint intersection. Same shape as SQL WHERE clauses combined by AND or linear-programming feasibility. See book-of-composition ch on constraint composition.")
    (:eng "The pattern is a canonical constraint-conjunction shape." :math "Realizes the intersection of half-planes / intervals." :cs "Constraint-intersection is a base of feasibility solving."))

(verb
  :name "sym/solve-linear"
  :library "sym"
  :kind "meta"
  :signature "(sym/solve-linear poly) -> number-or-escalate"
  :summary "Solve a linear polynomial (degree 1) for its root; escalates if the equation has no unique solution or if degree > 1."
  :explanation "A linear polynomial `a·x + b` has exactly one root (when `a ≠ 0`): `x = −b/a`. This verb solves it symbolically and returns that root as a number. If the leading coefficient is zero (meaning the polynomial is constant or degenerate), the equation has no unique solution and an `'no-unique-solution` escalation is raised. If the polynomial has degree > 1, a `'not-linear` escalation is raised. Use this when you know your polynomial is linear and want a quick, exact answer."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/solve-linear (sym/poly '(3 2)))" :note "Solve 3+2x=0 → x=−3/2")
    (:dialect "motoi" :tier "intermediate" :code "(define (find-balance cost revenue)\n  (sym/solve-linear (sym/poly (list (- cost) revenue))))\n(find-balance 100 20)" :note "Find x where 20x=100 (break-even point): returns 5")
    (:dialect "motoi" :tier "expert" :code "(define (line-intercepts slope y-intercept axis)\n  (case axis\n    ((x) (sym/solve-linear (sym/poly (list y-intercept slope))))\n    ((y) y-intercept)\n    (else (escalate 'bad-axis))))\n(line-intercepts 3 -6 'x)" :note "Helper to find where y=3x−6 crosses the x-axis; returns 2")
  )
  :caveats ("Input must have degree exactly 1; higher degrees escalate 'not-linear." "If the leading coefficient is 0 (degenerate case), 'no-unique-solution is escalated." "The result is a single number (rational or as a float approximation), not a list.")
  :drawbacks ("Only handles linear equations; for higher degrees, use `sym/solve-quadratic` or a numerical solver." "If you need the solution as a polynomial or symbolic form, you must convert manually.")
  :usecases ("Solving linear equations from real-world problems (cost, time, distance)." "Finding x- or y-intercepts of lines." "Quick root-finding when you are confident the polynomial is degree 1.")
  :related ("sym/solve-quadratic" "sym/poly" "sym/factor" "sym/evaluate")
  :learn (:concept "Linear equations and their unique solution; when equations are degenerate." :prerequisites ("sym/poly" "sym/degree") :progression "Master `sym/solve-linear` for the simplest case; then learn `sym/solve-quadratic` for degree 2.")
  :row-2-audit (
    (:problem "A game/pricing routine finds the break-even quantity where 20q = 100."
     :program "(sym/solve-linear (sym/poly '(-100 20)))"
     :explanation "Line 1 defines -100+20q. Solving gives q=5: sell 5 units to break even."
     :meta "Reach for sym/solve-linear and NOT (/ b a): the direct division works but lacks the guard against degenerate a=0 that solve-linear handles.")
    (:eng "The pricing log records the break-even quantity." :math "sym/solve-linear finds the unique root of a linear polynomial." :cs "Meta; O(1)."))
  :row-3-dimension (
    (:setup "Solving a first-degree equation for its unique root."
     :rungs (
       (:domain "sym"    :code "(sym/solve-linear p)")
       (:domain "geom (metaphor)" :code "(geom/line-intersect-x line)")
       (:domain "algebra"    :code "solve: ax+b=0 → -b/a"))
     :explanation "Rung 1 linear root. Rung 2 line-x-intercept. Rung 3 abstract root-finding. Same shape."
     :meta "Linear-solve transfers wherever a first-degree equation appears.")
    (:eng "Break-even, intercept, and threshold problems share this shape." :math "Zero of a linear function." :cs "Foundation for higher-degree solvers."))
  :row-4-proof (
    (:claim "sym/solve-linear on ax+b returns -b/a; verifying by evaluation gives 0."
     :program "(define p (sym/poly '(6 -3)))\n(define r (sym/solve-linear p))\n(= (sym/evaluate p r) 0)"
     :invariant "∀ p linear with a≠0. eval(p, solve-linear(p)) = 0"
     :meta "Pattern: root-correctness. Falsifies if the solver returns a non-root. See book-of-math ch on linear equations.")
    (:eng "Root-check invariant lets ops verify the solver output cheaply." :math "The defining property of a root." :cs "Round-trip test is a base for solver validation."))
  :row-5-emergence (
    (:base "sym/solve-linear finds the root of a linear polynomial."
     :composition "(define (critical-point-of-quadratic q) (sym/solve-linear (sym/derivative q)))\n(critical-point-of-quadratic (sym/poly '(-1 3 2)))"
     :emergent "quadratic-vertex-finder — derivative of a quadratic is linear; solving = 0 gives the vertex x-coordinate."
     :meta "Family: derivative-solver pipeline. Same shape as any gradient-based optimization. See book-of-composition ch on optimization pipelines.")
    (:eng "The pattern is the base of every first-order optimization." :math "Realizes the extremum condition p'(x)=0." :cs "Derivative-solver is a base for symbolic optimization."))

(verb
  :name "sym/solve-quadratic"
  :library "sym"
  :kind "meta"
  :signature "(sym/solve-quadratic poly) -> number-list-or-escalate"
  :summary "Solve a quadratic polynomial (degree 2) for its real roots using the quadratic formula; escalates if roots are complex."
  :explanation "For a quadratic `a·x² + b·x + c`, the quadratic formula gives the roots via the discriminant `Δ = b² − 4ac`. If `Δ ≥ 0`, there are two real roots (possibly equal); if `Δ < 0`, the roots are complex. This verb returns the list of real roots if they exist, or escalates `'complex-roots` if the discriminant is negative. Use this to find where a parabola crosses the x-axis, or to solve any quadratic equation symbolically."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/solve-quadratic (sym/poly '(-6 1 1)))" :note "Solve x²+x−6=0 via the quadratic formula → (2 -3)")
    (:dialect "motoi" :tier "intermediate" :code "(define (projectile-landing-time v-y g)\n  (let ((quad (sym/poly (list 0 v-y (/ (- g) 2)))))\n    (sym/solve-quadratic quad)))\n(projectile-landing-time 20 9.8)" :note "Find when height y(t) = v_y·t − (g/2)·t² returns to ground (y=0)")
    (:dialect "motoi" :tier "expert" :code "(define (quadratic-range a b c)\n  (if (= a 0)\n      (escalate 'not-quadratic)\n      (let* ((vertex-x (/ (- b) (* 2 a)))\n             (roots (sym/solve-quadratic (sym/poly (list c b a)))))\n        (list 'roots roots 'vertex-x vertex-x))))\n(quadratic-range 1 -4 3)" :note "Find both roots and vertex of y=x²−4x+3; roots are (1 3), vertex at x=2")
  )
  :caveats ("Input must be a valid quadratic (degree 2); linear or higher-degree polynomials are not solved." "Complex roots (when discriminant < 0) cause an escalation; real roots are guaranteed only if the call succeeds." "If there is a repeated root, it appears once in the list (not twice).")
  :drawbacks ("Only handles quadratic equations; for higher degrees, use a numerical root-finder or computer algebra system." "Floating-point arithmetic may introduce rounding error for very large or very small roots." "No built-in support for complex roots; the escalation indicates they exist but does not return them.")
  :usecases ("Finding x-intercepts of parabolas (set a quadratic equal to 0)." "Physics: projectile motion, collision detection, and trajectory problems." "Optimization: finding critical points of quadratic cost functions.")
  :related ("sym/solve-linear" "sym/factor" "sym/poly" "sym/evaluate")
  :learn (:concept "The quadratic formula and the discriminant; when real solutions exist." :prerequisites ("sym/poly" "sym/degree" "sym/solve-linear") :progression "Use `sym/solve-quadratic` to find roots; then use `sym/factor` to understand rational factorization if the roots are rational.")
  :row-2-audit (
    (:problem "A phys/projectile handler solves y=v_y·t - (g/2)·t² for t=0 (landing time) to time the audio cue for landing."
     :program "(define quad (sym/poly (list 0 20 (/ (- 9.8) 2))))\n(sym/solve-quadratic quad)"
     :explanation "Line 1 defines the height polynomial. Line 2 solves; returns two roots — 0 (launch) and ~4.08 (landing)."
     :meta "Reach for sym/solve-quadratic and NOT sym/factor: factor requires rational roots; solve-quadratic handles any real roots.")
    (:eng "The physics log records the landing time." :math "sym/solve-quadratic applies the quadratic formula." :cs "Meta; O(1)."))
  :row-3-dimension (
    (:setup "Two-root solving of a degree-2 equation."
     :rungs (
       (:domain "sym"    :code "(sym/solve-quadratic p)")
       (:domain "phys (metaphor)" :code "(phys/find-intersection-times traj plane)")
       (:domain "algebra"   :code "roots(ax²+bx+c) = (-b ± √Δ)/(2a)"))
     :explanation "Rung 1 quadratic roots. Rung 2 physical trajectory intersections. Rung 3 quadratic formula. Same shape."
     :meta "Quadratic-solve transfers to any two-real-root problem.")
    (:eng "Trajectory-intercept problems all share this shape." :math "The quadratic formula." :cs "Foundation for many closed-form solvers."))
  :row-4-proof (
    (:claim "sym/solve-quadratic returns roots that evaluate to 0 when substituted."
     :program "(define p (sym/poly '(-6 1 1)))\n(define roots (sym/solve-quadratic p))\n(if (list? roots) (map (lambda (r) (sym/evaluate p r)) roots) 'complex)"
     :invariant "∀ p quadratic with real roots. ∀ r ∈ solve-quadratic(p). eval(p, r) = 0"
     :meta "Pattern: root-correctness. Falsifies if any returned root doesn't evaluate to 0. See book-of-math ch on quadratic equations.")
    (:eng "Root-verification is a base sanity check." :math "The defining property of a root." :cs "Round-trip test is standard solver validation."))
  :row-5-emergence (
    (:base "sym/solve-quadratic finds real roots of a quadratic."
     :composition "(define (parabola-intercepts a b c) (let ((p (sym/poly (list c b a)))) (let ((roots (sym/solve-quadratic p))) (if (list? roots) roots 'no-real-intercepts))))\n(parabola-intercepts 1 -5 6)"
     :emergent "parabola-analyzer — find x-intercepts to characterize the parabola's shape."
     :meta "Family: geometry-from-algebra. Same shape as finding circle centers from equations or plane-plane intersections. See book-of-composition ch on algebra-geometry bridge.")
    (:eng "The pattern connects algebraic solving to geometric visualization." :math "Realizes the geometric root-finding." :cs "Algebra-geometry bridge is a base of teaching mathematics."))

(verb
  :name "sym/sub"
  :library "sym"
  :kind "meta"
  :signature "(sym/sub poly-a poly-b) -> polynomial"
  :summary "Subtract polynomial b from polynomial a, returning their difference."
  :explanation "sym/sub computes the polynomial difference a − b by subtracting coefficients term-by-term. Both operands must be valid polynomials (built with sym/poly, sym/var, sym/const, or results from other sym/* operations). If either operand is not a polynomial, the result is the symbolic 'nan. This is a workhorse for building larger algebraic expressions."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((p (sym/poly '(3 2 1)))\n      (q (sym/poly '(1 1))))\n  (sym/->string (sym/sub p q)))" :note "Subtract x+1 from x²+2x+3, yielding x²+x+2.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((f (sym/sub (sym/mul (sym/var 'x) (sym/var 'x))\n                       (sym/const 4)))\n      (g (sym/mul (sym/const 2) (sym/var 'x))))\n  (sym/evaluate (sym/sub f g) 3))" :note "Build x²−4 and 2x, subtract them, then evaluate at x=3 to get 2.")
    (:dialect "motoi" :tier "expert" :code "(define p 'p)\n(let ((shift-right (lambda (p n)\n                    (sym/substitute p (sym/poly (cons 0 (make-list n 0)))))))\n  (let ((p (sym/var 'x))\n        (deriv-approx (sym/sub (shift-right p 1) p)))\n    (sym/degree deriv-approx)))" :note "Compose subtraction with substitution to approximate finite differences and inspect the resulting polynomial degree.")
  )
  :caveats ("Both operands must be valid polynomials; non-polynomials silently become 'nan." "The result is zero-stripped; the zero polynomial has degree −1 (not 0)." "Subtraction is exact over rationals; no numerical rounding occurs.")
  :drawbacks ("sym/sub alone does not solve equations; use sym/solve-linear or sym/solve-quadratic for that." "Large degree polynomials may become unwieldy; consider sym/evaluate for numerical work instead.")
  :usecases ("Building difference equations or residuals for algebraic verification." "Constructing characteristic polynomials or shifted polynomials in iterative algorithms." "Symbolic form of subtraction when the exact polynomial result is needed.")
  :related ("sym/add" "sym/mul" "sym/evaluate" "sym/substitute" "sym/derivative")
  :learn (:concept "Polynomial ring operations and coefficient-level arithmetic." :prerequisites ("sym/poly" "sym/const" "sym/var") :progression "After sym/sub, learn sym/mul (products), then sym/derivative (calculus), then sym/solve-linear and sym/solve-quadratic.")
  :row-2-audit (
    (:problem "A math/residual computes p - q, the error polynomial between an actual and predicted polynomial in a fit."
     :program "(define actual (sym/poly '(1 2 3)))\n(define predicted (sym/poly '(0.9 1.9 3.1)))\n(sym/->string (sym/sub actual predicted))"
     :explanation "Line 1 defines actual. Line 2 defines predicted. Line 3 renders the residual as \"-0.1x^2 + 0.1x + 0.1\"."
     :meta "Reach for sym/sub and NOT sym/add with a negated q: sub is one call and preserves reader intent.")
    (:eng "The fit log records the residual polynomial." :math "sym/sub is the group operation of subtraction." :cs "Meta; O(max degree)."))
  :row-3-dimension (
    (:setup "Group subtraction: element minus element."
     :rungs (
       (:domain "sym"     :code "(sym/sub p q)")
       (:domain "vec (metaphor)" :code "(vec/sub u v)")
       (:domain "algebra"    :code "a - b in an abelian group"))
     :explanation "Rung 1 poly difference. Rung 2 vector difference. Rung 3 abstract group difference. Same shape."
     :meta "Group-difference transfers to any abelian group.")
    (:eng "Residuals and deltas share this shape." :math "Group operation." :cs "Base of error and delta computation."))
  :row-4-proof (
    (:claim "sym/sub is the inverse of sym/add: p - q + q = p."
     :program "(define p (sym/poly '(1 2 3)))\n(define q (sym/poly '(-1 0 4)))\n(sym/= (sym/add (sym/sub p q) q) p)"
     :invariant "∀ p q. (p - q) + q = p"
     :meta "Pattern: subtraction as add-inverse. Falsifies if any pair breaks. See book-of-math ch on group inverses.")
    (:eng "The invariant lets ops verify subtraction via addition." :math "Group inverse property." :cs "Round-trip via inverse is a base algebraic test."))
  :row-5-emergence (
    (:base "sym/sub subtracts two polynomials."
     :composition "(define (residual actual predicted) (sym/sub actual predicted))\n(define (mse actual predicted samples) (let ((r (residual actual predicted))) (apply + (map (lambda (x) (expt (sym/evaluate r x) 2)) samples))))\n(mse (sym/poly '(1 2 3)) (sym/poly '(0.9 1.9 3.1)) (list 0.0 1.0 2.0))"
     :emergent "MSE calculator — residual polynomial evaluated at samples, squared, and summed."
     :meta "Family: error-aggregation. Same shape as computing loss in ML or misfit in geophysics. See book-of-composition ch on error metrics.")
    (:eng "The pattern is a canonical fit-quality metric." :math "Realizes L2 loss over a sample." :cs "Error-aggregation is a base of numerical fitting."))

(verb
  :name "sym/substitute"
  :library "sym"
  :kind "meta"
  :signature "(sym/substitute poly replacement-poly) -> polynomial"
  :summary "Compose two polynomials: replace the variable in poly with replacement-poly."
  :explanation "sym/substitute performs polynomial composition: given a polynomial p(x) and a replacement polynomial q(x), it returns p(q(x)). This is the symbolic version of function composition. Both arguments must be valid polynomials. The result is returned in canonical (expanded, zero-stripped) form. Non-polynomial inputs yield 'nan. Substitution is useful for change-of-variables, building nested polynomial expressions, and studying polynomial roots under affine transformations."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((p (sym/poly '(0 0 1)))\n      (q (sym/poly '(1 1))))\n  (sym/->string (sym/substitute p q)))" :note "Substitute x→(x+1) into x². Result is (x+1)² = x²+2x+1.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((p (sym/poly '(-1 0 1)))\n      (u (sym/poly '(0 2))))\n  (let ((composed (sym/substitute p u)))\n    (sym/evaluate composed 1)))" :note "Substitute x→2x into x²−1, yielding 4x²−1. Evaluate at x=1 to get 3.")
    (:dialect "motoi" :tier "expert" :code "(let ((normalize-root (lambda (p root-val)\n                        (sym/substitute p (sym/add (sym/var 'x)\n                                              (sym/const root-val))))))\n  (let ((f (sym/poly '(-2 0 1))))\n    (sym/coeff (normalize-root f 1) 1)))" :note "Shift a polynomial so a root aligns with the origin, extracting the linear coefficient to diagnose the derivative at that point.")
  )
  :caveats ("Both operands must be valid polynomials; non-polynomials yield 'nan." "The degree of p∘q is (deg p) × (deg q); composition can rapidly increase degree." "The result is always returned in expanded form; no lazy or factored representation is kept.")
  :drawbacks ("Degree explosion: composing two degree-5 polynomials yields degree 25, which may be expensive." "sym/substitute is composition only; it cannot solve for the replacement (use sym/solve-* for that)." "No symbolic simplification beyond expansion; algebraic cancelation is not performed.")
  :usecases ("Change of variables in polynomial equations (e.g., u = x − c to shift roots)." "Building nested polynomial expressions for numerical stability studies." "Studying how polynomial roots transform under affine maps.")
  :related ("sym/evaluate" "sym/mul" "sym/add" "sym/expand")
  :learn (:concept "Function composition in the polynomial ring; degree multiplication." :prerequisites ("sym/poly" "sym/var" "sym/evaluate" "sym/mul") :progression "After sym/substitute, use sym/derivative on composed polynomials, then sym/solve-* on transformed equations.")
  :row-2-audit (
    (:problem "A math/change-of-variable shifts the polynomial x²-1 so its root moves from x=1 to origin via u=x-1."
     :program "(define p (sym/poly '(-1 0 1)))\n(define u (sym/add (sym/var 'x) (sym/const 1)))\n(sym/->string (sym/substitute p u))"
     :explanation "Line 1 defines x²-1 (root at x=1). Line 2 defines u=x+1. Line 3 substitutes yielding \"x^2 + 2x\" (root at origin)."
     :meta "Reach for sym/substitute and NOT manual expansion: substitute automates the algebra correctly and canonicalizes.")
    (:eng "The change-of-variable log records the shifted form." :math "sym/substitute is polynomial composition." :cs "Meta; O(d₁ · d₂ log d₂)."))
  :row-3-dimension (
    (:setup "Function composition: build (f ∘ g) from f and g."
     :rungs (
       (:domain "sym"     :code "(sym/substitute p q)")
       (:domain "route (metaphor)" :code "(route/via r stops)")
       (:domain "category theory"   :code "f ∘ g in the category of functions"))
     :explanation "Rung 1 polynomial composition. Rung 2 route composition. Rung 3 abstract morphism composition. Same shape."
     :meta "Composition transfers to any category-with-morphisms.")
    (:eng "Composition appears across every abstract-machinery domain." :math "Category composition." :cs "The fundamental combinator in FP."))
  :row-4-proof (
    (:claim "Substitution is associative: sub(sub(p, q), r) = sub(p, sub(q, r))."
     :program "(define p (sym/poly '(0 0 1)))\n(define q (sym/add (sym/var 'x) (sym/const 1)))\n(define r (sym/mul (sym/const 2) (sym/var 'x)))\n(sym/= (sym/substitute (sym/substitute p q) r) (sym/substitute p (sym/substitute q r)))"
     :invariant "∀ p q r. sub(sub(p,q), r) = sub(p, sub(q,r))"
     :meta "Pattern: associativity of composition. Falsifies if any triple breaks. See book-of-math ch on function composition.")
    (:eng "Associativity lets ops re-parenthesize composition chains freely." :math "Category associativity." :cs "Composition-associativity is a base algebraic property."))
  :row-5-emergence (
    (:base "sym/substitute composes polynomials."
     :composition "(define (nest-fn p depth) (let loop ((cur p) (i 1)) (if (>= i depth) cur (loop (sym/substitute p cur) (+ i 1)))))\n(sym/->string (nest-fn (sym/poly '(0 0 1)) 3))"
     :emergent "iterated composition — fn(fn(fn(x))) built by repeated substitution."
     :meta "Family: iterated-composition. Same shape as function-application repeated in fixed-point theorems or iterated maps in dynamical systems. See book-of-composition ch on iterated maps.")
    (:eng "The pattern is the base of dynamical-systems teaching." :math "Realizes fⁿ (n-fold composition)." :cs "Iterated-composition is a base of many CS constructions."))

(verb
  :name "sym/var"
  :library "sym"
  :kind "meta"
  :signature "(sym/var symbol) -> polynomial"
  :summary "Create the variable as a degree-1 polynomial with coefficients [0, 1]."
  :explanation "sym/var constructs the symbolic variable itself as a polynomial. It takes a symbol (typically 'x) and returns a polynomial object representing that variable—internally stored as the coefficient vector [0, 1], meaning 0 + 1·x. This is a foundational builder: every symbolic polynomial is constructed starting from sym/var and combined with sym/const and arithmetic (sym/add, sym/mul, sym/pow). The symbol name is stored for human-readable display but does not affect arithmetic. Non-symbols yield 'nan."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sym/->string (sym/var 'x))" :note "Display the variable x as the string \"x\".")
    (:dialect "motoi" :tier "intermediate" :code "(let ((x (sym/var 'x)))\n  (sym/->string (sym/add (sym/mul x x) (sym/mul (sym/const 3) x))))" :note "Build x²+3x by multiplying and adding the variable with itself and constants.")
    (:dialect "motoi" :tier "expert" :code "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(let ((make-monic-from-roots (lambda (roots)\n                               (fold-left (lambda (acc r)\n                                           (sym/mul acc (sym/sub (sym/var 't)\n                                                             (sym/const r))))\n                                        (sym/const 1)\n                                        roots))))\n  (sym/->string (make-monic-from-roots '(1 2 3))))" :note "Build a monic polynomial from roots by recursively multiplying (t−root) factors, starting with the variable.")
  )
  :caveats ("The symbol name is arbitrary and cosmetic; (sym/var 'x) and (sym/var 'u) are arithmetically identical." "sym/var returns a polynomial, not a symbolic expression; it has no special algebraic properties beyond its coefficients." "Non-symbol input (e.g., numbers, lists) silently becomes 'nan.")
  :drawbacks ("Multi-variable polynomials are not supported; all polynomials are univariate." "The variable name is not tracked across operations; (sym/substitute p q) treats p and q as abstract polynomials regardless of their symbol.")
  :usecases ("Initializing any symbolic computation: building a polynomial expression from scratch." "Defining polynomial families parametrically (roots, coefficients, degree)." "Writing algebraic test suites or verification code.")
  :related ("sym/const" "sym/poly" "sym/add" "sym/mul" "sym/->string")
  :learn (:concept "Polynomial representation as coefficient vectors; the foundational builder for symbolic algebra." :prerequisites () :progression "Start with sym/var and sym/const, then sym/poly to build arbitrary polynomials, then sym/add, sym/mul, sym/pow.")
  :row-2-audit (
    (:problem "A cortex/tutor builds x²+3x from primitives to demonstrate algebraic construction step by step."
     :program "(define x (sym/var 'x))\n(sym/->string (sym/add (sym/mul x x) (sym/mul (sym/const 3) x)))"
     :explanation "Line 1 creates the variable x. Line 2 builds x·x + 3·x and renders as \"x^2 + 3x\". The tutor shows each step."
     :meta "Reach for sym/var and NOT (sym/poly '(0 1)): var names intent as 'the variable', not 'a poly with these coefficients'. Better teaching artifact.")
    (:eng "The tutor log records each construction step." :math "sym/var creates the identity polynomial." :cs "Meta; O(1)."))
  :row-3-dimension (
    (:setup "Identity-element of a construction algebra."
     :rungs (
       (:domain "sym"    :code "(sym/var 'x)")
       (:domain "matrix (metaphor)" :code "(matrix/identity n)")
       (:domain "algebra"    :code "generator of a free algebra"))
     :explanation "Rung 1 variable-polynomial. Rung 2 identity matrix. Rung 3 abstract generator. Same shape."
     :meta "Generator element transfers to any free-algebra-like domain.")
    (:eng "Generators appear across every algebraic-construction domain." :math "Free-algebra generator." :cs "The foundational atom of expression trees."))
  :row-4-proof (
    (:claim "sym/var 'x is the multiplicative identity for substitution: sub(p, var) = p."
     :program "(define p (sym/poly '(1 2 3)))\n(sym/= (sym/substitute p (sym/var 'x)) p)"
     :invariant "∀ p. substitute(p, var('x)) = p"
     :meta "Pattern: identity element for composition. Falsifies if any polynomial changes on identity substitution. See book-of-math ch on category theory.")
    (:eng "Identity property means the variable substitutes for itself trivially." :math "Identity morphism of the category." :cs "The identity is a base algebraic element."))
  :row-5-emergence (
    (:base "sym/var creates the identity variable."
     :composition "(define (from-scratch)\n  (let ((x (sym/var 'x))) (sym/add (sym/mul x x) (sym/add (sym/mul (sym/const 3) x) (sym/const 2)))))\n(sym/->string (from-scratch))"
     :emergent "primitive-only polynomial builder — build x²+3x+2 using only var, const, mul, add — no sym/poly shortcut."
     :meta "Family: bottom-up algebraic construction. Same shape as building AST nodes from atoms or building matrices from elementary matrices. See book-of-composition ch on primitive-based construction.")
    (:eng "The pattern is the pedagogical bare-hands algebra construction." :math "Realizes the free-polynomial construction from generators." :cs "Bottom-up construction from atoms is a base of ADT design."))


))))))))))))))))))))  ;; paren-balance repair 2026-07-19
