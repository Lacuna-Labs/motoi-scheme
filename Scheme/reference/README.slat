;;; README.slat — Motoi Scheme Reference Manual · folder README
;;;
;;; This file is here so anyone (human, LLM, Rosetta, GitHub visitor) opening
;;; this folder can figure out what it IS and how to use it, without hunting.
;;; Same short pattern lives in every book folder in Motoi. Pure SLAT —
;;; Rosetta renders it to Markdown/HTML for GitHub display when it walks
;;; this tree.

(dialect :applies ("motoi") :note "Folder-level README — how to use this book.")

(readme
  :name          "motoi-scheme-reference-readme"
  :folder        "Scheme/reference/"
  :book-title    "Motoi Scheme Reference Manual"
  :book-kind     "reference-manual"
  :written       "2026-07-19"
  :for           ("human-reader" "motoi-copilot-training" "motoi-copilot-inference"
                  "sakura-training" "rosetta-render-target" "returning-collaborator")
  :training-eligible #t
  :confidentiality "public"

  :what-this-is
  "This folder is the Motoi Scheme Reference Manual — one book, many chapters.
   It is meant to be read by humans AND used as training data for LLMs (Motoi
   Copilot, Sakura). Every callable verb in the Motoi runtime has a record in
   one of these chapters. Reference wins when reference and code disagree."

  :how-to-use
  ("Start with 00-intro.slat — welcome, how to read the manual, the five-row rules"
   "Then 00b-introspection.slat — the language looking at itself (REPL commands, motoi/* verbs)"
   "Then 00c-runtime-and-composition.slat — how the runtime actually works"
   "Then 01-core.slat — the core forms and primitives (define, lambda, let, etc.)"
   "Then any library chapter (02-ai.slat through 72-world.slat) as you need it"
   "MANIFEST.slat is the machine-readable index — this is what Rosetta reads first")

  :what-is-in-here
  ((:file "00-intro.slat"                     :purpose "welcome + how to read + five-row rules")
   (:file "00b-introspection.slat"            :purpose "the language looking at itself")
   (:file "00c-runtime-and-composition.slat"  :purpose "runtime mechanics + composition")
   (:file "01-core.slat"                      :purpose "core forms + primitives (97 verbs)")
   (:file "02-ai.slat … 72-world.slat"        :purpose "one chapter per library (70 chapters)")
   (:file "99-appendix-prose.slat"            :purpose "Row-4/Row-5 prose essays (migrating)")
   (:file "MANIFEST.slat"                     :purpose "machine-readable index of chapters"))

  :the-rules
  "The rules for the format live in 00-intro.slat § 6 (five rows) and § 9 (14 rules).
   The same rules appear as a summary at the top of every library chapter.
   No philosopher names in verb entries. Real Motoi domains only. Every code
   block must run. Row purity (Rule 13): each row does its ONE job. No
   cross-contamination between rows. The format is LOCKED. See § 5 below."

  :for-rosetta
  "This folder is a book. Detect signals: this README.slat + MANIFEST.slat +
   numbered chapter files. Render this README as the folder's landing page.
   Render MANIFEST.slat as the table of contents. Render each chapter as its
   own page in the order given by MANIFEST's :chapters list. Cross-link verbs
   via :name across chapters (a mention of vec/dot in chapter 03 links to
   the vec/dot record in chapter 69)."

  :format-lock
  "This README pattern is the SAME pattern used in every book folder in
   Motoi. Same five sections: what-this-is · how-to-use · what-is-in-here ·
   the-rules · for-Rosetta. Same everywhere. Do not drift. Drifted formats
   train drifted models. If you are adding a new book folder, use this
   README as the template."

  :composes-with
  ("00-intro.slat (full doctrine)"
   "MANIFEST.slat (index)"
   "scheme-books/README.slat (top-level collection READMEs — same pattern)"))
