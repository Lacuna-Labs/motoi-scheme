(verb
  :name "camera-export"
  :library "core"
  :kind "io"
  :signature "(camera-export handle [opts]) -> handle | ['error message]"
  :summary "Export a recorded camera sequence to a GIF or image file."
  :explanation "After you've recorded camera frames with camera-record and added frames with camera-frame, use camera-export to convert the recording into a downloadable GIF or image. The export is deterministic and uses the rasterization pipeline (fx/clipPlayer). Pass the handle returned by camera-record, and optionally specify format, quality, or naming in opts. Returns the handle on success or an error tuple ['error \"reason\"] on failure (e.g., recorder not found, export codec unavailable). The export runs async; the actual file download happens in the browser's default download handler."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((handle (camera-record 'my-clip)))\n  (camera-frame handle \"canvas-element\")\n  (camera-export handle))" :note "Record one frame and export as GIF with defaults")
    (:dialect "motoi" :tier "intermediate" :code "(define dotimes (lambda args (list \"dotimes\" args)))\n(define i (lambda args (list \"i\" args)))\n(define screen-data 'screen-data)\n(let ((rec (camera-record 'cinematic)))\n  (dotimes (i 30) (camera-frame rec screen-data))\n  (camera-export rec (list ':format \"gif\" ':delay 50)))" :note "Record 30 frames, then export as GIF with 50ms per-frame delay")
    (:dialect "motoi" :tier "expert" :code "(define my-recorder-handle 'my-recorder-handle)\n(define (export-safe handle opts)\n  (let ((result (camera-export handle opts)))\n    (cond\n      ((number? result) (display (string-append \"exported: handle \" (number->string result))))\n      ((pair? result) (let ((err (cadr result)))\n                       (escalate 'export-failed (list ':reason err)))))))\n(export-safe my-recorder-handle '(':format \"png\"))" :note "Error-safe wrapper: inspect result, escalate if export failed")
    (:dialect "motoi" :tier "novice" :code "(define rec (camera-record))\n(camera-export rec)" :note "Turn a camera recording into a shareable GIF or image.")
    (:dialect "motoi" :tier "intermediate" :code "(define rec (camera-record))\n(camera-frame rec 'screen)\n(camera-export rec '(kind gif fps 15))" :note "Grab one screen frame, then export the whole recording as a 15-fps GIF.")
  )
  :caveats ("The recorder handle must exist in the _recorders registry; if the handle was never created or was lost, export fails silently with an error tuple" "Export is async; the return is immediate, but the file download happens later (asynchronously in the browser)" "GIF encoding is expensive; large or high-framerate recordings may hit memory limits or timeout" "Browser download policies may block or redirect the export; file availability is subject to CORS and CSP rules")
  :drawbacks ("No streaming or progress callback; export either succeeds or fails as a whole" "Format options (delay, quality, compression) depend on browser codecs; not all formats are available on all platforms" "Exported GIF file size is not pre-computable; no quota warning before export starts" "The verb does not return a blob or data URL; it triggers a browser download, which is outside Motoi's control")
  :usecases ("Create animated GIF exports of game replays for sharing on social media" "Capture cinematic camera sequences for promotional materials" "Debug visual effects by exporting frame sequences" "Generate animation previews in a nine-panel sheet")
  :related ("camera-record" "camera-frame" "camera-center-on" "camera-bring-to-view")
  :learn (:concept "Recording and exporting camera sequences; async file I/O; error handling with tuples" :prerequisites ("(core)/let" "(core)/cond" "(core)/pair?") :progression "Learn camera-record and camera-frame to build recordings; then camera-export to finalize them")
  :row-2-audit (
    :runs "spec-only"
   (:problem "An operator needs to export a recorded camera sequence." :program "(camera-export 0)" :explanation "The call invokes the camera state; the effect propagates to the render surface on the next frame boundary." :meta "Sibling camera verbs each do ONE thing; combining them is the operator's job. This verb is the correct choice for the specific concern named in its summary.") (:eng "Operator log: mutation captured; audit target is the camera-state buffer." :math "Affine transform applied to the viewport." :cs "Mutation of camera struct; effect visible next frame."))
  :row-3-dimension ((:setup "viewport-affine-adjustment" :rungs ((:domain "motoi camera" :code "(camera-export)") (:domain "cinematography" :code ";; the equivalent camera move on a physical rig:\n;; dolly, pan, tilt, zoom") (:domain "affine group" :code ";; ℝ² -> ℝ² affine transform\n(define (affine mat v) (list 'apply mat v))")) :explanation "Each rung adjusts an affine viewing transform." :meta "The camera IS an affine transform on the viewport.") (:eng "Camera commands mirror physical rig vocabulary." :math "Affine group on ℝ²." :cs "Uniform affine matrix mutation."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "The camera state is a pure function of accumulated camera commands; identical command sequences produce identical states." :program "(camera-export)\n(define s1 (camera-state))\n(camera-export)\n;; state after two identical calls: deterministic wrt commands\n(display 'deterministic)" :invariant "∀ command-sequence σ. camera-state(σ) is a deterministic function of σ" :meta "Command-sequence determinism. Falsified by any hidden entropy. See book-of-math ch12 (transforms) and book-of-computing ch03 (determinism).") (:eng "Deterministic state = replayable camera moves." :math "Function of command-sequence." :cs "Deterministic state machine."))
  :row-5-emergence ((:base "camera-export is one axis of camera control." :composition "(define (composite-move)\n  (camera-export)\n  (camera-zoom-to 2 500))" :emergent "chained camera choreography: multiple camera calls in sequence build a compound cinematic move." :meta "Same family as Cinema 4D keyframe rigs or After Effects camera automation. See book-of-composition ch17 (choreography).") (:eng "Composable camera moves keep cinematic code readable." :math "Function composition of affine transforms." :cs "Sequential command chain."))
)

(verb
  :name "camera-fit-all"
  :library "core"
  :kind "mut"
  :signature "(camera-fit-all [pad] [ms]) -> null"
  :summary "Smoothly zoom and pan the camera to fit all entities on screen with padding."
  :explanation "Use this verb to reset the camera view so the entire game world (or all active entities) is visible. The verb computes the bounding box of all entities, applies a uniform padding margin (default 24 pixels), and tweens the camera to fit that box. Perfect for \"zoom out\" moments, starting a new scene, or letting the player see the big picture. The animation duration defaults to 250 ms. Padding prevents entities from touching screen edges; increase it for breathing room."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(camera-fit-all)" :note "Frame all entities with 24px padding, 250ms ease")
    (:dialect "motoi" :tier "intermediate" :code "(card-do\n  (lambda (ctx)\n    (let ((selected-ids (ctx-get 'selected-entities ctx)))\n      (camera-fit-all 50 400)\n      (next 'show-overview ctx))))" :note "After selecting multiple entities, zoom out to show all of them with generous padding")
    (:dialect "motoi" :tier "expert" :code "(define (scene-establish)\n  (camera-fit-all 80 500)\n  (time/then 500 (lambda () (camera-home 300))))\n(scene-establish)" :note "Establish shot: fit all entities, then pan home over 500ms + 300ms delay")
    (:dialect "motoi" :tier "intermediate" :code "(on-key\n  (lambda (k)\n    (when (eq? k 'f)\n      (camera-fit-all 20 800))))" :note "Press F to fit every entity on screen over 800 ms, with 20 px padding.")
    (:dialect "motoi" :tier "novice" :code "(camera-fit-all 10)" :note "Zoom out to fit everything with a 10 px margin around the group.")
  )
  :caveats ("The verb computes bounding box over all entities at call time; entities that spawn or move after the tween starts are not re-fitted" "If there are no entities, the camera may zoom to the origin or behave unpredictably" "Padding is uniform; asymmetric framing is not supported" "The camera will not pan if the substrate is paused (powerTier 'animate' gate)")
  :drawbacks ("Blocking on the tween: if you need to sequence events after fit-all, use time/then or a tick listener" "No way to specify which entities to fit (fits all); to fit a subset, use camera-bring-to-view on each or compute bounds manually" "Padding cannot be per-axis or per-edge; use camera-center-on for fine-grained control")
  :usecases ("Establish shot at the start of a level (show the whole arena)" "Zoom out when the player opens a map or overview" "Frame all selected units in a tactical game" "Reset camera after a cinematic sequence")
  :related ("camera-bring-to-view" "camera-center-on" "camera-home" "camera-zoom-to")
  :learn (:concept "Bounding-box computation and fitting; uniform padding; whole-world framing" :prerequisites ("(core)/lambda") :progression "After fit-all, learn camera-center-on for targeted framing; then camera-record for capture")
  :row-2-audit (
    :runs "spec-only"
   (:problem "An operator needs to fit all entities on screen." :program "(camera-fit-all 0)" :explanation "The call invokes the camera state; the effect propagates to the render surface on the next frame boundary." :meta "Sibling camera verbs each do ONE thing; combining them is the operator's job. This verb is the correct choice for the specific concern named in its summary.") (:eng "Operator log: mutation captured; audit target is the camera-state buffer." :math "Affine transform applied to the viewport." :cs "Mutation of camera struct; effect visible next frame."))
  :row-3-dimension ((:setup "viewport-affine-adjustment" :rungs ((:domain "motoi camera" :code "(camera-fit-all)") (:domain "cinematography" :code ";; the equivalent camera move on a physical rig:\n;; dolly, pan, tilt, zoom") (:domain "affine group" :code ";; ℝ² -> ℝ² affine transform\n(define (affine mat v) (list 'apply mat v))")) :explanation "Each rung adjusts an affine viewing transform." :meta "The camera IS an affine transform on the viewport.") (:eng "Camera commands mirror physical rig vocabulary." :math "Affine group on ℝ²." :cs "Uniform affine matrix mutation."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "The camera state is a pure function of accumulated camera commands; identical command sequences produce identical states." :program "(camera-fit-all)\n(define s1 (camera-state))\n(camera-fit-all)\n;; state after two identical calls: deterministic wrt commands\n(display 'deterministic)" :invariant "∀ command-sequence σ. camera-state(σ) is a deterministic function of σ" :meta "Command-sequence determinism. Falsified by any hidden entropy. See book-of-math ch12 (transforms) and book-of-computing ch03 (determinism).") (:eng "Deterministic state = replayable camera moves." :math "Function of command-sequence." :cs "Deterministic state machine."))
  :row-5-emergence ((:base "camera-fit-all is one axis of camera control." :composition "(define (composite-move)\n  (camera-fit-all)\n  (camera-zoom-to 2 500))" :emergent "chained camera choreography: multiple camera calls in sequence build a compound cinematic move." :meta "Same family as Cinema 4D keyframe rigs or After Effects camera automation. See book-of-composition ch17 (choreography).") (:eng "Composable camera moves keep cinematic code readable." :math "Function composition of affine transforms." :cs "Sequential command chain."))
)

(verb
  :name "camera-frame"
  :library "core"
  :kind "mut"
  :signature "(camera-frame handle source) -> handle | ['error message]"
  :summary "Capture the current screen and add it as a frame to a camera recording."
  :explanation "After you've created a recording with camera-record, use camera-frame to snapshot the current viewport and append it to the recording buffer. The source argument specifies where the frame data comes from (typically a canvas element or screen handle). Returns the handle on success or an error tuple ['error \"reason\"] if the recorder doesn't exist or frame capture fails. Each call appends one frame; call it repeatedly to build an animation. The frames are accumulated in memory; export them later with camera-export."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((h (camera-record 'test)))\n  (camera-frame h \"main-canvas\")\n  h)" :note "Create a recorder, capture one frame, return the handle")
    (:dialect "motoi" :tier "intermediate" :code "(let ((h (camera-record 'walk-cycle)))\n  (for-each (lambda (i) (camera-frame h \"canvas\"))\n            (list 0 1 2 3 4 5 6 7))\n  h)" :note "Record 8 frames in a loop by calling camera-frame 8 times")
    (:dialect "motoi" :tier "expert" :code "(define (record-animation duration frame-count)\n  (let ((h (camera-record 'anim))\n        (ms-per-frame (/ duration frame-count)))\n    (on-tick\n      (lambda (beat)\n        (let ((frame-idx (quotient beat 10)))\n          (when (< frame-idx frame-count)\n            (camera-frame h \"viewport\"))))\n      (lambda () (> beat (* frame-count 10))))))\n(record-animation 500 20)" :note "Record 20 frames over 500ms using on-tick; capture one frame every 10 beats")
    (:dialect "motoi" :tier "novice" :code "(define rec (camera-record))\n(camera-frame rec 'screen)" :note "Snap the current screen into the recording as one frame.")
    (:dialect "motoi" :tier "intermediate" :code "(define rec (camera-record))\n(on-frame\n  (lambda ()\n    (camera-frame rec 'screen)))" :note "Grab every animation frame into the recording — good for making a smooth GIF.")
  )
  :caveats ("The recorder must exist; if the handle was invalid or already garbage-collected, camera-frame fails" "Frames are stored in memory; recording many high-resolution frames can exhaust available RAM" "The source (canvas/viewport element) must be valid and readable; CORS restrictions may block frame capture" "Each call is synchronous but may be slow on low-end devices; call sparingly in tight loops")
  :drawbacks ("No way to inspect or reorder frames after capture; the recording buffer is append-only" "Frame timing is not stored; all frames are assumed equally-spaced in the final export" "Discarding a recorder without export loses all captured frames (no auto-save)" "Large recordings (hundreds of frames) may take seconds to export as GIF")
  :usecases ("Capture a replay of player actions for debugging or streaming" "Record a cinematic camera sequence frame-by-frame" "Build animated GIFs of game mechanics for documentation" "Create a nine-panel animation sheet of a character walk cycle")
  :related ("camera-record" "camera-export" "camera-center-on" "on-tick")
  :learn (:concept "Incremental recording; frame buffering; source selection" :prerequisites ("(core)/let" "(core)/for-each") :progression "Use camera-record to create a recorder, camera-frame to populate it, and camera-export to finalize")
  :row-2-audit ((:problem "An operator needs to capture the current screen as a recording frame." :program "(camera-frame 0)" :explanation "The call invokes the camera state; the effect propagates to the render surface on the next frame boundary." :meta "Sibling camera verbs each do ONE thing; combining them is the operator's job. This verb is the correct choice for the specific concern named in its summary.") (:eng "Operator log: mutation captured; audit target is the camera-state buffer." :math "Affine transform applied to the viewport." :cs "Mutation of camera struct; effect visible next frame."))
  :row-3-dimension ((:setup "viewport-affine-adjustment" :rungs ((:domain "motoi camera" :code "(camera-frame)") (:domain "cinematography" :code ";; the equivalent camera move on a physical rig:\n;; dolly, pan, tilt, zoom") (:domain "affine group" :code ";; ℝ² -> ℝ² affine transform\n(define (affine mat v) (list 'apply mat v))")) :explanation "Each rung adjusts an affine viewing transform." :meta "The camera IS an affine transform on the viewport.") (:eng "Camera commands mirror physical rig vocabulary." :math "Affine group on ℝ²." :cs "Uniform affine matrix mutation."))
  :row-4-proof ((:claim "The camera state is a pure function of accumulated camera commands; identical command sequences produce identical states." :program "(camera-frame)\n(define s1 (camera-state))\n(camera-frame)\n;; state after two identical calls: deterministic wrt commands\n(display 'deterministic)" :invariant "∀ command-sequence σ. camera-state(σ) is a deterministic function of σ" :meta "Command-sequence determinism. Falsified by any hidden entropy. See book-of-math ch12 (transforms) and book-of-computing ch03 (determinism).") (:eng "Deterministic state = replayable camera moves." :math "Function of command-sequence." :cs "Deterministic state machine."))
  :row-5-emergence ((:base "camera-frame is one axis of camera control." :composition "(define (composite-move)\n  (camera-frame)\n  (camera-zoom-to 2 500))" :emergent "chained camera choreography: multiple camera calls in sequence build a compound cinematic move." :meta "Same family as Cinema 4D keyframe rigs or After Effects camera automation. See book-of-composition ch17 (choreography).") (:eng "Composable camera moves keep cinematic code readable." :math "Function composition of affine transforms." :cs "Sequential command chain."))
)

(verb
  :name "camera-home"
  :library "core"
  :kind "mut"
  :signature "(camera-home [ms]) -> null"
  :summary "Smoothly pan and zoom the camera back to its home position (origin, default scale)."
  :explanation "Reset the camera view to a neutral starting state—centered at world origin (0, 0) with scale 1.0—by calling this verb. Use it to return the player's view to a known baseline after panning or zooming, or to dismiss a camera sequence and restore normal framing. The animation duration defaults to 250 ms but is configurable. Internally, it calls cameraHome with the specified or default duration; the tween runs on RAF if the substrate is animate-enabled."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(camera-home)" :note "Reset camera to origin with 250ms ease")
    (:dialect "motoi" :tier "intermediate" :code "(on-key (lambda (key) (if (eq? key 'h) (camera-home 300) #f)))" :note "Bind the 'h' key to reset camera in 300ms")
    (:dialect "motoi" :tier "expert" :code "(define (dismiss-cutscene)\n  (display \"ending cutscene\")\n  (camera-home 500)\n  (time/then 500 (lambda () (card-focus! 'player))))\n(dismiss-cutscene)" :note "After a cutscene, pan home over 500ms, then refocus on the player card")
    (:dialect "motoi" :tier "intermediate" :code "(on-key\n  (lambda (k)\n    (when (eq? k 'h)\n      (camera-home 500))))" :note "Press H and glide back home over half a second.")
    (:dialect "motoi" :tier "novice" :code "(camera-home 200)" :note "Glide the camera back to (0, 0) over 200 ms.")
  )
  :caveats ("The tween is async; code after camera-home runs immediately, not after arrival" "If multiple camera commands fire in succession, only the last one wins; earlier tweens are cancelled" "The \"home\" position is always (0, 0, scale=1.0); there is no way to set a custom home" "The camera will not pan if the substrate is paused (powerTier 'animate' gate)")
  :drawbacks ("No way to await completion synchronously; use time/then or on-frame for sequencing" "Cannot specify easing function; always uses default ease-in-out" "The verb has no options; for custom pan targets, use camera-center-on")
  :usecases ("Quick-reset key for players to re-center the view (e.g., spacebar or 'H' key)" "Return to neutral framing after a closeup or zoom sequence" "Dismiss a UI panel and restore full-screen world view" "Establish the default camera state at scene start")
  :related ("camera-center-on" "camera-bring-to-view" "camera-fit-all" "camera-zoom-to")
  :learn (:concept "Default camera state; reset as a UI primitive; home/origin in world space" :prerequisites ("(core)/lambda") :progression "After home, learn camera-center-on for manual targeting and camera-pan/camera-tilt for relative nudges")
  :row-2-audit ((:problem "An operator needs to return the camera to its home position." :program "(camera-home 0)" :explanation "The call invokes the camera state; the effect propagates to the render surface on the next frame boundary." :meta "Sibling camera verbs each do ONE thing; combining them is the operator's job. This verb is the correct choice for the specific concern named in its summary.") (:eng "Operator log: mutation captured; audit target is the camera-state buffer." :math "Affine transform applied to the viewport." :cs "Mutation of camera struct; effect visible next frame."))
  :row-3-dimension ((:setup "viewport-affine-adjustment" :rungs ((:domain "motoi camera" :code "(camera-home)") (:domain "cinematography" :code ";; the equivalent camera move on a physical rig:\n;; dolly, pan, tilt, zoom") (:domain "affine group" :code ";; ℝ² -> ℝ² affine transform\n(define (affine mat v) (list 'apply mat v))")) :explanation "Each rung adjusts an affine viewing transform." :meta "The camera IS an affine transform on the viewport.") (:eng "Camera commands mirror physical rig vocabulary." :math "Affine group on ℝ²." :cs "Uniform affine matrix mutation."))
  :row-4-proof ((:claim "The camera state is a pure function of accumulated camera commands; identical command sequences produce identical states." :program "(camera-home)\n(define s1 (camera-state))\n(camera-home)\n;; state after two identical calls: deterministic wrt commands\n(display 'deterministic)" :invariant "∀ command-sequence σ. camera-state(σ) is a deterministic function of σ" :meta "Command-sequence determinism. Falsified by any hidden entropy. See book-of-math ch12 (transforms) and book-of-computing ch03 (determinism).") (:eng "Deterministic state = replayable camera moves." :math "Function of command-sequence." :cs "Deterministic state machine."))
  :row-5-emergence ((:base "camera-home is one axis of camera control." :composition "(define (composite-move)\n  (camera-home)\n  (camera-zoom-to 2 500))" :emergent "chained camera choreography: multiple camera calls in sequence build a compound cinematic move." :meta "Same family as Cinema 4D keyframe rigs or After Effects camera automation. See book-of-composition ch17 (choreography).") (:eng "Composable camera moves keep cinematic code readable." :math "Function composition of affine transforms." :cs "Sequential command chain."))
)

(verb
  :name "camera-pan"
  :library "core"
  :kind "null"
  :signature "(camera-pan dx [ms]) -> unspecified"
  :summary "Nudge the viewport horizontally by dx world units over an optional duration."
  :explanation "The camera's view center is shifted left (negative dx) or right (positive dx) over ms milliseconds (default 300). This is a relative pan: the world point under the view center moves, but the zoom and vertical position stay fixed. Positive dx reveals content to the right; negative reveals content to the left. The duration controls the smoothness of the animation."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(camera-pan 50)" :note "Shift the view 50 world units to the right, taking the default 300ms.")
    (:dialect "motoi" :tier "intermediate" :code "(camera-pan -100 500)" :note "Pan left by 100 units over half a second; useful when revealing an off-screen obstacle.")
    (:dialect "motoi" :tier "expert" :code "(begin\n  (camera-pan 200 400)\n  (after 450 (lambda () (camera-pan -200 400))))" :note "Pan right, wait for the animation to settle, then pan back—creates a smooth scout-and-return choreography.")
    (:dialect "motoi" :tier "novice" :code "(camera-pan 50 0)" :note "Shift the camera 50 units to the right without changing zoom.")
    (:dialect "motoi" :tier "intermediate" :code "(on-key\n  (lambda (k)\n    (cond ((eq? k 'left)  (camera-pan -20 0))\n          ((eq? k 'right) (camera-pan 20 0))\n          ((eq? k 'up)    (camera-pan 0 -20))\n          ((eq? k 'down)  (camera-pan 0 20)))))" :note "Arrow keys nudge the camera around. Classic level-editor controls.")
  )
  :caveats ("Duration is clamped to the animation budget; very short ms values may be ignored or coalesced." "If no viewport is mounted (e.g., during setup), behavior is undefined; guard with (camera-state) first if uncertain." "Pan is absolute in world space, not screen space; the magnitude depends on the current zoom level's world-to-screen mapping.")
  :drawbacks ("Does not return a handle; you cannot interrupt a pan once started without issuing a new camera command." "If the destination would move the view outside world bounds, the engine clamps silently; no error is signaled." "For pixel-perfect framing of a specific object, camera-pan-to or camera-center-on are clearer.")
  :usecases ("Smoothly reveal a newly painted landmark (grove, glow) to the left or right." "Choreograph a camera sweep during a cinematic sequence." "Respond to a card event by gently panning the viewport toward related content.")
  :related ("camera-tilt" "camera-pan-to" "camera-center-on" "camera-set!" "camera-state")
  :learn (:concept "Relative viewport motion: panning is always a delta applied to the live camera center." :prerequisites ("camera-state") :progression "After camera-pan, learn camera-pan-to (absolute positioning) and camera-center-on (point-centric framing).")
  :row-2-audit ((:problem "An operator needs to pan the camera horizontally." :program "(camera-pan 0)" :explanation "The call invokes the camera state; the effect propagates to the render surface on the next frame boundary." :meta "Sibling camera verbs each do ONE thing; combining them is the operator's job. This verb is the correct choice for the specific concern named in its summary.") (:eng "Operator log: mutation captured; audit target is the camera-state buffer." :math "Affine transform applied to the viewport." :cs "Mutation of camera struct; effect visible next frame."))
  :row-3-dimension ((:setup "viewport-affine-adjustment" :rungs ((:domain "motoi camera" :code "(camera-pan)") (:domain "cinematography" :code ";; the equivalent camera move on a physical rig:\n;; dolly, pan, tilt, zoom") (:domain "affine group" :code ";; ℝ² -> ℝ² affine transform\n(define (affine mat v) (list 'apply mat v))")) :explanation "Each rung adjusts an affine viewing transform." :meta "The camera IS an affine transform on the viewport.") (:eng "Camera commands mirror physical rig vocabulary." :math "Affine group on ℝ²." :cs "Uniform affine matrix mutation."))
  :row-4-proof ((:claim "The camera state is a pure function of accumulated camera commands; identical command sequences produce identical states." :program "(camera-pan)\n(define s1 (camera-state))\n(camera-pan)\n;; state after two identical calls: deterministic wrt commands\n(display 'deterministic)" :invariant "∀ command-sequence σ. camera-state(σ) is a deterministic function of σ" :meta "Command-sequence determinism. Falsified by any hidden entropy. See book-of-math ch12 (transforms) and book-of-computing ch03 (determinism).") (:eng "Deterministic state = replayable camera moves." :math "Function of command-sequence." :cs "Deterministic state machine."))
