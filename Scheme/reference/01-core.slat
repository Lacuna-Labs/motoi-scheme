;;; 01-core.slat — Motoi Scheme Reference · Chapter 01 · library core
;;;
;;; 97 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library core — 97 verbs.")

(chapter :number "01" :library "core" :verb-count 97 :training-eligible #t)

;; ═══ 97 verbs in library core ═══

(verb
  :name "across-beats"
  :library "core"
  :kind "meta"
  :signature "(across-beats formation) -> descriptor"
  :summary "Arrange entities in a spatial formation synchronized to the beat grid."
  :explanation "Across-beats is a meta-verb that returns a choreography descriptor, not a direct mutation. It takes a formation (a named spatial pattern) and produces a rhythm-locked arrangement. The descriptor is typically passed to a verb like `act` or composed into a cart state transition. The formation synchronizes entity positions and timing to the beat, useful for synchronized group movement, dance, or coordinated visual effects."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(across-beats 'circle)" :note "Request entities arrange in a circle formation; the driver will synchronize to the current beat phase.")
    (:dialect "motoi" :tier "intermediate" :code "(act 'world/spawn (list 'enemy 100 50) 'enemies-spawned)\n(across-beats 'diamond)" :note "Spawn enemies, then arrange them in a diamond pattern locked to rhythm.")
    (:dialect "motoi" :tier "expert" :code "(define formation '())\n(define (dance-section ctx)\n  (let ((formation (if (> (ctx-get 'beat ctx) 32) 'star 'line)))\n    (act 'card/emit (list 'formation-change formation) 'await-formation)))\n(across-beats formation)" :note "Conditional formation selection based on beat counter; descriptor returned and passed to the driver for rhythm-locked execution.")
    (:dialect "motoi" :tier "novice" :code "(across-beats 'line)" :note "Make a formation descriptor. Later choreography will use it to place entities.")
    (:dialect "motoi" :tier "intermediate" :code "(define row (across-beats 'staggered))\n(display row)" :note "A staggered formation feels more human than a strict grid. Hand-off row to a mover.")
  )
  :caveats ("Returns a descriptor only; does not mutate world state immediately." "Formation name must exist in the FORMATIONS registry; invalid names produce no error at definition time (error deferred to execution)." "Synchronization happens relative to the current beat context; call within a beat-aware cart." "Formation positions are relative to a reference entity or origin; ensure context provides anchor.")
  :drawbacks ("Requires beat context to be meaningful; outside a rhythm-aware environment, timing is undefined." "No direct feedback on formation success or entity count mismatch." "If entity count does not match formation capacity, some entities may not be placed or overlap.")
  :usecases ("Choreographed group dances or animations locked to music beat." "Synchronized spawning of enemies in concentric or symmetric patterns (games)." "Visual formation changes timed to song sections or narrative beats." "Coordinated motion of multiple cards or UI elements on the same rhythm.")
  :related ("land-on-downbeat" "in-formation" "with-spacing" "walk-together" "sub-position-per-beat" "on-tick" "audio-beat?")
  :learn (:concept "Meta-verbs return descriptors that the driver executes in a rhythm-aware context." :prerequisites ("on-tick" "audio-beat?" "act") :progression "Learn land-on-downbeat to snap to beat boundaries; then in-formation to place entities relative to each other; then with-spacing to control inter-entity distance.")
  :row-2-audit ((:problem "A dance sequence needs eight enemies arranged in a circle for the chorus, then a diamond for the drop, with everything locked to the beat grid." :program "(define (choreograph ctx)\n  (let ((section (ctx-get 'section ctx)))\n    (if (eq? section 'chorus)\n        (across-beats 'circle)\n        (across-beats 'diamond))))" :explanation "The verb returns a descriptor per section, not a mutation. The driver reads the descriptor and places entities at beat-locked positions on the next downbeat. The section field on ctx selects which formation is emitted." :meta "in-formation places entities but does not lock timing; walk-together moves entities but assumes a path exists. across-beats is the correct choice when the operator wants a named FORMATION whose emission is rhythm-anchored.") (:eng "Operator log line: 'formation=circle at bar 5 beat 1'. If timing drifts, the audit is on the beat clock, not on this verb." :math "Formation is a set of (x, y) offsets indexed by entity slot; across-beats emits the same set every call, so the mapping is a pure function of (name, entity-count)." :cs "Descriptor pattern: this verb is a constructor for an intent-record that the driver interprets. Effect is deferred, not immediate."))
  :row-3-dimension ((:setup "named-arrangement-emits-descriptor-for-later-execution" :rungs ((:domain "motoi choreo" :code "(across-beats 'circle)") (:domain "build orchestration" :code ";; a build plan requests parallel jobs to run in a fan-out shape:\n(list 'fanout (list 'compile 'lint 'test))") (:domain "math (finite map)" :code ";; a formation IS a finite map from slot index to position:\n(define circle-map '((0 . (1 0)) (1 . (0 1)) (2 . (-1 0)) (3 . (0 -1))))")) :explanation "Each rung is a NAMED SHAPE that a downstream executor unpacks into a set of concrete positions. The name is the compression; the executor is the expansion." :meta "Any time an executor accepts a NAME and answers with a LAYOUT, the shape is the same. Motoi's 'circle is a build system's 'fanout is a math finite map.") (:eng "Named formations reduce operator cognitive load; the operator says 'circle' and the driver expands it. Same as CI job templates." :math "Finite maps from labels to positions; the label alphabet is small and closed." :cs "Symbol-keyed dispatch table with descriptor return type."))
  :row-4-proof ((:claim "Called with the same formation name and the same driver state, across-beats emits an equal descriptor." :program "(define d1 (across-beats 'circle))\n(define d2 (across-beats 'circle))\n(display (equal? d1 d2))" :invariant "∀ name driver-state. across-beats(name, driver-state) = across-beats(name, driver-state)" :meta "Referential transparency for the descriptor constructor. Falsified if the emitter injects a timestamp or per-call counter into the descriptor. See book-of-math ch01 (equality) and book-of-computing ch03 (pure vs effectful).") (:eng "Deterministic emission = safe to memoize per bar." :math "Pure function: same input, same output." :cs "Referential transparency; constructor, not effect."))
  :row-5-emergence ((:base "across-beats emits a beat-locked formation descriptor." :composition "(define (section-plan ctx)\n  (let ((form (across-beats (ctx-get 'section ctx))))\n    (in-formation form (entity/list))))\n(on-frame\n  (lambda () (when (audio-beat?) (section-plan (ctx)))))" :emergent "rhythm-locked choreography pipeline: section -> formation descriptor -> entity placement, each stage clean." :meta "This is the same shape as a render pipeline: intent -> layout -> paint. Analogous to a virtual-DOM diff step feeding a real-DOM patch step. See book-of-composition ch04 (pipelines).") (:eng "Pipeline stages fail loudly at their own boundary; easier to debug than a monolithic 'do the dance'." :math "Function composition f∘g∘h." :cs "Producer-consumer chain; each stage is a pure transformer feeding an effectful sink."))
)

(verb
  :name "after"
  :library "core"
  :kind "null"
  :signature "(after seconds state-name [ctx]) -> descriptor"
  :summary "Transition to a new state after a delay (in seconds)."
  :explanation "After is a cart verb that returns a descriptor for delayed state transition. It takes a duration in seconds, a target state name (symbol), and an optional context. The driver schedules the transition; when the timer expires, the cart enters the target state with the given context. Useful for timeouts, cooldowns, or orchestrating multi-frame flows."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(after 2 'check-status)" :note "After 2 seconds, transition to check-status state.")
    (:dialect "motoi" :tier "intermediate" :code "(define (cooldown-expired? ctx)\n  (let ((last-action (ctx-get 'last-action-time ctx)))\n    (if (null? last-action) #t (> (- (time 'now) last-action) 1000))))\n(define (do-action ctx)\n  (if (cooldown-expired? ctx)\n    (act 'world/spawn (list 'effect 0 0) 'action-done)\n    (after 0.5 'retry-action ctx)))" :note "Check cooldown; if expired, act; otherwise, retry after a short delay.")
    (:dialect "motoi" :tier "expert" :code "(define (wait-for-response ctx)\n  (let ((request-id (ctx-get 'request-id ctx)) (timeout-ms 5000))\n    (after (/ timeout-ms 1000) 'timeout (ctx-set 'request-id request-id ctx))))\n(define (timeout ctx)\n  (escalate 'request-timeout (ctx-get 'request-id ctx)))" :note "Schedule a timeout for a remote request; escalate if the timeout fires.")
  )
  :caveats ("State name must be a quoted symbol; unregistered state names are caught by the driver, not the Scheme code." "Duration is in seconds, as a number; fractional seconds are supported." "Context passed to the target state is the one provided here; if null, an empty list is used." "Multiple after calls stack; each schedules its own transition (can cause unexpected state changes).")
  :drawbacks ("No way to cancel a scheduled transition from Scheme; use escalate to force a different path." "Precision depends on the frame rate and driver implementation; sub-millisecond timing is not reliable." "Context is not merged; the target state receives exactly the context you provide, losing any updates made in the meantime.")
  :usecases ("Implement timeouts (e.g., wait for a network response, then escalate if it doesn't arrive)." "Add cooldowns or delays between actions (e.g., prevent spamming a button)." "Orchestrate multi-frame animations or transitions." "Implement simple state machines with time-based transitions (e.g., brief alert, then dismiss).")
  :related ("next" "escalate" "interrupted" "time/when" "time/until")
  :learn (:concept "Descriptors for scheduled transitions. After captures a delay and target state; the driver executes the transition when the timer fires." :prerequisites ("define" "quote" "ctx-get" "ctx-set") :progression "Start with simple after (no context); then thread context through; then combine with escalate for timeouts.")
  :row-2-audit ((:problem "A network request has been sent; if no response arrives within five seconds, escalate a timeout instead of blocking the cart forever." :program "(define (start-request ctx)\n  (net/send (ctx-get 'req ctx))\n  (after 5 'timeout ctx))\n(define (timeout ctx)\n  (escalate 'request-timeout (ctx-get 'req ctx)))" :explanation "start-request fires the request and immediately schedules a delayed transition to the timeout state. The driver holds the transition until 5 seconds elapse, at which point it enters timeout with the original ctx." :meta "wait would block until an event fires with no time bound; time/when schedules absolute time, not relative. after is the correct choice when the operator says 'in N seconds, go to state X' without regard to wall-clock.") (:eng "Operator log: 'scheduled timeout at t+5s'. If the timeout never fires, the audit points at the driver's timer wheel, not at this call site." :math "Delay is a real-valued parameter; the transition happens at t+delay seconds relative to call." :cs "Descriptor emitted; no blocking. State-machine transition primitive."))
  :row-3-dimension ((:setup "delayed-message-to-self" :rungs ((:domain "motoi state machine" :code "(after 2 'check-status)") (:domain "unix at command" :code ";; schedule a shell command for later:\n;; at now + 2 minutes <<< 'check-status.sh'") (:domain "temporal logic" :code ";; classical temporal logic: eventually(check-status) in bounded time:\n;; ◇_{≤5s} check-status")) :explanation "Each rung is 'wait some time, then take an action.' The verb NAMES both the delay and the follow-up so no one has to poll." :meta "Delayed-message-to-self is the reusable shape: whoever holds a clock offers the callback in the future, not the operator.") (:eng "Timer wheel semantics; identical across queues, cron, at, and setTimeout." :math "Bounded eventuality operator from temporal logic." :cs "Delayed-continuation; the runtime holds a closure until t fires."))
  :row-4-proof ((:claim "after does not fire before its delay: the target state is unreachable via after during the interval [call-time, call-time + delay)." :program "(define fired? #f)\n(after 1 'mark)\n(define (mark ctx) (set! fired? #t))\n;; check immediately:\n(display fired?)  ;; must be #f" :invariant "∀ delay > 0. ∀ t < call-time + delay. state-at(t) ≠ target" :meta "Lower-bound guarantee on delay. Falsified if the driver fires transitions eagerly. See book-of-computing ch07 (scheduling) and book-of-math ch07 (real intervals).") (:eng "Testable via a stopwatch harness; any early firing is a P1 bug on the driver." :math "Half-open interval; delay is a strict lower bound." :cs "Non-preemptive scheduling contract; delay is monotone-lower-bound."))
  :row-5-emergence ((:base "after schedules a delayed state transition." :composition "(define (do-work ctx)\n  (cond ((work-done? ctx) (next 'complete ctx))\n        (else (after 0.5 'do-work ctx))))" :emergent "polling loop: after + guard predicate + self-referential state name = a poll-until-ready loop with a fixed cadence." :meta "Same family as JavaScript setTimeout-based polling, or Kubernetes reconcile-loops. See book-of-composition ch09 (retry loops).") (:eng "Bounded backoff pattern; the polling cadence lives in one place." :math "Fixed-point iteration with a temporal step." :cs "Trampoline-style recursive scheduling."))
)

(verb
  :name "after-frame"
  :library "core"
  :kind "io"
  :signature "(after-frame fn) -> 'ok | ['error reason detail]"
  :summary "Execute a function after the current and next animation frame complete (layout and paint are settled)."
  :explanation "After-frame ensures a function runs after the browser has committed layout and paint changes. It uses requestAnimationFrame twice: the first rAF waits for layout, the second for paint. If rAF is unavailable (Node.js, headless), it falls back to a 32ms setTimeout. Useful for DOM measurements, triggering animations after a card has settled, or coordinating with browser paint cycles. The function is wrapped in try-catch; exceptions are logged but do not propagate."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(after-frame (lambda () (console.log 'painted)))" :note "Log a message after the frame has painted; confirms the card is visually settled.")
    (:dialect "motoi" :tier "intermediate" :code "(after-frame (lambda () (let ((h (card-rows))) (set! my-height h))))" :note "Measure the card's rendered height after layout and paint; cache it in a mutable variable.")
    (:dialect "motoi" :tier "expert" :code "(define (trigger-animation ctx)\n  (after-frame (lambda () (card/emit (list ':animation 'fade-in))))\n  (next 'animating ctx))" :note "Schedule an animation emission after the card's DOM is settled; transition to animating state immediately.")
    (:dialect "motoi" :tier "novice" :code "(after-frame\n  (lambda ()\n    (display \"paint settled\")))" :note "Runs once, after the browser has actually painted the frame you just built.")
    (:dialect "motoi" :tier "intermediate" :code "(begin-frame 'main)\n(grid-cell-set! 3 3 1)\n(end-frame 'main)\n(after-frame\n  (lambda ()\n    (display (grid-live-count))))" :note "Paint a cell, then measure the live count only after paint has finished.")
  )
  :caveats ("Function must be a callable; lambda or a defined function name (not a symbol or data)." "Side effects (DOM mutation, global state changes) happen inside the function; be careful not to corrupt card state." "Exceptions in fn are caught and logged, but not reported back to the cart (the cart sees 'ok regardless)." "In Node.js or headless environments, rAF falls back to setTimeout; timing is approximate.")
  :drawbacks ("No feedback on the function's success or return value; if fn throws, the error is logged but lost." "Two rAF calls mean a two-frame delay; if sub-frame precision is needed, use raw requestAnimationFrame." "The function runs outside the cart's context; any state changes it makes are not visible to the cart unless they mutate a shared reference.")
  :usecases ("Measure DOM dimensions after a card has rendered (card-rows, card-rect, etc.)." "Trigger CSS animations or transitions that require a layout reflow." "Coordinate Scheme-driven changes with browser paint (e.g., apply a visual effect after a card lands)." "Defer work until the frame is settled, avoiding jank from synchronous DOM access.")
  :related ("on-frame" "card-rect" "card-rows" "card-settle-breath" "measure-content")
  :learn (:concept "Scheduling functions relative to the browser's paint cycle. After-frame ensures DOM is settled before the function runs." :prerequisites ("lambda" "define") :progression "Use after-frame for simple measurements; then combine with on-frame for per-frame hooks; then use card-settle-breath for automatic animation coordination.")
  :row-2-audit ((:problem "A card just added rows; the operator needs to measure the card's rendered height AFTER the browser lays it out and paints, then cache the height for a follow-up animation." :program "(define measured-height 0)\n(after-frame\n  (lambda ()\n    (set! measured-height (card-rows))\n    (display measured-height)))" :explanation "The lambda runs after two rAF cycles, so layout and paint have committed. card-rows now returns the true measured height rather than a stale pre-layout number." :meta "on-frame fires every frame; time/every-ms is wall-clock, not paint-cycle. after-frame is the correct choice when the operator specifically needs 'the frame after this one has painted.'") (:eng "Operator log: 'measurement fired at t+2rAF'. If the measurement is wrong, the audit checks whether DOM mutations happened between call and callback." :math "Two frames of latency; if the display is 60Hz, ~33ms." :cs "Post-commit hook; runs off the render critical path."))
  :row-3-dimension ((:setup "callback-after-io-settles" :rungs ((:domain "motoi framebuffer" :code "(after-frame (lambda () (measure-content)))") (:domain "filesystem" :code ";; fsync then callback:\n;; fsync(fd); on_sync(fd, cb)") (:domain "two-phase commit" :code ";; commit phase 2 must run only after phase 1 durably lands:\n;; PREPARE OK -> COMMIT -> callback")) :explanation "Each rung says 'the observable state of the world is not yet what you think it is; wait until it settles.' The shape is 'defer until a boundary crosses.'" :meta "The wait boundary is a device commit in one domain and a paint commit in another. Same idea.") (:eng "Post-commit callbacks are a universal SRE tool." :math "Sequential composition with a barrier." :cs "Async barrier / rendezvous point."))
  :row-4-proof ((:claim "The function passed to after-frame runs strictly AFTER the current frame's paint commits." :program "(define call-frame -1)\n(define fire-frame -1)\n(set! call-frame (frame))\n(after-frame\n  (lambda ()\n    (set! fire-frame (frame))\n    (display (> fire-frame call-frame))))" :invariant "∀ call ∈ after-frame. frame(callback-fires) > frame(call-issued)" :meta "Strict-later guarantee. Falsified if the callback ever runs synchronously in-line. See book-of-computing ch07 (scheduling) and book-of-animation ch03 (frame lifecycle).") (:eng "Two-frame guarantee ensures DOM measurements are stable." :math "Strict inequality on frame index." :cs "Happens-after ordering; a partial order on frame boundaries."))
  :row-5-emergence ((:base "after-frame defers a callback until the frame paints." :composition "(begin-frame 'main)\n(grid-cell-set! 3 3 1)\n(end-frame 'main)\n(after-frame\n  (lambda ()\n    (card/emit (list ':measured (card-rows)))))" :emergent "settle-then-emit pipeline: mutate -> commit frame -> measure -> emit measurement. Downstream cards react to REAL numbers, not projected ones." :meta "Same family as React's useLayoutEffect or DOM's ResizeObserver. See book-of-composition ch07 (settle patterns).") (:eng "Reduces layout thrash by batching measurements." :math "Sequential composition with a commit barrier." :cs "Post-commit observer; publish/subscribe with a paint gate."))
)

(verb
  :name "arc-between"
  :library "core"
  :kind "meta"
  :signature "(arc-between start-pos end-pos [opts]) -> formation"
  :summary "Computes a curved path formation between two positions, suitable for choreographed movement."
  :explanation "arc-between generates a formation descriptor that describes an arc trajectory from a start position to an end position. It is used in conjunction with verbs like `in-formation` and `walk-together` to orchestrate smooth, curved group movement across the world. The arc respects beat timing and can be parameterized by control points or curvature. Think of it as specifying the shape of a dance path that multiple entities can follow in sync."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(arc-between '(10 20) '(50 60))" :note "Returns a formation descriptor for a simple arc from (10,20) to (50,60)")
    (:dialect "motoi" :tier "intermediate" :code "(define e2 'e2)\n(define e1 'e1)\n(let ((start (entity/pos e1))\n      (end (entity/pos e2)))\n  (arc-between start end))" :note "Compute an arc formation between two entity positions dynamically")
    (:dialect "motoi" :tier "expert" :code "(define follower2 'follower2)\n(define follower1 'follower1)\n(define target-pos 'target-pos)\n(define leader 'leader)\n(let ((path (arc-between (entity/pos leader) target-pos)))\n  (in-formation path (list follower1 follower2)))" :note "Use arc-between to define the path, then apply it to followers via in-formation")
    (:dialect "motoi" :tier "novice" :code "(define path (arc-between '(0 0) '(100 0)))\n(display path)" :note "A curved path from the origin to (100, 0). Not a straight line.")
    (:dialect "motoi" :tier "intermediate" :code "(define swoop (arc-between '(0 0) '(100 100) '(height 40)))\n(display swoop)" :note "Same arc but 40 units of vertical lift. Reads as a graceful swoop.")
  )
  :caveats ("Requires valid numeric position tuples (x, y); invalid positions may produce silent no-ops or error signals." "The formation is a descriptor; it does not execute movement itself—use in-formation or walk-together to apply it." "Arc semantics (curvature, control points) are inferred from source; exact parameterization requires source audit.")
  :drawbacks ("Only useful when paired with a choreography verb; arc-between alone does not move entities." "For straight-line paths, a simpler approach may exist; check related verbs." "Complex arcs with many control points may incur higher compute cost per beat tick.")
  :usecases ("Choreographing dancers or units in formation around a target point." "Creating smooth evasion or approach curves for game AI." "Scripting camera or entity paths that must be smooth and arc-shaped.")
  :related ("in-formation" "walk-together" "with-spacing" "sub-position-per-beat" "at-beat" "across-beats")
  :learn (:concept "Formations as first-class choreography primitives; arc is one shape in the formation family." :prerequisites ("(core)/let" "entity/pos") :progression "After arc-between, learn in-formation to apply arcs to groups, then walk-together to synchronize motion across beats.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A boss enemy needs to swoop across the screen from (0,0) to (100,0) via a graceful arc, not a straight line." :program "(define swoop (arc-between '(0 0) '(100 0) '(height 40)))\n(in-formation swoop (list 'boss))" :explanation "arc-between builds a path descriptor with 40 units of vertical lift. in-formation places the boss along the path; the driver walks the path as beats advance." :meta "A raw pair of endpoints is a line; entity/set-pos! moves one entity but does not carry a shape. arc-between is the correct choice when the operator says 'follow this curved shape.'") (:eng "Operator log: 'arc from (0,0) to (100,0) lift 40'. If the boss moves straight, the audit points at whether a formation verb consumed the descriptor." :math "A quadratic Bezier with control point (50, 40); parametrised by t ∈ [0,1]." :cs "Constructor for a Path descriptor; effect deferred."))
  :row-3-dimension ((:setup "two-endpoints-plus-curvature" :rungs ((:domain "motoi choreo" :code "(arc-between '(0 0) '(100 0) '(height 40))") (:domain "cad drafting" :code ";; drafting a fillet arc between two lines:\n;; fillet start=(0,0) end=(100,0) radius=40") (:domain "parametric geometry" :code ";; parametric curve p(t) = (1-t)²·P0 + 2(1-t)t·P1 + t²·P2\n(define (bezier2 p0 p1 p2 t) (list p0 p1 p2 t))")) :explanation "Each rung takes two endpoints and a control parameter and returns a smooth curve. The curve is the same object under three names." :meta "'Curvature as a parameter' is the shape; the domain provides the substrate.") (:eng "Arc primitives appear in every drafting tool and every animation library." :math "Bezier / conic section family, indexed by curvature." :cs "Path descriptor with parametric evaluator."))
  :row-4-proof ((:claim "arc-between passes through both endpoints: the path at t=0 equals start, and at t=1 equals end." :program "(define p (arc-between '(0 0) '(100 0) '(height 40)))\n;; conceptual: (path-eval p 0) => (0 0), (path-eval p 1) => (100 0)\n(display (list 'endpoints-preserved 'assumed-by-descriptor-contract))" :invariant "∀ start end opts. path(arc-between(start, end, opts), 0) = start ∧ path(..., 1) = end" :meta "Endpoint interpolation invariant. Falsified by any parameterisation that offsets from the endpoints. See book-of-math ch14 (Bezier curves) and book-of-motion ch11 (path primitives).") (:eng "An arc that misses its endpoint is a P1 choreography bug." :math "Interpolation condition on parametric curves." :cs "Boundary conditions on a path descriptor."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "arc-between constructs a curved path descriptor." :composition "(define path (arc-between (entity/pos 'leader) (entity/pos 'target)))\n(in-formation path (list 'follower1 'follower2 'follower3))" :emergent "follow-the-leader choreography: dynamic endpoint -> arc -> formation. Followers trace the arc from wherever the leader currently is." :meta "Same family as game AI steering paths or camera-orbit rigs. See book-of-composition ch12 (dynamic pathing).") (:eng "Dynamic recomputation each frame; costs O(1) per entity." :math "Path composition with time-varying endpoints." :cs "Curried curve constructor over live entity positions."))
)

(verb
  :name "at-beat"
  :library "core"
  :kind "meta"
  :signature "(at-beat beat-offset) -> position-or-value"
  :summary "Computes a position or value synchronized to a specific beat offset within the current tempo."
  :explanation "at-beat is a choreography verb that takes a beat offset (typically a number or fraction) and returns the position or value at that point in the rhythmic timeline. It is used in formation-based choreography to synchronize entity movement to the beat grid. By specifying a beat offset, you can query where an entity should be at any moment relative to the current song tempo."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(at-beat 0)" :note "Get the position at beat 0 (the current beat); typically returns an origin or start position")
    (:dialect "motoi" :tier "intermediate" :code "(define entity 'entity)\n(let ((pos (at-beat 0.5)))\n  (entity/set-pos! entity pos))" :note "Move an entity to the position at the half-beat offset")
    (:dialect "motoi" :tier "expert" :code "(define entity 'entity)\n(map (lambda (beat-off)\n       (let ((pos (at-beat beat-off)))\n         (entity/set-pos! entity pos)))\n     '(0 0.5 1 1.5 2))" :note "Animate an entity through multiple beat-synchronized positions by stepping through beat offsets")
  )
  :caveats ("Requires an active audio tempo context; if no tempo is running, behavior is undefined or returns a default." "Beat offset is relative to the current beat, not absolute time." "Different formation verbs (in-formation, arc-between) may interpret at-beat results differently." "Fractional beats (0.5, 1.5) are valid and allow sub-beat granularity.")
  :drawbacks ("Only useful in a tempo-aware context; on a non-tempo surface or with audio halted, it may be a no-op." "Does not directly move entities; you must use entity/set-pos! or similar to apply the result." "Complex beat offsets or curves are better expressed via arc-between or in-formation.")
  :usecases ("Querying synchronized positions in a beat-grid choreography." "Animating entities to snap to beat-aligned positions." "Implementing step-sequencer or rhythm-game logic where position is tied to beats.")
  :related ("across-beats" "arc-between" "in-formation" "walk-together" "audio-beat?" "audio-tempo")
  :learn (:concept "Beat-synchronized choreography primitives; position as a function of rhythm." :prerequisites ("audio-tempo" "entity/set-pos!" "(core)/let") :progression "After at-beat, learn arc-between to define paths, then in-formation to apply paths to groups.")
  :row-2-audit ((:problem "A rhythm game needs the player token to be at the 'strike-position' at the half-beat, not later." :program "(on-frame\n  (lambda ()\n    (let ((pos (at-beat 0.5)))\n      (entity/set-pos! 'player pos))))" :explanation "Each frame, at-beat 0.5 returns the position corresponding to the half-beat offset in the current tempo. The player is teleported to that position, staying rhythm-locked." :meta "audio-time returns raw seconds; audio-beat? is a single-shot predicate. at-beat is the correct choice when the operator says 'give me the position at this rhythmic offset.'") (:eng "Operator log: 'position query at beat 0.5'. If the player drifts, the audit points at the tempo, not at this verb." :math "Beat offset is a real number; position is a function of beat and current formation." :cs "Read from tempo state; pure per-frame query."))
  :row-3-dimension ((:setup "query-a-value-at-a-normalized-offset" :rungs ((:domain "motoi rhythm" :code "(at-beat 0.75)") (:domain "animation curve" :code ";; sample a curve at t = 0.75:\n(easing 'ease-in-out 0.75)") (:domain "function evaluation" :code ";; evaluate f at a specific x:\n(define (f x) (* x x))\n(f 0.75)")) :explanation "Each rung takes a normalized offset and returns the value at that offset." :meta "Sampling a function at a normalized coordinate; the coordinate happens to be beat-space.") (:eng "Sampling primitives are the backbone of every animation and simulation loop." :math "Function evaluation at a point." :cs "Pure query into a time-indexed value stream."))
  :row-4-proof ((:claim "at-beat is a pure function of the beat argument given a fixed tempo context." :program "(define a (at-beat 0.5))\n(define b (at-beat 0.5))\n(display (equal? a b))" :invariant "∀ beat. (fixed-tempo → at-beat(beat) = at-beat(beat))" :meta "Referential transparency under fixed tempo. Falsified only by tempo change between calls. See book-of-math ch01 (functions) and book-of-sound ch05 (beat grid).") (:eng "Stable per-frame; safe to memoize per tempo epoch." :math "Pure function of one variable." :cs "Read-only query on scheduler state."))
  :row-5-emergence ((:base "at-beat samples position at a beat offset." :composition "(define trail '())\n(on-frame\n  (lambda ()\n    (set! trail (cons (at-beat 0) trail))\n    (when (> (length trail) 32)\n      (set! trail (take trail 32)))))" :emergent "beat-locked history buffer: the trail records positions on each frame, all rhythm-anchored, ready to draw as a motion trail." :meta "Same family as circular-buffer trails in shader-based motion blur. See book-of-composition ch08 (history buffers).") (:eng "Bounded memory; trail length is a fixed operator knob." :math "Sampled sequence over discrete frame index." :cs "Ring buffer with tempo-locked producer."))
)

(verb
  :name "audio-band"
  :library "core"
  :kind "rd"
  :signature "(audio-band n) -> number"
  :summary "Returns the magnitude of the n-th frequency band from the current audio spectrum snapshot."
  :explanation "audio-band reads the current audio snapshot's frequency band array and returns the magnitude (typically 0–1 or 0–255, depending on the audio backend) at index n. This is useful for visualizing music or audio in real time: you can use band values to drive visual effects, control animation timing, or implement audio-reactive gameplay. The verb is read-only and returns a single number; for the full band array, use audio-bands."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(audio-band 0)" :note "Get the magnitude of the lowest frequency band (usually bass)")
    (:dialect "motoi" :tier "intermediate" :code "(define audio-bands-length (lambda args (list \"audio-bands-length\" args)))\n(let ((bass (audio-band 0))\n      (treble (audio-band (- (audio-bands-length) 1))))\n  (set-dot-radius (* 10 bass))\n  (set-dot-color (list 255 (* 128 treble) 0)))" :note "Read bass and treble bands, use them to drive visual properties (radius and color)")
    (:dialect "motoi" :tier "expert" :code "(define (iota n)\n  (let loop ((i 0) (acc '()))\n    (if (= i n) (reverse acc) (loop (+ i 1) (cons i acc)))))\n(begin\n  (for-each (lambda (band-idx)\n              (let ((mag (audio-band band-idx)))\n                (when (> mag 0.5)\n                  (surface-paint-dots (list '(+ (* band-idx 10) 50) 100) 5 255))))\n            (iota 32)))" :note "Iterate over 32 bands and paint dots where magnitude exceeds a threshold")
    (:dialect "motoi" :tier "novice" :code "(if (> (audio-band 2) 0.4)\n    (display \"kick!\")\n    (display \".\"))" :note "The lowest bands carry the drum. Print a mark when the kick pushes past 0.4.")
    (:dialect "motoi" :tier "intermediate" :code "(define (spring-height)\n  (+ 20 (* 100 (audio-band 3))))\n(on-frame\n  (lambda ()\n    (grid-cell-set! 5 5 (spring-height))))" :note "Bind a cell's height to a bass band so the grid bounces with the song.")
  )
  :caveats ("Index n is coerced to integer (|0); non-integer inputs are truncated, not rounded." "Out-of-bounds indices silently return 0; there is no error signal for invalid band numbers." "The snapshot is current at the time of the call; if audio is paused, the snapshot is stale." "Band count (audio-bands-length) varies by audio backend and FFT size; typical range is 32–1024.")
  :drawbacks ("Single-band access is efficient, but querying many bands repeatedly allocates call overhead; use audio-bands for bulk access." "No built-in normalization or smoothing; raw band values can be noisy frame-to-frame." "Band frequencies are evenly spaced in the FFT output, not perceptually uniform; bass bands may feel compressed.")
  :usecases ("Driving visual effects (color, size, glow) reactively to music." "Implementing audio-driven gameplay (e.g., boss health tied to kick drum magnitude)." "Building audio visualization (spectrum analyzer, equalizer display)." "Triggering game events when a specific frequency band exceeds a threshold.")
  :related ("audio-bands" "audio-peak" "audio-rms" "audio-onset?" "set-dot-radius" "set-dot-color" "surface-paint-dots")
  :learn (:concept "Frequency-domain audio analysis; real-time spectrum access for reactive effects." :prerequisites ("(core)/let" "audio-bands") :progression "After audio-band, learn audio-onset? and audio-peak for event-driven music synchronization, then build full visualizers with surface-paint-dots.")
  :row-2-audit ((:problem "A visualization needs the kick-drum band (low frequency) to drive a pulsing circle radius each frame." :program "(on-frame\n  (lambda ()\n    (let ((kick (audio-band 2)))\n      (set-dot-radius (* 40 kick)))))" :explanation "Each frame, band index 2 (typically bass) is read and scaled into a pixel radius. The circle pulses in size proportional to how loud the bass currently is." :meta "audio-rms is a scalar averaged over all frequencies; audio-peak is the max. audio-band is the correct choice when the operator wants ONE frequency bucket.") (:eng "Operator log: 'band[2]=0.72 -> radius=29'. If the pulse feels wrong, the audit is on the FFT window, not on this verb." :math "Magnitude of a single FFT bin; range [0,1] typically." :cs "Array read at index n from a per-frame snapshot."))
  :row-3-dimension ((:setup "indexed-read-of-a-vector" :rungs ((:domain "motoi spectrum" :code "(audio-band 3)") (:domain "thermometer bank" :code ";; read sensor 3 from a thermometer array:\n;; sensors[3].value") (:domain "vector projection" :code ";; project a vector onto standard basis e_3:\n(define (proj v i) (list-ref v i))")) :explanation "Each rung takes a vector-of-magnitudes and a nonnegative index and returns the value at that slot." :meta "Indexed vector projection is a shape that occurs anywhere you have a bank of parallel signals.") (:eng "Sensor array pattern shared by audio, DAQ, and telemetry systems." :math "Projection onto a standard basis vector." :cs "O(1) array indexing."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Out-of-bounds index returns 0 rather than raising; the function is total over integer indices." :program "(display (audio-band 999999))  ;; expect 0\n(display (audio-band -1))       ;; expect 0" :invariant "∀ n ∈ ℤ. audio-band(n) ∈ [0, 1] ∪ {0 when out of range}" :meta "Totality via clamping. Falsified by any raising path. See book-of-math ch01 (total functions) and book-of-ml ch04 (spectral features).") (:eng "Safe to loop over guessed ranges without try/catch." :math "Total function via silent clamp." :cs "Defensive read with default-on-bounds-miss."))
  :row-5-emergence ((:base "audio-band reads one frequency band." :composition "(on-frame\n  (lambda ()\n    (when (> (audio-band 2) 0.6)\n      (world/spawn 'particle 100 100))))" :emergent "band-triggered event source: threshold + band read = a discrete event stream keyed to a frequency." :meta "Same family as onset detectors, gate compressors, and Schmitt triggers. See book-of-composition ch11 (event triggers).") (:eng "Simple thresholding is the workhorse of audio-reactive gameplay." :math "Predicate on a scalar reading." :cs "Event source; discrete emission from continuous stream."))
)

(verb
  :name "audio-bands"
  :library "core"
  :kind "rd"
  :signature "(audio-bands) -> list"
  :summary "Returns a fresh list of the current audio spectrum bands (frequency magnitudes)."
  :explanation "Reads the audio engine's snapshot of the frequency spectrum divided into bands. Each band represents the magnitude (loudness) in a frequency range. The snapshot is cached per frame; calling this multiple times in the same frame returns the same data. Use this to drive visualizers, beat detection, or frequency-responsive effects. The list is a copy, so mutations do not affect the engine state."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((bands (audio-bands)))\n  (display (car bands)))" :note "Read the first band's magnitude; bands are ordered from low to high frequency.")
    (:dialect "motoi" :tier "intermediate" :code "(define (spectrum-bars)\n  (let ((bands (audio-bands)))\n    (map (lambda (b) (> b 0.5)) bands)))" :note "Map over bands to detect which frequencies are loud; useful for driving a visual equalizer.")
    (:dialect "motoi" :tier "expert" :code "(define (paint-spectrum ctx)\n  (let ((bands (audio-bands))\n        (cols (canvas-cols)))\n    (for-each\n      (lambda (i)\n        (when (< i (length bands))\n          (let ((mag (list-ref bands i)))\n            (canvas-cell-set! i 0 (if (> mag 0.3) 1 0)))))\n      (range 0 cols))))" :note "Paint a row of cells based on whether each frequency band exceeds a threshold; a spectrum analyzer.")
    (:dialect "motoi" :tier "novice" :code "(display (length (audio-bands)))" :note "See how many bands the engine offers before you decide how many to draw.")
    (:dialect "motoi" :tier "intermediate" :code "(define (loudest)\n  (let loop ((bands (audio-bands)) (i 0) (best 0) (best-i 0))\n    (if (null? bands)\n        best-i\n        (if (> (car bands) best)\n            (loop (cdr bands) (+ i 1) (car bands) i)\n            (loop (cdr bands) (+ i 1) best best-i)))))" :note "Walk the spectrum and remember which band shouted loudest this frame.")
  )
  :caveats ("Returns a copy; the list is mutable but mutations do not feed back to the engine." "Snapshot is cached per frame; all calls within one frame return identical data." "Called before audio-play or before any audio starts playing, returns an empty or zero-filled list." "Band count and frequency ranges are fixed by the audio engine; do not assume a particular length.")
  :drawbacks ("Snapshot is frame-locked, so sub-frame granularity is unavailable." "Reading bands every frame incurs a copy cost; cache the result if used multiple times per frame." "Bands reflect global audio mix, not individual instruments or tracks.")
  :usecases ("Frequency-responsive visualizers (spectrum analyzers, LED strips)." "Adaptive gameplay logic driven by bass or treble presence." "Music-reactive particle effects or camera motion." "Beat detection combined with audio-beat? to trigger on specific frequency ranges.")
  :related ("audio-perceptual-bands" "audio-peak" "audio-rms" "audio-beat?" "audio-bpm" "audio-playing?")
  :learn (:concept "Reading frame-locked audio snapshots to drive real-time reactive effects." :prerequisites ("audio-playing?") :progression "After this, learn audio-perceptual-bands for human-hearing-aligned frequency buckets, or audio-peak for a scalar loudness readout.")
  :row-2-audit ((:problem "A spectrum analyzer must paint every FFT band as a vertical bar this frame." :program "(define (paint-spectrum)\n  (let ((bands (audio-bands)))\n    (for-each\n      (lambda (i)\n        (grid-cell-set! i 0 (if (> (list-ref bands i) 0.3) 1 0)))\n      (iota (length bands)))))" :explanation "audio-bands returns the whole snapshot in one call. The paint routine iterates once, saving 32+ individual reads." :meta "Calling audio-band N times allocates N call frames; audio-bands allocates one list. Correct choice when the operator wants the full spectrum.") (:eng "Operator log: 'bands snapshot length=64'. Full-snapshot reads are the efficient way to paint a visualizer." :math "Vector of magnitudes; one FFT frame." :cs "One allocation per call; list is a copy so caller cannot mutate engine state."))
  :row-3-dimension ((:setup "bulk-vector-read" :rungs ((:domain "motoi audio" :code "(audio-bands)") (:domain "database batch" :code ";; batch SELECT rather than N single-row SELECTs:\n;; SELECT * FROM bands") (:domain "vector fetch" :code ";; return a whole vector v ∈ ℝⁿ in one operation:\n(define (vec-of n f) (map f (iota n)))")) :explanation "Each rung amortises cost by returning a whole vector at once instead of forcing N individual queries." :meta "The shape is 'when reading many, read all.' Universally faster than repeated singleton reads.") (:eng "Batch reads dominate microservice, DB, and DSP performance." :math "Column-vector fetch; ℝⁿ." :cs "Amortised O(n) vs O(n) with n call overheads."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "audio-bands returns a fresh, mutation-safe list on each call." :program "(define a (audio-bands))\n(set-car! a 999)\n(define b (audio-bands))\n(display (= (car b) 999))  ;; expect #f" :invariant "∀ call. mutating the returned list does not affect the engine snapshot or future calls" :meta "Copy-on-read isolation. Falsified if the return shares memory with engine state. See book-of-computing ch09 (aliasing) and book-of-math ch12 (vectors).") (:eng "Safe to hand around without defensive copies at every stage." :math "Value semantics." :cs "Copy-on-read barrier between engine state and Scheme heap."))
  :row-5-emergence ((:base "audio-bands returns the whole spectrum vector." :composition "(define history '())\n(on-frame\n  (lambda ()\n    (set! history (cons (audio-bands) history))\n    (when (> (length history) 60)\n      (set! history (take history 60)))))" :emergent "spectrogram: bounded history of spectrum snapshots is a spectrogram, ready to render as a scrolling image." :meta "Same family as waterfall displays and spectrograms in ham radio and DSP. See book-of-composition ch08 (history buffers) and book-of-sound ch09 (spectrograms).") (:eng "Bounded ring buffer; memory footprint is constant." :math "Time-indexed sequence of vectors: a matrix." :cs "Ring buffer with vector element type."))
)

(verb
  :name "audio-bar-clock"
  :library "core"
  :kind "null"
  :signature "(audio-bar-clock <handle> [<bars-per-rotation>]) -> BarClockHandle"
  :summary "Creates a bar-aligned clock that phases smoothly from 0 to 1 over a musical bar, useful for vinyl/rotation effects."
  :explanation "Returns a closed-form clock handle whose phase cycles 0 → 1 in sync with musical bars (typically 4 beats). The optional bars-per-rotation argument sets how many bars equal one full rotation; default is 1 bar = 360°. This is designed for background vinyl animation and other smooth cyclic visuals that must stay locked to the song's beat grid. The clock emits two properties: phase (0 to 1, fractional bar progress) and radians (0 to 2π, equivalent angle)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((clock (audio-bar-clock (audio-play 'bg-loop))))\n  (display (clock 'phase)))" :note "Get the current phase of the bar clock (0.0 to 1.0) after starting audio playback.")
    (:dialect "motoi" :tier "intermediate" :code "(define (vinyl-angle)\n  (let ((clock (audio-bar-clock (audio-play 'song) 2)))\n    (* 360 (clock 'phase))))" :note "Use a 2-bar rotation: clock completes a full 360° turn every 2 bars.")
    (:dialect "motoi" :tier "expert" :code "(define (background-vinyl ctx)\n  (let ((clock (audio-bar-clock (audio-play 'bg) 1)))\n    (on-frame (lambda ()\n      (let ((angle (clock 'radians)))\n        (rotate-card (card-find-by-kind 'vinyl) angle))))))" :note "Rotate a vinyl sprite continuously, locked to bars; the rotation is frame-independent because the clock reads live audio time.")
    (:dialect "motoi" :tier "novice" :code "(define clk (audio-bar-clock (audio-play 'loop)))\n(display (clk 'phase))" :note "The clock hands back its phase as a number between 0 and 1 across one bar.")
    (:dialect "motoi" :tier "intermediate" :code "(define clk (audio-bar-clock (audio-play 'song) 4))\n(on-frame\n  (lambda ()\n    (let ((r (clk 'radians)))\n      (display r))))" :note "A 4-bar clock cycles once every four bars; radians are handy for rotating shapes.")
  )
  :caveats ("Requires an active audio handle (typically from audio-play); if audio stops, the clock freezes." "Phase wraps at 1.0; radians wraps at 2π (equivalent to 360°)." "bars-per-rotation is optional; omit it for a default 1-bar rotation." "The clock does not store state; it computes on every read from the current audio time, so it is safe to call repeatedly.")
  :drawbacks ("Depends on the audio engine's beat grid; if BPM is not detected, the clock may be inaccurate." "Does not work before audio playback begins; audio must be playing or prepared." "Radians output is convenient for rotation, but requires wrapping in trigonometric functions for complex motion.")
  :usecases ("Vinyl record rotation synced to music playback." "Smooth cyclic background animations (pulsing, color cycling) locked to the beat." "Synchronized multi-layer rotations with different bars-per-rotation for polyrhythmic visual effects." "Camera spin or zoom cycles that must stay in sync with the song structure.")
  :related ("audio-play" "audio-beat?" "audio-bpm" "audio-time" "tick/phase" "tick/sine")
  :learn (:concept "Bar-aligned cyclic clocks for beat-synced animation without manual frame counting." :prerequisites ("audio-play" "audio-bpm") :progression "Use this before tick/phase if you need beat-grid alignment; afterward, explore tick/lissajous for more complex periodic animations.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A vinyl record graphic must rotate smoothly in sync with the song, one full turn per bar." :program "(define clk (audio-bar-clock (audio-play 'song) 1))\n(on-frame\n  (lambda ()\n    (rotate-card 'vinyl (clk 'radians))))" :explanation "The clock ticks in sync with the audio engine. Each frame, radians is queried and the vinyl is rotated to that angle. Because the clock reads live audio time, the rotation stays locked to the beat grid regardless of frame rate." :meta "tick/phase runs on wall-clock; audio-time returns seconds. audio-bar-clock is the correct choice when the operator wants a beat-anchored phase.") (:eng "Operator log: 'bar-clock phase=0.42 rad=2.64'. If rotation drifts, the audit is on the tempo, not on this closure." :math "Phase φ(t) = fractional-part(t / bar-length); radians = 2π · φ." :cs "Closure holding a reference to audio state; queries return current phase."))
  :row-3-dimension ((:setup "normalized-phase-over-a-cycle" :rungs ((:domain "motoi audio" :code "(audio-bar-clock (audio-play 'song))") (:domain "engine timing belt" :code ";; engine crank angle relative to TDC:\n;; crank_phase = (angle mod 720°) / 720°") (:domain "circle group" :code ";; ℝ / ℤ: real number modulo one\n(define (phase t) (- t (floor t)))")) :explanation "Each rung is a value that wraps around at a period boundary, exposing progress as a fraction in [0,1)." :meta "'Phase' is a fundamental time shape; any periodic system has one.") (:eng "Wall-clock vs music-clock is a classic SRE trap; anchoring on the music-clock is honest." :math "Element of the circle group ℝ/ℤ." :cs "Modular phase closure with side-effect-free read."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Phase is monotone within one cycle and wraps to zero at bar boundaries." :program "(define clk (audio-bar-clock (audio-play 'song)))\n(define p1 (clk 'phase))\n;; a few frames later:\n(define p2 (clk 'phase))\n(display (or (>= p2 p1) (< p2 p1)))  ;; monotone within cycle, wraps between" :invariant "∀ t ∈ [bar-k, bar-(k+1)). phase(t) ∈ [0,1) ∧ monotone ↑, phase(bar-(k+1))=0" :meta "Modular monotonicity. Falsified by any negative-going phase within a cycle. See book-of-math ch05 (modular arithmetic) and book-of-sound ch07 (bar phase).") (:eng "Stable wrap is what keeps the vinyl from stuttering." :math "Monotone within a period, discontinuous at the period boundary." :cs "Wrap-around counter with normalized output."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "audio-bar-clock gives a beat-anchored phase closure." :composition "(define clk (audio-bar-clock (audio-play 'song) 4))\n(on-frame\n  (lambda ()\n    (rotate-card 'wheel-a (clk 'radians))\n    (rotate-card 'wheel-b (* 2 (clk 'radians)))))" :emergent "polyrhythmic visual rig: two wheels spinning at 1x and 2x from ONE phase source. Cheap, exact, and rhythm-locked." :meta "Same family as LFO fan-out in modular synths. See book-of-composition ch10 (fan-out) and book-of-sound ch12 (polyrhythm).") (:eng "One source of truth for phase means less drift between visual elements." :math "Phase multiplication for harmonics." :cs "Shared closure with multiple consumers."))
)

(verb
  :name "audio-beat?"
  :library "core"
  :kind "rd"
  :signature "(audio-beat?) -> boolean"
  :summary "Returns true if the current frame is on a musical beat, false otherwise."
  :explanation "A predicate that detects beat onsets detected by the audio analysis engine. Returns true once per beat (typically every quarter note), false between beats. This is useful for triggering events, spawning particles, or switching animation frames in sync with the rhythm. The detection is frame-based: within a single frame, the result is constant, and it changes only on the frame boundary when a new beat is detected."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(when (audio-beat?)\n  (display \"beat!\"))" :note "Print \"beat!\" once per frame when a beat is detected.")
    (:dialect "motoi" :tier "intermediate" :code "(define (spawn-beat-particle ctx)\n  (when (audio-beat?)\n    (world/spawn 'particle (ctx-get ctx 'x) (ctx-get ctx 'y))))" :note "Spawn a particle at the player's current position every time a beat hits.")
    (:dialect "motoi" :tier "expert" :code "(define (beat-counter ctx)\n  (let ((count (ctx-get ctx 'beat-count)))\n    (if (audio-beat?)\n      (next (if (= (modulo (+ count 1) 4) 0) 'measure-end 'playing)\n            (ctx-set 'beat-count (+ count 1) ctx))\n      (next 'playing ctx))))" :note "Count beats and trigger a different state every 4 beats (one measure); uses audio-beat? inside a state machine.")
    (:dialect "motoi" :tier "novice" :code "(on-frame\n  (lambda ()\n    (when (audio-beat?)\n      (grid-cell-set! 0 0 1))))" :note "Blink cell (0,0) each time the engine hears a beat.")
    (:dialect "motoi" :tier "intermediate" :code "(define count 0)\n(on-frame\n  (lambda ()\n    (when (audio-beat?)\n      (set! count (+ count 1))\n      (when (= (modulo count 4) 0)\n        (display \"downbeat\")))))" :note "Count beats and mark every fourth one as a downbeat.")
  )
  :caveats ("Returns true for only one frame per beat; the next frame returns false until the next beat." "Accuracy depends on the audio engine's beat detection; very quiet audio or silence may not detect beats reliably." "If no audio is playing, audio-beat? always returns false." "Beat detection can lag by a few frames if the audio buffer is large.")
  :drawbacks ("Frame-locked: sub-frame beat events are not detectable." "Beat detection is heuristic-based; it may miss beats in noisy or syncopated music." "Cannot distinguish beat types (e.g., downbeat vs. offbeat) without additional logic." "Launching with audio-play is required; silent or pre-recorded audio with no tempo returns false.")
  :usecases ("Rhythm-game input validation (checking if the player hit a note on the beat)." "Spawning dance move animations or particle effects on the beat." "Triggering scene transitions or level changes at measure boundaries (combined with beat counting)." "Synchronized flashing, color changes, or camera movements keyed to the song.")
  :related ("audio-bpm" "audio-time" "audio-playing?" "audio-bands" "audio-bar-clock")
  :learn (:concept "Frame-locked beat detection for rhythm-synchronized gameplay and animation." :prerequisites ("audio-play" "audio-playing?") :progression "After mastering audio-beat?, combine it with audio-bpm and custom beat counting to build complex measure-aware logic.")
  :row-2-audit ((:problem "A player must spawn a particle every time the beat lands, not on every frame." :program "(on-frame\n  (lambda ()\n    (when (audio-beat?)\n      (world/spawn 'particle 100 100))))" :explanation "Each frame the predicate is checked; only when a beat is detected does the spawn fire. Frames between beats are silent." :meta "audio-bpm returns tempo but is a magnitude, not an event; on-tick fires every frame. audio-beat? is the correct choice when the operator wants a discrete rhythmic pulse.") (:eng "Operator log: 'beat fired at frame 240'. If no particles appear, the audit checks whether audio is playing." :math "Predicate over frame index; true at most once per beat." :cs "Frame-locked boolean; edge-triggered per beat."))
  :row-3-dimension ((:setup "edge-triggered-event" :rungs ((:domain "motoi rhythm" :code "(when (audio-beat?) 'kick)") (:domain "digital circuit" :code ";; rising-edge detector on a clock signal:\n;; if prev==0 and cur==1 then edge") (:domain "calculus (derivative sign)" :code ";; f'(t) > 0 at t = beat instant\n(define (edge-of f t dt) (> (/ (- (f t) (f (- t dt))) dt) 0))")) :explanation "Each rung fires ONCE at the transition, not throughout the on-state." :meta "Edge-triggering is the shape; the substrate can be beats, clocks, or continuous signals.") (:eng "Edge triggers avoid double-fires that plague level-triggered systems." :math "Discrete derivative sign at a boundary." :cs "Debounce-adjacent primitive; single-pulse per event."))
  :row-4-proof ((:claim "Between two consecutive beats, audio-beat? returns true on at most one frame." :program "(define count 0)\n(on-frame\n  (lambda ()\n    (when (audio-beat?) (set! count (+ count 1)))))\n;; After 8 beats of playback, count = 8, not 8*frames-per-beat.\n(display count)" :invariant "∀ beat-interval [b_k, b_{k+1}). |{frames f ∈ interval : audio-beat?(f)}| ≤ 1" :meta "At-most-once-per-beat guarantee. Falsified if the predicate is level-triggered rather than edge-triggered. See book-of-computing ch04 (edge detection) and book-of-sound ch05 (beat detection).") (:eng "One event per beat; downstream counters stay honest." :math "Cardinality bound on the true-set per interval." :cs "Edge-trigger contract; latch-and-clear semantics."))
  :row-5-emergence ((:base "audio-beat? fires once per detected beat." :composition "(define beats 0)\n(on-frame\n  (lambda ()\n    (when (audio-beat?)\n      (set! beats (+ beats 1))\n      (when (= (modulo beats 4) 0)\n        (world/spawn 'downbeat-flash 0 0)))))" :emergent "measure detector: counter + modulo 4 + beat trigger = downbeat classifier. Every fourth beat is a downbeat." :meta "Same family as measure detection in DAW pianoroll UIs. See book-of-composition ch11 (event counting) and book-of-sound ch06 (measures).") (:eng "Composable rhythm classifier from primitives." :math "Modular counting on beat index." :cs "Counter + predicate = classifier."))
)

(verb
  :name "audio-bpm"
  :library "core"
  :kind "rd"
  :signature "(audio-bpm) -> number | #f"
  :summary "Returns the detected beats-per-minute of the playing audio, or false if no valid tempo is detected."
  :explanation "Reads the audio engine's BPM estimator. If the engine has detected a stable tempo, returns a positive number (e.g., 120.0 for 120 BPM); if no tempo is available or BPM is not detected, returns false. This is useful for calculating beat durations, scheduling events at fractional-beat intervals, or synchronizing visual timing to the song. The BPM is updated continuously as audio plays."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((bpm (audio-bpm)))\n  (if bpm\n    (display (list \"BPM:\" bpm))\n    (display \"No tempo detected\")))" :note "Read BPM and print it if available, or a fallback message if not.")
    (:dialect "motoi" :tier "intermediate" :code "(define (beat-duration-ms)\n  (let ((bpm (audio-bpm)))\n    (if bpm\n      (/ 60000 bpm)\n      1000)))" :note "Calculate the duration of one beat in milliseconds; used for scheduling events at beat intervals.")
    (:dialect "motoi" :tier "expert" :code "(define (sync-to-tempo ctx)\n  (let ((bpm (audio-bpm)))\n    (if bpm\n      (let ((beat-ms (/ 60000 bpm))\n            (next-beat-time (+ (audio-time) beat-ms)))\n        (next 'waiting (ctx-set 'next-event next-beat-time ctx)))\n      (next 'no-audio ctx))))" :note "Schedule the next event to fire at the next beat boundary; uses BPM to compute the beat interval.")
    (:dialect "motoi" :tier "novice" :code "(let ((bpm (audio-bpm)))\n  (if bpm (display bpm) (display \"no tempo yet\")))" :note "Ask the engine for the song's tempo; it may not know yet.")
    (:dialect "motoi" :tier "intermediate" :code "(define (beat-length-ms)\n  (let ((bpm (audio-bpm)))\n    (if bpm (/ 60000 bpm) 500)))\n(display (beat-length-ms))" :note "Turn a tempo into the length of one beat in milliseconds. Fall back to 500 ms.")
  )
  :caveats ("Returns false, not 0, if no tempo is detected; always check with if or cond." "BPM may take several frames to stabilize when audio first starts; early reads may return false." "BPM is estimated from the audio; highly syncopated or polyrhythmic music may give inaccurate results." "If audio stops, BPM may remain cached from the last audio session until a new audio-play call.")
  :drawbacks ("Estimation-based; not a guaranteed ground truth, especially for complex or beat-less audio." "False return value requires conditional logic; cannot safely divide by BPM without checking." "Does not detect polyrhythms or time signature changes; assumes a single global tempo." "Cached per frame; BPM changes are not detected mid-frame.")
  :usecases ("Calculating beat/bar durations for event scheduling." "Adaptive game difficulty or pacing scaled to the song's tempo." "Synchronizing animation frame rates or particle emission rates to the music." "Building a tempo map for a rhythm game or conductor UI.")
  :related ("audio-beat?" "audio-time" "audio-bar-clock" "audio-tempo" "tick/phase")
  :learn (:concept "Reading detected audio tempo for rhythm-aware scheduling and adaptive timing." :prerequisites ("audio-play" "audio-beat?") :progression "After using audio-bpm, combine it with time/every-ms to schedule events at fractional-beat intervals, or use it to seed tick/phase for synchronized oscillation.")
  :row-2-audit ((:problem "A scheduler needs to know how many milliseconds are in one beat so it can queue events at fractional-beat offsets." :program "(define (beat-ms)\n  (let ((bpm (audio-bpm)))\n    (if bpm (/ 60000 bpm) 500)))" :explanation "audio-bpm returns detected tempo or #f. The wrapper falls back to 500ms if the detector has not locked yet." :meta "audio-tempo SETS tempo; audio-time returns raw seconds. audio-bpm is the correct choice when the operator wants the CURRENT detected tempo.") (:eng "Operator log: 'bpm=124'. If bpm returns #f, the audit checks whether the detector has enough audio to lock." :math "60000 / bpm = beat length in ms." :cs "Read from tempo estimator; may return #f."))
  :row-3-dimension ((:setup "detected-rate-with-fallback" :rungs ((:domain "motoi audio" :code "(audio-bpm)") (:domain "network throughput" :code ";; measured MB/s or #f if not enough data:\n;; iperf3 --interval 1") (:domain "frequency estimation" :code ";; f_est = 1 / avg-period-between-peaks\n(define (freq-est peaks) (/ 1 (avg (map -diff peaks))))")) :explanation "Each rung produces a live estimate of a rate; each may return 'unknown' until enough evidence accumulates." :meta "'Rate estimator with confidence' shows up in networking, audio, sensor fusion.") (:eng "Falsy return communicates 'not enough data yet.'" :math "Estimator with an admission threshold." :cs "Sum-type return: Number ∪ #f."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "When bpm returns a number, that number is strictly positive." :program "(let ((b (audio-bpm)))\n  (display (or (not b) (> b 0))))  ;; expect #t" :invariant "∀ call. audio-bpm() ∈ (0, ∞) ∨ audio-bpm() = #f" :meta "Positivity of the detected rate. Falsified by any zero or negative return. See book-of-math ch03 (positive reals) and book-of-sound ch05 (tempo detection).") (:eng "Zero-bpm returns would cause divide-by-zero in beat-ms; the type keeps that out." :math "Positive real or 'undefined'." :cs "Sum type: Positive ∪ NoValue."))
  :row-5-emergence ((:base "audio-bpm returns detected tempo." :composition "(define (schedule-fractional n)\n  (let ((bpm (audio-bpm)))\n    (when bpm\n      (after (/ 60 (* bpm n)) 'trigger))))" :emergent "tempo-scaled scheduler: divide beat by n and schedule at that sub-beat. Straight from tempo to timing." :meta "Same family as DAW clip-launch quantization. See book-of-composition ch09 (scheduling) and book-of-sound ch04 (subdivisions).") (:eng "Tempo change automatically retunes the schedule." :math "Beat subdivision: 60 / (bpm · n) seconds per sub-beat." :cs "Rate-parametrised scheduler."))
)

(verb
  :name "audio-halt"
  :library "core"
  :kind "mut"
  :signature "(audio-halt <handle>) -> AudioHandle"
  :summary "Stops audio playback on the given handle and returns a zero-duration handle."
  :explanation "Takes an audio handle (typically returned from audio-play) and halts playback immediately. Returns a zero-duration handle (a handle that represents no time, useful for chaining with other audio operations). This is the inverse of audio-play: use it to stop background music, pause sound effects, or clean up audio resources. The returned handle has duration 0, so it does not block subsequent operations."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((h (audio-play 'music)))\n  (audio-halt h))" :note "Play music, then immediately stop it (in the next frame or operation).")
    (:dialect "motoi" :tier "intermediate" :code "(define (toggle-music ctx)\n  (let ((is-playing (audio-playing?)))\n    (if is-playing\n      (do (audio-halt (ctx-get ctx 'music-handle))\n          (next 'music-off (ctx-set 'music-handle #f ctx)))\n      (let ((h (audio-play 'music)))\n        (next 'music-on (ctx-set 'music-handle h ctx))))))" :note "Toggle music on/off by storing the handle and halting it when needed.")
    (:dialect "motoi" :tier "expert" :code "(define (fade-and-halt ctx)\n  (let ((h (ctx-get ctx 'music-handle))\n        (fade-time 1000))\n    (when h\n      (do (audio-master-volume 0)  ;; instant mute for demo\n          (audio-halt h)\n          (next 'music-off\n            (ctx-set 'music-handle #f ctx))))))" :note "Halt music as part of a state transition; mute and stop the handle together.")
    (:dialect "motoi" :tier "novice" :code "(define h (audio-play 'chime))\n(audio-halt h)" :note "Play a chime, then cut it off. Handles are how you talk to sounds already playing.")
    (:dialect "motoi" :tier "intermediate" :code "(define bg (audio-play 'ambient))\n(on-key\n  (lambda (k)\n    (when (eq? k 'q)\n      (audio-halt bg))))" :note "Press Q to quiet the ambient loop. Useful when a boss battle starts.")
  )
  :caveats ("Takes an audio handle, not a string; you must call audio-play first to get a handle." "Halting does not remove the handle from memory; the caller is responsible for clearing it (e.g., ctx-set)." "Calling audio-halt on an already-halted handle is safe (idempotent)." "The returned zero-duration handle cannot be used to resume playback; use audio-play to restart.")
  :drawbacks ("Stops immediately with no fade-out; combine with audio-master-volume for a smooth stop." "Once halted, a handle cannot be resumed; you must call audio-play again." "No callback or event fired when halt completes; state changes are not automatic.")
  :usecases ("Stopping background music when the scene changes or the game pauses." "Cleaning up sound effects that are no longer needed." "Implementing a mute or sound-off button." "Halting all audio on exit or scene teardown.")
  :related ("audio-play" "audio-playing?" "audio-master-volume" "audio-tempo")
  :learn (:concept "Stopping audio playback via handle-based control." :prerequisites ("audio-play") :progression "After learning audio-halt, explore audio-master-volume for volume ramping, or time/until to schedule a delayed halt.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The player pauses the game; all audio must stop cleanly and the audio handle must reflect that." :program "(define h (audio-play 'bg))\n(define paused? (lambda () (audio-halt h)))\n(paused?)" :explanation "audio-halt takes the play handle and stops the sound. The zero-duration handle it returns lets downstream code treat the halt uniformly with a play." :meta "audio-master-volume=0 mutes but keeps CPU cost; stop halts the whole game loop. audio-halt is the correct choice for stopping ONE source.") (:eng "Operator log: 'halted handle bg'. If sound continues, the audit checks whether other play handles are live." :math "Handle life ends at halt-time." :cs "Explicit dispose; returns a canonical zero-handle."))
  :row-3-dimension ((:setup "explicit-resource-close" :rungs ((:domain "motoi audio" :code "(audio-halt h)") (:domain "filesystem" :code ";; close a file descriptor:\n;; close(fd)") (:domain "linear resources" :code ";; a linear resource must be used exactly once, then freed:\n(define (use-then-free r use free) (let ((v (use r))) (free r) v))")) :explanation "Each rung explicitly ends the life of a runtime resource. After close, the handle is no longer valid for its original purpose." :meta "Close/halt/free are the same closure boundary for a runtime resource.") (:eng "Explicit close is the honest audit boundary." :math "Linearity: a resource is closed exactly once." :cs "RAII / manual dispose pattern."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "After audio-halt, the halted handle produces no further audio." :program "(define h (audio-play 'bg))\n(audio-halt h)\n(display (audio-playing?))  ;; #f expected if no other sources" :invariant "∀ h. after audio-halt(h): produces-sound(h) = #f" :meta "Halt idempotence and terminality. Falsified by any post-halt sound from the same handle. See book-of-computing ch10 (resource lifetimes).") (:eng "Halted means halted; no ghost playback." :math "Absorbing state; halted is a sink." :cs "Idempotent dispose."))
  :row-5-emergence ((:base "audio-halt stops one source cleanly." :composition "(define h #f)\n(define (play-once! id)\n  (when h (audio-halt h))\n  (set! h (audio-play id)))" :emergent "single-voice policy: at most one background source is alive at a time. New play halts the old one." :meta "Same family as CSS keyframe animations that override in-progress ones, or setTimeout guards. See book-of-composition ch13 (single-slot patterns).") (:eng "Prevents audio layering bugs from repeated play calls." :math "Singleton invariant on the live handle set." :cs "Mutual exclusion via replace-and-close."))
)

(verb
  :name "audio-master-volume"
  :library "core"
  :kind "mut"
  :signature "(audio-master-volume <level>) -> AudioHandle"
  :summary "Sets the global audio volume level (0.0 to 1.0) and returns a zero-duration handle."
  :explanation "Controls the master volume fader of the entire audio system. Takes a level between 0.0 (silent) and 1.0 (full volume) and applies it to all playing audio. Returns a zero-duration handle to allow chaining. This is useful for mute buttons, volume preferences, fade-outs, or dynamic volume control. The change is applied immediately; for ramping over time, layer with a tick or animation curve."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(audio-master-volume 0.5)" :note "Set volume to 50%; all audio plays at half loudness.")
    (:dialect "motoi" :tier "intermediate" :code "(define (mute-toggle ctx)\n  (let ((is-muted (ctx-get ctx 'muted)))\n    (do (audio-master-volume (if is-muted 1.0 0.0))\n        (next 'running (ctx-set 'muted (not is-muted) ctx)))))" :note "Toggle mute by setting volume to 0 or 1; store the muted state in the context.")
    (:dialect "motoi" :tier "expert" :code "(define (fade-out ctx)\n  (let ((vol (ctx-get ctx 'volume)))\n    (let ((new-vol (max 0 (- vol 0.1))))\n      (do (audio-master-volume new-vol)\n          (if (> new-vol 0)\n            (next 'fading (ctx-set 'volume new-vol ctx))\n            (do (audio-halt (ctx-get ctx 'handle))\n                (next 'stopped ctx)))))))" :note "Gradually fade out volume over multiple frames, halting when it reaches 0.")
    (:dialect "motoi" :tier "intermediate" :code "(define (fade-out steps)\n  (let loop ((i steps))\n    (when (> i 0)\n      (audio-master-volume (/ i steps))\n      (wait 50)\n      (loop (- i 1)))))" :note "Step the master volume down to zero for a slow fade at the end of a scene.")
    (:dialect "motoi" :tier "novice" :code "(audio-master-volume 0.25)" :note "Cut the overall volume to a quarter. Ranges 0.0 (silent) to 1.0 (full).")
  )
  :caveats ("Takes a single numeric argument (0.0 to 1.0); values outside this range may be clamped or wrapped." "Change is immediate, not gradual; combine with frame loops or tick/osc for smooth ramping." "Affects all audio; there is no per-channel volume control from Scheme." "Does not mute individual handles; it is a global fader.")
  :drawbacks ("Immediate change can be jarring; needs animation code for smooth fade-in/-out." "No feedback on current volume; you must track it yourself if you need to display it." "Applies to all audio, so muting one effect also mutes the music.")
  :usecases ("Implementing a volume slider in the settings menu." "Fade-out on scene exit or pause." "Mute button (set to 0.0, unmute with 1.0 or a saved level)." "Dynamic volume reduction when a high-priority sound (dialog, alert) is playing.")
  :related ("audio-play" "audio-halt" "audio-playing?" "tick/sine" "time/until")
  :learn (:concept "Global volume control for the audio engine." :prerequisites ("audio-play") :progression "Combine audio-master-volume with tick/sine or a custom fade loop to create smooth volume transitions; then explore per-handle panning or frequency filters if needed.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A settings menu slider must set the global audio volume." :program "(define (set-volume! v)\n  (audio-master-volume (max 0 (min 1 v))))\n(set-volume! 0.6)" :explanation "The wrapper clamps input to [0,1] and forwards. Applying the update takes effect immediately for all playing sources." :meta "audio-halt stops a source; audio-tempo changes speed. audio-master-volume is the correct choice for a global gain change.") (:eng "Operator log: 'master vol=0.60'. If audio gets too loud, the audit is on this call site." :math "Volume is a scalar multiplier applied to the mixed output." :cs "Global-state write; propagates to all live sources."))
  :row-3-dimension ((:setup "global-scalar-mixer" :rungs ((:domain "motoi audio" :code "(audio-master-volume 0.5)") (:domain "brightness" :code ";; set display backlight to 50%:\n;; brightnessctl set 50%") (:domain "linear scaling" :code ";; multiply every element of a vector by a scalar\n(define (scale k v) (map (lambda (x) (* k x)) v))")) :explanation "Each rung applies a single scalar to a whole downstream stream." :meta "'Scalar multiply on a bulk stream' is the same shape whether it's audio, display, or vectors.") (:eng "One knob for global gain reduces mixing complexity." :math "Scalar multiplication on a signal." :cs "Broadcast operation."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Volume 0 mutes; volume 1 is the original level; the mapping is monotone in between." :program "(audio-master-volume 0)\n(display (audio-playing?))  ;; may still be true, but silent" :invariant "∀ v ∈ [0,1]. output-amplitude(v) = v · original-amplitude" :meta "Linear gain mapping. Falsified by non-monotone or clipped-nonzero-at-zero curves. See book-of-math ch03 (linearity) and book-of-sound ch08 (gain).") (:eng "Linear mapping is easier to reason about than dB curves in game code." :math "Homogeneous linear map: g(αx) = αg(x)." :cs "Global scalar; O(1) write."))
  :row-5-emergence ((:base "audio-master-volume sets global gain." :composition "(define (fade-out ms)\n  (let loop ((v 1))\n    (audio-master-volume v)\n    (when (> v 0)\n      (after (/ ms 100 1000) (loop (- v 0.01))))))" :emergent "fade-out sequencer: after + volume = a smooth taper, no mixer plugin required." :meta "Same family as CSS transitions on opacity, or DAW automation lanes. See book-of-composition ch14 (envelopes) and book-of-sound ch10 (fades).") (:eng "Composed fade avoids abrupt silence at scene end." :math "Linear taper over time." :cs "Time-parameterised gain automation."))
)

(verb
  :name "audio-peak"
  :library "core"
  :kind "rd"
  :signature "(audio-peak) -> number"
  :summary "Returns the peak (maximum) loudness of the current audio frame, normalized to 0.0–1.0."
  :explanation "Reads the audio engine's frame-locked snapshot of the peak magnitude (the loudest sample in the frame). Returns a number between 0.0 (silent) and 1.0 (maximum loud). This is useful for loudness-responsive effects: flashing lights, camera shake, or particle bursts on loud moments. The peak is recalculated every frame, so it is always fresh and reflects the current audio."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((peak (audio-peak)))\n  (display peak))" :note "Read the current peak loudness and print it (e.g., 0.75).")
    (:dialect "motoi" :tier "intermediate" :code "(define (flash-brightness)\n  (let ((peak (audio-peak)))\n    (* peak 255)))" :note "Map peak loudness to brightness (0–255); brighter on louder parts of the song.")
    (:dialect "motoi" :tier "expert" :code "(define (shake-on-peak ctx)\n  (let ((peak (audio-peak))\n        (threshold 0.7))\n    (if (> peak threshold)\n      (do (world/camera-shake! (world/camera) (- 1.0 threshold))\n          (next 'running ctx))\n      (next 'running ctx))))" :note "Trigger camera shake when the audio peak exceeds a threshold; intensity scales with loudness.")
    (:dialect "motoi" :tier "novice" :code "(display (audio-peak))" :note "One number that tells you how loud the loudest sample is this frame.")
    (:dialect "motoi" :tier "intermediate" :code "(on-frame\n  (lambda ()\n    (let ((p (audio-peak)))\n      (grid-cell-set! 0 0 (if (> p 0.9) 1 0)))))" :note "Light up a cell whenever the audio is near clipping.")
  )
  :caveats ("Normalized to 0.0–1.0; interpretation depends on the audio source and gain settings." "Peak is frame-locked; called multiple times in one frame returns the same value." "Includes all audio channels; there is no per-channel peak readout." "Peak is a snapshot; very fast transients shorter than the audio buffer may be missed.")
  :drawbacks ("Does not distinguish between music and sound effects; all audio contributes to the peak." "Peak can be noisy or jittery if the audio is quiet; consider a running average or hysteresis." "Does not distinguish between different frequency ranges (use audio-bands for that)." "Silent periods return exactly 0.0, which can cause flickering if used directly (e.g., for brightness).")
  :usecases ("Loudness-reactive lighting or visual effects (glow, bloom, flash)." "Camera shake or motion synchronized to audio intensity." "Particle emission rate or size scaled to the audio peak." "Difficulty ramping or gameplay intensity tied to the music's energy.")
  :related ("audio-rms" "audio-bands" "audio-beat?" "world/camera-shake!")
  :learn (:concept "Reading instantaneous peak loudness for reactive effects." :prerequisites ("audio-playing?") :progression "After using audio-peak, explore audio-rms for a smoother average, or audio-bands to react to specific frequency ranges.")
  :row-2-audit ((:problem "A clip indicator light must turn red whenever peak loudness exceeds 0.95." :program "(on-frame\n  (lambda ()\n    (grid-cell-set! 0 0 (if (> (audio-peak) 0.95) 1 0))))" :explanation "audio-peak returns the frame's max amplitude. The cell lights red on any near-clip frame." :meta "audio-rms is averaged and hides transients; audio-band picks one frequency. audio-peak is the correct choice for clip detection.") (:eng "Operator log: 'peak=0.98 -> CLIP'. If clipping is missed, the audit is on the buffer window, not this verb." :math "peak = max(|sample|) over the current frame." :cs "Scalar reduction; O(n) over frame samples internally."))
  :row-3-dimension ((:setup "max-reduction-over-a-window" :rungs ((:domain "motoi audio" :code "(audio-peak)") (:domain "latency monitor" :code ";; max p99 over last minute:\n;; max_over_time(latency[1m])") (:domain "ℓ∞ norm" :code ";; the infinity norm of a vector\n(define (linf v) (apply max (map abs v)))")) :explanation "Each rung reduces a window of values to its maximum." :meta "Max-reduction is the shape; the substrate is audio frames, metrics windows, or vectors.") (:eng "Max-reductions catch transient events that averages hide." :math "ℓ∞ norm; supremum reduction." :cs "Fold with max."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "audio-peak is bounded above by 1 for normalized audio." :program "(display (<= (audio-peak) 1.0))  ;; expect #t" :invariant "∀ frame. audio-peak() ∈ [0, 1]" :meta "Range guarantee. Falsified by any peak > 1 without an explicit unclamped mode. See book-of-math ch03 (bounded functions) and book-of-sound ch08 (normalization).") (:eng "Bounded output = safe to treat as a proportion." :math "Range [0, 1]." :cs "Post-normalization reduction."))
  :row-5-emergence ((:base "audio-peak returns max-amplitude of the frame." :composition "(define recent-peaks '())\n(on-frame\n  (lambda ()\n    (set! recent-peaks (cons (audio-peak) recent-peaks))\n    (when (> (length recent-peaks) 60)\n      (set! recent-peaks (take recent-peaks 60)))))" :emergent "peak-history buffer: bounded ring of peaks = a rolling loudness meter." :meta "Same family as loudness meters in broadcast (LUFS-M short-term). See book-of-composition ch08 (rolling metrics) and book-of-sound ch09 (loudness).") (:eng "Rolling window smooths perception without losing transients." :math "Sliding-window ℓ∞." :cs "Ring buffer with scalar element."))
)

(verb
  :name "audio-perceptual-bands"
  :library "core"
  :kind "rd"
  :signature "(audio-perceptual-bands) -> list"
  :summary "Returns a fresh list of audio spectrum bands adjusted for human hearing perception (Mel scale)."
  :explanation "Like audio-bands, but the frequency ranges are remapped to the Mel scale, which approximates how humans perceive pitch and loudness. Lower frequencies are more densely bucketed (since we hear pitch differences better in the bass), and higher frequencies are grouped more coarsely. This perceptual weighting makes the bands more useful for music visualizers and beat detection aligned with human perception. The list is a copy; mutations do not affect the engine."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((pbands (audio-perceptual-bands)))\n  (display (length pbands)))" :note "Read perceptual bands and check how many there are (typically fewer than raw frequency bins).")
    (:dialect "motoi" :tier "intermediate" :code "(define (bass-and-treble)\n  (let ((pbands (audio-perceptual-bands)))\n    (list (car pbands)                          ;; bass\n          (list-ref pbands (- (length pbands) 1))))) ;; treble" :note "Extract bass and treble energy from the perceptual bands; first band ≈ bass, last ≈ treble.")
    (:dialect "motoi" :tier "expert" :code "(define (equalizer-paint ctx)\n  (let ((pbands (audio-perceptual-bands)))\n    (for-each\n      (lambda (i)\n        (when (< i (canvas-cols))\n          (let ((mag (list-ref pbands i))\n                (height (max 1 (quotient (* mag (canvas-rows)) 1))))\n            (canvas-cell-set! i 0 (if (> mag 0.2) height 0)))))\n      (range 0 (length pbands)))))" :note "Paint a Mel-scale equalizer display; each column height reflects one perceptual frequency band.")
    (:dialect "motoi" :tier "novice" :code "(display (length (audio-perceptual-bands)))" :note "Perceptual bands weight the spectrum the way our ears actually hear it.")
    (:dialect "motoi" :tier "intermediate" :code "(define (bar-heights)\n  (map (lambda (b) (* 10 b)) (audio-perceptual-bands)))\n(display (bar-heights))" :note "Turn the perceptual spectrum into a list of bar heights for a fair-looking visualizer.")
  )
  :caveats ("Returns a copy; mutations do not affect the engine." "Bands are Mel-scale transformed, so they do not correspond to linear frequency ranges." "Snapshot is cached per frame; all calls within one frame return identical data." "Band count may differ from audio-bands (typically fewer buckets for perceptual bands)." "Before audio playback starts, returns an empty or zero-filled list.")
  :drawbacks ("Perceptual remapping means the bands do not align with raw FFT bins; frequency lookup is harder." "Fewer bands than raw spectrum (for performance); some frequency resolution is lost." "Frame-locked snapshot limits sub-frame granularity." "Copy cost on every call; cache the result if used multiple times per frame.")
  :usecases ("Music visualizers aligned with human hearing (more detail in bass, less in ultrasonic)." "Perceptually weighted beat detection (emphasizing bass and mid tones)." "Equalizer displays that match listener expectations (bass/mids/treble)." "Texture or color selection based on which perceptual band is most active.")
  :related ("audio-bands" "audio-peak" "audio-rms" "audio-beat?" "tick/phase")
  :learn (:concept "Perceptually weighted frequency bands for human-hearing-aligned audio analysis." :prerequisites ("audio-bands" "audio-playing?") :progression "Use perceptual-bands for end-user visualizers; use raw audio-bands if you need precise frequency matching or scientific analysis.")
  :row-2-audit ((:problem "A VJ tool wants bars whose heights match how humans HEAR loudness, not raw FFT magnitude." :program "(on-frame\n  (lambda ()\n    (let ((bands (audio-perceptual-bands)))\n      (for-each\n        (lambda (i)\n          (grid-cell-set! i 0 (list-ref bands i)))\n        (iota (length bands))))))" :explanation "Perceptual bands are re-binned toward Mel or Bark scale, so bass regions get wider spacing than raw FFT would." :meta "audio-bands gives even-spaced FFT bins; audio-band picks one. audio-perceptual-bands is the correct choice when the operator wants bars that MATCH HEARING.") (:eng "Operator log: 'perceptual bands length=24'. Human-scaled bars 'look right' where FFT bars feel bass-heavy." :math "Mel-scale re-binning; f_mel = 2595 · log10(1 + f/700)." :cs "Re-index of the FFT bin array to non-uniform buckets."))
  :row-3-dimension ((:setup "perceptual-remapping" :rungs ((:domain "motoi audio" :code "(audio-perceptual-bands)") (:domain "tone-mapped image" :code ";; HDR to LDR with a Reinhard tone-map:\n;; ldr = hdr / (1 + hdr)") (:domain "log-scale plot" :code ";; y = log10(x): compress dynamic range to match perception\n(define (log-scale x) (/ (log x) (log 10)))")) :explanation "Each rung remaps a signal so equal steps in output correspond to equal steps in perception, not equal steps in the raw substrate." :meta "Perceptual remapping is the shape; audio, HDR, and log-plot all share it.") (:eng "Human eye and ear are logarithmic; matching them removes UX friction." :math "Nonlinear invertible remap." :cs "Re-binning transform."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Perceptual bands preserve total energy (up to bin-width weighting): sum of perceptual bands ≈ sum of FFT bands." :program "(let ((p (apply + (audio-perceptual-bands)))\n      (f (apply + (audio-bands))))\n  (display (list 'perceptual p 'fft f)))" :invariant "∀ frame. Σ perceptual ≈ Σ fft (up to weighting)" :meta "Energy-preservation. Falsified by re-binning that drops or duplicates FFT energy. See book-of-math ch11 (integration invariance) and book-of-ml ch04 (Mel spectrogram).") (:eng "Energy preservation means visualizations feel honest." :math "Parseval-like conservation across re-binning." :cs "Weighted sum reduction across buckets."))
  :row-5-emergence ((:base "audio-perceptual-bands returns Mel-scaled magnitudes." :composition "(define log '())\n(on-frame\n  (lambda ()\n    (set! log (cons (audio-perceptual-bands) log))\n    (when (> (length log) 300) (set! log (take log 300)))))" :emergent "Mel-spectrogram history: 300 frames of perceptual bands = the input feature to most audio ML models." :meta "Same family as MFCC pipelines in speech ML. See book-of-composition ch08 (features over time) and book-of-ml ch05 (Mel features).") (:eng "Feature buffer ready for ML consumption." :math "Time-frequency matrix in perceptual coordinates." :cs "Bounded feature buffer; ML-ready shape."))
)

(verb
  :name "audio-play"
  :library "core"
  :kind "null"
  :signature "*[verify]*"
  :summary "Begin playing an audio source or sample."
  :explanation "Motoi's audio system is handle-based: `audio-play` starts a source and returns a handle you can later pass to `audio/halt` or query. The source itself is identified by name or ID (exact form depends on the audio engine's initialization). The verb is synchronous but the audio itself plays asynchronously in the background. Handles are opaque values; treat them as tokens for later control."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(audio-play \"ambient-loop\")" :note "Start playback of a named audio source; get back a handle.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((handle (audio-play \"drum-kit-sample\")))\n  (when (audio-playing?)\n    (audio/halt handle)))" :note "Conditionally stop playback by passing the handle to `audio/halt`.")
    (:dialect "motoi" :tier "expert" :code "(define (fade-out-loop source-name delay-ms)\n  (let ((h (audio-play source-name)))\n    (after delay-ms (lambda () (audio/halt h)))))\n(fade-out-loop \"background-ambience\" 2000)" :note "Closure over a handle; use `after` to schedule a deferred halt.")
    (:dialect "motoi" :tier "novice" :code "(audio-play 'ping)" :note "Start a sample. The engine returns a handle you can keep if you want to stop it later.")
    (:dialect "motoi" :tier "intermediate" :code "(define song (audio-play 'song))\n(on-key\n  (lambda (k)\n    (when (eq? k 'space)\n      (if (audio-playing?)\n          (audio-halt song)\n          (audio-play 'song)))))" :note "Space bar toggles the song. If it's playing, stop it; otherwise start it again.")
  )
  :caveats ("The handle is only valid for the current playback session; do not serialize or re-use across cart resets." "Multiple calls to `audio-play` with the same source spawn independent playback instances; they do not queue or replace." "Halting a handle that has already ended naturally is a no-op.")
  :drawbacks ("No built-in fade/crossfade; use `audio/master-volume` for global gain control instead." "Source names/IDs must match the audio engine's registry; typos fail silently." "No direct callback on playback end; poll `audio-playing?` or use `after` with a duration estimate.")
  :usecases ("Background music loops that need to be stoppable." "Sound effects triggered by user input or game events." "Choreographed audio sequences with `after` or `on-tick`.")
  :related ("audio/halt" "audio/master-volume" "audio-playing?" "audio-tempo" "audio-time" "after")
  :learn (:concept "Opaque handle-based control of asynchronous audio resources." :prerequisites ("Understanding that Motoi is reactive (effects happen asynchronously).") :progression "Learn `audio/halt` to stop sources; then `audio-tempo` to sync playback; then `audio/bar-clock` to drive visuals.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "On level start, a background loop must begin." :program "(define (start-level!)\n  (define h (audio-play 'bg-loop))\n  h)\n(start-level!)" :explanation "audio-play kicks off playback of the named source and returns a handle. The handle is what audio-halt or audio-bar-clock consumes downstream." :meta "tempo sets rate but does not START; note-strike sounds ONE pitch. audio-play is the correct choice to start a named sample or loop.") (:eng "Operator log: 'play bg-loop handle=42'. If audio never starts, the audit checks the sample registry." :math "Handle life begins at play-time." :cs "Resource acquisition; returns a handle token."))
  :row-3-dimension ((:setup "named-resource-open" :rungs ((:domain "motoi audio" :code "(audio-play 'bg-loop)") (:domain "filesystem" :code ";; open a file by path:\n;; fd = open('/tmp/log', 'r')") (:domain "process fork" :code ";; fork returns a pid to the parent:\n(define (fork proc) (list 'pid proc))")) :explanation "Each rung takes a NAME and returns a HANDLE for later reference and cleanup." :meta "'Name in, handle out' is the shape.") (:eng "Handle-oriented APIs support explicit lifetime management." :math "Injection from name-space to handle-space." :cs "Resource-acquisition-is-handle pattern."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Two calls to audio-play with the same name return distinct handles." :program "(define a (audio-play 'bg))\n(define b (audio-play 'bg))\n(display (not (eq? a b)))" :invariant "∀ name. handle(play(name)) fresh across calls" :meta "Handle uniqueness. Falsified by any handle re-use. See book-of-computing ch10 (resource identity).") (:eng "Distinct handles allow independent halt / volume adjust per instance." :math "Injective handle generator." :cs "Fresh identifier allocation."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "audio-play starts a source and returns a handle." :composition "(define h1 (audio-play 'pad))\n(define h2 (audio-play 'lead))\n(after 4 'fade)\n(define (fade ctx) (audio-halt h1) (audio-halt h2))" :emergent "paired-source lifecycle: two plays and one delayed halt = a timed audio layer." :meta "Same family as clip-launcher / DAW automation. See book-of-composition ch09 (timed lifecycles) and book-of-sound ch11 (layered playback).") (:eng "Explicit lifecycle avoids stuck loops at scene change." :math "Bounded life interval [t_play, t_halt]." :cs "Paired acquire / release with a scheduler."))
)

(verb
  :name "audio-playing?"
  :library "core"
  :kind "rd"
  :signature "(audio-playing?) → boolean"
  :summary "Check whether the audio system is currently processing a non-trivial signal."
  :explanation "Returns `#t` if the analyser is detecting meaningful audio energy (playback or input), `#f` otherwise. This is a snapshot read that reflects the state at the moment the frame ticks; it does not account for brief silence or pauses. Use it to conditionally branch on whether *something* is playing, without needing to track individual handles."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(if (audio-playing?)\n  (display \"audio is running\")\n  (display \"silence\"))" :note "Conditional branch on playback activity.")
    (:dialect "motoi" :tier "intermediate" :code "(define (pulse-on-audio)\n  (when (audio-playing?)\n    (card/audio-pulse (card-id-of (card-list)))))" :note "Only trigger a visual pulse when audio is actually playing.")
    (:dialect "motoi" :tier "expert" :code "(define (check-state ctx)\n  (if (audio-playing?)\n    (next 'active ctx)\n    (next 'dormant ctx)))\n(define (active ctx)\n  (card-set! (ctx-get ctx) 'glow 1.0)\n  (on-tick check-state))" :note "State machine that responds to audio activity changes each frame.")
    (:dialect "motoi" :tier "novice" :code "(if (audio-playing?)\n    (display \"sound on\")\n    (display \"silence\"))" :note "Ask the engine whether anything is actually making noise right now.")
    (:dialect "motoi" :tier "intermediate" :code "(on-frame\n  (lambda ()\n    (when (not (audio-playing?))\n      (audio-play 'restart-cue))))" :note "If the sound stops for any reason, kick it back on with a cue.")
  )
  :caveats ("`audio-playing?` reflects the analyser's energy snapshot, not individual handle state; you cannot query a specific source." "Very brief silences (< frame time) may still report `#t` if the tail of a sound is ringing." "The flag is snapshot-cached within a frame; multiple reads return the same value.")
  :drawbacks ("Does not distinguish between playback, input, or background noise; all are 'playing'." "No way to get precise energy levels; use `audio-rms` or `audio-peak` for that." "Does not tell you which handle(s) are active.")
  :usecases ("Conditionally enable visuals (glow, animation) only when music is present." "Guard expensive operations (like `conway-step`) to avoid wasted CPU during silence." "State machines that respond to audio presence/absence.")
  :related ("audio-rms" "audio-peak" "audio-bpm" "audio-beat?" "audio/play" "audio/halt")
  :learn (:concept "Snapshot-based reactive state: read the current frame's audio status to gate logic." :prerequisites ("Understanding that Motoi snapshots state once per frame.") :progression "Once comfortable, use `audio-rms` or `audio-peak` for fine-grained energy-responsive effects.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "Before scheduling a beat-locked animation, the operator must confirm audio is actually playing." :program "(when (audio-playing?)\n  (on-frame (lambda () (when (audio-beat?) (world/spawn 'flash 0 0)))))" :explanation "The when guard skips scheduling entirely if audio is silent, preventing wasted animation cost." :meta "audio-bpm returning a number is a stronger claim; audio-beat? is one-shot. audio-playing? is the correct choice for a general 'is anything sounding?' guard.") (:eng "Operator log: 'audio-playing? = #f -> skip animation'. Safe entry check." :math "Boolean predicate over engine state." :cs "Global state read; O(1)."))
  :row-3-dimension ((:setup "liveness-predicate" :rungs ((:domain "motoi audio" :code "(audio-playing?)") (:domain "service healthcheck" :code ";; is my downstream up?\n;; curl -sf http://svc/healthz") (:domain "observable state" :code ";; predicate on a state variable\n(define running? #t)\n(define (alive?) running?)")) :explanation "Each rung is a boolean read that answers 'is this thing currently active?'" :meta "Liveness checks are the same shape whether audio, services, or state machines.") (:eng "Cheap probes; safe to call every frame." :math "Boolean-valued function of runtime state." :cs "Idempotent read."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "audio-playing? is idempotent: two consecutive calls in the same frame return equal values." :program "(display (equal? (audio-playing?) (audio-playing?)))" :invariant "∀ frame f. audio-playing?(f, t1) = audio-playing?(f, t2) for t1,t2 ∈ f" :meta "Intra-frame determinism. Falsified by any state change during a frame. See book-of-computing ch07 (frame semantics).") (:eng "Idempotent probes let operators cache the answer freely." :math "Function is constant over a frame partition." :cs "Frame-locked read."))
  :row-5-emergence ((:base "audio-playing? guards on audio liveness." :composition "(define (with-audio thunk)\n  (if (audio-playing?) (thunk) (display 'silent-skip)))" :emergent "conditional pipeline stage: predicate + thunk = a gate that skips downstream work when the substrate is inactive." :meta "Same family as guard clauses in service meshes. See book-of-composition ch06 (gates).") (:eng "Cost-avoidance pattern for silent scenes." :math "Conditional identity: thunk applied only under the predicate." :cs "Guard pattern; short-circuit evaluation."))
)

(verb
  :name "audio-rms"
  :library "core"
  :kind "rd"
  :signature "(audio-rms) → number"
  :summary "Get the instantaneous RMS audio energy level (0.0 to ~1.0)."
  :explanation "RMS (root-mean-square) is a measure of perceived loudness; it averages the energy over a small window (typically one frame). Returns a number in [0, 1] roughly proportional to how 'loud' the audio is right now. Unlike `audio-peak` (which catches momentary spikes), RMS is smoother and more stable for driving continuous effects like glow or size modulation. Use it when you want audio-reactive visuals that feel natural and lag-free."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(set-dot-radius (* (audio-rms) 10))" :note "Scale dot size proportionally to current audio loudness.")
    (:dialect "motoi" :tier "intermediate" :code "(define (glow-with-audio card)\n  (let ((rms (audio-rms)))\n    (card-set! card 'glow (min 1.0 (* rms 2.0)))))\n(on-tick (lambda () (glow-with-audio (card-list))))" :note "Update a card's glow each frame, clamped to [0, 1].")
    (:dialect "motoi" :tier "expert" :code "(define (conway-speed-sync ctx)\n  (let* ((rms (audio-rms))\n         (speed (if (> rms 0.3) 2 1)))\n    (card-set! (ctx-get ctx) 'conway-ticks speed)\n    (on-tick conway-speed-sync)))\n(conway-speed-sync (ctx-set 'card (card-list) '()))" :note "Accelerate a simulation when music peaks; decouple from frame rate.")
    (:dialect "motoi" :tier "novice" :code "(display (audio-rms))" :note "RMS reads the average loudness — steadier than peak, better for slow visuals.")
    (:dialect "motoi" :tier "intermediate" :code "(on-frame\n  (lambda ()\n    (let ((energy (audio-rms)))\n      (camera-scale (+ 1.0 (* 0.2 energy))))))" :note "Breathe the camera in and out with the music's overall loudness.")
  )
  :caveats ("RMS is computed over a small time window (frame-duration); it lags behind instantaneous peak by ~10ms." "Very quiet audio may report near-zero; no automatic normalization (use a multiplier if needed)." "The return value is a floating-point number; comparisons should use `<` / `>`, not `eq?`.")
  :drawbacks ("Does not give frequency information; use `audio-band` or FFT-based tools for that." "Smoothing makes it less responsive to sudden attacks (transients); use `audio-peak` if you need those." "No history; you cannot retrieve the RMS from a past frame without polling.")
  :usecases ("Audio-reactive size/scale (sprites, cells, shapes grow and shrink with the beat)." "Glow or color intensity driven by loudness (pulse effects)." "Adaptive game speed: slow during quiet sections, accelerate during peaks." "Conditional logic: skip expensive operations when audio is below a threshold.")
  :related ("audio-peak" "audio-playing?" "audio-beat?" "audio-band" "set-dot-radius" "set-dot-color")
  :learn (:concept "Continuous audio-reactive parameter: use RMS for smooth, natural modulation." :prerequisites ("Familiarity with `audio-playing?` and frame-based snapshots.") :progression "Graduate to `audio-band` for frequency-specific control, or `audio-peak` for transient sensitivity.")
  :row-2-audit ((:problem "A camera shake effect should scale with perceived loudness, which is closer to RMS than peak." :program "(on-frame\n  (lambda ()\n    (camera-set! (* 5 (audio-rms)) 0 1)))" :explanation "Each frame the RMS energy is scaled by 5 and used as the camera x offset. Loud sections shake more than quiet ones, smoothly." :meta "audio-peak jumps on transients; audio-band is bucket-specific. audio-rms is the correct choice for a perceived-loudness scalar.") (:eng "Operator log: 'rms=0.35 -> shake=1.75px'. Smooth shake without transient jerkiness." :math "rms = sqrt(mean(x²)) over frame samples." :cs "Reduction: fold with squared-add then sqrt."))
  :row-3-dimension ((:setup "quadratic-mean-of-a-window" :rungs ((:domain "motoi audio" :code "(audio-rms)") (:domain "voltage meter" :code ";; true-RMS DMM: reads the equivalent DC voltage of an AC waveform:\n;; V_rms = sqrt(1/T · ∫ v(t)² dt)") (:domain "ℓ² norm" :code ";; the 2-norm of a vector\n(define (l2 v) (sqrt (apply + (map (lambda (x) (* x x)) v))))")) :explanation "Each rung reduces a window of values to their quadratic mean." :meta "'Quadratic mean' is the shape; audio, voltage, and vector norm all use it.") (:eng "RMS is the honest perceptual loudness proxy." :math "ℓ² norm normalised by count." :cs "Fold with squared accumulator."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "audio-rms is always at most audio-peak in the same frame." :program "(let ((r (audio-rms)) (p (audio-peak)))\n  (display (<= r p)))" :invariant "∀ frame. audio-rms(frame) ≤ audio-peak(frame)" :meta "Norm inequality ℓ² ≤ ℓ∞ (with equal normalisation). Falsified only by a bug in the reduction. See book-of-math ch09 (norm inequalities) and book-of-sound ch08 (loudness measures).") (:eng "A tripped RMS-above-peak alert is a bug indicator." :math "Standard norm inequality." :cs "Reduction-consistency check."))
  :row-5-emergence ((:base "audio-rms returns the frame's quadratic-mean energy." :composition "(define (auto-duck! speech-level)\n  (audio-master-volume (max 0 (- 1 (* 2 speech-level)))))\n(on-frame (lambda () (auto-duck! (audio-rms))))" :emergent "ducking mixer: RMS-driven volume automation. When a voice speaks, background ducks proportionally." :meta "Same family as broadcast auto-duckers and podcast sidechain compressors. See book-of-composition ch14 (envelopes) and book-of-sound ch08 (ducking).") (:eng "Perceptual duck feels smoother than peak-triggered." :math "Continuous negative-feedback on gain." :cs "Control loop with RMS as sensor and gain as actuator."))
)

(verb
  :name "audio-tempo"
  :library "core"
  :kind "null"
  :signature "(audio-tempo bpm [keyword-args...]) → zero-duration AudioHandle"
  :summary "Set the playback tempo in beats per minute."
  :explanation "Tempo (BPM) governs how fast the audio engine ticks the beat clock used by animations, visuals, and rhythm verbs. `audio-tempo` changes the master tempo and returns a handle (which you typically ignore). In v1, only the `bpm` argument is honored; optional `:ms` and `:curve` keywords are accepted but deferred (per the source comment on ramp behavior). Use this early in your cart's setup to synchronize all time-based effects to the music."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(audio-tempo 120)" :note "Set the master tempo to 120 BPM; all beat-driven effects now sync to 120.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((bpm (if (audio-bpm) (audio-bpm) 120)))\n  (audio-tempo (* bpm 1.5)))" :note "Detect the incoming audio's BPM and tempo-shift by 1.5x if available.")
    (:dialect "motoi" :tier "expert" :code "(define (adaptive-tempo ctx)\n  (let* ((rms (audio-rms))\n         (base-bpm 100)\n         (target-bpm (if (> rms 0.5) (* base-bpm 1.2) base-bpm)))\n    (audio-tempo target-bpm)\n    (on-tick adaptive-tempo)))\n(adaptive-tempo '())" :note "Tempo morphs based on audio loudness; creates a responsive 'groove'.")
    (:dialect "motoi" :tier "intermediate" :code "(define (double-time)\n  (audio-tempo (* 2 (or (audio-bpm) 120))))\n(on-key\n  (lambda (k)\n    (when (eq? k 'd) (double-time))))" :note "Press D to double whatever tempo the song is at right now.")
    (:dialect "motoi" :tier "novice" :code "(audio-tempo 90)" :note "Set playback tempo to 90 beats per minute — a walking pace.")
  )
  :caveats ("Setting a new tempo reschedules all frame-based animations; be careful in tight loops." "BPM must be a positive number; zero or negative values are unchecked (will fail at the engine)." "The optional `:ms` and `:curve` keywords are accepted but have no effect in v1 (ramp is deferred).")
  :drawbacks ("No way to query the *current* tempo (use `audio-bpm` for the detected audio BPM instead)." "Changing tempo mid-animation may cause visually jarring reschedules." "No built-in tempo ramping; you must manually interpolate if you want a smooth transition.")
  :usecases ("Syncing animations to music: set tempo once at startup, or detect it from `audio-bpm`." "Adaptive play: increase tempo when energy peaks, decrease during low-energy sections." "Tempo-locked effects: ensure beats, pulses, and choreography all tick at the same rate.")
  :related ("audio-bpm" "audio-beat?" "audio-time" "on-tick" "across-beats" "transport/tempo")
  :learn (:concept "Master time-base: one global tempo synchronizes all frame-driven and beat-driven effects." :prerequisites ("Understanding that Motoi has a per-frame clock and a beat clock." "Familiarity with `audio-bpm` (the detected music tempo).") :progression "Learn `across-beats` to schedule actions on beat boundaries; then `on-tick` for sub-beat precision.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A boss fight speeds up: the tempo must jump from 120 to 160 BPM." :program "(audio-tempo 160)" :explanation "One call sets the transport tempo; all beat-locked systems immediately re-time." :meta "audio-bpm READS tempo; audio-play starts audio. audio-tempo is the correct choice to SET the master rate.") (:eng "Operator log: 'tempo <- 160'. If beat scheduling desyncs, the audit is on which transport is subscribed." :math "Tempo is a positive real in BPM." :cs "Global state write; broadcast semantics."))
  :row-3-dimension ((:setup "global-rate-set" :rungs ((:domain "motoi transport" :code "(audio-tempo 160)") (:domain "motor controller" :code ";; set spindle RPM:\n;; spindle_set_rpm(160)") (:domain "parameter of a periodic system" :code ";; increase the angular frequency ω of an oscillator\n(define omega 160)")) :explanation "Each rung sets a single global rate that governs the timing of everything downstream." :meta "Rate-set is the shape; the substrate is beats, RPM, or omega.") (:eng "One knob for global tempo simplifies music transport." :math "Angular frequency setter." :cs "Global scalar; propagates to subscribers."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "audio-tempo is monotone in effect: setting higher BPM increases beat rate." :program "(audio-tempo 60)\n(define t1 (audio-time))\n(audio-tempo 120)\n(define t2 (audio-time))\n(display (list t1 t2))" :invariant "∀ b1 < b2. beats-per-second(tempo=b1) < beats-per-second(tempo=b2)" :meta "Monotone rate mapping. Falsified by any non-monotone tempo-to-rate curve. See book-of-math ch06 (monotone functions) and book-of-sound ch05 (tempo).") (:eng "Monotone tempo = predictable playback speed." :math "Order-preserving map from BPM to Hz." :cs "Linear rate parameter."))
  :row-5-emergence ((:base "audio-tempo sets global BPM." :composition "(define target 120)\n(on-frame\n  (lambda ()\n    (let* ((cur (or (audio-bpm) 120))\n           (next-tempo (+ cur (* 0.05 (- target cur)))))\n      (audio-tempo next-tempo))))" :emergent "tempo-easing loop: proportional controller drives tempo toward a target smoothly, no jarring jumps." :meta "Same family as PID rate controllers or DAW tempo ramps. See book-of-composition ch14 (control loops) and book-of-sound ch05 (tempo automation).") (:eng "Smooth tempo change avoids listener jarring." :math "First-order lag: dτ/dt = k(target - τ)." :cs "Proportional controller with tempo as actuator."))
)

(verb
  :name "audio-time"
  :library "core"
  :kind "rd"
  :signature "(audio-time) → number"
  :summary "Get the elapsed time in the audio playback clock (in seconds or milliseconds)."
  :explanation "Returns a number representing how much time has elapsed since the audio engine started (or since the last reset). This is a snapshot value, updated once per frame. Use it to schedule time-dependent actions, to measure elapsed time, or to synchronize visuals with a known offset in the music. Unlike `audio-bpm` (which is the tempo) or `audio-beat?` (which is a pulse flag), `audio-time` is a continuous clock position."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((t (audio-time)))\n  (display (list \"Elapsed: \" t \" seconds\")))" :note "Print the current playback time.")
    (:dialect "motoi" :tier "intermediate" :code "(define (cue-at-time target-sec action)\n  (on-tick (lambda ()\n    (when (>= (audio-time) target-sec)\n      (action)\n      (cancel-tick)))))\n(cue-at-time 2.5 (lambda () (card-emit (card-list) 'beat)))" :note "Fire an action when playback reaches a specific time.")
    (:dialect "motoi" :tier "expert" :code "(define (time-locked-animation card start-sec duration-sec)\n  (let ((t (audio-time)))\n    (if (and (>= t start-sec) (< t (+ start-sec duration-sec)))\n      (let ((phase (/ (- t start-sec) duration-sec)))\n        (card-set! card 'scale (+ 1.0 (* 0.5 (sin (* phase 2 3.14159))))))\n      (card-set! card 'scale 1.0))))\n(on-tick (lambda () (time-locked-animation (card-list) 5.0 3.0)))" :note "Animate a card between 5.0 and 8.0 seconds with a sine wave; idle outside that window.")
    (:dialect "motoi" :tier "novice" :code "(display (audio-time))" :note "How long has the audio been playing? A single number in seconds.")
    (:dialect "motoi" :tier "intermediate" :code "(on-frame\n  (lambda ()\n    (let ((t (audio-time)))\n      (when (> t 30)\n        (display \"30 seconds in\")))))" :note "Trigger a moment once the song has been rolling for half a minute.")
  )
  :caveats ("`audio-time` is a snapshot; it does not change between frames (it updates once per frame tick)." "The time value may jump if the playback clock is reset or seeked." "Very long playback sessions (> 1 hour) may see floating-point precision loss.")
  :drawbacks ("No direct API to *set* the playback position (seek); time is read-only." "The granularity is one frame; sub-frame timing is not available." "No history or lookback; you cannot query past time values.")
  :usecases ("Cueing synchronized events: show a modal or fire a particle effect at a specific song time." "Scripted animations: morph parameters over a known time window (e.g., a 4-bar countdown)." "Logging/debugging: record when significant events happen relative to the playback clock.")
  :related ("audio-bpm" "audio-beat?" "audio-playing?" "on-tick" "after" "across-beats")
  :learn (:concept "Continuous time-base for scheduling: synchronize discrete events to a known offset in the audio." :prerequisites ("Understanding of the audio playback clock and frame snapshots.") :progression "Use `audio-beat?` or `across-beats` for beat-aligned cues; use `audio-time` for arbitrary second-aligned cues.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A scheduler must fire an event exactly 3 seconds after a music cue." :program "(define cue-time (audio-time))\n(define (check ctx)\n  (if (> (- (audio-time) cue-time) 3)\n      (next 'fire ctx)\n      (next 'check ctx)))" :explanation "cue-time captures the current audio clock. On each pass through check, the delta is compared against 3 seconds." :meta "frame counts video frames; wall-clock drifts from audio. audio-time is the correct choice for audio-anchored timing.") (:eng "Operator log: 'audio-time=42.14s'. If cue drift appears, the audit is on the audio buffer, not this verb." :math "Audio clock: monotone real in seconds." :cs "Read from audio scheduler's clock."))
  :row-3-dimension ((:setup "monotone-clock" :rungs ((:domain "motoi audio" :code "(audio-time)") (:domain "unix" :code ";; monotonic clock, unaffected by wall-clock changes:\n;; clock_gettime(CLOCK_MONOTONIC, &ts)") (:domain "totally ordered real time" :code ";; monotone increasing t:\n(define (later? a b) (> b a))")) :explanation "Each rung provides a value that never decreases, giving downstream logic a total order to reason about." :meta "'Monotone clock' is the shape; the substrate is audio buffer, kernel counter, or model of time.") (:eng "Monotonic clocks are the SRE gold standard for timing." :math "Total order on ℝ." :cs "Never-decreasing counter."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "audio-time is monotone non-decreasing across two consecutive reads." :program "(define a (audio-time))\n(define b (audio-time))\n(display (>= b a))" :invariant "∀ read pair (a, b) with a preceding b. audio-time(b) ≥ audio-time(a)" :meta "Clock monotonicity. Falsified by any backward step. See book-of-computing ch08 (clocks) and book-of-math ch01 (order).") (:eng "No backward clock; safe for elapsed-time arithmetic." :math "Monotone non-decreasing function of call-order." :cs "Monotonic counter contract."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "audio-time exposes the audio clock." :composition "(define start (audio-time))\n(define (fade-alpha)\n  (max 0 (- 1 (/ (- (audio-time) start) 5))))\n(on-frame (lambda () (set-alpha (fade-alpha))))" :emergent "fade envelope: audio-time + start-time = a time-since-start signal, ready to drive a linear fade." :meta "Same family as GLSL uniform 'time' driving shaders. See book-of-composition ch14 (envelopes).") (:eng "Time-since-cue is a universal envelope primitive." :math "Affine map: alpha = 1 - (t - start)/duration." :cs "Elapsed-time derivation from a monotonic clock."))
)

(verb
  :name "begin-frame"
  :library "core"
  :kind "io"
  :signature "(begin-frame surface) → boolean"
  :summary "Start a render frame on a named surface (canvas, dot-matrix, etc.)."
  :explanation "Marks the beginning of a drawing pass on a surface, setting up the rendering context (clear buffers, set clipping region, etc.). You must call begin-frame before any paint operations; end-frame closes the pass and commits the buffer to display. Returns #t on success, #f if the surface does not exist or does not support framing."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin-frame 'canvas)\n(paint-cell 'canvas 10 20 'red 1)\n(end-frame 'canvas)" :note "Wrap a paint call in begin/end frame; essential for correct rendering.")
    (:dialect "motoi" :tier "intermediate" :code "(define (list-range . args)\n  (let ((lo (if (= (length args) 1) 0 (car args)))\n        (hi (if (= (length args) 1) (car args) (cadr args))))\n    (let loop ((i (- hi 1)) (acc (quote ())))\n      (if (< i lo) acc (loop (- i 1) (cons i acc))))))\n(define (draw-grid cols rows)\n  (begin-frame 'canvas)\n  (for-each (lambda (col)\n    (for-each (lambda (row)\n      (paint-cell 'canvas col row 'blue 0.5))\n      (list-range 0 rows)))\n    (list-range 0 cols))\n  (end-frame 'canvas))\n(draw-grid 20 15)" :note "Frame a nested loop of paint calls; batch all drawing in one frame.")
    (:dialect "motoi" :tier "expert" :code "(define (render-scene scene-data)\n  (cond ((begin-frame 'main-canvas)\n         (for-each (lambda (layer)\n           (let ((color (car layer))\n                 (cells (cdr layer)))\n             (for-each (lambda (cell)\n               (paint-cell 'main-canvas (car cell) (cadr cell) color 1))\n               cells)))\n           scene-data)\n         (end-frame 'main-canvas))\n        (else (escalate 'no-surface '()))))\n(render-scene '((red (0 0) (1 1)) (blue (2 2) (3 3))))" :note "Render layers of cells in one frame; escalate if the surface is unavailable.")
    (:dialect "motoi" :tier "novice" :code "(begin-frame 'main)" :note "Start drawing on the surface called 'main. Pair with end-frame to publish.")
    (:dialect "motoi" :tier "intermediate" :code "(begin-frame 'card-a)\n(grid-cell-set! 0 0 1)\n(end-frame 'card-a)" :note "Frame a small edit into card-a. Nothing shows on screen until end-frame.")
  )
  :caveats ("Returns #f silently if the surface does not exist; use card-visible? to check surface state first." "Must pair with end-frame; forgetting end-frame leaves the buffer uncommitted and may cause artifacts." "Only one frame can be active per surface at a time; nested begin-frame calls on the same surface are undefined." "Surface name is a symbol; passing a string or wrong type will fail silently.")
  :drawbacks ("No way to abort a frame after begin-frame; you must call end-frame to clean up." "Framing overhead per paint operation; do not call begin/end-frame for every pixel." "Frame rate is tied to the display refresh; blocking inside a frame will cause visible jank." "No query for current frame state; you cannot inspect the buffer mid-frame.")
  :usecases ("Batch a grid of cells into a single rendered frame (dot-matrix display)." "Draw animated backgrounds, tiles, or particle systems to a canvas." "Synchronize multi-layer rendering to the display refresh cycle.")
  :related ("end-frame" "paint-cell" "surface-paint-dots" "surface-paint-text" "canvas-pause" "canvas-resume")
  :learn (:concept "Frame delimiters for batching paint operations; teaches render-cycle discipline." :prerequisites ("paint-cell" "surface-curtain") :progression "Once framing works, layer multiple paint verbs and use canvas-rule to add cellular automata.")
  :row-2-audit ((:problem "Before painting a scene, the operator must mark the frame boundary so drawing commands land in a fresh buffer." :program "(begin-frame 'main)\n(grid-cell-set! 0 0 1)\n(grid-cell-set! 1 1 1)\n(end-frame 'main)" :explanation "begin-frame opens a drawing session on the named surface. All drawing calls between begin and end are batched into one frame." :meta "on-frame runs a callback per frame; after-frame defers to post-paint. begin-frame is the correct choice to OPEN a paint session.") (:eng "Operator log: 'begin-frame main'. If drawings leak between frames, the audit checks begin/end pairing." :math "Frame boundary marker." :cs "Transaction begin."))
  :row-3-dimension ((:setup "scoped-batch-begin" :rungs ((:domain "motoi framebuffer" :code "(begin-frame 'main)") (:domain "database" :code ";; open a transaction:\n;; BEGIN;") (:domain "scope open" :code ";; let opens a scope binding\n(define (with-scope thunk) (thunk))")) :explanation "Each rung opens a bounded region where operations accumulate before being committed together." :meta "'Begin a scope' is the shape.") (:eng "Transactional paint prevents partial-frame artifacts." :math "Boundary of a scope operator." :cs "Begin marker of a two-phase operation."))
  :row-4-proof ((:claim "Every begin-frame must be paired with an end-frame; between them, drawing commands accumulate." :program "(begin-frame 'test)\n(grid-cell-set! 5 5 1)\n(end-frame 'test)\n(display 'paired-correctly)" :invariant "∀ surface s. begin-frame(s) has exactly one matching end-frame(s) before another begin-frame(s)" :meta "Balanced-pair invariant. Falsified by unbalanced begin/end. See book-of-computing ch06 (transactions) and book-of-animation ch03 (frame lifecycle).") (:eng "Unbalanced pairs are an easy grep target during audit." :math "Balanced parenthesization." :cs "Bracketed transaction semantics."))
  :row-5-emergence ((:base "begin-frame opens a paint session." :composition "(define (with-frame surface thunk)\n  (begin-frame surface)\n  (thunk)\n  (end-frame surface))\n(with-frame 'main (lambda () (grid-cell-set! 0 0 1)))" :emergent "scoped-frame macro: begin + user-code + end = a bracket, safer than manual pairing." :meta "Same family as Python's with-block, try/finally, or SQL BEGIN/COMMIT wrapper. See book-of-composition ch05 (brackets).") (:eng "Bracket forms eliminate leaked begin/end bugs." :math "Scope-forming higher-order function." :cs "Resource-scoped combinator."))
)

(verb
  :name "big-bang"
  :library "core"
  :kind "mut"
  :signature "(big-bang [initial-state ...]) → game-id"
  :summary "Initialize and run a game or simulation world, returning a live game ID."
  :explanation "The canonical entry point for physics worlds and game loops. big-bang takes an initial state (often a world structure) and starts a loop that advances by one frame per game/step call. You control the loop lifetime via game/stop; query state with game/state, frame count with game/frame, and liveness with game/running?. This is the verb that enables all physics, collisions, and entity choreography."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define game-id (big-bang (list)))\n(display (game/state game-id))" :note "Start a world with empty state; fetch its state immediately.")
    (:dialect "motoi" :tier "intermediate" :code "(define (list-range . args)\n  (let ((lo (if (= (length args) 1) 0 (car args)))\n        (hi (if (= (length args) 1) (car args) (cadr args))))\n    (let loop ((i (- hi 1)) (acc (quote ())))\n      (if (< i lo) acc (loop (- i 1) (cons i acc))))))\n(define (run-game initial-entities)\n  (let ((gid (big-bang initial-entities)))\n    (for-each (lambda (_) (game/step gid))\n      (list-range 0 60))\n    (game/state gid)))\n(run-game '())" :note "Step a world 60 times (one second at 60fps); return final state.")
    (:dialect "motoi" :tier "expert" :code "(define (game-loop initial-world)\n  (let ((gid (big-bang initial-world)))\n    (define (tick-step)\n      (if (game/running? gid)\n        (begin (game/step gid)\n               (let ((state (game/state gid)))\n                 (card-emit 'frame-done (list 'frame (game/frame gid) 'entities state))\n                 (if (>= (game/frame gid) 3600)\n                   (game/stop gid)\n                   (register-tick 'game-loop-step (lambda () (tick-step))))))\n        (card-emit 'game-finished state)))\n    (tick-step)\n    gid))\n(game-loop '())" :note "Self-scheduling loop via register-tick; emit frame events; stop at a frame limit.")
  )
  :caveats ("big-bang starts the loop immediately; there is no deferred initialization." "Game state is mutable via game/step; any state you pass in is not copied." "Loop control is manual; you must call game/step yourself (or via a registered tick)." "Game IDs are stable for the lifetime of the process; they do not reset across multiple big-bang calls.")
  :drawbacks ("No automatic frame limiting or time-delta calculation; you must manage loop frequency." "Stepping a stopped game (game/running? returns #f) is a no-op; no error is raised." "Memory usage grows with frame count (if you store history); no automatic cleanup." "Multiple concurrent games can interfere if they share mutable state.")
  :usecases ("Run a physics simulation (world/spawn entities, world/step to evolve)." "Implement a turn-based game loop (one game/step per user action)." "Boot a live animation or choreography that responds to input or audio.")
  :related ("game/step" "game/stop" "game/state" "game/frame" "game/running?" "world/spawn" "world/step")
  :learn (:concept "Game loop initialization and lifecycle; teaches state threading and manual loop control." :prerequisites ("world/spawn" "world/step" "register-tick") :progression "After big-bang, use world/spawn to populate entities; use game/step to advance; use on-tick to hook input or animation logic.")
  :row-2-audit ((:problem "A minimal game must be launched with an initial state, tick handler, and renderer wired up." :program "(big-bang '(0 0)\n  (on-tick (lambda (s) (list (+ 1 (car s)) (cadr s))))\n  (to-draw (lambda (s) (grid-cell-set! (modulo (car s) 20) 0 1))))" :explanation "big-bang boots the world with initial state (0 0), a tick handler that increments x, and a draw routine that lights a scrolling cell." :meta "on-tick and to-draw ALONE don't run anything; they register handlers. big-bang is the correct choice to LAUNCH the loop.") (:eng "Operator log: 'big-bang started game-id=17'. If nothing renders, the audit is on the handler wiring." :math "State transition machine over frames." :cs "Event loop kickoff; installs handlers and returns game id."))
  :row-3-dimension ((:setup "event-loop-init" :rungs ((:domain "motoi world" :code "(big-bang '(0 0) ...)") (:domain "react app" :code ";; render the initial component tree:\n;; ReactDOM.createRoot(rootEl).render(<App />)") (:domain "fixed-point iteration" :code ";; kickoff of a stateful iteration:\n(define (iter s f) (iter (f s) f))")) :explanation "Each rung takes initial state plus transition rules and starts the recurrence." :meta "'Fire up the world' is the shape.") (:eng "Universal event-loop start point." :math "Seeded iterated map." :cs "Reactor-pattern boot."))
  :row-4-proof ((:claim "big-bang returns a game id that is unique among live games." :program "(define g1 (big-bang '(0 0)))\n(define g2 (big-bang '(0 0)))\n(display (not (eq? g1 g2)))" :invariant "∀ two live games g1, g2. id(g1) ≠ id(g2)" :meta "Handle uniqueness. Falsified by any collision. See book-of-computing ch10 (identifiers).") (:eng "Distinct ids allow multi-game concurrency." :math "Injective id generator." :cs "Fresh identifier allocation."))
  :row-5-emergence ((:base "big-bang launches the world loop." :composition "(define g (big-bang '(0 0)\n  (on-tick (lambda (s) (map + s '(1 0))))\n  (stop-when (lambda (s) (> (car s) 100)))\n  (to-draw (lambda (s) (grid-cell-set! (car s) 0 1)))))" :emergent "game with defined start, step, and end: a complete tick-render-terminate lifecycle." :meta "Same family as SDL game loops, htdp/universe. See book-of-composition ch16 (game loops).") (:eng "Explicit stop-when is honest lifecycle management." :math "Terminating iterated system." :cs "Structured event loop with termination."))
)

(verb
  :name "camera-bring-to-view"
  :library "core"
  :kind "mut"
  :signature "(camera-bring-to-view id [pad] [ms]) -> null"
  :summary "Smoothly pan and zoom the camera so a given entity id is centered and visible."
  :explanation "When you want the player to focus on a specific game object—a character, a landmark, an event—use this verb. It animates the camera view to bring the entity into frame, applying a padding margin (default 24 pixels) around it so the entity isn't crushed against screen edges. The animation duration defaults to 200 ms but is configurable. The camera reads the entity's current position and size, computes the required pan and zoom, and tweens to that state. Under the hood, it calls cameraBringToView with padding and duration; the tween runs on the RAF if the substrate is animate-enabled."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(camera-bring-to-view \"player\")" :note "Center the camera on entity \"player\" with 24px padding, 200ms ease-in-out")
    (:dialect "motoi" :tier "intermediate" :code "(card-do\n  (lambda (ctx)\n    (let ((target-id (ctx-get 'enemy-id ctx)))\n      (camera-bring-to-view target-id 40 300)\n      (next 'aim-sequence ctx))))" :note "In a card action, focus on an enemy (40px padding, 300ms) before starting combat sequence")
    (:dialect "motoi" :tier "expert" :code "(define (entity/id e) e)\n(define (pan-to-event event-kind)\n  (let ((entity (world/find (lambda (e) (equal? (entity/kind e) event-kind)))))\n    (if entity\n      (camera-bring-to-view (entity/id entity) 50 400)\n      (display \"no matching entity\"))))\n(pan-to-event 'treasure-chest)" :note "Search world for an entity by kind, then bring it into view with custom padding and duration")
    (:dialect "motoi" :tier "novice" :code "(define hero (entity/make 'player))\n(camera-bring-to-view hero)" :note "Move the camera so the hero is on screen with a bit of padding.")
    (:dialect "motoi" :tier "intermediate" :code "(define boss (entity/make 'boss))\n(camera-bring-to-view boss 40 600)" :note "Pan to the boss over 600 ms with 40 px of breathing room around them.")
  )
  :caveats ("The verb returns null; the actual camera movement is async. Subsequent code runs immediately, not after the tween completes" "If the entity id does not exist or has no position, the camera may tween to an undefined or zero location" "The camera will not pan if the substrate is paused (powerTier 'animate' gate); the dispatcher silently refuses the tween" "Padding is applied uniformly; for asymmetric framing (e.g., leading space for motion), use camera-center-on instead")
  :drawbacks ("Blocking on the camera move: if you need to wait for the tween to finish, you must use time/then or a tick listener, not synchronous wait" "Padding cannot be per-axis; it's a uniform margin on all sides" "No callback when the tween completes; monitor camera state separately if you need certainty of arrival")
  :usecases ("Focus on the player when they respawn" "Pan to an NPC when dialogue begins" "Zoom on a power-up or quest marker to direct player attention" "Transition between scenes by bringing the next zone into view")
  :related ("camera-center-on" "camera-fit-all" "camera-home" "camera-zoom-to" "camera-pan" "camera-tilt")
  :learn (:concept "Animated camera framing; entity-relative positioning; padding and margins in screen space" :prerequisites ("(core)/let" "world/find" "entity/id" "entity/pos") :progression "Learn camera-center-on for absolute coordinate framing; then camera-fit-all to frame all entities; then camera recording for GIF capture")
  :row-2-audit (
    :runs "spec-only"
   (:problem "An operator needs to smoothly pan the camera to bring an entity into view." :program "(camera-bring-to-view 0)" :explanation "The call invokes the camera state; the effect propagates to the render surface on the next frame boundary." :meta "Sibling camera verbs each do ONE thing; combining them is the operator's job. This verb is the correct choice for the specific concern named in its summary.") (:eng "Operator log: mutation captured; audit target is the camera-state buffer." :math "Affine transform applied to the viewport." :cs "Mutation of camera struct; effect visible next frame."))
  :row-3-dimension ((:setup "viewport-affine-adjustment" :rungs ((:domain "motoi camera" :code "(camera-bring-to-view)") (:domain "cinematography" :code ";; the equivalent camera move on a physical rig:\n;; dolly, pan, tilt, zoom") (:domain "affine group" :code ";; ℝ² -> ℝ² affine transform\n(define (affine mat v) (list 'apply mat v))")) :explanation "Each rung adjusts an affine viewing transform." :meta "The camera IS an affine transform on the viewport.") (:eng "Camera commands mirror physical rig vocabulary." :math "Affine group on ℝ²." :cs "Uniform affine matrix mutation."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "The camera state is a pure function of accumulated camera commands; identical command sequences produce identical states." :program "(camera-bring-to-view)\n(define s1 (camera-state))\n(camera-bring-to-view)\n;; state after two identical calls: deterministic wrt commands\n(display 'deterministic)" :invariant "∀ command-sequence σ. camera-state(σ) is a deterministic function of σ" :meta "Command-sequence determinism. Falsified by any hidden entropy. See book-of-math ch12 (transforms) and book-of-computing ch03 (determinism).") (:eng "Deterministic state = replayable camera moves." :math "Function of command-sequence." :cs "Deterministic state machine."))
  :row-5-emergence ((:base "camera-bring-to-view is one axis of camera control." :composition "(define (composite-move)\n  (camera-bring-to-view)\n  (camera-zoom-to 2 500))" :emergent "chained camera choreography: multiple camera calls in sequence build a compound cinematic move." :meta "Same family as Cinema 4D keyframe rigs or After Effects camera automation. See book-of-composition ch17 (choreography).") (:eng "Composable camera moves keep cinematic code readable." :math "Function composition of affine transforms." :cs "Sequential command chain."))
)

(verb
  :name "camera-center-on"
  :library "core"
  :kind "mut"
  :signature "(camera-center-on x y [scale] [ms]) -> null"
  :summary "Smoothly pan and zoom the camera to center on world coordinates (x, y) at a given scale."
  :explanation "The most direct way to move the camera: give it a world coordinate and optionally a zoom level, and it tweens there. Unlike camera-bring-to-view (which focuses on an entity), this centers on an absolute (x, y) point. If you omit scale, the camera keeps its current zoom; if you omit ms, it defaults to 250 ms. Internally, the verb computes the required camera transform—accounting for the grid origin and viewport size—and tweens the camera matrix. Useful for scripted sequences, waypoint cameras, and manual framing."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(camera-center-on 100 50)" :note "Pan to world point (100, 50), keeping current zoom; 250ms default")
    (:dialect "motoi" :tier "intermediate" :code "(camera-center-on 0 0 1.5 400)" :note "Pan to origin (0, 0) and zoom in to 1.5× scale over 400ms")
    (:dialect "motoi" :tier "expert" :code "(define (camera-path waypoints)\n  (for-each\n    (lambda (wp)\n      (let ((x (car wp)) (y (cadr wp)) (z (caddr wp)) (t (cadddr wp)))\n        (camera-center-on x y z t)))\n    waypoints))\n(camera-path '((0 0 1 500) (100 50 2 600) (200 0 1 500)))" :note "Script a cinematic camera pan through multiple waypoints with varying zoom and duration")
    (:dialect "motoi" :tier "novice" :code "(camera-center-on 100 200)" :note "Slide the camera so world point (100, 200) sits at the middle of the screen.")
    (:dialect "motoi" :tier "intermediate" :code "(camera-center-on 0 0 2 400)" :note "Center on the origin at 2x zoom, taking 400 ms to get there smoothly.")
  )
  :caveats ("All tweens are async; code after camera-center-on runs immediately, not after the pan completes" "If multiple camera commands are issued in quick succession, they queue or overwrite; only the last one executes" "Scale is multiplicative zoom, not absolute pixel-per-world-unit; small values (< 0.5) may make the world tiny" "Grid origin is read at call time; if origin changes during a tween, the camera may not end where expected")
  :drawbacks ("No way to await completion synchronously; requires time/then, on-frame, or a tick listener to sequence events" "Cannot specify easing function (always ease-in-out); for custom easing, use motion/* primitives" "Viewport size is read from window.innerWidth/Height; in test environments or headless rigs, these may be mocked")
  :usecases ("Implement a \"follow the breadcrumb\" tutorial by centering on hints one at a time" "Zoom and pan to a boss arena before a fight" "Create cinematic pans during story sequences" "Implement a minimap click-to-pan mechanic")
  :related ("camera-bring-to-view" "camera-fit-all" "camera-home" "camera-zoom-to" "camera-pan" "camera-tilt")
  :learn (:concept "Camera transforms in 2D: pan (translation), zoom (scale); viewport-to-world mapping; origin-aware coordinates" :prerequisites ("(core)/let") :progression "After centering, learn camera-pan and camera-tilt for relative nudges; then camera-record for GIF capture")
  :row-2-audit ((:problem "An operator needs to center the camera on a world position." :program "(camera-center-on 0)" :explanation "The call invokes the camera state; the effect propagates to the render surface on the next frame boundary." :meta "Sibling camera verbs each do ONE thing; combining them is the operator's job. This verb is the correct choice for the specific concern named in its summary.") (:eng "Operator log: mutation captured; audit target is the camera-state buffer." :math "Affine transform applied to the viewport." :cs "Mutation of camera struct; effect visible next frame."))
