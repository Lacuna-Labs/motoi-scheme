(verb
  :name "note-release"
  :library "core"
  :kind "null"
  :signature "*[verify]*"
  :summary "Cut a sustained note (legacy form of note/release)."
  :explanation "Legacy alias of note/release. Terminates a sustained note that is currently playing. The underlying implementation noteRelease is deterministic, permissioned for 'animate-level operations, and marked stateChanging. See note/release for full semantics and examples."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(note-release)" :note "Cut the current sustained note (legacy form).")
    (:dialect "motoi" :tier "intermediate" :code "(begin\n  (note 'C4 'half 0.8)\n  (note-release))" :note "Play a note and then release it early (legacy form).")
    (:dialect "motoi" :tier "expert" :code "(define (legato-phrase notes dur)\n  (for-each\n    (lambda (n)\n      (begin\n        (note n dur 0.8)\n        (note-release)))\n    notes))\n(legato-phrase '(C4 E4 G4) 'eighth)" :note "Demonstrate the legacy form in a phrase helper; in new code, prefer note/release.")
    (:dialect "motoi" :tier "novice" :code "(note-release 60)" :note "Let go of middle C. Notes hang until you release them.")
    (:dialect "motoi" :tier "intermediate" :code "(note-strike 60)\n(wait 500)\n(note-release 60)" :note "Hold C for half a second, then release. A simple sustained tone.")
  )
  :caveats ("This is a legacy alias; prefer note/release in new code." "Signature inference pending verification (marked *[verify]* in source)." "Behavior and constraints identical to note/release." "Calling note-release without an active sustained note may be a no-op or error; behavior depends on the runtime state.")
  :drawbacks ("Deprecated; use note/release instead for clarity and future compatibility.")
  :usecases ("Maintaining compatibility with older Motoi Scheme code." "Migrating legacy code to the modern note/* namespace (use note/release going forward).")
  :related ("note/release" "note" "note-strike" "note-place" "note/place-at")
  :learn (:concept "Legacy namespace convention; prefer modern note/* forms." :prerequisites ("note/release") :progression "Understand this for legacy code reading; migrate to note/release for new work.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "Operator needs to release a sustained note" :program "(note-release 60 4 100)" :explanation "The call operates on the currently-loaded note substrate. Pitch, duration, and velocity are the standard triple." :meta "Sibling note verbs each do ONE thing. This verb is the correct choice for the specific concern named in its summary.") (:eng "Operator log: note operation captured." :math "Discrete pitch (MIDI 0-127); duration in beats; velocity in [0,127]." :cs "Sample scheduler mutation."))
  :row-3-dimension ((:setup "pitch-and-duration" :rungs ((:domain "motoi notes" :code "(note-release 60 4 100)") (:domain "staff notation" :code ";; middle C, quarter note, mezzo-forte on a staff:\n;; note c4 q mf") (:domain "tuple of discrete parameters" :code ";; (pitch, duration, velocity) ∈ ℤ × ℝ⁺ × ℤ\n(define (note p d v) (list p d v))")) :explanation "Each rung is a tuple of discrete musical parameters interpreted by a downstream player." :meta "Musical-parameter tuple is the shape.") (:eng "Pitch/duration/velocity is the universal note contract." :math "Product of discrete and continuous domains." :cs "Struct of three fields."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "note-release with identical arguments produces identical audible effect (given identical instrument state)." :program "(note-release 60 4 100)\n(note-release 60 4 100)\n(display 'deterministic-audible-effect)" :invariant "∀ p d v. note-release(p, d, v) is deterministic in current instrument state" :meta "Same-input-same-effect. Falsified by any hidden entropy in note dispatch. See book-of-sound ch04 (note events) and book-of-computing ch03 (determinism).") (:eng "Deterministic notes = replayable songs." :math "Function of (pitch, duration, velocity, state)." :cs "Pure event emission."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "note-release produces a single note event." :composition "(for-each\n  (lambda (p) (note-release p 1 80))\n  '(60 62 64 65 67 69 71 72))" :emergent "scale player: for-each + note = a scale, arpeggio, or melody builder." :meta "Same family as MIDI sequences or tracker-style step programming. See book-of-composition ch13 (sequences) and book-of-sound ch03 (scales).") (:eng "Composable notes power melody generation." :math "Function applied over a pitch sequence." :cs "Iterated event emission."))
)

(verb
  :name "note-strike"
  :library "core"
  :kind "null"
  :signature "*[verify]*"
  :summary "Sound the pitch for the duration (legacy form of note/strike)."
  :explanation "Legacy alias of note/strike. Emits a note that both renders visually on the staff and produces audio for the specified duration. The underlying implementation noteStrike is deterministic and permissioned for 'animate-level operations. See note/strike for full semantics and examples."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(note-strike 'C4 'quarter)" :note "Sound C4 for a quarter note (legacy form).")
    (:dialect "motoi" :tier "intermediate" :code "(begin\n  (note-strike 'C4 'quarter)\n  (note-strike 'E4 'quarter)\n  (note-strike 'G4 'half))" :note "Emit a three-note melody with audio and staff display (legacy form).")
    (:dialect "motoi" :tier "expert" :code "(define (melody notes dur vel)\n  (for-each\n    (lambda (n) (note-strike n dur))\n    notes))\n(melody '(C4 E4 G4 B4) 'sixteenth)" :note "Helper to iterate over a list and strike each note; teaches composition with legacy form.")
    (:dialect "motoi" :tier "novice" :code "(note-strike 60)" :note "Play middle C. Strike starts a note; you'll want to release it later.")
    (:dialect "motoi" :tier "intermediate" :code "(on-key\n  (lambda (k)\n    (when (eq? k 'a)\n      (note-strike 60))))" :note "Play middle C every time you press A. A tiny keyboard.")
  )
  :caveats ("This is a legacy alias; prefer note/strike in new code." "Signature inference pending verification (marked *[verify]* in source)." "Behavior and constraints identical to note/strike." "Multiple rapid calls may overlap in the audio output; use timing or card choreography to space them.")
  :drawbacks ("Deprecated; use note/strike instead for clarity and future compatibility.")
  :usecases ("Maintaining compatibility with older Motoi Scheme code." "Migrating legacy code to the modern note/* namespace (use note/strike going forward).")
