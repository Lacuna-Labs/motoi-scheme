(verb
  :name "on-canvas-trace"
  :library "core"
  :kind "null"
  :signature "(on-canvas-trace handler) -> 'ok | ['error code details]"
  :summary "Register a callback that fires when the user traces on the canvas."
  :explanation "Registers a handler procedure to be invoked whenever the user draws a trace or stroke on the canvas surface. The handler is a closure that receives trace data (position, velocity, or other stroke metadata) and can inspect or react to it in real time. Returns 'ok on success, or an error tuple if handler is not a procedure. This is part of the paint event-handling system and complements on-key and on-frame for user input. The handler is stored in the _traceMod subsystem and remains registered until the program stops or a new handler is set."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(on-canvas-trace (lambda (trace-data) (display trace-data)))" :note "Registers a handler that prints each trace event to the console.")
    (:dialect "motoi" :tier "intermediate" :code "(define trace-points (list))\n(on-canvas-trace (lambda (trace-data)\n  (set! trace-points (cons (trace-data 'pos) trace-points))))\n(display trace-points)" :note "Collects all trace positions in a list as user draws; side-effect driven.")
    (:dialect "motoi" :tier "expert" :code "(define (gesture-recognizer initial-state)\n  (define state initial-state)\n  (on-canvas-trace (lambda (trace-data)\n    (let ((new-state (interpret-gesture state trace-data)))\n      (set! state new-state)\n      (if (complete? new-state) (emit 'gesture-complete new-state)))))\n  state)\n(gesture-recognizer 'waiting)" :note "Stateful gesture recognizer: accumulates trace events, interprets gestures, emits completion event.")
    (:dialect "motoi" :tier "novice" :code "(on-canvas-trace\n  (lambda (event)\n    (display event)))" :note "Listen for every trace event the canvas emits and print it.")
    (:dialect "motoi" :tier "intermediate" :code "(on-canvas-trace\n  (lambda (e)\n    (when (eq? (car e) 'draw)\n      (display \"a draw happened\"))))" :note "React only to draw events. Ignore everything else the canvas reports.")
  )
  :caveats ("handler must be a procedure; non-procedures are rejected with an error tuple." "Registering a new handler overwrites any previous handler; no chaining or multiple handlers." "trace-data structure (what fields are available) is undocumented; likely position, velocity, timestamp." "Handler is not invoked until the program's paint loop is running; may have no effect in headless tests." "Throwing inside the handler will bubble to the studio and stop the loop.")
  :drawbacks ("Single handler per program; cannot register multiple independent trace listeners." "No built-in debouncing or filtering; high-frequency trace events may overwhelm handler." "Trace data format is not documented; handler must be written defensively." "No way to unregister or disable handler without redefining it to a no-op.")
  :usecases ("Collecting user-drawn strokes for gesture recognition or handwriting." "Real-time drawing or painting applications." "Signature capture or authentication via pen gesture." "Educational apps: tracking and analyzing student handwriting or sketches.")
  :related ("on-frame" "on-key" "card-on-trace" "surface-paint-dots")
  :learn (:concept "Event handler registration; callback-driven UI interaction; stateful closure patterns." :prerequisites ("understanding of lambda and closures" "understanding of mutable state (set!)" "familiarity with on-frame and on-key") :progression "Learn to compose trace handlers with gesture logic; explore surface-paint-* for drawing output.")
  :row-2-audit ((:problem "A drawing app must respond when the user traces a stroke on the canvas." :program "(on-canvas-trace\n  (lambda (path)\n    (display (list 'traced path))))" :explanation "The lambda is invoked when a completed trace event fires, receiving the path data." :meta "on-key handles keyboard; on-frame is per-frame. on-canvas-trace is the correct choice for stroke events.") (:eng "Operator log: 'trace received points=42'." :math "Stroke as a list of (x, y) points." :cs "Event handler registration."))
  :row-3-dimension ((:setup "callback-on-user-gesture" :rungs ((:domain "motoi canvas" :code "(on-canvas-trace f)") (:domain "dom pointer events" :code ";; canvas.addEventListener('pointerup', f)") (:domain "event-driven programming" :code ";; subscribe(topic, handler)\n(define (sub topic h) (list 'subscribed topic h))")) :explanation "Each rung registers a callback for a user-driven event." :meta "'Subscribe to an event' is the shape.") (:eng "Event subscriptions are the backbone of interactive UIs." :math "Function assigned to an event stream." :cs "Subscribe pattern."))
  :row-4-proof ((:claim "on-canvas-trace registration is stable: multiple calls with the same function are idempotent." :program "(on-canvas-trace f)\n(on-canvas-trace f)\n(display 'stable-registration)" :invariant "∀ f. register(f) twice ≡ register(f) once" :meta "Idempotent registration. Falsified by duplicate dispatches. See book-of-composition ch06 (subscriptions).") (:eng "Idempotent register avoids double-fires." :math "Idempotent set-add." :cs "Subscriber deduplication."))
  :row-5-emergence ((:base "on-canvas-trace subscribes to stroke events." :composition "(define strokes '())\n(on-canvas-trace (lambda (p) (set! strokes (cons p strokes))))" :emergent "stroke history: subscription + accumulator = a drawing recorder." :meta "Same family as event-sourced UI state. See book-of-composition ch16 (event log).") (:eng "Event log makes undo/redo feasible." :math "Time-indexed sequence of strokes." :cs "Event-sourcing pattern."))
)

(verb
  :name "on-frame"
  :library "core"
  :kind "null"
  :signature "(on-frame fn) -> undefined"
  :summary "Register a procedure to be called once per animation frame."
  :explanation "Sets up a frame callback: a procedure fn with no arguments that fires once per render frame (typically 60 Hz). The callback is stored in the global game.onFrame field and invoked by the tickFrame routine before rendering. This is the primary hook for continuous game logic, state updates, and frame-driven animations. Returning from on-frame causes the frame counter to increment; throwing inside the callback bubbles to the studio as a user error. Fuel is reset before each call, allowing deterministic per-frame budgets."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(on-frame (lambda () (display (frame))))" :note "Prints the current frame number to the console every frame.")
    (:dialect "motoi" :tier "intermediate" :code "(define position 0)\n(on-frame (lambda ()\n  (if (key? 'ArrowRight) (set! position (+ position 2)))\n  (if (key? 'ArrowLeft) (set! position (- position 2)))))" :note "Simple continuous input handling: moves position left/right based on key state.")
    (:dialect "motoi" :tier "expert" :code "(define initial-state (lambda args (list \"initial-state\" args)))\n(define state (initial-state))\n(on-frame (lambda ()\n  (set! state (update state))\n  (render state)))" :note "Proper game loop: state is a top-level binding rebound via set!; update and render are decoupled. Decision-006 (immutable pair cells) rules out set-car! — use set! on a name.")
    (:dialect "motoi" :tier "novice" :code "(on-frame\n  (lambda ()\n    (display \"tick\")))" :note "Run this every animation frame. The screen refreshes about 60 times a second.")
    (:dialect "motoi" :tier "intermediate" :code "(define count 0)\n(on-frame\n  (lambda ()\n    (set! count (+ count 1))\n    (when (= (modulo count 60) 0)\n      (display \"one second\"))))" :note "Count frames and mark each second that passes.")
  )
  :caveats ("fn must be a procedure with zero arguments; passing a non-procedure or arity mismatch may cause runtime error." "The callback is invoked BEFORE rendering; changes to world state or canvas happen immediately." "Throwing inside the callback stops the loop and surfaces the error in the studio." "No return value is used; side-effects are the entire point." "Fuel budget is per-frame; complex logic may exhaust fuel and escalate.")
  :drawbacks ("Single callback; no chaining or multiple listeners (use higher-order functions to multiplex)." "Synchronous and blocking; no async/await or promises inside the callback." "Loop cannot be paused or stepped from within (use stop to halt)." "Frame rate is fixed by the studio (typically 60 Hz); no way to change per-frame cadence.")
  :usecases ("Main game loop: update physics, collision detection, and entity state." "Continuous animation: move sprites, cameras, or particles." "Input polling: read key state each frame and respond." "Debugging: log state or metrics every frame.")
  :related ("frame" "key?" "stop" "on-key" "on-canvas-trace")
  :learn (:concept "Frame callback and game loop structure; per-frame fuel budgeting; continuity of state." :prerequisites ("understanding of lambda and side-effects" "understanding of mutable state (set!)" "understanding of frame counters and timing") :progression "Learn to structure state updates inside on-frame; move to card-each or world/each for entity iteration.")
  :row-2-audit ((:problem "Each frame, the operator must repaint a bouncing ball's position." :program "(on-frame\n  (lambda () (display (frame))))" :explanation "The lambda fires once per frame from the driver's animation loop." :meta "on-tick is game-loop-specific; after-frame is a one-shot. on-frame is the correct choice for a persistent per-frame callback.") (:eng "Operator log: 'on-frame registered'." :math "Callback attached to frame index sequence." :cs "Handler registration."))
  :row-3-dimension ((:setup "periodic-callback" :rungs ((:domain "motoi runtime" :code "(on-frame f)") (:domain "unix" :code ";; run f every second:\n;; while true; do f; sleep 1; done") (:domain "iterated function" :code ";; f applied at each n\n(define (each-n f) (list 'each f))")) :explanation "Each rung schedules a function to run at every step of a periodic clock." :meta "'Every step' is the shape.") (:eng "Frame-based dispatch is universal in games." :math "Function applied at every integer index." :cs "Periodic callback."))
  :row-4-proof ((:claim "Callback registered via on-frame fires exactly once per frame." :program "(define count 0)\n(on-frame (lambda () (set! count (+ count 1))))\n;; after N frames, count = N" :invariant "∀ n frames. count = n after n frames pass" :meta "Once-per-frame guarantee. Falsified by any double-fire or skip. See book-of-computing ch07 (scheduling).") (:eng "Once-per-frame = predictable game logic." :math "Bijection to frame index." :cs "Exactly-once per period."))
  :row-5-emergence ((:base "on-frame runs a callback per frame." :composition "(define x 0)\n(on-frame\n  (lambda ()\n    (set! x (+ x 1))\n    (grid-cell-set! (modulo x 20) 0 1)))" :emergent "scrolling animation: state + on-frame + draw = classic tick-driven animation." :meta "Same family as requestAnimationFrame loops in browsers. See book-of-composition ch16 (animation loops) and book-of-animation ch03 (frame loops).") (:eng "Standard animation contract." :math "Discrete-time dynamical system." :cs "Tick-driven state machine."))
)

(verb
  :name "on-key"
  :library "core"
  :kind "pure"
  :signature "(on-key handler) → clause"
  :summary "Register a keyboard event handler in a game loop."
  :explanation "on-key wraps a handler function so that each keystroke feeds into the loop's state machine. The handler receives the current state and a key event, and returns a new state. This clause is pure (does not mutate the loop itself), but composes with big-bang and other clauses to build a complete game. Think of it as defining the rule: 'whenever a key is pressed, run this handler to decide the next state.'"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(big-bang 0\n  (on-tick (lambda (s) (+ s 1)))\n  (on-key (lambda (s k) (if (equal? k \"r\") 0 s))))" :note "Pressing 'r' resets the counter to 0; any other key leaves state unchanged.")
    (:dialect "motoi" :tier "intermediate" :code "(define (move-player state key)\n  (cond ((equal? key \"ArrowUp\") (+ state 1))\n        ((equal? key \"ArrowDown\") (- state 1))\n        (else state)))\n(big-bang 0\n  (to-draw (lambda (s) s))\n  (on-key move-player))" :note "Arrow keys increment/decrement state; composed with to-draw for rendering.")
    (:dialect "motoi" :tier "expert" :code "(define (handle-input state key)\n  (let ((action (cond ((equal? key \"w\") 'up)\n                      ((equal? key \"s\") 'down)\n                      (else 'none))))\n    (if (equal? action 'none) state\n      (let ((new-pos (+ (state 'pos)\n                       (if (equal? action 'up) 1 -1))))\n        (state 'set 'pos new-pos)))))\n(big-bang (list 'pos 0)\n  (on-tick (lambda (s) s))\n  (on-key handle-input)\n  (to-draw (lambda (s) (display s))))" :note "Handler inspects key, decides action, mutates structured state dict (using position 'pos key).")
    (:dialect "motoi" :tier "novice" :code "(on-key\n  (lambda (k)\n    (display k)))" :note "Print whichever key was pressed. Learn what your keyboard sends.")
    (:dialect "motoi" :tier "intermediate" :code "(on-key\n  (lambda (k)\n    (cond ((eq? k 'space) (display \"jump\"))\n          ((eq? k 'esc)   (display \"pause\")))))" :note "Space jumps, Escape pauses. A tiny game-input router.")
  )
  :caveats ("The handler runs *after* on-tick for the same frame (key events are queued per-frame)." "The handler must return a valid state; returning null or #f will halt the loop if stop-when sees it." "Multiple keys pressed in one frame are delivered in order; only the final state is retained.")
  :drawbacks ("on-key does not distinguish key-down from key-up; use check-with or a custom event listener if you need finer control." "High-frequency key events can saturate the state machine; consider debouncing for UI-heavy loops.")
  :usecases ("Player input in games (directional movement, jumps, ability triggers)." "Interactive simulations (pause/resume, parameter tweaks during play)." "REPL-like loops that read commands and update display.")
  :related ("on-tick" "to-draw" "stop-when" "big-bang" "check-with" "input/pressed?")
  :learn (:concept "Functional event handling: pure functions that consume events and produce new state." :prerequisites ("big-bang" "on-tick" "lambda") :progression "After mastering on-key, explore input/pressed? and input/buttons for more granular control, then input/may-i? for permission checks.")
  :row-2-audit ((:problem "When the player presses P, the game must pause." :program "(on-key\n  (lambda (state key)\n    (if (eq? key 'p) (stop) state)))" :explanation "on-key registers an edge-triggered handler; the function receives the current state and the pressed key symbol." :meta "key? is per-frame polling; on-frame is not key-specific. on-key is the correct choice for KEY-EDGE events.") (:eng "Operator log: 'on-key registered for P'." :math "Handler over (state, key) -> state." :cs "Edge-triggered event handler."))
  :row-3-dimension ((:setup "named-event-handler" :rungs ((:domain "motoi input" :code "(on-key f)") (:domain "terminal" :code ";; bind ctrl+c to signal:\n;; trap handler INT") (:domain "labeled callback" :code ";; subscribe(label, handler)\n(define (bind label h) (list 'bind label h))")) :explanation "Each rung binds a callback to an event label." :meta "'Bind handler to event' is the shape.") (:eng "Event bindings are the interactive UI standard." :math "Function on labeled event stream." :cs "Handler-registration pattern."))
  :row-4-proof ((:claim "on-key handler receives an edge event: called ONCE per keypress, not per held frame." :program "(define fires 0)\n(on-key (lambda (s k) (set! fires (+ fires 1)) s))\n;; after 3 discrete presses, fires = 3, regardless of hold length" :invariant "∀ keypress event. handler fires exactly once per event" :meta "Edge-triggered guarantee. Falsified by any per-frame level-triggering. See book-of-computing ch04 (edge triggers).") (:eng "Edge triggers avoid runaway repeats." :math "One event, one call." :cs "Debounce contract."))
  :row-5-emergence ((:base "on-key handles key events in a game loop." :composition "(define bindings '((p . pause) (q . quit) (r . reset)))\n(on-key\n  (lambda (s k) (assoc k bindings)))" :emergent "keybinding table: on-key + assoc lookup = a data-driven keymap." :meta "Same family as vim command tables or Emacs keymaps. See book-of-composition ch18 (keymaps).") (:eng "Data-driven maps scale to many keys." :math "Function via table lookup." :cs "Table-driven dispatch."))
)

(verb
  :name "on-tick"
  :library "core"
  :kind "pure"
  :signature "(on-tick handler) → clause"
  :summary "Register a per-frame state update function in a game loop."
  :explanation "on-tick defines the rule for advancing state each frame. The handler receives the current state and returns the next state. This is the heartbeat of a game loop: on-tick fires reliably at every frame boundary, making it ideal for animation, physics, AI, and any repeating logic. Like on-key, on-tick is pure; it returns a clause that big-bang composes into the loop's machinery."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(big-bang 0\n  (on-tick (lambda (s) (+ s 1)))\n  (to-draw (lambda (s) (display s))))" :note "Counter increments by 1 each frame and is printed.")
    (:dialect "motoi" :tier "intermediate" :code "(define (update-pos state)\n  (let ((x (state 'x))\n        (vx (state 'vx)))\n    (state 'set 'x (+ x vx))))\n(big-bang (list 'x 0 'vx 2)\n  (on-tick update-pos)\n  (to-draw (lambda (s) (display (s 'x)))))" :note "Position updates by velocity each frame; state is a dict-like structure.")
    (:dialect "motoi" :tier "expert" :code "(define (physics-step state)\n  (let* ((vel (state 'vel))\n         (grav -0.2)\n         (new-vel (+ vel grav))\n         (y (state 'y))\n         (new-y (+ y new-vel)))\n    (if (<= new-y 0)\n      (state 'set 'y 0 'vel 0 'falling? #f)\n      (state 'set 'y new-y 'vel new-vel 'falling? #t))))\n(big-bang (list 'y 100 'vel 0 'falling? #t)\n  (on-tick physics-step)\n  (stop-when (lambda (s) (not (s 'falling?)))))" :note "Simulated gravity with ground collision; loop stops when object settles.")
    (:dialect "motoi" :tier "novice" :code "(on-tick\n  (lambda ()\n    (display \"beat\")))" :note "Fire every audio beat. Different from on-frame, which fires every screen frame.")
    (:dialect "motoi" :tier "intermediate" :code "(define beats 0)\n(on-tick\n  (lambda ()\n    (set! beats (+ beats 1))\n    (when (= (modulo beats 8) 0)\n      (display \"measure\"))))" :note "Count beats and announce every 8-beat measure. Useful for phrase-aware music.")
  )
  :caveats ("on-tick is called *before* on-key in each frame; input handlers see the state from after the previous tick." "If on-tick returns null or #f, it is treated as an error; use stop-when to end the loop cleanly." "Heavy computation in on-tick can reduce frame rate; consider deferring work to background actors or spreading it across frames.")
  :drawbacks ("All state updates must happen synchronously within the handler; asynchronous side effects require a different abstraction (e.g., card/do)." "State is copied at each step, making large state objects slow; consider using closures to maintain hidden state if needed.")
  :usecases ("Simulations (physics, cellular automata, flocking)." "Animations (position tweening, fade effects)." "Game logic that runs every frame (AI decisions, collision checks, score updates)." "Timer-based mechanics (cooldowns, duration counters).")
  :related ("on-key" "to-draw" "stop-when" "big-bang" "check-with" "time/delta")
  :learn (:concept "The game loop's state machine: a pure function that advances state each frame." :prerequisites ("big-bang" "lambda" "let") :progression "After on-tick, explore to-draw for rendering, then stop-when for loop termination conditions, and check-with for invariant monitoring.")
  :row-2-audit ((:problem "Each game tick, the player state must advance by their velocity." :program "(on-tick\n  (lambda (s) (map + s '(1 0))))" :explanation "on-tick receives the state and returns the next state; the driver replaces it for the next tick." :meta "on-frame runs any code; to-draw is for rendering. on-tick is the correct choice for pure state transitions.") (:eng "Operator log: 'on-tick registered'." :math "State transition function s -> s'." :cs "Pure step in a game loop."))
  :row-3-dimension ((:setup "pure-state-step" :rungs ((:domain "motoi game loop" :code "(on-tick f)") (:domain "redux" :code ";; reducer function\n;; (state, action) => next-state") (:domain "transition function" :code ";; δ : S -> S\n(define (step s) s)")) :explanation "Each rung defines the successor state as a function of the previous." :meta "'Pure state step' is the shape.") (:eng "Pure state steps are testable in isolation." :math "Function δ : S -> S." :cs "Reducer pattern."))
  :row-4-proof ((:claim "on-tick handler is pure: same state in, same state out." :program "(on-tick (lambda (s) (list (+ 1 (car s)))))\n(display 'pure-step)" :invariant "∀ s. f(s) is deterministic" :meta "Pure-function contract. Falsified by any hidden entropy. See book-of-computing ch03 (pure functions).") (:eng "Pure ticks = deterministic replay." :math "Function S -> S." :cs "Pure reducer."))
  :row-5-emergence ((:base "on-tick advances state per tick." :composition "(big-bang '(0 0)\n  (on-tick (lambda (s) (map + s '(1 0))))\n  (stop-when (lambda (s) (> (car s) 100))))" :emergent "terminating game: state + tick + stop-when = a bounded simulation." :meta "Same family as htdp/universe world programs. See book-of-composition ch16 (game loops).") (:eng "Explicit termination = honest lifecycle." :math "Bounded iterated system." :cs "Simulation loop."))
)

(verb
  :name "pixels-tall"
  :library "core"
  :kind "null"
  :signature "pixels-tall -> number"
  :summary "Return the total height of the drawing surface in pixels."
  :explanation "Pixels-tall is a built-in constant equal to the number of rows on the dot-matrix surface multiplied by the sub-pixel scale factor (SUB). It allows you to query the vertical extent of the canvas without hardcoding values. This is essential for camera framing, viewport calculations, and responsive sprite positioning. The value is frozen before your program runs and cannot be redefined."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(display pixels-tall)" :note "Print the surface height to console; typical value is 360 or 720 depending on grid resolution")
    (:dialect "motoi" :tier "intermediate" :code "(define avatar 'avatar)\n(let ((half-height (/ pixels-tall 2))) (world/spawn avatar 100 half-height))" :note "Calculate the vertical center of the surface; spawn a sprite at that midpoint")
    (:dialect "motoi" :tier "expert" :code "(define ball 'ball)\n(let ((bounds (list 0 0 pixels-wide pixels-tall))) (camera-fit-all bounds) (map (lambda (x) (world/spawn ball x (- pixels-tall 50))) (list 100 200 300)))" :note "Use pixels-tall in a bounds list to fit camera; spawn multiple entities near the bottom of the canvas")
    (:dialect "motoi" :tier "novice" :code "(display (pixels-tall))" :note "How many pixels tall is the current surface?")
    (:dialect "motoi" :tier "intermediate" :code "(define middle (/ (pixels-tall) 2))\n(camera-center-on (/ (pixels-wide) 2) middle)" :note "Aim the camera at the exact middle of the screen without hardcoding a size.")
  )
  :caveats ("Pixels-tall is immutable; attempting to redefine it will raise an error (the binding is frozen)" "The value includes the sub-pixel scale factor; if you need the logical row count, divide by SUB" "The value is constant throughout the program; changing canvas resolution requires a restart")
  :drawbacks ("Cannot be customized or parameterized per-scene; all scenes share the same pixel dimensions" "No way to query the logical grid dimensions separately from the pixel count without knowing SUB" "Hard dependency on the global SUB constant (typically not exposed for modification)")
  :usecases ("Calculate the vertical center of the canvas for sprite spawning" "Determine safe boundary regions for camera panning and sprite culling" "Scale UI elements or text relative to the screen height" "Define collision zones or safe areas within the play space" "Responsive layout calculations that adapt to the canvas size")
  :related ("pixels-wide" "camera-frame" "card-screen-rect" "viewport")
  :learn (:concept "Canvas dimensions as queryable constants for responsive layout" :prerequisites ("basic sprite spawning" "understanding the dot-matrix surface model") :progression "Query pixels-tall and pixels-wide together to understand canvas bounds; then use camera-frame or card-screen-rect to position UI or cameras relative to those bounds")
  :row-2-audit ((:problem "Operator needs the surface height in pixels for layout math." :program "(display (pixels-tall))" :explanation "Returns the surface height in raw pixels, not cells." :meta "rows returns cells; grid-rows same but grid-scoped. pixels-tall is the correct choice for RAW PIXEL height.") (:eng "Operator log: 'pixels-tall=600'." :math "Height ∈ ℤ₊ in pixels." :cs "O(1) read."))
  :row-3-dimension ((:setup "raw-dimension-query" :rungs ((:domain "motoi surface" :code "(pixels-tall)") (:domain "display" :code ";; screen height in pixels:\n;; window.innerHeight") (:domain "cardinality" :code ";; |axis|\n(define (h m) (length m))")) :explanation "Each rung reports the extent of an axis in native units." :meta "'Raw dimension' is the shape.") (:eng "Raw pixels vs cells distinction is essential." :math "Element of ℕ." :cs "Nonnegative int query."))
  :row-4-proof ((:claim "pixels-tall is positive when surface is initialized." :program "(display (> (pixels-tall) 0))" :invariant "∀ init surface. pixels-tall ∈ ℤ₊" :meta "Positive dimension. Falsified only by uninitialized surface. See book-of-animation ch02 (dimensions).") (:eng "Positive height for safe division." :math "Element of ℤ₊." :cs "Nonneg int."))
  :row-5-emergence ((:base "pixels-tall returns surface height." :composition "(define (aspect) (/ (pixels-wide) (pixels-tall)))\n(display (aspect))" :emergent "aspect ratio: width / height = a scale-invariant layout metric." :meta "Same family as viewport-aspect calculations in responsive design. See book-of-composition ch07 (layout metrics).") (:eng "Aspect derived from primitives." :math "Ratio of dimensions." :cs "Compound derivation."))
)

(verb
  :name "pixels-wide"
  :library "core"
  :kind "null"
  :signature "pixels-wide -> number"
  :summary "Return the total width of the drawing surface in pixels."
  :explanation "Pixels-wide is a built-in constant equal to the number of columns on the dot-matrix surface multiplied by the sub-pixel scale factor (SUB). It complements pixels-tall to fully describe the canvas extent. Use it to calculate horizontal centering, boundary checks, and responsive sprite positioning. Like pixels-tall, the value is frozen at program startup and cannot be redefined."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(display pixels-wide)" :note "Print the surface width to console; typical value is 640 or 960 depending on grid resolution")
    (:dialect "motoi" :tier "intermediate" :code "(define avatar 'avatar)\n(let ((center-x (/ pixels-wide 2))) (world/spawn avatar center-x 200))" :note "Calculate the horizontal center of the canvas; spawn a sprite at that x-coordinate")
    (:dialect "motoi" :tier "expert" :code "(define cell 'cell)\n(let ((bounds (list 0 0 pixels-wide pixels-tall))) (define (spawn-row y count) (map (lambda (i) (world/spawn cell (* i (/ pixels-wide count)) y)) (list 0 1 2 3))) (spawn-row 100 4) (spawn-row 200 4))" :note "Use pixels-wide to divide canvas into equal columns; spawn a grid of entities evenly distributed horizontally")
    (:dialect "motoi" :tier "novice" :code "(display (pixels-wide))" :note "How many pixels wide is the current surface?")
    (:dialect "motoi" :tier "intermediate" :code "(define right-edge (- (pixels-wide) 20))\n(display right-edge)" :note "Compute a safe right-edge coordinate that stays 20 px away from the screen edge.")
  )
  :caveats ("Pixels-wide is immutable; redefining it will raise an error (binding is frozen)" "The value includes the sub-pixel scale factor; divide by SUB to get logical column count" "The value remains constant throughout the program; canvas resolution changes require a restart")
  :drawbacks ("Cannot be customized or adjusted per-scene; all scenes share the same pixel width" "No direct way to query logical column count without knowing the SUB constant (typically unexposed)" "Hard dependency on the global SUB scale; changes to grid resolution require program restart")
  :usecases ("Calculate the horizontal center of the canvas for centered sprite spawning" "Distribute sprites evenly across the width of the canvas" "Define safe play areas and boundary zones for camera or entity bounds" "Scale UI elements (text, buttons, panels) relative to screen width" "Implement responsive layouts that adapt to canvas dimensions")
  :related ("pixels-tall" "camera-frame" "card-screen-rect" "viewport-width")
  :learn (:concept "Canvas dimensions as immutable constants for layout and positioning" :prerequisites ("basic sprite spawning" "dot-matrix surface model") :progression "Query pixels-wide and pixels-tall together to understand canvas bounds; compose with division and multiplication to calculate responsive positions; use with camera-zoom-to or viewport for relative framing")
  :row-2-audit ((:problem "Operator needs the surface width in pixels for centering math." :program "(display (/ (pixels-wide) 2))" :explanation "Returns raw pixel width; divided by 2 for horizontal center." :meta "cols is cells; grid-cols is grid-scoped. pixels-wide is the correct choice for RAW PIXEL width.") (:eng "Operator log: 'pixels-wide=800'." :math "Width ∈ ℤ₊ in pixels." :cs "O(1) read."))
  :row-3-dimension ((:setup "raw-dimension-query" :rungs ((:domain "motoi surface" :code "(pixels-wide)") (:domain "display" :code ";; window.innerWidth") (:domain "cardinality" :code ";; |axis|\n(define (w m) (length (car m)))")) :explanation "Each rung reports width in native units." :meta "'Raw width' is the shape.") (:eng "Raw pixels for pixel-perfect layout." :math "Element of ℕ." :cs "O(1) read."))
  :row-4-proof ((:claim "pixels-wide is positive on init." :program "(display (> (pixels-wide) 0))" :invariant "∀ init surface. pixels-wide ∈ ℤ₊" :meta "Positive dimension. See book-of-animation ch02 (dimensions).") (:eng "Positive width for safe division." :math "Element of ℤ₊." :cs "Nonneg int."))
  :row-5-emergence ((:base "pixels-wide returns surface width." :composition "(define (center-x) (/ (pixels-wide) 2))" :emergent "center-x helper." :meta "Foundational primitive for centering-based layout. See book-of-composition ch07 (layout).") (:eng "Center primitives reduce hardcoded numbers." :math "Half of the width." :cs "Derived primitive."))
)

(verb
  :name "randint"
  :library "core"
  :kind "pure"
  :signature "(randint a b) -> integer"
  :summary "Return a uniformly random integer in the range [a, b), inclusive of a, exclusive of b."
  :explanation "Generates a pseudo-random integer between a (inclusive) and b (exclusive). The range is [a, b), so randint(0, 10) returns values from 0 to 9. The implementation scales a uniform random float to the interval, floors it, and adds the lower bound. This is the workhorse for discrete randomness in games and simulations."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(randint 1 7)" :note "Simulate a six-sided die roll (1–6).")
    (:dialect "motoi" :tier "intermediate" :code "(define (spawn-coins rows cols)\n  (map (lambda (r)\n    (map (lambda (c)\n      (if (> (randint 0 100) 70) 'coin 'empty))\n      (range 0 cols)))\n    (range 0 rows)))" :note "Populate a 2D grid with coins at ~30% density (each cell has a 30% chance).")
    (:dialect "motoi" :tier "expert" :code "(define (weighted-enemy-spawn wave)\n  (let ((base-count (+ 3 (quotient wave 2))))\n    (let ((variance (randint (- base-count) base-count)))\n      (max 1 (+ base-count variance)))))\n(weighted-enemy-spawn 5)" :note "Spawn enemies with a base count per wave plus a random variance, ensuring minimum of 1.")
  )
  :caveats ("Range is [a, b); do not confuse with inclusive ranges. randint(0, 10) never returns 10." "If a >= b, behavior is undefined; no guard is applied." "The random number generator is deterministic if seeded (with-seed); each call advances the state.")
  :drawbacks ("No Gaussian or weighted distribution; only uniform randomness." "Calling randint in a tight loop may repeat values short-term; use a larger range or seed for better distribution." "No way to exclude specific values (e.g., 'no 7 on this die') without post-processing.")
  :usecases ("Die rolls, coin flips, random selections in games." "Procedural level generation (enemy spawn counts, chest placement, etc.)." "Randomized animation or behavior intervals (wait 1–5 frames, move 2–8 pixels).")
  :related ("random-int" "random-range" "random-pick" "with-seed" "random")
  :learn (:concept "Bounded integer sampling from a continuous uniform random generator." :prerequisites ("random" "number?" "floor" "modulo") :progression "After randint, learn random-range for floating-point ranges, random-pick for sampling from lists, and with-seed to control reproducibility.")
  :row-2-audit ((:problem "Operator needs to get a uniform random integer in [a, b)" :program "(randint 0 100)" :explanation "The call draws a fresh pseudorandom sample from the current RNG." :meta "with-seed pins a seed; sibling verbs shape the sample differently. This verb is the correct choice for the specific distribution named in its summary.") (:eng "Operator log: 'random sample drawn'." :math "Sample from a uniform distribution." :cs "PRNG read."))
  :row-3-dimension ((:setup "pseudorandom-sample" :rungs ((:domain "motoi rng" :code "(randint 0 100)") (:domain "unix" :code ";; sample from /dev/urandom\n;; head -c 4 /dev/urandom") (:domain "probability" :code ";; X ~ Uniform[a, b]\n(define (uniform a b) (list 'sample-in a b))")) :explanation "Each rung produces a fresh sample from a distribution." :meta "'Random draw' is the shape.") (:eng "PRNG samples are the workhorse of procedural content." :math "Sample from a distribution." :cs "PRNG state advance."))
  :row-4-proof ((:claim "randint with fixed seed produces identical samples across runs." :program "(with-seed 42 (lambda () (define a (randint 0 100)) (define b (randint 0 100)) (list a b)))" :invariant "∀ seed s, index i. randint with seed s at index i is deterministic" :meta "Seed-determinism. Falsified by any hidden entropy source. See book-of-math ch07 (probability) and book-of-computing ch03 (determinism).") (:eng "Seeded RNG = reproducible test runs." :math "Deterministic pseudorandom sequence." :cs "PRNG state machine."))
  :row-5-emergence ((:base "randint draws a sample." :composition "(define samples (map (lambda (_) (randint 0 100)) (iota 10)))" :emergent "sample buffer: repeated calls = a bag of samples." :meta "Same family as Monte Carlo sampling. See book-of-composition ch11 (sampling) and book-of-math ch07 (Monte Carlo).") (:eng "Bulk sampling for procedural generation." :math "Empirical distribution." :cs "Iterated PRNG advances."))
)

(verb
  :name "random"
  :library "core"
  :kind "null"
  :signature "(random) -> number"
  :summary "Returns a uniformly distributed random float in the range [0, 1)."
  :explanation "Generates a single random decimal between 0 (inclusive) and 1 (exclusive). This is the foundation for all randomness in Motoi; use it to build scaled or picked selections. Returns a fresh value on each call."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define r (random))\n(display r)" :note "generates a single float like 0.427; call again to get a different value")
    (:dialect "motoi" :tier "intermediate" :code "(define coin-flip (< (random) 0.5))\n(if coin-flip 'heads 'tails)" :note "scales [0,1) into a boolean outcome by comparing against a threshold")
    (:dialect "motoi" :tier "expert" :code "(define (weighted-choice opts weights)\n  (let ((r (* (random) (apply + weights))))\n    (define (pick lst wts acc)\n      (if (null? lst) (car lst)\n          (if (<= r (+ acc (car wts))) (car lst)\n              (pick (cdr lst) (cdr wts) (+ acc (car wts))))))\n    (pick opts weights 0)))\n(weighted-choice '(a b c) '(0.5 0.3 0.2))" :note "accumulates weighted thresholds to implement categorical sampling")
  )
  :caveats ("Returns a fresh value each call; no seed control at this level (use with-seed if reproducibility is needed)." "Range is [0, 1); does not include 1 exactly." "Suitable for floating-point work; for integers, prefer random-int or randint.")
  :drawbacks ("Cannot be seeded directly; if you need determinism, wrap with-seed around the whole expression." "Not cryptographically secure; intended for games and simulations, not security-sensitive operations.")
  :usecases ("Seeding other random distributions (scale, threshold, pick)." "Weighted probability checks ('if (< (random) 0.3) …')." "Generating smooth noise or jitter in animations.")
  :related ("random-int" "random-range" "random-pick" "randint" "with-seed")
  :learn (:concept "uniform distribution as the atomic random source" :prerequisites () :progression "Move to random-int for integers, then random-pick for lists, then with-seed for reproducible sequences.")
  :row-2-audit ((:problem "Operator needs to get a uniform random float in [0, 1)" :program "(random)" :explanation "The call draws a fresh pseudorandom sample from the current RNG." :meta "with-seed pins a seed; sibling verbs shape the sample differently. This verb is the correct choice for the specific distribution named in its summary.") (:eng "Operator log: 'random sample drawn'." :math "Sample from a uniform distribution." :cs "PRNG read."))
  :row-3-dimension ((:setup "pseudorandom-sample" :rungs ((:domain "motoi rng" :code "(random)") (:domain "unix" :code ";; sample from /dev/urandom\n;; head -c 4 /dev/urandom") (:domain "probability" :code ";; X ~ Uniform[a, b]\n(define (uniform a b) (list 'sample-in a b))")) :explanation "Each rung produces a fresh sample from a distribution." :meta "'Random draw' is the shape.") (:eng "PRNG samples are the workhorse of procedural content." :math "Sample from a distribution." :cs "PRNG state advance."))
  :row-4-proof ((:claim "random with fixed seed produces identical samples across runs." :program "(with-seed 42 (lambda () (define a (random)) (define b (random)) (list a b)))" :invariant "∀ seed s, index i. random with seed s at index i is deterministic" :meta "Seed-determinism. Falsified by any hidden entropy source. See book-of-math ch07 (probability) and book-of-computing ch03 (determinism).") (:eng "Seeded RNG = reproducible test runs." :math "Deterministic pseudorandom sequence." :cs "PRNG state machine."))
  :row-5-emergence ((:base "random draws a sample." :composition "(define samples (map (lambda (_) (random)) (iota 10)))" :emergent "sample buffer: repeated calls = a bag of samples." :meta "Same family as Monte Carlo sampling. See book-of-composition ch11 (sampling) and book-of-math ch07 (Monte Carlo).") (:eng "Bulk sampling for procedural generation." :math "Empirical distribution." :cs "Iterated PRNG advances."))
)

(verb
  :name "random-int"
  :library "core"
  :kind "null"
  :signature "(random-int n) -> integer"
  :summary "Returns a uniformly distributed random integer in [0, n)."
  :explanation "Generates a single random whole number from 0 up to (but not including) n. Internally scales random and floors the result, ensuring n is treated as a positive integer. Safer than manual scaling because it guards against edge cases (n=0, n negative)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define die (random-int 6))\n(display (+ die 1))" :note "rolls 0–5, displayed as 1–6 by adding 1")
    (:dialect "motoi" :tier "intermediate" :code "(define (take xs n)\n  (let loop ((xs xs) (n n) (acc '()))\n    (if (or (zero? n) (null? xs))\n        (reverse acc)\n        (loop (cdr xs) (- n 1) (cons (car xs) acc)))))\n(define (drop xs n)\n  (let loop ((xs xs) (n n))\n    (if (or (zero? n) (null? xs)) xs (loop (cdr xs) (- n 1)))))\n(define (shuffle lst)\n  (if (null? lst) lst\n      (let* ((i (random-int (length lst)))\n             (x (list-ref lst i))\n             (rest (append (take lst i) (drop lst (+ i 1)))))\n        (cons x (shuffle rest)))))\n(shuffle '(a b c d))" :note "picks random indices to permute a list (naive but honest)")
    (:dialect "motoi" :tier "expert" :code "(define (spawn-enemies count max-hp)\n  (map (lambda (i)\n         (list 'id i\n               'hp (+ 1 (random-int max-hp))\n               'x (random-int 22)\n               'y (random-int 13)))\n       (range 0 count)))\n(spawn-enemies 5 10)" :note "generates entities with random HP and position, using random-int twice per entity")
    (:dialect "motoi" :tier "novice" :code "(display (random-int 6))" :note "A random whole number from 0 up to 5. Handy for dice.")
    (:dialect "motoi" :tier "intermediate" :code "(define (roll)\n  (+ 1 (random-int 6)))\n(display (roll))" :note "Wrap random-int in a helper to roll a proper 1-to-6 die.")
  )
  :caveats ("Returns [0, n), not [1, n]; add 1 if you need 1-indexed dice or rolls." "n is coerced to an integer via |0; floats are truncated, not rounded." "If n ≤ 0, result is always 0 (because max(1, n|0) forces at least 1)." "Slower than random for floating-point work; use random-range for continuous values.")
  :drawbacks ("Silent clamping of negative or zero n to 0 output; no error raised." "Not suitable for cryptography.")
  :usecases ("Dice rolls, card indices, grid coordinates." "Picking from a fixed finite set of outcomes." "Spawning entities at random positions within bounded dimensions.")
  :related ("random" "random-range" "random-pick" "randint" "with-seed")
  :learn (:concept "scaling and flooring uniform random to integer ranges" :prerequisites ("random") :progression "Use random-pick to select from lists by random-int index, or random-range for floating-point ranges.")
  :row-2-audit ((:problem "Operator needs to get a uniform random integer in [0, n)" :program "(random-int 10)" :explanation "The call draws a fresh pseudorandom sample from the current RNG." :meta "with-seed pins a seed; sibling verbs shape the sample differently. This verb is the correct choice for the specific distribution named in its summary.") (:eng "Operator log: 'random sample drawn'." :math "Sample from a uniform distribution." :cs "PRNG read."))
  :row-3-dimension ((:setup "pseudorandom-sample" :rungs ((:domain "motoi rng" :code "(random-int 10)") (:domain "unix" :code ";; sample from /dev/urandom\n;; head -c 4 /dev/urandom") (:domain "probability" :code ";; X ~ Uniform[a, b]\n(define (uniform a b) (list 'sample-in a b))")) :explanation "Each rung produces a fresh sample from a distribution." :meta "'Random draw' is the shape.") (:eng "PRNG samples are the workhorse of procedural content." :math "Sample from a distribution." :cs "PRNG state advance."))
  :row-4-proof ((:claim "random-int with fixed seed produces identical samples across runs." :program "(with-seed 42 (lambda () (define a (random-int 10)) (define b (random-int 10)) (list a b)))" :invariant "∀ seed s, index i. random-int with seed s at index i is deterministic" :meta "Seed-determinism. Falsified by any hidden entropy source. See book-of-math ch07 (probability) and book-of-computing ch03 (determinism).") (:eng "Seeded RNG = reproducible test runs." :math "Deterministic pseudorandom sequence." :cs "PRNG state machine."))
  :row-5-emergence ((:base "random-int draws a sample." :composition "(define samples (map (lambda (_) (random-int 10)) (iota 10)))" :emergent "sample buffer: repeated calls = a bag of samples." :meta "Same family as Monte Carlo sampling. See book-of-composition ch11 (sampling) and book-of-math ch07 (Monte Carlo).") (:eng "Bulk sampling for procedural generation." :math "Empirical distribution." :cs "Iterated PRNG advances."))
)

(verb
  :name "random-pick"
  :library "core"
  :kind "null"
  :signature "(random-pick lst) -> any | null"
  :summary "Returns a uniformly random element from a list, or null if the list is empty."
  :explanation "Picks one item from a non-empty list with equal probability. Returns null gracefully if the list is empty or falsy, avoiding crashes. Internally generates a random index within bounds and dereferences it."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define colors '(red green blue))\n(display (random-pick colors))" :note "outputs one color at random; each call may differ")
    (:dialect "motoi" :tier "intermediate" :code "(define (weighted-spawn sprite-pool)\n  (let ((chosen (random-pick sprite-pool)))\n    (if chosen\n        (list 'sprite chosen 'x (random-int 22) 'y (random-int 13))\n        '())))\n(weighted-spawn '(star coin enemy))" :note "safely picks a sprite type and pairs it with random position")
    (:dialect "motoi" :tier "expert" :code "(define my-state 'my-state)\n(define can-apply? (lambda args (list \"can-apply?\" args)))\n(define move-left (lambda args (list \"move-left\" args)))\n(define move-right (lambda args (list \"move-right\" args)))\n(define jump (lambda args (list \"jump\" args)))\n(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (sample-strategy strategies state)\n  (let loop ((remaining strategies))\n    (let ((pick (random-pick remaining)))\n      (if (and pick (can-apply? pick state))\n          (apply pick state)\n          (if (null? remaining) 'fallback\n              (loop (filter (lambda (s) (not (eq? s pick))) remaining)))))))\n(sample-strategy '(move-left move-right jump) my-state)" :note "repeatedly samples strategies until finding one applicable to the state")
    (:dialect "motoi" :tier "novice" :code "(display (random-pick '(red green blue)))" :note "Pick one item at random from a list. Each has equal weight.")
    (:dialect "motoi" :tier "intermediate" :code "(define hats '(top bowler fedora))\n(on-key\n  (lambda (k)\n    (when (eq? k 'h)\n      (display (random-pick hats)))))" :note "Press H to draw a hat at random from the wardrobe.")
  )
  :caveats ("Returns null for empty or falsy input, not an error; caller must handle null." "Equal probability only if the underlying random is uniform." "Does not remove the picked item; picking is non-destructive." "No built-in 'without replacement'; successive picks may repeat.")
  :drawbacks ("Each call is O(1) but generates a random number even if the list is empty." "Silent null-return on empty list may mask logic errors." "For weighted selection, use a manual threshold approach with random-range.")
  :usecases ("Choosing a random element from a set of options (colors, sounds, names)." "Sampling strategies or behaviors in game AI." "Safe list access with random fallback to null.")
  :related ("random" "random-int" "random-range" "randint")
  :learn (:concept "uniform random selection from a finite set" :prerequisites ("random" "random-int") :progression "Combine with filters or loops to implement weighted or conditional sampling.")
  :row-2-audit ((:problem "Operator needs to pick a uniformly random element from a list" :program "(random-pick '(a b c))" :explanation "The call draws a fresh pseudorandom sample from the current RNG." :meta "with-seed pins a seed; sibling verbs shape the sample differently. This verb is the correct choice for the specific distribution named in its summary.") (:eng "Operator log: 'random sample drawn'." :math "Sample from a uniform distribution." :cs "PRNG read."))
  :row-3-dimension ((:setup "pseudorandom-sample" :rungs ((:domain "motoi rng" :code "(random-pick '(a b c))") (:domain "unix" :code ";; sample from /dev/urandom\n;; head -c 4 /dev/urandom") (:domain "probability" :code ";; X ~ Uniform[a, b]\n(define (uniform a b) (list 'sample-in a b))")) :explanation "Each rung produces a fresh sample from a distribution." :meta "'Random draw' is the shape.") (:eng "PRNG samples are the workhorse of procedural content." :math "Sample from a distribution." :cs "PRNG state advance."))
  :row-4-proof ((:claim "random-pick with fixed seed produces identical samples across runs." :program "(with-seed 42 (lambda () (define a (random-pick '(a b c))) (define b (random-pick '(a b c))) (list a b)))" :invariant "∀ seed s, index i. random-pick with seed s at index i is deterministic" :meta "Seed-determinism. Falsified by any hidden entropy source. See book-of-math ch07 (probability) and book-of-computing ch03 (determinism).") (:eng "Seeded RNG = reproducible test runs." :math "Deterministic pseudorandom sequence." :cs "PRNG state machine."))
  :row-5-emergence ((:base "random-pick draws a sample." :composition "(define samples (map (lambda (_) (random-pick '(a b c))) (iota 10)))" :emergent "sample buffer: repeated calls = a bag of samples." :meta "Same family as Monte Carlo sampling. See book-of-composition ch11 (sampling) and book-of-math ch07 (Monte Carlo).") (:eng "Bulk sampling for procedural generation." :math "Empirical distribution." :cs "Iterated PRNG advances."))
)

(verb
  :name "random-range"
  :library "core"
  :kind "null"
  :signature "(random-range lo hi) -> number"
  :summary "Returns a uniformly distributed random float in the range [lo, hi)."
  :explanation "Scales random to a floating-point interval. Given two bounds, generates a decimal evenly distributed between lo (inclusive) and hi (exclusive). Useful for continuous parameters like velocity, delay, or position offset."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define velocity (random-range 1.5 3.0))\n(display velocity)" :note "generates a speed between 1.5 and 3.0; each call differs")
    (:dialect "motoi" :tier "intermediate" :code "(define (jitter val amount)\n  (+ val (random-range (- amount) amount)))\n(define smoothed-pos (jitter 10.0 0.5))" :note "adds ±0.5 noise to a position; useful for tremor or drift")
    (:dialect "motoi" :tier "expert" :code "(define (spawn-particle x y)\n  (list 'pos (list x y)\n        'vel (list (random-range -2.0 2.0) (random-range -3.0 1.0))\n        'life (random-range 0.5 2.0)\n        'color (random-pick '(white yellow orange))))\n(spawn-particle 100 50)" :note "generates a particle with randomized velocity and lifetime")
    (:dialect "motoi" :tier "novice" :code "(display (random-range 10 20))" :note "A random number between 10 and 20. Lets you set both edges.")
    (:dialect "motoi" :tier "intermediate" :code "(define (jitter x)\n  (+ x (random-range -3 3)))\n(display (jitter 100))" :note "Wiggle a value by a few units either way. Handy for hand-drawn-looking placement.")
  )
  :caveats ("Range is [lo, hi); hi is excluded." "Returns floating-point; use random-int for integers." "Behavior undefined if lo > hi (implementation does not clamp or swap)." "Assumes lo and hi are numbers; non-numbers coerce to NaN.")
  :drawbacks ("Floating-point arithmetic may produce values very close to hi but never equal." "No error on lo > hi; silently produces negative or zero-width ranges." "Slower than random for simple boolean checks; prefer < (random) p.")
  :usecases ("Particle velocities, timers, and continuous physics parameters." "Smooth noise or jitter applied to animations." "Spawn delays or duration variation.")
  :related ("random" "random-int" "random-pick")
  :learn (:concept "linear interpolation of uniform random to continuous ranges" :prerequisites ("random") :progression "Combine with map or for-each to fill collections with random continuous values.")
  :row-2-audit ((:problem "Operator needs to get a uniform random float in [lo, hi)" :program "(random-range 0 1)" :explanation "The call draws a fresh pseudorandom sample from the current RNG." :meta "with-seed pins a seed; sibling verbs shape the sample differently. This verb is the correct choice for the specific distribution named in its summary.") (:eng "Operator log: 'random sample drawn'." :math "Sample from a uniform distribution." :cs "PRNG read."))
  :row-3-dimension ((:setup "pseudorandom-sample" :rungs ((:domain "motoi rng" :code "(random-range 0 1)") (:domain "unix" :code ";; sample from /dev/urandom\n;; head -c 4 /dev/urandom") (:domain "probability" :code ";; X ~ Uniform[a, b]\n(define (uniform a b) (list 'sample-in a b))")) :explanation "Each rung produces a fresh sample from a distribution." :meta "'Random draw' is the shape.") (:eng "PRNG samples are the workhorse of procedural content." :math "Sample from a distribution." :cs "PRNG state advance."))
  :row-4-proof ((:claim "random-range with fixed seed produces identical samples across runs." :program "(with-seed 42 (lambda () (define a (random-range 0 1)) (define b (random-range 0 1)) (list a b)))" :invariant "∀ seed s, index i. random-range with seed s at index i is deterministic" :meta "Seed-determinism. Falsified by any hidden entropy source. See book-of-math ch07 (probability) and book-of-computing ch03 (determinism).") (:eng "Seeded RNG = reproducible test runs." :math "Deterministic pseudorandom sequence." :cs "PRNG state machine."))
  :row-5-emergence ((:base "random-range draws a sample." :composition "(define samples (map (lambda (_) (random-range 0 1)) (iota 10)))" :emergent "sample buffer: repeated calls = a bag of samples." :meta "Same family as Monte Carlo sampling. See book-of-composition ch11 (sampling) and book-of-math ch07 (Monte Carlo).") (:eng "Bulk sampling for procedural generation." :math "Empirical distribution." :cs "Iterated PRNG advances."))
)

(verb
  :name "rows"
  :library "core"
  :kind "rd"
  :signature "(rows) -> number"
  :summary "Return the number of rows (height) of the surface canvas in cells."
  :explanation "This verb returns the total row count of the dot-matrix surface — the vertical dimension of the playable area. It is a read-only constant for the lifetime of the program run. Analogous to canvas-rows but for the whole surface. Use rows together with cols to calculate canvas geometry, tile layouts, and bounding checks. The value is fixed at program start and does not change during execution."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(display (rows))" :note "Print the number of rows to the console.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((h (rows))\n      (w (cols)))\n  (define center-x (quotient w 2))\n  (define center-y (quotient h 2))\n  (list center-x center-y))" :note "Calculate the center of the canvas using rows and cols.")
    (:dialect "motoi" :tier "expert" :code "(define (fill-grid-pattern ctx)\n  (let ((h (rows))\n        (w (cols)))\n    (define (fill-row r)\n      (if (>= r h)\n        (next 'grid-complete ctx)\n        (begin\n          (define (fill-col c)\n            (if (< c w)\n              (begin\n                (canvas-cell-set! c r 1)\n                (fill-col (+ c 1)))))\n          (fill-col 0)\n          (fill-row (+ r 1)))))\n    (fill-row 0)))" :note "State function that iterates over all cells and fills the grid pattern using rows and cols as bounds.")
    (:dialect "motoi" :tier "intermediate" :code "(define (last-row) (- (rows) 1))\n(display (last-row))" :note "Compute the bottom row index. Now your code survives a resize.")
    (:dialect "motoi" :tier "novice" :code "(let ((h (rows))) (display h))" :note "Bind the row count to a name first, then print. Easier to reuse.")
  )
  :caveats ("rows returns a fixed number; calling it multiple times in the same program always returns the same value." "The value depends on the HelloSurface DOM element's current dimensions; headless or test environments may have different values." "rows is measured in cells, not pixels; multiply by the pixel scale (SUB) to get pixel height.")
  :drawbacks ("No way to change canvas dimensions at runtime; if you need a different size, you must restart the program." "On responsive displays, the number of rows may vary between runs; do not hardcode expected values in tests.")
  :usecases ("Tile-based game: use rows and cols to determine the map size and loop bounds." "Camera framing: clamp camera position to the canvas bounds using rows and cols." "Grid initialization: seed a cellular automaton or grid with a size derived from rows and cols." "Responsive layout: scale UI elements (cards, buttons) relative to the canvas size.")
  :related ("cols" "canvas-rows" "canvas-cols" "pixels-tall" "pixels-wide" "canvas-cell-set!" "grid-init")
  :learn (:concept "Reading the fixed canvas geometry (height in cells)." :prerequisites ("display" "let" "quotient") :progression "After learning rows and cols, use them to initialize grids (grid-init, canvas-cell-set!), clamp positions, and calculate layouts. Then explore camera bounds (camera-bounds!) and viewport operations.")
  :row-2-audit ((:problem "Operator needs the grid height in cells to loop over every row." :program "(let loop ((i 0)) (when (< i (rows)) (grid-cell-set! 0 i 1) (loop (+ i 1))))" :explanation "rows returns the row count. Loop paints the leftmost column." :meta "grid-rows is the grid-scoped duplicate; pixels-tall is in pixels. rows is the correct choice for cell-height.") (:eng "Operator log: 'rows=30'." :math "Positive integer." :cs "O(1) read."))
  :row-3-dimension ((:setup "cell-height-query" :rungs ((:domain "motoi grid" :code "(rows)") (:domain "spreadsheet" :code ";; row count in sheet") (:domain "cardinality" :code ";; |rows|\n(define (h m) (length m))")) :explanation "Each rung reports the number of rows in the 2D container." :meta "'Row count' is the shape.") (:eng "Row query for loop bounds." :math "Cardinality of the row axis." :cs "O(1) length."))
  :row-4-proof ((:claim "rows is positive when grid is init." :program "(display (> (rows) 0))" :invariant "∀ init grid. rows ∈ ℤ₊" :meta "See book-of-computing ch04 (dimensions).") (:eng "Positive rows for safe loops." :math "Element of ℤ₊." :cs "Nonneg int query."))
  :row-5-emergence ((:base "rows returns grid height." :composition "(let loop ((i 0)) (when (< i (rows)) (grid-cell-set! 0 i 1) (loop (+ i 1))))" :emergent "column painter." :meta "Same family as parametric loops. See book-of-composition ch04 (loops).") (:eng "Grid-agnostic column paint." :math "Iterate over [0, rows)." :cs "Data-dependent loop bound."))
)

(verb
  :name "sprite"
  :library "core"
  :kind "pure"
  :signature "(sprite name [form ...]) -> sprite-object | error"
  :summary "Construct or retrieve a sprite by name and apply optional transformations (turn, size, tint, etc.)."
  :explanation "Selects a named sprite from the built-in sprite library and optionally applies one or more transformation forms (e.g., (turn 90), (size 2)). The sprite name is case-insensitive. If the sprite name is unknown, returns an error tuple ['error', 'unknown-sprite', {...}]. Multiple forms are applied in order. The result is a sprite object that can be rendered, painted, or passed to entities and world verbs."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sprite 'rose)" :note "Fetch the 'rose' sprite in its default state; returns a sprite object.")
    (:dialect "motoi" :tier "intermediate" :code "(define turn (lambda args (list \"turn\" args)))\n(define size (lambda args (list \"size\" args)))\n(sprite 'blossom (turn 90) (size 2))" :note "Fetch 'blossom', rotate it 90 degrees, and double its size. Multiple forms are applied in sequence.")
    (:dialect "motoi" :tier "expert" :code "(define (flower-row count spacing)\n  (map (lambda (i)\n         (let ((rotation (* i (/ 360 count))))\n           (sprite 'rose (turn rotation))))\n       (range count)))\n(flower-row 6 45)" :note "Generate a circle of 6 rose sprites, each rotated by 60 degrees.")
  )
  :caveats ("Sprite name must exist in the built-in library; unknown names return an error tuple, not an exception." "Forms are applied in the order given; order may matter for some transformations (e.g., turn then size vs. size then turn)." "Case is normalized to lowercase; 'Rose', 'ROSE', and 'rose' all refer to the same sprite." "Return value is a sprite object, not a string or number; do not use in arithmetic or string operations.")
  :drawbacks ("No custom or user-defined sprites; only built-in library sprites are available." "Transformations are baked into the sprite object at construction time; dynamic re-transformation requires constructing a new sprite." "Error handling requires pattern matching on the return tuple; no exception is raised.")
  :usecases ("Render a sprite to the canvas or world." "Create a list of variations (rotations, scales) of a sprite for animation or composition." "Fetch a sprite for use as an entity's visual representation.")
  :related ("sprite/landmarks" "sprite/address" "sprite/rasterize" "entity/sprite!" "world/render" "paint-coin" "paint-cell")
  :learn (:concept "Asset lookup and transformation; error handling for missing resources." :prerequisites ("(core)/let" "(core)/map" "(core)/if") :progression "Next: sprite/landmarks to learn sprite metrics; sprite/rasterize to render a sprite as text or pixels.")
  :row-2-audit ((:problem "Operator needs to display a named sprite rotated 45° and tinted red." :program "(sprite 'hero '(turn 45) '(tint red))" :explanation "sprite constructs or fetches the named sprite and applies transformations." :meta "sprites (plural) attaches to a card; grid-cell-set! draws a cell. sprite is the correct choice for a NAMED sprite handle.") (:eng "Operator log: 'sprite hero turn=45 tint=red'." :math "Transformations composed." :cs "Constructor with transform list."))
  :row-3-dimension ((:setup "transformable-named-resource" :rungs ((:domain "motoi sprite" :code "(sprite 'hero '(turn 45))") (:domain "css" :code ";; transform: rotate(45deg) tint(red)") (:domain "affine transform composition" :code ";; apply matrices in sequence\n(define (compose a b) (list a b))")) :explanation "Each rung takes a resource and stacks transformations." :meta "'Transformable named resource' is the shape.") (:eng "Named + transformed is a UI staple." :math "Group action on resources." :cs "Composable transform list."))
  :row-4-proof ((:claim "Same name and same transform list returns equivalent sprite." :program "(define a (sprite 'x))\n(define b (sprite 'x))\n(display 'stable-lookup)" :invariant "∀ name transforms. sprite(name, T) is a deterministic function" :meta "Referential transparency. Falsified only by env-dependence. See book-of-composition ch12 (transforms).") (:eng "Deterministic sprite lookup = stable UI." :math "Function of (name, T)." :cs "Pure constructor."))
  :row-5-emergence ((:base "sprite gets a transformed sprite handle." :composition "(sprite 'hero '(turn (* 45 (audio-band 3))))" :emergent "audio-reactive sprite: sprite + audio-band = a beat-driven visual." :meta "Same family as Milkdrop-style visualizers. See book-of-composition ch14 (audio-reactive).") (:eng "Audio-reactive visuals via primitive composition." :math "Time-varying transform parameter." :cs "Reactive transform expression."))
)

(verb
  :name "sprites"
  :library "core"
  :kind "null"
  :signature "(sprites sprite-list form) -> undefined"
  :summary "Attach a sprite-rendering form (animation, transformation) to one or more named sprites on a card."
  :explanation "The `sprites` verb lets you declaratively bind a rendering or transformation form to one or more sprites currently active on a card. It takes a sprite name (or list of names) and a form (usually a combinator like 'in-order', 'loop', etc.), validates the form, and emits a card event that applies that rendering instruction to the matching sprites. This is how you animate sprites, apply effects, or chain behaviors without manually stepping the sprite state machine."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(sprites 'goblin (list 'rotate 45))" :note "Rotate the goblin sprite 45 degrees.")
    (:dialect "motoi" :tier "intermediate" :code "(sprites (list 'knight 'squire)\n  (list 'in-order\n    (list 'move-to 100 200)\n    (list 'wait 500)\n    (list 'rotate 90)))" :note "Animate two sprites in sequence: move both to (100, 200), wait, then rotate.")
    (:dialect "motoi" :tier "expert" :code "(define (choreograph-combat attacker defender)\n  (sprites attacker\n    (list 'in-order\n      (list 'lean-aside 30)\n      (list 'wait 200)))\n  (sprites defender\n    (list 'in-order\n      (list 'wait 200)\n      (list 'lean-aside -40)\n      (list 'wait 100))))\n(choreograph-combat 'hero 'goblin)" :note "Coordinate two sprites' animations: hero leans, then goblin reacts with a delayed lean.")
  )
  :caveats ("The form must be valid; invalid forms return an error and the event is not emitted." "Sprite names are case-insensitive and may include the '#sprite/' prefix; both are normalized." "If a sprite name does not match any sprite on the card, the event is still emitted but may silently do nothing (or escalate, depending on the card's error handling)." "Multiple calls to `sprites` for the same sprite will queue or replace animations; order matters.")
  :drawbacks ("Asynchronous: the form is validated but the actual animation is applied by the card renderer, which may not be immediate." "Does not return the sprite's final state; if you need state inspection, use card/get or card/ask after the animation completes." "Forms are limited to the registered combinators; custom animation logic must be wrapped in a known combinator or expressed as a state machine.")
  :usecases ("Choreographing multi-sprite animations: NPC conversations, combat exchanges, synchronized dancing." "Applying persistent transforms: rotate, scale, or tint a sprite and keep it that way until replaced." "Event-driven animation: trigger sprite behaviors in response to user input, card logic, or game state changes.")
  :related ("sprite/address" "sprite/landmarks" "sprite/rasterize" "card/emit" "part/lean" "part/wave")
  :learn (:concept "Declarative sprite choreography: binding animation forms to named sprites via event emission." :prerequisites ("card/emit (core verb)" "validateForm, validateCombinator (internal utilities — understand what makes a valid form)" "list (core form)") :progression "Combine with card/ask to poll sprite state; use part/* verbs to build humanoid animations; integrate with on-frame for frame-by-frame control if needed.")
  :row-2-audit ((:problem "Operator must animate multiple named sprites on a card at once." :program "(sprites 'card (list 'hero 'sidekick) '(anim 'walk))" :explanation "sprites attaches an animation form to several named sprites simultaneously." :meta "sprite is single; touch is contact-oriented. sprites is the correct choice for BATCH sprite ops.") (:eng "Operator log: 'sprites walk on hero+sidekick'." :math "Broadcast transform across a set." :cs "Bulk operation on sprite set."))
  :row-3-dimension ((:setup "broadcast-transform" :rungs ((:domain "motoi sprite" :code "(sprites 'card ...)") (:domain "css" :code ";; apply transform to class-set:\n;; .selected { transform: ... }") (:domain "uniform map" :code ";; map f over a set\n(define (uniform-map f s) (map f s))")) :explanation "Each rung applies the same operation to a batch of targets." :meta "'Broadcast op' is the shape.") (:eng "Batch ops reduce individual manipulation cost." :math "Uniform map over a set." :cs "SIMD-like broadcast."))
  :row-4-proof ((:claim "sprites applies the same form to each named target consistently." :program "(sprites 'card '(a b c) '(tint red))\n(display 'consistent-across-targets)" :invariant "∀ card, targets. same form applied to each" :meta "Uniform application. See book-of-composition ch12 (broadcast).") (:eng "Same behavior across batch = predictable UI." :math "Function preserved on batch application." :cs "Uniform apply pattern."))
  :row-5-emergence ((:base "sprites broadcasts an animation." :composition "(sprites 'main (list 'a 'b 'c) '(anim 'idle))" :emergent "crowd animation: broadcast form + list of names = a full crowd in idle." :meta "Same family as instanced rendering. See book-of-composition ch16 (batching).") (:eng "Crowd animations via one call." :math "Instanced application." :cs "Batch dispatch."))
)

(verb
  :name "stop"
  :library "core"
  :kind "mut"
  :signature "(stop) -> undefined"
  :summary "Halt the currently running game loop immediately."
  :explanation "`stop` is a no-argument verb that sets an internal flag (`game.stopped = true`) which causes the frame loop to exit after the current frame completes. It returns undefined. This is the low-level way to end a game loop started by `big-bang`; it is often paired with conditions like (when (>= (game/frame) 1000) (stop)) to exit when time runs out, or with escalate to fail gracefully."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define initial (lambda args (list \"initial\" args)))\n(big-bang\n  (initial 100)\n  (on-tick (lambda (s) (if (= s 0) (stop)) (- s 1))))" :note "Count down from 100; when it reaches 0, call (stop) to end the loop.")
    (:dialect "motoi" :tier "intermediate" :code "(big-bang (list 'player (list 0 0) 100)\n           (lambda (state)\n             (if (<= (list-ref state 2) 0)\n                 (begin (display \"Game Over\") (stop))\n                 (list (car state) (cadr state) (- (list-ref state 2) 1)))))" :note "Decrement HP; when it reaches 0, print and stop.")
    (:dialect "motoi" :tier "expert" :code "(define initial (lambda args (list \"initial\" args)))\n(define (victory-condition world-state)\n  (let ((enemies-alive (world/count world-state 'goblin)))\n    (if (= enemies-alive 0)\n      (begin\n        (display \"Victory!\")\n        (stop))\n      world-state)))\n(big-bang\n  (initial (world/spawn 'hero 50 50))\n  (on-tick victory-condition))" :note "Query world state in on-tick; when all enemies are gone, declare victory and stop.")
  )
  :caveats ("Does not save state; the game loop simply exits. If you need to persist results, do so before calling (stop)." "Calling (stop) from outside a running game loop has no effect (there is no game to stop)." "After (stop), the game remains in memory; to restart, call big-bang again to create a new loop.")
  :drawbacks ("No return value; cannot query whether the stop succeeded or what the final state is." "Does not unwind or clean up; any open resources (audio, sprites) remain active unless explicitly shut down." "If called from a callback (on-tick, on-frame), it stops the loop but the callback's return value is ignored.")
  :usecases ("Ending a game when the player wins or loses." "Timeout: stopping the loop after a fixed number of frames." "Pause state: toggling a 'paused' flag that calls (stop) when true.")
  :related ("big-bang" "game/step" "game/stop" "game/running?" "stop-when")
  :learn (:concept "Game loop control: the imperative way to exit a loop (vs. the declarative stop-when clause)." :prerequisites ("big-bang (core verb)" "on-tick (core form)") :progression "Use stop-when for declarative loop termination (preferred); use stop for imperative control when you need side effects (logging, state saving) at exit.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "On game-over, the running loop must halt immediately." :program "(when (game-over?) (stop))" :explanation "stop signals the driver to end the game loop; no further ticks or renders fire." :meta "cancel-tick cancels ONE timer; audio-halt halts audio. stop is the correct choice for whole-loop termination.") (:eng "Operator log: 'stop invoked'." :math "Loop termination signal." :cs "Loop exit; no further ticks."))
  :row-3-dimension ((:setup "terminate-signal" :rungs ((:domain "motoi runtime" :code "(stop)") (:domain "unix" :code ";; SIGTERM the process\n;; kill -TERM $pid") (:domain "halting predicate" :code ";; enter accepting state\n(define halt? #t)")) :explanation "Each rung sends a signal that stops iteration." :meta "'Halt' is the shape.") (:eng "Clean halt is an SRE fundamental." :math "Accept state." :cs "Loop-exit signal."))
  :row-4-proof ((:claim "After stop, no further on-tick or on-frame callbacks fire." :program "(stop)\n(display 'no-more-ticks)" :invariant "∀ time t > stop-time. no ticks fire" :meta "Termination. Falsified by any post-stop tick. See book-of-computing ch06 (termination).") (:eng "Stop means stop." :math "Absorbing state." :cs "Idempotent halt."))
  :row-5-emergence ((:base "stop halts the loop." :composition "(on-tick (lambda (s) (if (game-over? s) (stop) (step s))))" :emergent "conditional termination: predicate + stop = a loop that ends on a condition." :meta "Same family as while-loop break in imperative code. See book-of-composition ch16 (termination).") (:eng "Predicate-driven halt is honest." :math "Bounded iteration." :cs "Conditional break."))
)

(verb
  :name "stop-when"
  :library "core"
  :kind "pure"
  :signature "(stop-when predicate) -> clause"
  :summary "Declare a loop-termination condition: the loop exits when the predicate returns true."
  :explanation "Instead of calling `stop` imperatively inside a callback, `stop-when` lets you declare termination declaratively as a clause in `big-bang`. You provide a predicate function that receives the current state; if it returns true, the loop exits after that frame. This is cleaner than embedding stop in on-tick, because it separates the exit logic from the state update logic. It is the preferred way to end a loop based on a state condition."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define initial (lambda args (list \"initial\" args)))\n(big-bang\n  (initial 10)\n  (on-tick (lambda (s) (- s 1)))\n  (stop-when (lambda (s) (= s 0))))" :note "Count down from 10; exit when state reaches 0.")
    (:dialect "motoi" :tier "intermediate" :code "(define initial (lambda args (list \"initial\" args)))\n(big-bang\n  (initial (list 'hero (list 100 100) 100 #t))\n  (on-tick (lambda (state)\n    (let* ((pos (cadr state)) (hp (list-ref state 2)))\n      (if (> (random-int 100) 80) ; take damage 20% of time\n        (list (car state) pos (- hp 1) #t)\n        state))))\n  (stop-when (lambda (state) (<= (list-ref state 2) 0))))" :note "Simulate combat damage; exit when HP reaches 0. No explicit (stop) call needed.")
    (:dialect "motoi" :tier "expert" :code "(define initial (lambda args (list \"initial\" args)))\n(define game-start-state (lambda args (list \"game-start-state\" args)))\n(define game-loop-step 'game-loop-step)\n(define render-frame 'render-frame)\n(define (all-objectives-met state)\n  (and (>= (state-cash state) 1000)\n       (>= (state-reputation state) 50)\n       (null? (state-enemies state))))\n(big-bang\n  (initial (game-start-state))\n  (on-tick game-loop-step)\n  (on-frame render-frame)\n  (stop-when all-objectives-met))" :note "Compose multiple conditions (cash, reputation, enemies cleared) into a single exit check.")
  )
  :caveats ("The predicate is called every frame; if it is expensive, consider caching intermediate results in the state." "If the predicate throws, the exception bubbles to the studio (loop halts, error is surfaced)." "Multiple stop-when clauses are all evaluated; the loop exits on the first one that returns true.")
  :drawbacks ("Declarative only: you cannot perform side effects (logging, state saving) when exiting without wrapping the predicate." "Predicate is called AFTER the state is updated; you cannot prevent an update, only trigger exit after it completes." "If you need to exit with a custom result or message, use escalate instead (which throws a catchable error).")
  :usecases ("Game-over conditions: exit when player HP ≤ 0 or when objective is completed." "Timeout: exit when (game/frame) exceeds a limit." "State-based termination: exit when a flag is set or a counter reaches a goal.")
  :related ("big-bang" "stop" "game/running?" "on-tick" "check-with")
  :learn (:concept "Declarative loop termination: separating exit logic from update logic via predicate clauses." :prerequisites ("big-bang (core verb)" "lambda (core form)" "game/frame (core verb) — often used in the predicate") :progression "Combine with check-with for frame-level assertions; use escalate if you need to signal failure with a message.")
  :row-2-audit ((:problem "A big-bang loop must end when x exceeds 100." :program "(big-bang 0\n  (on-tick (lambda (s) (+ s 1)))\n  (stop-when (lambda (s) (> s 100))))" :explanation "stop-when installs a predicate; when it returns true, the loop terminates." :meta "stop is an imperative halt; on-tick's return does not terminate. stop-when is the correct choice for a declarative termination predicate.") (:eng "Operator log: 'stop-when installed'." :math "Termination predicate on state." :cs "Predicate installed on the loop."))
  :row-3-dimension ((:setup "predicate-driven-termination" :rungs ((:domain "motoi big-bang" :code "(stop-when p)") (:domain "while loop" :code ";; while not(p(s)): iterate\n;; while [ ! p ]; do step; done") (:domain "halting condition" :code ";; halts iff P(state) = true\n(define (halt? s) #f)")) :explanation "Each rung declares a state-based termination condition." :meta "'Predicate halt' is the shape.") (:eng "Declarative halt is easier to reason about than imperative stop." :math "Halting predicate on state." :cs "Loop-condition clause."))
  :row-4-proof ((:claim "stop-when predicate is checked once per tick." :program "(big-bang 0\n  (on-tick (lambda (s) (+ s 1)))\n  (stop-when (lambda (s) (> s 5))))" :invariant "∀ tick. predicate checked exactly once" :meta "Once-per-tick check. Falsified by any double-check or skip. See book-of-computing ch07 (loops).") (:eng "Predictable termination timing." :math "Predicate evaluated on each state." :cs "Loop-condition once per step."))
  :row-5-emergence ((:base "stop-when installs a halt predicate." :composition "(big-bang '(0 0)\n  (on-tick (lambda (s) (map + s '(1 0))))\n  (stop-when (lambda (s) (>= (car s) 10))))" :emergent "bounded simulation: on-tick + stop-when = a finite-time simulation." :meta "Same family as htdp/universe stop-when. See book-of-composition ch16 (game loops).") (:eng "Bounded execution = testable." :math "Bounded iterated system." :cs "Predicate-driven loop."))
)

(verb
  :name "sub-position-per-beat"
  :library "core"
  :kind "null"
  :signature "*[verify]*"
  :summary "Place an entity at a rhythmic sub-position within a beat formation."
  :explanation "This verb is part of the position-rhythm system for choreographing entities to move in formation alongside a musical beat. It allows you to specify a fractional position relative to the beat grid, useful for step-by-step dances or synchronized group motion. The underlying FORMATIONS table defines available formation templates."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define entity 'entity)\n(sub-position-per-beat entity 0.5 'line)" :note "Place entity at the halfway point of a beat in line formation")
    (:dialect "motoi" :tier "intermediate" :code "(define (dance-line entities)\n  (map (lambda (e) (sub-position-per-beat e 0.25 'line))\n       entities))" :note "Map over entities, placing each at quarter-beat intervals in formation")
    (:dialect "motoi" :tier "expert" :code "(define (choreograph ctx)\n  (let ((beat (audio-beat? (card-id-of (ctx-get 'card ctx))))\n        (formation (ctx-get 'formation ctx)))\n    (when beat\n      (for-each (lambda (e)\n                  (sub-position-per-beat e (/ (entity-x e) 100) formation))\n                (ctx-get 'dancers ctx)))))" :note "Synchronize dancers to current beat; derive sub-position from entity x-coordinate normalized to formation")
    (:dialect "motoi" :tier "novice" :code "(display (sub-position-per-beat 0.5))" :note "Convert a half-beat offset into a sub-position for smooth interpolation.")
    (:dialect "motoi" :tier "intermediate" :code "(on-frame\n  (lambda ()\n    (let ((p (sub-position-per-beat 0.25)))\n      (grid-cell-set! p 0 1))))" :note "Move a cell one quarter of a beat at a time — a tight sequencer step.")
  )
  :caveats ("Requires audio-beat? to be active; behavior undefined if no beat is playing" "Formation name must exist in FORMATIONS; unknown formations are silently ignored" "Sub-position values should be in [0, 1) to wrap cleanly to the next beat" "Entity velocity is reset; prior motion is overridden")
  :drawbacks ("Tight coupling to beat phase; brittle if audio tempo changes suddenly" "All entities in the formation move synchronously; individual timing variation requires additional logic" "Does not account for entity size; overlaps possible in dense formations")
  :usecases ("Synchronized dance or marching routines where entities move together on beat" "Chorus line or group choreography with repeating formation patterns" "Step-by-step puzzle where entities must land on specific beat phases")
  :related ("walk-together" "audio-beat?" "audio-tempo" "entity/set-pos!" "motion/anchor-to-input")
  :learn (:concept "Rhythmic choreography: syncing entity motion to a beat's fractional timeline" :prerequisites ("audio-beat?" "entity/set-pos!" "map") :progression "Learn walk-together to choreograph multi-entity gaits, then explore motion/with-pace for eased position transitions")
  :row-2-audit ((:problem "An entity must sit at a rhythmic sub-position within a beat formation." :program "(sub-position-per-beat 'e1 0.25)" :explanation "The entity is placed at the quarter-beat sub-position within the formation." :meta "at-beat samples the formation; in-formation applies a whole formation. sub-position-per-beat is the correct choice for per-entity sub-beat placement.") (:eng "Operator log: 'e1 sub-pos 0.25'." :math "Fraction of beat mapped to position." :cs "Descriptor construction."))
  :row-3-dimension ((:setup "sub-lattice-position" :rungs ((:domain "motoi choreo" :code "(sub-position-per-beat 'e1 0.25)") (:domain "drum machine" :code ";; place a hi-hat on the 'and' of 1:\n;; step 2 of 4 = 0.25 beat offset") (:domain "rational subdivision" :code ";; 1/4 within a period\n(define (subd n d) (/ n d))")) :explanation "Each rung places an event at a rational subdivision of a period." :meta "'Sub-beat placement' is the shape.") (:eng "Sub-beat placement is at the heart of rhythmic feel." :math "Rational offset in [0, 1)." :cs "Descriptor with fractional offset."))
  :row-4-proof ((:claim "Same entity and offset yields deterministic placement." :program "(sub-position-per-beat 'e 0.5)\n(sub-position-per-beat 'e 0.5)\n(display 'deterministic)" :invariant "∀ e offset. placement is deterministic" :meta "Determinism. See book-of-sound ch06 (subdivisions).") (:eng "Deterministic sub-beat = repeatable rhythms." :math "Function of (entity, offset)." :cs "Pure descriptor emission."))
  :row-5-emergence ((:base "sub-position-per-beat places at a fractional beat." :composition "(for-each\n  (lambda (i) (sub-position-per-beat (list 'e i) (/ i 4)))\n  '(0 1 2 3))" :emergent "beat-quantized crowd: many entities at rational offsets = a rhythm-locked formation." :meta "Same family as step-sequencer grids. See book-of-composition ch13 (subdivisions).") (:eng "Coordinated sub-beat = intentional rhythm." :math "Rational grid over entities." :cs "Batch fractional placement."))
)

(verb
  :name "surface-exists?"
  :library "core"
  :kind "rd"
  :signature "(surface-exists? surface-name) -> boolean"
  :summary "Check whether a named surface is registered and available."
  :explanation "The surface-exists? verb queries the SurfaceRegistry to determine if a surface with a given name exists. It takes a symbol or string and returns true if the surface is found, false otherwise. Useful for defensive coding before attempting surface operations like clear-surface-layer."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(surface-exists? 'main)" :note "Check if the 'main surface is registered")
    (:dialect "motoi" :tier "intermediate" :code "(define (safe-clear-layer surface layer)\n  (if (surface-exists? surface)\n    (clear-surface-layer surface layer)\n    (display \"Surface not found\")))" :note "Guard a clear-surface-layer call with a safety check")
    (:dialect "motoi" :tier "expert" :code "(define (ensure-surfaces-ready ctx)\n  (let ((required-surfaces (list 'main 'overlay 'effects)))\n    (for-each (lambda (s)\n                (unless (surface-exists? s)\n                  (escalate 'missing-surface s)))\n              required-surfaces)\n    (next 'start-render ctx)))" :note "Validate that all required surfaces exist before starting a render loop; escalate if any are missing")
  )
  :caveats ("The verb takes a symbol; if passed a string, it is coerced via symName" "Returns false for null, undefined, or unregistered names; no distinction between the two" "Does not check if the surface is currently active or healthy, only that it is registered")
  :drawbacks ("No error information; false could mean not found, not initialized, or registry corruption" "Surfaces can be unregistered dynamically; a true result at one moment does not guarantee availability later")
  :usecases ("Defensive check before calling clear-surface-layer or other surface operations" "Validate that a multi-surface setup is initialized before rendering" "Guard state transitions that depend on a specific surface being available")
  :related ("clear-surface-layer" "surface-dim" "surface-curtain" "surface-dusk" "surface/spotlight" "surface-spotlight")
  :learn (:concept "Registry queries: checking resource availability before use" :prerequisites ("if" "unless" "for-each") :progression "Pair with clear-surface-layer to build safe surface manipulation routines; then learn card-list and form-list for similar defensive patterns")
  :row-2-audit ((:problem "Before drawing on a surface, the operator must confirm it is registered." :program "(when (surface-exists? 'overlay)\n  (begin-frame 'overlay))" :explanation "The guard prevents begin-frame on a non-existent surface." :meta "grid-init creates the grid; end-frame commits. surface-exists? is the correct choice for a REGISTRATION probe.") (:eng "Operator log: 'surface overlay? #t'." :math "Boolean over surface registry." :cs "Name-in-set predicate."))
  :row-3-dimension ((:setup "registry-membership" :rungs ((:domain "motoi surface" :code "(surface-exists? 'overlay)") (:domain "filesystem" :code ";; -e /path/to/file") (:domain "set membership" :code ";; x ∈ S\n(define (in? x s) (member x s))")) :explanation "Each rung asks 'is this name known?'" :meta "'Registry membership' is the shape.") (:eng "Membership probes precede any surface op." :math "Predicate x ∈ S." :cs "Hash membership query."))
  :row-4-proof ((:claim "surface-exists? is a pure query of the surface registry." :program "(display (equal? (surface-exists? 'main) (surface-exists? 'main)))" :invariant "∀ name. exists?(name) idempotent within a frame" :meta "Determinism. See book-of-computing ch09 (registries).") (:eng "Cheap probe; safe to call every frame." :math "Pure boolean function." :cs "Idempotent read."))
  :row-5-emergence ((:base "surface-exists? guards surface ops." :composition "(define (safe-begin s) (when (surface-exists? s) (begin-frame s)))" :emergent "safe-begin wrapper: probe + begin = a surface-agnostic starter." :meta "Same family as file-open guards. See book-of-composition ch06 (safe access).") (:eng "Guard prevents phantom-surface crashes." :math "Guarded operation." :cs "Precondition check."))
)

(verb
  :name "tempo"
  :library "core"
  :kind "mut"
  :signature "(tempo bpm) → bpm"
  :summary "Set the shared transport BPM — the metronome that all timed systems synchronize to."
  :explanation "All music, animation, and choreography in the world run on a shared beat. `tempo` sets the BPM (beats per minute) that drives `audio/tempo`, `tick/phase`, `on-beat`, and motion timing. Every call updates the global transport; all systems see the new tempo immediately on the next frame. Return value is the BPM that was set."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(tempo 120)" :note "Set the transport to 120 BPM. All timed systems now run at this rate.")
    (:dialect "motoi" :tier "intermediate" :code "(define (double-time)\n  (let ((current 120))\n    (tempo (* current 2))))\n(double-time)" :note "Change tempo dynamically—useful for progressive or remix patterns.")
    (:dialect "motoi" :tier "expert" :code "(define (sync-to-audio-tempo)\n  (let ((audio-bpm (audio-bpm)))\n    (when (number? audio-bpm)\n      (tempo audio-bpm))))\n(on-frame sync-to-audio-tempo)" :note "Tie the transport tempo to the detected audio tempo, updating every frame.")
  )
  :caveats ("Tempo changes apply globally; all animated systems respond immediately." "Setting tempo to 0 or negative halts the beat but does not reset phase." "Tempo is a floating-point value; fractional BPMs are valid (e.g., 120.5)." "The transport does not quantize; rapid tempo changes can cause jitter.")
  :drawbacks ("Global state mutation; affects all simultaneous animations and audio." "No undo; previous tempo is lost once overwritten." "If tempo is changed while audio is playing, audio and visuals may desynchronize unless re-synced manually.")
  :usecases ("Build a DJ or remix interface where the user adjusts tempo in real time." "Synchronize a choreography to a detected beat (audio-bpm detection)." "Implement tempo ramping for a swell or climax sequence." "Test timing-sensitive logic at different speeds.")
  :related ("audio/tempo" "audio-bpm" "on-beat" "tick/phase" "transport/tempo")
  :learn (:concept "Shared timing: how all periodic systems in the world synchronize to a single metronome." :prerequisites ("(core)" "on-frame") :progression "Learn audio-bpm to detect tempo from audio; then on-beat to align logic to beats; then tick/phase to compute time-dependent values.")
  :row-2-audit ((:problem "A song intro needs tempo set to 90 BPM." :program "(tempo 90)" :explanation "tempo sets the shared transport BPM; all beat-locked systems retune immediately." :meta "audio-tempo sets audio-engine tempo; audio-bpm reads. tempo is the correct choice for the SHARED TRANSPORT.") (:eng "Operator log: 'transport BPM=90'." :math "Positive real." :cs "Global-state write."))
  :row-3-dimension ((:setup "global-rate-set" :rungs ((:domain "motoi transport" :code "(tempo 90)") (:domain "daw" :code ";; set project BPM\n;; project.tempo = 90") (:domain "angular frequency" :code ";; ω = 2π · f\n(define omega 90)")) :explanation "Each rung sets a global rate for the periodic system." :meta "'Global rate' is the shape.") (:eng "One-knob-tempo simplifies session music." :math "Angular frequency." :cs "Global scalar write."))
  :row-4-proof ((:claim "tempo is monotone in effect." :program "(tempo 60)\n(tempo 120)\n(display 'faster)" :invariant "∀ b1 < b2. rate(tempo=b1) < rate(tempo=b2)" :meta "Monotone rate. See book-of-sound ch05 (tempo).") (:eng "Predictable tempo change." :math "Order-preserving map." :cs "Linear rate scalar."))
  :row-5-emergence ((:base "tempo sets shared BPM." :composition "(define (ramp from to steps)\n  (let loop ((i 0)) (when (< i steps) (tempo (+ from (* (- to from) (/ i steps)))) (loop (+ i 1)))))" :emergent "tempo ramp: iterated tempo calls = a linear ramp between rates." :meta "Same family as DAW tempo automation. See book-of-composition ch14 (automation).") (:eng "Smooth ramps for transitions." :math "Linear interpolation in tempo space." :cs "Ramp generator."))
)

(verb
  :name "to-draw"
  :library "core"
  :kind "pure"
  :signature "(to-draw render-fn) → clause"
  :summary "Wrap a rendering function into a clause for big-bang."
  :explanation "to-draw transforms a pure render function (one that takes a world state and returns a renderable structure) into a clause that big-bang can execute each frame. The clause has no side-effects itself; it is the render-fn that does the work. The function receives the current game state and must return rendering directives (e.g., paint-grid, paint-coin, etc.). This is the primary way to hook visual output into a game loop."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define (start ctx)\n  (big-bang\n    (list (to-draw (lambda (state) (paint-grid state))))))" :note "Render a grid every frame from the state.")
    (:dialect "motoi" :tier "intermediate" :code "(define (start ctx)\n  (big-bang\n    (list (to-draw (lambda (state)\n                     (let ((cells (ctx-get 'cells state)))\n                       (paint-grid state))))\n          (on-key (lambda (k s) s)))))" :note "Extract cells from state, then render the grid. Input handling runs in parallel.")
    (:dialect "motoi" :tier "expert" :code "(define (start ctx)\n  (big-bang\n    (list (time/during (lambda () (ctx-get 'is-playing? ctx))\n                       (to-draw (lambda (state)\n                                 (let ((health (ctx-get 'health state))\n                                       (score (ctx-get 'score state)))\n                                   (begin (paint-grid state)\n                                          (paint-coin health score))))))\n          (on-key (lambda (k s) s)))))" :note "Conditionally render grid and coin overlay while playing; render is gated by time/during.")
  )
  :caveats ("The render-fn must be pure: it cannot mutate the state or have side-effects beyond producing render directives." "If the render-fn throws an error, the loop may halt or render an error screen." "Returning nil or an empty list produces no output (a blank frame).")
  :drawbacks ("Expensive rendering (e.g., rasterizing large text every frame) will slow the loop; cache or compute incrementally if needed." "The state passed to render-fn is read-only; use ctx-set to mutate state in other clauses (on-key, etc.).")
  :usecases ("Drawing the main game world each frame." "Rendering UI overlays (score, health, inventory)." "Visualizing AI state or debug info." "Composing multiple paint operations (grid, sprites, text).")
  :related ("big-bang" "on-key" "on-tick" "stop-when" "check-with" "paint-grid" "paint-coin")
  :learn (:concept "Convert a pure render function into a clause for the game loop." :prerequisites ("big-bang" "lambda" "ctx-get") :progression "Combine to-draw with on-key and time/during to build a complete game loop; learn to-draw alongside other clause forms.")
  :row-2-audit ((:problem "A big-bang loop needs a rendering function." :program "(big-bang '(0 0)\n  (on-tick (lambda (s) s))\n  (to-draw (lambda (s) (grid-cell-set! (car s) 0 1))))" :explanation "to-draw wraps a rendering function into a big-bang clause." :meta "on-frame is generic per-frame; display registers a widget. to-draw is the correct choice for the BIG-BANG RENDER clause.") (:eng "Operator log: 'to-draw registered'." :math "Function state -> render effect." :cs "big-bang clause tag."))
  :row-3-dimension ((:setup "render-clause" :rungs ((:domain "motoi world" :code "(to-draw f)") (:domain "react" :code ";; render function\n;; function render(state) { return <View>...</View> }") (:domain "state-to-view" :code ";; V : S -> R\n(define (view s) (list 'render s))")) :explanation "Each rung defines how state becomes a rendered view." :meta "'State-to-view' is the shape.") (:eng "Pure render clauses are the MVC contract." :math "Function S -> R." :cs "View function."))
  :row-4-proof ((:claim "to-draw function receives the current state each frame." :program "(big-bang '(0)\n  (to-draw (lambda (s) (display s))))" :invariant "∀ frame. render receives current state" :meta "State-render coupling. See book-of-composition ch16 (game loops).") (:eng "State-render tight coupling." :math "Function of state." :cs "Pure view derivation."))
  :row-5-emergence ((:base "to-draw wraps a render clause." :composition "(big-bang '(0 0)\n  (on-tick (lambda (s) (map + s '(1 1))))\n  (to-draw (lambda (s) (grid-cell-set! (car s) (cadr s) 1))))" :emergent "MVC-lite loop: state + tick + draw = a functional game architecture." :meta "Same family as htdp/universe or React's declarative render. See book-of-composition ch16 (loops).") (:eng "Functional MVC in one call." :math "Discrete-time observable view." :cs "Reactor with pure view."))
)

(verb
  :name "touch"
  :library "core"
  :kind "meta"
  :signature "(touch part-name target-card [options]) → gesture"
  :summary "Choreograph a character's hand or limb to make contact with a card or location."
  :explanation "touch orchestrates a body part (hand, foot, etc.) to reach out and make deliberate contact with a target — typically another card or a region of the screen. It is a choreography verb: it composes semantic body parts (via part/*) into a gesture that the system can visualize and interact with. Unlike raw motion, touch includes intentionality: the system knows this is a deliberate reach, not just movement, and can trigger collision, gesture-recognition, and UI feedback. Often used within form-group or as part of a larger interaction choreography."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define (start ctx)\n  (touch 'hand (card-id-of (card-find-by-kind 'button))))" :note "Reach out with the hand to touch a button card.")
    (:dialect "motoi" :tier "intermediate" :code "(define (start ctx)\n  (let ((target (card-find-by-kind 'switch)))\n    (if (pair? target)\n        (touch 'hand (card-id-of target))\n        (list))))" :note "Find a switch card, then touch it with the hand. Return empty list if not found.")
    (:dialect "motoi" :tier "expert" :code "(define (start ctx)\n  (let ((src-id (ctx-get 'source-card ctx))\n        (dst-id (ctx-get 'target-card ctx)))\n    (when (and (number? src-id) (number? dst-id))\n      (part/point 'hand dst-id)\n      (touch 'hand dst-id))))" :note "Point to a target card, then touch it. Composes part/point and touch for a multi-step gesture.")
    (:dialect "motoi" :tier "novice" :code "(display (touch))" :note "Where is the finger or mouse right now? Returns coordinates or #f.")
    (:dialect "motoi" :tier "intermediate" :code "(on-frame\n  (lambda ()\n    (let ((t (touch)))\n      (when t\n        (camera-center-on (car t) (cadr t))))))" :note "Follow the finger with the camera. Feels like drag-panning a map.")
  )
  :caveats ("The target must be a valid card ID; passing nil or a non-existent card may fail silently or error." "touch by itself does not transfer items or trigger callbacks; pair it with transfer or card-emit for full interaction." "The hand's reach is limited by the card layout; touching a card far off-screen may not animate smoothly.")
  :drawbacks ("Requires a target card to exist; dynamic targets may not be available when the gesture runs." "Chaining multiple touches can be verbose; consider form-group for multi-touch interactions.")
  :usecases ("Interactive UI: touch a button to confirm or dismiss a dialog." "Inventory management: touch an item card to pick it up." "Gesture-driven gameplay: touch targets in sequence as part of a puzzle." "Choreographed cutscenes: character reaches out to interact with the environment.")
  :related ("part/reach" "part/point" "hand-off" "form-group" "card-emit" "transfer" "card-find-by-kind")
  :learn (:concept "Semantically meaningful limb motion: reaching to touch a target." :prerequisites ("card-id-of" "card-find-by-kind" "part/reach") :progression "Combine with hand-off for two-handed interactions; use within form-group to choreograph multi-step sequences.")
  :row-2-audit ((:problem "A character must reach out and touch a card." :program "(touch 'hero 'card-a)" :explanation "touch choreographs the character's hand or limb to make contact." :meta "in-formation places entities; sprite renders. touch is the correct choice for contact CHOREOGRAPHY.") (:eng "Operator log: 'hero touch card-a'." :math "Path from actor to target." :cs "Choreography descriptor."))
  :row-3-dimension ((:setup "reach-and-contact" :rungs ((:domain "motoi choreo" :code "(touch 'hero 'card-a)") (:domain "ik solver" :code ";; solve inverse kinematics for hand-to-target\n;; ik.solve(hand, target)") (:domain "pathfinding-with-contact" :code ";; path from A to B ending in contact\n(define (path a b) (list a b))")) :explanation "Each rung reaches from an actor to a target ending in contact." :meta "'Reach + contact' is the shape.") (:eng "IK-style reaches feel natural in choreography." :math "Path terminating at a target." :cs "Contact choreography descriptor."))
  :row-4-proof ((:claim "touch is deterministic in actor and target." :program "(touch 'hero 'card-a)\n(display 'deterministic-choreo)" :invariant "∀ actor, target. touch is a deterministic descriptor" :meta "Determinism. See book-of-composition ch17 (choreography).") (:eng "Deterministic choreography = replayable scenes." :math "Function of (actor, target)." :cs "Pure descriptor."))
  :row-5-emergence ((:base "touch produces a contact choreography." :composition "(for-each (lambda (c) (touch 'hero c)) '(card-a card-b card-c))" :emergent "deal-out: iterated touches = dealing a hand of cards." :meta "Same family as blackjack dealer animations. See book-of-composition ch17 (choreography).") (:eng "Iterated choreography for card dealing." :math "Map touch over target list." :cs "Batch choreography."))
)

(verb
  :name "viewport"
  :library "core"
  :kind "rd"
  :signature "(viewport) -> {x, y, w, h} | null"
  :summary "Query the current viewport bounding box (camera frame on the card surface)."
  :explanation "viewport returns an object containing the camera's current x, y position and width (w) and height (h) in canvas/world coordinates. This defines what portion of the world is visible on screen. Use it to query camera state for layout, collision detection, or on-screen checks. Returns null if no viewport is active (rare in normal operation)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((vp (viewport)))\n  (if vp\n    (display (list 'width (hash-ref vp 'w) 'height (hash-ref vp 'h)))\n    (display 'no-viewport)))" :note "Check if viewport exists and print its dimensions; handle the null case.")
    (:dialect "motoi" :tier "intermediate" :code "(define x 'x)\n(define (on-screen? entity-x entity-y)\n  (let ((vp (viewport)))\n    (if (not vp) #f\n      (and (>= entity-x (vp :x))\n           (<= entity-x (+ (vp :x) (vp :w)))\n           (>= entity-y (vp :y))\n           (<= entity-y (+ (vp :y) (vp :h)))))))\n\n(if (on-screen? 512 256) (display 'visible))" :note "Build a collision test: is a point within the viewport bounds? Used for culling or event handling.")
    (:dialect "motoi" :tier "expert" :code "(define (fit-card-in-view card-id)\n  (let* ((rect (card-screen-rect card-id))\n         (vp (viewport))\n         (offset-x (- (rect :x) (vp :x)))\n         (offset-y (- (rect :y) (vp :y))))\n    (if (or (< offset-x 0) (> offset-x (vp :w)))\n      (camera-pan-to (+ (vp :x) (rect :x)) (vp :y))\n      (if (or (< offset-y 0) (> offset-y (vp :h)))\n        (camera-pan-to (vp :x) (+ (vp :y) (rect :y)))))))" :note "Pan camera to keep a card on-screen; compute viewport-relative offsets to decide panning direction.")
    (:dialect "motoi" :tier "novice" :code "(display (viewport))" :note "Ask what part of the world is currently visible. Returns bounds.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((v (viewport)))\n  (display (list 'left (car v) 'top (cadr v))))" :note "Peel apart the viewport tuple to see the top-left corner.")
  )
  :caveats ("viewport returns the *world* bounding box of the visible area, not screen pixels. Coordinates are in world space." "The returned object keys are lowercase (:x, :y, :w, :h); use keyword access, not dot notation." "Viewport is a snapshot at query time; it may change on the next frame if camera is moving.")
  :drawbacks ("Reading viewport repeatedly in a tight loop is wasteful; cache the result if you need to query it multiple times per frame." "Does not directly tell you whether a shape or card is on-screen; you must implement your own bounding-box test.")
  :usecases ("Culling: only update or render entities within the viewport." "Pan-to-fit: automatically center the camera on a card or region of interest." "UI layout: position HUD elements relative to viewport bounds.")
  :related ("viewport-width" "camera-state" "camera-pan-to" "card-screen-rect" "camera-fit-all")
  :learn (:concept "Viewport as a read-only window into world state; world coordinates vs. screen coordinates." :prerequisites ("camera-state") :progression "After viewport, learn viewport-width for quick width queries, then explore camera-pan-to and camera-fit-all for active camera control.")
  :row-2-audit ((:problem "Operator needs the viewport bounding box for collision culling." :program "(define vp (viewport))\n(display vp)" :explanation "viewport returns the current bounding box on the card surface." :meta "camera-state returns position/zoom; pixels-wide returns raw dims. viewport is the correct choice for the VIEW BOX.") (:eng "Operator log: 'viewport (0 0 800 600)'." :math "Rectangle in world coordinates." :cs "Read of viewport state."))
  :row-3-dimension ((:setup "observable-region" :rungs ((:domain "motoi camera" :code "(viewport)") (:domain "cctv monitor" :code ";; the region the camera is watching") (:domain "axis-aligned bounding box" :code ";; (x0 y0 x1 y1)\n(define (aabb) '(0 0 100 100))")) :explanation "Each rung returns the observable rectangular region." :meta "'Observable region' is the shape.") (:eng "Bounding boxes drive culling everywhere." :math "Axis-aligned bounding box." :cs "AABB struct."))
  :row-4-proof ((:claim "viewport is a function of camera state; identical camera state yields identical viewport." :program "(define a (viewport))\n(define b (viewport))\n(display (equal? a b))" :invariant "∀ camera-state. viewport is deterministic" :meta "Determinism. See book-of-math ch12 (transforms).") (:eng "Predictable culling." :math "Function of camera state." :cs "Pure derivation from camera."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "viewport returns the current view box." :composition "(define (visible? e) (in-box? (entity/pos e) (viewport)))\n(filter visible? (entity/list))" :emergent "frustum culling: filter + viewport = a culling primitive." :meta "Same family as GPU frustum culling. See book-of-composition ch15 (culling).") (:eng "Culling reduces render cost." :math "Set filter by AABB predicate." :cs "Spatial filter."))
)

(verb
  :name "viewport-width"
  :library "core"
  :kind "rd"
  :signature "(viewport-width) -> number"
  :summary "Query the current viewport width in world coordinates."
  :explanation "viewport-width is a convenience accessor that returns just the width of the current camera view. It extracts the :w field from viewport and returns it, or 0 if no viewport is active. Use it when you only care about the horizontal span of what's visible—common for responsive layout, horizontal scrolling bounds, and edge detection."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(display (viewport-width))" :note "Print the current viewport width; always returns a non-negative number.")
    (:dialect "motoi" :tier "intermediate" :code "(define (card-fits-horizontally? card-id)\n  (let ((rect (card-screen-rect card-id))\n        (vp-w (viewport-width)))\n    (if vp-w\n      (<= (hash-ref rect 'w) vp-w)\n      #f)))\n\n(card-fits-horizontally? 'my-card)" :note "Check if a card's width fits within the current viewport width; handles missing viewport gracefully.")
    (:dialect "motoi" :tier "expert" :code "(define (reflow-columns ctx)\n  (let* ((vp-w (viewport-width))\n         (col-width (/ vp-w 3))\n         (cards (card-list)))\n    (for-each (lambda (card-id i)\n      (card-set! card-id 'x (* col-width (modulo i 3))))\n      cards)))" :note "Divide the viewport into three columns and reflow cards into them based on viewport width; responsive layout pattern.")
  )
  :caveats ("Returns 0 if viewport is unavailable, not an error. Always check for zero before division." "Width is in world coordinates, not screen pixels. If the camera is zoomed, world units per pixel changes." "viewport-width is a snapshot; it does not update live as the camera moves unless you call it again each frame.")
  :drawbacks ("Limited utility compared to querying the full viewport object; use viewport() if you also need x, y, or height." "Returns 0 as a sentinel rather than null or false, which can be ambiguous in certain control flows.")
  :usecases ("Responsive layout: adjust card positions or sizes based on available horizontal space." "Horizontal culling: skip rendering entities far off the left or right edge." "Safe zone detection: keep interactive elements within a margin of the viewport width.")
  :related ("viewport" "camera-state" "camera-zoom-to" "card-screen-rect")
  :learn (:concept "Viewport convenience accessors; extracting scalar queries from compound state." :prerequisites ("viewport") :progression "After viewport-width, explore the full viewport query, then move to active camera control with camera-pan-to and camera-zoom-to.")
  :row-2-audit ((:problem "Operator needs the viewport width in world units for edge-detection math." :program "(display (viewport-width))" :explanation "viewport-width returns the horizontal extent of the current viewport." :meta "pixels-wide returns pixels; camera-scale returns zoom. viewport-width is the correct choice for WORLD-UNIT width.") (:eng "Operator log: 'viewport-width=1000 world units'." :math "Positive real in world units." :cs "Read."))
  :row-3-dimension ((:setup "world-space-extent" :rungs ((:domain "motoi camera" :code "(viewport-width)") (:domain "map" :code ";; miles across the visible map:\n;; visible_bounds.width") (:domain "metric extent" :code ";; width of an interval\n(define (w a b) (- b a))")) :explanation "Each rung reports width in world units." :meta "'World extent' is the shape.") (:eng "World units differ from screen pixels; keep them straight." :math "Positive real." :cs "Read."))
  :row-4-proof ((:claim "viewport-width equals viewport's x1 - x0." :program "(define vp (viewport))\n(display (equal? (viewport-width) (- (caddr vp) (car vp))))" :invariant "∀. viewport-width = box.x1 - box.x0" :meta "Derived identity. See book-of-math ch14 (extents).") (:eng "Consistent width metric." :math "Extent difference." :cs "Derivable from viewport."))
  :row-5-emergence ((:base "viewport-width returns world-space width." :composition "(define (edge? x) (or (< x 0) (> x (viewport-width))))" :emergent "edge predicate: x + viewport-width = a boundary test." :meta "Same family as world-bounds tests. See book-of-composition ch15 (bounds).") (:eng "Boundary tests for gameplay." :math "Interval membership." :cs "Boundary predicate."))
)

(verb
  :name "wait"
  :library "core"
  :kind "null"
  :signature "(wait event [deadline-ms]) -> descriptor"
  :summary "Pause state execution until a named event fires or an optional deadline expires."
  :explanation "wait returns a control descriptor that tells the cart runtime to suspend the current state and resume it only when event fires (from on-key, on-frame, on-tick, or external listeners). If deadline-ms is provided, the wait times out and resumes with an interruption after that duration. wait is the primary way to implement non-blocking I/O and event-driven choreography in cart state machines. Unlike blocking sleep, wait keeps the surface responsive."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define (listen-for-click ctx)\n  (wait 'click-detected))" :note "Suspend execution until an event named 'click-detected' fires; simple blocking-free pause.")
    (:dialect "motoi" :tier "intermediate" :code "(define (fetch-with-timeout ctx)\n  (act 'api/fetch (list 'https://example.com/data) 'got-data))\n\n(define (got-data ctx)\n  (let ((result (ctx-result ctx)))\n    (if (null? result)\n      (next 'retry (wait 'retry-signal 5000))\n      (next 'done ctx))))" :note "Fetch data, and if empty, wait up to 5 seconds for a 'retry-signal' event; if it doesn't arrive, timeout and move to retry state.")
    (:dialect "motoi" :tier "expert" :code "(define (interactive-choreography ctx)\n  (define (step-1 ctx)\n    (act 'part/step (list 'walk) 'step-done))\n  (define (step-2 ctx)\n    (wait 'user-input 3000))\n  (define (on-input ctx)\n    (let ((input (ctx-result ctx)))\n      (if (eq? input 'skip) (next 'idle ctx)\n        (next 'step-3 ctx))))\n  (next 'step-2 (step-1 ctx)))" :note "Choreography state machine: after a part motion, wait for user input with a 3-second timeout; if input arrives, handle it; if timeout, skip to idle.")
  )
  :caveats ("wait suspends the current state; execution does not resume until the event fires or the deadline expires." "The event name must match exactly (case-sensitive, as a symbol); typos result in indefinite wait." "If the deadline is null or omitted, the wait never times out; use a timeout to prevent indefinite hangs." "When a deadline expires, the state resumes with an interruption, not a normal result; check ctx-result for nil or the interruption marker.")
  :drawbacks ("Each wait adds a listener registration; excessive wait calls can slow down the event dispatcher." "Deadline is not a \"soft\" timeout; if the event fires within the deadline window, it may still resume slightly before deadline expiry due to frame latency." "No way to cancel a pending wait from outside the state machine; the state must complete or timeout.")
  :usecases ("Interactive storytelling: wait for user input (button press, key) before advancing narrative." "Choreography choreography: pause dance moves until music reaches a specific beat." "API polling with timeout: fetch data and retry only if the user requests it within a time window.")
  :related ("after" "interrupted" "act" "next" "on-key" "on-frame")
  :learn (:concept "Non-blocking I/O and event-driven state machines; the separation between suspension and resume." :prerequisites ("next" "act" "ctx-result") :progression "After wait, learn after for delayed resumption, then explore interrupted for handling timeout/cancellation scenarios.")
  :row-2-audit ((:problem "A state must wait for a 'user-input' event or 5 seconds, whichever comes first." :program "(wait 'user-input 5)" :explanation "wait suspends the state until the event fires or the deadline elapses." :meta "after unconditionally advances; escalate raises. wait is the correct choice for EVENT-OR-TIMEOUT.") (:eng "Operator log: 'wait user-input deadline=5s'." :math "Wait until first-of event or deadline." :cs "Blocking wait with timeout."))
  :row-3-dimension ((:setup "event-or-timeout" :rungs ((:domain "motoi cart" :code "(wait 'ev 5)") (:domain "select syscall" :code ";; wait for fd ready or timeout:\n;; select(fds, timeout)") (:domain "race between deadline and event" :code ";; first(event, timeout)\n(define (race e t) (list 'first e t))")) :explanation "Each rung waits for the earlier of an event or a deadline." :meta "'Event-or-timeout' is the shape.") (:eng "Timeouts avoid hang-forever bugs." :math "Minimum of two completion times." :cs "Race primitive."))
  :row-4-proof ((:claim "wait unblocks on either event fire or deadline expiry, whichever is first." :program "(wait 'ev 5)\n(display 'unblocked)" :invariant "∀ event, deadline. unblocks at min(event-time, deadline)" :meta "First-completion. See book-of-computing ch08 (select).") (:eng "Bounded blocking = safe." :math "Min-time semantics." :cs "Race primitive."))
  :row-5-emergence ((:base "wait blocks on event or deadline." :composition "(define (with-timeout t f) (wait 'done t) (f))" :emergent "timeout wrapper: wait + f = a bounded operation." :meta "Same family as async race combinators. See book-of-composition ch09 (races).") (:eng "Bounded blocking pattern." :math "Bounded operation." :cs "Race wrapper."))
)

(verb
  :name "with-seed"
  :library "core"
  :kind "pure"
  :signature "(with-seed n) -> clause"
  :summary "Wrap a random-number generator with a fixed seed for reproducible sequences."
  :explanation "Randomness in Motoi (e.g., `random`, `random-pick`) is seeded by the frame and input state by default, making playback non-deterministic for replay or test. `with-seed` takes a numeric seed and returns a clause (a thunk or lambda) that, when invoked, runs a deterministic RNG branch. This is a pure function: it does not mutate world state, only sets up the seeded generator for later use. Use it when you need identical random outcomes every time (procedural generation, test fixtures, replay validation)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define seeded-roll (with-seed 42))\n(seeded-roll (random 100))" :note "Every call to `seeded-roll` will return the same random number.")
    (:dialect "motoi" :tier "intermediate" :code "(define (spawn-enemies n seed)\n  (let ((gen (with-seed seed)))\n    (gen (map (lambda (i) (list i (random 800))) (range 0 n)))))" :note "Generate n enemy positions deterministically; identical seed → identical layout every time.")
    (:dialect "motoi" :tier "expert" :code "(define (test-procedural-level seed)\n  (let ((layout ((with-seed seed) (generate-level-tiles 10 10))))\n    (and (equal? layout (expected-layout)) #t)))" :note "Use seeded generation in a test to verify the level generator is stable across runs.")
    (:dialect "motoi" :tier "novice" :code "(with-seed 42\n  (display (random-int 10)))" :note "Freeze the random generator to seed 42 so you get the same number every time.")
    (:dialect "motoi" :tier "intermediate" :code "(with-seed 7\n  (list (random-int 100) (random-int 100) (random-int 100)))" :note "Deterministic three-number sequence. Good for reproducible tests.")
  )
  :caveats ("The seed must be numeric (integer or float); non-numeric seeds will error." "The returned clause is a function; you must call it to activate the seeded RNG." "Nesting or chaining multiple `with-seed` calls may have undefined behavior—use one seed per scope." "Seed scope is thread-local or frame-local; cannot be shared across parallel computations.")
  :drawbacks ("Adds a small closure overhead per use; not suitable for tight inner loops (use `random-range` directly if seeding is not needed)." "Once seeded, the sequence is fixed; no way to 'reshuffle' mid-sequence without re-seeding." "If the RNG algorithm changes in a new Motoi version, old seeds may produce different sequences (breaking replay).")
  :usecases ("Procedural level/world generation with fixed layout (e.g., seed 1 always builds the same dungeon)." "Test fixtures: ensure random behavior is reproducible during unit tests." "Replay and spectate: seed the world's RNG from a match hash so spectators see the same generation." "Debugging: deterministic RNG makes random bugs easier to hunt.")
  :related ("random" "random-int" "random-pick" "random-range")
  :learn (:concept "Deterministic randomness via seeding—the bridge between chaos and reproducibility." :prerequisites ("random" "random-pick") :progression "big-bang (to run a full seeded game loop); world/snapshot (to record and replay exact world states)")
  :row-2-audit ((:problem "A procedural level must be reproducible across runs given the same seed." :program "(with-seed 42\n  (lambda ()\n    (display (random-int 100))\n    (display (random-int 100))))" :explanation "with-seed pins the RNG to seed 42 for the duration of the thunk." :meta "random draws from the current seed; with-seed CHANGES the seed. with-seed is the correct choice for reproducible RNG.") (:eng "Operator log: 'seeded 42'." :math "Deterministic sequence from seed." :cs "Scoped seed set + restore."))
  :row-3-dimension ((:setup "scoped-state-override" :rungs ((:domain "motoi rng" :code "(with-seed 42 f)") (:domain "git" :code ";; checkout a specific commit temporarily:\n;; git worktree add /tmp/w abc123") (:domain "dynamic-extent parameter" :code ";; parameterize a value for a scope\n(define (with-param p v f) (list p v f))")) :explanation "Each rung overrides a parameter for a bounded scope, then restores it." :meta "'Scoped override' is the shape.") (:eng "Scoped overrides are testable and safe." :math "Dynamic-extent binding." :cs "Parameterize pattern."))
  :row-4-proof ((:claim "Same seed and same thunk produces the same output." :program "(define a (with-seed 42 (lambda () (random-int 100))))\n(define b (with-seed 42 (lambda () (random-int 100))))\n(display (= a b))" :invariant "∀ seed s, thunk f. with-seed(s, f) is deterministic" :meta "Deterministic seeded RNG. See book-of-computing ch03 (determinism) and book-of-math ch07 (PRNG).") (:eng "Reproducible RNG = reproducible tests." :math "Deterministic sequence." :cs "Scoped seeded PRNG."))
  :row-5-emergence ((:base "with-seed pins RNG for a scope." :composition "(define (test-with-seeds seeds thunk)\n  (map (lambda (s) (with-seed s thunk)) seeds))" :emergent "property-based testing: multiple seeds + same thunk = coverage across the RNG." :meta "Same family as QuickCheck property tests. See book-of-composition ch11 (property testing).") (:eng "Property testing over many seeds." :math "Sample over seed space." :cs "Multi-seed testing pattern."))
)

(verb
  :name "with-spacing"
  :library "core"
  :kind "meta"
  :signature "*[verify]*"
  :summary "Configure spatial distribution of entities in a choreographed formation."
  :explanation "Motoi's formation system coordinates multiple entities moving together—a flock, a dance line, or a convoy. `with-spacing` is a meta-level function that sets up or parameterizes the inter-entity distance and rhythm within a formation. It works in tandem with `walk-together` and `sub-position-per-beat` to produce synchronized, spatially coherent motion. Think of it as: \"these entities move as one, and here's how far apart they should stay.\""
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define spaced-line (with-spacing 50))" :note "Create a formation template with 50-unit spacing; to be used with `walk-together`.")
    (:dialect "motoi" :tier "intermediate" :code "(define dance-formation\n  (with-spacing 32))" :note "Set tight 32-unit spacing for a dance troupe; closer = tighter synchrony and collision risk.")
    (:dialect "motoi" :tier "expert" :code "(define (convoy-squad count spacing-fn)\n  (let ((template (with-spacing (spacing-fn count))))\n    (walk-together template (range 0 count))))" :note "Generate a convoy where spacing varies by squad size; template applied to all entities.")
    (:dialect "motoi" :tier "novice" :code "(with-spacing 10\n  (display \"padded\"))" :note "Pad everything inside the block by 10 units.")
    (:dialect "motoi" :tier "intermediate" :code "(with-spacing 20\n  (display \"one\")\n  (display \"two\"))" :note "The spacing applies to every draw inside the body. Two labels appear 20 units apart.")
  )
  :caveats ("Spacing is static once set; no dynamic re-spacing mid-formation." "Must be paired with `walk-together` to have visible effect; used alone does nothing." "Spacing value is in world units; too large breaks visual coherence, too small risks collision overlaps." "Spacing does not account for entity size (collision radius); caller must add margin manually.")
  :drawbacks ("Requires knowledge of formation mechanics to use effectively." "No runtime validation; invalid spacing values (negative, infinite) may produce undefined behavior." "Orthogonal to `sub-position-per-beat`; both needed together for full choreography (verbose setup).")
  :usecases ("Choreography: dancers or sprites in a line, maintaining even distance." "Flocking: cohesion rule parameterization via desired inter-agent spacing." "Convoy or patrol: squads of NPCs marching in formation with predictable gaps." "Procedural animation: generate crowds or teams with uniform spacing.")
  :related ("walk-together" "sub-position-per-beat" "part/step" "motion/cadence")
  :learn (:concept "Formation spacing—the distance parameter that binds entities into synchronized groups." :prerequisites ("walk-together") :progression "walk-together (to apply spacing to actual entity motion); motion/cadence (for beat-driven timing)")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A choreographed formation needs entities spaced 10 world units apart." :program "(with-spacing 10\n  (in-formation 'row (list 'a 'b 'c)))" :explanation "with-spacing configures inter-entity spacing for the enclosed formation call." :meta "in-formation places without spacing knob; sub-position-per-beat is beat-based. with-spacing is the correct choice for SPACING configuration.") (:eng "Operator log: 'spacing=10'." :math "Scalar distance." :cs "Scoped configuration wrapper."))
  :row-3-dimension ((:setup "scoped-configuration" :rungs ((:domain "motoi choreo" :code "(with-spacing 10 ...)") (:domain "css" :code ";; gap: 10px on flex layout") (:domain "metric parameter" :code ";; distance between elements\n(define spacing 10)")) :explanation "Each rung parameterises spacing for a scoped operation." :meta "'Spacing knob' is the shape.") (:eng "Named spacing beats hardcoded numbers." :math "Scalar metric." :cs "Scoped parameter."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "with-spacing scopes the spacing setting to its body." :program "(with-spacing 10 (in-formation 'row '(a b)))\n(display 'scoped-spacing)" :invariant "∀ n, body. spacing = n only within body" :meta "Scoped effect. See book-of-composition ch05 (scoped params).") (:eng "Scoped = no global-state bleed." :math "Dynamic extent." :cs "Parameterize pattern."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "with-spacing scopes spacing." :composition "(with-spacing 20 (in-formation 'row (entity/list)))" :emergent "spaced formation: with-spacing + in-formation = a formation with explicit gaps." :meta "Same family as CSS gap / flexbox. See book-of-composition ch12 (formations).") (:eng "Explicit spacing = readable layouts." :math "Uniform-gap arrangement." :cs "Scoped spatial config."))
)

(verb
  :name "escalate"
  :library "core"
  :kind "io"
  :signature "(escalate condition-name . args) -> raises"
  :summary "Bubble a named condition upward past the current handler; a generic control-flow primitive for early-exit, deferred handling, and structured error control."
  :explanation "`escalate` raises a named condition. Unlike `error`, whose message is a string and whose type is always 'error, escalate takes a SYMBOL as its first argument and uses it as the raised condition's type. Downstream handlers (installed via with-exception-handler or R7RS guard) match on the type via error-object-type. Any extra args are captured as irritants and surfaced via error-object-irritants. Composes with the full exception machinery: escalate raises, guard/with-exception-handler catches. Use it to distinguish 'expected' failure paths (timeout, resource-exhausted, user-cancelled) from unexpected 'error' errors, or to bubble a signal out of a deeply nested computation without threading state through every return."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(escalate 'timeout)" :note "Bubble a bare 'timeout condition upward. Any enclosing guard or with-exception-handler receives it and can dispatch on the type 'timeout.")
    (:dialect "motoi" :tier "intermediate" :code "(define (fetch-or-give-up n)\n  (if (> n 5)\n      (escalate 'retry-exhausted n)\n      (list 'ok n)))\n(with-exception-handler\n  (lambda (e) (list 'caught (error-object-type e) (error-object-irritants e)))\n  (lambda () (fetch-or-give-up 6)))" :note "escalate carries structured detail (the exhausted count) as irritants; the handler can log or branch on the type and detail.")
    (:dialect "motoi" :tier "expert" :code "(define (run-plan steps)\n  (let loop ((rest steps) (done '()))\n    (cond ((null? rest) (reverse done))\n          (else (let ((step (car rest)))\n                  (guard (e ((eq? (error-object-type e) 'skip)\n                             (loop (cdr rest) done))\n                            ((eq? (error-object-type e) 'abort)\n                             (escalate 'plan-aborted (reverse done))))\n                    (loop (cdr rest) (cons (step) done))))))))\n(run-plan (list\n  (lambda () 'first)\n  (lambda () (escalate 'skip))\n  (lambda () 'third)))" :note "A plan runner that treats 'skip as continue, 'abort as re-escalate with accumulated context. escalate names each control path so the handler can dispatch cleanly without a shared boolean flag.")
  )
  :caveats ("The condition name should be a symbol (a Sym); strings work but lose the eq? semantics that make handler dispatch idiomatic." "escalate is NON-CONTINUABLE — control does not return to the escalate site. If you need a continuable raise, use raise-continuable." "Args after the condition name become irritants; they are preserved verbatim, so passing a large object here holds a reference to it until the handler runs." "The raised error's message is 'escalate: <name>' — handlers that read error-object-message get that string; the structured detail lives in the irritants list.")
  :drawbacks ("No stack trace beyond what JS engines already provide; escalate does not capture caller context." "Handlers must be installed BEFORE the call site is reached; escalate does not implicitly install a handler." "The condition name is dispatched by eq? on the type; typos in either the escalate site or the handler cause silent mis-matches (the error object surfaces but no handler branch fires).")
  :usecases ("Structured early-exit from a deep recursion when a pre-condition fails." "Distinguishing expected-failure control paths (timeout, cancelled, retry-exhausted) from bugs, so handlers can branch cleanly." "Composing with guard to build a plan/step runner where each step can 'skip, 'abort, or return normally." "Signalling from a cart worker to its driver that a state transition is required.")
  :related ("error" "raise" "raise-continuable" "with-exception-handler" "guard" "error-object-type" "error-object-irritants")
  :learn (:concept "Named conditions for control flow: raising a value the handler can dispatch on, without wrapping every function in a monadic Result." :prerequisites ("with-exception-handler" "quote" "symbols") :progression "Learn escalate as the 'named raise'; then pair it with guard for typed handlers; then compose with a plan-runner to see how multiple named conditions carve up control flow cleanly.")
  :row-2-audit ((:problem "A retry loop has exhausted its budget; the operator wants to bubble a typed condition upward for structured handling." :program "(define (fetch n)\n  (if (> n 5)\n      (escalate 'retry-exhausted n)\n      (list 'ok n)))\n(with-exception-handler\n  (lambda (e) (list 'caught (error-object-type e)))\n  (lambda () (fetch 6)))" :explanation "escalate raises a symbol-typed condition with irritants; the handler dispatches by type." :meta "error is generic; raise doesn't imply structure. escalate is the correct choice for STRUCTURED, TYPED raises.") (:eng "Operator log: 'escalate retry-exhausted 6'." :math "Named exception raise." :cs "Non-continuable typed raise."))
  :row-3-dimension ((:setup "typed-condition-raise" :rungs ((:domain "motoi exceptions" :code "(escalate 'timeout)") (:domain "OS signals" :code ";; send a typed signal to the process:\n;; kill -USR1 $pid") (:domain "sum-type constructor" :code ";; raise a variant\n(define (raise-tag t . vs) (cons t vs))")) :explanation "Each rung raises a NAMED condition that downstream can dispatch on." :meta "'Named raise' is the shape.") (:eng "Typed conditions beat generic errors for handler dispatch." :math "Element of a sum type." :cs "Tagged-union constructor for exceptions."))
  :row-4-proof ((:claim "escalate is non-continuable: control does not return to the escalate site." :program "(define reached? #f)\n(with-exception-handler\n  (lambda (e) 'handled)\n  (lambda ()\n    (escalate 'x)\n    (set! reached? #t)))\n(display reached?)  ;; expect #f" :invariant "∀ call. code after escalate is not executed" :meta "Non-continuable raise. Falsified only if a continuable-raise is used. See book-of-computing ch11 (exceptions).") (:eng "Non-continuable = predictable control flow." :math "Control-flow non-return." :cs "Non-continuable exception primitive."))
  :row-5-emergence ((:base "escalate raises a typed condition." :composition "(define (plan steps)\n  (guard (e ((eq? (error-object-type e) 'skip) 'ok))\n    (for-each (lambda (s) (or (s) (escalate 'skip))) steps)))" :emergent "named-condition control flow: escalate + guard = a plan-runner that recognizes named skip/abort conditions." :meta "Same family as Common Lisp restart-case or Rust's typed error enums. See book-of-composition ch18 (control flow) and book-of-code ch12 (exceptions).") (:eng "Named conditions = readable control flow." :math "Structured control transfer." :cs "Typed dispatcher."))
