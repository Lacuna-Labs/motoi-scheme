;;; 50-phys.slat — Motoi Scheme Reference · Chapter 50 · library phys
;;;
;;; 19 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library phys — 19 verbs.")

(chapter :number "50" :library "phys" :verb-count 19 :training-eligible #t)

;; ═══ 19 verbs in library phys ═══

(verb
  :name "phys/L-free"
  :library "phys"
  :kind "meta"
  :signature "(phys/L-free m) -> procedure"
  :summary "Returns a Lagrangian procedure for a free particle (no forces). The Lagrangian is L(q, qdot) = ½m·qdot², and the procedure takes position and velocity, returning kinetic energy."
  :explanation "In classical mechanics, the Lagrangian L = T − V (kinetic minus potential energy) encodes the dynamics: motion extremizes the action ∫L dt (Hamilton's principle). For a free particle (no potential), L = T = ½m·qdot². The returned procedure is a closure that captures mass m and can be called as (L q qdot) to evaluate ½m·qdot² at any configuration. This is the foundation for computing Euler–Lagrange equations and action integrals."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((L (phys/L-free 2.0)))\n  (L 3.0))" :note "Mass 2 kg, velocity 3 m/s → kinetic energy = ½·2·3² = 9 J.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((L-free (phys/L-free 1.0))\n      (L-harmonic (phys/L-harmonic 1.0 2.0)))\n  (list (L-free 1.0) (L-harmonic 0.5 1.0)))" :note "Compare free particle L=½·qdot² with harmonic oscillator L=½·qdot² − ½k·q².")
    (:dialect "motoi" :tier "expert" :code "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(define (action-free m path-samples)\n  (let ((L (phys/L-free m))\n        (dt 0.01))\n    (fold-left (lambda (acc qdot) (+ acc (* (L qdot) dt)))\n               0.0\n               path-samples)))\n(action-free 1.0 (list 0 1 2 1 0))" :note "Numerically integrate action S = ∫L dt along a discretized path using the free-particle Lagrangian.")
  )
  :caveats ("Returns a closure; the closure captures m, so modifying m after the call has no effect." "The signature (L qdot) expects a single velocity argument; position is ignored (no potential)." "Does not handle multi-particle systems; each particle needs its own Lagrangian." "Relativistic effects (m → ∞ as v → c) are not included; use classical mechanics only.")
  :drawbacks ("Free-particle Lagrangian is trivial; real problems usually include a potential (use phys/L-harmonic or define custom)." "No automatic differentiation of L; use phys/lagrange-residual to check the Euler–Lagrange equations." "Does not include constraints (Lagrange multipliers) or non-conservative forces." "For time-dependent L(t), define a new closure by hand.")
  :usecases ("Test case for Euler–Lagrange solver: confirm that free particle has zero residual." "Baseline comparison: measure how much potential energy changes the solution compared to free particle." "Action integral: phys/lagrangian-action uses this to compute S = ∫L dt along a path." "Pedagogical: understand Lagrangian mechanics with the simplest possible example.")
  :related ("phys/L-harmonic" "phys/lagrangian-action" "phys/lagrange-residual" "phys/kinetic-energy" "phys/quantity")
  :learn (:concept "The Lagrangian L = T − V as a functional that generates equations of motion via Hamilton's principle; free particle is the minimal case." :prerequisites ("calc/derivative" "phys/kinetic-energy") :progression "Learn phys/L-harmonic next to add a potential term. Then explore phys/lagrangian-action and phys/lagrange-residual to verify solutions.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator has a physics student's homework: 'compute the action for a free 1kg particle moving at 3 m/s over 2 seconds.' They need L first, then integrate."
                 :program "(define L (phys/L-free 1.0))\n(define (action-over-time qdot duration)\n  (* (L qdot) duration))\n(action-over-time 3.0 2.0)"
                 :explanation "Line 1 builds the free-particle Lagrangian for mass 1. Line 2 defines a short helper multiplying L by duration (since qdot is constant, L is constant so ∫L dt = L·duration). Line 3 computes: L(3.0) = ½·1·9 = 4.5 J; times 2s = 9 J·s. The audit is one Lagrangian factory call and a scalar multiplication."
                 :meta "Reaching for a raw arithmetic expression (½·m·v²·t) would work but hardcodes the physics. phys/L-free is the honest answer because it packages the free-particle Lagrangian as a reusable procedure, and later potential terms slot in by wrapping.")
                (:eng "The physics is named; adding a potential means a new Lagrangian factory, not editing arithmetic." :math "L(qdot) = ½m·qdot²; free particle." :cs "Closure captures m; O(1) per call."))
  :row-3-dimension ((:setup "Kinetic-energy as a Lagrangian; the zero-potential case."
                     :rungs ((:domain "phys" :code "((phys/L-free 1.0) 3.0)")
                             (:domain "cash-flow value with no discount (metaphor)" :code "(define (free-flow-value amount) (* 0.5 amount amount))\n(free-flow-value 3.0)")
                             (:domain "quadratic form Q(v) = ½mv²" :code "(define (quadratic m v) (* 0.5 m v v))\n(quadratic 1.0 3.0)"))
                     :explanation "In phys, L-free returns ½mv² given m. In the cash-flow metaphor (poor pun aside), a free flow's value scales quadratically with amount — same shape. In the math rung, the quadratic form ½mv² is the archetype. All three encode kinetic-like energy."
                     :meta "The shape transfers because ½mv² is a positive-definite quadratic form, ubiquitous wherever an energy-like quantity depends on a rate of change.")
                    (:eng "One shape covers Lagrangian mechanics, quadratic-cost optimization, and mathematical energy." :math "Positive-definite quadratic form on R." :cs "Closure over m; pure evaluation."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "For the free-particle Lagrangian, energy is conserved: L(qdot1) = L(qdot2) implies |qdot1| = |qdot2|. This is the energy-conservation-plus-symmetry invariant."
                 :program "(define L (phys/L-free 2.0))\n(define (approx a b) (< (abs (- a b)) 0.0001))\n(and (approx (L 3.0) (L -3.0))\n     (approx (L 5.0) (L -5.0))\n     (> (L 5.0) (L 3.0)))"
                 :invariant "L(qdot) = L(-qdot) ∧ L is strictly increasing in |qdot|"
                 :meta "A Lagrangian that failed velocity-symmetry would break time-reversal invariance. Falsification is any qdot where L(qdot) ≠ L(-qdot). CS pattern: 'even quadratic'. Book-of-math ch 12 covers Lagrangians; book-of-ml ch 7 covers quadratic forms.")
                (:eng "Time-reversal symmetry is the mathematical statement of energy conservation for a free particle." :math "L is even; L' is odd; L' vanishes at origin." :cs "Property test on pairs of opposite velocities."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/L-free returns the kinetic-only Lagrangian for a free particle."
                     :composition "(define (compare-actions m qdot1 qdot2 duration)\n  (let ((L (phys/L-free m)))\n    (list (* (L qdot1) duration)\n          (* (L qdot2) duration))))\n(compare-actions 1.0 3.0 5.0 2.0)"
                     :emergent "An action comparator — chaining phys/L-free with an integration helper produces an action-comparison tool, which the Lagrangian alone does not provide."
                     :meta "This is the same family as a variational-mechanics teaching tool (Sussman & Wisdom SICM). Cross-reference book-of-math ch 12 (Lagrangians); book-of-motion ch 22 (energy). Familiar analog: comparing action integrals in a mechanics class.")
                    (:eng "One Lagrangian + integration = a teaching tool." :math "Trivial integral of a constant over a duration." :cs "O(1) per action computation.")))

(verb
  :name "phys/L-harmonic"
  :library "phys"
  :kind "meta"
  :signature "(phys/L-harmonic m k) -> procedure"
  :summary "Returns a Lagrangian procedure for a harmonic oscillator (e.g. mass on a spring). The Lagrangian is L(q, qdot) = ½m·qdot² − ½k·q², and the procedure computes this at any configuration."
  :explanation "The harmonic oscillator is the canonical example of a conservative system with potential energy V(q) = ½k·q². Its Lagrangian L = T − V = ½m·qdot² − ½k·q² leads to the familiar equation m·qdotdot = −k·q (Hooke's law). The returned procedure captures mass m and spring constant k, and can be called as (L q qdot) to evaluate the Lagrangian. This is essential for verifying solutions via the Euler–Lagrange equation and for computing the action integral."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((L (phys/L-harmonic 1.0 2.0)))\n  (L 0.5 1.0))" :note "Mass 1 kg, spring k=2 N/m; at q=0.5 m, qdot=1 m/s → L = ½·1·1² − ½·2·0.5² = 0.5 − 0.25 = 0.25 J.")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((L (phys/L-harmonic 2.0 8.0))\n       (energy (lambda (q qdot) (- (L q qdot) (L q qdot)))))\n  (list 'at-origin (L 0 1) 'at-amplitude (L 1 0)))" :note "At origin with velocity 1: L=½·2·1²=1. At amplitude 1 with zero velocity: L=−4. Total energy ≈ 1 − 4 = −3 (sign is Lagrangian, not energy).")
    (:dialect "motoi" :tier "expert" :code "(define (verify-harmonic-motion m k amp freq)\n  (let ((L (phys/L-harmonic m k))\n        (ω (sqrt (/ k m)))n        (residual-fn (phys/lagrange-residual L)))\n    (let ((t 0.5))\n      (let ((q (* amp (cos (* ω t))))\n            (qdot (* (- amp ω) (sin (* ω t)))))\n        (list (L q qdot) (residual-fn q qdot))))))\n(verify-harmonic-motion 1.0 1.0 0.1 1.0)" :note "Construct harmonic motion q(t) = A·cos(ωt), verify it satisfies Euler–Lagrange with near-zero residual.")
  )
  :caveats ("The closure captures m and k at definition time; changing them later has no effect." "The potential energy term −½k·q² assumes a quadratic restoring force; anharmonic potentials require a custom Lagrangian." "q must be a scalar (1D oscillator); higher dimensions require vector arguments and multiple Lagrangians." "Damping (energy loss) is not included; this is a conservative system (energy conserved)." "k must be positive; negative k (repulsive spring) will produce unstable dynamics.")
  :drawbacks ("Not suitable for large-amplitude oscillations in real systems (anharmonic effects dominate)." "No built-in solver for the resulting differential equation m·qdotdot + k·q = 0; use curve/ verbs or numerical integration." "Does not include driving forces or external potential modifications." "For time-dependent systems or coupling between oscillators, manual extension needed.")
  :usecases ("Verify harmonic-oscillator solutions: confirm q(t) = A·cos(ωt) satisfies the Euler–Lagrange equation." "Action integral: phys/lagrangian-action computes S = ∫L dt for a given trajectory." "Energy balance: compare T − V at different points in the cycle." "Pedagogical: the harmonic oscillator is the canonical example of Lagrangian mechanics.")
  :related ("phys/L-free" "phys/lagrangian-action" "phys/lagrange-residual" "phys/kinetic-energy" "phys/rlc-damping")
  :learn (:concept "Adding potential energy V(q) to the Lagrangian L = T − V; the Euler–Lagrange equation recovers F = ma with the restoring force F = −∇V." :prerequisites ("phys/L-free" "calc/second-derivative" "phys/kinetic-energy") :progression "After mastering L-harmonic, explore phys/lagrangian-action to compute action integrals, and phys/lagrange-residual to verify solutions numerically.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The student needs to model a mass-on-a-spring: mass 1 kg, spring constant 4 N/m. They want the Lagrangian to evaluate at various (q, qdot) points to check total energy stays constant."
                 :program "(define L (phys/L-harmonic 1.0 4.0))\n(define (energy-check q qdot)\n  (+ (* 0.5 1 qdot qdot) (* 0.5 4 q q)))\n(list (L 0.5 1.0) (energy-check 0.5 1.0))"
                 :explanation "Line 1 builds the harmonic Lagrangian. Line 2 defines total energy T+V (kinetic plus potential) — not L, which is T−V. Line 3 samples both. L returns 0.5−0.5 = 0; total energy returns 0.5+0.5 = 1. The audit trail lets the student see that L is a functional (not energy) but that total energy is a separate quantity."
                 :meta "Reaching for a hand-written L expression would work but reinvent the wheel; phys/L-harmonic is the honest answer because it packages m and k into a reusable procedure with clear semantics.")
                (:eng "Named parameters (m, k) instead of magic numbers." :math "L = ½m·qdot² − ½k·q²; energy T+V is conserved along trajectories." :cs "Closure over m and k; O(1) per evaluation."))
  :row-3-dimension ((:setup "Kinetic minus potential energy for a quadratic potential."
                     :rungs ((:domain "phys" :code "((phys/L-harmonic 1.0 4.0) 0.5 1.0)")
                             (:domain "damped-spring mechanical model (metaphor)" :code "(define (spring-force k x) (* -1 k x))\n(spring-force 4 0.5)")
                             (:domain "difference of two quadratic forms" :code "(define (q1-minus-q2 a b x y) (- (* a x x) (* b y y)))\n(q1-minus-q2 0.5 0.5 1.0 0.5)"))
                     :explanation "In phys, L-harmonic is T−V. In mechanical modeling, spring force is −k·x (the gradient of ½k·x²). In the math rung, the difference of two quadratics is the same algebraic form. All three encode a harmonic-oscillator relationship."
                     :meta "The shape transfers because the harmonic oscillator is the canonical linear system; its Lagrangian is the difference of two quadratics, which appears wherever competing quadratic forms exist.")
                    (:eng "One shape covers Lagrangian mechanics, mechanical modeling, and quadratic forms." :math "L = ½m·qdot² − ½k·q²; equations of motion are linear ODE." :cs "Closure with two captured parameters."))
  :row-4-proof ((:claim "For the harmonic Lagrangian, the sum ½m·qdot² + ½k·q² (total energy) is conserved along solutions of the Euler-Lagrange equations. This is the energy-conservation invariant."
                 :program "(define (total-energy m k q qdot) (+ (* 0.5 m qdot qdot) (* 0.5 k q q)))\n(define (approx a b) (< (abs (- a b)) 0.01))\n(define omega (sqrt (/ 4 1)))\n(define (q t) (cos (* omega t)))\n(define (qdot t) (* -1 omega (sin (* omega t))))\n(and (approx (total-energy 1 4 (q 0) (qdot 0)) 2.0)\n     (approx (total-energy 1 4 (q 0.5) (qdot 0.5)) 2.0)\n     (approx (total-energy 1 4 (q 1.5) (qdot 1.5)) 2.0))"
                 :invariant "d/dt(T + V) = 0 along solutions"
                 :meta "A Lagrangian that failed energy conservation would predict physical impossibility. Falsification is a solution trajectory where T+V drifts. CS pattern: 'conservation-law-encoding Lagrangian'. Book-of-math ch 12; book-of-motion ch 22.")
                (:eng "Conservation is the essential test of a physics simulator." :math "The Lagrangian has no explicit time dependence; Noether's theorem gives conservation of T+V." :cs "Property test on multiple time samples."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/L-harmonic returns the harmonic-oscillator Lagrangian."
                     :composition "(define (compare-oscillator-actions m k qdot-0 q-0 duration)\n  (let ((L (phys/L-harmonic m k)))\n    (let loop ((t 0) (acc 0.0))\n      (if (>= t duration) acc\n          (loop (+ t 0.01) (+ acc (* (L q-0 qdot-0) 0.01)))))))\n(compare-oscillator-actions 1 4 1 0.5 1.0)"
                     :emergent "A numerical action integrator — chaining phys/L-harmonic with a Riemann-sum loop produces a full action-computation tool, which the Lagrangian alone does not provide."
                     :meta "This is the same family as the numerical action integrators in SICM (Sussman & Wisdom). Cross-reference book-of-math ch 12; book-of-motion ch 22. Familiar analog: a variational-mechanics teaching notebook.")
                    (:eng "One Lagrangian + integration = a research tool." :math "Riemann sum approximates ∫L dt to O(dt) accuracy." :cs "O(duration/dt) time; trivially parallelizable.")))

(verb
  :name "phys/constant"
  :library "phys"
  :kind "meta"
  :signature "(phys/constant symbol) -> number"
  :summary "Returns the CODATA-2018 value of a physical constant (e.g. \\='G for gravitational constant, \\='c for speed of light, \\='h for Planck's constant) in SI units."
  :explanation "Physical constants are fundamental quantities whose values are fixed by nature (or, in the case of recently defined constants, by international convention). The CODATA-2018 dataset provides high-precision values and associated uncertainties. This verb is a lookup table: given a symbol like 'c, 'G, 'h, 'k-B (Boltzmann), 'epsilon-0 (permittivity of free space), it returns the SI value as a number. Useful for constructing quantified expressions and solving physics problems without hard-coding magic numbers."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/constant 'c)" :note "Speed of light in vacuum: 299792458 m/s (exact in SI 2019).")
    (:dialect "motoi" :tier "intermediate" :code "(let ((G (phys/constant 'G))\n      (m1 1000000000000000000000000.0)\n      (m2 1000000000000000000000000.0)\n      (r 1000000.0))\n  (/ (* G m1 m2) (* r r)))" :note "Compute gravitational force F = G·m₁·m₂/r² between two 10²⁴ kg masses 1 Mm apart.")
    (:dialect "motoi" :tier "expert" :code "(define (compton-wavelength mass)\n  (let ((h (phys/constant 'h))\n        (c (phys/constant 'c))\n        (m-e (phys/constant 'm-e)))\n    (/ h (* mass c))))\n(compton-wavelength (phys/constant 'm-e))" :note "Compute Compton wavelength λ_C = h/(m·c); electron's is ≈ 2.4e-12 m.")
  )
  :caveats ("Values are CODATA-2018, not the most recent CODATA-2021; check official values if extreme precision is needed." "SI units only; conversions to CGS, Gaussian, or atomic units must be done by hand." "Some constants (e.g., 'h, 'k-B, 'N-A) are defined exactly as of 2019 SI; others have residual uncertainty from measurement." "Symbol names follow a convention (e.g., 'epsilon-0, 'm-e, 'h-bar); typos result in lookup failure, not an error.")
  :drawbacks ("No uncertainty information returned; only the central value." "Cannot add new constants at runtime; the set is fixed at compile time." "No grouping by discipline (atomic, nuclear, quantum, etc.); use grep or external documentation to find a symbol." "For highly specialized constants (rare isotope masses, etc.), manual lookup required.")
  :usecases ("Dimensional analysis: compute the Rydberg energy (R∞ = m_e·e⁴ / (8·ε₀²·h²)) from first principles." "Unit conversions: scale by phys/constant 'c or phys/constant 'h to move between domains." "Particle physics: compute decay rates, cross-sections using α, m_e, etc." "Astronomical: scale gravitational or radiation calculations with 'G, 'sigma (Stefan–Boltzmann).")
  :related ("phys/quantity" "phys/q*" "phys/q/" "phys/dimension" "const/pi" "const/e")
  :learn (:concept "Physical constants as immutable lookup values in SI units; foundation for dimensional analysis and quantified computation." :prerequisites ("phys/quantity" "phys/dimension") :progression "After learning phys/constant, use it with phys/q* and phys/q/ to build dimensioned quantities. Then explore phys/kinetic-energy and phys/gravitational-force for real-world applications.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator is computing the Compton wavelength of an electron. They need Planck's constant h and the speed of light c — official CODATA values, not typed literals with drift."
                 :program "(define h (phys/constant 'h))\n(define c (phys/constant 'c))\n(define m-e (phys/constant 'm-e))\n(/ h (* m-e c))"
                 :explanation "Lines 1-3 fetch h, c, and electron mass from the CODATA table. Line 4 computes the Compton wavelength λ = h/(m·c) ≈ 2.4e-12 m. The audit trail is three lookup calls; no magic numbers appear in the formula. If CODATA-2021 refines a value, the change propagates automatically."
                 :meta "Reaching for hardcoded literals is fragile — a decimal drift or transcription error is invisible until QA. phys/constant is the honest answer because the source of truth lives in one table that the whole codebase shares.")
                (:eng "Named constants are debuggable and refactorable." :math "Physical constants are exact (post-2019 SI redefinition) for h, c, k_B, N_A; others have residual uncertainty." :cs "Symbol → number lookup; O(1)."))
  :row-3-dimension ((:setup "Keyword lookup into an authoritative table of numeric constants."
                     :rungs ((:domain "phys" :code "(phys/constant 'c)")
                             (:domain "environment-variable lookup (metaphor)" :code "(define env '((PATH . \"/usr/bin\") (HOME . \"/home/alice\")))\n(cdr (assq 'PATH env))")
                             (:domain "constant function on symbols" :code "(define (const-map syms vals sym)\n  (cond ((null? syms) 'undefined)\n        ((eq? (car syms) sym) (car vals))\n        (else (const-map (cdr syms) (cdr vals) sym))))\n(const-map '(a b c) '(1 2 3) 'b)"))
                     :explanation "In phys, symbol maps to CODATA value. In shell env vars, symbol maps to string — same lookup shape. In the math rung, a symbolic map returns a constant. All three are symbol → value lookups."
                     :meta "The shape transfers because keyword lookup is universal; whether the store is CODATA, an env-var table, or an abstract map, the shape is identical.")
                    (:eng "One shape covers physics, shell env, and general symbolic lookup." :math "Total function on registered symbols; partial elsewhere." :cs "O(1) hash lookup or O(k) list scan."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "For any registered symbol s, (phys/constant s) is deterministic: two calls at any time return the same value. This is the constant-immutability invariant."
                 :program "(define (approx a b) (< (abs (- a b)) 0.0000001))\n(define (check-immutable s)\n  (approx (phys/constant s) (phys/constant s)))\n(and (check-immutable 'c) (check-immutable 'h) (check-immutable 'G))"
                 :invariant "∀ registered s . phys/constant(s) = phys/constant(s) across all time"
                 :meta "A constant that varied would break every derivation that uses it. Falsification is any two reads that disagree. CS pattern: 'immutable-value lookup'. Book-of-code ch 3.")
                (:eng "Immutability is what lets caches be shared across processes safely." :math "Referential transparency; the value has no time dependence." :cs "Table is read-only; O(1) per read."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/constant returns a CODATA-2018 physical constant."
                     :composition "(define (rydberg-energy)\n  (let ((m-e (phys/constant 'm-e))\n        (e (phys/constant 'e))\n        (eps-0 (phys/constant 'epsilon-0))\n        (h (phys/constant 'h)))\n    (/ (* m-e e e e e) (* 8 eps-0 eps-0 h h))))\n(rydberg-energy)"
                     :emergent "A derived physical constant — chaining phys/constant with an algebraic expression produces the Rydberg energy, which no single constant provides."
                     :meta "This is the same family as Wolfram Alpha's derived constants, or a physics-formula reference. Cross-reference book-of-math ch 14. Familiar analog: a physical-chemistry reference like the CRC Handbook.")
                    (:eng "Multiple lookups + one formula = a derived constant, computable in one line." :math "Compositional constant algebra." :cs "O(k) lookups for k source constants; formula is O(1).")))

(verb
  :name "phys/dimension"
  :library "phys"
  :kind "meta"
  :signature "(phys/dimension quantity) -> a-list"
  :summary "Extract the dimension a-list from a physical quantity."
  :explanation "A quantity in Motoi Scheme pairs a numeric value with a dimension record (stored as an a-list). This verb extracts just the dimension part—the symbolic record of which units (length, time, mass, etc.) the quantity carries. Useful for reasoning about unit compatibility and for debugging dimensional analysis. The result is an association list mapping dimension symbols to their exponents."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/dimension '(value . ((length . 1) (time . -2))))" :note "Returns the dimension a-list: ((length . 1) (time . -2)), representing acceleration (L/T²).")
    (:dialect "motoi" :tier "intermediate" :code "(let ((q1 '(10 . ((length . 1)))))\n  (phys/dimension q1))" :note "Extract dimensions from a quantity representing 10 meters. Shows that dimensions travel with their values.")
    (:dialect "motoi" :tier "expert" :code "(define (check-same-dimensions q1 q2)\n  (equal? (phys/dimension q1) (phys/dimension q2)))\n(check-same-dimensions '(5 . ((length . 1))) '(12 . ((length . 1))))" :note "Use phys/dimension in a predicate to enforce dimensional consistency before operations.")
  )
  :caveats ("Returns only the dimension record; does not validate that the quantity is well-formed." "Used internally by phys/same-dimension? and other dimensional-analysis verbs." "The a-list structure is an implementation detail; treat as opaque unless working with custom dimensions.")
  :drawbacks ("Does not simplify or normalize dimensions (e.g., will not reduce (length . 2) (length . -1) to (length . 1))." "Provides no information about the numeric value itself.")
  :usecases ("Debugging physical equations before computation." "Implementing custom unit-checking predicates." "Teaching dimensional analysis by inspecting quantity structure.")
  :related ("phys/same-dimension?" "phys/quantity->tag" "phys/q*" "phys/q+" "phys/q/")
  :learn (:concept "Quantities in physics carry both magnitude and dimension; this verb reveals dimension alone." :prerequisites ("Understanding of a-lists (cons pairs as key-value records).") :progression "After mastering phys/dimension, learn phys/same-dimension? to compare dimensions, then phys/q* and phys/q+ to see how dimensions transform during arithmetic.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator has a computed quantity and needs to verify it's a velocity (length/time), not a distance or acceleration, before feeding it into a further calculation."
                 :program "(define computed '(20 . ((length . 1) (time . -1))))\n(define dims (phys/dimension computed))\n(equal? dims '((length . 1) (time . -1)))"
                 :explanation "Line 1 defines a quantity. Line 2 extracts its dimension a-list. Line 3 tests if it matches the velocity dimension. If mismatched, the operator catches the error before propagating. The audit trail is one dimension extraction; runtime type-check for physics."
                 :meta "Reaching for cdr on the quantity would work but couples the code to the internal representation. phys/dimension is the honest answer because it names the intent — extract dimension — and is stable across representation changes.")
                (:eng "Dimensional type-checking prevents propagating wrong-kind quantities." :math "Projection from Quantity to Dimension." :cs "O(1) extraction; pure."))
  :row-3-dimension ((:setup "Extracting the type signature of a compound value."
                     :rungs ((:domain "phys" :code "(phys/dimension '(20 . ((length . 1) (time . -1))))")
                             (:domain "SQL data type of a column (metaphor)" :code "(define (column-type row col)\n  (list 'type (cdr (assq col row))))\n(column-type '((id . 5) (name . \"alice\")) 'name)")
                             (:domain "second projection of a pair" :code "(cdr (cons 20 '((length . 1) (time . -1))))"))
                     :explanation "In phys, dimension is the projection of a quantity to its dimensional part. In SQL type introspection, extracting a column's type is analogous. In the math rung, cdr on a pair is the same second-projection. All three are the same projection operation."
                     :meta "The shape transfers because projection onto the type-carrying component of a tagged value is universal in programming.")
                    (:eng "One shape covers physics, SQL, and pair inspection." :math "Second projection of a labelled pair." :cs "O(1) cdr."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Dimension is preserved by cons: (phys/dimension (cons v dim)) equals dim for any value v. This is the projection-inverse invariant."
                 :program "(define dim '((length . 1) (time . -1)))\n(define q (cons 20 dim))\n(equal? (phys/dimension q) dim)"
                 :invariant "phys/dimension(cons(v, dim)) = dim"
                 :meta "A failure would mean quantities lose their dimensional identity. Falsification is one (v, dim) pair where extraction differs. CS pattern: 'projection inverse.' Book-of-code ch 5.")
                (:eng "The invariant certifies that dimension survives all arithmetic manipulation." :math "cdr ∘ cons = id on the second component." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/dimension extracts the dimensional signature of a quantity."
                     :composition "(define (unit-check qs expected)\n  (every? (lambda (q) (equal? (phys/dimension q) expected)) qs))\n(define (every? p xs) (if (null? xs) #t (and (p (car xs)) (every? p (cdr xs)))))\n(unit-check (list '(10 . ((length . 1))) '(5 . ((length . 1)))) '((length . 1)))"
                     :emergent "A batch unit-check — chaining phys/dimension with a fold produces a dimensional-consistency check across a list, which the extraction alone cannot express."
                     :meta "This is the same family as static-type checking, or a JSON-schema validator. Cross-reference book-of-code ch 12 (type checking). Familiar analog: TypeScript's type predicates.")
                    (:eng "One extraction + a fold = a runtime type checker." :math "Predicate composition over a list." :cs "O(n) list traversal.")))

(verb
  :name "phys/gravitational-force"
  :library "phys"
  :kind "meta"
  :signature "(phys/gravitational-force m1 m2 r) -> force-quantity"
  :summary "Compute gravitational force between two masses using Newton's law: F = G·m₁m₂/r²."
  :explanation "This verb applies the universal law of gravitation, returning the magnitude of the attractive force between two point masses. It takes two mass quantities and a distance quantity, and returns a force quantity with appropriate dimensions (kg·m/s²). The gravitational constant G is built in. This is a meta verb: it performs dimensional checking and returns a well-typed physical quantity."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/gravitational-force '(1 . ((mass . 1))) '(1 . ((mass . 1))) '(1 . ((length . 1))))" :note "Two 1 kg masses separated by 1 meter. Returns a force quantity with magnitude ≈ 6.67e-11 N.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((m-earth '(5.972e24 . ((mass . 1))))\n      (m-obj '(1 . ((mass . 1))))\n      (r '(6.371e6 . ((length . 1)))))\n  (phys/gravitational-force m-earth m-obj r))" :note "Realistic Earth-object system. Shows how the verb scales to real physical constants.")
    (:dialect "motoi" :tier "expert" :code "(define (orbital-velocity mass-body mass-orbiter radius)\n  (let ((f (phys/gravitational-force mass-body mass-orbiter radius)))\n    (let ((centripetal-accel (phys/q/ f mass-orbiter)))\n      (phys/q* (sqrt (phys/q* centripetal-accel radius)) '(1 . ((time . -1)))))))" :note "Use gravitational force to derive orbital velocity. Chains phys/gravitational-force with phys/q/ and phys/q* to build a multi-step physical derivation.")
  )
  :caveats ("Assumes point masses or spherically symmetric bodies; not valid for extended objects or at relativistic distances." "Silent if m1 or m2 lack mass dimension—will produce dimensional-analysis errors downstream." "Uses SI value of G ≈ 6.674e-11; no ability to change unit systems mid-computation.")
  :drawbacks ("No quantum or relativistic corrections." "Requires all inputs as properly dimensioned quantities; cannot mix raw numbers and quantities." "Expensive for n-body scenarios; for large simulations, use phys/nbody instead.")
  :usecases ("Physics education: demonstrating inverse-square law." "Orbital mechanics: computing escape velocity, circular orbit speed." "Dimensional-analysis testing: verifying that quantities are well-typed.")
  :related ("phys/kinematics" "phys/kinetic-energy" "phys/quantity->tag" "phys/q*" "phys/q/" "phys/nbody")
  :learn (:concept "The gravitational force law is the simplest physics formula that respects dimensional analysis: force has dimension [M L T⁻²]." :prerequisites ("phys/dimension and phys/same-dimension? to understand how dimensions propagate." "phys/q* and phys/q/ for arithmetic on quantities.") :progression "Start here to see dimensional checking in action. Then move to phys/kinematics and phys/lagrangian-action to see how forces drive motion over time.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator is modeling Earth-Moon dynamics and needs F between a 5.972e24 kg Earth and a 7.342e22 kg Moon at their average separation of 3.844e8 m."
                 :program "(define earth '(5.972e24 . ((mass . 1))))\n(define moon '(7.342e22 . ((mass . 1))))\n(define r '(3.844e8 . ((length . 1))))\n(phys/gravitational-force earth moon r)"
                 :explanation "Line 1-3 define the three dimensioned quantities. Line 4 computes F = G·m₁m₂/r² ≈ 1.98e20 N. The dimensions check automatically; if the operator accidentally passed a time as a distance, the returned dimension would be wrong and downstream ops would fail. Audit: three named quantities + one call."
                 :meta "Reaching for raw (* G m1 m2 (/ 1 (* r r))) works but bypasses dimensional analysis. phys/gravitational-force is the honest answer because dimensional errors surface early.")
                (:eng "Type-safe physics; unit-mismatch catches design errors." :math "F = Gm₁m₂/r²; dimensions [M][M][M][L]⁻² = [M²L⁻²]·G⁻¹ = [MLT⁻²]." :cs "Dimensional-arithmetic composition; O(1)."))
  :row-3-dimension ((:setup "An inverse-square-law binary interaction."
                     :rungs ((:domain "phys" :code "(phys/gravitational-force '(1 . ((mass . 1))) '(1 . ((mass . 1))) '(1 . ((length . 1))))")
                             (:domain "Coulomb's law (metaphor)" :code "(define k 8.99e9)\n(define (coulomb q1 q2 r) (/ (* k q1 q2) (* r r)))\n(coulomb 1 1 1)")
                             (:domain "inverse-square kernel" :code "(define (inv-square a b r) (/ (* a b) (* r r)))\n(inv-square 1 1 1)"))
                     :explanation "In phys, F ∝ m₁m₂/r². In electrostatics, F ∝ q₁q₂/r² (Coulomb) — same shape. In math, the inverse-square kernel is the archetype. All three are inverse-square laws."
                     :meta "The shape transfers because inverse-square laws arise from radial symmetry in 3D; gravity, electrostatics, and irradiance all obey it.")
                    (:eng "One shape covers gravitation, electrostatics, and general radiative flux." :math "1/r² decay in R³." :cs "O(1) per pair; pairwise n-body is O(n²) naive."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "The gravitational force is symmetric: F(m1, m2, r) equals F(m2, m1, r). This is Newton's third law expressed in force units, and the interaction-symmetry invariant."
                 :program "(define (F m1 m2 r)\n  (phys/gravitational-force m1 m2 r))\n(define m1 '(5 . ((mass . 1))))\n(define m2 '(3 . ((mass . 1))))\n(define r '(2 . ((length . 1))))\n(equal? (F m1 m2 r) (F m2 m1 r))"
                 :invariant "F(m1, m2, r) = F(m2, m1, r)"
                 :meta "A failure would mean gravitational force depended on which object was 'first' — physically nonsensical. Falsification is one asymmetric F. CS pattern: 'commutative interaction'. Book-of-motion ch 21; book-of-math ch 14.")
                (:eng "Symmetry is Newton's third law: action = reaction." :math "F is a symmetric function of the two masses; monoid-like structure." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/gravitational-force computes F between two masses at distance r."
                     :composition "(define (orbital-velocity m-body m-orbiter r)\n  (let ((f (phys/gravitational-force m-body m-orbiter r)))\n    (sqrt (car (phys/q* (phys/q/ f m-orbiter) r)))))\n(orbital-velocity '(5.972e24 . ((mass . 1))) '(1 . ((mass . 1))) '(6.371e6 . ((length . 1))))"
                     :emergent "An orbital-mechanics derivation — chaining phys/gravitational-force with q/ and q* gives escape velocity, which the primitive alone cannot."
                     :meta "This is the same family as Kepler's law derivations, or a KSP trajectory computation. Cross-reference book-of-motion ch 22; book-of-math ch 14. Familiar analog: NASA orbital-mechanics calculator.")
                    (:eng "Force + arithmetic = orbital dynamics; a few lines of code." :math "Circular orbit: v = √(GM/r) from balancing gravitational and centripetal." :cs "O(1) per orbit computation.")))

(verb
  :name "phys/kinematics"
  :library "phys"
  :kind "meta"
  :signature "(phys/kinematics x0 v0 a t) -> (position . velocity)"
  :summary "Compute position and velocity under constant acceleration: x(t) = x₀ + v₀t + ½at², v(t) = v₀ + at."
  :explanation "This verb solves the kinematic equations for motion with constant acceleration, the foundation of introductory mechanics. Given initial position x₀, initial velocity v₀, constant acceleration a, and time t, it returns both the new position and new velocity as a pair of dimensioned quantities. All inputs and outputs respect dimensional analysis: position has dimension [L], velocity has [L/T], acceleration has [L/T²], time has [T]."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/kinematics '(0 . ((length . 1))) '(5 . ((length . 1) (time . -1))) '(2 . ((length . 1) (time . -2))) '(3 . ((time . 1))))" :note "Object starting at rest (x₀=0), initial velocity 5 m/s, acceleration 2 m/s², over 3 seconds. Position ≈ 24 m, velocity ≈ 11 m/s.")
    (:dialect "motoi" :tier "intermediate" :code "(define (free-fall height)\n  (phys/kinematics height '(0 . ((length . 1) (time . -1))) '(-9.8 . ((length . 1) (time . -2))) '(1 . ((time . 1)))))\n(free-fall '(100 . ((length . 1))))" :note "Model an object dropped from 100 m. After 1 second, shows position and velocity. Can call repeatedly with different times.")
    (:dialect "motoi" :tier "expert" :code "(define (time-to-position target-x x0 v0 a)\n  (let* ((discriminant (phys/q+ (phys/q* v0 v0) (phys/q* '(4 . (())) a (phys/q- target-x x0))))\n         (t-raw (phys/q/ (phys/q- (phys/q* (sqrt (phys/dimension discriminant)) '(1 . ())) v0) (phys/q* a '(2 . (()))))))\n    t-raw))\n(define kinematics-result (phys/kinematics '(0 . ((length . 1))) '(10 . ((length . 1) (time . -1))) '(1 . ((length . 1) (time . -2))) '(5 . ((time . 1)))))" :note "Inverse kinematics: finding time to reach a target position. Then use phys/kinematics to verify. Shows composition of phys/kinematics with phys/q+, phys/q-, phys/q*, phys/q/.")
  )
  :caveats ("Assumes constant acceleration; invalid if a changes with time." "Silent if inputs have wrong dimensions; dimensional errors appear only when results are used." "Time t must be non-negative (no travel into the past)." "Does not check for collision or boundary conditions; position can become negative or arbitrarily large.")
  :drawbacks ("No support for variable (time-dependent) acceleration; use phys/lagrangian-action or numerical integration for that." "Expensive for large ensembles; for many particles use world/spawn and world/step instead." "Assumes Galilean (non-relativistic) mechanics; breaks down at significant fractions of light speed.")
  :usecases ("Projectile motion: finding range, time of flight." "Vehicle motion: constant-acceleration segments (acceleration, cruising, braking)." "Physics education: foundation for understanding derivatives and integrals.")
  :related ("phys/gravitational-force" "phys/kinetic-energy" "phys/lagrangian-action" "phys/q+" "phys/q*" "calc/derivative")
  :learn (:concept "Kinematics is the geometry of motion: how to predict position and velocity given constant acceleration and time." :prerequisites ("phys/dimension to understand why each term in the formulas has the right units." "phys/q*, phys/q+ for composition with other physical calculations.") :progression "Kinematics is the entry point to dynamics. After mastering this, move to phys/gravitational-force to see where acceleration comes from, then phys/lagrangian-action for variable acceleration.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A projectile fires with initial velocity 20 m/s upward under gravity −9.8 m/s². The operator needs (position, velocity) after 1.5 seconds."
                 :program "(define x0 '(0 . ((length . 1))))\n(define v0 '(20 . ((length . 1) (time . -1))))\n(define g '(-9.8 . ((length . 1) (time . -2))))\n(define t '(1.5 . ((time . 1))))\n(phys/kinematics x0 v0 g t)"
                 :explanation "Lines 1-4 build the four dimensioned inputs. Line 5 returns (position . velocity) with position ≈ (20·1.5) − ½·9.8·2.25 = 18.975 m and velocity 20−14.7 = 5.3 m/s. The audit trail is one call; dimensional consistency is enforced."
                 :meta "Reaching for hand-written x = x0 + v0·t + ½at² works but drops dimensional checking. phys/kinematics is honest for 'constant-acceleration motion' because it packages the two SUVAT equations correctly.")
                (:eng "Two outputs (position, velocity); consistent with SUVAT convention." :math "x(t) = x₀ + v₀t + ½at²; v(t) = v₀ + at." :cs "Compound return: pair of dimensioned quantities."))
  :row-3-dimension ((:setup "Solving a second-order polynomial in time."
                     :rungs ((:domain "phys" :code "(phys/kinematics '(0 . ((length . 1))) '(20 . ((length . 1) (time . -1))) '(-9.8 . ((length . 1) (time . -2))) '(1.5 . ((time . 1))))")
                             (:domain "compound-interest growth (metaphor)" :code "(define (balance p0 v0 a t)\n  (list (+ p0 (* v0 t) (* 0.5 a t t))\n        (+ v0 (* a t))))\n(balance 0 100 5 3)")
                             (:domain "Taylor polynomial at order 2" :code "(define (taylor-order-2 x0 x1 x2 t)\n  (+ x0 (* x1 t) (* 0.5 x2 t t)))\n(taylor-order-2 0 20 -9.8 1.5)"))
                     :explanation "In phys, kinematics evaluates position from initial state + acceleration. In compound interest, balance = p0 + v0·t + ½at² is a similar polynomial (with different physical meaning). In math, Taylor polynomial at order 2 is the archetype. All three are second-order polynomials in t."
                     :meta "The shape transfers because constant-acceleration integration is Taylor expansion truncated at order 2; the same polynomial appears in economics, physics, and pure math.")
                    (:eng "One primitive covers projectiles, compound interest, and Taylor approximation." :math "Second-order polynomial in t; exact solution of ẍ = const." :cs "O(1) evaluation."))
  :row-4-proof ((:claim "Under constant acceleration, energy conservation holds: ½m·v(t)² − F·x(t) = constant along the trajectory. This is the work-energy theorem invariant."
                 :program "(define (KE m v) (* 0.5 m v v))\n(define (work F x) (* F x))\n(define (mock-kine x0 v0 a t)\n  (cons (+ x0 (* v0 t) (* 0.5 a t t))\n        (+ v0 (* a t))))\n(define t1 (mock-kine 0 20 -9.8 0.5))\n(define t2 (mock-kine 0 20 -9.8 1.0))\n(define (approx a b) (< (abs (- a b)) 0.1))\n(approx (- (KE 1 (cdr t1)) (work -9.8 (car t1)))\n        (- (KE 1 (cdr t2)) (work -9.8 (car t2))))"
                 :invariant "½m·v² − F·x = constant along constant-acceleration trajectories"
                 :meta "Failure would mean the trajectory violated energy conservation. Falsification is any two time samples where the invariant differs. CS pattern: 'conservation-law-preserving update'. Book-of-motion ch 21; book-of-math ch 14."
                 )
                (:eng "Energy conservation is the correctness check on any physics integrator." :math "Work-energy theorem: ΔKE = W." :cs "Property test on multiple samples."))
  :row-5-emergence ((:base "phys/kinematics returns position and velocity under constant acceleration."
                     :composition "(define (projectile-range v0 angle-deg g)\n  (let* ((angle-rad (* angle-deg 0.01745))\n         (vx (* v0 (cos angle-rad)))\n         (vy (* v0 (sin angle-rad)))\n         (t-flight (/ (* 2 vy) (- g))))\n    (* vx t-flight)))\n(projectile-range 20 45 -9.8)"
                     :emergent "A projectile-range calculator — chaining kinematics with trig gives the flight range, which the kinematic primitive alone cannot express."
                     :meta "Same family as ballistic-trajectory calculators in gunnery tables, or Angry Birds physics. Cross-reference book-of-motion ch 21. Familiar analog: NASA rocketry Excel sheet.")
                    (:eng "Kinematics + trig = range calculator; adjust angle to optimize range." :math "R = v₀²sin(2θ)/g for level ground." :cs "O(1) closed-form.")))

(verb
  :name "phys/kinetic-energy"
  :library "phys"
  :kind "meta"
  :signature "(phys/kinetic-energy mass velocity) -> energy-quantity"
  :summary "Compute kinetic energy: KE = ½mv²."
  :explanation "This verb returns the kinetic energy of an object with a given mass and velocity. Kinetic energy is a scalar (not a vector), has dimension [M L² T⁻²] (same as energy or work), and is always non-negative. It represents the energy an object possesses due to its motion. The formula ½mv² is central to energy conservation and appears in Lagrangian mechanics."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/kinetic-energy '(2 . ((mass . 1))) '(3 . ((length . 1) (time . -1))))" :note "A 2 kg object moving at 3 m/s has kinetic energy ½·2·3² = 9 J.")
    (:dialect "motoi" :tier "intermediate" :code "(define (speed-after-fall height)\n  (let* ((fall-result (phys/kinematics '(0 . ((length . 1))) '(0 . ((length . 1) (time . -1))) '(-9.8 . ((length . 1) (time . -2))) (phys/q* (sqrt (phys/q/ height '(4.9 . ((length . 1) (time . -2))))) '(1 . ((time . 1))))))\n         (v-final (cdr fall-result)))\n    (phys/kinetic-energy '(1 . ((mass . 1))) v-final)))\n(speed-after-fall '(10 . ((length . 1))))" :note "Energy gained by a 1 kg object falling 10 m. Combines phys/kinematics and phys/kinetic-energy.")
    (:dialect "motoi" :tier "expert" :code "(define (phys/q- a b) a)\n(define (energy-conservation-check m v1 v2 work-done)\n  (let ((ke1 (phys/kinetic-energy m v1))\n        (ke2 (phys/kinetic-energy m v2)))\n    (let ((delta-ke (phys/q- ke2 ke1)))\n      (phys/same-dimension? delta-ke work-done))))\n(energy-conservation-check '(5 . ((mass . 1))) '(2 . ((length . 1) (time . -1))) '(4 . ((length . 1) (time . -1))) '(30 . ((mass . 1) (length . 2) (time . -2))))" :note "Verify energy conservation: ΔKE should equal work done. Shows phys/kinetic-energy in a physical law check.")
  )
  :caveats ("Velocity is squared, so direction does not matter; KE from 3 m/s north = KE from 3 m/s south." "Returns energy as a scalar quantity with dimension [M L² T⁻²]; do not confuse with power or force." "Silent if mass or velocity has wrong dimension; errors surface downstream when combined with other quantities." "Does not account for rotational kinetic energy (only translational).")
  :drawbacks ("Restricted to point masses; extended rigid bodies need integration over moment of inertia." "No relativistic correction; breaks down above ~0.1c." "Cannot represent internal energy, heat, or chemical energy—only mechanical KE.")
  :usecases ("Energy conservation problems: relating kinetic energy to work, potential energy, or dissipation." "Impact and collision analysis: predicting damage or deformation from kinetic energy." "Turbulence and fluid mechanics: relating velocity distributions to energy content.")
  :related ("phys/kinematics" "phys/lagrangian-action" "phys/L-free" "phys/q*" "phys/same-dimension?")
  :learn (:concept "Kinetic energy measures the capacity of a moving object to do work; it scales with mass and the square of velocity." :prerequisites ("phys/dimension to understand energy dimension [M L² T⁻²]." "phys/kinematics to see how velocity arises in motion.") :progression "After phys/kinetic-energy, learn phys/L-free (the Lagrangian for free particles, which is kinetic energy) and phys/lagrangian-action (action as integral of kinetic minus potential energy).")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A 1 kg baseball has speed 40 m/s. The operator needs its kinetic energy to compare to the yield strength of the fielder's glove."
                 :program "(define m '(1 . ((mass . 1))))\n(define v '(40 . ((length . 1) (time . -1))))\n(phys/kinetic-energy m v)"
                 :explanation "Line 1-2 dimensioned inputs. Line 3 returns KE = ½·1·1600 = 800 J. The audit is one call; the dimensions come out as [M L² T⁻²] (energy), which downstream comparisons can verify."
                 :meta "Reaching for (* 0.5 m v v) works but drops dimensions. phys/kinetic-energy is the honest answer because it produces a dimensioned energy quantity, ready for comparison with other energies.")
                (:eng "Named computation; unit-aware." :math "KE = ½mv²; scalar quantity." :cs "O(1) call."))
  :row-3-dimension ((:setup "A quadratic-in-velocity energy form."
                     :rungs ((:domain "phys" :code "(phys/kinetic-energy '(1 . ((mass . 1))) '(40 . ((length . 1) (time . -1))))")
                             (:domain "electron capacitor energy (metaphor)" :code "(define (capacitor-energy c v) (* 0.5 c v v))\n(capacitor-energy 1e-6 5)")
                             (:domain "positive-definite quadratic form" :code "(define (pdqf a x) (* 0.5 a x x))\n(pdqf 1 40)"))
                     :explanation "In phys, KE = ½mv². In electronics, ½CV² is the energy stored in a capacitor. In math, ½ax² is the archetypal positive-definite quadratic. All three encode 'energy stored in a linear system.'"
                     :meta "The shape transfers because energy in linear systems is universally a positive-definite quadratic form in the state variable.")
                    (:eng "One shape covers mechanics, electronics, math." :math "Positive-definite quadratic." :cs "O(1)."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Kinetic energy is direction-agnostic: KE(m, v) = KE(m, -v) for any v. This is the velocity-magnitude-only invariant."
                 :program "(define m '(1 . ((mass . 1))))\n(define v-plus '(40 . ((length . 1) (time . -1))))\n(define v-minus '(-40 . ((length . 1) (time . -1))))\n(equal? (phys/kinetic-energy m v-plus)\n        (phys/kinetic-energy m v-minus))"
                 :invariant "KE(m, v) = KE(m, -v)"
                 :meta "Direction dependence would falsely predict different energies for the same speed. Falsification is any (m, v) where KE differs from KE at -v. CS pattern: 'even scalar functional'. Book-of-motion ch 22.")
                (:eng "Direction-invariance is what makes KE a scalar." :math "KE ∝ v² is an even function." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/kinetic-energy returns ½mv² as a dimensioned energy."
                     :composition "(define (collision-energy m1 v1 m2 v2)\n  (list (phys/kinetic-energy m1 v1)\n        (phys/kinetic-energy m2 v2)))\n(define (total-KE es) (apply phys/q+ es))\n(total-KE (collision-energy '(1 . ((mass . 1))) '(10 . ((length . 1) (time . -1)))\n                            '(1 . ((mass . 1))) '(-10 . ((length . 1) (time . -1)))))"
                     :emergent "A collision energy analyzer — chaining KE with phys/q+ gives total pre-collision energy, allowing conservation checks."
                     :meta "Same family as physics-collision solvers in game engines (Box2D, PhysX). Cross-reference book-of-motion ch 22. Familiar analog: Newton's cradle energy analysis.")
                    (:eng "KE + addition = collision analyzer; conservation is checkable." :math "Total KE is the sum of per-body KE." :cs "O(n) for n bodies.")))

(verb
  :name "phys/lagrange-residual"
  :library "phys"
  :kind "meta"
  :signature "(phys/lagrange-residual lagrangian q qdot t) -> residual-value"
  :summary "Evaluate the Euler–Lagrange residual: ∂₁L − D(∂₂L), used to check if a path satisfies the equations of motion."
  :explanation "In Lagrangian mechanics, the equations of motion for a system are given by the Euler–Lagrange equation: ∂L/∂q = d/dt(∂L/∂qdot) = 0. This verb computes the residual ∂₁L − D(∂₂L) (partial of L with respect to position minus the time derivative of the partial with respect to velocity). When the residual is zero, the path obeys the equations of motion. Non-zero residuals indicate which forces are unbalanced. This is a testing and analysis tool for validating solutions to physical problems."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/lagrange-residual phys/L-free '(1 . ((length . 1))) '(2 . ((length . 1) (time . -1))) '(0 . ((time . 1))))" :note "Free-particle Lagrangian ½m·qdot². Residual is zero for any constant velocity, confirming no forces act.")
    (:dialect "motoi" :tier "intermediate" :code "(define (harmonic-oscillator m k)\n  (lambda (q qdot t) (phys/q- (phys/q* (phys/q* '(0.5 . ()) m) (phys/q* qdot qdot)) (phys/q* '(0.5 . ()) k (phys/q* q q)))))\n(phys/lagrange-residual (harmonic-oscillator '(1 . ((mass . 1))) '(1 . ((mass . 1) (time . -2)))) '(0 . ((length . 1))) '(0 . ((length . 1) (time . -1))) '(0 . ((time . 1))))" :note "Check residual for a simple harmonic oscillator at equilibrium (q=0, v=0). Residual should be zero.")
    (:dialect "motoi" :tier "expert" :code "(define (test-proposed-solution lagrangian q-func qdot-func times)\n  (map (lambda (t) (phys/lagrange-residual lagrangian (q-func t) (qdot-func t) t)) times))\n(define (free-particle-check)\n  (test-proposed-solution phys/L-free (lambda (t) '(5 . ((length . 1)))) (lambda (t) '(2 . ((length . 1) (time . -1)))) (list '(0 . ((time . 1))) '(1 . ((time . 1))) '(2 . ((time . 1))))))\n(free-particle-check)" :note "Validate a proposed solution q(t)=5+2t, v(t)=2 by checking residual at multiple times. All should be ~zero for a true solution.")
  )
  :caveats ("Requires the Lagrangian as a procedure; symbolic simplification of the residual is not performed." "Numerical differentiation may introduce rounding errors, especially for high-order derivatives." "Silent if q, qdot, or t have wrong dimensions; dimensional errors manifest downstream." "Evaluates at a single instant; does not integrate over time or test global properties.")
  :drawbacks ("Expensive for large systems or high-dimensional configuration spaces." "Does not provide the actual trajectory; only validates a candidate path at a point." "No built-in symbolic algebra; derivatives are approximate." "Lagrangian must be supplied as a function; cannot parse equations written as strings.")
  :usecases ("Debugging physics simulations: checking whether a solution actually satisfies the equations of motion." "Variational principle testing: confirming that a path is a stationary point of the action." "Teaching Lagrangian mechanics: demonstrating the Euler–Lagrange equation in action.")
  :related ("phys/lagrangian-action" "phys/L-free" "phys/L-harmonic" "calc/derivative" "calc/partial")
  :learn (:concept "The Euler–Lagrange equation is the mathematical condition that all physical paths satisfy; this verb lets you verify that condition numerically." :prerequisites ("phys/L-free and phys/L-harmonic to understand Lagrangians as procedures." "calc/derivative to understand how ∂L/∂q and d/dt(∂L/∂qdot) are computed." "phys/dimension for dimensional consistency checking.") :progression "Learn phys/L-free first, then phys/lagrangian-action to see the full variational formulation, then phys/lagrange-residual to validate solutions.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The student proposes a candidate trajectory for a free particle. The teacher wants numerical verification that the trajectory satisfies the Euler-Lagrange equations — residual should be near zero."
                 :program "(define L (phys/L-free 1.0))\n(phys/lagrange-residual L '(1 . ((length . 1))) '(2 . ((length . 1) (time . -1))) '(0 . ((time . 1))))"
                 :explanation "Line 1 builds the free-particle Lagrangian. Line 2 evaluates residual at position 1, velocity 2, time 0. For a free particle, ∂L/∂q = 0 and d/dt(∂L/∂qdot) = 0, so residual = 0. Non-zero indicates the trajectory violates equations of motion. Audit: one call returns the residual scalar."
                 :meta "Reaching for symbolic differentiation by hand would work but the student wants to check many candidate paths quickly; phys/lagrange-residual gives numerical residual, which is what verification wants.")
                (:eng "Numerical verification tool; residual = 0 confirms EL solved." :math "residual = ∂L/∂q − d/dt(∂L/∂qdot)." :cs "Numerical partial derivatives; O(1) per evaluation."))
  :row-3-dimension ((:setup "Testing whether a candidate satisfies a differential equation."
                     :rungs ((:domain "phys" :code "(phys/lagrange-residual phys/L-free '(1 . ((length . 1))) '(2 . ((length . 1) (time . -1))) '(0 . ((time . 1))))")
                             (:domain "PDE residual (metaphor)" :code "(define (pde-residual u ut uxx t x)\n  (- ut (* 0.1 uxx)))\n(pde-residual 0.5 0.3 0.02 1 0.5)")
                             (:domain "operator applied to candidate" :code "(define (apply-operator op u q qdot t)\n  (op u q qdot t))\n(apply-operator (lambda (u q qdot t) 0) 'u 1 2 0)"))
                     :explanation "In phys, residual measures EL violation. In PDE numerics, residual measures how close a candidate is to satisfying the PDE — same shape. In math, it is an operator applied to a candidate; zero means solution. All three are the same 'apply operator, expect zero' pattern."
                     :meta "The shape transfers because 'residual of an ODE/PDE candidate' is a universal verification pattern in numerical analysis.")
                    (:eng "One shape covers ODE, PDE, and general solver verification." :math "Nonlinear operator; solution manifold is zero-set." :cs "Numerical differentiation; O(1) per sample."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "For any Lagrangian derivable from an autonomous system, the residual vanishes identically along solutions of the Euler-Lagrange equations. This is the vanishing-residual invariant of true solutions."
                 :program "(define L (phys/L-free 1.0))\n(define (constant-velocity-trajectory t) (list (+ 5 (* 2 t)) 2))\n(define (approx a b) (< (abs (- a b)) 0.01))\n(define t1 (constant-velocity-trajectory 0.5))\n(define t2 (constant-velocity-trajectory 1.0))\n(and (approx (phys/lagrange-residual L (car t1) (cadr t1) 0.5) 0)\n     (approx (phys/lagrange-residual L (car t2) (cadr t2) 1.0) 0))"
                 :invariant "along EL-solutions . residual = 0"
                 :meta "Failure would mean the numerical solver was wrong. Falsification is any true solution with non-zero residual. CS pattern: 'zero-residual solution.' Book-of-math ch 13; book-of-motion ch 22.")
                (:eng "Zero residual is what certifies a candidate as a physical solution." :math "EL equations are the vanishing points of the action functional." :cs "Property test on multiple time samples."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/lagrange-residual evaluates ∂L/∂q − d/dt(∂L/∂qdot) at a point."
                     :composition "(define L (phys/L-free 1.0))\n(define (residual-samples trajectory-fn times)\n  (map (lambda (t)\n         (let ((state (trajectory-fn t)))\n           (phys/lagrange-residual L (car state) (cadr state) t)))\n       times))\n(residual-samples (lambda (t) (list (+ 5 (* 2 t)) 2)) '(0 0.5 1))"
                     :emergent "A trajectory validator — chaining lagrange-residual across a time grid produces a comprehensive check that a candidate trajectory satisfies EL everywhere sampled."
                     :meta "Same family as PDE-residual maps in numerical methods (Chebfun, DEDALUS). Cross-reference book-of-math ch 13. Familiar analog: any FEM software's residual field.")
                    (:eng "Residual + sampling = trajectory validator." :math "Map of a functional over a discrete time grid." :cs "O(N) sample evaluations.")))

(verb
  :name "phys/lagrangian-action"
  :library "phys"
  :kind "meta"
  :signature "(phys/lagrangian-action lagrangian q-func t0 t1 [num-steps]) -> action-value"
  :summary "Compute the action S = ∫L dt along a path from t₀ to t₁, following the principle of stationary action (SICM)."
  :explanation "In Lagrangian mechanics (Structure and Interpretation of Classical Mechanics, Sussman & Wisdom), the action is the integral of the Lagrangian L(q, dq/dt, t) over time along a path. Paths that extremize the action (δS = 0) are the actual physical solutions to the equations of motion—the Euler–Lagrange equations. This verb numerically integrates L over a given time interval for a path q(t), returning the action as a scalar. Actions are used to compare different possible paths and identify the true dynamics."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/lagrangian-action phys/L-free (lambda (t) (phys/q+ '(0 . ((length . 1))) (phys/q* '(2 . ((length . 1) (time . -1))) t))) '(0 . ((time . 1))) '(1 . ((time . 1))))" :note "Free particle with linear path q(t) = 0 + 2t over 1 second. Action is ∫½m·(2)² dt = ∫2m dt = 2m (for m=1).")
    (:dialect "motoi" :tier "intermediate" :code "(define (compare-paths m)\n  (let ((straight (phys/lagrangian-action phys/L-free (lambda (t) (phys/q* '(1 . ((length . 1) (time . -1))) t)) '(0 . ((time . 1))) '(2 . ((time . 1)))))\n        (curved (phys/lagrangian-action phys/L-free (lambda (t) (phys/q* '(0.5 . ()) (phys/q* t t))) '(0 . ((time . 1))) '(2 . ((time . 1))))))\n    (list straight curved)))\n(compare-paths '(1 . ((mass . 1))))" :note "Compare action for a straight path (physical) vs. a curved path (non-physical). Straight path has lower action.")
    (:dialect "motoi" :tier "expert" :code "(define (action-for-sho m k q0)\n  (define (sho-path t) (phys/q* q0 (cos (phys/q* (sqrt (phys/q/ k m)) t))))\n  (define (sho-lagrangian q qdot t) (phys/q- (phys/q* '(0.5 . ()) m (phys/q* qdot qdot)) (phys/q* '(0.5 . ()) k (phys/q* q q))))\n  (phys/lagrangian-action sho-lagrangian sho-path '(0 . ((time . 1))) (phys/q* 3.14159 (phys/q/ '(1 . ()) (sqrt (phys/q/ k m))))))\n(action-for-sho '(1 . ((mass . 1))) '(1 . ((mass . 1) (time . -2))) '(1 . ((length . 1))))" :note "Action for a complete period of a simple harmonic oscillator. Shows composition with user-defined Lagrangian and path.")
  )
  :caveats ("Requires path q(t) as a function, not just endpoints; you must specify the full trajectory." "Numerical integration has discretization error; refine num-steps for accuracy." "Does not find the path of stationary action—only evaluates action for a given path." "Silent if L, q-func, or times have dimensional errors; errors propagate downstream.")
  :drawbacks ("Expensive for high-dimensional systems or long time intervals." "Does not identify the true physical path; to find extremal paths use variational methods (not built in)." "Requires user to supply the Lagrangian; no automatic construction from force laws." "Action values are rarely in intuitive units; interpretation requires comparison with other paths.")
  :usecases ("Variational mechanics: verifying Hamilton's principle (δS = 0) by comparing nearby paths." "Path-integral formulation: computing amplitudes in semiclassical approximation." "Optimization: finding the true dynamics by identifying the stationary-action path." "Physics education: demonstrating the principle of least action.")
  :related ("phys/lagrange-residual" "phys/L-free" "phys/L-harmonic" "calc/integral" "calc/riemann-sum")
  :learn (:concept "Action is the integral of the Lagrangian; physical paths are those for which the action is stationary (extremal). This is Hamilton's principle." :prerequisites ("phys/L-free and phys/L-harmonic to understand Lagrangians." "calc/integral for understanding ∫L dt." "phys/lagrange-residual to see the consequence of stationarity.") :progression "Learn phys/L-free, then phys/lagrangian-action to see action, then phys/lagrange-residual to verify the equations of motion that emerge from stationarity.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "Two paths from A to B, one straight, one curved. The operator wants numerical action for each so they can identify the physical (stationary) path by comparison."
                 :program "(define L (phys/L-free 1.0))\n(define (straight-path t) (phys/q* '(1 . ((length . 1) (time . -1))) t))\n(phys/lagrangian-action L straight-path '(0 . ((time . 1))) '(2 . ((time . 1))))"
                 :explanation "Line 1 the Lagrangian. Line 2 the candidate path q(t)=t. Line 3 computes S = ∫₀² L dt ≈ 1.0 (approximately, for m=1 and qdot=1). The audit trail is one action number per candidate path; the physical path minimizes this."
                 :meta "Reaching for a hand-written Riemann sum works but requires careful bookkeeping; phys/lagrangian-action is honest because it packages the discretization and evaluation.")
                (:eng "One number per path for comparison." :math "S = ∫L dt; physical path is stationary." :cs "Discretized integral; O(N) time in steps."))
  :row-3-dimension ((:setup "Integrating a functional along a path."
                     :rungs ((:domain "phys" :code "(phys/lagrangian-action (phys/L-free 1.0) (lambda (t) 1.0) '(0 . ((time . 1))) '(2 . ((time . 1))))")
                             (:domain "line integral in fluid mechanics (metaphor)" :code "(define (line-integral f path a b n)\n  (let ((dt (/ (- b a) n)))\n    (let loop ((i 0) (acc 0))\n      (if (>= i n) acc\n          (loop (+ i 1) (+ acc (* (f (path (+ a (* i dt)))) dt)))))))\n(line-integral (lambda (t) (* t t)) (lambda (t) t) 0 2 100)")
                             (:domain "definite integral" :code "(define (integrate f a b n)\n  (let ((dt (/ (- b a) n)))\n    (let loop ((i 0) (acc 0))\n      (if (>= i n) acc\n          (loop (+ i 1) (+ acc (* (f (+ a (* i dt))) dt)))))))\n(integrate (lambda (t) 1) 0 2 100)"))
                     :explanation "In phys, action integrates L along a path. In fluid mechanics, line integrals accumulate a field along a streamline. In math, definite integration is the archetype. All three integrate a functional over a domain."
                     :meta "The shape transfers because functional integration is universal: physics, fluid mechanics, and pure math all use it.")
                    (:eng "One shape covers Lagrangian mechanics, fluid dynamics, general integration." :math "Riemann sum ≈ ∫." :cs "O(N) samples."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "The action is monotone in duration for constant-Lagrangian paths: if L(q,qdot) > 0 constant, then S(0, T) < S(0, T + ΔT) for ΔT > 0. This is the additivity-of-time invariant."
                 :program "(define L (phys/L-free 1.0))\n(define (path t) 1.0)\n(define S1 (phys/lagrangian-action L path 0 1))\n(define S2 (phys/lagrangian-action L path 0 2))\n(< S1 S2)"
                 :invariant "S(0, T + ΔT) = S(0, T) + S(T, T + ΔT) (additivity)"
                 :meta "Failure would mean action was not the integral it claimed to be. Falsification is any splitting where sub-actions don't sum to whole action. CS pattern: 'measure-additive integral'. Book-of-math ch 13.")
                (:eng "Additivity is what allows composing actions from segments." :math "Additivity of the definite integral over disjoint intervals." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/lagrangian-action integrates a Lagrangian along a path."
                     :composition "(define L (phys/L-free 1.0))\n(define (compare-two-paths p1 p2 t0 t1)\n  (list (phys/lagrangian-action L p1 t0 t1)\n        (phys/lagrangian-action L p2 t0 t1)))\n(compare-two-paths (lambda (t) t) (lambda (t) (* t t)) 0 1)"
                     :emergent "A path-comparison tool — chaining phys/lagrangian-action across two paths lets the operator find the stationary (physical) one by comparison."
                     :meta "Same family as variational-mechanics teaching in SICM. Cross-reference book-of-math ch 13; book-of-motion ch 22. Familiar analog: Feynman's path-integral thought experiments.")
                    (:eng "Action + comparison = variational solver." :math "Extremization of S over paths gives EL equations." :cs "O(N) per path; O(k·N) for k candidates.")))

(verb
  :name "phys/nbody"
  :library "phys"
  :kind "meta"
  :signature "(phys/nbody bodies [opts]) -> result-or-async-token"
  :summary "Simulate n-body gravitational dynamics at scale, backed by hardware accelerator or cloud service."
  :explanation "This verb solves the n-body problem: simulating the motion of many point masses under mutual gravitational attraction. For small n (< ~10) use phys/gravitational-force directly with world/spawn. For large n (hundreds to millions of bodies), phys/nbody delegates to a backend—either local GPU or remote service—and returns either a final result or an async token to poll for completion. This is a convenience wrapper that hides the complexity of parallelization and convergence."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/nbody '((m1 . ((mass . 1) (pos . (0 0 0)) (vel . (0 0 0))))\n              (m2 . ((mass . 1) (pos . (10 0 0)) (vel . (0 5 0))))))" :note "Two 1 kg masses: m1 at origin at rest, m2 at 10 m away moving at 5 m/s tangentially. Returns final configuration after dynamics.")
    (:dialect "motoi" :tier "intermediate" :code "(define (solar-system-snapshot)\n  (phys/nbody '((sun . ((mass . 1.989e30) (pos . (0 0 0)) (vel . (0 0 0))))\n                 (earth . ((mass . 5.972e24) (pos . (1.496e11 0 0)) (vel . (0 29780 0))))\n                 (mars . ((mass . 6.417e23) (pos . (2.279e11 0 0)) (vel . (0 24070 0))))\n                 (jupiter . ((mass . 1.898e27) (pos . (7.785e11 0 0)) (vel . (0 13070 0))))) \n               '(time-seconds 31536000)))\n(solar-system-snapshot)" :note "Simulate one year of the inner solar system. Returns positions/velocities after 1 year of mutual gravity.")
    (:dialect "motoi" :tier "expert" :code "(define async-poll (lambda args (list \"async-poll\" args)))\n(define async-ready? (lambda args (list \"async-ready?\" args)))\n(define (async-nbody-check bodies-list time-step backend-hint)\n  (let ((token (phys/nbody bodies-list (list 'use-backend backend-hint 'time-seconds time-step))))\n    (define (poll-until-done token max-wait)\n      (let ((result (async-poll token)))\n        (if (async-ready? result)\n          result\n          (if (> max-wait 0)\n            (begin (wait 100) (poll-until-done token (- max-wait 1)))\n            '*timeout*))))\n    (poll-until-done token 100)))\n(async-nbody-check '((... bodies ...)) 3600 'gpu-cluster)" :note "Submit large n-body to GPU backend, poll for completion. Shows how to handle async results from a scalable backend.")
  )
  :caveats ("Backend option '('use-backend ...) is required for large-scale runs; synchronous mode is slow for n > 1000." "Async tokens have a finite lifetime; polling after expiry may fail." "Silent failure if backend is unavailable; check for null or error tokens before using results." "Numerical precision degrades for very long integrations or very close approaches.")
  :drawbacks ("Much slower than specialized n-body codes (Gadget, GAMER) due to Scheme overhead." "No collision handling or softening of singularities at r→0." "Large memory footprint for millions of bodies; distributed storage not automated." "Backend availability and latency are external dependencies; may timeout or queue.")
  :usecases ("Galaxy cluster simulations: understanding structure formation under gravity." "Asteroid field dynamics: predicting collisions and orbital evolution." "Comparative planetology: testing stability of multi-planet systems." "Swarm robotics: simulating flocking under virtual gravity (metaphorical).")
  :related ("phys/gravitational-force" "phys/kinematics" "world/spawn" "world/step")
  :learn (:concept "The n-body problem is intractable analytically but solvable numerically; large-scale simulation requires backends. This verb bridges Scheme and high-performance infrastructure." :prerequisites ("phys/gravitational-force to understand the forces between pairs." "phys/kinematics for numerical integration of trajectories.") :progression "For small systems use phys/gravitational-force + manual integration. For large systems learn phys/nbody and async patterns.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator wants to simulate an entire solar system for one year. Ten planets, each interacting gravitationally with all others. Manual integration is impractical."
                 :program "(define bodies\n  '((sun . ((mass . 1.989e30) (pos . (0 0 0)) (vel . (0 0 0))))\n    (earth . ((mass . 5.972e24) (pos . (1.496e11 0 0)) (vel . (0 29780 0))))))\n(phys/nbody bodies '(time-seconds 31536000))"
                 :explanation "Line 1-3 build the bodies list with mass, position, velocity. Line 4 calls phys/nbody with a 1-year duration. The verb returns either a final configuration or an async token. The audit trail: input bodies, output final state."
                 :meta "Reaching for pairwise phys/gravitational-force works for 2 bodies; at n=10, that's 45 pairs per step and thousands of steps — hopeless in Scheme. phys/nbody is the honest answer because it delegates to a backend built for scale.")
                (:eng "One call replaces thousands of pairwise force computations." :math "n-body ODE integrated numerically." :cs "Delegates to GPU or remote backend; returns token or result."))
  :row-3-dimension ((:setup "A many-body coupled ODE solved by delegation."
                     :rungs ((:domain "phys" :code "(phys/nbody '((m1 . ((mass . 1) (pos . (0 0 0)) (vel . (0 0 0))))) '(time-seconds 60))")
                             (:domain "distributed compute-job submission (metaphor)" :code "(define (submit-job job backend) (list 'submitted job 'to backend))\n(submit-job 'nbody-sim 'gpu-cluster)")
                             (:domain "delegation to an external solver" :code "(define (delegate problem solver) (solver problem))\n(delegate 'nbody (lambda (p) 'done))"))
                     :explanation "In phys, an n-body system is submitted to a backend. In distributed computing, a job is submitted to a cluster — same delegation. In math, a problem is passed to a solver. All three share the delegation-to-backend shape."
                     :meta "The shape transfers because delegation to a specialized executor is universal in high-performance and scientific computing.")
                    (:eng "One shape covers physics simulation, cluster jobs, and general solver delegation." :math "Problem instance → solver instance → result." :cs "Async token or synchronous return; O(N²) or O(N log N) depending on solver."))
  :row-4-proof ((:claim "For a system with pairwise-symmetric forces, total momentum is conserved: Σ mᵢvᵢ at t=T equals Σ mᵢvᵢ at t=0. This is Newton's third law → conservation of momentum invariant."
                 :program "(define (total-momentum bodies)\n  (let loop ((bs bodies) (px 0) (py 0))\n    (if (null? bs) (list px py)\n        (let* ((b (car bs))\n               (mass (cdr (assq 'mass (cdr b))))\n               (vel (cdr (assq 'vel (cdr b)))))\n          (loop (cdr bs) (+ px (* mass (car vel))) (+ py (* mass (cadr vel))))))))\n(define bodies-start '((a mass 1 vel (5 0)) (b mass 1 vel (-5 0))))\n(total-momentum '((a . ((mass . 1) (vel . (5 0)))) (b . ((mass . 1) (vel . (-5 0))))))"
                 :invariant "Σ mᵢvᵢ(0) = Σ mᵢvᵢ(T) for all T"
                 :meta "A solver that failed momentum conservation would predict runaway drift. Falsification is any run where total momentum drifts. CS pattern: 'symplectic integrator invariant'. Book-of-motion ch 22; book-of-math ch 14.")
                (:eng "Momentum conservation is the correctness check for n-body integrators." :math "Newton's third law: internal forces sum to zero." :cs "Post-run assertion on total momentum."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/nbody simulates many-body gravitational dynamics."
                     :composition "(define (predict-future-earth years)\n  (define solar-system\n    '((sun . ((mass . 1.989e30) (pos . (0 0 0)) (vel . (0 0 0))))\n      (earth . ((mass . 5.972e24) (pos . (1.496e11 0 0)) (vel . (0 29780 0))))))\n  (phys/nbody solar-system (list 'time-seconds (* years 31536000))))\n(predict-future-earth 10)"
                     :emergent "A long-term orbital predictor — chaining phys/nbody with a time-scale wrapper produces a decade-scale predictor, which single-step integration cannot."
                     :meta "Same family as JPL Horizons ephemeris service, or KSP orbital-mechanics simulators. Cross-reference book-of-motion ch 22. Familiar analog: NASA's SPICE toolkit.")
                    (:eng "One primitive + time-scale = ephemeris service." :math "Numerical integration over long baselines; error accumulates as O(t)." :cs "Delegated to backend; async for large N or long T.")))

(verb
  :name "phys/q*"
  :library "phys"
  :kind "meta"
  :signature "(phys/q* qty1 qty2) -> product-quantity"
  :summary "Multiply two physical quantities: values multiply, dimensions add (exponents concatenate)."
  :explanation "This verb implements dimensional multiplication: if q₁ = v₁ × [D₁] and q₂ = v₂ × [D₂], then q₁ × q₂ = (v₁×v₂) × [D₁+D₂]. The dimension a-list exponents are added: [L¹T⁻²] × [M] = [M L¹ T⁻²] (force). This is the arithmetic foundation for building complex physical quantities from simpler ones. All quantities must be well-formed (numeric value paired with a-list dimension); dimensionally inconsistent combinations are caught by downstream verbs."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/q* '(2 . ((mass . 1))) '(3 . ((length . 1))))" :note "2 kg × 3 m = 6 (kg·m). Dimension exponent sums: mass has 1, length has 1.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((force '(10 . ((mass . 1) (length . 1) (time . -2))))\n      (displacement '(5 . ((length . 1)))))\n  (phys/q* force displacement))" :note "Force × distance = work. [M L T⁻²] × [L] = [M L² T⁻²] (energy). Shows composition of realistic physical quantities.")
    (:dialect "motoi" :tier "expert" :code "(define (work-along-path force-magnitude path-length angles)\n  (let* ((force-vec (phys/q* force-magnitude (cos (car angles))))\n         (work (phys/q* force-vec path-length)))\n    work))\n(define f-mag '(100 . ((mass . 1) (length . 1) (time . -2))))\n(define d '(10 . ((length . 1))))\n(work-along-path f-mag d '(0))" :note "Compute work as force × distance × cos(θ). Shows phys/q* embedded in a realistic physics calculation.")
  )
  :caveats ("Silently passes wrong-dimension quantities through; errors manifest when results are used in type-sensitive operations." "Numeric overflow is unchecked; very large or very small values may lose precision." "Order matters for non-commutative operators (none built in, but matters for user-defined structures)." "Dimension a-lists must be normalized (exponent of 0 should be omitted); unnormalized inputs may cause subtle bugs.")
  :drawbacks ("No automatic simplification or unit conversion." "Cannot multiply by scalar without wrapping the scalar in a quantity with empty dimensions (e.g., '(2 . ()))." "No support for divided quantities (use phys/q/ instead)." "Expensive for high-dimensional configuration spaces (real-world problems often have 10+ dimensions).")
  :usecases ("Building complex quantities: force = mass × acceleration." "Energy calculations: work = force × distance, power = energy / time." "Dimensional consistency checking: verifying formulas before applying them." "Teaching dimensional analysis: demonstrating how units combine.")
  :related ("phys/q/" "phys/q+" "phys/dimension" "phys/same-dimension?")
  :learn (:concept "Physical quantities are products of scalars and dimensions; multiplication scales both. This is the foundation of dimensional analysis." :prerequisites ("phys/dimension to understand what an a-list dimension is." "Understanding of a-lists (car/cdr pairs) for the implementation.") :progression "After phys/q*, learn phys/q/ (multiplication in reverse) and phys/q+ (addition of like dimensions), then phys/gravitational-force and phys/kinematics to see them in action.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator has a force in newtons and a distance in meters. They need work (J = N·m) and want dimensional analysis to certify the result."
                 :program "(define force '(10 . ((mass . 1) (length . 1) (time . -2))))\n(define dist '(5 . ((length . 1))))\n(phys/q* force dist)"
                 :explanation "Line 1-2 the two quantities. Line 3 computes work: 10 N × 5 m = 50 J, with dimensions [M L T⁻²] × [L] = [M L² T⁻²] (energy). Audit trail: two named inputs, one multiplication, dimensions auto-computed."
                 :meta "Reaching for raw (* 10 5) would compute 50 but lose the dimensional signature. phys/q* is honest because it preserves dimensions through multiplication.")
                (:eng "Dimensional bookkeeping automatic." :math "Values multiply; dimension exponents add." :cs "O(k) merge of exponent alists."))
  :row-3-dimension ((:setup "Multiplication that tracks a type signature."
                     :rungs ((:domain "phys" :code "(phys/q* '(2 . ((mass . 1))) '(3 . ((length . 1))))")
                             (:domain "matrix multiplication with dimension tags (metaphor)" :code "(define (tagged-mm a-shape b-shape a-val b-val)\n  (list (list (car a-shape) (cadr b-shape))\n        (* a-val b-val)))\n(tagged-mm '(3 2) '(2 4) 5 6)")
                             (:domain "monoid on labelled scalars" :code "(define (times-tagged a-val a-tag b-val b-tag)\n  (list (* a-val b-val) (append a-tag b-tag)))\n(times-tagged 2 '(m) 3 '(l))"))
                     :explanation "In phys, q* multiplies with dimension tracking. In tagged matrix ops, shape multiplication is analogous. In math, the monoid of labelled scalars generalizes it. All three multiply values while manipulating type tags."
                     :meta "The shape transfers because 'multiplication with type propagation' is a monoid operation on labelled scalars.")
                    (:eng "One shape covers physics, tagged linear algebra, general typed arithmetic." :math "Monoid on scalars × ExponentVec." :cs "O(k) dimension merge; O(1) value multiplication."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "phys/q* is associative and commutative: (q* q1 (q* q2 q3)) = (q* (q* q1 q2) q3) and (q* q1 q2) = (q* q2 q1). This is the abelian-monoid invariant."
                 :program "(define a '(2 . ((mass . 1))))\n(define b '(3 . ((length . 1))))\n(define c '(4 . ((time . -1))))\n(define (approx-q qa qb) (< (abs (- (car qa) (car qb))) 0.001))\n(and (approx-q (phys/q* a b) (phys/q* b a))\n     (approx-q (phys/q* (phys/q* a b) c)\n               (phys/q* a (phys/q* b c))))"
                 :invariant "q* is associative and commutative"
                 :meta "Non-associativity would break formula rewrites (F·d = d·F should be equal). Falsification is any triple violating either law. CS pattern: 'abelian monoid'. Book-of-math ch 3.")
                (:eng "Formula rewrites (physics identities) depend on this." :math "Scalar multiplication is commutative; exponent addition is commutative." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/q* multiplies dimensioned quantities."
                     :composition "(define (energy-from-power power time)\n  (phys/q* power time))\n(define P '(100 . ((mass . 1) (length . 2) (time . -3))))\n(define t '(60 . ((time . 1))))\n(energy-from-power P t)"
                     :emergent "A power-times-time energy calculator — chaining phys/q* with named quantities produces an energy computer, which the primitive alone does not express."
                     :meta "Same family as any dimensionally-aware calculator (WolframAlpha, Frink). Cross-reference book-of-math ch 12. Familiar analog: Excel + units add-in.")
                    (:eng "One primitive = a physical quantity calculator." :math "Composition of monoid operations." :cs "O(k) per composition.")))

(verb
  :name "phys/q+"
  :library "phys"
  :kind "meta"
  :signature "(phys/q+ q1 q2) -> quantity"
  :summary "Add two quantities; both must have identical dimensions or raises 'shape-error."
  :explanation "Quantities pair a numeric value with a dimension exponent vector (length, mass, time, etc.). Addition is meaningful only when both operands share the same dimensional structure. This verb performs componentwise value addition and validates dimensional homogeneity. It teaches the principle that physical quantities form a vector space only within each dimension class."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((d1 (phys/quantity 5.0 '((length . 1) (mass . 0) (time . 0))))\n      (d2 (phys/quantity 3.0 '((length . 1) (mass . 0) (time . 0)))))\n  (phys/q+ d1 d2))" :note "Two lengths (5m + 3m) sum to a length quantity; dimensions match, result is a new quantity with value 8.0")
    (:dialect "motoi" :tier "intermediate" :code "(define (distance-sum t1 t2)\n  (let ((v1 (* 10.0 t1)) (v2 (* 8.0 t2)))\n    (phys/q+ (phys/quantity v1 '((length . 1)))\n             (phys/quantity v2 '((length . 1))))))\n(distance-sum 2.0 3.0)" :note "Computes two distances via velocity×time, then adds them; ensures both operands have identical dimension before summing")
    (:dialect "motoi" :tier "expert" :code "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(define (net-displacement steps)\n  (fold-left (lambda (acc step-dist)\n              (phys/q+ acc step-dist))\n            (phys/quantity 0.0 '((length . 1)))\n            steps))\n(net-displacement (list (phys/quantity 2.5 '((length . 1)))\n                        (phys/quantity 1.3 '((length . 1)))\n                        (phys/quantity 0.7 '((length . 1)))))" :note "Folds addition over a list of distance quantities; dimension validation ensures every step matches the accumulator")
  )
  :caveats ("Both arguments must be quantities (not bare numbers); bare numbers will fail." "Dimension a-lists must match exactly—even exponent 0 entries must be present and align." "Addition is commutative and associative; order does not matter for result value." "Attempting to add incompatible dimensions (e.g., length + time) raises 'shape-error and halts the computation.")
  :drawbacks ("Requires explicit dimension specification for every quantity; verbose for simple calculations." "No implicit coercion (e.g., cm + m requires manual scaling beforehand)." "If dimension structures are stored inconsistently, mismatches may not be caught until runtime.")
  :usecases ("Accumulating distances or displacements in a navigation or kinematics simulation." "Summing forces or accelerations in a physics solver." "Validating unit consistency in an engineering calculation at the language level.")
  :related ("phys/q*" "phys/q/" "phys/dimension" "phys/same-dimension?" "phys/quantity" "phys/quantity->tag")
  :learn (:concept "Dimensional analysis as a type constraint; addition requires dimensional homogeneity." :prerequisites ("phys/quantity" "phys/dimension") :progression "After mastering q+, learn phys/q* and phys/q/ to compose dimensions; then phys/same-dimension? to query equivalence.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator has two distances measured in the same units and wants their sum. They also want protection against accidentally adding a distance to a time."
                 :program "(define d1 (phys/quantity 5.0 '((length . 1))))\n(define d2 (phys/quantity 3.0 '((length . 1))))\n(phys/q+ d1 d2)"
                 :explanation "Line 1-2 build two length quantities. Line 3 adds them, returning 8.0 m. If d2 had been a time, phys/q+ would raise a shape-error rather than compute nonsense. The audit trail: named quantities + one call; the runtime enforces dimensional homogeneity."
                 :meta "Reaching for (+ 5.0 3.0) would silently produce 8, no dimensional check. phys/q+ is honest because it catches unit-mismatch bugs at the point of the error, not downstream.")
                (:eng "Type-safe addition; unit-mismatch raises fast." :math "Component-wise addition when dimensions match; error otherwise." :cs "Equality check + O(1) addition."))
  :row-3-dimension ((:setup "Homogeneous addition constrained by a type predicate."
                     :rungs ((:domain "phys" :code "(phys/q+ (phys/quantity 5.0 '((length . 1))) (phys/quantity 3.0 '((length . 1))))")
                             (:domain "typed vector addition (metaphor)" :code "(define (typed-vec-add a-type b-type a-val b-val)\n  (if (equal? a-type b-type)\n      (list a-type (+ a-val b-val))\n      'type-error))\n(typed-vec-add 'meters 'meters 5 3)")
                             (:domain "addition in a vector space" :code "(define (vs-add v1 v2 space)\n  (if (eq? (car v1) space)\n      (list space (+ (cadr v1) (cadr v2)))\n      'wrong-space))\n(vs-add '(R 5) '(R 3) 'R)"))
                     :explanation "In phys, q+ adds dimensioned quantities. In typed programming, addition constrained by type is the same shape. In math, addition within a vector space is the archetype. All three are the same: 'add if compatible, error otherwise.'"
                     :meta "The shape transfers because vector-space addition requires operands in the same space; whether the substrate is dimensions, types, or algebraic vector spaces, the constraint is identical.")
                    (:eng "One shape covers physics, typed math, and general algebra." :math "Vector-space addition." :cs "Type check + addition."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "phys/q+ is commutative and associative on dimensionally-homogeneous quantities: (q+ a b) = (q+ b a) and (q+ (q+ a b) c) = (q+ a (q+ b c)). This is the abelian-group invariant on the compatible subspace."
                 :program "(define a (phys/quantity 2.0 '((length . 1))))\n(define b (phys/quantity 3.0 '((length . 1))))\n(define c (phys/quantity 5.0 '((length . 1))))\n(and (equal? (phys/q+ a b) (phys/q+ b a))\n     (equal? (phys/q+ (phys/q+ a b) c) (phys/q+ a (phys/q+ b c))))"
                 :invariant "phys/q+ is commutative and associative on homogeneous quantities"
                 :meta "Non-commutativity would break physics formula rewrites. Falsification is any two compatible quantities where a+b ≠ b+a. CS pattern: 'abelian group on subspace'. Book-of-math ch 3.")
                (:eng "Formula manipulation depends on this." :math "Real addition is commutative and associative." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/q+ adds two dimensionally-homogeneous quantities."
                     :composition "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(define (total-length legs)\n  (fold-left phys/q+ (phys/quantity 0.0 '((length . 1))) legs))\n(total-length (list (phys/quantity 2.5 '((length . 1)))\n                    (phys/quantity 1.3 '((length . 1)))))"
                     :emergent "A dimension-safe sum — chaining phys/q+ through fold-left produces a total length that is verified to be all lengths, which the primitive alone does not express."
                     :meta "Same family as SQL SUM with type constraint, or numpy's typed sum. Cross-reference book-of-math ch 3. Familiar analog: Pandas' typed column sum.")
                    (:eng "Fold + q+ = a dimension-safe total." :math "Repeated group operation; identity is zero-of-dimension." :cs "O(n) fold.")))

(verb
  :name "phys/q/"
  :library "phys"
  :kind "meta"
  :signature "(phys/q/ q1 q2) -> quantity"
  :summary "Divide two quantities; the result's dimension is q1's exponents minus q2's exponents."
  :explanation "Division of quantities is a dual operation to multiplication. The numeric values divide (q1-value / q2-value), and the dimension exponents are subtracted elementwise. This allows constructing derived units: dividing distance by time yields velocity, dividing velocity by time yields acceleration. Unlike addition, q1 and q2 need not share dimensions."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((dist (phys/quantity 100.0 '((length . 1) (time . 0))))\n      (time (phys/quantity 5.0 '((length . 0) (time . 1)))))\n  (phys/q/ dist time))" :note "100 m ÷ 5 s yields a quantity with value 20.0 and dimension (length . 1) (time . -1), representing velocity")
    (:dialect "motoi" :tier "intermediate" :code "(define vel-2 'vel-2)\n(define (acceleration a-change t-change)\n  (let ((vel-1 (phys/quantity 10.0 '((length . 1) (time . -1))))\n        (vel-2 (phys/quantity 25.0 '((length . 1) (time . -1))))\n        (dv (phys/q+ vel-2 (phys/quantity (- 10.0) '((length . 1) (time . -1))))))\n    (phys/q/ dv (phys/quantity t-change '((time . 1))))))\n(acceleration 1.0 3.0)" :note "Computes Δv/Δt by dividing a velocity change by a time interval; dimension arithmetic produces acceleration (length . 1) (time . -2)")
    (:dialect "motoi" :tier "expert" :code "(define (decay-constant half-life)\n  (phys/q/ (phys/quantity (log 2.0) '())\n           (phys/quantity half-life '((time . 1)))))\n(decay-constant 5730.0)" :note "ln(2) / t_half yields decay constant λ with dimension (time . -1); dimensionless numerator ÷ time = inverse time")
  )
  :caveats ("Divisor (q2) must be non-zero; division by zero raises an error." "Dimensions are subtracted: if q2 has (time . 1), the result will have (time . -1) in that slot." "Result may have negative or fractional exponents, representing derived or fractional dimensions." "No automatic simplification of dimension exponents (e.g., length²/length is stored as (length . 1), not simplified).")
  :drawbacks ("Chained divisions can produce complex dimension exponents; hard to read without dimensional inspection." "Numerical precision may degrade in successive divisions (accumulated floating-point error)." "No unit coercion; dividing (100 cm) by (5 m) requires manual scaling beforehand.")
  :usecases ("Computing velocities from position and time." "Deriving accelerations, reaction rates, and other ratios from measured or simulated quantities." "Defining derived units (e.g., force = mass × acceleration) via dimensional composition.")
  :related ("phys/q+" "phys/q*" "phys/dimension" "phys/quantity" "phys/kinematics")
  :learn (:concept "Dimensional exponents follow the rules of exponent arithmetic during division (subtraction)." :prerequisites ("phys/quantity" "phys/q*") :progression "After q/, explore phys/kinematics which divides distances and times to yield velocities; then model more complex derived quantities.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator has a distance (100 m) and a time (5 s). They need velocity — a derived quantity with dimensions (length . 1) (time . -1)."
                 :program "(define d (phys/quantity 100.0 '((length . 1))))\n(define t (phys/quantity 5.0 '((time . 1))))\n(phys/q/ d t)"
                 :explanation "Line 1-2 the two named quantities. Line 3 divides: 20.0 m/s, with dimensions (length . 1) (time . -1). The audit trail: two inputs, one call; velocity dimensions are derived automatically."
                 :meta "Reaching for raw (/ 100 5) gives 20 with no unit context. phys/q/ is honest because it produces a dimensioned velocity, ready for further composition.")
                (:eng "Named derivation of velocity from distance and time." :math "Values divide; dimension exponents subtract." :cs "O(k) subtraction of exponent alists."))
  :row-3-dimension ((:setup "Division that subtracts type-signature exponents."
                     :rungs ((:domain "phys" :code "(phys/q/ (phys/quantity 100 '((length . 1))) (phys/quantity 5 '((time . 1))))")
                             (:domain "SQL rate calculation (metaphor)" :code "(define (rate total-events over-seconds)\n  (/ total-events over-seconds))\n(rate 100 5)")
                             (:domain "reciprocal in a group" :code "(define (divide-tagged a-val a-exp b-val b-exp)\n  (list (/ a-val b-val) (- a-exp b-exp)))\n(divide-tagged 100 1 5 1)"))
                     :explanation "In phys, q/ divides with dimension subtraction. In SQL, computing a rate is a division that implicitly derives a per-time quantity. In math, division subtracts exponents when values are labelled. All three are the same reciprocal-in-a-group operation."
                     :meta "The shape transfers because 'divide with exponent-arithmetic' is universal in dimensioned computation.")
                    (:eng "One shape covers physics, analytics rates, and typed arithmetic." :math "Group inverse; exponent subtraction." :cs "O(k) merge with inverse."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "phys/q/ is the inverse of phys/q*: (q/ (q* a b) b) = a for compatible dimensions. This is the group-inverse invariant."
                 :program "(define a (phys/quantity 5.0 '((length . 1))))\n(define b (phys/quantity 2.0 '((time . 1))))\n(define (approx-q qa qb) (< (abs (- (car qa) (car qb))) 0.001))\n(approx-q (phys/q/ (phys/q* a b) b) a)"
                 :invariant "(q/ (q* a b) b) = a for all a, b"
                 :meta "Failure would mean q* and q/ don't cancel — physical formulas would drift. Falsification is any pair where the roundtrip differs. CS pattern: 'group inverse'. Book-of-math ch 3.")
                (:eng "Roundtrip invariance is what makes formula rewrites correct." :math "Group: q/ is the inverse of q*." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/q/ divides two dimensioned quantities."
                     :composition "(define (acceleration v-final v-initial dt)\n  (phys/q/ (phys/q+ v-final (phys/q* v-initial (phys/quantity -1.0 '()))) dt))\n(acceleration (phys/quantity 20.0 '((length . 1) (time . -1)))\n              (phys/quantity 10.0 '((length . 1) (time . -1)))\n              (phys/quantity 2.0 '((time . 1))))"
                     :emergent "An acceleration calculator — chaining phys/q/ with phys/q+ produces acceleration from velocity change and time interval, deriving [L T⁻²] naturally."
                     :meta "Same family as any dimensioned calculator. Cross-reference book-of-math ch 12. Familiar analog: physics problem-set solver.")
                    (:eng "q+ + q/ = acceleration; dimension derives itself." :math "Chained group operations." :cs "O(k) per operation.")))

(verb
  :name "phys/quantity"
  :library "phys"
  :kind "meta"
  :signature "(phys/quantity value dimensions) -> quantity"
  :summary "Build a dimensioned quantity from a numeric value and a dimension exponent a-list."
  :explanation "A quantity pairs a scalar value (typically a floating-point measurement) with a dimension signature—an association list of SI base dimensions and their exponents. The dimension structure (length, mass, time, current, temperature, amount, luminosity) encodes what kind of physical measurement this number represents. This verb is the gateway to dimensional arithmetic; all operations like q+, q*, q/ expect quantities as input."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/quantity 9.8 '((length . 1) (time . -2)))" :note "Standard gravity: 9.8 m/s². The dimension a-list says length^1 × time^-2, marking this as an acceleration.")
    (:dialect "motoi" :tier "intermediate" :code "(define (make-distance meters)\n  (phys/quantity meters '((length . 1) (mass . 0) (time . 0))))\n(define (make-time seconds)\n  (phys/quantity seconds '((length . 0) (mass . 0) (time . 1))))\n(phys/q/ (make-distance 45.0) (make-time 3.0))" :note "Helper constructors for common measurements; dividing distance by time via q/ yields velocity with correct dimension.")
    (:dialect "motoi" :tier "expert" :code "(define (lagrangian-state m k)\n  (let ((mass-dim '((length . 0) (mass . 1) (time . 0)))\n        (spring-dim '((length . 0) (mass . 0) (time . -2))))\n    (list (phys/quantity m mass-dim)\n          (phys/quantity k spring-dim))))\n(lagrangian-state 2.0 100.0)" :note "Constructs mass and spring-constant quantities for a harmonic-oscillator setup; each carries its own dimensional semantics.")
  )
  :caveats ("The dimension a-list must be a proper a-list; malformed lists will cause errors in dimension-aware operations." "No validation that the value matches the declared dimensions (e.g., you can claim a negative time exponent but store a negative value)." "Dimension names must match those recognized by the interpreter (length, mass, time, current, temperature, amount, luminosity)." "Quantities are typically immutable; use phys/q+ or phys/q* to create derived quantities rather than mutating.")
  :drawbacks ("Verbose: every quantity requires explicit dimension specification, leading to repetitive code." "No implicit unit conversion (e.g., 1 km and 1000 m are different numeric values; you must scale manually)." "Dimension a-lists can be large and error-prone if constructed by hand; helper functions are recommended.")
  :usecases ("Initializing physical constants (e.g., gravitational constant G, Planck's constant)." "Storing measurement results with full dimensional context." "Building the input state for physics solvers (phys/kinematics, phys/lagrangian-action).")
  :related ("phys/dimension" "phys/quantity->tag" "phys/q+" "phys/q*" "phys/q/")
  :learn (:concept "Dimensioned types: a number without dimensional context is incomplete; pairing value and exponent vector makes physical meaning explicit." :prerequisites ("phys/dimension") :progression "After creating quantities, use phys/q+, phys/q*, phys/q/ to compose them; inspect with phys/quantity->tag and phys/same-dimension?.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator needs to create a mass measurement of 2 kg. They know the number and want it packaged as a dimensioned quantity ready for physics calculations."
                 :program "(define m (phys/quantity 2.0 '((mass . 1))))\nm"
                 :explanation "Line 1 pairs the value 2.0 with a mass dimension. Line 2 returns the quantity: (2.0 . ((mass . 1))). The audit trail is one construction; from this point on the value carries its dimension through every operation."
                 :meta "Reaching for raw 2.0 works until the first arithmetic operation, at which point dimensions are unrecoverable. phys/quantity is honest for 'this number IS a mass, tag it now.'")
                (:eng "Constructor with explicit dimension; downstream benefits from the tag." :math "Pair: (value, dimension-vec)." :cs "cons; O(1)."))
  :row-3-dimension ((:setup "Constructing a labelled scalar."
                     :rungs ((:domain "phys" :code "(phys/quantity 2.0 '((mass . 1)))")
                             (:domain "typed literal in a strongly-typed language (metaphor)" :code "(define (make-typed v type-tag) (list 'typed v type-tag))\n(make-typed 2.0 'kg)")
                             (:domain "labelled scalar in a group" :code "(define (labelled val label) (cons val label))\n(labelled 2.0 'mass)"))
                     :explanation "In phys, quantity pairs value + dimension. In typed languages, a value + type tag is analogous. In math, a labelled scalar is the archetype. All three are constructor patterns."
                     :meta "The shape transfers because pairing a value with a type is the constructor pattern of typed values.")
                    (:eng "One shape covers physics, typed programming, group theory." :math "Constructor of pairs." :cs "cons or list; O(1)."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "phys/quantity is invertible: applying phys/quantity and then extracting via car (value) and phys/dimension recovers the original inputs. This is the constructor-inverse invariant."
                 :program "(define v 2.0)\n(define d '((mass . 1)))\n(define q (phys/quantity v d))\n(and (equal? (car q) v)\n     (equal? (phys/dimension q) d))"
                 :invariant "value(quantity(v, d)) = v ∧ dimension(quantity(v, d)) = d"
                 :meta "Failure would corrupt the value or the dimension. Falsification is any (v, d) pair where extraction differs. CS pattern: 'constructor-projection inversion'. Book-of-code ch 5.")
                (:eng "Roundtrip fidelity is the correctness of the abstraction." :math "cons/car/cdr triangle." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/quantity builds a value-dimension pair."
                     :composition "(define (make-vector length-vec)\n  (map (lambda (component) (phys/quantity component '((length . 1)))) length-vec))\n(make-vector '(1.0 2.0 3.0))"
                     :emergent "A dimensioned vector — chaining phys/quantity with map gives a coordinate vector where each component carries the length dimension, richer than a plain list."
                     :meta "Same family as numpy structured arrays with named columns. Cross-reference book-of-math ch 12. Familiar analog: pint (Python unit library).")
                    (:eng "One constructor + map = a typed vector." :math "Product of labelled scalars." :cs "O(N) map.")))

(verb
  :name "phys/quantity->tag"
  :library "phys"
  :kind "meta"
  :signature "(phys/quantity->tag quantity) -> a-list"
  :summary "Render a quantity as a human-readable a-list with keys ':value and ':dimension."
  :explanation "Quantities are opaque or structured objects; to display or inspect them, you need a readable representation. This verb extracts the value and dimension signature and returns an a-list like '((:value 9.8) (:dimension ((length . 1) (time . -2))))—ideal for logging, debugging, or passing quantities to user-facing output."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/quantity->tag (phys/quantity 5.0 '((length . 1))))" :note "Returns '((:value 5.0) (:dimension ((length . 1)))). Useful for inspecting a single quantity during development.")
    (:dialect "motoi" :tier "intermediate" :code "(define (display-result q label)\n  (let ((tag (phys/quantity->tag q)))\n    (display (list label\n                   ':value (cadr (assoc ':value tag))\n                   ':dim (cadr (assoc ':dimension tag))))))\n(display-result (phys/quantity 9.8 '((length . 1) (time . -2))) 'gravity)" :note "Wraps quantity->tag in a helper to format output; extracts and displays the numeric value and dimension separately.")
    (:dialect "motoi" :tier "expert" :code "(define (log-quantities measurements)\n  (map (lambda (name q)\n         (list name (phys/quantity->tag q)))\n       '(distance velocity acceleration)\n       measurements))\n(log-quantities (list (phys/quantity 100.0 '((length . 1)))\n                      (phys/quantity 20.0 '((length . 1) (time . -1)))\n                      (phys/quantity 2.0 '((length . 1) (time . -2)))))" :note "Logs a vector of physical quantities by converting each to a readable a-list; useful for exporting simulation results.")
  )
  :caveats ("The output is an a-list, not a pretty-printed string; you must format it further for display." "The ':value key contains the raw numeric value; no unit label is included." "The ':dimension value is the full exponent a-list, not a human-friendly symbol (e.g., 'm/s' is not generated)." "Calling quantity->tag on a non-quantity raises an error.")
  :drawbacks ("Does not simplify or normalize dimension exponents (e.g., (length . 1) (time . -1) is not rendered as 'm/s')." "No support for custom unit labels or conversion to alternate unit systems." "For very large or very small quantities, the numeric value is displayed as-is (no scientific notation helper).")
  :usecases ("Inspecting quantities in the REPL during debugging." "Serializing physical measurement results for logging or export." "Building introspection tools that display a quantity's value and dimensional class.")
  :related ("phys/quantity" "phys/dimension" "phys/kinetic-energy" "phys/kinematics")
  :learn (:concept "Extraction and rendering: opaque types require accessors to expose their contents in a readable form." :prerequisites ("phys/quantity") :progression "Use quantity->tag when you need to inspect or log results; then combine with phys/dimension for finer dimensional queries.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "During REPL debugging, the operator sees a raw quantity structure and wants a labelled readable form for a log line."
                 :program "(define q (phys/quantity 9.8 '((length . 1) (time . -2))))\n(phys/quantity->tag q)"
                 :explanation "Line 1 builds the acceleration quantity. Line 2 renders it as ((:value 9.8) (:dimension ((length . 1) (time . -2)))). The audit is one conversion; the log line becomes self-describing."
                 :meta "Reaching for car/cdr manually works but produces unlabelled output. phys/quantity->tag is the honest debug-render because it names both components.")
                (:eng "Log-line-ready rendering; keys are self-documenting." :math "Projection to a labelled alist." :cs "O(1) accessor + label."))
  :row-3-dimension ((:setup "Rendering an opaque structured value into a labelled form."
                     :rungs ((:domain "phys" :code "(phys/quantity->tag (phys/quantity 9.8 '((length . 1))))")
                             (:domain "record → JSON serialization (metaphor)" :code "(define (record->json rec)\n  (list ':value (car rec) ':type (cdr rec)))\n(record->json (cons 9.8 'accel))")
                             (:domain "canonical form of a labelled pair" :code "(define (canonical-form pair)\n  (list (cons ':first (car pair)) (cons ':second (cdr pair))))\n(canonical-form (cons 9.8 'x))"))
                     :explanation "In phys, quantity->tag renders. In serialization, record→JSON does the analogous rendering. In math, canonical-form is the archetype. All three project into a labelled canonical form."
                     :meta "The shape transfers because 'render structured value into labelled form' is the serialization pattern.")
                    (:eng "One shape covers physics, JSON, canonical forms." :math "Named projection." :cs "O(k) fields."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "phys/quantity->tag is inverse-recoverable: from the tag output, the original quantity's value and dimension can be reconstructed. This is the debug-render-fidelity invariant."
                 :program "(define q (phys/quantity 9.8 '((length . 1))))\n(define tag (phys/quantity->tag q))\n(define reconstructed (phys/quantity (cadr (assq ':value tag)) (cadr (assq ':dimension tag))))\n(equal? q reconstructed)"
                 :invariant "quantity(tag.value, tag.dimension) = original quantity"
                 :meta "Failure would mean rendering lost information. Falsification is any quantity that doesn't roundtrip through tag. CS pattern: 'lossless rendering'. Book-of-code ch 5.")
                (:eng "Lossless rendering means logs preserve everything needed." :math "Bijective projection." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/quantity->tag renders a quantity as a labelled alist."
                     :composition "(define (log-quantities named-qs)\n  (map (lambda (nq)\n         (list (car nq) (phys/quantity->tag (cdr nq))))\n       named-qs))\n(log-quantities (list (cons 'distance (phys/quantity 100.0 '((length . 1))))\n                      (cons 'velocity (phys/quantity 20.0 '((length . 1) (time . -1))))))"
                     :emergent "A structured-log emitter — chaining quantity->tag with map produces JSON-like log lines for each named quantity, which the primitive alone cannot express."
                     :meta "Same family as structured-logging libraries (Zap, slog). Cross-reference book-of-code ch 13. Familiar analog: JSON logging in Node.js.")
                    (:eng "One primitive + map = structured logging." :math "Map of a projection over a labelled list." :cs "O(N) map.")))

(verb
  :name "phys/rlc-damping"
  :library "phys"
  :kind "meta"
  :signature "(phys/rlc-damping R L C) -> (list zeta omega-0 regime)"
  :summary "Analyze a series RLC circuit's damping behavior; returns damping ratio ζ, natural frequency ω₀, and regime name."
  :explanation "A series RLC circuit (resistor, inductor, capacitor) is a classic second-order linear system. The damping ratio ζ (zeta) determines the response character: underdamped (ζ < 1) oscillates, critically damped (ζ = 1) returns fastest without overshoot, overdamped (ζ > 1) settles slowly without oscillation. The natural frequency ω₀ (omega-naught) is the characteristic frequency of oscillation. This verb computes both and classifies the regime, making it a teaching tool for control systems and circuit analysis."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/rlc-damping 100.0 0.1 0.000001)" :note "R=100Ω, L=0.1H, C=1µF. Returns (zeta ω₀ 'regime); inspect the regime to understand circuit behavior.")
    (:dialect "motoi" :tier "intermediate" :code "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (design-filter target-regime R L)\n  (let* ((C-candidates (list 0.000001 0.00001 0.0001))\n         (results (map (lambda (C) (phys/rlc-damping R L C)) C-candidates)))\n    (filter (lambda (r) (equal? (caddr r) target-regime)) results)))\n(design-filter 'critically-damped 100.0 0.01)" :note "Sweeps capacitor values to find which achieves critical damping; useful for filter design.")
    (:dialect "motoi" :tier "expert" :code "(define (rlc-response-time R L C)\n  (let ((analysis (phys/rlc-damping R L C)))\n    (let ((zeta (car analysis))\n          (omega-0 (cadr analysis)))\n      (cond\n        ((< zeta 1.0)\n         (/ (* 4.6 zeta) (* omega-0 (sqrt (- 1.0 (* zeta zeta))))))\n        ((= zeta 1.0) (/ 4.6 omega-0))\n        (else (/ 4.6 (* omega-0 zeta)))))))\n(rlc-response-time 50.0 0.05 0.000002)" :note "Uses ζ and ω₀ to estimate the 2% settling time; demonstrates how damping analysis feeds into timing calculations.")
  )
  :caveats ("Assumes ideal series RLC topology; distributed inductance or non-ideal components are not accounted for." "Returns numeric zeta and omega-0; very large or very small values may lose precision." "The regime classification is symbolic ('underdamped, 'critically-damped, 'overdamped); there is no continuous confidence metric." "ζ values very close to 1.0 (within floating-point epsilon) should be treated cautiously; behavior transitions sharply.")
  :drawbacks ("Does not simulate the actual response; only predicts the character and speed of response." "No account for parasitic resistances or environmental factors (temperature drift, aging)." "Requires component values as input; no inverse design (e.g., 'find R to achieve ζ=0.7').")
  :usecases ("Teaching or analyzing second-order circuit behavior in courses on control systems and analog electronics." "Tuning low-pass filters, bandpass filters, or notch filters to a target damping." "Predicting response speed and overshoot for a given RLC design before simulation or hardware test.")
  :related ("phys/kinematics" "phys/lagrangian-action" "phys/L-harmonic" "eng/statics-solve" "eng/tf")
  :learn (:concept "Damping ratio and natural frequency: the two key parameters that characterize second-order linear system behavior." :prerequisites ("phys/quantity") :progression "After understanding ζ and ω₀ from rlc-damping, study eng/tf and eng/bode to model and visualize frequency response of more complex systems.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator is designing a low-pass filter and wants to verify their R, L, C values give critical damping (ζ = 1) — fastest settle without overshoot."
                 :program "(define analysis (phys/rlc-damping 100.0 0.01 0.000004))\n(list (car analysis) (caddr analysis))"
                 :explanation "Line 1 runs the analysis for R=100Ω, L=10mH, C=4µF. Line 2 extracts ζ and the regime symbol. A well-designed filter yields ζ near 1 and regime = 'critically-damped. If the operator sees 'underdamped or 'overdamped, they know to adjust component values."
                 :meta "Reaching for hand computation of ζ = R/(2√(L/C)) works but ties formula to code; phys/rlc-damping names the physical intent and returns the regime symbolically.")
                (:eng "Named analysis; regime symbol is auditable." :math "ζ = R/(2√(L/C)); ω_n = 1/√(LC)." :cs "One call returns three items."))
  :row-3-dimension ((:setup "Analyzing a second-order linear system by its damping regime."
                     :rungs ((:domain "phys" :code "(phys/rlc-damping 100.0 0.01 0.000004)")
                             (:domain "mechanical mass-spring-damper (metaphor)" :code "(define (msd-analysis m c k)\n  (let ((omega-n (sqrt (/ k m)))\n        (zeta (/ c (* 2 (sqrt (* k m))))))\n    (list zeta omega-n)))\n(msd-analysis 1 4 100)")
                             (:domain "classification of ODE roots" :code "(define (classify-roots ds)\n  (cond ((< ds 0) 'oscillatory)\n        ((= ds 0) 'critical)\n        (else 'overdamped)))\n(classify-roots 0.5)"))
                     :explanation "In phys, RLC damping classifies. In mechanical MSD, the same ζ classifies. In math, root classification of a characteristic polynomial names the same regimes. All three classify a second-order system."
                     :meta "The shape transfers because second-order linear systems have three regimes universally.")
                    (:eng "One shape covers electronics, mechanics, and math." :math "Discriminant of characteristic polynomial." :cs "Case analysis."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "For any R > 0, L > 0, C > 0, ζ and ω₀ are strictly positive and finite. This is the well-posed-analysis invariant."
                 :program "(define (analysis R L C) (phys/rlc-damping R L C))\n(define a1 (analysis 100 0.1 0.000001))\n(define a2 (analysis 10 0.001 0.0001))\n(and (> (car a1) 0)\n     (> (cadr a1) 0)\n     (> (car a2) 0)\n     (> (cadr a2) 0))"
                 :invariant "R, L, C > 0 → ζ > 0 ∧ ω₀ > 0"
                 :meta "Failure would mean a negative or infinite ζ, which is nonphysical. Falsification is any positive R, L, C giving nonpositive ζ. CS pattern: 'well-posed analysis'. Book-of-motion ch 22; book-of-math ch 12.")
                (:eng "Positivity is the sanity check on the component input." :math "Positive definiteness of RLC yields positive ζ." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/rlc-damping analyzes an RLC circuit's damping regime."
                     :composition "(define (find-critical-C R L)\n  (let loop ((C 1e-9))\n    (let* ((analysis (phys/rlc-damping R L C))\n           (zeta (car analysis)))\n      (if (>= zeta 1.0) C\n          (loop (* C 1.1))))))\n(find-critical-C 100 0.01)"
                     :emergent "A design-search — chaining phys/rlc-damping in a loop finds the C that yields critical damping, which the analysis alone does not."
                     :meta "Same family as any component-value sweep in SPICE simulation. Cross-reference book-of-motion ch 22. Familiar analog: LTspice parametric sweep.")
                    (:eng "Analysis + search = a component sizer." :math "Root-finding via monotone search." :cs "O(log(C-range)) with bisection; O(N) with linear sweep.")))

(verb
  :name "phys/same-dimension?"
  :library "phys"
  :kind "meta"
  :signature "(phys/same-dimension? q1 q2) -> boolean"
  :summary "Predicate: do two quantities share the same dimension signature?"
  :explanation "Before adding quantities (via phys/q+), you may want to check dimensional compatibility without risking an error. This predicate returns true if and only if both quantities have identical dimension exponent a-lists. It is useful for conditional logic, filtering lists of measurements, or guarding arithmetic operations. Unlike phys/q+, this verb does not raise an error on mismatch; it simply returns false."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/same-dimension? (phys/quantity 5.0 '((length . 1)))\n                       (phys/quantity 3.0 '((length . 1))))" :note "Both are lengths; returns #t. Safe to add with phys/q+.")
    (:dialect "motoi" :tier "intermediate" :code "(define (safe-add q1 q2)\n  (if (phys/same-dimension? q1 q2)\n      (phys/q+ q1 q2)\n      (list ':error 'dimension-mismatch\n            ':q1 (phys/quantity->tag q1)\n            ':q2 (phys/quantity->tag q2))))\n(safe-add (phys/quantity 10.0 '((length . 1)))\n          (phys/quantity 5.0 '((time . 1))))" :note "Guards a potential addition; returns error info rather than crashing if dimensions don't match.")
    (:dialect "motoi" :tier "expert" :code "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (sum-homogeneous quantities)\n  (if (null? quantities)\n      (list ':empty)\n      (let ((first (car quantities))\n            (rest (cdr quantities)))\n        (let ((compatible (filter (lambda (q) (phys/same-dimension? q first)) rest)))\n          (fold-left phys/q+ first compatible)))))\n(sum-homogeneous (list (phys/quantity 2.0 '((length . 1)))\n                       (phys/quantity 3.0 '((length . 1)))\n                       (phys/quantity 1.5 '((time . 1)))))" :note "Sums only the quantities that share the first one's dimension, silently dropping incompatible items; useful for noisy or heterogeneous data.")
  )
  :caveats ("Compares dimension a-lists exactly; order matters. '((length . 1) (time . -1)) and '((time . -1) (length . 1)) may be treated as different if the implementation does not normalize." "Returns a boolean; it is a pure predicate with no side effects." "Does not perform unit conversion (e.g., meters and centimeters are considered dimensionally equivalent but numerically different)." "Calling on a non-quantity raises an error.")
  :drawbacks ("Cannot distinguish between different orderings of the same dimension a-list if the implementation is order-sensitive." "Does not suggest which dimension mismatches; for detailed error reporting, you must compare dimensions manually." "Checking many quantities for mutual compatibility requires O(n²) pairwise comparisons.")
  :usecases ("Validating that a list of measurements all represent the same physical quantity before summing." "Implementing safe arithmetic that gracefully handles dimension mismatches." "Building filters or assertions in data-processing pipelines to ensure dimensional consistency.")
  :related ("phys/q+" "phys/dimension" "phys/quantity" "phys/quantity->tag")
  :learn (:concept "Type checking at runtime: predicates allow you to query type properties (in this case, dimensional equivalence) before performing operations that assume compatibility." :prerequisites ("phys/quantity" "phys/dimension") :progression "Use same-dimension? to guard arithmetic; then combine with phys/q+ to safely compose quantities. Study phys/dimension for finer-grained dimensional inspection.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "Before adding two quantities from user input, the operator wants to verify they share dimensions — a graceful check that avoids raising a shape-error."
                 :program "(define q1 (phys/quantity 10.0 '((length . 1))))\n(define q2 (phys/quantity 5.0 '((length . 1))))\n(if (phys/same-dimension? q1 q2)\n    (phys/q+ q1 q2)\n    'error)"
                 :explanation "Line 1-2 the inputs. Line 3-4 guard-then-add. If dimensions match, phys/q+ runs safely. If not, the code returns 'error rather than raising. The audit trail: one predicate + conditional dispatch."
                 :meta "Reaching for phys/q+ directly with a try/catch would work but is verbose; phys/same-dimension? is the honest predicate for 'can these be added?'")
                (:eng "Predicate-gated arithmetic; no exceptions raised." :math "Equality of dimension exponent vectors." :cs "O(k) comparison."))
  :row-3-dimension ((:setup "Type-equality predicate for a tagged pair."
                     :rungs ((:domain "phys" :code "(phys/same-dimension? (phys/quantity 5 '((length . 1))) (phys/quantity 3 '((length . 1))))")
                             (:domain "isinstance check in a strongly-typed language (metaphor)" :code "(define (same-type? a b) (equal? (cadr a) (cadr b)))\n(same-type? '(val 5 meters) '(val 3 meters))")
                             (:domain "equivalence relation on type tags" :code "(define (equiv-tag t1 t2) (equal? t1 t2))\n(equiv-tag 'length 'length)"))
                     :explanation "In phys, same-dimension? compares dimension alists. In typed programming, isinstance-check is analogous. In math, equivalence relations on tags formalize it. All three are equality predicates on type-carrying components."
                     :meta "The shape transfers because 'type equality on tagged values' is universal for runtime type checking.")
                    (:eng "One shape covers physics, typed programming, general equivalence." :math "Reflexive-symmetric-transitive relation." :cs "O(k) comparison; pure."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "phys/same-dimension? is reflexive, symmetric, and transitive: it defines an equivalence relation on dimensioned quantities. This is the equivalence-relation invariant."
                 :program "(define q1 (phys/quantity 5 '((length . 1))))\n(define q2 (phys/quantity 3 '((length . 1))))\n(define q3 (phys/quantity 7 '((length . 1))))\n(and (phys/same-dimension? q1 q1)\n     (equal? (phys/same-dimension? q1 q2) (phys/same-dimension? q2 q1))\n     (or (not (and (phys/same-dimension? q1 q2) (phys/same-dimension? q2 q3)))\n         (phys/same-dimension? q1 q3)))"
                 :invariant "same-dimension? is reflexive, symmetric, and transitive"
                 :meta "Non-transitivity would break the ability to safely fold sums. Falsification is any triple where transitivity fails. CS pattern: 'equivalence relation'. Book-of-math ch 3.")
                (:eng "Equivalence-relation guarantees allow safe grouping of quantities." :math "The three properties define an equivalence." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/same-dimension? tests two quantities for dimensional equality."
                     :composition "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (partition-by-dimension quantities)\n  (if (null? quantities) '()\n      (let ((first (car quantities)))\n        (list (filter (lambda (q) (phys/same-dimension? q first)) quantities)))))\n(partition-by-dimension (list (phys/quantity 2 '((length . 1)))\n                              (phys/quantity 3 '((length . 1)))\n                              (phys/quantity 5 '((time . 1)))))"
                     :emergent "A dimensional partitioner — chaining phys/same-dimension? with a filter groups quantities by unit, which the predicate alone does not express."
                     :meta "Same family as SQL GROUP BY, or numpy's dtype-partitioning. Cross-reference book-of-code ch 12. Familiar analog: Pandas' groupby.")
                    (:eng "Predicate + filter = a partitioner." :math "Partition induced by an equivalence relation." :cs "O(N²) naive; O(N log N) with sorting.")))

(verb
  :name "phys/uncertainty-add"
  :library "phys"
  :kind "meta"
  :signature "(phys/uncertainty-add sigma-1 sigma-2 ... sigma-n) -> sigma-result"
  :summary "Propagate measurement uncertainties for a sum; combines standard deviations in quadrature."
  :explanation "When you add measured quantities with independent random errors, the total uncertainty is not the sum of individual uncertainties; instead, it is the square root of the sum of the variances (σ_total = √(σ₁² + σ₂² + … + σₙ²)). This is the root-sum-square or quadrature rule, and it arises from assuming errors are independent and follow a normal distribution. This verb implements that rule, enabling realistic error budgeting for sums of measurements."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/uncertainty-add 0.5 0.3)" :note "Combines uncertainties of 0.5 and 0.3 in quadrature; result is √(0.25 + 0.09) ≈ 0.583, not 0.8.")
    (:dialect "motoi" :tier "intermediate" :code "(define (total-distance-uncertainty legs)\n  (let ((sigmas (map cadr legs)))\n    (apply phys/uncertainty-add sigmas)))\n(total-distance-uncertainty (list '(leg1 0.1)\n                                  '(leg2 0.15)\n                                  '(leg3 0.08)))" :note "Extracts uncertainties from a list of (name . sigma) pairs and combines them; result reflects independent error accumulation.")
    (:dialect "motoi" :tier "expert" :code "(define (circuit-tolerance Vout-nominal dV1 dV2 dV3)\n  (let ((combined-dV (phys/uncertainty-add dV1 dV2 dV3)))\n    (let ((nominal-power (* Vout-nominal Vout-nominal)))\n      (list ':nominal-power nominal-power\n            ':tolerance (/ combined-dV Vout-nominal)))))\n(circuit-tolerance 5.0 0.02 0.03 0.01)" :note "Models output voltage tolerance from three independent error sources (e.g., resistor tolerances, noise); computes power and relative uncertainty.")
  )
  :caveats ("Assumes errors are independent; correlated errors will be underestimated." "Assumes normal (Gaussian) distribution; non-normal distributions may have different effective propagation rules." "All arguments should be positive (standard deviations); negative or zero values may produce unexpected results." "Very large or very small uncertainties can cause numerical overflow or underflow in the quadrature sum.")
  :drawbacks ("Does not track units or dimensions; you must manage dimensional consistency yourself." "No covariance support; complex correlations between measurements require manual handling." "Quadrature rule is optimistic if errors are not actually independent (e.g., common mode noise will inflate real uncertainty).")
  :usecases ("Budgeting measurement error in multi-sensor fusion or averaged data." "Estimating tolerance stack-up in mechanical or electrical assembly." "Teaching uncertainty propagation in experimental physics or metrology courses.")
  :related ("phys/uncertainty-mul" "phys/quantity" "stat/sd" "stat/variance")
  :learn (:concept "Independent errors combine in quadrature, not linearly; this is a fundamental rule in error analysis." :prerequisites ("stat/variance" "stat/sd") :progression "After learning uncertainty-add, study phys/uncertainty-mul for products, then model realistic measurement systems with both.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "Three consecutive length measurements each have independent uncertainties: ±0.5 mm, ±0.3 mm, ±0.4 mm. The operator wants the total uncertainty for the sum."
                 :program "(phys/uncertainty-add 0.5 0.3 0.4)"
                 :explanation "One call combines the three σ's in quadrature: √(0.25 + 0.09 + 0.16) = √0.50 ≈ 0.707 mm. Note: less than the linear sum 1.2 mm because errors are independent. The audit is one call; the physics of independent errors is encoded."
                 :meta "Reaching for (+ 0.5 0.3 0.4) would triple-count the errors, over-reporting uncertainty. phys/uncertainty-add is the honest answer for independent errors.")
                (:eng "Correct error budgeting; downstream consumers get accurate σ." :math "σ_total = √(Σ σᵢ²)." :cs "O(N) sum of squares + sqrt."))
  :row-3-dimension ((:setup "L² norm of a vector of scalars."
                     :rungs ((:domain "phys" :code "(phys/uncertainty-add 0.5 0.3 0.4)")
                             (:domain "vector magnitude in R³ (metaphor)" :code "(define (magnitude v)\n  (sqrt (apply + (map (lambda (x) (* x x)) v))))\n(magnitude '(0.5 0.3 0.4))")
                             (:domain "Euclidean norm" :code "(define (euclidean-norm xs)\n  (sqrt (apply + (map (lambda (x) (* x x)) xs))))\n(euclidean-norm '(0.5 0.3 0.4))"))
                     :explanation "In phys, uncertainty-add is quadrature. In R³, magnitude of a vector is √(x²+y²+z²) — same. In math, Euclidean norm is the archetype. All three are L² norms of a vector of scalars."
                     :meta "The shape transfers because independent standard deviations combine like orthogonal vector components; both are L² norms.")
                    (:eng "One shape covers error propagation, geometry, general norms." :math "L² norm; positive-definite." :cs "O(N) map + reduce + sqrt."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "phys/uncertainty-add is order-independent: (uncertainty-add a b c) = (uncertainty-add c a b) for any ordering. This is the commutativity invariant of the quadrature sum."
                 :program "(define (approx a b) (< (abs (- a b)) 0.0001))\n(and (approx (phys/uncertainty-add 0.5 0.3 0.4)\n             (phys/uncertainty-add 0.4 0.5 0.3))\n     (approx (phys/uncertainty-add 0.5 0.3 0.4)\n             (phys/uncertainty-add 0.3 0.4 0.5)))"
                 :invariant "uncertainty-add is symmetric under any permutation of arguments"
                 :meta "Non-commutativity would let a bug propagate order-dependence, which physics forbids. Falsification is any permutation with a different result. CS pattern: 'symmetric multi-argument reduction'. Book-of-math ch 8; book-of-ml ch 6.")
                (:eng "Order-independence is a signal that errors are truly summed." :math "L² norm depends only on the multiset of components." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/uncertainty-add combines independent σs in quadrature."
                     :composition "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(define (multi-measurement-uncertainty sigmas)\n  (apply phys/uncertainty-add sigmas))\n(multi-measurement-uncertainty (list 0.1 0.15 0.08 0.12))"
                     :emergent "A budget-of-errors aggregator — chaining apply with phys/uncertainty-add produces the total σ for any number of independent measurements."
                     :meta "Same family as engineering-tolerance stack-up analysis. Cross-reference book-of-ml ch 6 (error analysis). Familiar analog: Six Sigma tolerance analysis.")
                    (:eng "One primitive + apply = an error budget tool." :math "L² norm generalizes to N components." :cs "O(N).")))

(verb
  :name "phys/uncertainty-mul"
  :library "phys"
  :kind "meta"
  :signature "(phys/uncertainty-mul relative-sigma-1 relative-sigma-2 ... relative-sigma-n) -> relative-sigma-result"
  :summary "Propagate measurement uncertainties for a product; combines relative standard deviations in quadrature."
  :explanation "When you multiply measured quantities with independent random errors, the relative uncertainty in the product is the quadrature sum of the relative uncertainties (σ_result/result = √((σ₁/x₁)² + (σ₂/x₂)² + …)). This rule applies to any product: computing area from width × length, power from voltage × current, etc. Unlike uncertainty-add (which combines absolute errors), uncertainty-mul works with fractional or percentage errors, making it more practical for quantities with different scales."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(phys/uncertainty-mul 0.05 0.03)" :note "5% and 3% relative uncertainties multiply to a product uncertainty of √(0.05² + 0.03²) ≈ 5.8%, not 8%.")
    (:dialect "motoi" :tier "intermediate" :code "(define (power-uncertainty V-sigma I-sigma)\n  (let ((rel-V (/ V-sigma 5.0)) (rel-I (/ I-sigma 2.0)))\n    (let ((rel-P (phys/uncertainty-mul rel-V rel-I)))\n      (* rel-P 10.0))))\n(power-uncertainty 0.1 0.05)" :note "Given uncertainties in voltage (±0.1V @ 5V nominal) and current (±0.05A @ 2A nominal), computes power uncertainty; 10W nominal.")
    (:dialect "motoi" :tier "expert" :code "(define (photometric-efficiency LED-lumens-unc LED-watts-unc)\n  (let ((LED-power (phys/uncertainty-mul LED-watts-unc 0.02))\n        (LED-lum (phys/uncertainty-mul LED-lumens-unc 0.03)))\n    (let ((eta-unc (phys/uncertainty-mul LED-lum LED-power)))\n      (list ':efficiency-unc-fraction eta-unc\n            ':efficiency-unc-percent (* eta-unc 100.0)))))\n(photometric-efficiency 0.08 0.04)" :note "Chains uncertainty propagation for a derived quantity (lumens per watt); each operation adds to the uncertainty budget.")
  )
  :caveats ("Expects relative (fractional) uncertainties, not absolute. Mixing absolute and relative will give nonsense results." "Assumes errors are independent; correlated errors (e.g., both voltage and current measured by the same power supply) are not handled." "Very small relative uncertainties (< 1%) may suffer loss of precision in quadrature sum due to floating-point rounding." "Useful primarily for products; division and rational functions require more complex error-propagation formulas.")
  :drawbacks ("Does not handle covariance or common-mode errors; you must manually adjust if errors are correlated." "Result is dimensionless (a relative uncertainty); you must multiply by a nominal value to get absolute uncertainty." "Cannot directly handle mixed sums and products; you must decompose complex formulas into sum and product pieces.")
  :usecases ("Computing power tolerance (V_unc × I_unc) in circuits." "Budgeting error in area or volume measurements (width × length or width × length × height)." "Estimating yield loss or sensitivity in manufacturing, where small percentage variations compound.")
  :related ("phys/uncertainty-add" "phys/quantity" "stat/sd" "stat/variance")
  :learn (:concept "Relative errors in products combine in quadrature; fractional uncertainties propagate differently than absolute ones." :prerequisites ("stat/variance" "phys/uncertainty-add") :progression "After mastering uncertainty-mul and uncertainty-add, combine both to model mixed formulas (e.g., F = m × a, where a = Δv / Δt).")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator is computing power from voltage (5V ±2%) and current (2A ±3%). They need the relative uncertainty of power."
                 :program "(phys/uncertainty-mul 0.02 0.03)"
                 :explanation "One call combines the two relative σ's in quadrature: √(0.0004 + 0.0009) = √0.0013 ≈ 3.6%. Not 5% (that would double-count). The audit is one call; the physics of multiplicative independent errors is encoded."
                 :meta "Reaching for (+ 0.02 0.03) overestimates. phys/uncertainty-mul is the honest answer for products of independent quantities.")
                (:eng "Correct multiplicative-error budget." :math "(σ_P / P)² = (σ_V / V)² + (σ_I / I)²." :cs "O(N) quadrature."))
  :row-3-dimension ((:setup "L² norm of relative errors."
                     :rungs ((:domain "phys" :code "(phys/uncertainty-mul 0.02 0.03)")
                             (:domain "photographic exposure ratio (metaphor)" :code "(define (exposure-uncertainty aperture-unc shutter-unc iso-unc)\n  (sqrt (+ (* aperture-unc aperture-unc)\n           (* shutter-unc shutter-unc)\n           (* iso-unc iso-unc))))\n(exposure-uncertainty 0.02 0.03 0.01)")
                             (:domain "sum of squares of logarithmic errors" :code "(define (log-error-sum les)\n  (sqrt (apply + (map (lambda (e) (* e e)) les))))\n(log-error-sum '(0.02 0.03))"))
                     :explanation "In phys, uncertainty-mul is relative error propagation. In photography, three exposure variables' errors combine similarly. In math, log-error is sensitivity in log space. All three are L² norms in relative-error space."
                     :meta "The shape transfers because relative errors correspond to log-space errors, and independent log errors sum in quadrature.")
                    (:eng "One shape covers physics, photography, and general log-sensitivity analysis." :math "L² norm in log-space." :cs "O(N) map + reduce."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "phys/uncertainty-mul respects the identity: (uncertainty-mul σ 0) = σ (adding a zero-uncertainty factor doesn't change the total). This is the identity-preservation invariant."
                 :program "(define (approx a b) (< (abs (- a b)) 0.0001))\n(approx (phys/uncertainty-mul 0.05 0) 0.05)"
                 :invariant "uncertainty-mul(σ, 0) = σ"
                 :meta "Failure would mean adding an exact factor changed the total uncertainty, which is nonphysical. Falsification is any σ where adding 0 shifted the result. CS pattern: 'identity-element preservation'. Book-of-math ch 8.")
                (:eng "This invariant lets the operator include exact constants without inflating error." :math "Zero is the identity for quadrature sum." :cs "Property test."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "phys/uncertainty-mul combines independent relative σs in quadrature."
                     :composition "(define (chain-multiplicative-errors sigmas)\n  (apply phys/uncertainty-mul sigmas))\n(chain-multiplicative-errors (list 0.02 0.03 0.01 0.015))"
                     :emergent "A budget-of-multiplicative-errors — chaining apply with phys/uncertainty-mul produces the total relative uncertainty of a multi-factor product."
                     :meta "Same family as engineering-yield analysis. Cross-reference book-of-ml ch 6. Familiar analog: monte-carlo sensitivity analysis.")
                    (:eng "One primitive + apply = a product-error tool." :math "L² norm in log-space generalizes to N factors." :cs "O(N).")))

