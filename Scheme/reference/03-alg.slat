     :program "(define n 7)\n(and (= (alg/zn-add 3 4 n) (alg/zn-add 4 3 n))\n     (= (alg/zn-add 3 0 n) 3)\n     (= (alg/zn-add 3 (- n 3) n) 0))"
     :invariant "∀ a b ∈ Z/nZ. a + b = b + a  ∧  a + 0 = a  ∧  a + (n-a) = 0"
