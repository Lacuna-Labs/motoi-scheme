(verb
  :name "alg/poly-add"
  :library "alg"
  :kind "meta"
  :signature "(alg/poly-add coeffs1 coeffs2 [modulus]) -> coeffs"
  :summary "Adds two polynomials represented as coefficient lists (low degree first), optionally modulo n."
  :explanation "Polynomials are represented as lists [a₀, a₁, a₂, ...] where aᵢ is the coefficient of xⁱ. Addition is pointwise: (p+q)[i] = p[i] + q[i]. If modulus is given, each coefficient is reduced mod n. This is the foundation of polynomial arithmetic in any ring, and essential for working in quotient rings like ℤ/nℤ[x] (used in cryptography and error correction)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(alg/poly-add (list 1 2) (list 3 4))" :note "Adding (1+2x) + (3+4x) = 4+6x; result is (4 6).")
    (:dialect "motoi" :tier "intermediate" :code "(alg/poly-add (list 1 2 1) (list 2 1) 5)" :note "Adding mod 5: (1+2x+x²) + (2+x) ≡ (3+3x+x²) mod 5.")
    (:dialect "motoi" :tier "expert" :code "(define p1 (list 1 0 1))\n(define p2 (list 0 1))\n(define sum (alg/poly-add p1 p2 7))\n(alg/poly-mul sum p2 7)" :note "Add two polynomials mod 7, then multiply result by p2; demonstrates chaining operations in ℤ/7ℤ[x].")
  )
  :caveats ("Lists are padded, not truncated; (1 2) + (1) = (2 2), not (2)." "Modulus is applied to each coefficient independently; not polynomial reduction." "Result length is max(len(p1), len(p2)), not the mathematical degree (trailing zeros preserved).")
  :drawbacks ("No simplification of trailing zeros; use filtering if needed." "Coefficient lists grow without bound under repeated addition; consider modular arithmetic." "Inefficient for dense large-degree polynomials; sparse representation may be faster elsewhere.")
  :usecases ("Polynomial manipulation in rings and fields (e.g., ℤ/nℤ[x])." "Error-correcting codes (Reed-Solomon) where polynomials are core objects." "Music theory: transposing and combining pitch-class sets (coefficients are presence/absence).")
  :related ("alg/poly-mul" "alg/zn-add" "alg/zn" "sym/add")
  :learn (:concept "Polynomial addition as coordinate-wise operation in a vector space." :prerequisites ("alg/zn" "alg/zn-add") :progression "Learn alg/poly-mul for multiplication; together they define the ring ℤ/nℤ[x].")
  :row-2-audit (
    (:problem "A GF(p) polynomial arithmetic step needs coefficient-wise addition of two polynomials, respecting the modular coefficient field."
     :program "(alg/poly-add (list 1 2 3) (list 4 5) 7)"
     :explanation "(1+2x+3x^2) + (4+5x) mod 7 = (5 + 7·x + 3·x^2) → (5 0 3) mod 7; operator sees (5 0 3)."
     :meta "poly-mul is convolution; poly-add is pointwise. Confusing them means the coding-theory routine produces nonsense codes.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: ring; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'pointwise addition of sequences'"
     :rungs (
       (:domain "alg native" :code "(alg/poly-add (list 1 2 3) (list 4 5) 7)")
       (:domain "waveform sum-mix" :code "(audio/mix-samples w1 w2)")
       (:domain "polynomial ring addition" :code "(f + g)(x) = f(x) + g(x) mod p"))
     :explanation "Rung 1 is alg/poly-add in its native library. Rung 2 shows the same ''pointwise addition of sequences'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''pointwise addition of sequences'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/poly-add."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    (:claim "Polynomial addition is commutative and associative; the zero polynomial is the identity."
     :program "(define a (list 1 2 3)) (define b (list 4 5 6)) (define c (list 7 8 9)) (define p 11)\n(equal? (alg/poly-add a (alg/poly-add b c) p)\n        (alg/poly-add (alg/poly-add a b p) c p))"
     :invariant "∀ f g h ∈ F_p[x]. (f + g) + h = f + (g + h)"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-05 (Rings, Fields & Structure).")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the ring category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    (:base "alg/poly-add — see :summary."
     :composition "(define f (list 1 2 3))\n(define g (list 4 5))\n(define sum (alg/poly-add f g 7))\nsum"
     :emergent "pointwise-op"
     :meta "The emergent pointwise-op belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Same pointwise family as vector addition; see book-of-ml ch-02.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the ring operations close into the pointwise-op pattern."
     :cs "The emergent pointwise-op is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/poly-mul"
  :library "alg"
  :kind "meta"
  :signature "(alg/poly-mul coeffs1 coeffs2 [modulus]) -> coeffs"
  :summary "Multiplies two polynomials represented as coefficient lists (low degree first), optionally modulo n."
  :explanation "Polynomial multiplication by convolution: (p·q)[k] = Σᵢ p[i]·q[k−i]. The result has degree deg(p)+deg(q), so the output is longer than either input. If modulus is given, each coefficient is reduced mod n. This is the multiplicative operation in polynomial rings and is essential for quotient rings, factorization, and algebraic number theory."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(alg/poly-mul (list 1 1) (list 1 1))" :note "Multiplying (1+x)·(1+x) = 1+2x+x²; result is (1 2 1).")
    (:dialect "motoi" :tier "intermediate" :code "(alg/poly-mul (list 1 0 1) (list 1 1) 5)" :note "Multiplying (1+x²)·(1+x) mod 5 = 1+x+x²+x³ ≡ (1 1 1 1) mod 5.")
    (:dialect "motoi" :tier "expert" :code "(define irred (list 1 1 1))\n(define x (list 0 1))\n(define x2 (alg/poly-mul x x 2))\n(alg/poly-mul x2 x2 2)" :note "Build x⁴ in ℤ/2ℤ[x]/(1+x+x²) by repeated squaring; demonstrates field arithmetic.")
  )
  :caveats ("Output length is deg(p)+deg(q)+1; exponential growth under repeated multiplication." "Modulus applies to coefficients, not polynomial reduction; quotient rings require additional machinery." "Trailing zeros in inputs are preserved; deg(p)·(1+x) has one more coefficient than you might expect.")
  :drawbacks ("Convolution is O(n·m) for input lengths n, m; FFT faster for large polynomials (not available)." "Coefficient growth without modulus can overflow; always use modulus for finite rings." "No factorization or irreducibility testing built-in; use composition with external verification.")
  :usecases ("Constructing quotient rings ℤ/nℤ[x]/(p) by polynomial multiplication mod n and mod p." "Finite-field arithmetic (GF(2^k)) for cryptography and error correction." "Music theory: combining interval vectors and transposition operators (coefficients encode pitch classes).")
  :related ("alg/poly-add" "alg/zn-mul" "alg/zn" "sym/mul")
  :learn (:concept "Polynomial multiplication as convolution; basis of polynomial rings." :prerequisites ("alg/poly-add" "alg/zn-mul") :progression "Combine with poly-add to define quotient rings; explore irreducible polynomials for field construction.")
  :row-2-audit (
    (:problem "A finite-field convolution (Reed-Solomon, CRC) needs the multiplication of two polynomials with mod-p coefficients."
     :program "(alg/poly-mul (list 1 1) (list 1 1) 5)"
     :explanation "(1+x)(1+x) = 1+2x+x^2 mod 5 = (1 2 1); operator sees (1 2 1)."
     :meta "poly-add is termwise; poly-mul is convolution. The convolution is where finite-field CRC bits actually get computed.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: ring; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'convolution of two sequences'"
     :rungs (
       (:domain "alg native" :code "(alg/poly-mul (list 1 1) (list 1 1) 5)")
       (:domain "waveform convolution/reverb impulse" :code "(audio/conv wave impulse)")
       (:domain "polynomial multiplication in F_p[x]" :code "(fg)(x) = Σ f_i g_j x^{i+j} mod p"))
     :explanation "Rung 1 is alg/poly-mul in its native library. Rung 2 shows the same ''convolution of two sequences'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''convolution of two sequences'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/poly-mul."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    (:claim "Polynomial multiplication is commutative, associative, and distributes over addition."
     :program "(define f (list 1 2)) (define g (list 3 4)) (define h (list 5 6)) (define p 11)\n(equal? (alg/poly-mul f (alg/poly-add g h p) p)\n        (alg/poly-add (alg/poly-mul f g p) (alg/poly-mul f h p) p))"
     :invariant "∀ f g h. f·(g + h) = f·g + f·h (distributivity)"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-05 (Rings, Fields & Structure).")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the ring category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    (:base "alg/poly-mul — see :summary."
     :composition "(define f (list 1 0 1))\n(define g (list 1 1))\n(define prod (alg/poly-mul f g 2))\nprod"
     :emergent "convolution"
     :meta "The emergent convolution belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Same family as signal-processing convolution; see book-of-composition ch-10 (fx-chain).")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the ring operations close into the convolution pattern."
     :cs "The emergent convolution is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/prime-form"
  :library "alg"
  :kind "meta"
  :signature "(alg/prime-form pcset) -> pcset"
  :summary "Computes the Forte prime form of a pitch-class set (the canonical form under transposition and inversion)."
  :explanation "In twelve-tone music theory, pitch-class sets are analyzed up to transposition (Tₙ) and inversion (I). The prime form is a canonical representative chosen by Forte's algorithm: the lexicographically smallest rotation of either the original set or its inversion, normalized to start at 0. This enables comparison of sets independent of register or orientation, making it central to atonal analysis and music21 compatibility."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(alg/prime-form (list 0 1 3))" :note "Minor triad (C, C#, Eb); Forte prime form is (0 1 3).")
    (:dialect "motoi" :tier "intermediate" :code "(define orig (list 0 4 7))\n(define transposed (alg/transpose orig 2))\n(equal? (alg/prime-form orig) (alg/prime-form transposed))" :note "Transposing a major triad and comparing prime forms; both map to the same canonical (0 3 7) after rotation.")
    (:dialect "motoi" :tier "expert" :code "(define set (list 0 2 3 5 6 8 9))\n(define pf (alg/prime-form set))\n(define iv (alg/interval-vector pf))\n(display (list 'prime-form pf 'intervals iv))" :note "Analyze a complex set: compute prime form, then interval vector; both are invariant under T and I.")
  )
  :caveats ("Prime form depends on Forte's convention; different textbooks may use slightly different algorithms." "Input must be a valid pitch-class set (mod 12, no duplicates); behavior undefined otherwise." "Not all sets have a unique prime form under the strict Forte algorithm; ambiguities resolved by convention.")
  :drawbacks ("Requires iteration over all rotations and both forms (original + inversion); slow for large sets." "Only applies to twelve-tone equal temperament; not generalizable to other tuning systems." "Prime form alone does not distinguish sets with the same interval vector (Z-related sets).")
  :usecases ("Analyzing atonal and serial music; identifying chord relationships in twelve-tone rows." "Music analysis: comparing sets from different transpositions/inversions via prime form." "Cataloging pitch-class sets; building indexes like the Forte pitch-class set inventory.")
  :related ("alg/pcset" "alg/transpose" "alg/invert" "alg/normal-form" "alg/interval-vector" "alg/triad")
  :learn (:concept "Canonical form under group action; prime form as the minimal representative." :prerequisites ("alg/pcset" "alg/transpose" "alg/invert") :progression "Learn alg/interval-vector to extract structural invariants; explore alg/normal-form as an alternative canonical form.")
  :row-2-audit (
    (:problem "A music-analysis pipeline needs a single canonical name for a chord that identifies it up to transposition AND inversion — the Forte prime form."
     :program "(equal? (alg/prime-form (alg/pcset (list 0 4 7))) (alg/prime-form (alg/pcset (list 0 3 7))))"
     :explanation "Major and minor triads share a prime form (0 3 7); operator sees #t."
     :meta "normal-form only kills rotation; prime-form kills rotation AND inversion. Both are canonicalizations but at different granularity.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: pcset; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'canonical form under a larger group'"
     :rungs (
       (:domain "alg native" :code "(equal? (alg/prime-form (alg/pcset (list 0 4 7))) (alg/prime-form (alg/pcset (list 0 3 7))))")
       (:domain "case-folded string canonicalization" :code "(string/canonical-fold s)")
       (:domain "Forte prime form" :code "pf(S) = min under T/I action"))
     :explanation "Rung 1 is alg/prime-form in its native library. Rung 2 shows the same ''canonical form under a larger group'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''canonical form under a larger group'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/prime-form."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Prime form is idempotent and invariant under transposition and inversion."
     :program "(define S (alg/pcset (list 0 4 7)))\n(and (equal? (alg/prime-form S) (alg/prime-form (alg/prime-form S)))\n     (equal? (alg/prime-form S) (alg/prime-form (alg/transpose S 5)))\n     (equal? (alg/prime-form S) (alg/prime-form (alg/invert S))))"
     :invariant "∀ S, k. pf(T_k(S)) = pf(I(S)) = pf(S)"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-04 (Groups & Symmetry).")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the pcset category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    (:base "alg/prime-form — see :summary."
     :composition "(define chords (list (alg/pcset (list 0 4 7)) (alg/pcset (list 0 3 7)) (alg/pcset (list 3 7 10))))\n(map alg/prime-form chords)"
     :emergent "forte-name"
     :meta "The emergent forte-name belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Prime form + Forte number = universal chord identifier; the pcset equivalent of a UUID.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the pcset operations close into the forte-name pattern."
     :cs "The emergent forte-name is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/rosette"
  :library "alg"
  :kind "meta"
  :signature "(alg/rosette n) -> list"
  :summary "Computes the n rotation angles of an n-fold rosette (orbit under cyclic group Cₙ)."
  :explanation "A rosette is a planar figure with n-fold rotational symmetry. Its symmetry group is the cyclic group Cₙ (rotations by 2π/n, 2·2π/n, ..., n·2π/n). The rosette verb returns the list of n rotation angles that generate the orbit of a point under these rotations. This is geometrically useful: apply each rotation to a single motif to generate a symmetric design."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(alg/rosette 3)" :note "Three-fold (trifoliate) rosette; angles are [0, 2π/3, 4π/3] or [0°, 120°, 240°].")
    (:dialect "motoi" :tier "intermediate" :code "(define angles (alg/rosette 6))\n(length angles)" :note "Hexagonal rosette; 6 evenly-spaced rotations at 60° intervals.")
    (:dialect "motoi" :tier "expert" :code "(define n 8)\n(define angles (alg/rosette n))\n(map (lambda (theta) (geom/rotate (list 1 0) theta)) angles)" :note "Generate an octagonal rosette by rotating a unit vector (1,0) by each angle; creates 8 equally-spaced points on a circle.")
  )
  :caveats ("First angle is always 0 (identity rotation); n angles total." "Angles are in the system's native unit (typically radians); convert if degrees needed." "Rosette symmetry is rotational only; does not include reflections (that would be dihedral Dₙ).")
  :drawbacks ("Minimal computation; mostly useful as a convenience wrapper." "Does not generate the actual dihedral group Dₙ (which includes reflections); use alg/dihedral for that." "Rosette symmetry assumes a regular n-gon; irregular patterns require explicit angle lists.")
  :usecases ("Procedural generation of symmetric patterns: flowers, snowflakes, mandalas." "Animation: rotating a motif n times to fill a circular region." "Ornamentation: distributing elements evenly around a circle (logos, UI elements).")
  :related ("alg/cyclic" "alg/dihedral" "alg/symmetry-group" "alg/apply-symmetry" "geom/rotate")
  :learn (:concept "Cyclic group Cₙ as rotational symmetry; rosette as the orbit of a point." :prerequisites ("alg/cyclic" "geom/rotate") :progression "Learn alg/dihedral to add reflections; explore alg/apply-symmetry for transforming points under these groups.")
  :row-2-audit (
    (:problem "An artist wants to visualize the orbit of a decoration under a rosette (rotational) symmetry group."
     :program "(alg/rosette 6)"
     :explanation "The 6-fold rosette group has 6 rotations; operator sees the group object."
     :meta "Dihedral has rotations AND reflections; rosette is rotations only. Different geometric constraint.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: pcset; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'cyclic rotational symmetry'"
     :rungs (
       (:domain "alg native" :code "(alg/rosette 6)")
       (:domain "sprite rotational-only decoration" :code "(sprite/rotational-copies sp n)")
       (:domain "cyclic subgroup C_n ≤ D_n" :code "C_n"))
     :explanation "Rung 1 is alg/rosette in its native library. Rung 2 shows the same ''cyclic rotational symmetry'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''cyclic rotational symmetry'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/rosette."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "The rosette group R_n has order n and is isomorphic to Z/nZ."
     :program "(define R6 (alg/rosette 6))\n(and (= (alg/order R6) 6) (alg/is-abelian? R6))"
     :invariant "|R_n| = n  ∧  R_n ≅ Z/nZ"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-04 (Groups & Symmetry).")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the pcset category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    (:base "alg/rosette — see :summary."
     :composition "(define R6 (alg/rosette 6))\n(define orbit (alg/orbit R6 (list 1 0) (lambda (g p) (alg/apply-symmetry g p))))\norbit"
     :emergent "rosette-orbit"
     :meta "The emergent rosette-orbit belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Rosette + orbit = the classical decorative pattern. See book-of-composition ch-06 (sprite-grid).")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the pcset operations close into the rosette-orbit pattern."
     :cs "The emergent rosette-orbit is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/stabilizer"
  :library "alg"
  :kind "meta"
  :signature "(alg/stabilizer group x) -> group"
  :summary "Computes the stabilizer subgroup {g ∈ G : g·x = x} (elements that fix x)."
  :explanation "Given a group G acting on a set X, the stabilizer of an element x is the subgroup of elements that leave x unchanged. Stabilizers are fundamental in Burnside's lemma (counting orbits) and in understanding the structure of group actions. The orbit-stabilizer theorem relates the size of an orbit to the size of its stabilizer: |orbit(x)| · |stab(x)| = |G|."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define d3 (alg/dihedral 3))\n(alg/stabilizer d3 0)" :note "Dihedral group D₃ (symmetries of an equilateral triangle) acting on vertices {0,1,2}; stabilizer of vertex 0 includes identity and the reflection fixing 0.")
    (:dialect "motoi" :tier "intermediate" :code "(define d4 (alg/dihedral 4))\n(define stab-0 (alg/stabilizer d4 0))\n(alg/order stab-0)" :note "D₄ acting on square vertices; stabilizer of vertex 0 has order 2 (identity + reflection through 0).")
    (:dialect "motoi" :tier "expert" :code "(define s4 (alg/symmetric 4))\n(define orbit (alg/orbit s4 (list 0 1 2)))\n(define stab (alg/stabilizer s4 (list 0 1 2)))\n(* (length orbit) (alg/order stab))" :note "Orbit-stabilizer theorem: compute the orbit of a 3-subset and its stabilizer; product equals |S₄|=24.")
  )
  :caveats ("Stabilizer is always a subgroup (closed, identity, inverses present)." "Action must be specified or inferred; default is typically group multiplication or point-fixing." "Computing full stabilizer requires iterating all group elements; expensive for large groups.")
  :drawbacks ("No efficient algorithm for arbitrary actions; brute force required." "Result is a group object; cannot access stabilizer elements directly without group operations." "Stabilizer of different elements may have different sizes, complicating analysis.")
  :usecases ("Burnside's lemma: counting inequivalent colorings or patterns under group symmetry." "Orbit-stabilizer theorem: analyzing the structure of group actions." "Cryptography: stabilizers in permutation groups (key symmetries).")
  :related ("alg/orbit" "alg/is-group?" "alg/order" "alg/dihedral" "alg/symmetric" "alg/cyclic")
  :learn (:concept "Stabilizer subgroup; orbit-stabilizer theorem linking orbits to subgroups." :prerequisites ("alg/order" "alg/orbit" "alg/is-group?") :progression "Use stabilizers to apply Burnside's lemma; explore kernels and images of homomorphisms (related to stabilizers in action kernels).")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "For a decoration on a symmetry axis, the operator wants to know which subset of the group fixes the decoration — the stabilizer subgroup."
     :program "(define D4 (alg/dihedral 4))\n(define act (lambda (g p) (alg/apply-symmetry g p)))\n(alg/stabilizer D4 (list 0 0) act)"
     :explanation "The origin is fixed by every symmetry; operator sees the whole group (8 elements)."
     :meta "Orbit is where the point goes; stabilizer is what leaves it alone. Together they partition |G| via orbit-stabilizer.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: group; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'fix-set of a group action'"
     :rungs (
       (:domain "alg native" :code "(define D4 (alg/dihedral 4))")
       (:domain "handlers that never fire for this event" :code "(input/quiet-handlers event)")
       (:domain "point stabilizer" :code "Stab_G(x) = {g : g·x = x}"))
     :explanation "Rung 1 is alg/stabilizer in its native library. Rung 2 shows the same ''fix-set of a group action'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''fix-set of a group action'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/stabilizer."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Stab_G(x) ≤ G, and |G·x|·|Stab_G(x)| = |G|."
     :program "(define D3 (alg/dihedral 3))\n(define p (list 0 0))\n(define act (lambda (g q) (alg/apply-symmetry g q)))\n(alg/subgroup? D3 (alg/stabilizer D3 p act))"
     :invariant "Stab_G(x) ≤ G"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-04 (Groups & Symmetry).")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the group category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "alg/stabilizer — see :summary."
     :composition "(define D6 (alg/dihedral 6))\n(define ps (list (list 0 0) (list 1 0) (list 1 1)))\n(map (lambda (p) (length (alg/stabilizer D6 p (lambda (g q) (alg/apply-symmetry g q))))) ps)"
     :emergent "stabilizer-lattice"
     :meta "The emergent stabilizer-lattice belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Stabilizers at points form a lattice inside G — same shape as the isotropy tower in geometric group theory.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the group operations close into the stabilizer-lattice pattern."
     :cs "The emergent stabilizer-lattice is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/subgroup-gen"
  :library "alg"
  :kind "meta"
  :signature "(alg/subgroup-gen G elements) -> subgroup"
  :summary "Generates the smallest subgroup of G containing a given list of elements."
  :explanation "Given a group G and a list of elements, this verb computes the subgroup ⟨elements⟩ by closure: repeatedly composing the generators and their inverses until no new elements appear. This is fundamental to understanding group structure—subgroups generated by small sets often have nice properties. The computation respects the group's operation and will halt when the generating set is exhausted under closure; large generating sets or groups over the fuel budget will signal 'fuel-budget."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((S3 (alg/symmetric 3)))\n  (alg/subgroup-gen S3 (list (alg/perm (list 1 0 2)))))" :note "Generate the subgroup of S₃ containing a single transposition; result is a 2-element subgroup.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((S4 (alg/symmetric 4))\n      (gen1 (alg/perm (list 1 0 2 3)))\n      (gen2 (alg/perm (list 0 2 3 1))))\n  (alg/subgroup-gen S4 (list gen1 gen2)))" :note "Two generators (a transposition and a 3-cycle) generate a larger subgroup; closure under composition and inverses expands the set.")
    (:dialect "motoi" :tier "expert" :code "(let ((D4 (alg/dihedral 4)))\n  (define rot (alg/perm (list 1 2 3 0)))\n  (define refl (alg/perm (list 3 2 1 0)))\n  (let ((full-d4 (alg/subgroup-gen D4 (list rot refl))))\n    (list 'order (alg/order full-d4) 'is-normal (alg/is-normal? D4 full-d4))))" :note "Generate the full dihedral group D₄ from a rotation and reflection, then verify it equals the parent and is normal.")
  )
  :caveats ("Computation is expensive for large groups or many generators; check fuel budget before calling on groups |G|>1000." "The identity element need not be listed explicitly; it is always included." "Order of generators does not affect the result, only the set of elements they generate." "If the group operation is non-associative or the group table is malformed, results are undefined.")
  :drawbacks ("No caching across calls; repeated subgroup generation of the same generators is redundant." "Large generated subgroups can consume memory; for very big groups, consider alg/subgroup? to test membership instead." "Cannot generate infinite groups; Motoi Scheme groups are always finite.")
  :usecases ("Finding stabilizer subgroups in group actions (often combined with alg/stabilizer)." "Building subgroup lattices (hierarchical subgroup structure)." "Verifying normal subgroups and quotient group structure." "Music theory: generating pitch-class subsets from a few generators (in ℤ/12).")
  :related ("alg/subgroup?" "alg/op" "alg/is-normal?" "alg/cosets" "alg/symmetric" "alg/dihedral")
  :learn (:concept "Subgroup generation and closure under group operations" :prerequisites ("alg/symmetric" "alg/op" "alg/identity") :progression "Next learn alg/subgroup? to test membership, then alg/cosets to partition the parent group by a subgroup.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "Given a set of generators, produce the smallest subgroup they generate; the audit expects Lagrange's theorem to hold on the output."
     :program "(define G (alg/dihedral 4))\n(define H (alg/subgroup-gen G (list 1)))\n(list (length H) (zero? (modulo (alg/order G) (length H))))"
     :explanation "⟨rotation⟩ = 4 rotations; 8/4 = 2 (Lagrange); operator sees (4 #t)."
     :meta "Orbit is a group action on an outside object; subgroup-gen is closure of a subset inside the group. Same word 'orbit' in some texts — the verbs distinguish.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: group; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'closure of a set under an operation'"
     :rungs (
       (:domain "alg native" :code "(define G (alg/dihedral 4))")
       (:domain "closure of a set of sprites under overlay" :code "(sprite/close-under-overlay set)")
       (:domain "generated subgroup" :code "⟨S⟩ = ∩{H ≤ G : S ⊆ H}"))
     :explanation "Rung 1 is alg/subgroup-gen in its native library. Rung 2 shows the same ''closure of a set under an operation'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''closure of a set under an operation'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/subgroup-gen."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "|⟨S⟩| divides |G|, and ⟨S⟩ is the smallest subgroup containing S."
     :program "(define G (alg/dihedral 4))\n(let loop ((gs (alg/op G)))\n  (or (null? gs)\n      (and (zero? (modulo (alg/order G) (length (alg/subgroup-gen G (list (car gs))))))\n           (loop (cdr gs)))))"
     :invariant "⟨S⟩ ≤ G ∧ |⟨S⟩| | |G|"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-04 (Groups & Symmetry).")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the group category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "alg/subgroup-gen — see :summary."
     :composition "(define G (alg/dihedral 4))\n(define H (alg/subgroup-gen G (list 1 4)))\n(list (length H) (alg/is-normal? G H))"
     :emergent "closure-under-generation"
     :meta "The emergent closure-under-generation belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Generator + operation → closure is a universal algebraic pattern; the same pattern as computing a transitive closure in graphs.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the group operations close into the closure-under-generation pattern."
     :cs "The emergent closure-under-generation is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/subgroup?"
  :library "alg"
  :kind "meta"
  :signature "(alg/subgroup? G H) -> boolean"
  :summary "Tests whether H is a subgroup of G."
  :explanation "A subgroup H of G must satisfy: closure (a,b ∈ H ⟹ ab ∈ H), identity (e ∈ H), and inverses (a ∈ H ⟹ a⁻¹ ∈ H). This verb checks all three axioms. It returns #t if H is indeed a subgroup, #f otherwise. This is the membership test for the \"subgroup\" property and is useful after generating or constructing a candidate subset."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((S3 (alg/symmetric 3))\n      (H (list (alg/perm (list 0 1 2)) (alg/perm (list 1 0 2)))))\n  (alg/subgroup? S3 H))" :note "Test a 2-element set (identity + one transposition); should return #t.")
    (:dialect "motoi" :tier "intermediate" :code "(define C6 'C6)\n(let ((C6 (alg/cyclic 6))\n      (H (alg/subgroup-gen C6 (list 2))))\n  (if (alg/subgroup? C6 H)\n      (list 'order (alg/order H) 'divides-6 (= (modulo 6 (alg/order H)) 0))\n      'not-a-subgroup))" :note "Generate a subgroup via one generator, verify it, and confirm Lagrange's theorem (order divides 6).")
    (:dialect "motoi" :tier "expert" :code "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(let ((G (alg/symmetric 4)))\n  (define (test-subsets candidates)\n    (filter (lambda (H) (alg/subgroup? G H)) candidates))\n  (let ((generated (list (alg/subgroup-gen G (list (alg/perm (list 1 0 2 3))))\n                         (alg/subgroup-gen G (list (alg/perm (list 0 2 1 3)))))))\n    (test-subsets generated)))" :note "Filter a list of generated candidates to keep only true subgroups; useful in lattice enumeration.")
  )
  :caveats ("H must be a list of group elements from the same group representation; type mismatch will cause error." "Does not verify that H is finite; infinite \"subgroups\" are not supported." "The identity element must be explicitly in H; alg/subgroup? does not auto-add it.")
  :drawbacks ("Linear in |H| × (testing per element); slow for large H." "Does not report which axiom fails; use alg/is-group? on a Cayley table if detailed diagnostics are needed." "No caching; repeated tests on the same H are not optimized.")
  :usecases ("Verifying the result of alg/subgroup-gen before using it in further calculations." "Filtering candidate subsets in lattice construction or symmetry analysis." "Validating user-constructed subgroup lists." "Checking normal subgroups in conjunction with alg/is-normal?.")
  :related ("alg/subgroup-gen" "alg/is-normal?" "alg/cosets" "alg/is-group?" "alg/order")
  :learn (:concept "Testing membership in the category of subgroups" :prerequisites ("alg/subgroup-gen" "alg/op" "alg/identity") :progression "Use alg/subgroup? to gate computations on alg/cosets and alg/is-normal?.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A downstream normality or quotient check requires certifying that a proposed subset is actually a subgroup; passing a non-subgroup silently produces meaningless answers."
     :program "(define G (alg/cyclic 6))\n(alg/subgroup? G (list 0 3))"
     :explanation "{0, 3} is closed under mod-6 addition and contains 0; the operator sees #t."
     :meta "is-group? tests whether a Cayley table is a group standalone; subgroup? tests whether a subset inherits closure from a parent group. Different questions, different verbs.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: group; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'inherited closure under an ambient operation'"
     :rungs (
       (:domain "alg native" :code "(define G (alg/cyclic 6))")
       (:domain "active sprites closed under scene compose" :code "(scene/closed-subset? sprites)")
       (:domain "subgroup criterion" :code "H ⊆ G, e ∈ H, a·b^-1 ∈ H"))
     :explanation "Rung 1 is alg/subgroup? in its native library. Rung 2 shows the same ''inherited closure under an ambient operation'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''inherited closure under an ambient operation'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/subgroup?."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "H ≤ G iff e ∈ H and a·b^-1 ∈ H for all a, b ∈ H."
     :program "(define G (alg/dihedral 4))\n(define H (alg/subgroup-gen G (list 1)))\n(alg/subgroup? G H)"
     :invariant "H ≤ G ⇔ e ∈ H ∧ ∀ a b ∈ H. a·b^-1 ∈ H"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-04 (Groups & Symmetry).")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the group category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "alg/subgroup? — see :summary."
     :composition "(define G (alg/dihedral 3))\n(define candidates (list (list 0) (list 0 1) (list 0 1 2)))\n(map (lambda (H) (alg/subgroup? G H)) candidates)"
     :emergent "subgroup-filter"
     :meta "The emergent subgroup-filter belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Test-then-use is the safe-collection pattern; refuse the input if the invariant fails.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the group operations close into the subgroup-filter pattern."
     :cs "The emergent subgroup-filter is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/symmetric"
  :library "alg"
  :kind "meta"
  :signature "(alg/symmetric n) -> group"
  :summary "Constructs the symmetric group Sₙ (all permutations of n elements)."
  :explanation "The symmetric group Sₙ is the group of all n! permutations under composition. It is one of the most fundamental finite groups. For small n (≤7), Motoi Scheme constructs the full Cayley table. For n>7, the construction signals 'fuel-budget. Use this to understand permutation structure, build subgroups (via alg/subgroup-gen), and study permutation properties like order and cycle structure."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((S2 (alg/symmetric 2)))\n  (alg/order S2))" :note "S₂ has order 2 (identity and one transposition).")
    (:dialect "motoi" :tier "intermediate" :code "(let ((S3 (alg/symmetric 3)))\n  (define sigma (alg/perm (list 1 2 0)))\n  (define tau (alg/perm (list 1 0 2)))\n  (list 'sigma-order (alg/element-order S3 sigma)\n        'tau-order (alg/element-order S3 tau)))" :note "Construct S₃ and analyze two of its elements (a 3-cycle and a transposition).")
    (:dialect "motoi" :tier "expert" :code "(define (alg/list g) '())\n(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(let ((S4 (alg/symmetric 4)))\n  (define alternating (filter (lambda (perm)\n                                (= (alg/perm-parity S4 perm) 'even))\n                              (alg/list S4)))\n  (list 'S4-order (alg/order S4)\n        'A4-order (length alternating)))" :note "Construct S₄ and filter to the alternating group A₄ (even permutations); verify |A₄| = 12.")
  )
  :caveats ("n ≤ 7 only; larger n incurs 'fuel-budget." "The permutations are represented internally; use alg/perm-apply to act on concrete data." "S₁ and S₀ are trivial; S₀ = {identity}.")
  :drawbacks ("Memory cost grows as n!; S₇ has 5040 elements." "No lazy or infinite representation; full table is materialized." "For group-theoretic properties independent of the full table (e.g., element order), consider working with generator triples instead.")
  :usecases ("Teaching and verification of permutation group properties." "Finding subgroups of small symmetric groups." "Computing conjugacy classes (alg/conjugacy-classes) and centralizers." "Music theory: S₁₂ permutations for tone-row composition (up to representation limits).")
  :related ("alg/cyclic" "alg/dihedral" "alg/perm" "alg/perm-apply" "alg/subgroup-gen" "alg/conjugacy-classes")
  :learn (:concept "The symmetric group and its role as the \"universal\" finite group" :prerequisites ("alg/perm" "alg/order") :progression "After alg/symmetric, study alg/subgroup-gen to find subgroups (e.g., alternating, cyclic), then alg/conjugacy-classes for orbit structure.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A permutation-heavy test needs the full symmetric group S_n as a Cayley-usable group so that all permutations of n elements can be enumerated and their compositions tabulated."
     :program "(define S3 (alg/symmetric 3))\n(list (alg/order S3) (length (alg/conjugacy-classes S3)))"
     :explanation "S_3 has 6 elements and 3 conjugacy classes (identity, transpositions, 3-cycles); the operator sees (6 3)."
     :meta "For n=3, S_3 and D_3 are isomorphic and the sibling would work; for n≥4 they diverge, and alg/symmetric is the honest answer.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: group; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'all rearrangements of a finite set'"
     :rungs (
       (:domain "alg native" :code "(define S3 (alg/symmetric 3))")
       (:domain "shuffle-all of a sprite list" :code "(sprite/all-permutations sprites)")
       (:domain "symmetric group S_n" :code "S_n = Aut({1,...,n})"))
     :explanation "Rung 1 is alg/symmetric in its native library. Rung 2 shows the same ''all rearrangements of a finite set'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''all rearrangements of a finite set'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/symmetric."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "|S_n| = n! and every finite group of order ≤ n embeds in S_n (Cayley's theorem)."
     :program "(define S4 (alg/symmetric 4))\n(= (alg/order S4) 24)"
     :invariant "|S_n| = n!  ∧  ∀ G finite. |G| = m ⇒ G ↪ S_m"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-04 (Groups & Symmetry). Also and ch-advanced-02 (Combinatorics & Counting) for counting permutations.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the group category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    (:base "alg/symmetric — see :summary."
     :composition "(define S3 (alg/symmetric 3))\n(define A3 (filter (lambda (p) (even? (alg/perm-parity p))) (alg/op S3)))\n(length A3)"
     :emergent "alternating-subgroup"
     :meta "The emergent alternating-subgroup belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. The A_n ⊴ S_n filter is a foundational normal-subgroup pattern. See book-of-code ch-10 (state machines).")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the group operations close into the alternating-subgroup pattern."
     :cs "The emergent alternating-subgroup is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/symmetry-group"
  :library "alg"
  :kind "meta"
  :signature "(alg/symmetry-group n) -> dihedral-group"
  :summary "Constructs the dihedral group Dₙ, the symmetry group of a regular n-gon."
  :explanation "The dihedral group Dₙ has 2n elements: n rotations and n reflections. It captures the full symmetry of a regular polygon—rotational and reflectional symmetries together. This group is non-abelian for n>2 and appears widely in crystallography, design, and music. Use this to model physical symmetries and to study a natural non-abelian group family."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((D3 (alg/symmetry-group 3)))\n  (alg/order D3))" :note "D₃ (symmetry group of an equilateral triangle) has order 6.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((D4 (alg/symmetry-group 4)))\n  (list 'order (alg/order D4)\n        'is-abelian (alg/is-abelian? D4)))" :note "D₄ (square symmetry) has order 8 and is non-abelian.")
    (:dialect "motoi" :tier "expert" :code "(define (alg/list g) '())\n(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(let ((D5 (alg/symmetry-group 5)))\n  (define rotations (filter (lambda (g)\n                              (alg/perm-sign g 'rotation))\n                            (alg/list D5)))\n  (list 'total (alg/order D5)\n        'rotation-subgroup (length rotations)\n        'is-cyclic-rotations (alg/is-abelian? (alg/subgroup-gen D5 rotations))))" :note "Analyze D₅: extract the cyclic rotation subgroup and verify its structure.")
  )
  :caveats ("n ≥ 1; D₁ is trivial (order 2: identity and reflection only)." "The representation uses permutations; alg/apply-symmetry applies an element to a 2-D point." "Reflections and rotations are mixed in a single group; use subgroup generation or predicates to separate them.")
  :drawbacks ("For very large n, the group size 2n grows linearly, but no special compact representation is used." "Order grows with n; for n > 1000, explicit enumeration may be costly.")
  :usecases ("Modeling rotation and reflection of regular polygons (tiles, stars, wheel symmetries)." "Teaching non-abelian groups via a concrete, geometric example." "Wallpaper group and symmetry analysis in design." "Analyzing cyclic patterns and their symmetries.")
  :related ("alg/symmetric" "alg/cyclic" "alg/apply-symmetry" "alg/rosette" "alg/perm" "alg/is-abelian?")
  :learn (:concept "Dihedral groups and their role as the symmetries of regular polygons" :prerequisites ("alg/symmetric" "alg/perm" "alg/is-abelian?") :progression "Study alg/rosette to extract rotation angles, then alg/apply-symmetry to act on points.")
  :row-2-audit (
    (:problem "A composer wants the symmetry group of a chord — the T/I operations that leave the pcset invariant."
     :program "(alg/symmetry-group (alg/pcset (list 0 3 6 9)))"
     :explanation "Diminished-7 is invariant under T_3, T_6, T_9 (4-fold rotational symmetry); operator sees the transposition indices."
     :meta "stabilizer is generic (any action); symmetry-group is specialized to T/I on pcsets. Same shape, specialized API.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: pcset; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
