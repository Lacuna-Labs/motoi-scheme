)

(verb
  :name "alg/index"
  :library "alg"
  :kind "meta"
  :signature "(alg/index G H) -> k"
  :summary "Compute the index [G:H], the number of distinct left cosets of H in G."
  :explanation "If H is a subgroup of G, the index [G:H] is the count of left cosets {gH : g ∈ G}, where gH = {g·h : h ∈ H}. By Lagrange's theorem, [G:H] = |G|/|H|, so the index divides the group order. An index of 2 makes H normal in G. The index measures how much 'bigger' G is than H. For instance, in S₃ (order 6), the alternating group A₃ has index 2."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((G (alg/group-from-table '((e a b c) (a b c e) (b c e a) (c e a b))))\n      (H (alg/group-from-table '((e a) (a e)))))\n  (alg/index G H))" :note "Z/4 contains Z/2; cosets {e, a} and {b, ba}; index = 2")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((G (alg/group-from-table '((e a b c d f) (a b c d f e) (b c d f e a) (c d f e a b) (d f e a b c) (f e a b c d))))\n       (H (alg/group-from-table '((e a) (a e))))\n       (idx (alg/index G H)))\n  (list 'order-G 6 'order-H 2 'index idx 'computed-by (* idx 2)))" :note "Z/6 contains Z/2; verify Lagrange: |G| = [G:H] · |H|")
    (:dialect "motoi" :tier "expert" :code "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (find-subgroups-by-index G target-idx)\n  (let* ((order-G (alg/order G))\n         (order-H (/ order-G target-idx)))\n    (filter (lambda (H) (and (alg/subgroup? G H) (= (alg/index G H) target-idx)))\n            (list 'H1 'H2 'H3))))\n(let ((G (alg/group-from-table '((e a b c) (a b c e) (b c e a) (c e a b)))))\n  (alg/index G (alg/group-from-table '((e c) (c e)))))" :note "Find subgroups of given index; useful for subgroup classification")
  )
  :caveats ("H must be a true subgroup of G; no validation happens here. Use alg/subgroup? first." "Index is undefined if H is not a subgroup; result may be spurious." "For large groups, computing all cosets is expensive; prefer |G|/|H| if orders are known.")
  :drawbacks ("No error if H ⊄ G; silent wrong answer." "Coset enumeration scales as O(|G|·|H|)." "Does not tell you whether H is normal; use alg/is-normal? separately.")
  :usecases ("Verify subgroup relationships via Lagrange's theorem." "Test normality: if [G:H] = 2, then H is normal." "Count quotient groups: G/H has order [G:H]." "Classify subgroups by index in small groups.")
  :related ("alg/subgroup?" "alg/cosets" "alg/is-normal?" "alg/order" "alg/group-from-table")
  :learn (:concept "Index as a measure of subgroup containment and quotient structure" :prerequisites ("alg/subgroup?" "alg/cosets" "alg/order") :progression "alg/is-normal? → alg/conjugacy-classes")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "Before applying Lagrange or checking normality, the operator wants a single integer — the index [G:H] — to log and compare across candidate subgroups."
     :program "(define G (alg/dihedral 4))\n(define H (alg/subgroup-gen G (list 1)))\n(alg/index G H)"
     :explanation "D_4 has order 8; ⟨rotation⟩ has order 4; index = 2; operator sees 2."
     :meta "alg/cosets returns the whole partition; alg/index returns only the count. When you only need the count, the smaller call is faster and easier to log.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: group; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'ratio of two sizes'"
     :rungs (
       (:domain "alg native" :code "(define G (alg/dihedral 4))")
       (:domain "ratio of scene to layer sizes" :code "(scene/layer-ratio scene layer)")
       (:domain "index of a subgroup" :code "[G:H] = |G|/|H|"))
     :explanation "Rung 1 is alg/index in its native library. Rung 2 shows the same ''ratio of two sizes'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''ratio of two sizes'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/index."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "[G:H] = |G|/|H| (Lagrange)."
     :program "(define G (alg/dihedral 4))\n(define H (alg/subgroup-gen G (list 1)))\n(= (alg/index G H) (/ (alg/order G) (length H)))"
     :invariant "[G:H] = |G|/|H|"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-04 (Groups & Symmetry).")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the group category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "alg/index — see :summary."
     :composition "(define G (alg/dihedral 4))\n(map (lambda (g) (list g (alg/index G (alg/subgroup-gen G (list g)))))\n     (alg/op G))"
     :emergent "index-spectrum"
     :meta "The emergent index-spectrum belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Index-per-generator gives a quick subgroup-lattice fingerprint.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the group operations close into the index-spectrum pattern."
     :cs "The emergent index-spectrum is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/interval-vector"
  :library "alg"
  :kind "meta"
  :signature "(alg/interval-vector pcset) -> (ic1 ic2 ic3 ic4 ic5 ic6)"
  :summary "Compute the interval-class vector of a pitch-class set, counting semitone intervals 1–6."
  :explanation "In music, pitch classes are integers mod 12 (C=0, C#=1, ..., B=11). An interval class (ic) is the minimum semitone distance between two notes; since octaves repeat, we count upward distance mod 6 (intervals 1–6 semitones become classes 1–6). The interval-class vector is a 6-tuple [ic1, ic2, ic3, ic4, ic5, ic6] counting how many ordered pairs (p, q) in the set have interval class 1, 2, ..., 6. It measures harmonic color and symmetries of the sonority. Complementary sets have related vectors."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(alg/interval-vector (alg/pcset '(0 4 7)))" :note "Major triad C-E-G: intervals are 4 (C→E), 7 (C→G), 3 (E→G); ic vector counts these")
    (:dialect "motoi" :tier "intermediate" :code "(let ((major (alg/interval-vector (alg/pcset '(0 4 7))))\n      (minor (alg/interval-vector (alg/pcset '(0 3 7)))))\n  (list 'major-iv major 'minor-iv minor))" :note "Compare major and minor triads; minor has different interval counts")
    (:dialect "motoi" :tier "expert" :code "(define (compare-sonorities names pcsets)\n  (map (lambda (name pcs) (list name (alg/interval-vector (alg/pcset pcs)))) names pcsets))\n(compare-sonorities '(major minor diminished augmented)\n                    '((0 4 7) (0 3 7) (0 3 6) (0 4 8)))" :note "Generate interval vectors for all classical triads; study symmetries and relationships")
  )
  :caveats ("The input must be a pitch-class set (integers 0–11); mod 12 is implicit." "Interval vectors are unordered; (0, 4, 7) and (0, 3, 8) have different vectors but may be related by transformation." "The vector has 6 entries; larger intervals (7+ semitones) wrap (e.g., 8 semitones = ic 4).")
  :drawbacks ("Interval vector alone does not uniquely identify a set (two non-isomorphic sets can share a vector)." "Not directly useful outside music theory; requires domain knowledge." "Does not track which specific intervals appear, only counts.")
  :usecases ("Analyze harmony: cluster sonorities by interval-class vector." "Study set relationships: Z-related sets share the same vector." "Compose with symmetry: use vectors to find sonorities with specific coloristic properties.")
  :related ("alg/pcset" "alg/prime-form" "alg/normal-form" "alg/triad")
  :learn (:concept "Pitch-class interval counts as a harmonic fingerprint" :prerequisites ("alg/pcset") :progression "alg/prime-form → alg/triad")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A composer wants to compare two chords by interval content, not by voicing — the interval vector answers 'do these sonorities have the same harmonic color?'"
     :program "(list (alg/interval-vector (alg/pcset (list 0 4 7)))\n      (alg/interval-vector (alg/pcset (list 0 3 7))))"
     :explanation "Major and minor triads have the same interval vector (1 0 1 1 1 0); operator sees two identical vectors — Z-related."
     :meta "prime-form gives a canonical name; interval-vector gives the coloristic content. Two Z-related sets share interval-vector but have different prime-forms.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: pcset; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'histogram of pairwise differences'"
     :rungs (
       (:domain "alg native" :code "(list (alg/interval-vector (alg/pcset (list 0 4 7)))")
       (:domain "histogram of pixel-color differences" :code "(color/interval-histogram px)")
       (:domain "interval-class distribution" :code "⟨ic_1, ic_2, ..., ic_6⟩"))
     :explanation "Rung 1 is alg/interval-vector in its native library. Rung 2 shows the same ''histogram of pairwise differences'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''histogram of pairwise differences'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/interval-vector."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "The interval vector is invariant under transposition and inversion."
     :program "(define c (alg/pcset (list 0 4 7)))\n(define ct (alg/transpose c 3))\n(equal? (alg/interval-vector c) (alg/interval-vector ct))"
     :invariant "∀ S, k. iv(T_k(S)) = iv(S)  ∧  ∀ S. iv(I(S)) = iv(S)"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-04 (Groups & Symmetry).")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the pcset category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "alg/interval-vector — see :summary."
     :composition "(define triads (list (alg/pcset (list 0 4 7)) (alg/pcset (list 0 3 7)) (alg/pcset (list 0 3 6))))\n(map alg/interval-vector triads)"
     :emergent "harmonic-classifier"
     :meta "The emergent harmonic-classifier belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Interval vector = histogram = fingerprint; same family as color histograms in image classification. See book-of-ml ch-01.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the pcset operations close into the harmonic-classifier pattern."
     :cs "The emergent harmonic-classifier is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/inverse"
  :library "alg"
  :kind "meta"
  :signature "(alg/inverse G a) -> a⁻¹"
  :summary "Return the multiplicative inverse of element a in group G."
  :explanation "In a group G, every element a has a unique inverse a⁻¹ satisfying a·a⁻¹ = a⁻¹·a = e (identity). This inverse undoes the action of a. For instance, in addition mod n, the inverse of 3 is n−3; in permutations, the inverse is the permutation that reverses all swaps. Inverses are essential for solving equations (a·x = b ⟹ x = a⁻¹·b) and defining group homomorphisms."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((G (alg/group-from-table '((e a b) (a b e) (b e a)))))\n  (alg/inverse G 'a))" :note "In Z/3, 'a' is order 3; its inverse is itself (a·a = b, b·a = e)")
    (:dialect "motoi" :tier "intermediate" :code "(let ((G (alg/group-from-table '((e a b c) (a b c e) (b c e a) (c e a b)))))\n  (let ((inv-a (alg/inverse G 'a)))\n    (list (alg/op G 'a inv-a) (alg/op G inv-a 'a))))" :note "Verify a·a⁻¹ = e and a⁻¹·a = e for any element")
    (:dialect "motoi" :tier "expert" :code "(define (solve-equation G a b)\n  ;; solve a·x = b ⟹ x = a⁻¹·b\n  (let ((inv-a (alg/inverse G a)))\n    (alg/op G inv-a b)))\n(let ((G (alg/group-from-table '((e a b c) (a b c e) (b c e a) (c e a b)))))\n  (solve-equation G 'a 'c))" :note "Use inverses to solve group equations")
  )
  :caveats ("Every element has exactly one inverse." "In non-abelian groups, left inverse = right inverse (both exist and are equal)." "The inverse of the identity is itself.")
  :drawbacks ("Lookup is O(|G|²) in the worst case (scan entire table)." "Does not validate that G is a group; if the table is invalid, the result is spurious.")
  :usecases ("Solve linear equations in groups." "Compute powers: a⁻³ = (a⁻¹)·(a⁻¹)·(a⁻¹)." "Analyze subgroup structure: inverses identify generators.")
  :related ("alg/identity" "alg/op" "alg/element-order" "alg/group-from-table")
  :learn (:concept "Inverse as the undoing operation; foundational to group equations" :prerequisites ("alg/identity" "alg/op" "alg/group-from-table") :progression "alg/element-order")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A cryptographic simulation needs to undo a group action — encrypt then decrypt should be identity. The audit is: does the inverse exist and does it undo?"
     :program "(define G (alg/zn 7))\n(define a 3)\n(define inv-a (alg/inverse G a))\n(equal? (alg/op G a inv-a) (alg/identity G))"
     :explanation "3 is a unit mod 7; its inverse is 5 (3·5=15≡1); the operator sees #t."
     :meta "alg/op would iterate to find the inverse; alg/inverse retrieves it directly and errors honestly if the element is not invertible in that group.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: group; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'undo of a composition'"
     :rungs (
       (:domain "alg native" :code "(define G (alg/zn 7))")
       (:domain "sprite undo action" :code "(sprite/undo last-move)")
       (:domain "multiplicative inverse in a group" :code "a·a^-1 = e"))
     :explanation "Rung 1 is alg/inverse in its native library. Rung 2 shows the same ''undo of a composition'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''undo of a composition'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for alg/inverse."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Every group element has a unique two-sided inverse."
     :program "(define G (alg/dihedral 3))\n(define all (alg/op G))\n(let loop ((xs all))\n  (cond ((null? xs) #t)\n        (else (let* ((x (car xs)) (ix (alg/inverse G x)))\n                (and (equal? (alg/op G x ix) (alg/identity G))\n                     (equal? (alg/op G ix x) (alg/identity G))\n                     (loop (cdr xs)))))))"
     :invariant "∀ a ∈ G. ∃! b ∈ G. a·b = b·a = e"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch-advanced-04 (Groups & Symmetry).")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the group category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "alg/inverse — see :summary."
     :composition "(define G (alg/dihedral 4))\n(map (lambda (x) (list x (alg/inverse G x) (alg/op G x (alg/inverse G x))))\n     (alg/op G))"
     :emergent "involutive-map"
     :meta "The emergent involutive-map belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Inverse-then-inverse = identity; the same involution family covers negation, transpose, complex conjugate. See book-of-code ch-02 (boolean-logic).")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the group operations close into the involutive-map pattern."
     :cs "The emergent involutive-map is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "alg/invert"
  :library "alg"
  :kind "meta"
  :signature "(alg/invert pcset [axis]) -> inverted-pcset"
  :summary "Apply inversion to a pitch-class set: map each pitch class p to (axis − p) mod 12."
  :explanation "In pitch-class algebra, inversion is a reflection about a chosen axis. With default axis 0, inversion maps p ↦ (−p) mod 12: C=0→0, C#=1→11, D=2→10, etc. With axis k, it maps p ↦ (2k − p) mod 12, reflecting around the pair (k, k). Inversion is an involution (apply twice to get identity). Combined with transposition, inversion generates the dihedral group D₆ acting on pitch-class sets. It reveals symmetries and is used to relate different harmonies (e.g., major and minor chords under certain inversions)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(alg/invert (alg/pcset '(0 1 2)))" :note "Invert {0,1,2} around axis 0: 0→0, 1→11, 2→10; result {0, 10, 11}")
    (:dialect "motoi" :tier "intermediate" :code "(let ((major (alg/pcset '(0 4 7))))\n  (list 'original major 'inverted (alg/invert major)))" :note "Major triad C-E-G becomes {0, 5, 8}; reveals harmonic mirror")
    (:dialect "motoi" :tier "expert" :code "(define (generate-orbit pcset)\n  (let ((t0 pcset)\n        (i0 (alg/invert pcset))\n        (t6 (alg/transpose pcset 6))\n        (i6 (alg/invert (alg/transpose pcset 6))))\n    (list 'p0 t0 'p6 t6 'i0 i0 'i6 i6)))\n(generate-orbit (alg/pcset '(0 4 7)))" :note "Generate the P-I class (Prime and Inverted forms with transposition); fundamental in twelve-tone technique")
  )
  :caveats ("Axis is an integer 0–11; default 0 inverts around C." "Inversion is an involution: (alg/invert (alg/invert pcset axis) axis) = pcset." "The output is a sorted pitch-class set; inversion does not preserve register or octave.")
  :drawbacks ("Inversion alone (without transposition) may not reveal all symmetries; compose with alg/transpose for full orbit." "Results are sensitive to axis choice; different axes yield different transformed sets." "Domain-specific; primarily useful in music theory and compositional analysis.")
  :usecases ("Discover harmonic relationships: invert a chord to find its mirror." "Twelve-tone composition: generate P/I/R/RI forms." "Analyze set symmetries: is a set self-inverse (palindromic)?")
  :related ("alg/transpose" "alg/pcset" "alg/prime-form" "alg/normal-form" "alg/symmetry-group")
  :learn (:concept "Inversion as reflection symmetry in pitch-class space" :prerequisites ("alg/pcset" "alg/transpose") :progression "alg/transpose → alg/prime-form")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A twelve-tone composer needs the inversion I(S) of a row S under a chosen axis so the composition can present the I-form of the tone-row."
     :program "(alg/invert (alg/pcset (list 0 4 7)))"
     :explanation "Inverted around 0: 0→0, 4→8, 7→5; operator sees (0 5 8)."
     :meta "transpose shifts; invert reflects. Both are affine, but they give different sets — twelve-tone technique needs both.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: pcset; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'reflection in Z/12Z'"
     :rungs (
       (:domain "alg native" :code "(alg/invert (alg/pcset (list 0 4 7)))")
       (:domain "sprite mirror flip" :code "(sprite/flip axis sp)")
       (:domain "inversion I_k in pitch-class algebra" :code "I_k(p) = (k - p) mod 12"))
