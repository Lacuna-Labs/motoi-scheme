;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library game — 32 verbs.")

(chapter :number "28" :library "game" :verb-count 32 :training-eligible #t)

;; ═══ 32 verbs in library game ═══

(verb
  :name "game/frame"
  :library "game"
  :kind "pure"
  :signature "(game/frame id) -> n"
  :summary "Return the frame counter of a specific game instance."
  :explanation "In Motoi Scheme, multiple independent games may be running in the same world via different cards or scenes. game/frame retrieves the frame count for a given game id. Unlike frame, which returns the global studio frame counter, game/frame is scoped to a single game instance. Use it when you need per-game timing (e.g. a card running its own logic independent of the world frame)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((g (big-bang 'my-game)))\n  (on-frame (lambda () (display (game/frame g)))))" :note "Create a game and periodically read its frame counter.")
    (:dialect "motoi" :tier "intermediate" :code "(define g (big-bang 'scene-game))\n(on-frame\n  (lambda ()\n    (when (game/running? g)\n      (let ((f (game/frame g)))\n        (when (= (modulo f 15) 0)\n          (display (list ':game-beat f)))))))" :note "Log the game frame only if the game is running and on a 15-frame boundary.")
    (:dialect "motoi" :tier "expert" :code "(define games (list (big-bang 'game-a) (big-bang 'game-b)))\n(on-frame\n  (lambda ()\n    (for-each\n      (lambda (g)\n        (when (game/running? g)\n          (let ((f (game/frame g)))\n            (display (list (game/state g) f)))))\n      games)))" :note "Poll multiple game instances and log each one's frame and state, filtering out stopped games.")
  )
  :caveats ("game/frame requires a valid game id; passing an invalid id will escalate." "game/frame is only meaningful while the game is running; after game/stop, the frame value is stale." "Each game instance has its own independent frame counter; they do not sync with the studio frame or each other.")
  :drawbacks ("No direct way to reset a game's frame counter; create a new game instance if you need a fresh frame clock." "game/frame is read-only; use game/step or the game's on-tick handler to advance time.")
  :usecases ("Synchronize per-game logic to that game's timeline (e.g. a card's internal clock)." "Implement frame-rate-independent timing by comparing game/frame values across frames." "Debug multi-game scenarios by logging each game's frame independently.")
  :related ("big-bang" "game/running?" "game/state" "game/step" "frame" "on-frame")
  :learn (:concept "Scoped frame counters: each game world has its own time, independent of other games or the studio." :prerequisites ("big-bang" "frame") :progression "After querying game/frame, learn game/state and game/step to inspect and advance the game's full state.")
  :row-2-audit ((:problem "Two independent games run in parallel; the operator needs to log each one's own tick counter, not the shared studio frame."
                 :program "(define ga (big-bang 'a))\n(define gb (big-bang 'b))\n(list (game/frame ga) (game/frame gb))"
                 :explanation "Create two games. Query each one's frame counter. Independent numbers, one per world."
                 :meta "Reach for game/frame over the global frame primitive when per-game time matters; the global frame would give both games the same number.")
                (:eng "Per-game frames let the operator disambiguate logs of concurrent worlds."
                 :math "frame : id → ℕ, injective on ids."
                 :cs "Registry lookup by id; O(1)."))
  :row-3-dimension ((:setup "per-instance counter scoped by id: same shape appears in games, in processes, in loggers with correlation ids"
                     :rungs ((:domain "game" :code "(let ((g (big-bang 'x))) (game/frame g))")
                             (:domain "process" :code "(define (proc-id pid) (list 'process pid 'ticks 0))\n(proc-id 42)")
                             (:domain "logger" :code "(define (with-cid cid msg) (list cid msg))\n(with-cid 'req-1 'saved)"))
                     :explanation "Rung 1 reads per-game frame. Rung 2 tags per-process ticks. Rung 3 tags per-request logs. Each scopes a counter to an identifier."
                     :meta "The shape transfers because 'per-key counter' is one primitive across systems.")
                    (:eng "OS pids, request tracing, and per-game frames all instantiate 'scope by id'."
                     :math "counter : id × ℕ → ℕ."
                     :cs "Same registry pattern."))
  :row-4-proof ((:claim "game/frame is monotone: successive queries give non-decreasing values."
                 :program "(define g (big-bang 'x))\n(define f1 (game/frame g))\n(game/step g)\n(define f2 (game/frame g))\n(>= f2 f1)"
                 :invariant "∀ id t1<t2. frame(id, t1) ≤ frame(id, t2)"
                 :meta "Monotonicity is the defining property of a step counter. Falsified by any observed decrease. See book-of-code on monotone counters.")
                (:eng "Regression: frame never regresses across game/step."
                 :math "Non-decreasing sequence."
                 :cs "One assertion."))
  :row-5-emergence ((:base "game/frame reads the per-game tick counter."
                     :composition "(define g (big-bang 'x))\n(define (heartbeat g interval)\n  (when (= (modulo (game/frame g) interval) 0)\n    (list 'beat (game/frame g))))\n(heartbeat g 10)"
                     :emergent "A per-game heartbeat: chaining game/frame with modulo yields periodic-tick signals."
                     :meta "This is the same family as a cron/interval scheduler. Cross-ref book-of-composition on periodic triggers.")
                    (:eng "Heartbeats are how UIs animate spinners without global state."
                     :math "frame mod k = 0 defines a subsequence."
                     :cs "Composition = read + mod + guard.")))

(verb
  :name "game/grundy"
  :library "game"
  :kind "meta"
  :signature "(game/grundy state-set moves-fn) -> nimber"
  :summary "Compute the Grundy number (nimber) of an impartial game via mex-recursion."
  :explanation "In combinatorial game theory, the Grundy number of a position is the minimum excludant (mex) of the Grundy numbers of all positions reachable in one move. game/grundy automates this recursive computation with memoization: you provide a set of starting states and a function that generates the next states from a given state, and game/grundy returns the nimber. The nimber encodes the winning strategy of the game: a position with nimber 0 is a losing (second-player) position; any other nimber is a winning (first-player) position. This is the core engine for solving games like Nim, Wythoff's game, or custom rulesets."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(game/grundy '(3 5 7) (lambda (state) (list (- state 1))))" :note "Compute the Grundy number of a position where you can subtract 1 from any state.")
    (:dialect "motoi" :tier "intermediate" :code "(define (game-moves state)\n  (let ((valid '()))\n    (for-each\n      (lambda (subtract)\n        (when (>= state subtract)\n          (set! valid (cons (- state subtract) valid))))\n      '(1 2 3))\n    valid))\n(let ((nimber (game/grundy '(10) game-moves)))\n  (display (if (= nimber 0) 'losing 'winning)))" :note "Define a moves function that generates all reachable states, then classify a position as winning or losing.")
    (:dialect "motoi" :tier "expert" :code "(define (multi-heap-moves heaps)\n  (fold-left\n    (lambda (results i)\n      (let ((h (list-ref heaps i)))\n        (fold-left\n          (lambda (acc remove)\n            (when (> h remove)\n              (let ((new-heaps (map (lambda (j) (if (= j i) (- h remove) (list-ref heaps j)))\n                                     (range 0 (length heaps)))))\n                (cons new-heaps acc))))\n          results\n          '(1 2))))\n    '()\n    (range 0 (length heaps))))\n(game/grundy '((3 5 7)) multi-heap-moves)" :note "Solve a multi-heap game (like Nim) by recursively removing from each heap; the Grundy number predicts the winner.")
  )
  :caveats ("If the game tree is infinite or very large, memoization may exhaust the fuel budget and return 'fuel-budget instead of a nimber; check the result." "moves-fn must be deterministic; if the same state generates different successors on different calls, the memoization cache will give wrong answers." "The starting state-set should be a singleton list for most use cases; passing multiple states returns the mex of their nimbers (useful for parallel games)." "Nimbers are bitwise XOR-closed; combining independent games is done via game/nim-sum, not addition.")
  :drawbacks ("No way to extract the actual winning move; game/grundy only returns the nimber. Use game/ttt-best-move for tic-tac-toe or roll your own minimax for other games." "The memoization cache is global and not easily cleared; redefining moves-fn will not invalidate old cache entries (use for testing only)." "State representation matters: if two logically identical states have different representation, they will be cached separately, wasting memory.")
  :usecases ("Solve impartial games (both players have the same moves) by computing the winner from any position." "Analyze multi-heap games (Nim, Wythoff, etc.) without hardcoded lookup tables." "Build a game-playing AI that always makes optimal moves in a small game tree.")
  :related ("game/mex" "game/nim-sum" "game/nim-outcome" "game/ttt-best-move" "game/surreal")
  :learn (:concept "Grundy numbers: a numeric encoding of optimal play in impartial games. Compute via mex-recursion over all reachable states." :prerequisites ("game/mex" "lambda" "fold-left") :progression "After computing Grundy numbers, learn game/nim-outcome to apply the theory to Nim, and game/surreal for partisan (asymmetric) games.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A teacher needs to decide whether a custom subtraction game is a first-player win. What computes the answer for any move set?"
                 :program "(define moves (lambda (n) (filter (lambda (x) (>= x 0)) (map (lambda (k) (- n k)) '(1 2 3)))))\n(define g (game/grundy '(10) moves))\n(if (= g 0) 'second-player-wins 'first-player-wins)"
                 :explanation "Define the move-generator (subtract 1, 2, or 3 from the current heap). Compute the Grundy number from starting pile 10. Zero means the mover loses; non-zero, wins."
                 :meta "Reach for game/grundy over hand-rolled minimax when the game is impartial; nimbers collapse the tree to a scalar.")
                (:eng "Log the nimber; a change over game versions signals rule drift."
                 :math "G(s) = mex{G(s') : s' ∈ moves(s)}."
                 :cs "Memoized recursion; may hit fuel budget."))
  :row-3-dimension ((:setup "recursive collapse to a fixed point via mex: same shape appears in games, in graph coloring, in constraint propagation"
                     :rungs ((:domain "game" :code "(game/grundy '(3) (lambda (n) (if (> n 0) (list (- n 1)) '())))")
                             (:domain "coloring" :code "(define (min-free-color used)\n  (let loop ((c 0)) (if (memv c used) (loop (+ c 1)) c)))\n(min-free-color '(0 1 3))")
                             (:domain "propagation" :code "(define (fixed-point f x) (let loop ((cur x)) (let ((nxt (f cur))) (if (equal? nxt cur) cur (loop nxt)))))\n(fixed-point (lambda (s) (map (lambda (x) (min x 3)) s)) '(5 2 4))"))
                     :explanation "Rung 1 finds a game's nimber via mex-recursion. Rung 2 assigns the smallest free color. Rung 3 iterates to a fixed point. All three fold a graph of dependencies into a scalar or stable configuration."
                     :meta "The shape transfers because 'recursive collapse via mex/argmin' is one primitive.")
                    (:eng "Constraint solvers, game analyzers, and graph colorers share this pattern."
                     :math "Fixed-point of mex operator."
                     :cs "Memoization key; same solver kernel."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Two positions with the same Grundy number are equivalent under sum: their nim-sum is 0."
                 :program "(define a (game/grundy '(3) (lambda (n) (if (> n 0) (list (- n 1)) '()))))\n(define b (game/grundy '(3) (lambda (n) (if (> n 0) (list (- n 1)) '()))))\n(= (game/nim-sum (list a b)) 0)"
                 :invariant "∀ s. G(s) ⊕ G(s) = 0"
                 :meta "Self-XOR annihilation is the definition of nim-sum. Falsified by any nonzero result. See book-of-math on XOR.")
                (:eng "Regression: pair of identical games XOR to 0."
                 :math "a ⊕ a = 0."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/grundy returns the nimber of a game position."
                     :composition "(define moves (lambda (n) (filter positive? (map (lambda (k) (- n k)) '(1 2 3)))))\n(define positive? (lambda (x) (> x 0)))\n(define games '(5 8 11))\n(define nims (map (lambda (start) (game/grundy (list start) moves)) games))\n(fold-left (lambda (acc n) (game/nim-sum (list acc n))) 0 nims)"
                     :emergent "A multi-component solver: chaining game/grundy over independent games and combining with nim-sum yields the overall game value."
                     :meta "This is the same family as decomposing a big problem into independent sub-problems and XOR-combining. Cross-ref book-of-composition on component-wise solvers.")
                    (:eng "Complex tabletop games with independent parts use this decomposition."
                     :math "Sum-of-games: G(A + B) = G(A) ⊕ G(B)."
                     :cs "Map + reduce with XOR.")))

(verb
  :name "game/mex"
  :library "game"
  :kind "meta"
  :signature "(game/mex numbers-list) -> n"
  :summary "Return the minimum excludant (mex): the smallest non-negative integer not in the list."
  :explanation "The mex of a set of non-negative integers is the smallest natural number that is absent from the set. For example, the mex of (0 1 3) is 2; the mex of (1 2 3) is 0. In game theory, mex is the core operation for computing Grundy numbers: the nimber of a position is the mex of the nimbers of all positions reachable in one move. game/mex directly computes this; use it to implement game solvers or to reason about the structure of game trees."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(game/mex '(0 1 2))" :note "The smallest integer not in the list 0, 1, 2 is 3.")
    (:dialect "motoi" :tier "intermediate" :code "(define (nimber-of-position successors)\n  (game/mex (map nimber-of-position successors)))\n(nimber-of-position '((0) (1) (2)))" :note "Use mex to compute Grundy numbers recursively: the nimber is the mex of successors' nimbers.")
    (:dialect "motoi" :tier "expert" :code "(define (analyze-game-state state moves-fn)\n  (let ((successors (moves-fn state)))\n    (let ((successor-nimbers (map (lambda (s) (analyze-game-state s moves-fn)) successors)))\n      (game/mex successor-nimbers))))\n(analyze-game-state 'start (lambda (s) (list (list s 1) (list s 2))))" :note "Recursive game solver: compute the Grundy number of any state by mex-ing the nimbers of all successors (foundation for game/grundy).")
  )
  :caveats ("game/mex expects a list of non-negative integers; passing negative numbers, non-integers, or non-numeric values will produce unexpected results." "An empty list has mex 0 (since 0 is the smallest non-negative integer and is absent from the empty set)." "The list may be in any order; game/mex does not assume sorting.")
  :drawbacks ("O(n) scan for each call; if you need to compute mex many times, caching or bulk operations may be faster." "No built-in way to compute multiple mex queries on the same list; you must call game/mex once per query.")
  :usecases ("Compute Grundy numbers for impartial games by mex-ing successor nimbers." "Check whether a set of heap sizes (in Nim) is a losing position (nimber 0) via game/nim-sum." "Verify game-theoretic properties: positions with mex 0 are second-player wins.")
  :related ("game/grundy" "game/nim-sum" "game/nim-outcome" "list" "map")
  :learn (:concept "Mex (minimum excludant): the fundamental operation in Grundy-number arithmetic. Every position's nimber is the mex of its successors' nimbers." :prerequisites ("list" "map") :progression "Use game/mex in game/grundy; compose with game/nim-sum to analyze multi-component games.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A recursive solver needs the smallest non-negative integer absent from a set of successor nimbers."
                 :program "(define succs '(0 1 3 4))\n(game/mex succs)"
                 :explanation "Given the successors' nimbers, mex returns 2 — the smallest missing non-negative integer. This is the current node's Grundy number."
                 :meta "Reach for mex, not min or max; mex captures 'first gap in the coverage' which is what game-theoretic value assignment requires.")
                (:eng "Log the mex; a mex of 0 means the current position is losing."
                 :math "mex(S) = min(ℕ \\ S)."
                 :cs "O(n) scan; return first missing."))
  :row-3-dimension ((:setup "smallest-absent-token in a set: same shape appears in game theory, in slot allocation, in generation of unique ids"
                     :rungs ((:domain "game" :code "(game/mex '(0 1 2 4))")
                             (:domain "slot-alloc" :code "(define (next-free used)\n  (let loop ((i 0)) (if (memv i used) (loop (+ i 1)) i)))\n(next-free '(0 1 3))")
                             (:domain "unique-id" :code "(define (next-id issued)\n  (let loop ((i 0)) (if (memv i issued) (loop (+ i 1)) i)))\n(next-id '(0 2))"))
                     :explanation "Rung 1 finds the game-theoretic mex. Rung 2 allocates the next free slot. Rung 3 assigns the next unique id. All three scan a set for the smallest gap."
                     :meta "The shape transfers because 'smallest absent non-negative integer' is a substrate-neutral primitive.")
                    (:eng "Resource allocators, id generators, and game solvers share this scan."
                     :math "mex : 2^ℕ → ℕ."
                     :cs "Linear scan; O(n)."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "mex of a set is not in the set."
                 :program "(define s '(0 1 2 4))\n(define m (game/mex s))\n(not (memv m s))"
                 :invariant "∀ S ⊂ ℕ. mex(S) ∉ S"
                 :meta "Absence-from-set is definitional. Falsified only by a broken scan. See book-of-math on Grundy theory.")
                (:eng "Regression: mex output is never a member of the input."
                 :math "mex(S) ∉ S."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/mex returns the smallest absent non-negative integer."
                     :composition "(define (grundy-step state gens)\n  (game/mex (map (lambda (s) (car s)) (gens state))))\n(grundy-step 3 (lambda (n) (map (lambda (k) (list (- n k))) '(1 2 3))))"
                     :emergent "One step of nim-value assignment: chaining mex with a successor-generator yields the current Grundy value."
                     :meta "This is the same family as one step of Bellman iteration in DP. Cross-ref book-of-composition on Bellman.")
                    (:eng "Game solvers, DP planners, and constraint solvers share this step."
                     :math "One Bellman/mex iteration."
                     :cs "Composition = generate successors + mex.")))

(verb
  :name "game/nim-outcome"
  :library "game"
  :kind "meta"
  :signature "(game/nim-outcome heap-list) -> symbol"
  :summary "Classify a Nim position as a first-player or second-player win based on nim-sum."
  :explanation "Nim is a classical impartial game: two players take turns removing any number of objects from a single heap. The player who takes the last object wins. The key insight is that a position is a second-player (losing) win if and only if the nim-sum (XOR of all heap sizes) is 0; otherwise it is a first-player (winning) win. game/nim-outcome computes the nim-sum of a position and returns a symbol indicating the outcome: either a first-player or second-player victory. This is the cannonical solver for Nim and similar games."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(game/nim-outcome '(3 5 6))" :note "Classify the Nim position (3, 5, 6): the nim-sum is 3 ⊕ 5 ⊕ 6 = 0, so second player wins.")
    (:dialect "motoi" :tier "intermediate" :code "(define (nim-solver heaps)\n  (let ((outcome (game/nim-outcome heaps)))\n    (cond\n      ((eq? outcome 'first-player-win)\n       (list ':you-can-win-from heaps))\n      (else\n       (list ':you-will-lose-from heaps)))))\n(nim-solver '(1 4 5))" :note "Wrap the outcome in a helper to provide user-friendly feedback about a position.")
    (:dialect "motoi" :tier "expert" :code "(define (nim-best-move heaps)\n  (let ((target-xor 0))\n    (fold-left\n      (lambda (moves i)\n        (let ((remove (- (list-ref heaps i) target-xor)))\n          (if (and (>= (list-ref heaps i) remove) (> remove 0))\n            (cons (list i remove) moves)\n            moves)))\n      '()\n      (range 0 (length heaps)))))\n(define heaps '(3 5 6))\n(if (eq? (game/nim-outcome heaps) 'first-player-win)\n  (display (nim-best-move heaps))\n  (display 'no-winning-move))" :note "Check the outcome; if first player can win, compute a winning move by reducing a heap to make nim-sum 0.")
  )
  :caveats ("game/nim-outcome assumes the standard (normal-play) Nim rule: the last player wins. It does not handle misère Nim (last player loses)." "Heap sizes must be non-negative integers; passing negative or non-numeric values gives undefined behavior." "The order of heaps does not matter; (3 5 6) and (6 3 5) have the same outcome.")
  :drawbacks ("game/nim-outcome only returns the outcome, not the optimal move; use the nim-sum value directly or roll your own move selection." "No built-in way to find all moves that lead to a second-player-win position; you must iterate and check each move manually.")
  :usecases ("Teach students game theory by computing the winner of any Nim position instantly." "Build a Nim-playing bot that never loses: check the outcome and always move to make nim-sum 0." "Analyze Nim variants (like Wythoff's game) by comparing their outcome structure to standard Nim.")
  :related ("game/nim-sum" "game/mex" "game/grundy" "game/wythoff-p?" "game/ttt-best-move")
  :learn (:concept "Nim strategy via nim-sum: a position is a second-player win iff nim-sum = 0. Outcome classification is instant." :prerequisites ("game/nim-sum") :progression "Extend Nim theory: use game/grundy for non-Nim games, and game/surreal for partisan (asymmetric) games.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A user hands over a Nim board and asks: is this position winnable if I move next?"
                 :program "(define heaps '(3 4 5))\n(game/nim-outcome heaps)"
                 :explanation "Compute the nim outcome for heaps (3,4,5). Returns 'first-player-win or 'second-player-win."
                 :meta "Reach for nim-outcome, not raw XOR, when the caller wants a plain symbol; nim-sum returns a number the operator still has to interpret.")
                (:eng "Log the outcome; a user reporting 'first-player-win but I lost' points to a misplay, not a bug."
                 :math "outcome = if XOR(heaps) = 0 then second else first."
                 :cs "Pure eval; O(n) in heap count."))
  :row-3-dimension ((:setup "sign-of-invariant decides an outcome: same shape appears in Nim, in parity games, in P/NP classification"
                     :rungs ((:domain "game" :code "(game/nim-outcome '(3 4 5))")
                             (:domain "parity" :code "(define (parity xs) (if (odd? (apply + xs)) 'odd 'even))\n(parity '(1 2 3 4))")
                             (:domain "class" :code "(define (classify v thresh) (if (> v thresh) 'positive 'non-positive))\n(classify 5 0)"))
                     :explanation "Rung 1 uses XOR-of-heaps as an invariant. Rung 2 uses sum-parity as an invariant. Rung 3 uses value-vs-threshold. All three collapse a state to a category via a single invariant."
                     :meta "The shape transfers because 'category from invariant' is one primitive.")
                    (:eng "Game solvers, static analyzers, and classifiers share this pattern."
                     :math "Classify = predicate(invariant(state))."
                     :cs "One reduction + one branch."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Empty heaps is a second-player win."
                 :program "(eq? (game/nim-outcome '()) 'second-player-win)"
                 :invariant "outcome([]) = second-player-win"
                 :meta "Empty XOR is 0, which is the P-position. Falsified by any implementation returning first-player. See book-of-math on nim theory.")
                (:eng "Regression: empty Nim is a losing position for the mover."
                 :math "XOR([]) = 0."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/nim-outcome classifies a Nim position."
                     :composition "(define boards '((3 4 5) (1 2 3) (5 5 5)))\n(map game/nim-outcome boards)"
                     :emergent "A Nim classifier fleet: chaining nim-outcome over many positions yields a game-catalog analysis."
                     :meta "This is the same family as batch-classifying instances by a rule. Cross-ref book-of-composition on batch classifiers.")
                    (:eng "Puzzle authors run outcome sweeps to find good example positions."
                     :math "outcome : 2^ℕ → {first, second}."
                     :cs "Trivially map-parallel.")))

(verb
  :name "game/nim-sum"
  :library "game"
  :kind "meta"
  :signature "(game/nim-sum heap-list) -> n"
  :summary "Return the nim-sum (XOR) of a list of heap sizes, which is the Grundy value of a Nim position."
  :explanation "Nim is the canonical impartial game, and its theory rests on a single idea: the nim-sum (bitwise XOR) of all heap sizes encodes the position's value. If nim-sum is 0, the position is a losing (second-player) win; otherwise it is a winning (first-player) win. game/nim-sum computes this XOR directly. In fact, nim-sum is the same as the Grundy number for Nim: it is the minimum excludant (mex) of all positions reachable in one move. Use game/nim-sum to reason about Nim, to find winning moves (reduce a heap so nim-sum becomes 0), or to compare Nim to other games."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(game/nim-sum '(3 5 6))" :note "Compute 3 ⊕ 5 ⊕ 6 = 0 (the heaps sum to a losing position).")
    (:dialect "motoi" :tier "intermediate" :code "(define (is-losing-position heaps)\n  (= (game/nim-sum heaps) 0))\n(display (is-losing-position '(3 5 6)))\n(display (is-losing-position '(1 2 3)))" :note "Test whether a position is a second-player win (nim-sum 0) or first-player win (nim-sum non-zero).")
    (:dialect "motoi" :tier "expert" :code "(define (bitwise-xor a b) (let loop ((a a) (b b) (out 0) (bit 1)) (if (and (= a 0) (= b 0)) out (loop (quotient a 2) (quotient b 2) (+ out (* bit (modulo (+ a b) 2))) (* bit 2)))))\n(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(define (find-winning-moves heaps)\n  (let ((target (game/nim-sum heaps)))\n    (fold-left\n      (lambda (moves i)\n        (let ((h (list-ref heaps i))\n              (new-h (bitwise-xor (list-ref heaps i) target)))\n          (if (< new-h h)\n            (cons (list ':heap i ':remove (- h new-h)) moves)\n            moves)))\n      '()\n      (range 0 (length heaps)))))\n(find-winning-moves '(3 5 6))" :note "If nim-sum is non-zero, find all moves that reduce it to 0 by XORing each heap with the nim-sum.")
  )
  :caveats ("game/nim-sum is XOR, not addition; 3 + 5 ≠ 3 ⊕ 5. XOR is commutative and self-inverse: a ⊕ a = 0." "An empty heap list has nim-sum 0 (the empty XOR is the identity, 0)." "Heap sizes must be non-negative integers; passing negative or non-numeric values is undefined.")
  :drawbacks ("game/nim-sum only computes the value, not the strategy; you must use it as a building block (e.g., to find winning moves)." "Nim-sum is specific to Nim; other games use Grundy numbers or surreal numbers, which require game/grundy or game/surreal.")
  :usecases ("Analyze any Nim position: nim-sum 0 means second player wins; any other value means first player can win." "Find winning moves in Nim by XORing each heap with the current nim-sum; any heap that becomes smaller is a valid winning move." "Verify game-theoretic theory: the nim-sum is the Grundy number of the position, so game/nim-sum = game/grundy for Nim.")
  :related ("game/nim-outcome" "game/grundy" "game/mex" "game/wythoff-p?" "bitwise-xor")
  :learn (:concept "Nim-sum (XOR): the invariant that encodes optimal play in Nim. A position is a second-player win iff nim-sum = 0." :prerequisites ("list" "fold-left" "modulo") :progression "Master Nim via nim-sum; extend to game/grundy for non-Nim games, and game/wythoff-p? for Wythoff's game.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A Nim solver needs the raw XOR of heap sizes to search for winning moves."
                 :program "(define heaps '(3 5 6))\n(game/nim-sum heaps)"
                 :explanation "Compute XOR = 0 (losing). The solver knows there is no winning move from this position."
                 :meta "Reach for nim-sum over hand-rolled loops; it's the canonical XOR-fold used by the whole theory.")
                (:eng "Log the XOR; zero means losing, non-zero means winning."
                 :math "XOR reduction."
                 :cs "O(n) fold."))
  :row-3-dimension ((:setup "XOR-reduction as an invariant: same shape appears in Nim, in checksums, in error detection"
                     :rungs ((:domain "game" :code "(game/nim-sum '(3 5 6))")
                             (:domain "checksum" :code "(define (xor-checksum bytes) (fold-left (lambda (a b) (bitwise-xor a b)) 0 bytes))\n'checksum-example")
                             (:domain "parity-bit" :code "(define (parity-bit bits) (modulo (apply + bits) 2))\n(parity-bit '(1 0 1 1))"))
                     :explanation "Rung 1 XORs heap sizes. Rung 2 XORs bytes. Rung 3 sums bits mod 2. All three fold a stream to a scalar via a self-inverse operator."
                     :meta "The shape transfers because 'reduce with a self-inverse operator' is one primitive.")
                    (:eng "Networking, storage, and game theory all use self-inverse folds."
                     :math "Reduce with ⊕: a ⊕ a = 0."
                     :cs "One-pass fold."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Nim-sum of a list XORed with itself is zero."
                 :program "(define heaps '(3 5 6))\n(define s (game/nim-sum heaps))\n(= (game/nim-sum (list s s)) 0)"
                 :invariant "∀ heaps. XOR(heaps) ⊕ XOR(heaps) = 0"
                 :meta "Self-inverse follows from XOR properties. Falsified only by broken XOR. See book-of-math on XOR.")
                (:eng "Regression: XOR self-cancellation."
                 :math "a ⊕ a = 0."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/nim-sum XORs heap sizes."
                     :composition "(define heaps '(3 5 7))\n(define s (game/nim-sum heaps))\n(define (find-winning-move heaps s)\n  (fold-left (lambda (acc h) (if (or (not (null? acc)) (>= h (bitwise-xor h s))) acc (cons (bitwise-xor h s) acc))) '() heaps))\n(find-winning-move heaps s)"
                     :emergent "A move-finder: chaining nim-sum with per-heap XOR checks yields the winning reduction target."
                     :meta "This is the same family as gradient-guided search — invariant tells you which axis to change. Cross-ref book-of-composition on invariant-guided moves.")
                    (:eng "Nim bots use this to always play optimally."
                     :math "Reduce heap h to h ⊕ s if smaller."
                     :cs "One-pass scan.")))

(verb
  :name "game/running?"
  :library "game"
  :kind "pure"
  :signature "(game/running? id) -> #t | #f"
  :summary "Test whether a game instance is currently running."
  :explanation "Each game instance (created via big-bang) has a running/stopped state. game/running? returns #t if the game is active (the loop is ticking and on-tick is being called), and #f if it has been stopped (via game/stop). Use game/running? to guard logic that should only execute while a game is active, or to check whether it is safe to query game/frame or game/state."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((g (big-bang 'test)))\n  (display (game/running? g)))" :note "A freshly created game is running, so this prints #t.")
    (:dialect "motoi" :tier "intermediate" :code "(define g (big-bang 'my-game))\n(on-frame\n  (lambda ()\n    (when (game/running? g)\n      (display (list 'frame (game/frame g))))))" :note "Safely query game/frame only when the game is running.")
    (:dialect "motoi" :tier "expert" :code "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define games (list (big-bang 'game-a) (big-bang 'game-b)))\n(on-frame\n  (lambda ()\n    (let ((active (filter game/running? games)))\n      (for-each\n        (lambda (g)\n          (display (list (game/state g) (game/frame g))))\n        active))))" :note "Filter the list of games to only those still running, then query their state and frame.")
  )
  :caveats ("game/running? returns #f for invalid or destroyed game ids; it does not error." "A game may be running but not actually ticking if it is paused or hidden; game/running? only checks the stopped flag, not visibility or pause state." "Calling game/running? does not block or advance time; it is a pure read.")
  :drawbacks ("No way to pause a game without stopping it; game/stop is all-or-nothing." "game/running? does not tell you why a game is stopped; check game/state to inspect the state post-mortem.")
  :usecases ("Guard frame-by-frame logic to avoid errors when querying a stopped game." "Implement game-over sequences: check game/running? to detect when a game has ended, then display a summary." "Manage multiple concurrent games: poll each to skip those that have stopped.")
  :related ("big-bang" "game/stop" "game/frame" "game/state" "on-frame")
  :learn (:concept "Game lifecycle: a game is created (big-bang), runs (game/running? = #t), and is stopped (game/stop, game/running? = #f)." :prerequisites ("big-bang" "game/frame" "game/state") :progression "Once you can check and manage game state, learn game/step to manually advance the game without the loop.")
  :row-2-audit ((:problem "A tick handler must skip stopped games to avoid errors on game/step. What predicate guards?"
                 :program "(define g (big-bang 'x))\n(when (game/running? g) (game/step g))"
                 :explanation "Guard the step call with game/running?. If the game has been stopped, skip."
                 :meta "Reach for game/running? over inspecting game/state; the former is the canonical liveness check.")
                (:eng "Guarded step avoids escalations from stopped games."
                 :math "running? : id → 𝔹."
                 :cs "Registry read; O(1)."))
  :row-3-dimension ((:setup "liveness predicate on a resource: same shape appears in games, in file handles, in threads"
                     :rungs ((:domain "game" :code "(game/running? (big-bang 'x))")
                             (:domain "handle" :code "(define (open? h) (not (eq? h 'closed)))\n(open? 'closed)")
                             (:domain "thread" :code "(define (alive? t) (eq? (car t) 'running))\n(alive? '(running 42))"))
                     :explanation "Rung 1 checks game liveness. Rung 2 checks handle liveness. Rung 3 checks thread liveness. Each queries a resource's state to decide whether to act."
                     :meta "The shape transfers because 'liveness before use' is universal in resource management.")
                    (:eng "OS, runtime, and game systems all guard reads and writes with liveness."
                     :math "alive? : resource → 𝔹."
                     :cs "One indirection + one compare."))
  :row-4-proof ((:claim "A freshly created game is running."
                 :program "(game/running? (big-bang 'x))"
                 :invariant "∀ x. running?(big-bang(x)) = #t"
                 :meta "Fresh-alive is the constructor invariant. Falsified by any dead-on-arrival game. See book-of-code on constructor invariants.")
                (:eng "Regression: newly-created games are alive."
                 :math "Constructor postcondition."
                 :cs "One assertion."))
  :row-5-emergence ((:base "game/running? predicate on a game id."
                     :composition "(define games (list (big-bang 'a) (big-bang 'b) (big-bang 'c)))\n(game/stop (cadr games))\n(filter game/running? games)"
                     :emergent "A living-games filter: chaining running? with filter yields only the alive games."
                     :meta "This is the same family as any liveness-based partitioning. Cross-ref book-of-composition on predicate filters.")
                    (:eng "Scene managers use this to decide which games get frame updates."
                     :math "filter : (id list × pred) → id list."
                     :cs "One-pass filter.")))

(verb
  :name "game/star-n"
  :library "game"
  :kind "meta"
  :signature "(game/star-n n) -> surreal-nimber"
  :summary "Construct the nimber *n, the canonical impartial game value with Grundy number n."
  :explanation "In combinatorial game theory, nimbers (or nim-values) are the equivalence classes of impartial games under sum. The nimber *n represents the unique impartial game with Grundy number n. Negative inputs map to 'nan (not-a-nimber). This verb lets you build game positions that can be analyzed via nim-sum and compared for winning strategy."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define nim-zero (game/star-n 0))\n(define nim-one (game/star-n 1))" :note "Construct nimbers 0 and 1, which represent games with Grundy numbers 0 (P-position, losing) and 1 (N-position, winning).")
    (:dialect "motoi" :tier "intermediate" :code "(define (is-losing-nimber? s)\n  (game/surreal-eq? s (game/star-n 0)))\n(if (is-losing-nimber? (game/star-n 0))\n    (display \"position is P\"))" :note "Use game/surreal-eq? to test whether a nimber equals *0 (the losing position in impartial games).")
    (:dialect "motoi" :tier "expert" :code "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(define (analyze-game-pile sizes)\n  (let ((nimbers (map game/star-n sizes)))\n    (fold-left\n      (lambda (acc n) (game/nim-sum acc n))\n      (game/star-n 0)\n      nimbers)))\n(if (game/surreal-eq? (analyze-game-pile '(3 5 7)) (game/star-n 0))\n    (display \"next player loses\"))" :note "Combine multiple pile sizes via nim-sum to determine the game outcome; if the XOR is *0, the next mover is in a losing position.")
  )
  :caveats ("Negative n maps to 'nan; always check for valid input in untrusted contexts." "Nimbers are a subclass of surreal numbers; use game/surreal-eq? and game/surreal-add (nim-sum) for comparison and combination." "game/star-n does not validate that n is an integer; non-integer inputs produce undefined behavior.")
  :drawbacks ("Constructing large nimbers (very high Grundy numbers) may be computationally expensive; use memoization if analyzing many positions." "Surreal operations on nimbers do not commute with all operations; use only game-theoretic verbs (nim-sum, Grundy equivalence) for correct results.")
  :usecases ("Analyzing impartial combinatorial games (Nim, Wythoff, staircase, Green Hackenbush on trees)." "Computing the Grundy number of a game position by building nimbers and comparing sums." "Teaching combinatorial game theory: demonstrating P/N-positions and nim arithmetic.")
  :related ("game/nim-sum" "game/surreal" "game/surreal-eq?" "game/surreal-add" "game/wythoff-p?")
  :learn (:concept "Nimbers as the Grundy numbers of impartial games; *n encodes all positions equivalent under sum." :prerequisites ("game/surreal" "game/surreal-eq?") :progression "Learn nim-sum (game/nim-sum) next to combine nimbers; then study game/wythoff-p? for specific game families.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A partisan-game solver needs to build a canonical nim-value from an integer."
                 :program "(define n (game/star-n 3))\nn"
                 :explanation "Construct the nimber *3. Feed into surreal arithmetic and comparisons downstream."
                 :meta "Reach for game/star-n rather than raw surreal construction; star-n is the canonical constructor and yields a canonical form.")
                (:eng "Log 'star-N built' with n; malformed n (negative) returns 'nan."
                 :math "*n represents the game with Grundy value n."
                 :cs "Pure constructor; O(1)."))
  :row-3-dimension ((:setup "canonical constructor from an integer: same shape appears in nimbers, in tags, in enums"
                     :rungs ((:domain "game" :code "(game/star-n 3)")
                             (:domain "enum" :code "(define (color-code n) (list-ref '(red green blue) n))\n(color-code 1)")
                             (:domain "tag" :code "(define (make-tag k) (list 'tag k))\n(make-tag 42)"))
                     :explanation "Rung 1 builds a nimber. Rung 2 builds an enum value. Rung 3 tags a value. Each is a canonical constructor from an integer."
                     :meta "The shape transfers because 'integer-indexed canonical builder' is one primitive.")
                    (:eng "Enums, tags, and nimbers share the same integer-key idiom."
                     :math "*_ : ℕ → nimber."
                     :cs "One lookup or wrap."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "star-n is idempotent under equal integer input."
                 :program "(define a (game/star-n 3))\n(define b (game/star-n 3))\n(game/surreal-eq? a b)"
                 :invariant "∀ n. star-n(n) surreal-eq? star-n(n)"
                 :meta "Referential transparency on canonical builders. Falsified only by non-determinism. See book-of-code on referential transparency.")
                (:eng "Regression: identical inputs yield equal outputs."
                 :math "Deterministic canonical construction."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/star-n constructs a canonical nimber."
                     :composition "(define nims (map game/star-n '(1 2 3)))\n(define total (fold-left (lambda (acc n) (game/surreal-add acc n)) (game/star-n 0) nims))\ntotal"
                     :emergent "A multi-nimber sum: chaining star-n with surreal-add over integers yields the total game value."
                     :meta "This is the same family as any 'construct + fold' pipeline. Cross-ref book-of-composition on construct-and-fold.")
                    (:eng "Multi-heap Nim analysis walks this pipeline once per position."
                     :math "Sum of *nᵢ."
                     :cs "Map + reduce.")))

(verb
  :name "game/state"
  :library "game"
  :kind "pure"
  :signature "(game/state id) -> state-object"
  :summary "Retrieve the current state object for a running game loop by its id."
  :explanation "Every game loop in Motoi holds mutable state keyed by a numeric id. game/state lets you read that state at the current frame without advancing the loop. The state object is opaque to the caller but can be passed to other game verbs (e.g., game/frame, game/running?) or stored for comparison. This is a pure read operation—it does not trigger a frame advance or change any world."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define my-loop-id 1)\n(define state (game/state my-loop-id))\n(display state)" :note "Fetch and display the state of a game loop by its id.")
    (:dialect "motoi" :tier "intermediate" :code "(define (check-game-alive id)\n  (let ((s (game/state id)))\n    (if (game/running? id)\n        (display \"loop is active\")\n        (display \"loop halted\"))))\n(check-game-alive 1)" :note "Combine game/state with game/running? to check the loop status without side effect.")
    (:dialect "motoi" :tier "expert" :code "(define (advance-and-log id)\n  (let ((before (game/state id))\n        (_ (game/step id))\n        (after (game/state id)))\n    (if (equal? before after)\n        (display \"state unchanged\")\n        (display \"state changed\"))))\n(advance-and-log 1)" :note "Read state before and after game/step to inspect frame-to-frame changes without storing intermediate copies.")
  )
  :caveats ("game/state returns a reference to internal state; mutating it directly will break the game loop. Do not use card/set! or similar on the result." "If the game loop id is invalid or has been stopped/destroyed, game/state may return 'nan or escalate." "State is keyed by id; the same id always points to the same loop instance.")
  :drawbacks ("game/state does not guarantee consistency across concurrent threads; if a game/step is in progress, the returned state may be stale." "Frequent calls to game/state have a lookup cost; cache the result if you need it multiple times in one frame.")
  :usecases ("Inspecting game loop state for debugging or logging." "Comparing state before and after a frame to detect changes." "Guarding decisions on whether to call game/step or game/stop based on state properties.")
  :related ("game/step" "game/frame" "game/running?" "game/stop")
  :learn (:concept "Pure state reads as a way to inspect a running game loop without advancing it." :prerequisites ("game/frame" "game/running?") :progression "Learn game/step next to advance the loop; then study game/stop to halt it.")
  :row-2-audit ((:problem "A debugger needs to snapshot a game's state without advancing its clock."
                 :program "(define g (big-bang '(score 5)))\n(define snap (game/state g))\nsnap"
                 :explanation "Read the game state. Non-mutating; safe from any thread that has the id."
                 :meta "Reach for game/state over any snapshot that would tick the game; state is a pure read.")
                (:eng "Log the snapshot alongside the frame counter for correlation."
                 :math "state : id → any."
                 :cs "Registry read; O(1)."))
  :row-3-dimension ((:setup "pure read of a mutable resource: same shape appears in games, in atomic reads, in database SELECT"
                     :rungs ((:domain "game" :code "(game/state (big-bang 'x))")
                             (:domain "atomic" :code "(define (atomic-read reg) reg)\n(atomic-read 42)")
                             (:domain "select" :code "(define (select-latest db key) (list 'value 100))\n(select-latest 'db 'k)"))
                     :explanation "Rung 1 reads game state. Rung 2 reads a register. Rung 3 reads a database. All three retrieve without mutation."
                     :meta "The shape transfers because 'observer read' is a universal pattern."
                    )
                    (:eng "Concurrency, databases, and game state share this read primitive."
                     :math "read : id → any."
                     :cs "Idempotent read."))
  :row-4-proof ((:claim "Two consecutive reads of an unstepped game yield equal state."
                 :program "(define g (big-bang '(score 0)))\n(define a (game/state g))\n(define b (game/state g))\n(equal? a b)"
                 :invariant "∀ id. without step in between, state(id) is stable"
                 :meta "Read stability under no mutation. Falsified by any inconsistency. See book-of-code on read stability.")
                (:eng "Regression: repeated reads equal without intervening step."
                 :math "Read idempotence."
                 :cs "One assertion."))
  :row-5-emergence ((:base "game/state reads current state."
                     :composition "(define g (big-bang 0 (lambda (s f) (+ s 1))))\n(define trace (map (lambda (_) (let ((v (game/state g))) (game/step g) v)) '(1 2 3)))\ntrace"
                     :emergent "A state trace: chaining game/state before each step yields a history of states."
                     :meta "This is the same family as event sourcing or replay logs. Cross-ref book-of-composition on traces.")
                    (:eng "Debugging replays reconstruct sequences of state changes."
                     :math "trace = [state_0, state_1, …]."
                     :cs "Composition = repeated read-then-step.")))

(verb
  :name "game/step"
  :library "game"
  :kind "mut"
  :signature "(game/step id) -> status"
  :summary "Advance one frame of a game loop by id, returning a status indicator."
  :explanation "game/step drives a game loop forward by one frame. It mutates the internal state of the loop (frame counter, user input processing, entity updates, rendering) and returns a status (typically 'ok or a signal like 'done or 'error). Each call to game/step represents one logical frame of gameplay. You typically call this in a loop or via a ticker (e.g., register-tick) until the game halts or you call game/stop."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(game/step 1)\n(game/step 1)\n(game/step 1)" :note "Manually advance a game loop three times, each call processes one frame.")
    (:dialect "motoi" :tier "intermediate" :code "(define (run-n-frames id n)\n  (if (> n 0)\n      (begin\n        (game/step id)\n        (run-n-frames id (- n 1)))))\n(run-n-frames 1 10)" :note "Recursively step a game loop n times, useful for testing or replaying a fixed sequence.")
    (:dialect "motoi" :tier "expert" :code "(define (game-loop-auto id)\n  (if (game/running? id)\n      (let ((status (game/step id)))\n        (cond ((equal? status 'done) (display \"game finished\"))\n              ((equal? status 'ok) (register-tick 'next-frame (lambda () (game-loop-auto id))))\n              (else (escalate 'game-error status))))))\n(game-loop-auto 1)" :note "Use game/step in a recursive ticker loop that halts when status is 'done; advances the game until completion.")
  )
  :caveats ("game/step advances the frame counter even if the status is 'error or 'done; calling game/step on a stopped loop may escalate." "The status return value is a symbol; always check it before deciding to continue stepping." "game/step is synchronous and may block if the frame callback is expensive; use motion/with-feel or motion/with-pace to spread work across frames.")
  :drawbacks ("Manual game/step calls require explicit loop management; consider define-card with hand-off for automatic looping." "Each game/step call has overhead; stepping at sub-frame granularity (very frequently) may starve other Motoi tasks." "State mutations in game/step are not transactional; if an error occurs mid-frame, state may be inconsistent.")
  :usecases ("Driving a custom game loop forward in response to user input or external events." "Testing game logic by stepping through frames and inspecting state." "Implementing replay: step the same game id multiple times with recorded inputs to reproduce a sequence.")
  :related ("game/state" "game/running?" "game/stop" "game/frame" "register-tick")
  :learn (:concept "Explicit frame advancement: game/step is the verb that drives time in a game loop." :prerequisites ("game/state" "game/running?") :progression "Learn game/stop to halt loops; then explore game/frame to track elapsed frames and build time-dependent logic.")
  :row-2-audit ((:problem "A test needs to drive a game forward n frames without the top-level loop."
                 :program "(define g (big-bang 0 (lambda (s f) (+ s 1))))\n(game/step g) (game/step g) (game/step g)\n(game/state g)"
                 :explanation "Step the game 3 times. State advances by the step-fn each call. Returns 3."
                 :meta "Reach for game/step over ticking sleep-based drivers when determinism matters; step is synchronous and predictable.")
                (:eng "Log the status per step; 'error indicates a step-fn exception."
                 :math "step : id → status."
                 :cs "Mutating; increments frame and applies step-fn."))
  :row-3-dimension ((:setup "advance one unit of time on a resource: same shape appears in games, in simulators, in schedulers"
                     :rungs ((:domain "game" :code "(game/step (big-bang 'x))")
                             (:domain "simulator" :code "(define (sim-tick state) (cons 'ticked state))\n(sim-tick 'init)")
                             (:domain "scheduler" :code "(define (sched-tick queue) (if (null? queue) queue (cdr queue)))\n(sched-tick '(a b c))"))
                     :explanation "Rung 1 steps a game. Rung 2 advances a simulator. Rung 3 pops a queue. All three progress a mutable resource by one unit."
                     :meta "The shape transfers because 'one tick forward' is universal."
                    )
                    (:eng "Test harnesses, simulations, and schedulers share this idiom."
                     :math "step is a transition function."
                     :cs "One mutation per call."))
  :row-4-proof ((:claim "game/step increments the frame counter by 1 on 'ok."
                 :program "(define g (big-bang 'x))\n(define f0 (game/frame g))\n(game/step g)\n(define f1 (game/frame g))\n(= (- f1 f0) 1)"
                 :invariant "∀ id. status = 'ok ⟹ frame(id) after step = frame(id) before step + 1"
                 :meta "Unit increment is the definition of step. Falsified by any drift. See book-of-code on discrete time.")
                (:eng "Regression: one step advances the frame by exactly one."
                 :math "Successor operator on ℕ."
                 :cs "One assertion."))
  :row-5-emergence ((:base "game/step advances a game by one frame."
                     :composition "(define g (big-bang 0 (lambda (s f) (+ s 1))))\n(define (run-until g stop?)\n  (let loop ()\n    (unless (stop? (game/state g))\n      (game/step g)\n      (loop))))\n(run-until g (lambda (s) (>= s 5)))\n(game/state g)"
                     :emergent "A run-until-condition loop: chaining game/step with a stop-predicate yields event-driven simulation."
                     :meta "This is the same family as any while-loop over a state machine. Cross-ref book-of-composition on event loops.")
                    (:eng "Automated tests, simulations, and headless runs use this idiom."
                     :math "Iterate step until predicate holds."
                     :cs "Recursion + guard.")))

(verb
  :name "game/stop"
  :library "game"
  :kind "mut"
  :signature "(game/stop id) -> #t"
  :summary "Halt a running game loop by id, returning #t on success."
  :explanation "game/stop terminates a game loop that was started and has been advancing via game/step. It cleans up any registered tickers, resets the running flag, and returns #t. After game/stop, game/running? will return #f for that id. If the loop is already stopped, game/stop may return 'nan or escalate (behavior depends on strictness). Use this to cleanly exit a game, cancel a card's loop, or reset state before starting a new game."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define id (game/frame 1))\n(game/stop id)\n(if (game/running? id) (display \"still running\") (display \"stopped\"))" :note "Stop a game loop and immediately verify it is no longer running.")
    (:dialect "motoi" :tier "intermediate" :code "(define (stop-all-games games)\n  (for-each game/stop games))\n(stop-all-games '(1 2 3))" :note "Stop multiple game loops in sequence; useful when cleaning up before a scene transition.")
    (:dialect "motoi" :tier "expert" :code "(define id 'id)\n(define (safe-stop-on-condition id pred)\n  (let ((s (game/state id)))\n    (when (pred s)\n      (game/stop id)\n      (display \"stopped due to condition\"))))\n(safe-stop-on-condition 1 (lambda (state) (> (game/frame id) 1000)))" :note "Inspect game state and conditionally stop the loop; useful for implementing win/lose/timeout conditions.")
  )
  :caveats ("game/stop cancels tickers; any register-tick callbacks associated with the game loop will be cancelled." "After game/stop, the game state is frozen; game/state and game/frame still return the final values, but game/step will fail." "If the game id is invalid or already stopped, behavior is undefined; wrap game/stop in a guard if unsure.")
  :drawbacks ("game/stop does not reset the game state; use game/reset! (if available in world verbs) or re-initialize to start fresh." "Calling game/stop frequently may be a sign of poor control flow; consider using game/running? guards instead." "There is no way to pause and resume a loop; game/stop is permanent for that id.")
  :usecases ("Implementing game-over, level-complete, or timeout conditions." "Cleaning up a game loop before transitioning to another scene or card." "Debugging: stopping a loop to inspect final state without further mutation.")
  :related ("game/running?" "game/step" "game/state" "register-tick")
  :learn (:concept "Halting loops: game/stop is the clean way to terminate a game without escalation." :prerequisites ("game/step" "game/running?") :progression "Learn to compose game/stop with conditionals (if, when) for goal-driven termination; then study world/step for broader simulation patterns.")
  :row-2-audit ((:problem "A win condition fires; the loop should halt cleanly."
                 :program "(define g (big-bang 'playing))\n(when (eq? (game/state g) 'playing)\n  (game/stop g))\n(game/running? g)"
                 :explanation "On win, call game/stop. Subsequent game/running? returns #f. Clean shutdown."
                 :meta "Reach for game/stop over abandoning the id; abandoning leaks the registry entry.")
                (:eng "Log stop reason so post-mortems can reconstruct."
                 :math "stop : id → #t."
                 :cs "Mutating; sets running=false."))
  :row-3-dimension ((:setup "clean termination of a resource: same shape appears in games, in file close, in thread join"
                     :rungs ((:domain "game" :code "(game/stop (big-bang 'x))")
                             (:domain "close" :code "(define (close h) (list 'closed h))\n(close 'file)")
                             (:domain "join" :code "(define (join t) (list 'joined t))\n(join 'thread-42)"))
                     :explanation "Rung 1 stops a game. Rung 2 closes a file. Rung 3 joins a thread. All three cleanly terminate a lifecycle."
                     :meta "The shape transfers because 'clean shutdown' is a universal lifecycle primitive."
                    )
                    (:eng "Files, threads, and games share the same shutdown discipline."
                     :math "state transition to terminal."
                     :cs "Cleanup step."))
  :row-4-proof ((:claim "After game/stop, game/running? returns #f."
                 :program "(define g (big-bang 'x))\n(game/stop g)\n(not (game/running? g))"
                 :invariant "∀ id. after stop(id), running?(id) = #f"
                 :meta "Post-stop dead-state is the shutdown contract. Falsified by any zombie liveness. See book-of-code on lifecycles.")
                (:eng "Regression: stop + running? = #f."
                 :math "Terminal-state absorption."
                 :cs "One assertion."))
  :row-5-emergence ((:base "game/stop halts a running game."
                     :composition "(define games (list (big-bang 'a) (big-bang 'b) (big-bang 'c)))\n(for-each game/stop games)\n(map game/running? games)"
                     :emergent "A bulk shutdown: chaining game/stop over a list yields a stopped-all state."
                     :meta "This is the same family as bulk resource cleanup. Cross-ref book-of-composition on cleanup pipelines.")
                    (:eng "Scene transitions call this to clear all live games."
                     :math "∀ i. running?(games[i]) after cleanup = #f."
                     :cs "for-each traversal.")))

(verb
  :name "game/surreal"
  :library "game"
  :kind "meta"
  :signature "(game/surreal left-options right-options) -> surreal-number"
  :summary "Construct a surreal number from left and right option lists: {L|R}."
  :explanation "Surreal numbers are an algebraic structure that unifies real numbers, infinite ordinals, and infinitesimals. In combinatorial game theory, every game has a surreal value {L|R}, where L is the set of options available to the Left player and R is the set of options available to the Right player. This verb constructs that pair. Surreals form a field under addition, negation, and multiplication. Use game/surreal when you need to reason about partizan games (where players have different moves) or to build the number line itself."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define zero (game/surreal '() '()))\n(define one (game/surreal (list zero) '()))" :note "Build surreal 0 (no options for either player) and surreal 1 (Left can move to 0, Right has no moves).")
    (:dialect "motoi" :tier "intermediate" :code "(define zero 0)\n(define neg-one (game/surreal '() (list (game/surreal (list (game/surreal '() '())) '()))))\n(define half (game/surreal (list (game/surreal '() '())) (list (game/surreal (list zero) '()))))" :note "Construct -1 and 1/2 by nesting surreal pairs; the number line emerges from recursive definitions.")
    (:dialect "motoi" :tier "expert" :code "(define zero 0)\n(define (fuzzy-game)\n  (game/surreal\n    (list (game/surreal '() '()))\n    (list (game/surreal '() '()))))\n(define (compare-surreals x y)\n  (cond ((game/surreal-le? x y) (display \"x <= y\"))\n        ((game/surreal-le? y x) (display \"y <= x\"))\n        (else (display \"incomparable\"))))\n(compare-surreals (fuzzy-game) zero)" :note "Build a fuzzy game (where both players can move to 0) and compare it to zero using surreal order.")
  )
  :caveats ("The number condition (every L < every R) is not checked on construction; invalid input produces undefined results or 'nan." "Surreal equality (game/surreal-eq?) is not the same as Lisp equality; use game/surreal-eq? for game values." "Deeply nested surreal definitions (high birthday) are expensive to construct and compare; memoize if generating many.")
  :drawbacks ("Surreal arithmetic operations (game/surreal-add, etc.) are slower than machine integers; avoid hot loops." "The surreal number line is infinite in all directions (infinitesimals, infinities); operations do not saturate or error on overflow." "game/surreal does not provide a human-readable string format; pretty-printing requires custom code.")
  :usecases ("Analyzing partizan combinatorial games (Chess, Go, Checkers) using game theory." "Constructing the surreal number line to teach infinitesimals and ordinal arithmetic." "Computing game values and strategy by building surreal trees and comparing payoffs.")
  :related ("game/surreal-add" "game/surreal-eq?" "game/surreal-le?" "game/surreal-birthday" "game/surreal-is-number?" "game/to-real")
  :learn (:concept "Surreal numbers as recursive pairs {L|R}; the algebra of games." :prerequisites ("game/nim-sum") :progression "Learn game/surreal-add and comparison predicates (game/surreal-le?, game/surreal-eq?) to reason about game values; then study game/temperature for hot games.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A partisan-game solver needs to construct a game value from Left and Right option sets."
                 :program "(define zero (game/surreal '() '()))\n(define one (game/surreal (list zero) '()))\none"
                 :explanation "Build zero as {|}, then one as {0|}. These are the birth days 0 and 1 of the surreal number line."
                 :meta "Reach for game/surreal, not game/star-n, when the game is partisan (Left and Right have different moves); star-n is impartial only.")
                (:eng "Log birthday to catch runaway recursion."
                 :math "surreal = {L | R}."
                 :cs "Constructor from two lists."))
  :row-3-dimension ((:setup "recursive constructor from left and right bounds: same shape appears in surreals, in Dedekind cuts, in interval refinement"
                     :rungs ((:domain "game" :code "(game/surreal '() '())")
                             (:domain "cut" :code "(define (cut lo hi) (list lo hi))\n(cut '(0 1/2) '(1 2))")
                             (:domain "interval" :code "(define (bracket lo hi) (list lo hi))\n(bracket 0 1)"))
                     :explanation "Rung 1 is a surreal from L and R lists. Rung 2 is a Dedekind cut. Rung 3 is an interval bracket. All three define a point (or game) by what lies below and above."
                     :meta "The shape transfers because 'define by lower and upper sets' is universal in constructive real number theory."
                    )
                    (:eng "Real-number construction, game theory, and interval arithmetic share the pattern."
                     :math "{L | R} with L < R."
                     :cs "Pair of lists."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Surreal zero equals itself."
                 :program "(define a (game/surreal '() '()))\n(define b (game/surreal '() '()))\n(game/surreal-eq? a b)"
                 :invariant "∀ empty L, R. surreal(L,R) surreal-eq? surreal(L,R)"
                 :meta "Reflexivity of surreal equality. Falsified only by a broken equality check. See book-of-math on surreal equivalence.")
                (:eng "Regression: identically-built zeros are equal."
                 :math "Reflexivity."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal constructs {L | R}."
                     :composition "(define zero (game/surreal '() '()))\n(define one (game/surreal (list zero) '()))\n(define two (game/surreal-add one one))\ntwo"
                     :emergent "Number-line construction: chaining surreal with surreal-add yields the integer part of the surreal line."
                     :meta "This is the same family as inductive number-line construction. Cross-ref book-of-math on Peano/surreal.")
                    (:eng "Educational demos of surreals walk this pipeline."
                     :math "N = build(0) → build(1) → …"
                     :cs "Recursive construction.")))

(verb
  :name "game/surreal-add"
  :library "game"
  :kind "meta"
  :signature "(game/surreal-add x y) -> surreal-number"
  :summary "Add two surreal numbers: x + y."
  :explanation "Surreal addition is defined recursively: x + y = {x_L + y, x + y_L | x_R + y, x + y_R}. This recursive definition ensures that surreal numbers form an ordered field, and it extends to infinitesimals and infinities. When both operands are dyadic rationals (numbers with terminating binary expansions), the result is also dyadic. Use game/surreal-add to combine game values, compute nim-sums in partizan games, or build surreal sums for theoretical analysis."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define zero (game/surreal '() '()))\n(define one (game/surreal (list zero) '()))\n(define two (game/surreal-add one one))" :note "Add surreal 1 + 1 to construct 2.")
    (:dialect "motoi" :tier "intermediate" :code "(define (fold-left f init xs) (let loop ((xs xs) (acc init)) (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n;; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(define (game-value-sum games)\n  (fold-left game/surreal-add (game/surreal '() '()) games))\n(define vs (game-value-sum (list (game/surreal-lit 1/2) (game/surreal-lit 1/4))))\n(display (game/to-real vs))" :note "Sum a list of surreal game values and convert the result to a real number (dyadic approximation).")
    (:dialect "motoi" :tier "expert" :code "(define (domineering-value left-moves right-moves)\n  (let ((L (map (lambda (move) (domineering-value (cdr move) right-moves)) left-moves))\n        (R (map (lambda (move) (domineering-value left-moves (cdr move))) right-moves)))\n    (game/surreal L R)))\n(define (total-board-value moves-list)\n  (fold-left game/surreal-add (game/surreal '() '()) \n    (map (lambda (m) (domineering-value (car m) (cdr m))) moves-list)))" :note "Combine surreal values from independent games (e.g., multiple dominoes on a board) to find the overall game value.")
  )
  :caveats ("Surreal addition is not the same as numeric addition for non-dyadic reals; use game/to-real to convert to approximate real values." "Adding deeply nested surreals (high birthday) can be exponentially expensive; memoization helps but is not always sufficient." "If either operand is 'nan or not a valid surreal, game/surreal-add produces undefined results.")
  :drawbacks ("Performance degrades for surreals with many options; limit recursion depth or use surreal-lit for dyadic constants." "There is no built-in pretty-printing; results require game/to-real or custom formatting for human readability." "Surreal addition does not truncate or saturate; sums of many operands can grow very large in birthday (complexity).")
  :usecases ("Computing the combined value of independent games (e.g., multiple piles in impartial games or board positions)." "Reasoning about partizan games by summing component surreals." "Teaching surreal arithmetic: demonstrating associativity, commutativity, and order properties.")
  :related ("game/surreal" "game/surreal-sub" "game/surreal-mul" "game/surreal-le?" "game/to-real" "game/nim-sum")
  :learn (:concept "Surreal addition: recursive definition that preserves field structure." :prerequisites ("game/surreal" "game/surreal-le?") :progression "Learn game/surreal-sub and game/surreal-mul for full field arithmetic; then study partizan game analysis.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A game solver needs to combine two independent partisan games."
                 :program "(define a (game/surreal-lit 1))\n(define b (game/surreal-lit 2))\n(game/surreal-add a b)"
                 :explanation "Add two surreal-literal values 1 and 2. Result is 3."
                 :meta "Reach for game/surreal-add over game/nim-sum when the games are partisan; nim-sum is XOR for impartial games only.")
                (:eng "Log birthdays of operands; adding two deep surreals produces even deeper results."
                 :math "a + b = {aL+b, a+bL | aR+b, a+bR}."
                 :cs "Recursive; expensive at depth."))
  :row-3-dimension ((:setup "recursive addition preserving order: same shape appears in surreals, in extended reals, in wall-clock times"
                     :rungs ((:domain "game" :code "(game/surreal-add (game/surreal-lit 1) (game/surreal-lit 2))")
                             (:domain "extended-real" :code "(define (ext-add a b) (if (or (eq? a '+inf) (eq? b '+inf)) '+inf (+ a b)))\n(ext-add 3 5)")
                             (:domain "time" :code "(define (add-secs t s) (+ t s))\n(add-secs 100 30)"))
                     :explanation "Rung 1 adds surreals. Rung 2 adds extended reals. Rung 3 adds times. Each defines addition compatible with the ordering."
                     :meta "The shape transfers because 'order-preserving addition' is universal."
                    )
                    (:eng "Games, extended reals, and time-of-day arithmetic share this shape."
                     :math "a + b preserves ≤."
                     :cs "Same commutativity, associativity."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Zero is a right identity for surreal addition."
                 :program "(define a (game/surreal-lit 3))\n(define z (game/surreal-lit 0))\n(game/surreal-eq? (game/surreal-add a z) a)"
                 :invariant "∀ a. a + 0 = a"
                 :meta "Right identity is a field axiom. Falsified by any drift. See book-of-math on fields.")
                (:eng "Regression: adding zero is a no-op."
                 :math "Field identity."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal-add combines two surreals."
                     :composition "(define vals (list (game/surreal-lit 1) (game/surreal-lit 2) (game/surreal-lit 3)))\n(fold-left game/surreal-add (game/surreal-lit 0) vals)"
                     :emergent "A surreal sum: chaining surreal-add over a list yields the total."
                     :meta "This is the same family as sum-of-games in CGT. Cross-ref book-of-composition on folds.")
                    (:eng "Multi-component partisan games are analyzed via this fold."
                     :math "Σ aᵢ."
                     :cs "One-pass fold.")))

(verb
  :name "game/surreal-birthday"
  :library "game"
  :kind "meta"
  :signature "(game/surreal-birthday s) -> n"
  :summary "Return the birthday (generation/depth) of a surreal number."
  :explanation "In surreal number theory, the birthday of a surreal is the ordinal day on which it was born—intuitively, the depth of recursion needed to construct it. The surreal 0 = {|} has birthday 0. The surreals 1 = {0|} and -1 = {|-0} have birthday 1. Each new generation introduces new infinities, infinitesimals, and intermediate rationals. The birthday is useful for understanding the complexity of a surreal and for debugging: if a surreal has unexpectedly high birthday, it may indicate infinite recursion or a malformed game tree."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define zero (game/surreal '() '()))\n(display (game/surreal-birthday zero))" :note "The birthday of 0 is 0 (born on day 0).")
    (:dialect "motoi" :tier "intermediate" :code "(define zero (game/surreal '() '()))\n(define one (game/surreal (list zero) '()))\n(define two (game/surreal-add one one))\n(display (game/surreal-birthday two))" :note "Construct 1 (birthday 1) and 2 (birthday 2); birthday increases as surreals grow more complex.")
    (:dialect "motoi" :tier "expert" :code "(define (depth-bounded-game max-depth options)\n  (if (<= max-depth 0)\n      (game/surreal '() '())\n      (game/surreal\n        (map (lambda (opt) (depth-bounded-game (- max-depth 1) opt)) (car options))\n        (map (lambda (opt) (depth-bounded-game (- max-depth 1) opt)) (cdr options)))))\n(let ((g (depth-bounded-game 5 '(() ()))))\n  (display (game/surreal-birthday g)))" :note "Build a game tree up to a fixed depth and inspect its birthday; useful for controlling complexity in minimax analysis.")
  )
  :caveats ("Birthday is the recursion depth, not the numeric value; large-birthday surreals may have small numeric values (e.g., 1/1024)." "If a surreal is malformed (e.g., options contain non-surreals), game/surreal-birthday behavior is undefined." "Birthday increases with each arithmetic operation; repeated surreal-add can cause birthday explosion.")
  :drawbacks ("Surreals with high birthday are expensive to operate on; algorithmic complexity grows exponentially with birthday." "There is no automatic simplification; different surreal representations may have different birthdays but equal values." "Memoization helps but is not magic; very deep game trees (birthday > 20) may still cause memory or time blowup.")
  :usecases ("Debugging game-theoretic computations: detecting infinite recursion or malformed surreals." "Analyzing complexity: ensuring that computed game values stay within a reasonable birthday bound." "Teaching surreal numbers: illustrating the generational construction of the number line.")
  :related ("game/surreal" "game/surreal-is-number?" "game/surreal-simplest")
  :learn (:concept "Birthday as a measure of surreal complexity; ordinal generation of numbers." :prerequisites ("game/surreal" "game/surreal-le?") :progression "Use birthday to bound recursion in game analysis (e.g., minimax with depth cutoff); then study game/temperature for evaluating complex games.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A debugger needs to check whether a surreal has blown up in recursive depth."
                 :program "(define s (game/surreal-lit 3))\n(if (> (game/surreal-birthday s) 20) 'too-deep 'ok)"
                 :explanation "Query birthday. Deeper than 20 = expensive; guard downstream operations."
                 :meta "Reach for birthday over other complexity measures; it's the direct recursion-depth metric on surreals.")
                (:eng "Birthday spikes signal accidentally-nested constructions."
                 :math "birthday : surreal → ordinal."
                 :cs "Tree depth query."))
  :row-3-dimension ((:setup "depth measure on a recursive structure: same shape appears in surreals, in trees, in AST nesting"
                     :rungs ((:domain "game" :code "(game/surreal-birthday (game/surreal-lit 3))")
                             (:domain "tree" :code "(define (tree-depth t) (if (list? t) (+ 1 (apply max 0 (map tree-depth t))) 0))\n(tree-depth '(a (b (c))))")
                             (:domain "ast" :code "(define (ast-depth e) (if (pair? e) (+ 1 (apply max 0 (map ast-depth e))) 0))\n(ast-depth '(+ 1 (* 2 3)))"))
                     :explanation "Rung 1 measures surreal depth. Rung 2 measures tree depth. Rung 3 measures AST depth. All three return the maximum recursion depth."
                     :meta "The shape transfers because 'max recursion depth' is one measure across recursive substrates."
                    )
                    (:eng "Compilers, tree analyzers, and game evaluators share this metric."
                     :math "depth : recursive → ℕ."
                     :cs "Recursive scan."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Birthday of zero is 0."
                 :program "(= (game/surreal-birthday (game/surreal-lit 0)) 0)"
                 :invariant "birthday(0) = 0"
                 :meta "Base case of the recursive definition. Falsified by any non-zero result. See book-of-math on ordinal generation.")
                (:eng "Regression: zero-birthday check."
                 :math "Base case."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal-birthday returns recursion depth."
                     :composition "(define ns (map game/surreal-lit '(0 1 2 3)))\n(map game/surreal-birthday ns)"
                     :emergent "A complexity profile: chaining birthday over a set of surreals yields depth distribution."
                     :meta "This is the same family as depth histograms in tree analysis. Cross-ref book-of-composition on complexity metrics.")
                    (:eng "Profilers use this to catch depth blowups."
                     :math "Distribution over ordinals."
                     :cs "Map + histogram.")))

(verb
  :name "game/surreal-eq?"
  :library "game"
  :kind "meta"
  :signature "(game/surreal-eq? x y) -> #t | #f"
  :summary "Test surreal equality: do x and y represent the same number?"
  :explanation "Surreal equality is not the same as Lisp structural equality (eq?, equal?). Two surreals {L_x | R_x} and {L_y | R_y} are equal if they induce the same order relation with all other surreals. This is checked by a recursive definition: x = y iff every left option of x is less than y and every right option of y is greater than x, and vice versa. game/surreal-eq? implements this equivalence check. Use it to compare game values, test whether a surreal equals a known constant (e.g., zero), or verify game-theoretic properties."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define zero (game/surreal '() '()))\n(define also-zero (game/surreal '() '()))\n(if (game/surreal-eq? zero also-zero)\n    (display \"equal\"))" :note "Two independently constructed surreal zeros are equal.")
    (:dialect "motoi" :tier "intermediate" :code "(define zero (game/surreal '() '()))\n(define one (game/surreal (list zero) '()))\n(define sum (game/surreal-add zero one))\n(if (game/surreal-eq? sum one)\n    (display \"0 + 1 = 1\"))" :note "Verify that adding zero leaves a surreal unchanged.")
    (:dialect "motoi" :tier "expert" :code "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (game-outcome-is-draw? value)\n  (game/surreal-eq? value (game/surreal '() '())))\n(define (partition-by-outcome games)\n  (let ((p-games (filter (lambda (g) (game/surreal-eq? g (game/star-n 0))) games))\n        (n-games (filter (lambda (g) (not (game/surreal-eq? g (game/star-n 0)))) games)))\n    (list p-games n-games)))\n(partition-by-outcome '(...))" :note "Sort games into P and N positions by testing whether their value equals *0 (the losing position).")
  )
  :caveats ("game/surreal-eq? is different from eq? and equal?; always use game/surreal-eq? for game-theoretic comparison." "Equality of surreals with very high birthday is expensive; memoization helps but may consume memory." "If either operand is 'nan or not a valid surreal, game/surreal-eq? produces undefined results or escalates.")
  :drawbacks ("No short-circuit optimization; even obviously equal surreals (same structure) require full traversal." "For infinitely many options (unbounded game trees), game/surreal-eq? may not terminate." "Equality is the most expensive of the surreal operations; minimize redundant equality checks in tight loops.")
  :usecases ("Testing game outcomes: checking whether a game value equals a known position (e.g., *0 = losing, or 0 = draw)." "Verifying arithmetic properties: asserting that surreal operations are correct (e.g., x + 0 = x)." "Partitioning games by equivalence: sorting games into strategy categories based on their surreal values.")
  :related ("game/surreal" "game/surreal-le?" "game/surreal-add" "game/star-n")
  :learn (:concept "Surreal equality as a recursive equivalence relation, distinct from Lisp equality." :prerequisites ("game/surreal" "game/surreal-le?") :progression "Use game/surreal-eq? in conditionals to branch on game outcomes; then study game/nim-sum for impartial games.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A test needs to check whether two surreals denote the same value regardless of construction path."
                 :program "(define a (game/surreal-lit 1))\n(define b (game/surreal-add (game/surreal-lit 0) (game/surreal-lit 1)))\n(game/surreal-eq? a b)"
                 :explanation "Both a and b denote 1 through different constructions. surreal-eq? recognizes this."
                 :meta "Reach for surreal-eq? over eq?; eq? checks pointer identity, not surreal value identity.")
                (:eng "Equality checks can be expensive; guard hot loops."
                 :math "a = b iff a ≤ b and b ≤ a."
                 :cs "Recursive; O(depth²)."))
  :row-3-dimension ((:setup "value equality on a semantic space: same shape appears in surreals, in rational numbers, in sets"
                     :rungs ((:domain "game" :code "(game/surreal-eq? (game/surreal-lit 1) (game/surreal-lit 1))")
                             (:domain "rational" :code "(define (rat-eq a b c d) (= (* a d) (* b c)))\n(rat-eq 1 2 2 4)")
                             (:domain "set" :code "(define (set-eq a b) (and (equal? (sort a <) (sort b <)) #t))\n(set-eq '(1 2 3) '(3 2 1))"))
                     :explanation "Rung 1 tests surreal equality. Rung 2 tests rational equality (cross-multiply). Rung 3 tests set equality (sort + compare). Each tests semantic equivalence, not structural."
                     :meta "The shape transfers because 'value-not-representation equality' is universal."
                    )
                    (:eng "Value equality vs. representation equality is a recurring lesson."
                     :math "Equivalence class equality."
                     :cs "Normalize + compare, or bidirectional inequality."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "surreal equality is symmetric."
                 :program "(define a (game/surreal-lit 1))\n(define b (game/surreal-lit 1))\n(and (game/surreal-eq? a b) (game/surreal-eq? b a))"
                 :invariant "∀ a, b. eq(a,b) ⟹ eq(b,a)"
                 :meta "Symmetry of an equivalence relation. Falsified by any asymmetry. See book-of-math on equivalence.")
                (:eng "Regression: symmetric equality."
                 :math "Symmetry of ≡."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal-eq? tests semantic equality."
                     :composition "(define target (game/surreal-lit 3))\n(define candidates (map game/surreal-lit '(1 2 3 4 5)))\n(filter (lambda (c) (game/surreal-eq? c target)) candidates)"
                     :emergent "A canonical-value finder: chaining surreal-eq? with filter yields all representations equal to a target."
                     :meta "This is the same family as any predicate-based filter. Cross-ref book-of-composition on predicate filters.")
                    (:eng "Canonical-form testing uses this filter."
                     :math "Preimage of a target under eq."
                     :cs "One-pass filter.")))

(verb
  :name "game/surreal-is-number?"
  :library "game"
  :kind "meta"
  :signature "(game/surreal-is-number? surreal) -> boolean"
  :summary "Test whether a surreal number satisfies the number condition: every left option is strictly less than every right option."
  :explanation "In combinatorial game theory, surreal numbers are constructed recursively as pairs {L|R} where L and R are sets of surreals. A surreal is a *number* (as opposed to a more general game) if and only if every element of L is strictly less than every element of R. This predicate tests that condition. It is a structural check that validates whether a surreal inhabits the numeric subclass, which is necessary before applying surreal arithmetic operations."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((zero (game/surreal-lit 0)))\n  (game/surreal-is-number? zero))" :note "The dyadic 0 is a surreal number; returns #t")
    (:dialect "motoi" :tier "intermediate" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((half (game/surreal-lit 1/2))\n      (quarter (game/surreal-lit 1/4)))\n  (and (game/surreal-is-number? half)\n       (game/surreal-is-number? quarter)))" :note "Dyadic rationals like 1/2 and 1/4 are surreal numbers; both check pass")
    (:dialect "motoi" :tier "expert" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((a (game/surreal-lit 1/2))\n      (b (game/surreal-lit 1/4)))\n  (when (game/surreal-is-number? a)\n    (game/surreal-add a b)))" :note "Guard arithmetic with the number check before performing operations; ensures operands are in the numeric subclass")
  )
  :caveats ("Only surreal numbers (not general partizan games) support arithmetic operations" "Returns #f for ill-formed sureals or partizan games like nimbers" "Non-dyadic rationals will fail the check and return 'nan when constructed")
  :drawbacks ("Checking is O(depth) in the recursion depth of the surreal; deep surreals incur cost" "If you already constructed a surreal via game/surreal-lit, it is guaranteed to be a number—this check is mainly useful for games returned from other sources")
  :usecases ("Validating that a game value is numeric before performing arithmetic" "Filtering a mixed list of games and surreals to find only the numbers" "Defensive checks in game-theoretic analysis to ensure type safety")
  :related ("game/surreal-lit" "game/surreal-add" "game/surreal-mul" "game/surreal-le?" "game/surreal-eq?" "game/star-n")
  :learn (:concept "Surreal numbers are a recursive numeric system that extends reals; this predicate validates membership in the numeric subclass" :prerequisites ("game/surreal-lit" "game/to-real") :progression "After understanding number validation, learn surreal arithmetic: game/surreal-add, game/surreal-mul, game/surreal-neg")
  :row-2-audit (
    :runs "spec-only"
   (:problem "Surreal arithmetic requires operand to be a number, not a general game. What predicate guards?"
                 :program "(define x (game/surreal-lit 1))\n(if (game/surreal-is-number? x) (game/surreal-add x x) 'not-a-number)"
                 :explanation "Guard the add. If x is a number, add; otherwise return sentinel."
                 :meta "Reach for is-number? over game/surreal-le? for typechecking; le? is fine for comparison but doesn't verify numeric structure.")
                (:eng "Log 'is-number check' before invoking arithmetic in production."
                 :math "Number condition: all L < all R."
                 :cs "Recursive check; O(depth)."))
  :row-3-dimension ((:setup "structural predicate on a recursive type: same shape appears in surreals, in valid ASTs, in well-formed JSON"
                     :rungs ((:domain "game" :code "(game/surreal-is-number? (game/surreal-lit 1))")
                             (:domain "valid-ast" :code "(define (valid-ast? e) (or (number? e) (and (pair? e) (symbol? (car e)))))\n(valid-ast? '(+ 1 2))")
                             (:domain "well-formed" :code "(define (well-formed? x) (or (number? x) (string? x) (list? x)))\n(well-formed? '(1 2 3))"))
                     :explanation "Rung 1 checks number structure. Rung 2 checks AST validity. Rung 3 checks JSON well-formedness. All three recursively verify structural constraints."
                     :meta "The shape transfers because 'recursive structural predicate' is universal."
                    )
                    (:eng "Type validators, parsers, and structural checkers share this pattern."
                     :math "Structural well-formedness."
                     :cs "Recursive walk."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "surreal-lit output is always a valid number."
                 :program "(game/surreal-is-number? (game/surreal-lit 3))"
                 :invariant "∀ dyadic q. is-number?(surreal-lit q) = #t"
                 :meta "Constructor postcondition. Falsified only by broken canonical construction. See book-of-math on canonical surreals.")
                (:eng "Regression: literals are always numbers."
                 :math "Constructor invariant."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal-is-number? predicates the numeric subclass."
                     :composition "(define games (list (game/surreal-lit 1) (game/surreal-lit 2) (game/star-n 3)))\n(filter game/surreal-is-number? games)"
                     :emergent "A numeric-subset filter: chaining is-number? with filter partitions the game list."
                     :meta "This is the same family as partition-by-type. Cross-ref book-of-composition on type filters.")
                    (:eng "Solvers dispatch on numeric vs. general games using this filter."
                     :math "Preimage of the number subclass."
                     :cs "One-pass filter.")))

(verb
  :name "game/surreal-le?"
  :library "game"
  :kind "meta"
  :signature "(game/surreal-le? a b) -> boolean"
  :summary "Test whether surreal number a is less than or equal to b under surreal ordering."
  :explanation "Surreal numbers are ordered recursively: a ≤ b iff no left option of a is ≥ b AND no right option of b is ≤ a. This implements that total order over the numeric subclass. Unlike floating-point arithmetic, surreal comparison is exact and respects the full recursively-defined structure. Use this to reason about relationships between game values or to sort surreal numbers."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((zero (game/surreal-lit 0))\n      (one (game/surreal-lit 1)))\n  (game/surreal-le? zero one))" :note "0 ≤ 1 is true; returns #t")
    (:dialect "motoi" :tier "intermediate" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((a (game/surreal-lit 1/4))\n      (b (game/surreal-lit 1/2))\n      (c (game/surreal-lit 1)))\n  (and (game/surreal-le? a b)\n       (game/surreal-le? b c)\n       (game/surreal-le? a c)))" :note "Chain comparisons: 1/4 ≤ 1/2 ≤ 1; transitivity holds")
    (:dialect "motoi" :tier "expert" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((vals (list (game/surreal-lit 1/2)\n                  (game/surreal-lit 1/4)\n                  (game/surreal-lit 1))))\n  (sort vals (lambda (x y) (game/surreal-le? x y))))" :note "Use surreal-le? as a comparator in a sort; orders sureals by their numeric value")
  )
  :caveats ("Both arguments must be surreal numbers (game/surreal-is-number? must hold); behavior undefined otherwise" "Non-numeric games (partizan or nimbers) do not have a total order and will error if passed here" "Comparison is exact; there is no ≈ or epsilon-tolerance as in floating-point")
  :drawbacks ("Comparison cost is O(depth²) in the worst case (recursive descent on both trees)" "For very deep sureals, repeated comparisons become expensive; cache results if doing many lookups")
  :usecases ("Comparing game values in combinatorial game theory analysis" "Sorting a collection of surreal numbers" "Asserting invariants in game-solving algorithms")
  :related ("game/surreal-eq?" "game/surreal-lit" "game/surreal-is-number?" "game/to-real")
  :learn (:concept "Surreal ordering is a total order defined recursively via left/right sets; this predicate implements that order" :prerequisites ("game/surreal-lit" "game/surreal-is-number?") :progression "After mastering comparison, learn equality (game/surreal-eq?) and then arithmetic (game/surreal-add, game/surreal-mul)")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A sorter needs to compare two surreal numbers."
                 :program "(define a (game/surreal-lit 1))\n(define b (game/surreal-lit 2))\n(game/surreal-le? a b)"
                 :explanation "Compare a and b. Returns #t."
                 :meta "Reach for surreal-le? over converting to real; conversion loses information at infinitesimals.")
                (:eng "Compare surreals in their native representation for exactness."
                 :math "a ≤ b iff no aL ≥ b and no bR ≤ a."
                 :cs "Recursive; O(depth²)."))
  :row-3-dimension ((:setup "recursive total order: same shape appears in surreals, in dictionary order, in tree comparison"
                     :rungs ((:domain "game" :code "(game/surreal-le? (game/surreal-lit 1) (game/surreal-lit 2))")
                             (:domain "dict-order" :code "(define (str<? a b) (string<? a b))\n(str<? \"apple\" \"banana\")")
                             (:domain "tree-cmp" :code "(define (tree<? a b) (if (and (number? a) (number? b)) (< a b) #f))\n(tree<? 1 2)"))
                     :explanation "Rung 1 compares surreals. Rung 2 compares strings. Rung 3 compares tree nodes. Each is a total order defined recursively."
                     :meta "The shape transfers because 'total order via recursion' is universal."
                    )
                    (:eng "Sorting, ordering, and comparison functions share this shape."
                     :math "≤ is total, transitive, antisymmetric."
                     :cs "Recursive comparator."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "surreal-le? is reflexive."
                 :program "(define a (game/surreal-lit 5))\n(game/surreal-le? a a)"
                 :invariant "∀ a. a ≤ a"
                 :meta "Reflexivity of ≤. Falsified by any strict-less-than-only comparator. See book-of-math on partial orders.")
                (:eng "Regression: self ≤ self."
                 :math "Reflexivity."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal-le? tests surreal ≤."
                     :composition "(define nums (map game/surreal-lit '(3 1 2 4)))\n(sort nums (lambda (a b) (game/surreal-le? a b)))"
                     :emergent "A surreal sorter: chaining surreal-le? with sort yields ordered surreals."
                     :meta "This is the same family as any comparator-based sort. Cross-ref book-of-composition on sorting.")
                    (:eng "Game analyzers sort candidate values by surreal order."
                     :math "Sort by ≤."
                     :cs "Comparator + sort.")))

(verb
  :name "game/surreal-lit"
  :library "game"
  :kind "meta"
  :signature "(game/surreal-lit rational) -> surreal"
  :summary "Construct the canonical surreal number for a dyadic rational (fraction with 2^n denominator); non-dyadic input returns 'nan."
  :explanation "Every dyadic rational has a unique minimal surreal representation born at a finite day (recursion depth). This verb constructs that canonical form. It is the primary way to *birth* surreal numbers from Scheme rationals. Non-dyadic rationals (e.g., 1/3, π) cannot be exactly represented and return the sentinel 'nan. This is the inverse of game/to-real in the dyadic domain."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((zero (game/surreal-lit 0)))\n  zero)" :note "0 is dyadic; constructs the surreal 0 born at day 0")
    (:dialect "motoi" :tier "intermediate" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((half (game/surreal-lit 1/2))\n      (quarter (game/surreal-lit 1/4))\n      (three-quarters (game/surreal-lit 3/4)))\n  (list (game/surreal-le? quarter half)\n        (game/surreal-le? half three-quarters)))" :note "Construct several dyadic fractions; their order is 1/4 < 1/2 < 3/4")
    (:dialect "motoi" :tier "expert" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(define (dyadic? r)\n  (let ((denom (denominator r)))\n    (= (modulo denom 2) 0)))\n(let ((candidates (list 1/2 1/3 3/4 2/5)))\n  (map (lambda (r)\n         (if (dyadic? r)\n           (game/surreal-lit r)\n           'not-dyadic))\n       candidates))" :note "Map over candidates, constructing sureals only for dyadic rationals; others yield 'not-dyadic")
  )
  :caveats ("Argument must be a rational number; non-rational input is an error" "Non-dyadic rationals (denominator not a power of 2) return 'nan, not an error" "The result is immutable; surreal numbers cannot be modified after birth")
  :drawbacks ("Only dyadic rationals are supported; most 'real-world' fractions (1/3, 1/5, etc.) cannot be represented" "Birth day grows with denominator size; large dyadic rationals create deep sureals with high comparison cost" "If you need non-dyadic rationals, use exact/float->rat or an external symbolic algebra system")
  :usecases ("Constructing game values for combinatorial game theory analysis" "Building numeric operands for surreal arithmetic" "Testing and benchmarking surreal ordering and equality")
  :related ("game/to-real" "game/surreal-is-number?" "game/surreal-le?" "game/surreal-eq?" "game/surreal-add" "exact/float->rat")
  :learn (:concept "Dyadic rationals are the foundation of surreal numbers; this verb constructs their canonical form" :prerequisites ("Understanding Scheme rational arithmetic (quotient, denominator)") :progression "After constructing sureals, learn to query and compare them (game/surreal-is-number?, game/surreal-le?), then do arithmetic (game/surreal-add, game/surreal-mul)")
  :row-2-audit (
    :runs "spec-only"
   (:problem "Solver needs a canonical surreal for a dyadic rational."
                 :program "(define x (game/surreal-lit 3))\nx"
                 :explanation "Construct canonical surreal for 3. Ready for arithmetic and comparison."
                 :meta "Reach for surreal-lit over hand-built game/surreal when the value is a plain rational; lit is the canonical constructor.")
                (:eng "Log the input; non-dyadic yields 'nan and callers must handle it."
                 :math "lit(q) returns unique minimal-birthday surreal for dyadic q."
                 :cs "Recursive construction; O(log denom)."))
  :row-3-dimension ((:setup "canonical constructor from a value: same shape appears in surreals, in string interning, in immutable list construction"
                     :rungs ((:domain "game" :code "(game/surreal-lit 3)")
                             (:domain "intern" :code "(define (intern s) (list 'sym s))\n(intern \"hello\")")
                             (:domain "immutable" :code "(define (freeze xs) (list 'frozen xs))\n(freeze '(1 2 3))"))
                     :explanation "Rung 1 canonicalizes a rational. Rung 2 canonicalizes a string. Rung 3 freezes a list. Each turns a raw value into a canonical form."
                     :meta "The shape transfers because 'canonical constructor' is universal."
                    )
                    (:eng "Interners, canonical builders, and immutable wrappers share the pattern."
                     :math "Canonical form: representative of equivalence class."
                     :cs "One factory function."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "surreal-lit is deterministic on dyadic input."
                 :program "(game/surreal-eq? (game/surreal-lit 3) (game/surreal-lit 3))"
                 :invariant "∀ dyadic q. lit(q) surreal-eq? lit(q)"
                 :meta "Deterministic canonical builder. Falsified only by non-determinism. See book-of-code on canonicalization.")
                (:eng "Regression: identical inputs are surreal-equal."
                 :math "Canonicity."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal-lit builds a canonical surreal."
                     :composition "(define ns (map game/surreal-lit '(0 1 2 3 4 5)))\n(map game/surreal-birthday ns)"
                     :emergent "A birthday-distribution scan: chaining lit with birthday reveals how surreal complexity scales with value."
                     :meta "This is the same family as complexity profiling. Cross-ref book-of-composition on profilers.")
                    (:eng "Educational surreal explorers use this to teach birthday growth."
                     :math "birthday(lit(n)) grows with n."
                     :cs "Map + inspect.")))

(verb
  :name "game/surreal-mul"
  :library "game"
  :kind "meta"
  :signature "(game/surreal-mul a b) -> surreal"
  :summary "Multiply two surreal numbers under the recursive surreal multiplication rule."
  :explanation "Surreal multiplication extends real multiplication recursively: a×b = {aL×b + a×bL − aL×bL, aR×b + a×bR − aR×bR | aL×b + a×bR − aL×bR, aR×b + a×bL − aR×bL}. It respects sign (0, positive, negative), commutativity, and associativity over the numeric subclass. Like all surreal operations, it is exact and involves no rounding."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((two (game/surreal-lit 2))\n      (three (game/surreal-lit 3)))\n  (game/surreal-mul two three))" :note "2 × 3 = 6 in surreal form")
    (:dialect "motoi" :tier "intermediate" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((half (game/surreal-lit 1/2))\n      (two (game/surreal-lit 2)))\n  (let ((result (game/surreal-mul half two)))\n    (game/surreal-eq? result (game/surreal-lit 1))))" :note "1/2 × 2 = 1; verify the result equals 1 using game/surreal-eq?")
    (:dialect "motoi" :tier "expert" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((a (game/surreal-lit 1/4))\n      (b (game/surreal-lit 3))\n      (c (game/surreal-lit 2)))\n  (let ((ab (game/surreal-mul a b))\n        (ac (game/surreal-mul a c))\n        (expected (game/surreal-mul a (game/surreal-add b c))))\n    (game/surreal-eq? expected (game/surreal-add ab ac))))" :note "Verify distributivity: a×(b+c) = a×b + a×c in surreal arithmetic")
  )
  :caveats ("Both operands must be surreal numbers (game/surreal-is-number? must return #t); non-numbers escalate with error" "Multiplication of very deep sureals can produce extremely deep results; the recursion depth may grow exponentially" "Zero is a multiplicative annihilator: any × 0 = 0")
  :drawbacks ("Cost is exponential in the birth days of the operands in the worst case" "For large dyadic operands, multiplication becomes prohibitively slow" "The result may be much deeper than either input; chain multiplications accumulate depth")
  :usecases ("Computing products in surreal game value analysis" "Verifying algebraic identities over surreal numbers (distributivity, associativity)" "Scaling game values by surreal multipliers in game-theoretic reasoning")
  :related ("game/surreal-add" "game/surreal-sub" "game/surreal-neg" "game/surreal-is-number?" "game/surreal-lit")
  :learn (:concept "Surreal multiplication extends recursively from left and right sets, respecting the numeric structure" :prerequisites ("game/surreal-lit" "game/surreal-add" "game/surreal-is-number?") :progression "After multiplication, explore game/surreal-birthday (recursion depth) and game/surreal-simplest (finding minimal forms)")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A game solver needs to scale a surreal value by an integer."
                 :program "(define a (game/surreal-lit 3))\n(define b (game/surreal-lit 2))\n(game/surreal-mul a b)"
                 :explanation "Multiply 3 · 2. Returns surreal 6."
                 :meta "Reach for surreal-mul over converting to real; retains exact surreal semantics.")
                (:eng "Deep operands blow up birthday; log if depth exceeds threshold."
                 :math "Recursive: a·b = {aL·b + a·bL − aL·bL, … | …}."
                 :cs "Exponential in depth worst case."))
  :row-3-dimension ((:setup "recursive multiplication on a structured type: same shape appears in surreals, in polynomials, in matrices"
                     :rungs ((:domain "game" :code "(game/surreal-mul (game/surreal-lit 2) (game/surreal-lit 3))")
                             (:domain "poly" :code "(define (poly-mul a b) (map (lambda (x) (* x (car b))) a))\n(poly-mul '(1 2) '(3))")
                             (:domain "mat-mul" :code "(define (mat-scale s m) (map (lambda (r) (map (lambda (x) (* s x)) r)) m))\n(mat-scale 2 '((1 2) (3 4)))"))
                     :explanation "Rung 1 multiplies surreals. Rung 2 multiplies polynomials. Rung 3 scales matrices. Each is a recursive multiplication on structured values."
                     :meta "The shape transfers because 'recursive multiplication' is universal in algebra."
                    )
                    (:eng "Algebra libraries share this pattern."
                     :math "Recursive definition of ×."
                     :cs "Recursive descent."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "One is a right identity for surreal multiplication."
                 :program "(define a (game/surreal-lit 5))\n(define one (game/surreal-lit 1))\n(game/surreal-eq? (game/surreal-mul a one) a)"
                 :invariant "∀ a. a · 1 = a"
                 :meta "Identity element. Falsified by any drift. See book-of-math on fields.")
                (:eng "Regression: multiplying by 1 is identity."
                 :math "1 is multiplicative identity."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal-mul multiplies two surreals."
                     :composition "(define a (game/surreal-lit 2))\n(define b (game/surreal-lit 3))\n(define c (game/surreal-lit 4))\n(define lhs (game/surreal-mul a (game/surreal-add b c)))\n(define rhs (game/surreal-add (game/surreal-mul a b) (game/surreal-mul a c)))\n(game/surreal-eq? lhs rhs)"
                     :emergent "A distributivity check: chaining mul and add over triples yields a verifier for the field axiom."
                     :meta "This is the same family as any algebraic-identity checker. Cross-ref book-of-math on distributivity.")
                    (:eng "Test suites verify field axioms with these compositions."
                     :math "a(b+c) = ab + ac."
                     :cs "Two branches + one comparison.")))

(verb
  :name "game/surreal-neg"
  :library "game"
  :kind "meta"
  :signature "(game/surreal-neg s) -> surreal"
  :summary "Negate a surreal number: −s = {−R | −L}, swapping and negating left and right sets."
  :explanation "Surreal negation is defined recursively by swapping and negating: if s = {L|R}, then −s = {−R|−L}. This operation is self-inverse (−(−s) = s), respects ordering (s ≤ t iff −t ≤ −s), and is the additive inverse (s + (−s) = 0). It is the foundation for surreal subtraction."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((two (game/surreal-lit 2)))\n  (game/surreal-neg two))" :note "Negate 2 to get −2")
    (:dialect "motoi" :tier "intermediate" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((x (game/surreal-lit 1/2)))\n  (let ((neg-x (game/surreal-neg x)))\n    (game/surreal-eq? (game/surreal-add x neg-x) (game/surreal-lit 0))))" :note "Verify that x + (−x) = 0 for x = 1/2; negation is the additive inverse")
    (:dialect "motoi" :tier "expert" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((a (game/surreal-lit 3/4))\n      (b (game/surreal-lit 1/4)))\n  (let ((neg-a (game/surreal-neg a)))\n    (game/surreal-eq? (game/surreal-sub a b)\n                      (game/surreal-add a (game/surreal-neg b)))))" :note "Implement subtraction via negation: a − b = a + (−b)")
  )
  :caveats ("Operand must be a surreal number; non-numbers escalate" "Negation reverses the ordering: if a < b, then −b < −a" "Double negation recovers the original: −(−s) = s (identity-like)")
  :drawbacks ("While O(depth), repeated negations accumulate depth in surrounding expressions" "Negation is primarily a building block; prefer game/surreal-sub for direct subtraction")
  :usecases ("Computing additive inverses in surreal arithmetic" "Implementing surreal subtraction (a − b = a + (−b))" "Reasoning about symmetric game positions (e.g., flipping sides of a game)")
  :related ("game/surreal-add" "game/surreal-sub" "game/surreal-mul" "game/surreal-lit" "game/surreal-le?")
  :learn (:concept "Negation is a recursive tree transformation that swaps and negates left/right sets; it is the additive inverse" :prerequisites ("game/surreal-lit" "game/surreal-is-number?") :progression "After negation, learn addition (game/surreal-add) and subtraction (game/surreal-sub) which rely on negation")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A game engine needs the additive inverse to flip a game's polarity."
                 :program "(define a (game/surreal-lit 5))\n(game/surreal-neg a)"
                 :explanation "Negate a. Result is −5. Downstream, adding a and −a gives zero."
                 :meta "Reach for surreal-neg over any arithmetic-based inversion; direct negation is the primitive.")
                (:eng "Log the birthday of neg; should equal the birthday of a."
                 :math "−{L|R} = {−R|−L}."
                 :cs "Recursive; depth-preserving."))
  :row-3-dimension ((:setup "recursive inversion: same shape appears in surreals, in tree flipping, in vector negation"
                     :rungs ((:domain "game" :code "(game/surreal-neg (game/surreal-lit 3))")
                             (:domain "tree-flip" :code "(define (flip t) (if (pair? t) (reverse (map flip t)) t))\n(flip '(1 2 3))")
                             (:domain "vec-neg" :code "(define (neg v) (map - v))\n(neg '(1 -2 3))"))
                     :explanation "Rung 1 negates a surreal. Rung 2 flips a tree. Rung 3 negates a vector. Each recursively applies an inverse transformation."
                     :meta "The shape transfers because 'recursive inversion' is a universal transform.")
                    (:eng "Sign flips, tree mirrors, and vector negations share this pattern."
                     :math "−(−x) = x."
                     :cs "One-pass recursion."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Double negation is identity."
                 :program "(define a (game/surreal-lit 3))\n(game/surreal-eq? (game/surreal-neg (game/surreal-neg a)) a)"
                 :invariant "∀ a. −(−a) = a"
                 :meta "Involution property. Falsified only by broken recursion. See book-of-math on involutions.")
                (:eng "Regression: double negation cancels."
                 :math "Involution."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal-neg produces the additive inverse."
                     :composition "(define a (game/surreal-lit 3))\n(define na (game/surreal-neg a))\n(game/surreal-eq? (game/surreal-add a na) (game/surreal-lit 0))"
                     :emergent "An inverse-annihilation verifier: chaining neg + add + eq? yields the field axiom check."
                     :meta "This is the same family as inverse-verification in any algebraic structure. Cross-ref book-of-math on additive inverse.")
                    (:eng "Test suites verify inverse axioms with this composition."
                     :math "a + (−a) = 0."
                     :cs "Three-verb chain.")))

(verb
  :name "game/surreal-simplest"
  :library "game"
  :kind "meta"
  :signature "(game/surreal-simplest lo hi) -> surreal"
  :summary "Find the simplest dyadic surreal number strictly between lo and hi (both reals); if lo ≥ hi, return 'nan."
  :explanation "The \"simplest\" surreal between two values is the one with the smallest birth day—the minimal recursion depth needed to separate them. This is useful in game-solving algorithms that build sureals incrementally by binary search, or that need to find canonical representatives in a range. If lo ≥ hi, the interval is empty or inverted, and 'nan is returned."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((zero (game/surreal-lit 0))\n      (one (game/surreal-lit 1)))\n  (game/surreal-simplest zero one))" :note "Simplest surreal between 0 and 1 is 1/2 (born at day 1)")
    (:dialect "motoi" :tier "intermediate" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((quarter (game/surreal-lit 1/4))\n      (half (game/surreal-lit 1/2)))\n  (let ((simple (game/surreal-simplest quarter half)))\n    (game/surreal-le? quarter simple)))" :note "Find simplest between 1/4 and 1/2; the result is strictly between them")
    (:dialect "motoi" :tier "expert" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(define (binary-search target epsilon-day)\n  (let loop ((lo 0) (hi 1) (day 0))\n    (if (> day epsilon-day)\n      target\n      (let ((mid (game/surreal-simplest lo hi)))\n        (if (game/surreal-le? mid target)\n          (loop mid hi (+ day 1))\n          (loop lo mid (+ day 1)))))))\n(binary-search (game/surreal-lit 3/8) 5)" :note "Iterative binary search using surreal-simplest to converge on a value to depth 5")
  )
  :caveats ("Both lo and hi must be real numbers (integers or rationals); non-reals escalate" "If lo ≥ hi, returns 'nan (empty or inverted interval)" "The result is always dyadic; non-dyadic targets require iterative narrowing")
  :drawbacks ("Only finds dyadic sureals; most irrational values require infinite recursion or external approximation" "For very tight bounds, the simplest surreal may still be quite deep (born at a late day)" "Not suitable for approximating transcendental numbers")
  :usecases ("Game-solving algorithms that build sureals via binary search" "Finding canonical representatives in game intervals" "Demonstrating surreal density and birth-day minimality")
  :related ("game/surreal-lit" "game/surreal-le?" "game/surreal-birthday" "game/to-real")
  :learn (:concept "Surreal numbers are dense with a notion of \"simplicity\" measured by birth day; this finds the minimal element in a range" :prerequisites ("game/surreal-lit" "game/surreal-le?" "game/surreal-birthday") :progression "After finding simplest sureals, learn to query their birth day (game/surreal-birthday) and use them in game analysis")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A binary-search algorithm needs the simplest surreal strictly between two known bounds."
                 :program "(define lo 0) (define hi 1)\n(game/surreal-simplest lo hi)"
                 :explanation "Find the minimal-birthday surreal in (0, 1). Returns 1/2."
                 :meta "Reach for surreal-simplest over hand-rolled midpoint; simplest gives canonical minimality, not just an arithmetic midpoint.")
                (:eng "Log 'nan when lo ≥ hi to catch inverted intervals."
                 :math "Simplest = min-birthday surreal in (lo, hi)."
                 :cs "Recursive descent on the interval."))
  :row-3-dimension ((:setup "canonical representative in an open interval: same shape appears in surreals, in interval arithmetic, in convex-hull center"
                     :rungs ((:domain "game" :code "(game/surreal-simplest 0 1)")
                             (:domain "interval" :code "(define (mid lo hi) (/ (+ lo hi) 2))\n(mid 0 1)")
                             (:domain "hull-center" :code "(define (centroid pts) (map / (fold-left (lambda (a b) (map + a b)) '(0 0) pts) (list (length pts) (length pts))))\n(centroid '((0 0) (1 0) (0 1)))"))
                     :explanation "Rung 1 finds the simplest surreal. Rung 2 picks the midpoint. Rung 3 gives a centroid. Each picks a canonical representative between bounds."
                     :meta "The shape transfers because 'canonical between-bounds' is a substrate-neutral primitive.")
                    (:eng "Bisection, geometric centering, and surreal search share the pattern."
                     :math "Canonical representative in a bounded region."
                     :cs "Descend + return canonical."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "For lo < hi, simplest is strictly between."
                 :program "(define s (game/surreal-simplest 0 1))\n(and (game/surreal-le? (game/surreal-lit 0) s) (game/surreal-le? s (game/surreal-lit 1)))"
                 :invariant "∀ lo < hi. lo < simplest(lo,hi) < hi"
                 :meta "Strict-between is definitional. Falsified by boundary violations. See book-of-math on dense orders.")
                (:eng "Regression: simplest is bracketed strictly."
                 :math "Strict order in the open interval."
                 :cs "Two assertions."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal-simplest returns min-birthday surreal in an interval."
                     :composition "(define (bisect target n)\n  (let loop ((lo 0) (hi 1) (i 0))\n    (if (>= i n) lo\n        (let ((m (game/surreal-simplest lo hi)))\n          (if (game/surreal-le? m target) (loop m hi (+ i 1)) (loop lo m (+ i 1)))))))\n(bisect (game/surreal-lit 1) 5)"
                     :emergent "A surreal binary search: chaining simplest with a target-comparison yields dyadic approximation."
                     :meta "This is the same family as any bisection search. Cross-ref book-of-composition on binary search.")
                    (:eng "Educational demos of surreal density walk this loop."
                     :math "Binary search convergence."
                     :cs "Loop + branch.")))

(verb
  :name "game/surreal-sub"
  :library "game"
  :kind "meta"
  :signature "(game/surreal-sub a b) -> surreal"
  :summary "Subtract two surreal numbers: a − b."
  :explanation "Surreal subtraction is defined as a − b = a + (−b), reusing addition and negation. It is the inverse of addition: (a − b) + b = a. Like addition, it is associative and respects the numeric order (a ≤ b iff 0 ≤ b − a)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((three (game/surreal-lit 3))\n      (one (game/surreal-lit 1)))\n  (game/surreal-sub three one))" :note "3 − 1 = 2")
    (:dialect "motoi" :tier "intermediate" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((a (game/surreal-lit 5/4))\n      (b (game/surreal-lit 1/4)))\n  (game/surreal-eq? (game/surreal-sub a b)\n                    (game/surreal-lit 1)))" :note "5/4 − 1/4 = 1; verify with surreal-eq?")
    (:dialect "motoi" :tier "expert" :code ";; NOTE: rational literals (e.g. 1/2) deferred pending TBD-026 (decision-011 has no numerical tower).\n(let ((x (game/surreal-lit 7/8))\n      (y (game/surreal-lit 3/8))\n      (z (game/surreal-lit 1/2)))\n  (let ((diff (game/surreal-sub x y)))\n    (game/surreal-eq? diff z)))" :note "Verify that 7/8 − 3/8 = 1/2 in surreal arithmetic")
  )
  :caveats ("Both operands must be surreal numbers (game/surreal-is-number? must hold); non-numbers escalate" "Subtraction cost is dominated by negation and addition; expect O(depth²) or worse for deep sureals" "Order matters: a − b ≠ b − a (anti-commutativity)")
  :drawbacks ("Repeated subtractions accumulate depth and cost; prefer batching operations or building minimal forms" "For deep sureals, subtraction is expensive; consider game/surreal-le? for comparison-based algorithms instead")
  :usecases ("Computing differences in game values and positions" "Verifying that one game value is \"worth\" more than another by a specific amount" "Building game-theoretic expressions that involve net advantage")
  :related ("game/surreal-add" "game/surreal-neg" "game/surreal-mul" "game/surreal-lit")
  :learn (:concept "Subtraction decomposes into negation and addition; it is the inverse of addition in surreal arithmetic" :prerequisites ("game/surreal-lit" "game/surreal-neg" "game/surreal-add") :progression "After subtraction, master multiplication (game/surreal-mul) to complete surreal arithmetic")
  :row-2-audit (
    :runs "spec-only"
   (:problem "Compute a game's marginal value: what does one side gain by moving to this position?"
                 :program "(define after (game/surreal-lit 5))\n(define before (game/surreal-lit 3))\n(game/surreal-sub after before)"
                 :explanation "Subtract before from after. Result is 2 — the marginal gain."
                 :meta "Reach for surreal-sub over composing add + neg manually; the built-in captures the composition atomically.")
                (:eng "Log the difference; a negative marginal indicates the move hurts."
                 :math "a − b = a + (−b)."
                 :cs "One-shot; internally composes."))
  :row-3-dimension ((:setup "difference of two magnitudes: same shape appears in surreals, in physical differences, in accounting deltas"
                     :rungs ((:domain "game" :code "(game/surreal-sub (game/surreal-lit 5) (game/surreal-lit 3))")
                             (:domain "physics" :code "(- 100 30)")
                             (:domain "delta" :code "(define (delta before after) (- after before))\n(delta 10 15)"))
                     :explanation "Rung 1 subtracts surreals. Rung 2 subtracts numbers. Rung 3 forms a delta. Each computes 'change from before to after.'"
                     :meta "The shape transfers because 'difference' is universal.")
                    (:eng "Physical, financial, and game-value differences share the shape."
                     :math "Δ = a − b."
                     :cs "Standard binary operator."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "a − a = 0."
                 :program "(define a (game/surreal-lit 3))\n(game/surreal-eq? (game/surreal-sub a a) (game/surreal-lit 0))"
                 :invariant "∀ a. a − a = 0"
                 :meta "Self-cancellation. Falsified only by broken subtraction. See book-of-math on group axioms.")
                (:eng "Regression: self-subtraction yields zero."
                 :math "Group inverse axiom."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/surreal-sub differences two surreals."
                     :composition "(define snapshots (list (game/surreal-lit 1) (game/surreal-lit 3) (game/surreal-lit 6)))\n(define deltas (map game/surreal-sub (cdr snapshots) snapshots))\ndeltas"
                     :emergent "A change-log: chaining surreal-sub over consecutive snapshots yields per-step deltas."
                     :meta "This is the same family as any diff-over-time analysis. Cross-ref book-of-composition on diffs.")
                    (:eng "Game analyzers use per-move deltas for evaluation."
                     :math "Consecutive-diff sequence."
                     :cs "Pairwise map.")))

(verb
  :name "game/temperature"
  :library "game"
  :kind "io"
  :signature "(game/temperature game-state) -> real"
  :summary "Compute the thermographic temperature of a game via deep search on the backend; on-device analysis escalates."
  :explanation "Temperature measures how \"hot\" (sensitive to small perturbations) a game is. Formally, it is the highest number t such that the game is still a win for the moving player after each player adds −t to their payoff. Computing temperature requires solving the game tree to completion, which is intractable on-device for most games. This verb delegates to a backend service; if called without backend access, it escalates with 'use-backend."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(game/temperature (list ':game 'nim ':piles (list 1 2 3)))" :note "Query the temperature of a Nim game with piles (1,2,3); must have backend access")
    (:dialect "motoi" :tier "intermediate" :code "(define game-state 'game-state)\n(let ((result (game/temperature game-state)))\n  (if (number? result)\n    result\n    'backend-unavailable))" :note "Attempt to compute temperature; if it escalates, catch and handle gracefully")
    (:dialect "motoi" :tier "expert" :code "(define my-game-state 'my-game-state)\n(define try (lambda args (list \"try\" args)))\n(define (analyze-game state)\n  (try\n    (let ((temp (game/temperature state)))\n      (list ':temperature temp ':type (if (> temp 0) 'hot 'cold)))\n    (lambda (err)\n      (if (eq? err 'use-backend)\n        (list ':status 'offline ':fallback 'use-heuristic)\n        (escalate err)))))\n(analyze-game my-game-state)" :note "Wrap temperature query in error handling; degrade gracefully if backend is unavailable")
  )
  :caveats ("Requires backend service and network connectivity; escalates with 'use-backend if unavailable" "Computation time grows exponentially with game complexity; very large games may time out" "The result is a surreal number (or escalation); do not assume IEEE floating-point")
  :drawbacks ("Not suitable for real-time game-solving; backend latency may be seconds or minutes" "Game state must be serializable and sent over the network; complex closures or mutable state cannot be analyzed" "Scalability: deep trees (depth > ~20) are typically intractable even with backend support")
  :usecases ("Analyzing small to medium combinatorial games (Nim, Wythoff, Chomp, etc.) for educational purposes" "Computing exact thermographic values for game-theoretic research" "Verifying game-solving algorithms by comparing against known temperatures")
  :related ("game/surreal-lit" "game/surreal-is-number?" "game/nim-sum" "game/ttt-value")
  :learn (:concept "Temperature quantifies game sensitivity; computing it requires full tree analysis, delegated to a backend solver" :prerequisites ("game/nim-sum" "game/surreal-lit" "Understanding game trees and surreal games") :progression "After learning temperature, explore related metrics: game/nim-outcome, game/ttt-value for specific game families")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A game engine wants to know how 'hot' a game position is — how sensitive to move ordering."
                 :program "(define g '(game-state (piles 1 2 3)))\n(define t (game/temperature g))\nt"
                 :explanation "Query the temperature. High = hot (mover benefits from moving now). May escalate 'use-backend."
                 :meta "Reach for game/temperature over surreal-eq? checks when the goal is a scalar 'urgency' measure; equality doesn't answer sensitivity.")
                (:eng "Escalations must be caught in fallback code."
                 :math "T = sup{t : G − t·* is still hot}."
                 :cs "Backend-delegated; may be expensive."))
  :row-3-dimension ((:setup "sensitivity metric on a game: same shape appears in games, in options-pricing (volatility), in ML (gradient magnitude)"
                     :rungs ((:domain "game" :code "(game/temperature '(state))")
                             (:domain "volatility" :code "(define (vol prices) (let ((m (/ (apply + prices) (length prices)))) (sqrt (/ (apply + (map (lambda (p) (* (- p m) (- p m))) prices)) (length prices)))))\n(vol '(100 105 95 110))")
                             (:domain "grad-norm" :code "(define (grad-norm g) (sqrt (fold-left + 0 (map * g g))))\n(grad-norm '(3 4))"))
                     :explanation "Rung 1 measures game temperature. Rung 2 measures price volatility. Rung 3 measures gradient magnitude. Each is a sensitivity scalar."
                     :meta "The shape transfers because 'urgency scalar' is universal.")
                    (:eng "Finance, ML, and games all use single-number sensitivity."
                     :math "Sensitivity = spread of outcomes."
                     :cs "Reduce over evaluations."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Cold game (temperature ≤ 0) is a settled position."
                 :program "(define g (game/surreal-lit 0))\n(<= (game/to-real g) 0)"
                 :invariant "T(cold game) ≤ 0"
                 :meta "Definition of cold game. Falsified by a broken temperature. See book-of-math on temperature.")
                (:eng "Regression: settled positions report non-positive temperature."
                 :math "Cold ≤ 0."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/temperature returns urgency of a game."
                     :composition "(define games (list 'g1 'g2 'g3))\n(define temps (map (lambda (g) (list g (game/temperature g))) games))\n(sort temps (lambda (a b) (> (cadr a) (cadr b))))"
                     :emergent "A hot-first priority queue: chaining temperature with sort yields games ordered by urgency."
                     :meta "This is the same family as priority-based scheduling. Cross-ref book-of-composition on priority queues.")
                    (:eng "Move-orderers use temperature to pick which board to play on first."
                     :math "Sort by decreasing T."
                     :cs "Map + sort.")))

(verb
  :name "game/to-real"
  :library "game"
  :kind "meta"
  :signature "(game/to-real surreal) -> number | nan"
  :summary "Extract the real-number value of a surreal number; non-numbers escalate."
  :explanation "Surreal numbers form a field that extends the reals and infinitesimals. Every surreal has a dyadic (binary-rational) value. This verb projects a surreal onto its underlying real or dyadic magnitude. If the input is not a valid surreal, escalates 'not-a-number. Use this when you need to reason about surreals in a game tree but want to ground the result back into the familiar number line."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((s (game/surreal-lit 3))) (game/to-real s))" :note "Convert the surreal literal 3 to its real value (should be 3)")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((s1 (game/surreal-lit 2)) (s2 (game/surreal-lit 3)) (sum (game/surreal-add s1 s2))) (game/to-real sum))" :note "Surreal addition, then extract the real value of the sum")
    (:dialect "motoi" :tier "expert" :code "(define (evaluate-position board) (let ((outcome (game/surreal-lit (if (equal? board 'x-win) 1 (if (equal? board 'o-win) -1 0))))) (game/to-real outcome))) (evaluate-position 'x-win)" :note "Game evaluation closure that lifts board outcomes into surreals and projects back to scalars for comparison")
  )
  :caveats ("Escalates with 'not-a-number if surreal is malformed or nil" "Dyadic precision is limited to the precision of the surreal representation" "Does not round; returns exact dyadic rational")
  :drawbacks ("Surreal arithmetic is slower than native number arithmetic; prefer native +/-/* if you don't need infinitesimals" "Loss of information if the surreal was infinite or infinitesimal (coerces to dyadic)")
  :usecases ("Grounding surreal game-tree values into scorelines for decision-making" "Exporting game evaluations for display or heuristic comparison" "Bridging combinatorial-game theory (CGT) with numeric optimization")
  :related ("game/surreal-lit" "game/surreal-add" "game/surreal-mul" "game/surreal-eq?" "game/ttt-value")
  :learn (:concept "Surreal numbers as a rigorous extension of reals; dyadic values as canonical representation." :prerequisites ("game/surreal-lit") :progression "Understand surreal arithmetic (game/surreal-add, game/surreal-mul) before using game/to-real in larger search trees.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A display needs a floating-point value to show the user; the game logic uses surreals internally."
                 :program "(define s (game/surreal-lit 3))\n(game/to-real s)"
                 :explanation "Convert a surreal to a plain number. The display shows 3."
                 :meta "Reach for to-real at the boundary between surreal-logic and human-facing UI; internal comparisons stay on surreals for exactness.")
                (:eng "Log conversion; non-dyadic surreals return 'nan."
                 :math "to-real : surreal → ℚ_dyadic ∪ {nan}."
                 :cs "Recursive projection."))
  :row-3-dimension ((:setup "projection from a rich type to a poorer display type: same shape appears in surreals, in symbolic to float, in database ORM to plain object"
                     :rungs ((:domain "game" :code "(game/to-real (game/surreal-lit 3))")
                             (:domain "sym-to-float" :code "(exact->inexact 3)")
                             (:domain "orm-to-obj" :code "(define (to-plain row) (list 'row row))\n(to-plain 'db-record)"))
                     :explanation "Rung 1 projects a surreal to a dyadic. Rung 2 projects an exact rational to a float. Rung 3 projects a DB row to a plain object. Each strips higher structure to serve a simpler consumer."
                     :meta "The shape transfers because 'projection to display type' is universal."
                    )
                    (:eng "Boundary conversions are how internal richness meets external simplicity."
                     :math "Section of an inclusion."
                     :cs "Structural projection."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "to-real of lit is round-trip identity on dyadic values."
                 :program "(= (game/to-real (game/surreal-lit 3)) 3)"
                 :invariant "∀ dyadic q. to-real(lit(q)) = q"
                 :meta "Section-retraction identity. Falsified by any lossy conversion. See book-of-math on section-retraction.")
                (:eng "Regression: round-trip test."
                 :math "Section-retraction."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/to-real converts surreal to real."
                     :composition "(define vals (map game/surreal-lit '(0 1 2 3 4)))\n(map game/to-real vals)"
                     :emergent "A batch display map: chaining to-real over surreals yields display-ready numbers."
                     :meta "This is the same family as any batch projection. Cross-ref book-of-composition on projections.")
                    (:eng "UI generation walks a list of game values through to-real."
                     :math "Point-wise projection."
                     :cs "Map.")))

(verb
  :name "game/ttt-best-move"
  :library "game"
  :kind "meta"
  :signature "(game/ttt-best-move board) -> integer (0..8) | nan"
  :summary "Compute the optimal next move (cell 0–8) in tic-tac-toe under perfect play."
  :explanation "Given a board state, this verb runs minimax to find the move that maximizes the current player's outcome. It assumes both players play perfectly. Returns a cell index 0–8 (row-major); if the board is full or already won, returns NaN (no legal move exists or the game is over). Use this to power an unbeatable tic-tac-toe AI or to verify opening-book theory."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(game/ttt-best-move '(empty empty empty empty empty empty empty empty empty))" :note "From an empty board, returns the best opening move (typically 4 or a corner)")
    (:dialect "motoi" :tier "intermediate" :code "(let ((board '(x empty empty empty o empty empty empty empty))) (game/ttt-best-move board))" :note "After X opens at 0 and O responds at 4, find X's next best move")
    (:dialect "motoi" :tier "expert" :code "(define (ai-move board) (let ((cell (game/ttt-best-move board))) (if (number? cell) (begin (display (string-append \"AI plays cell \" (number->string cell))) cell) (display \"Game over or full\")))) (ai-move '(x o x o x empty empty empty empty))" :note "AI wrapper that validates the move before executing; handles the NaN case gracefully")
  )
  :caveats ("Returns NaN if the board is full, already won, or malformed" "Assumes standard tic-tac-toe rules (3×3, three in a row)" "Does not disambiguate between multiple equally-good moves; returns one canonical choice")
  :drawbacks ("No alpha-beta pruning means slower on larger game trees (not an issue for tic-tac-toe)" "No ability to vary difficulty; always returns the perfect move")
  :usecases ("Building an unbeatable tic-tac-toe opponent" "Verifying opening books or endgame theory" "Teaching minimax by example (small, auditable tree)")
  :related ("game/ttt-value" "game/temperature" "game/nim-outcome" "game/wythoff-p?")
  :learn (:concept "Minimax: recursive evaluation of all futures under optimal play; deterministic, perfect information." :prerequisites ("game/ttt-value") :progression "Learn game/temperature for imperfect-information games; study game/nim-outcome for combinatorial-game theory.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "An unbeatable AI needs its next tic-tac-toe move at a given board state."
                 :program "(define board '(x empty empty empty o empty empty empty empty))\n(game/ttt-best-move board)"
                 :explanation "Query the best move. Returns the cell index the AI should play."
                 :meta "Reach for ttt-best-move over ttt-value + one-ply lookahead; the best-move verb bundles the search.")
                (:eng "Log the move; if it returns 'nan, the board is terminal or malformed."
                 :math "argmax over legal moves under minimax."
                 :cs "Full minimax; O(9!) worst case for tic-tac-toe (small)."))
  :row-3-dimension ((:setup "argmax under optimal opponent play: same shape appears in tic-tac-toe, in adversarial ML, in worst-case-analysis"
                     :rungs ((:domain "game" :code "(game/ttt-best-move '(empty empty empty empty empty empty empty empty empty))")
                             (:domain "adv-ml" :code "(define (safe-choice options adversary) (car options))\n(safe-choice '(a b c) 'attacker)")
                             (:domain "worst-case" :code "(define (worst-case scenarios) (apply min scenarios))\n(worst-case '(3 5 1 7))"))
                     :explanation "Rung 1 picks best move given optimal opponent. Rung 2 picks safest choice under adversary. Rung 3 evaluates worst-case cost. Each is an argmax-of-min or its dual."
                     :meta "The shape transfers because 'best against optimal opponent' is universal."
                    )
                    (:eng "Game AI, adversarial ML, and worst-case planning share the pattern."
                     :math "max_x min_y payoff(x,y)."
                     :cs "Minimax kernel."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "On a full board, best-move returns 'nan."
                 :program "(let ((full '(x o x o x o x o x))) (eq? (game/ttt-best-move full) 'nan))"
                 :invariant "No-legal-move ⟹ result = 'nan"
                 :meta "No-legal-move sentinel. Falsified by any non-nan return on a full board. See book-of-code on sentinels.")
                (:eng "Regression: full board returns 'nan."
                 :math "Termination indicator."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/ttt-best-move returns the optimal move."
                     :composition "(define (play-out initial)\n  (let loop ((board initial))\n    (let ((m (game/ttt-best-move board)))\n      (if (eq? m 'nan) board (loop (place-marker board m))))))\n(define (place-marker b i) b)\n(play-out '(empty empty empty empty empty empty empty empty empty))"
                     :emergent "A game auto-play: chaining ttt-best-move with a place-marker step drives the game to a terminal state."
                     :meta "This is the same family as any state-machine driven by a policy. Cross-ref book-of-composition on state machines.")
                    (:eng "Automated tests play through games to check invariants."
                     :math "Iterate policy until terminal."
                     :cs "Loop + terminal check.")))

(verb
  :name "game/ttt-value"
  :library "game"
  :kind "meta"
  :signature "(game/ttt-value board) -> 'x-win | 'o-win | 'draw"
  :summary "Evaluate a tic-tac-toe board: which player wins (or draws) under perfect play?"
  :explanation "This verb runs minimax to determine the outcome of a given board position if both players continue optimally. It returns a symbol: 'x-win, 'o-win, or 'draw. Unlike game/ttt-best-move (which returns a move), this returns the verdict. Use it to verify endgame positions, to score game trees, or to test board safety."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(game/ttt-value '(x x x o o empty empty empty empty))" :note "X has won (three in the top row); returns 'x-win")
    (:dialect "motoi" :tier "intermediate" :code "(let ((board '(x empty empty empty o empty empty empty empty))) (if (equal? (game/ttt-value board) 'draw) (display \"Game will end in a draw\") (display \"Winner exists\")))" :note "Check whether a position is a theoretical draw or has a winner")
    (:dialect "motoi" :tier "expert" :code "(define (score-move board move) (let* ((new-board (apply list-item-toss (list board move 'x))) (verdict (game/ttt-value new-board))) (cond ((equal? verdict 'x-win) 1) ((equal? verdict 'draw) 0) (else -1)))) (score-move '(empty empty empty empty o empty empty empty empty) 0)" :note "Score a candidate move by evaluating the resulting board state; used in move ordering")
  )
  :caveats ("Assumes both players play optimally after the current position" "Does not detect invalid boards (e.g., both players having three in a row)" "Outcome depends on whose turn it is (implicit in the board's parity)")
  :drawbacks ("Full minimax is exponential in tree depth; acceptable for tic-tac-toe (5 ply max) but not for chess" "Does not return a score (draw is not distinguished from a loss); only three possible outcomes")
  :usecases ("Verifying endgame correctness" "Testing whether a position is safe or losing" "Grading moves: compare before/after verdicts" "Proof by exhaustion for tic-tac-toe theory")
  :related ("game/ttt-best-move" "game/temperature" "game/nim-outcome" "game/surreal-lit")
  :learn (:concept "Terminal evaluation and backward induction: outcomes propagate up a game tree." :prerequisites ("Core conditionals (cond, if)") :progression "Build game/ttt-best-move on top of game/ttt-value; then study game/temperature for heuristic scores.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A trainer needs the theoretical outcome of a tic-tac-toe position to grade moves."
                 :program "(define board '(x x empty empty o empty empty empty empty))\n(game/ttt-value board)"
                 :explanation "Query the position's outcome under optimal play. Returns 'draw, 'x-win, or 'o-win."
                 :meta "Reach for ttt-value to grade positions; ttt-best-move gives a move, ttt-value gives the verdict.")
                (:eng "Log the verdict alongside the board hash for training data."
                 :math "Terminal-payoff propagated via minimax."
                 :cs "Full search on a small tree."))
  :row-3-dimension ((:setup "verdict on a state under optimal continuation: same shape appears in tic-tac-toe, in chess endgame tables, in solved puzzles"
                     :rungs ((:domain "game" :code "(game/ttt-value '(x x x o o empty empty empty empty))")
                             (:domain "chess-endgame" :code "(define (endgame-verdict pos) 'draw)\n(endgame-verdict 'kk)")
                             (:domain "puzzle" :code "(define (puzzle-solvable? state) #t)\n(puzzle-solvable? '(1 2 3))"))
                     :explanation "Rung 1 verdicts a TTT board. Rung 2 verdicts a chess endgame. Rung 3 verdicts a puzzle. Each returns a symbolic outcome from a state."
                     :meta "The shape transfers because 'verdict from state' is universal in solved games."
                    )
                    (:eng "Endgame tables, TTT solvers, and puzzle solvers share this shape."
                     :math "Verdict = argmax over minimax."
                     :cs "Table lookup or search."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "A winning-for-x board yields 'x-win."
                 :program "(eq? (game/ttt-value '(x x x o o empty empty empty empty)) 'x-win)"
                 :invariant "Winning position yields corresponding-symbol verdict"
                 :meta "Terminal correctness. Falsified by mismatch. See book-of-code on terminal payoffs.")
                (:eng "Regression: known winning position returns 'x-win."
                 :math "Terminal condition preservation."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/ttt-value returns the position's verdict."
                     :composition "(define positions (list '(x empty empty empty o empty empty empty empty)\n                        '(x x empty empty o empty empty empty empty)))\n(map game/ttt-value positions)"
                     :emergent "A batch verdict: chaining ttt-value over positions yields per-position outcomes."
                     :meta "This is the same family as batch classification. Cross-ref book-of-composition on batch analysis.")
                    (:eng "Training data labeling walks a corpus through this map."
                     :math "Batch verdict."
                     :cs "Map.")))

(verb
  :name "game/wythoff-p?"
  :library "game"
  :kind "meta"
  :signature "(game/wythoff-p? a b) -> boolean"
  :summary "Test whether (a,b) is a P-position (losing position) in Wythoff's game."
  :explanation "Wythoff's game is a combinatorial game: two players alternate removing any number of objects from one pile, or the same number from both piles. A position (a,b) is a P-position (Previous player wins, or equivalently, the mover loses) if and only if it is a Beatty pair: (a,b) = (⌊nφ⌋, ⌊nφ²⌋) for some non-negative integer n, where φ = (1+√5)/2 is the golden ratio. This verb checks that condition. Use it to determine optimal play, to generate safe positions, or to teach about nimbers."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(game/wythoff-p? 0 0)" :note "The empty piles (0,0) is a P-position; the mover has no move and loses")
    (:dialect "motoi" :tier "intermediate" :code "(let ((candidates '((1 2) (3 5) (4 7)))) (map (lambda (pair) (game/wythoff-p? (car pair) (cadr pair))) candidates))" :note "Check a list of candidate positions to identify which are P-positions (safe for the previous player)")
    (:dialect "motoi" :tier "expert" :code "(define (safe-move a b) (let loop ((da 1)) (if (> da a (let loop2 ((db 1)) (if (> db b) #f (if (not (game/wythoff-p? (- a da) (- b db))) (list (- a da) (- b db)) (loop2 (+ db 1)))))) (if (game/wythoff-p? (- a da) b) (list (- a da) b) (loop (+ da 1)))))) (safe-move 5 8)" :note "Find a safe move from (a,b) by trying all successors and picking one that reaches a P-position")
  )
  :caveats ("The Beatty sequence grows quadratically; large a or b may require significant computation" "Does not validate that a and b are non-negative; behavior on negative inputs is undefined" "Floating-point rounding in φ may cause precision loss for very large indices")
  :drawbacks ("Slower than memoized game/nim-outcome for multiple queries on related positions" "Does not return the next safe move; only the verdict")
  :usecases ("Solving Wythoff's game optimally" "Teaching Beatty pairs and the golden ratio in game theory" "Generating opening books or endgame tables" "Verifying mathematical conjectures about combinatorial games")
  :related ("game/nim-outcome" "game/nimsum" "game/temperature" "game/ttt-value")
  :learn (:concept "P-positions vs N-positions; Beatty pairs; connection between game theory and number theory." :prerequisites ("game/nim-outcome" "math/round (for understanding ⌊·⌋)") :progression "Study game/temperature and surreal numbers for more complex combinatorial games.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A Wythoff solver checks whether the position (a, b) is a losing P-position."
                 :program "(game/wythoff-p? 3 5)"
                 :explanation "Test whether (3,5) is a P-position. Returns #t iff it's the Beatty pair for some n."
                 :meta "Reach for wythoff-p? over hand-rolled Beatty tests; it uses the exact formula involving the golden ratio.")
                (:eng "Log the query; verifies safe-position claims in gameplay tests."
                 :math "(a,b) P iff (a,b) = (⌊nφ⌋, ⌊nφ²⌋) for some n."
                 :cs "Uses golden ratio; watch precision for large a,b."))
  :row-3-dimension ((:setup "membership test in a Beatty sequence: same shape appears in Wythoff, in modular residue tests, in lattice-point tests"
                     :rungs ((:domain "game" :code "(game/wythoff-p? 3 5)")
                             (:domain "residue" :code "(define (residue-in? n mod set) (memv (modulo n mod) set))\n(residue-in? 7 5 '(2 3))")
                             (:domain "lattice" :code "(define (lattice-point? x y) (and (integer? x) (integer? y)))\n(lattice-point? 3.0 4.0)"))
                     :explanation "Rung 1 tests Wythoff P membership. Rung 2 tests residue class membership. Rung 3 tests lattice point membership. Each is a decision procedure on a discrete structured set."
                     :meta "The shape transfers because 'discrete membership test' is universal."
                    )
                    (:eng "Number theory tests, game theory, and lattice queries share the pattern."
                     :math "Predicate on ℕ × ℕ."
                     :cs "Formula + threshold."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "(0,0) is a P-position."
                 :program "(game/wythoff-p? 0 0)"
                 :invariant "wythoff-p?(0,0) = #t"
                 :meta "Empty position is losing (mover has no moves). Falsified by any negative return. See book-of-math on Wythoff's game.")
                (:eng "Regression: origin is P."
                 :math "n=0 Beatty pair."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "game/wythoff-p? predicates Beatty membership."
                     :composition "(define pairs '((1 2) (3 5) (4 7) (6 10)))\n(filter (lambda (p) (game/wythoff-p? (car p) (cadr p))) pairs)"
                     :emergent "A P-position sieve: chaining wythoff-p? with filter yields Beatty pairs from a candidate list."
                     :meta "This is the same family as any number-theoretic sieve. Cross-ref book-of-composition on sieves.")
                    (:eng "Puzzle authors sieve candidate positions for safe teaching examples."
                     :math "Preimage of the P-position set."
                     :cs "One-pass filter.")))

(verb
  :name "big-bang"
  :library "game"
  :kind "mut"
  :dialect "motoi"
  :signature "(big-bang initial-state [step-fn]) -> integer"
  :arity "1-2"
  :contract "initial-state any; step-fn optional procedure of (state, frame)→state → integer id"
  :summary "Start a new game instance with an initial state and an optional step function. Returns a numeric id."
  :doc "Creates an entry in the game-instances registry. The step-fn, if given, is called on each (game/step id) invocation with the current state and frame counter, and its return value replaces the state. If the step-fn is omitted or returns undefined, the state is unchanged."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(big-bang 'ready)" :note "Start a stateful world seeded with the symbol 'ready. Returns an integer id.")
    (:dialect "motoi" :tier "intermediate" :code "(big-bang 0 (lambda (s f) (+ s 1)))" :note "State counts up by 1 each step. Returns the id.")
    (:dialect "motoi" :tier "expert" :code "(define id (big-bang '(score 0)\n                    (lambda (s f) (cons 'score (list (+ 1 (car (cdr s))))))))\n(game/step id)\n(game/state id)" :note "Advance one step; state becomes (score 1).")
  )
  :related ("game/state" "game/step" "game/stop" "game/frame")
  :row-2-audit ((:problem "A card wants a fresh game instance seeded with an initial state and a per-frame step function."
                 :program "(define id (big-bang 0 (lambda (s f) (+ s 1))))\n(game/step id) (game/step id)\n(game/state id)"
                 :explanation "Create a game seeded with 0 and a step-fn that increments state. Step twice. State is 2."
                 :meta "Reach for big-bang over ad-hoc state variables when the game deserves its own lifecycle (id + step-fn + running flag).")
                (:eng "Log the returned id; every subsequent game/* verb needs it."
                 :math "big-bang : state × step-fn → id."
                 :cs "Registers a new entry in the game-instances registry."))
  :row-3-dimension ((:setup "constructor + closure = lifecycle: same shape appears in games, in threads, in actors"
                     :rungs ((:domain "game" :code "(big-bang 'initial (lambda (s f) s))")
                             (:domain "thread" :code "(define (spawn thunk) (list 'thread thunk))\n(spawn (lambda () (display 'go)))")
                             (:domain "actor" :code "(define (actor-spawn init behavior) (list 'actor init behavior))\n(actor-spawn 0 (lambda (s m) s))"))
                     :explanation "Rung 1 spawns a game. Rung 2 spawns a thread. Rung 3 spawns an actor. Each returns an id/handle for a running-lifecycle resource."
                     :meta "The shape transfers because 'spawn + get id' is universal.")
                    (:eng "Concurrency systems, actors, and games share this constructor."
                     :math "Constructor with closure."
                     :cs "Register + return handle."))
  :row-4-proof ((:claim "Fresh big-bang yields frame 0."
                 :program "(let ((id (big-bang 'x))) (= (game/frame id) 0))"
                 :invariant "∀ x. frame(big-bang(x)) = 0"
                 :meta "Constructor postcondition. Falsified by nonzero initial frame. See book-of-code on constructor invariants.")
                (:eng "Regression: fresh game starts at frame 0."
                 :math "Initial value."
                 :cs "One assertion."))
  :row-5-emergence ((:base "big-bang creates a new game instance."
                     :composition "(define ids (map (lambda (init) (big-bang init (lambda (s f) (+ s 1)))) '(0 100 500)))\nids"
                     :emergent "A fleet of independent games: chaining big-bang over seeds yields a set of parallel worlds."
                     :meta "This is the same family as any fleet-spawn pattern. Cross-ref book-of-composition on parallel worlds.")
                    (:eng "Multiplayer scenes spawn one game per player using this map."
                     :math "Family of independent states."
                     :cs "Map over seeds."))
)

(verb
  :name "game/state"
  :library "game"
  :kind "pure"
  :dialect "motoi"
  :signature "(game/state id) -> any | 'nan"
  :arity "1"
  :contract "id is an integer from big-bang → the instance's current state, or the symbol 'nan for unknown id"
  :summary "Read the current state of a game instance."
  :doc "Non-mutating. Returns 'nan (a sentinel symbol) for unknown ids so callers can guard without exception handling."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((id (big-bang 'starting))) (game/state id))" :note "Returns 'starting.")
    (:dialect "motoi" :tier "intermediate" :code "(game/state 9999)" :note "Unknown id. Returns 'nan.")
    (:dialect "motoi" :tier "expert" :code "(define (state-or default id)\n  (let ((s (game/state id)))\n    (if (eq? s 'nan) default s)))\n(state-or 'no-game 9999)" :note "Guarded accessor with a caller-supplied default.")
  )
  :related ("big-bang" "game/step" "game/frame" "game/running?")
  :row-2-audit ((:problem "A UI needs the current game state to render the scene."
                 :program "(define id (big-bang '(score 0)))\n(game/state id)"
                 :explanation "Read state. Returns the seeded (score 0). UI paints score."
                 :meta "Reach for game/state (this signature returning 'nan for unknown) over the state signature that escalates; nan-return lets consumers guard.")
                (:eng "'nan return signals malformed id; log and skip."
                 :math "state : id → any ∪ {nan}."
                 :cs "Registry read; O(1)."))
  :row-3-dimension ((:setup "read + sentinel-on-miss: same shape appears in games, in dictionary get-with-default, in HTTP 404"
                     :rungs ((:domain "game" :code "(game/state 9999)")
                             (:domain "dict-get" :code "(define (dict-get d k default) (or (assoc k d) default))\n(dict-get '((a 1)) 'x 'miss)")
                             (:domain "http" :code "(define (http-get url) (if (equal? url \"/known\") 200 404))\n(http-get \"/unknown\")"))
                     :explanation "Rung 1 returns 'nan on miss. Rung 2 returns default. Rung 3 returns 404. Each returns a sentinel on lookup failure instead of raising."
                     :meta "The shape transfers because 'read + sentinel' is universal.")
                    (:eng "Registries, caches, and services share the sentinel pattern."
                     :math "Read is total: id → any + missing."
                     :cs "Lookup + sentinel."))
  :row-4-proof ((:claim "Unknown id returns 'nan."
                 :program "(eq? (game/state 999999) 'nan)"
                 :invariant "∀ unknown id. state(id) = 'nan"
                 :meta "Miss-sentinel contract. Falsified by any escalation. See book-of-code on sentinel values.")
                (:eng "Regression: unknown id yields 'nan."
                 :math "Total function."
                 :cs "One assertion."))
  :row-5-emergence ((:base "game/state reads game state with 'nan on miss."
                     :composition "(define ids (list (big-bang 'a) 12345 (big-bang 'b)))\n(map game/state ids)"
                     :emergent "A resilient batch read: chaining state over mixed valid + invalid ids yields uniform result list with 'nan for misses."
                     :meta "This is the same family as any resilient batch operation. Cross-ref book-of-composition on resilient reads.")
                    (:eng "Debuggers batch-read all known + potentially-stale ids without crashing."
                     :math "Map is total."
                     :cs "One-pass map."))
)

(verb
  :name "game/step"
  :library "game"
  :kind "mut"
  :dialect "motoi"
  :signature "(game/step id) -> symbol"
  :arity "1"
  :contract "id is an integer → 'ok | 'done | 'error | 'nan"
  :summary "Advance a game instance by one frame. Returns a status symbol."
  :doc "Increments the frame counter; if a step-fn is registered, invokes it. Return values: 'ok on success, 'done if the instance was previously stopped, 'error if the step-fn threw, 'nan if the id is unknown."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((id (big-bang 'x))) (game/step id))" :note "Returns 'ok.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((id (big-bang 0 (lambda (s f) (+ s 1)))))\n  (game/step id) (game/step id) (game/step id)\n  (game/state id))" :note "Three steps advance state 0 → 3.")
    (:dialect "motoi" :tier "expert" :code "(let* ((id (big-bang 0 (lambda (s f) (+ s 1))))\n       (statuses (map (lambda (_) (game/step id)) (range 0 5))))\n  (list 'statuses statuses 'final (game/state id)))" :note "Run five steps, collect statuses, report final state.")
  )
  :related ("big-bang" "game/state" "game/frame" "game/stop")
  :row-2-audit ((:problem "A tester needs to step a game and check the status."
                 :program "(define id (big-bang 0 (lambda (s f) (+ s 1))))\n(game/step id)"
                 :explanation "Step the game. Returns 'ok. State advances to 1."
                 :meta "Reach for this game/step (returning status symbol) over the raw signature; the symbol lets callers branch cleanly.")
                (:eng "'done means game was stopped; 'error means step-fn threw; 'nan means unknown id."
                 :math "step : id → symbol."
                 :cs "Increments frame + applies step-fn."))
  :row-3-dimension ((:setup "advance + status: same shape appears in games, in state machines, in HTTP request-status pairs"
                     :rungs ((:domain "game" :code "(game/step (big-bang 'x))")
                             (:domain "state-machine" :code "(define (fsm-step state input) (list 'ok state))\n(fsm-step 'idle 'go)")
                             (:domain "http" :code "(define (request url) (list 200 'body))\n(request \"/\")"))
                     :explanation "Rung 1 steps a game with status. Rung 2 fires a state machine transition with status. Rung 3 completes an HTTP request with status. Each returns a status symbol alongside effect."
                     :meta "The shape transfers because 'advance + status' is universal."
                    )
                    (:eng "State machines, HTTP, and games share the returned-symbol pattern."
                     :math "Transition + status."
                     :cs "Effect + return."))
  :row-4-proof ((:claim "After game/stop, game/step returns 'done."
                 :program "(define id (big-bang 'x))\n(game/stop id)\n(eq? (game/step id) 'done)"
                 :invariant "∀ stopped id. step(id) = 'done"
                 :meta "Post-stop status contract. Falsified by any misreport. See book-of-code on lifecycles.")
                (:eng "Regression: stopped games report done."
                 :math "Absorbing state."
                 :cs "One assertion."))
  :row-5-emergence ((:base "game/step advances a game and returns status."
                     :composition "(define id (big-bang 0 (lambda (s f) (+ s 1))))\n(define statuses (map (lambda (_) (game/step id)) '(1 2 3)))\nstatuses"
                     :emergent "A status trace: chaining step over calls yields a sequence of statuses."
                     :meta "This is the same family as any trace of transitions. Cross-ref book-of-composition on trace analysis.")
                    (:eng "Debug tools capture this trace to reconstruct sessions."
                     :math "trace : ℕ → status list."
                     :cs "Map + collect."))
)

(verb
  :name "game/frame"
  :library "game"
  :kind "pure"
  :dialect "motoi"
  :signature "(game/frame id) -> integer | 'nan"
  :arity "1"
  :contract "id is an integer → nonnegative integer, or 'nan for unknown id"
  :summary "Read the frame counter of a game instance."
  :doc "Starts at 0 immediately after big-bang, increments by 1 per game/step. Never resets. Independent of running/stopped state."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((id (big-bang 'x))) (game/frame id))" :note "Fresh instance. Returns 0.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((id (big-bang 'x)))\n  (game/step id) (game/step id) (game/frame id))" :note "After two steps. Returns 2.")
    (:dialect "motoi" :tier "expert" :code "(let* ((id (big-bang 'x))\n       (frames (map (lambda (_) (game/step id) (game/frame id))\n                    (range 0 4))))\n  frames)" :note "Collect frame numbers over four steps: (1 2 3 4).")
  )
  :related ("big-bang" "game/state" "game/step")
  :row-2-audit ((:problem "A per-game clock reads the current frame counter."
                 :program "(define id (big-bang 'x))\n(game/frame id)"
                 :explanation "Read the frame counter. Fresh game returns 0."
                 :meta "Reach for this game/frame (returning 'nan on unknown id) over the raw signature; nan-return lets callers guard.")
                (:eng "'nan flags an unknown id."
                 :math "frame : id → ℕ ∪ {nan}."
                 :cs "Registry read; O(1)."))
  :row-3-dimension ((:setup "read a per-instance counter: same shape appears in games, in per-thread counters, in per-request request-id"
                     :rungs ((:domain "game" :code "(game/frame (big-bang 'x))")
                             (:domain "thread-counter" :code "(define (thread-ticks t) (cadr t))\n(thread-ticks '(t 5))")
                             (:domain "request-id" :code "(define (req-id r) (cadr r))\n(req-id '(req 42))"))
                     :explanation "Rung 1 reads per-game frame. Rung 2 reads per-thread ticks. Rung 3 reads per-request id. Each reads a per-instance counter."
                     :meta "The shape transfers because 'per-instance counter read' is universal."
                    )
                    (:eng "Threading, tracing, and games share this pattern."
                     :math "Counter read: id → ℕ."
                     :cs "Registry-scoped counter."))
  :row-4-proof ((:claim "game/frame after stop is not reset."
                 :program "(define id (big-bang 'x))\n(game/step id) (game/step id)\n(game/stop id)\n(= (game/frame id) 2)"
                 :invariant "∀ id. frame(id) after stop = frame(id) at stop time"
                 :meta "Frame persistence past stop. Falsified by any reset. See book-of-code on non-destructive lifecycle.")
                (:eng "Regression: frame survives stop."
                 :math "Post-stop state preservation."
                 :cs "One assertion."))
  :row-5-emergence ((:base "game/frame reads per-game frame counter."
                     :composition "(define id (big-bang 'x))\n(define frames (map (lambda (_) (game/step id) (game/frame id)) '(1 2 3 4)))\nframes"
                     :emergent "A frame trace: chaining step + frame yields the sequence (1,2,3,4)."
                     :meta "This is the same family as any counter-observing trace. Cross-ref book-of-composition on trace analysis.")
                    (:eng "Frame tracing correlates game events to per-instance time."
                     :math "trace = [1, 2, 3, …]."
                     :cs "Interleaved effect + read."))
)

(verb
  :name "game/stop"
  :library "game"
  :kind "mut"
  :dialect "motoi"
  :signature "(game/stop id) -> boolean"
  :arity "1"
  :contract "id is an integer → #t if stopped, #f for unknown id"
  :summary "Halt a game instance. Subsequent game/step calls return 'done."
  :doc "Sets running=false. The instance's state, frame counter, and step-fn remain accessible; only stepping is inert."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((id (big-bang 'x))) (game/stop id))" :note "Returns #t.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((id (big-bang 'x))) (game/stop id) (game/step id))" :note "After stop, step returns 'done.")
    (:dialect "motoi" :tier "expert" :code "(let ((id (big-bang 'x)))\n  (list 'before (game/running? id)\n        'stop-result (game/stop id)\n        'after (game/running? id)))" :note "Observe the transition. Returns (before #t stop-result #t after #f).")
  )
  :related ("big-bang" "game/running?" "game/step")
  :row-2-audit ((:problem "A win condition halts a game."
                 :program "(define id (big-bang 'x))\n(game/stop id)\n(game/running? id)"
                 :explanation "Stop the game. Returns #t. game/running? afterward returns #f."
                 :meta "Reach for this game/stop (boolean return) over the raw signature; the boolean lets callers know if the stop succeeded.")
                (:eng "Log 'stopped id N' for post-mortem correlation."
                 :math "stop : id → 𝔹."
                 :cs "Mutating; sets running=false."))
  :row-3-dimension ((:setup "shutdown-with-status: same shape appears in games, in kill signals, in transaction commits"
                     :rungs ((:domain "game" :code "(game/stop (big-bang 'x))")
                             (:domain "signal" :code "(define (kill pid) #t)\n(kill 42)")
                             (:domain "commit" :code "(define (commit txn) #t)\n(commit 'txn)"))
                     :explanation "Rung 1 stops a game. Rung 2 sends a kill signal. Rung 3 commits a transaction. Each returns #t/success on completion."
                     :meta "The shape transfers because 'shutdown returning status' is universal."
                    )
                    (:eng "Processes, transactions, and games share the completion-signal pattern."
                     :math "shutdown : id → 𝔹."
                     :cs "Boolean result."))
  :row-4-proof ((:claim "Stopping an unknown id returns #f."
                 :program "(not (game/stop 999999))"
                 :invariant "∀ unknown id. stop(id) = #f"
                 :meta "Sentinel-on-miss. Falsified by any escalation. See book-of-code on total functions.")
                (:eng "Regression: unknown-id stop returns #f."
                 :math "Total shutdown function."
                 :cs "One assertion."))
  :row-5-emergence ((:base "game/stop halts a game with boolean status."
                     :composition "(define ids (list (big-bang 'a) (big-bang 'b) 99999))\n(map game/stop ids)"
                     :emergent "A bulk-stop result: chaining stop over a mixed list yields per-id status."
                     :meta "This is the same family as bulk-shutdown with per-item reporting. Cross-ref book-of-composition on bulk operations.")
                    (:eng "Scene transitions stop-all with a report of what succeeded."
                     :math "Per-id boolean."
                     :cs "Map."))
)

(verb
  :name "on-collision"
  :library "game"
  :kind "io"
  :signature "(on-collision handler | #f) -> void"
  :status "landed"
  :since "2026-07-16"
  :dialect "motoi"
  :audience "adult"
  :provenance "motoi-scheme/lib/game/game.js"
  :training-eligible #t
  :confidentiality "open"
  :summary "Install a per-step collision handler; fires for every overlapping pair inside physics/step."
  :explanation "on-collision registers a single callback the physics engine fires from within physics/step for every unordered pair of entities whose AABBs overlap. Handler is called with (a-id b-id) — both as Syms — so the callback can look up entity state, apply damage, spawn particles, or issue impulses. Single-slot per Motoi convention (matches on-frame, on-key): calling on-collision again replaces the previous handler. Pass #f (or false) to clear. Adapter-safe: the collision math is pure geometry (see aabbOverlap in lib/game/game.js)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(on-collision (lambda (a b) (display 'hit) (newline)))" :note "Print 'hit whenever any two entities touch.")
    (:dialect "motoi" :tier "intermediate" :code "(entity/make 'ball 100 100)\n(entity/make 'wall 108 108 16 16)\n(entity/pin! 'wall)\n(on-collision (lambda (a b)\n  (cond ((eq? a 'ball) (entity/apply-force! a -2 -5))\n        ((eq? b 'ball) (entity/apply-force! b -2 -5)))))\n(physics/step)" :note "Bounce the ball off a pinned wall by applying a reactive impulse in the collision handler.")
    (:dialect "motoi" :tier "expert" :code "(define scored 0)\n(on-collision (lambda (a b)\n  (let ((kinds (list (entity/has-tag? a 'coin) (entity/has-tag? b 'coin))\n                (list (entity/has-tag? a 'player) (entity/has-tag? b 'player))))\n    ; If one side is player and the other a coin, score and despawn the coin.\n    (cond ((and (entity/has-tag? a 'player) (entity/has-tag? b 'coin))\n           (set! scored (+ scored 1)) (entity/remove! b))\n          ((and (entity/has-tag? a 'coin) (entity/has-tag? b 'player))\n           (set! scored (+ scored 1)) (entity/remove! a))))))" :note "Pickup logic: player + coin collision increments score and removes the coin. Symmetric handling because pair order is unspecified.")
  )
  :caveats ("Pair order is unspecified — handle (a, b) and (b, a) symmetrically." "Handler fires from inside physics/step; keep it small. Heavy work should defer via after-frame." "Single-slot per canonical Motoi shape: setting a new handler replaces the previous one. Compose in Scheme if you need multiple listeners." "Collision detection is AABB only; use entity/shape! + custom checks for pixel-perfect or convex-polygon collisions.")
  :drawbacks ("O(n²) per step — every pair is tested. For large N, filter with entity/tag! + entity/hits-tag first." "No collision metadata (contact point, normal, penetration depth) — only the two ids." "Doesn't fire for tween/tween or tween/entity overlaps; scope is entity-entity only.")
  :usecases ("Damage on hit." "Item pickup." "Trigger zones and switches." "Enemy AI: react to touching the player." "Physics reactions (bounce, break, stick).")
  :related ("physics/step" "entity/collisions" "entity/apply-force!" "entity/hits-tag" "motion/on-settle")
  :learn (:concept "Callback-driven collision reporting inside the physics loop." :prerequisites ("entity/make" "physics/step") :progression "Combine on-collision with entity/tag! for team logic, then with entity/apply-force! for reactive physics.")
  :row-2-audit ((:problem "A game needs to react whenever two entities overlap."
                 :program "(on-collision (lambda (a b) (display 'hit)))\n(physics/step)"
                 :explanation "Register a handler. On the next physics step, every overlapping pair fires the handler once."
                 :meta "Reach for on-collision over polling entity/collisions each frame; the callback fires at the right point in physics/step.")
                (:eng "Handler runs inside physics/step — keep it small."
                 :math "on-collision : handler → void."
                 :cs "Single-slot per Motoi convention."))
  :row-3-dimension ((:setup "callback registration for pair-wise events: same shape appears in games, in event listeners, in signal-handlers"
                     :rungs ((:domain "game" :code "(on-collision (lambda (a b) (display 'hit)))")
                             (:domain "event" :code "(define (on-click handler) (list 'click-handler handler))\n(on-click (lambda (e) e))")
                             (:domain "signal" :code "(define (on-signal sig handler) (list sig handler))\n(on-signal 'sigterm (lambda () 'stopped))"))
                     :explanation "Rung 1 registers collision callback. Rung 2 registers click callback. Rung 3 registers signal handler. Each installs a per-slot callback for asynchronous events."
                     :meta "The shape transfers because 'single-slot event callback' is universal."
                    )
                    (:eng "UI, OS signals, and physics share this registration."
                     :math "handler slot."
                     :cs "Replace-on-set semantics."))
  :row-4-proof ((:claim "Registering #f clears the collision handler."
                 :program "(on-collision (lambda (a b) 'x))\n(on-collision #f)\n#t"
                 :invariant "on-collision(#f) removes any prior handler"
                 :meta "Handler-clear convention. Falsified by residual firing after clear. See book-of-code on handler slots.")
                (:eng "Regression: clearing prevents further fires."
                 :math "Idempotent clear."
                 :cs "One assertion."))
  :row-5-emergence ((:base "on-collision installs a per-step pair callback."
                     :composition "(define score 0)\n(on-collision (lambda (a b)\n  (when (and (eq? a 'player) (eq? b 'coin)) (set! score (+ score 1)))))\n(physics/step)\nscore"
                     :emergent "A pickup system: chaining on-collision with tag inspection yields score-on-touch."
                     :meta "This is the same family as any physics-driven game rule. Cross-ref book-of-composition on physics-callbacks.")
                    (:eng "Coin pickup, damage-on-hit, and trigger zones use this composition."
                     :math "Score is a fold over collision events."
                     :cs "Handler + mutation.")))

