;;; 69-vec.slat — Motoi Scheme Reference · Chapter 69 · library vec
;;;
;;; 18 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library vec — 18 verbs.")

(chapter :number "69" :library "vec" :verb-count 18 :training-eligible #t)

;; ═══ 18 verbs in library vec ═══

(verb
  :name "vec/+"
  :library "vec"
  :kind "meta"
  :signature "(vec/+ v1 v2 ...) -> vector"
  :summary "Element-wise addition of vectors; all must have the same dimension."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Variadic component-wise sum over an arbitrary number of vectors. Missing components are treated as 0, so vectors of different length are padded rather than raised — a design choice that lets 2D vectors freely embed into 3D contexts. Empty arg list returns ()."
  :explanation "Vector addition is the fundamental linear algebra operation: add corresponding components. If v1 = [a, b, c] and v2 = [d, e, f], then v1 + v2 = [a+d, b+e, c+f]. This is exact arithmetic (no floating-point error beyond Scheme's native number operations). Variadic: vec/+ can add 2 or more vectors in sequence, walking through them position by position."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/+ '(1 2 3) '(4 5 6))" :note "3-dimensional vector addition. Returns (5 7 9) — each position summed independently.")
    (:dialect "motoi" :tier "apprentice" :code "(define player-pos '(100 200))\n(define delta '(3 -1))\n(vec/+ player-pos delta)" :note "The classic 'move by a delta' pattern. New position (103 199). Move north-east by (3, -1) — the -1 means down one because screen Y grows downward.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((v1 '(1 0 -1))\n      (v2 '(2 3 4))\n      (v3 '(-3 2 0)))\n  (vec/+ v1 v2 v3))" :note "Variadic: add three vectors in one call. Returns (0 5 3).")
    (:dialect "motoi" :tier "expert" :code "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(let* ((forces (list '(10 0) '(0 15) '(-5 3)))\n       (net-force (fold-left vec/+ '(0 0) forces)))\n  net-force)" :note "Sum a list of force vectors via fold. Net force = (5 18). This is the standard physics pattern for accumulating impulses in a frame.")
    (:dialect "motoi" :tier "master" :code "(define (path->positions origin steps)\n  ;; Given a starting position and a list of step vectors,\n  ;; return the visited positions including the origin.\n  (let loop ((cur origin) (rest steps) (acc (list origin)))\n    (if (null? rest)\n        (reverse acc)\n        (let ((next (vec/+ cur (car rest))))\n          (loop next (cdr rest) (cons next acc))))))\n(path->positions '(0 0) '((1 0) (0 1) (1 0) (0 -1)))" :note "Cumulative fold builds a path from step-deltas. Returns ((0 0) (1 0) (1 1) (2 1) (2 0)) — a square-like walk that ends one right of the start.")
  )
  :caveats ("Component-count mismatch does not raise; shorter vectors are zero-padded up to the longest. Callers who need strict equality should validate first." "Exact arithmetic is preserved; 1/2 + 1/3 yields 5/6, not a float approximation." "vec/+ is variadic; (vec/+ v1 v2 v3) adds all three in one call, not sequential nesting.")
  :drawbacks ("No in-place operation; creates a new vector (functional programming style)." "Variadic unpacking may be slower than binary + for very long chains." "Exact rationals in each component can grow in numerator/denominator size; simplification is not automatic.")
  :usecases ("Physics: summing forces, velocities, or displacements." "Computer graphics: adding translation or offset vectors." "Linear algebra: assembling linear combinations (paired with vec/scale)." "Data science: element-wise merging of numerical features.")
  :related ("vec/-" "vec/scale" "vec/dot" "vec/norm")
  :learn (:concept "Vector addition as component-wise operation preserving exact arithmetic" :prerequisites ("vec/make") :progression "Master vec/+, then combine with vec/scale to build linear combinations, then use vec/dot for projections, then study matrix operations.")
  :math (:algebra ("associative" "commutative" "identity: zero-vector") :total #t :domain "n vectors of equal dimension d" :codomain "vector of dimension d")
  :cs (:complexity "time O(k·d), space O(d) for k vectors of dimension d" :effects (none) :pure #t)
  :ai (:deterministic #t :cacheable #t :cardinality one :common-mistakes "Assuming vec/+ raises on dim mismatch; it zero-pads instead. If you need strict dim checking, use (vec/dim v) yourself first.")
  :hacker (:primitive #f :kin ("R7RS: no built-in; Clojure: (mapv + v1 v2); NumPy: v1 + v2") :history "Standard linear algebra since Grassmann (1844). Our impl is a straightforward variadic component-wise fold.")
  :row-2-audit (
    (:problem "A physics tick accumulates forces from gravity, wind, and drag on an entity; the operator wants one net-force vector to feed entity/set-vel!."
     :program "(define forces (list '(0 -9.8) '(2 0) '(-0.3 0.1)))\n(define (fold-left f init xs) (if (null? xs) init (fold-left f (f init (car xs)) (cdr xs))))\n(define net-force (fold-left vec/+ '(0 0) forces))\nnet-force"
     :explanation "Three 2-D force vectors are folded left-to-right into a zero-vector seed. Each fold step calls vec/+ once, adding the running total to the next force. The final value is (1.7 -9.7) — gravity dominates the y axis, wind and drag mostly cancel on x."
     :meta "vec/+ is the honest verb because we are combining SAME-KIND quantities (forces on the same body in the same frame). A sibling like vec/lerp would blend two forces halfway — wrong semantics. vec/scale would multiply by a scalar — wrong shape. Under audit, vec/+ documents that we accumulated; that intent survives into logs. See SRE Manual ch on 'the verb names the intent'.")
    (:eng "Operators grep logs for '(vec/+ ...)' to prove force accumulation happened; if the code used raw map+ zip, the audit trail vanishes."
     :math "Vector addition in R^n is closed, associative, and commutative — the fold order does not affect the answer, so parallel workers can partial-sum safely."
     :cs "O(k·d) time; folded via left-fold to keep intermediate allocations linear in k. The variadic surface is a thin wrapper over binary +."))
  :row-3-dimension (
    (:setup "Same-shape combine: two things of the same kind get merged into one thing of that kind, preserving totals."
     :rungs (
       (:domain "vec" :code "(vec/+ '(3 4) '(1 2))  ;; (4 6)")
       (:domain "audio/mix" :code "(audio/mix track-a track-b)  ;; two waveforms superposed sample-by-sample")
       (:domain "monoid ⟨R^n, +, 0⟩" :code "(fold-left + 0 (map car pairs))  ;; the underlying monoid operation on any component"))
     :explanation "Rung 1 sums two vectors component-wise. Rung 2 superposes two audio buffers sample-by-sample — the SAME shape: two signals combine into one by pointwise addition. Rung 3 is the underlying algebraic structure: a commutative monoid where the identity is the zero element and the operation is closed. All three rungs are the same aspect wearing three costumes."
     :meta "The shape transfers because each substrate has an identity element and a closed, associative binary op. Any domain with those two properties supports the same 'accumulate-a-batch-into-a-running-total' idiom.")
    (:eng "Mixing consoles physically implement the audio rung with resistor summing junctions — engineering realizes the same shape."
     :math "The abstract structure is a commutative monoid; see book-of-math ch on abelian groups and monoids."
     :cs "Any monoid supports MapReduce-style parallel summation because associativity lets us re-parenthesize freely."))
  :row-4-proof (
    (:claim "vec/+ is commutative: adding a to b gives the same vector as adding b to a."
     :program "(define a '(3 -1 2))\n(define b '(0 5 7))\n(equal? (vec/+ a b) (vec/+ b a))"
     :invariant "∀ a b ∈ R^d.  vec/+(a, b) = vec/+(b, a)"
     :meta "Commutativity is inherited from + on numbers component-by-component. What would falsify: any pair where left and right disagree — e.g., a floating-point non-associativity artifact showing up in a triple sum. See book-of-math ch on abelian groups; the pattern-name is 'commutative binary operation'.")
    (:eng "Order-independent combine means a load balancer can shard force-accumulation across workers and reduce with matrix/+ later without deterministic-ordering constraints."
     :math "Commutativity + associativity = the vector monoid is abelian; this is what lets us re-order fold sequences."
     :cs "For high-dimensional float vectors, commutativity holds bitwise per pair, but ASSOCIATIVITY of a longer chain can drift by ULPs — a different invariant with a different test."))
  :row-5-emergence (
    (:base "vec/+ adds two vectors component-wise."
     :composition "(define positions (list '(0 0) '(1 0) '(1 1) '(0 1)))\n(define (fold-left f init xs) (if (null? xs) init (fold-left f (f init (car xs)) (cdr xs))))\n(define n (length positions))\n(define centroid\n  (let ((sum (fold-left vec/+ '(0 0) positions)))\n    (list (/ (car sum) n) (/ (cadr sum) n))))\ncentroid"
     :emergent "centroid / average-of-points — a summary statistic emerges from (repeated vec/+) + (division by count). Neither verb alone is a centroid; their composition is."
     :meta "Family: reduction-then-scale, the same pattern as arithmetic mean, center-of-mass, and running-average. Analog: SQL AVG() = SUM()/COUNT(). See book-of-composition ch on fold-and-normalize.")
    (:eng "Every game that computes 'party center point' or 'average enemy position' composes exactly this chain — vec/+ over a list, then scale by 1/n."
     :math "This is the arithmetic mean of a set of points in R^d."
     :cs "Two-pass fold: first accumulate, then normalize. Streaming variants (running mean) fuse into one pass with a counter.")))

(verb
  :name "vec/-"
  :library "vec"
  :kind "meta"
  :signature "(vec/- v1 [v2 ...]) -> vector"
  :summary "Element-wise subtraction of vectors; single-arg negates, N-ary subtracts left-to-right."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Variadic component-wise subtraction. One arg negates. Two args = v1-v2. N-ary = (((v1-v2)-v3)-v4). Missing components zero-pad rather than raise — see vec/+ for the matching design."
  :explanation "Vector subtraction is addition of the negated vector: v1 − v2 = v1 + (−v2). If v1 = [a, b, c] and v2 = [d, e, f], then v1 − v2 = [a−d, b−e, c−f]. Exact arithmetic is preserved. With one argument, returns the negation. With 2+ arguments, subtracts left-to-right: vec/- v1 v2 v3 = (v1 − v2) − v3."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/- '(5 7 9) '(1 2 3))" :note "3-D subtraction. Returns (4 5 6).")
    (:dialect "motoi" :tier "apprentice" :code "(vec/- '(1 2 3))" :note "One-arg negates every component. Returns (-1 -2 -3) — cleaner than writing (vec/- '(0 0 0) v) for the same effect.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((start '(3 4))\n      (end '(7 1)))\n  (vec/- end start))" :note "Displacement vector (end − start) from two positions. Returns (4 -3) — four right, three up in screen space where Y grows downward.")
    (:dialect "motoi" :tier "expert" :code "(vec/- '(10 10 10) '(1 2 3) '(1 1 1))" :note "N-ary left-to-right subtraction. (10-1-1, 10-2-1, 10-3-1) = (8 7 6). Handy for subtracting several offsets in one call.")
    (:dialect "motoi" :tier "master" :code "(define (velocity from to dt)\n  ;; Given two positions and a time delta, return the average\n  ;; velocity vector: displacement / dt applied component-wise.\n  (map (lambda (x) (/ x dt)) (vec/- to from)))\n(velocity '(0 0) '(6 8) 2)" :note "Compose vec/- with map to compute a velocity. From (0,0) to (6,8) over 2 seconds: (3 4). Magnitude 5 — the 3-4-5 triangle appearing in kinematics.")
  )
  :caveats ("Component-count mismatch does not raise; shorter vectors are zero-padded." "Left-associative: vec/- a b c = (a − b) − c, not a − (b − c)." "Single-argument form returns negation." "Exact arithmetic is preserved; 1/2 − 1/3 yields 1/6 exactly.")
  :drawbacks ("Variadic left-associativity can be counterintuitive; use parentheses to clarify intent." "No in-place operation; creates a fresh vector each time." "Exact rationals can accumulate large numerators/denominators over many operations.")
  :usecases ("Physics: computing relative velocity or displacement between two points." "Graphics: computing edge vectors from vertex pairs." "Linear algebra: forming differences for numerical methods (e.g. gradient descent)." "Signal processing: computing deltas or differences in time series.")
  :related ("vec/+" "vec/scale" "vec/norm" "vec/dot")
  :learn (:concept "Vector subtraction as component-wise negation and addition; left-to-right evaluation" :prerequisites ("vec/+" "vec/make") :progression "Use vec/- to compute displacements, then combine with vec/norm to compute distances, then study vec/angle-between for relative orientation.")
  :math (:algebra ("not-commutative" "identity: zero-vector on the right") :total #t :domain "one or more vectors" :codomain "vector of the largest input dimension")
  :cs (:complexity "time O(k·d), space O(d)" :effects (none) :pure #t)
  :ai (:deterministic #t :cacheable #t :cardinality one :common-mistakes "Expecting right-associative evaluation. (vec/- a b c) subtracts BOTH b and c from a, not (a - (b-c)).")
  :hacker (:primitive #f :kin ("NumPy: v1 - v2 - v3; Clojure: (mapv - v1 v2 v3)") :history "Follows Grassmann's vector algebra; the negation-of-one-arg convention echoes Scheme's numeric (-).")
  :row-2-audit (
    (:problem "An entity at position P wants to know the direction and magnitude to a target T so the AI planner can decide whether to pursue or ignore."
     :program "(define P '(3 4))\n(define T '(10 9))\n(define delta (vec/- T P))\n(define dist (sqrt (+ (* (car delta) (car delta)) (* (cadr delta) (cadr delta)))))\n(list 'delta delta 'dist dist)"
     :explanation "vec/- with two args returns the displacement vector T − P. We then compute Euclidean magnitude by hand from delta. Result: displacement (7 5), distance sqrt(74) ≈ 8.60."
     :meta "vec/- is the audit answer because 'displacement' has a signed direction. A sibling like vec/distance collapses direction to a scalar — losing the pursuit-vector the planner needs. Order matters: (vec/- T P) points FROM P TO T; reversed operands would send the entity backward.")
    (:eng "Operational logs show 'delta = (7 5)' when pursuit begins; if we had used a scalar distance verb, the log would say only '8.60' and later replay would not tell us which direction the entity was moving."
     :math "T − P is the vector from P to T; this is the coordinate-free definition of displacement in an affine space."
     :cs "Two-arg call is O(d); we manually re-square components rather than call vec/norm to show the shape."))
  :row-3-dimension (
    (:setup "Directed difference: taking one state and asking 'what's the arrow to another state?'"
     :rungs (
       (:domain "vec" :code "(vec/- '(10 9) '(3 4))  ;; (7 5) — displacement")
       (:domain "time/deltas" :code "(- t-now t-then)  ;; elapsed time between two clock reads")
       (:domain "affine space P^n" :code "(sub P T)  ;; the tangent vector such that T + v = P"))
     :explanation "Rung 1 subtracts vector positions. Rung 2 subtracts scalar timestamps to get a duration. Rung 3 is the general affine principle: subtracting two POINTS gives a VECTOR — the tangent that connects them. All three share the shape 'two states → the arrow between them.'"
     :meta "The shape transfers because in any affine structure, the difference of points is a vector — a group-theoretic complement to a torsor.")
    (:eng "Both a game engine tracking positions and a distributed system tracking clocks use exactly this shape to reason about relative offsets."
     :math "In an affine space, subtraction of points yields the associated vector-space element; see book-of-math ch on affine geometry."
     :cs "The tangent-vs-point distinction shows up as separate types in type-safe geometry libs; Motoi keeps them as lists for brevity."))
  :row-4-proof (
    (:claim "vec/- is the inverse of vec/+ in the second argument: (vec/+ a (vec/- b a)) recovers b."
     :program "(define a '(3 -1 2))\n(define b '(0 5 7))\n(equal? (vec/+ a (vec/- b a)) b)"
     :invariant "∀ a b ∈ R^d.  vec/+(a, vec/-(b, a)) = b"
     :meta "This is the affine reconstruction identity: from a base point and the displacement to another, we recover the other. What falsifies: any pair where roundtrip fails — e.g., a bug where vec/- returns the wrong sign, or a floating-point discrepancy in the last decimal. Pattern-name: subtraction-is-inverse-of-addition in an abelian group. See book-of-math ch on group inverses.")
    (:eng "The reconstruction identity means a save-file can store base + delta and rebuild the target exactly on load — used in physics-replay and telemetry compression."
     :math "In an abelian group ⟨R^d, +, 0, −⟩, − is the group inverse operation; this is what makes reconstruction exact for integers/rationals."
     :cs "For floats, the identity holds bitwise per component when both operands are finite; NaN or inf breaks it — a testable falsifier."))
  :row-5-emergence (
    (:base "vec/- takes two vectors and returns their component-wise difference."
     :composition "(define (path-points ps)\n  (let loop ((rest (cdr ps)) (prev (car ps)) (acc '()))\n    (if (null? rest) (reverse acc)\n        (loop (cdr rest) (car rest) (cons (vec/- (car rest) prev) acc)))))\n(path-points (list '(0 0) '(1 0) '(3 1) '(4 4)))"
     :emergent "step-vectors / segment-differences — the sequence of arrows between consecutive path points emerges from mapping vec/- over adjacent pairs."
     :meta "Family: pairwise-delta or difference-stream, the same pattern as time-series differencing in statistics (numpy.diff) or SQL LAG()-based deltas. See book-of-composition ch on stream-adjacent-map.")
    (:eng "Animation systems compute per-frame movement by taking vec/- of consecutive keyframe positions — the step-vector is what interpolators consume."
     :math "Discrete forward-difference operator Δ on a sequence of vectors."
     :cs "Two-argument sliding window; formally a zip(xs, cdr xs) mapped with the operator.")))

(verb
  :name "vec/->string"
  :library "vec"
  :kind "meta"
  :signature "(vec/->string v) -> string"
  :summary "Convert a vector to a compact parenthesized string of components."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Formats as \"(c1 c2 c3)\" — s-expression style. NOT bracket notation. The impl uses parens so debug output round-trips through the reader with a leading quote or list."
  :explanation "Produces a compact string for logging, display, or REPL output. The format uses parentheses and space separators — the same shape the reader accepts, so debug output can be pasted back into code (with a leading quote or list) and it will round-trip. Non-numeric components render as their JS-default toString."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/->string '(3 4))" :note "Bare list works. Returns the string \"(3 4)\".")
    (:dialect "motoi" :tier "apprentice" :code "(vec/->string (vec/make (list 3 4)))" :note "Same result via vec/make: \"(3 4)\". The vector's underlying shape is a list, so vec/->string doesn't need to know the difference.")
    (:dialect "motoi" :tier "intermediate" :code "(vec/->string (vec/+ '(1 2 3) '(4 5 6)))" :note "Compose vec/+ with vec/->string for a one-liner debug print. Returns \"(5 7 9)\".")
    (:dialect "motoi" :tier "expert" :code "(define (debug-vector-ops label v)\n  (string-append label \": \" (vec/->string v)))\n(list (debug-vector-ops \"Original\" '(1 2 3))\n      (debug-vector-ops \"Doubled\" (vec/+ '(1 2 3) '(1 2 3))))" :note "Named debug helper for annotated inspection. Composable — feeds directly into (display ...) or log lines.")
    (:dialect "motoi" :tier "master" :code "(define (format-transcript ops)\n  ;; ops is a list of (label vec) pairs; render each as one line.\n  (define (fmt-pair p) (string-append (car p) \" = \" (vec/->string (cadr p))))\n  (let loop ((remaining ops) (acc '()))\n    (if (null? remaining)\n        (reverse acc)\n        (loop (cdr remaining)\n              (cons (fmt-pair (car remaining)) acc)))))\n(format-transcript (list (list \"a\" '(1 2))\n                         (list \"b\" '(3 4))\n                         (list \"sum\" (vec/+ '(1 2) '(3 4)))))" :note "Build a transcript of vector operations by pairing each with vec/->string. Three annotated lines — a common pattern when teaching or debugging a linear-algebra derivation.")
  )
  :caveats ("Format is parenthesized (\"(1 2 3)\"), not bracketed — the earlier summary said brackets but the impl uses s-expr style." "Not meant to be a serialization format; use it for humans, not for machine round-trips." "Non-numeric components render as their JS-side toString.")
  :drawbacks ("Produces a new string object per call — avoid in tight inner loops." "No control over precision; Scheme numbers render with JS defaults.")
  :usecases ("Debugging: examining intermediate vector values in a calculation." "REPL interaction: quick eyeball inspection of vec/+ or vec/scale outputs." "Logging: recording vector states during a simulation.")
  :related ("vec/make" "vec/ref" "vec/dim" "vec/=" "matrix/->string")
  :learn (:concept "Display and introspection of vector data without mutation." :prerequisites ("vec/make") :progression "After learning vec/->string, inspect results of vec/+, vec/-, and vec/scale to understand composition.")
  :cs (:complexity "time O(d), space O(d) for dimension d" :effects (none) :pure #t)
  :ai (:deterministic #t :cacheable #t :cardinality one)
  :hacker (:primitive #f :history "Motoi convention — parens over brackets to match the reader.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A REPL session shows a mysterious vector value; the operator wants to eyeball its components before feeding it into a downstream verb."
     :program "(define v (vec/+ '(1 2 3) '(4 5 6)))\n(define msg (vec/->string v))\n(display (string-append \"got: \" msg))"
     :explanation "vec/+ produces a vector; vec/->string renders it as the string \"(5 7 9)\"; string-append and display show it once. The renderer is the only piece that can be trusted to reveal ALL components — a truncated toString could hide surprises."
     :meta "vec/->string is the audit-safe rendering; sibling display alone might print the underlying list representation with quirks (e.g., dotted pairs). Under audit we want stable, parseable output.")
    (:eng "Log lines like 'net-force = (1.7 -9.7)' are what operators grep; a raw list print '(1.7 . (-9.7 . ()))' would be unreadable."
     :math "String rendering has no algebraic content; it is a display function on the value space."
     :cs "Pure: same input yields the same string. No side effect except the returned string; the display call is what actually emits to stdout."))
  :row-3-dimension (
    (:setup "Value-to-text projection: rendering an internal structure as a human-legible string for inspection."
     :rungs (
       (:domain "vec" :code "(vec/->string '(3 4))  ;; \"(3 4)\"")
       (:domain "matrix" :code "(matrix/->string '((1 2)(3 4)))  ;; \"((1 2) (3 4))\"")
       (:domain "monoid hom to strings" :code "(number->string 3.14)  ;; \"3.14\" — same shape at scalar level"))
     :explanation "Rung 1 renders a vector as text. Rung 2 renders a matrix by the same convention. Rung 3 is the underlying general shape: a mapping from internal representation to a printable form that another program (or human) can read. Each rung is a specific case of 'give me a string I can look at'."
     :meta "The shape transfers because rendering is a homomorphism from the value domain into the string monoid; each substrate implements its own specialization while sharing the intent.")
    (:eng "Every debug logger uses this shape to turn structured values into log lines."
     :math "In categorical terms, a display function is a natural transformation from the value functor to a constant string functor."
     :cs "Related to Show typeclass in Haskell, __repr__ in Python."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "vec/->string is deterministic: the same vector always renders to the same string."
     :program "(define v '(1 2 3))\n(equal? (vec/->string v) (vec/->string v))"
     :invariant "∀ v ∈ vector.  vec/->string(v) = vec/->string(v)"
     :meta "Determinism is what makes rendering trustworthy for logs. What falsifies: any nondeterminism (memory-address printing, timestamp inclusion). Pattern-name: pure function / referential transparency. See book-of-code ch on purity.")
    (:eng "Deterministic rendering means log diff-ing across runs finds real changes, not noise."
     :math "A pure function f: A → B satisfies f(a) = f(a); trivial but load-bearing."
     :cs "Referential transparency at the string level; safe to memoize."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "vec/->string turns a vector into a display string."
     :composition "(define (log-op label v)\n  (display (string-append label \": \" (vec/->string v) \"\\n\")))\n(log-op \"pos\" '(3 4))\n(log-op \"vel\" (vec/+ '(1 0) '(0 2)))"
     :emergent "structured-logger / labeled-trace — a mini-logging framework emerges from vec/->string chained with string-append and display."
     :meta "Family: log-line-builder, same pattern as printf-style formatters or Bunyan/Winston structured logs. See book-of-composition ch on emit-and-format.")
    (:eng "Every ad-hoc debug logger in Motoi code repeats this three-verb chain."
     :math "Function composition: display ∘ (string-append label) ∘ vec/->string."
     :cs "Composability of pure renderers into an IO edge; the pure/impure boundary is the display call.")))

(verb
  :name "vec/="
  :library "vec"
  :kind "meta"
  :signature "(vec/= a b) -> boolean"
  :summary "Test exact component-wise equality of two vectors."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Dim check first, then strict === per component. No tolerance."
  :explanation "Returns true if and only if two vectors have the same dimension and every corresponding component is exactly equal (using Scheme's = predicate on numbers). Dimension mismatch returns false. This is a strict equality test, not approximate; use it for validation and exact comparisons, not for floating-point tolerance checks."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/= '(1 2 3) '(1 2 3))" :note "Two identical 3-vectors return #t.")
    (:dialect "motoi" :tier "apprentice" :code "(vec/= '(1 2 3) '(1 2 4))" :note "One component differs — vec/= is all-or-nothing, so #f.")
    (:dialect "motoi" :tier "intermediate" :code "(define orig '(2 3))\n(define scaled (vec/scale '(1 1.5) 2))\n(if (vec/= orig scaled) 'match 'differ)" :note "Round-trip: build the target directly, then via vec/scale, verify they agree. (vec/scale v k) returns v*k componentwise.")
    (:dialect "motoi" :tier "expert" :code "(define (all-equal? vecs)\n  (if (null? vecs) #t\n    (let ((v0 (car vecs)))\n      (let loop ((rest (cdr vecs)))\n        (cond ((null? rest) #t)\n              ((vec/= v0 (car rest)) (loop (cdr rest)))\n              (else #f))))))\n(all-equal? (list '(1 0) '(1 0) '(1 0)))" :note "Fold vec/= to check every vector equals the first. Manual short-circuit exits on first mismatch.")
    (:dialect "motoi" :tier "master" :code "(define (find-index target vecs)\n  (let loop ((rest vecs) (i 0))\n    (cond ((null? rest) -1)\n          ((vec/= target (car rest)) i)\n          (else (loop (cdr rest) (+ i 1))))))\n(find-index '(2 3) (list '(1 0) '(0 1) '(2 3) '(5 5)))" :note "Linear search returns 0-based position of first match. Returns 2 — target is at index 2.")
  )
  :math (:algebra ("equivalence relation") :total #t :domain "two vectors" :codomain "boolean")
  :cs (:complexity "time O(d), space O(1)" :effects (none) :pure #t)
  :ai (:deterministic #t :cacheable #t :cardinality one)
  :caveats ("Exact equality: 0.3 ≠ (0.1 + 0.2) due to floating-point rounding." "Different dimensions always compare false; no automatic alignment or zero-padding." "Both arguments must be vectors; passing non-vectors yields false or error depending on implementation.")
  :drawbacks ("Too strict for many numerical applications; consider approximate comparison (e.g., checking vec/norm of difference)." "Does not short-circuit on dimension mismatch in all implementations; may be slower than a custom predicate." "Not idempotent with floating-point: (vec/= v1 v1) is always true, but (vec/= (vec/+ a b) (vec/+ a b)) may differ if intermediate rounding differs.")
  :usecases ("Unit tests: verifying that a transformation produces an expected exact result." "Discrete geometry: checking whether two lattice points coincide." "Symbolic computation: comparing vectors over exact rational or symbolic components.")
  :related ("vec/make" "vec/+" "vec/-" "vec/norm" "matrix/=")
  :learn (:concept "Exact comparison and equality testing in linear algebra." :prerequisites ("vec/make" "= (core form)") :progression "Master vec/= before attempting approximate comparisons or tolerance-based checks; understand floating-point limitations.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A unit test verifies that applying vec/+ then vec/- recovers the original vector; the operator wants a boolean answer to feed assert/eq."
     :program "(define original '(3 4 5))\n(define delta '(1 -2 0))\n(define round-trip (vec/- (vec/+ original delta) delta))\n(vec/= original round-trip)"
     :explanation "We start with a vector, add and subtract a delta, and check that the round-trip landed exactly. vec/= walks components and compares strictly. For exact rationals this is #t; for floats this may drift and fail — which is the correct signal."
     :meta "vec/= is the audit answer for EXACT tests. A sibling like an epsilon-tolerant compare would silently paper over rounding — hiding bugs. Under strict audit we want the truth: exact-equal or not.")
    (:eng "Test suites use vec/= to gate a pass/fail; loose tolerance would let regressions slip in."
     :math "Equality is an equivalence relation: reflexive, symmetric, transitive on R^d."
     :cs "O(d) short-circuit walk; strict === per component."))
  :row-3-dimension (
    (:setup "Structural equality across a compound value: two things count as equal iff every corresponding piece is equal."
     :rungs (
       (:domain "vec" :code "(vec/= '(1 2) '(1 2))  ;; #t")
       (:domain "list" :code "(equal? '(1 2) '(1 2))  ;; base Scheme structural equality")
       (:domain "product type A×B" :code "(and (= a1 a2) (= b1 b2))  ;; equality is conjunction of piecewise equalities"))
     :explanation "Rung 1 tests vector equality. Rung 2 is base Scheme's equal? on lists — the same shape. Rung 3 is the underlying rule: in any product type, equality is the conjunction of component equalities. Vectors are a specialization of that shape."
     :meta "Structural equality composes: an equality relation on the pieces induces one on the whole; the shape moves cleanly.")
    (:eng "Diff tools use exactly this shape when comparing config records field-by-field."
     :math "In category theory, this is equality in a product object; see book-of-math ch on products and equivalence relations."
     :cs "Recursively-structured equality is what equal? in Scheme (or __eq__ in Python) does at each level."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "vec/= is an equivalence relation: reflexive, symmetric, and transitive."
     :program "(define a '(1 2 3))\n(define b '(1 2 3))\n(define c '(1 2 3))\n(list (vec/= a a) (equal? (vec/= a b) (vec/= b a)) (or (not (and (vec/= a b) (vec/= b c))) (vec/= a c)))"
     :invariant "∀ a b c ∈ R^d.  (vec/=(a,a)) ∧ (vec/=(a,b) ↔ vec/=(b,a)) ∧ ((vec/=(a,b) ∧ vec/=(b,c)) → vec/=(a,c))"
     :meta "Equivalence-relation laws are what let vec/= be used to partition a set of vectors into equivalence classes safely. Falsifier: any triple that reveals asymmetry (would indicate a bug in component order). See book-of-code ch on equivalence relations.")
    (:eng "Correct equivalence semantics means memoization tables using vec/= as key comparison won't leak duplicate entries."
     :math "Equivalence relation on the codomain R^d; standard set-theory."
     :cs "Hash-tables using vec/= as their equality require a compatible hash — a companion invariant."))
  :row-5-emergence (
    (:base "vec/= tests two vectors for exact component equality."
     :composition "(define (memoize-vec-op f)\n  (let ((cache '()))\n    (lambda (v)\n      (let loop ((entries cache))\n        (cond ((null? entries)\n               (let ((r (f v)))\n                 (set! cache (cons (cons v r) cache))\n                 r))\n              ((vec/= v (caar entries)) (cdar entries))\n              (else (loop (cdr entries))))))))\n(define slow-double (memoize-vec-op (lambda (v) (vec/+ v v))))\n(slow-double '(1 2 3))"
     :emergent "memoization cache keyed by vector value — an alist cache emerges from vec/= plus set!."
     :meta "Family: memoize-by-equality, same pattern as Python's functools.lru_cache or Redis GET/SET. See book-of-composition ch on stateful cache patterns.")
    (:eng "Repeated-call speedup: complex vec operations become O(1) on cache hit."
     :math "Fixed-point invariant: f(v) = cache-lookup(v) after the first evaluation, forever."
     :cs "Association-list cache; O(n) lookup worst case. A hash-based version would need vec-hash and vec/= together.")))

(verb
  :name "vec/angle-between"
  :library "vec"
  :kind "meta"
  :signature "(vec/angle-between a b) -> number"
  :summary "Compute the angle (in radians) between two vectors via arccosine."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Direct dot/magnitude formula: acos(dot(a,b) / (|a|*|b|)). Clamps the cosine to [-1, 1] before acos so tiny floating-point overflows don't produce NaN. Zero-magnitude inputs return 0."
  :explanation "Returns the unsigned angle θ ∈ [0, π] between vectors a and b using θ = acos((a·b)/(‖a‖·‖b‖)). Parallel yields 0. Anti-parallel yields π. Perpendicular yields π/2."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/angle-between '(1 0) '(0 1))" :note "Perpendicular 2-D unit vectors. Returns π/2 ≈ 1.5708.")
    (:dialect "motoi" :tier "apprentice" :code "(vec/angle-between '(1 0) '(-1 0))" :note "Anti-parallel: same axis, opposite direction. Returns π ≈ 3.1416.")
    (:dialect "motoi" :tier "intermediate" :code "(define theta (vec/angle-between '(1 1 1) '(1 0 0)))\n(list 'radians theta 'degrees (* theta (/ 180 3.141592653589793)))" :note "3-D angle between (1,1,1) and the x-axis. About 54.7° — the tetrahedral half-angle.")
    (:dialect "motoi" :tier "expert" :code "(define (closest-to target candidates)\n  (let loop ((rest candidates) (best (car candidates))\n              (best-a (vec/angle-between target (car candidates))))\n    (if (null? rest) best\n        (let ((a (vec/angle-between target (car rest))))\n          (if (< a best-a)\n              (loop (cdr rest) (car rest) a)\n              (loop (cdr rest) best best-a))))))\n(closest-to '(1 0 0) (list '(1 1 0) '(0 1 0) '(1 0 1)))" :note "Find the candidate with smallest angle to target — direction snapping. Returns the first one that ties (both (1 1 0) and (1 0 1) are 45° off).")
    (:dialect "motoi" :tier "master" :code "(define (angle-classify a b)\n  (let ((theta (vec/angle-between a b)))\n    (cond ((< theta 0.001)                'parallel)\n          ((< (abs (- theta 1.5708)) 0.001) 'perpendicular)\n          ((< (abs (- theta 3.14159)) 0.001) 'anti-parallel)\n          ((< theta 1.5708)               'acute)\n          (else                            'obtuse))))\n(list (angle-classify '(1 0) '(1 0))\n      (angle-classify '(1 0) '(0 1))\n      (angle-classify '(1 0) '(-1 0))\n      (angle-classify '(1 0) '(1 1)))" :note "Named regions with epsilon tolerance. Returns (parallel perpendicular anti-parallel acute) — the four archetypal cases.")
  )
  :math (:total #t :domain "two vectors of matching dimension" :codomain "real in [0, π]")
  :cs (:complexity "time O(d), space O(1)" :effects (none) :pure #t)
  :ai (:deterministic #t :cacheable #t :cardinality one :common-mistakes "Passing zero vectors — the impl returns 0 rather than raising; a common source of silent bugs.")
  :caveats ("Dimension mismatch halts with 'dim-mismatch; ensure vectors have equal size." "Zero vectors cause division by zero, yielding NaN." "Floating-point rounding in dot product and norms can introduce small errors; angles near 0 or π are most sensitive." "The result is always in [0, π]; use vec/dot or geom/atan2 to distinguish opposite directions if needed.")
  :drawbacks ("Slower than direct dot-product tests (e.g., dot ≈ 0 for perpendicularity); use vec/dot first for filtering." "acos is computationally expensive; avoid calling repeatedly in tight loops without caching." "Returns NaN (not an error) for zero vectors, making silent bugs possible.")
  :usecases ("Robotics: measuring angular deviation between desired and actual heading vectors." "Computer vision: finding the closest-aligned feature vector in a set." "Geometry: classifying angle relationships (acute, right, obtuse) for constraints.")
  :related ("vec/dot" "vec/norm" "vec/normalize" "vec/cross" "geom/angle-between" "const/pi")
  :learn (:concept "Geometric angle measurement via the dot product and arccosine." :prerequisites ("vec/dot" "vec/norm" "geom/->radians") :progression "After vec/angle-between, learn vec/cross for 3-D orientation and geom/law-of-cosines-angle for triangle geometry.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "An AI-controlled ship must turn toward a waypoint; the pilot logic needs the angular deviation between current heading and target-direction vectors to decide turn direction."
     :program "(define heading '(1 0))\n(define target-dir '(0.7 0.7))\n(define theta (vec/angle-between heading target-dir))\ntheta"
     :explanation "Two 2-D unit-ish vectors are passed in; the returned scalar is the unsigned angle between them in radians. For the given inputs, theta ≈ 0.785 (π/4, a 45° turn). The pilot then uses vec/cross sign to decide clockwise vs counterclockwise."
     :meta "vec/angle-between is the operator's answer for magnitude of deviation. A sibling like vec/dot alone gives a signed alignment scalar but not an angle in radians. Under audit we want a value the pilot code understands universally (radians).")
    (:eng "Log line 'turn-error = 0.785 rad' is human-legible and unit-labeled."
     :math "Formula: arccos(a·b / (|a||b|))."
     :cs "Two dot products plus sqrt plus acos; O(d) in dimension."))
  :row-3-dimension (
    (:setup "Alignment measurement: how far apart in orientation are two directions in a space?"
     :rungs (
       (:domain "vec" :code "(vec/angle-between '(1 0) '(0 1))  ;; π/2")
       (:domain "signal similarity" :code "cosine-similarity of two feature vectors — same acos-of-normalized-dot")
       (:domain "inner product space" :code "θ = arccos(⟨u,v⟩/(‖u‖‖v‖))"))
     :explanation "Rung 1 measures a geometric angle. Rung 2 is cosine similarity in ML — the same formula measuring 'how alike are these vectors' at unit magnitude. Rung 3 is the general inner-product-space definition."
     :meta "Shape transfers wherever an inner product and a norm exist; angle is the invariant those two build together.")
    (:eng "Recommender systems use this shape via cosine similarity to rank items."
     :math "Inner-product-space geometry; see book-of-math ch on inner products."
     :cs "In high dimensions, cosine similarity is preferred over Euclidean; same verb, different framing."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "vec/angle-between is symmetric: swapping arguments does not change the angle."
     :program "(define a '(1 2 3))\n(define b '(4 5 6))\n(equal? (vec/angle-between a b) (vec/angle-between b a))"
     :invariant "∀ a b ∈ R^d \\ {0}.  vec/angle-between(a, b) = vec/angle-between(b, a)"
     :meta "Symmetry falls out of commutativity of vec/dot in the numerator. Falsifier: any pair where swap yields a different angle — would indicate a bug in argument ordering. Pattern-name: symmetric binary function. See book-of-math ch on inner-product properties.")
    (:eng "Symmetry means the pilot can pass heading-first or target-first without changing the log value."
     :math "Follows from a·b = b·a."
     :cs "Bit-for-bit under exact rationals; under floats, holds within ULP of each dot-product computation."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "vec/angle-between returns the unsigned angle in [0, π] between two vectors."
     :composition "(define waypoints (list '(1 0) '(1 1) '(0 1) '(-1 1)))\n(define (pairwise-angles vs)\n  (let loop ((rest (cdr vs)) (prev (car vs)) (acc '()))\n    (if (null? rest) (reverse acc)\n        (loop (cdr rest) (car rest) (cons (vec/angle-between prev (car rest)) acc)))))\n(pairwise-angles waypoints)"
     :emergent "turn-sequence / heading-schedule — a list of successive turn angles emerges from mapping vec/angle-between across adjacent waypoints."
     :meta "Family: adjacent-pair reduce, same pattern as computing a route's total distance or a signal's zero-crossings. See book-of-composition ch on sliding-window operations.")
    (:eng "Path planners use this chain to precompute per-segment turn costs."
     :math "Discrete curvature approximation on a polyline."
     :cs "Sliding-window fold; runtime O(n·d) for n waypoints of dimension d.")))

(verb
  :name "vec/cross"
  :library "vec"
  :kind "meta"
  :signature "(vec/cross a b) -> vector"
  :summary "Compute the 3-D cross product a × b."
  :explanation "Returns a new 3-D vector perpendicular to both input vectors, with magnitude equal to the area of the parallelogram they span. The direction follows the right-hand rule. Both inputs must be exactly 3-dimensional; other dimensions yield 'dim-3-required error. The result is exact for rational inputs but subject to floating-point rounding for reals."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define x-axis (vec/make (list 1 0 0)))\n(define y-axis (vec/make (list 0 1 0)))\n(vec/cross x-axis y-axis)" :note "Standard basis vectors; result is (0, 0, 1) (the z-axis).")
    (:dialect "motoi" :tier "intermediate" :code "(define a (vec/make (list 1 2 3)))\n(define b (vec/make (list 4 5 6)))\n(define perp (vec/cross a b))\n(display (list 'perpendicular: (vec/->string perp)\n               'dot-with-a: (vec/dot a perp)\n               'dot-with-b: (vec/dot b perp)))" :note "Computes cross product and verifies orthogonality by checking dot products are zero.")
    (:dialect "motoi" :tier "expert" :code "(define (triangle-normal p1 p2 p3)\n  (vec/cross (vec/- p2 p1) (vec/- p3 p1)))\n(define (triangle-area p1 p2 p3)\n  (/ (vec/norm (triangle-normal p1 p2 p3)) 2))\n(let ((v0 (vec/make (list 0 0 0)))\n      (v1 (vec/make (list 1 0 0)))\n      (v2 (vec/make (list 0 1 0))))\n  (triangle-area v0 v1 v2))" :note "Uses cross product to compute a triangle's surface normal and area—standard in 3-D graphics.")
  )
  :caveats ("Input dimension must be exactly 3; 2-D or 4-D vectors raise 'dim-3-required." "Cross product is not commutative: a × b = -(b × a)." "For nearly parallel vectors, the result has very small magnitude and is numerically unstable." "The cross product is a 3-D concept; there is no generalization to other dimensions in this library.")
  :drawbacks ("Only works in 3-D; for 2-D, compute the scalar (pseudo) cross product using vec/dot indirectly or use geom/cross." "Slower than vec/dot; avoid in inner loops if a scalar test (like orientation) suffices." "Result magnitude grows as the sine of the angle; nearly parallel vectors give unreliable normals for graphics.")
  :usecases ("3-D graphics: computing surface normals for lighting calculations." "Robotics: finding the axis of rotation between two end-effector directions." "Computational geometry: determining the orientation (handedness) of point triples.")
  :related ("vec/dot" "vec/norm" "vec/normalize" "vec/angle-between" "geom/cross")
  :learn (:concept "The cross product and its right-hand-rule orientation in 3-D space." :prerequisites ("vec/make" "vec/dot" "vec/-") :progression "Master vec/cross before diving into matrix transformations (linalg/* verbs) or 3-D graphics (entity/* spatial verbs).")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A 3-D graphics pipeline needs the surface normal of a triangle formed by three vertices, so lighting can shade the face."
     :program "(define v0 '(0 0 0))\n(define v1 '(1 0 0))\n(define v2 '(0 1 0))\n(define normal (vec/cross (vec/- v1 v0) (vec/- v2 v0)))\nnormal"
     :explanation "Two edge vectors are formed via vec/- from vertex 0 to vertices 1 and 2. vec/cross returns their perpendicular — here (0 0 1), the upward normal. The magnitude equals twice the triangle's area (parallelogram)."
     :meta "vec/cross is the honest verb; a scalar dot won't give a perpendicular direction. Under audit, the log line 'normal = (0 0 1)' proves the face's orientation before lighting math runs.")
    (:eng "Face-culling and back-face-hiding pipelines log normals to explain visibility decisions."
     :math "Result is orthogonal to both inputs and has magnitude |a||b|sin(θ)."
     :cs "O(1) — nine multiplies and three subtracts; strict 3-D input."))
  :row-3-dimension (
    (:setup "Perpendicular-from-two: given two directions, produce a third direction orthogonal to both."
     :rungs (
       (:domain "vec" :code "(vec/cross '(1 0 0) '(0 1 0))  ;; (0 0 1)")
       (:domain "physics angular momentum" :code "L = r × p in classical mechanics")
       (:domain "exterior algebra" :code "wedge product a ∧ b in 3-D returns a bivector representable as a vector"))
     :explanation "Rung 1 gives a coordinate cross product. Rung 2 is angular momentum, physically the same shape — position × momentum yields a perpendicular vector to their plane. Rung 3 is the abstract wedge; the cross product is a 3-D special case."
     :meta "The shape transfers wherever a 3-D oriented plane needs a canonical normal.")
    (:eng "Rigid-body physics engines use this shape at every timestep to update angular momentum."
     :math "Wedge product in exterior algebra; see book-of-math ch on multilinear algebra."
     :cs "Cross is a bilinear alternating operation — a special-case of a general skew-symmetric bilinear form."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "vec/cross is anti-commutative: swapping arguments negates the result."
     :program "(define a '(1 2 3))\n(define b '(4 5 6))\n(equal? (vec/cross a b) (map - (vec/cross b a)))"
     :invariant "∀ a b ∈ R^3.  vec/cross(a, b) = − vec/cross(b, a)"
     :meta "Anti-commutativity encodes right-hand-rule orientation; falsifier: any pair where swap gives an equal (not negated) result — indicates the impl silently commuted. Pattern-name: skew-symmetric bilinear map. See book-of-math ch on alternating forms.")
    (:eng "Anti-commutativity is what lets one canonical normal per triangle be defined (choose vertex order = choose which way normal points)."
     :math "Follows from the determinant definition; det with two rows swapped negates."
     :cs "Zero-vector self-cross: a × a = 0 — a corollary that's a strong sanity test."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "vec/cross returns a vector perpendicular to two given 3-D vectors, with magnitude equal to their parallelogram area."
     :composition "(define (triangle-area p1 p2 p3)\n  (let ((n (vec/cross (vec/- p2 p1) (vec/- p3 p1))))\n    (/ (sqrt (+ (* (car n) (car n)) (* (cadr n) (cadr n)) (* (caddr n) (caddr n)))) 2)))\n(triangle-area '(0 0 0) '(3 0 0) '(0 4 0))"
     :emergent "area-of-triangle — a geometric measurement emerges from vec/cross + vec/- + norm/half."
     :meta "Family: derived-geometry-from-orientation, same pattern as the Shoelace formula for polygon area. See book-of-composition ch on emergent measurement.")
    (:eng "Mesh statistics (total surface area, per-face area) fold this chain over triangle lists."
     :math "Half-magnitude of cross product equals triangle area."
     :cs "O(1) per triangle; folded O(n) over n triangles.")))

(verb
  :name "vec/dim"
  :library "vec"
  :kind "meta"
  :signature "(vec/dim v) -> number"
  :summary "Return the dimension (component count) of a vector."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Length lookup on the underlying list. Non-list inputs coerce to a 1-element list (dim 1); the empty list gives 0."
  :explanation "Returns the number of components in the vector as a non-negative integer. A vector with components [a, b, c] has dimension 3. This is O(1) introspection that does not modify the vector. Essential for dimension-polymorphic code and for validation before vec/+ that require matching dimensions."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/dim '(1 2 3 4))" :note "A 4-component vector. Returns 4.")
    (:dialect "motoi" :tier "apprentice" :code "(vec/dim '())" :note "Empty list has dimension 0. Valid, if uncommon — often signals an intermediate calculation ran out of components.")
    (:dialect "motoi" :tier "intermediate" :code "(define (same-size? u v)\n  (= (vec/dim u) (vec/dim v)))\n(list (same-size? '(1 2 3) '(4 5 6)) (same-size? '(1 2) '(1 2 3)))" :note "Predicate for pre-checking vec/+ compatibility. Returns (#t #f).")
    (:dialect "motoi" :tier "expert" :code "(define (safe-vec-op u v op)\n  (if (= (vec/dim u) (vec/dim v))\n      (op u v)\n      'dim-mismatch))\n(list (safe-vec-op '(1 2 3) '(4 5 6) vec/+)\n      (safe-vec-op '(1 2) '(1 2 3) vec/+))" :note "Guarded op: apply only when dims agree, else return the sentinel. Returns ((5 7 9) dim-mismatch).")
    (:dialect "motoi" :tier "master" :code "(define (all-same-dim? vecs)\n  (cond ((null? vecs) #t)\n        (else\n         (let ((d (vec/dim (car vecs))))\n           (let loop ((rest (cdr vecs)))\n             (cond ((null? rest) #t)\n                   ((= (vec/dim (car rest)) d) (loop (cdr rest)))\n                   (else #f)))))))\n(list (all-same-dim? (list '(1 0) '(0 1) '(1 1)))\n      (all-same-dim? (list '(1 2 3) '(4 5))))" :note "Validate a whole batch: only proceed with (vec/+) or its friends if every vector in the list has matching dim. Returns (#t #f).")
  )
  :caveats ("Returns the logical dimension; an empty vector (dimension 0) is valid but uncommon." "Dimension is immutable once the vector is constructed; you cannot resize a vector in place." "Two vectors with the same dimension may still fail operations like vec/cross if dimension ≠ 3.")
  :drawbacks ("Not necessary for vectors created and used inline; useful mainly for validation in polymorphic contexts." "Should not be called in tight loops if you already know the dimension; cache it instead.")
  :usecases ("Validation: checking that incoming vectors match expected shape before computation." "Polymorphism: writing functions that work across vectors of any dimension (2-D, 3-D, n-D)." "Serialization: recording metadata about a vector for later reconstruction.")
  :related ("vec/make" "vec/ref" "vec/->string" "matrix/rows" "matrix/cols")
  :learn (:concept "Dimension as a fundamental property of a vector and a guard for operation composition." :prerequisites ("vec/make") :progression "Use vec/dim in guards before calling vec/+ or vec/cross; learn it early as a safety tool.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A polymorphic 'clamp-to-box' helper accepts vectors of any dimension; the operator must guard vec/cross calls to only 3-D inputs."
     :program "(define (safe-cross a b)\n  (if (and (= (vec/dim a) 3) (= (vec/dim b) 3))\n      (vec/cross a b)\n      'dim-error))\n(list (safe-cross '(1 2 3) '(4 5 6)) (safe-cross '(1 2) '(3 4)))"
     :explanation "vec/dim reads the length of each vector; the guard rejects non-3-D inputs before vec/cross would raise. The result: valid cross for 3-D pair, 'dim-error sentinel for 2-D pair."
     :meta "vec/dim is the audit-preferred sibling of raw length because it announces intent: 'I am asking about a vector's dimension'. A raw length would work but obscures the domain.")
    (:eng "Audit-friendly guards make dim-mismatch bugs visible before they blow up in cross/dot."
     :math "Dimension is a scalar invariant of the vector; determined at construction."
     :cs "O(1) list-length lookup."))
  :row-3-dimension (
    (:setup "Shape query: asking a compound value 'how big are you?' without touching contents."
     :rungs (
       (:domain "vec" :code "(vec/dim '(1 2 3))  ;; 3")
       (:domain "matrix" :code "(matrix/rows M)  ;; how tall is this matrix")
       (:domain "type-level" :code "In type theory: the length parameter of a length-indexed vector type Vec n a"))
     :explanation "Rung 1 is vector dimension. Rung 2 is matrix row count — the same 'how many' query on a different container. Rung 3 is the general concept of a size parameter attached to a container type."
     :meta "Shape transfers because every compound-shaped value has a natural size query.")
    (:eng "Shape-query verbs are the first line of defense in typed data pipelines."
     :math "Cardinality of an indexed family; see book-of-math ch on set cardinality."
     :cs "Size queries are O(1) for arrays, O(n) worst case for lists — but Motoi caches dimension at construction."))
  :row-4-proof (
    (:claim "vec/dim is invariant under vec/+, vec/-, and vec/scale: dimension of the result equals dimension of the input."
     :program "(define v '(1 2 3))\n(and (= (vec/dim v) (vec/dim (vec/scale v 5)))\n     (= (vec/dim v) (vec/dim (vec/+ v v))))"
     :invariant "∀ v ∈ R^d, k ∈ R.  vec/dim(v) = vec/dim(vec/scale(v, k)) = vec/dim(vec/+(v, v))"
     :meta "Dimension preservation is what makes shape-check-once-then-compute safe. Falsifier: any op that silently reshapes. Pattern-name: shape-preserving morphism. See book-of-math ch on preserving invariants.")
    (:eng "Preserved dimension means shape-checks amortize across long chains of ops."
     :math "The verbs vec/+, vec/-, vec/scale all live in the endomorphism monoid on R^d."
     :cs "Static-shape typing systems bake this invariant into types (e.g., Haskell's Vec n a)."))
  :row-5-emergence (
    (:base "vec/dim returns the number of components in a vector."
     :composition "(define (align-vectors vs)\n  (let ((max-d (apply max (map vec/dim vs))))\n    (map (lambda (v)\n           (let loop ((i 0) (acc '()))\n             (if (= i max-d) (reverse acc)\n                 (loop (+ i 1) (cons (if (< i (vec/dim v)) (list-ref v i) 0) acc)))))\n         vs)))\n(align-vectors (list '(1 2) '(3 4 5) '(6)))"
     :emergent "shape-aligner / zero-padder — a batch-preprocessing step emerges from vec/dim + max + iota."
     :meta "Family: pre-alignment before uniform op, same pattern as NumPy broadcasting or SQL COALESCE-to-shape. See book-of-composition ch on prepare-then-apply.")
    (:eng "ML feature-vector batching relies on this shape."
     :math "Padding to a common dimension embeds smaller vectors into a larger space by zero-augmentation."
     :cs "The pattern is a common preprocessing step in tensor-computing libs.")))

(verb
  :name "vec/dot"
  :library "vec"
  :kind "meta"
  :signature "(vec/dot a b) -> number"
  :summary "Compute the dot product a·b (a scalar)."
  :explanation "Returns the sum of component-wise products: a·b = Σ(aᵢ × bᵢ). The result is a scalar (single number), not a vector. Both inputs must have identical dimension; dimension mismatch yields 'dim-mismatch. The dot product measures alignment: positive (< 90°), zero (perpendicular), or negative (> 90°). It is the foundation for projections, angles, and norms."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define u (vec/make (list 1 2)))\n(define v (vec/make (list 3 4)))\n(vec/dot u v)" :note "Computes 1*3 + 2*4 = 11.")
    (:dialect "motoi" :tier "intermediate" :code "(define a (vec/make (list 1 0 0)))\n(define b (vec/make (list 1 1 1)))\n(define projection-scale (/ (vec/dot a b) (vec/dot a a)))\n(vec/scale projection-scale a)" :note "Uses dot product to project vector b onto vector a.")
    (:dialect "motoi" :tier "expert" :code "(define (gram-matrix vecs)\n  (map (lambda (u)\n         (map (lambda (v) (vec/dot u v)) vecs))\n       vecs))\n(let ((basis (list (vec/make (list 1 0))\n                   (vec/make (list 0 1)))))\n  (gram-matrix basis))" :note "Constructs the Gram matrix (all pairwise dot products) of a set of vectors—used in linear independence checks.")
  )
  :caveats ("Dimension must match exactly; no broadcasting or zero-padding." "Returns 'dim-mismatch (not an error exception) on dimension mismatch." "Floating-point rounding accumulates in the sum; for high-dimensional vectors, consider Kahan summation if precision is critical." "Dot product with zero vector is always 0, making it unsuitable for distinguishing orthogonality in degenerate cases.")
  :drawbacks ("O(n) in dimension, so very high-dimensional vectors are slow to dot-product." "Not suitable as the sole test for perpendicularity (use vec/angle-between or tolerance-based checks)." "Result can overflow or underflow for very large or very small component values.")
  :usecases ("Linear algebra: computing projections, orthogonal decompositions, and inner products." "Physics: calculating work (force · displacement) or power in simulations." "Machine learning: computing similarities and distances between feature vectors.")
  :related ("vec/+" "vec/-" "vec/scale" "vec/norm" "vec/angle-between" "vec/cross")
  :learn (:concept "The dot product as a measure of alignment and the foundation of inner product spaces." :prerequisites ("vec/make" "+ (core form)") :progression "Master vec/dot before vec/norm (which uses dot internally) and vec/angle-between.")
  :row-2-audit (
    (:problem "A physics tick computes work done by a force on a moving body: work = F·d, where F is the force vector and d is the displacement over the tick."
     :program "(define F '(5 0 0))\n(define d '(3 4 0))\n(define work (vec/dot F d))\nwork"
     :explanation "vec/dot pair-multiplies components and sums: 5·3 + 0·4 + 0·0 = 15. That scalar is the mechanical work in joules if F is newtons and d meters."
     :meta "vec/dot is the honest answer for 'scalar-projection into a direction'. A sibling vec/cross returns a vector (wrong shape for work). Under audit, 'work = 15 J' is unit-correct.")
    (:eng "Physics logs 'work-per-tick = 15' — a single scalar per body, cheap to store."
     :math "Bilinear symmetric form: ⟨u, v⟩ = Σ u_i v_i."
     :cs "O(d) pair-multiply-and-sum."))
  :row-3-dimension (
    (:setup "Alignment scalar: pair-multiply-and-sum captures 'how much of one thing points along another'."
     :rungs (
       (:domain "vec" :code "(vec/dot '(1 2 3) '(4 5 6))  ;; 32")
       (:domain "signal correlation" :code "Σ x[n]·y[n] — correlation of two discrete signals")
       (:domain "inner-product space" :code "⟨u, v⟩ = Σ conj(u_i) v_i — general Hilbert-space form"))
     :explanation "Rung 1 is coordinate dot. Rung 2 is signal correlation — the same sum for time-series alignment. Rung 3 is the abstract Hermitian inner product; the real-valued dot is a special case."
     :meta "Shape transfers wherever you want a scalar measuring 'similarity' or 'projection'.")
    (:eng "Filter matched-filter detection uses this shape in DSP."
     :math "Bilinear positive-definite form — see book-of-math ch on inner-product spaces."
     :cs "In ML this becomes 'cosine similarity' after normalization; same primitive."))
  :row-4-proof (
    (:claim "vec/dot is commutative (symmetric bilinear form): u·v = v·u."
     :program "(define u '(1 2 3))\n(define v '(4 5 6))\n(= (vec/dot u v) (vec/dot v u))"
     :invariant "∀ u v ∈ R^d.  vec/dot(u, v) = vec/dot(v, u)"
     :meta "Symmetry falls out of commutativity of × on numbers. Falsifier: any pair where swap gives a different value. Pattern-name: symmetric bilinear form. See book-of-math ch on inner products.")
    (:eng "Symmetric semantics means work = F·d = d·F; caller need not remember order."
     :math "Symmetric bilinear form on R^d."
     :cs "Bitwise-equal under exact arithmetic; under floats, sum-reordering ULPs may drift."))
  :row-5-emergence (
    (:base "vec/dot pair-multiplies components and sums to a scalar."
     :composition "(define (project a u)\n  (let* ((k (/ (vec/dot a u) (vec/dot u u))))\n    (vec/scale u k)))\n(project '(3 4) '(1 0))"
     :emergent "vector-onto-line projection — a geometric projection emerges from two vec/dot calls plus vec/scale."
     :meta "Family: projection formula = (⟨a,u⟩/⟨u,u⟩)·u, foundational for Gram-Schmidt and least-squares. See book-of-composition ch on projection composition; book-of-ml ch on regression normal equations.")
    (:eng "Least-squares fits every day in regression pipelines chain this pattern."
     :math "The linear-algebra projection formula onto a line spanned by u."
     :cs "Two O(d) dot products and one O(d) scale = O(d) total.")))

(verb
  :name "vec/make"
  :library "vec"
  :kind "meta"
  :signature "(vec/make lst) -> vector"
  :summary "Construct a vector from a list of components."
  :explanation "Takes a Scheme list of numbers and returns a new vector object. Non-numeric elements yield 'nan. The order of elements in the list becomes the order of components in the vector. Lists are the standard way to bootstrap vectors in Motoi Scheme; once created, vectors are accessed via vec/ref (by index) or composed with arithmetic operators. This is the entry point for all vector operations."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/make (list 3 4))" :note "Creates a 2-D vector with components [3, 4].")
    (:dialect "motoi" :tier "intermediate" :code "(define coords (list 1 2 3))\n(define v (vec/make coords))\n(vec/dot v v)" :note "Constructs a 3-D vector from a list and computes its squared norm (vec/dot v v = ‖v‖²).")
    (:dialect "motoi" :tier "expert" :code "(define (every pred xs)\n  (let loop ((xs xs))\n    (cond ((null? xs) #t) ((not (pred (car xs))) #f) (else (loop (cdr xs))))))\n(define (list->vec-safe lst)\n  (if (every number? lst)\n    (vec/make lst)\n    (escalate 'non-numeric-element lst)))\n(define (batch-normalize vecs)\n  (map (lambda (lst)\n         (let ((v (list->vec-safe lst)))\n           (vec/normalize v)))\n       vecs))\n(batch-normalize (list (list 3 4) (list 1 0 0)))" :note "Wraps vec/make in validation logic and uses it to normalize a batch of vector-like lists.")
  )
  :caveats ("Input must be a proper list; improper lists (dotted pairs) are rejected." "Non-numeric elements are detected and yield 'nan; no partial construction." "An empty list creates a vector of dimension 0, which is valid but uncommon and can cause issues in dot products." "Once created, the internal structure cannot be modified; vectors are immutable.")
  :drawbacks ("O(n) construction time in dimension n; creating many high-dimensional vectors is slow." "No lazy or streaming construction; the entire list is consumed at once." "If a list is reused after vec/make, changes to the list do not affect the vector (deep copy semantics).")
  :usecases ("Initialization: bootstrap vectors from user input, file data, or computed lists." "Scripting: quick vector creation in REPL or test code." "Interoperability: convert list-based data formats to vectors for linear algebra.")
  :related ("vec/ref" "vec/dim" "vec/->string" "vec/+" "list (core form)" "matrix/make")
  :learn (:concept "Vector construction from lists and the transition from list-based to vector-based arithmetic." :prerequisites ("list (core form)" "number? (core form)") :progression "After vec/make, learn vec/ref (to access components) and vec/+ (to compose vectors).")
  :row-2-audit (
    (:problem "A csv-like file yields rows of numbers; the operator needs to promote each row into a vector object so downstream vec/* verbs work uniformly."
     :program "(define rows (list (list 3 4) (list 1 2 3) (list 5)))\n(define vs (map vec/make rows))\nvs"
     :explanation "map applies vec/make to each row-list. Each returned value is a vector ready for vec/+, vec/dot, etc. The three vectors have dimensions 2, 3, 1."
     :meta "vec/make is the audit constructor — it establishes the domain object. Passing raw lists directly to vec/+ works by coincidence today, but future guards may enforce vec/make.")
    (:eng "Explicit construction shows in logs what was promoted from list to vector."
     :math "Injection from lists into R^d."
     :cs "O(d) — walks the input list."))
  :row-3-dimension (
    (:setup "Value-lifting: turning a raw representation into a domain object."
     :rungs (
       (:domain "vec" :code "(vec/make (list 3 4))  ;; vector (3 4)")
       (:domain "matrix" :code "(matrix/make '((1 2)(3 4)))  ;; matrix from list-of-rows")
       (:domain "smart constructor" :code "In OOP: `new Vec2(3, 4)` — same shape at a different syntax level"))
     :explanation "Rung 1 lifts a list to a vector. Rung 2 lifts nested lists to a matrix. Rung 3 is the general smart-constructor pattern: a function that produces a validated domain object."
     :meta "Shape transfers because every domain has 'lift raw data into typed object'.")
    (:eng "Constructors are the boundary where invariants become enforced."
     :math "Function from the input alphabet to the target codomain, with validation."
     :cs "Smart-constructor pattern is a core discipline in typed FP."))
  :row-4-proof (
    (:claim "vec/make preserves length: dim of the constructed vector equals length of the input list."
     :program "(define lst '(1 2 3 4 5))\n(= (vec/dim (vec/make lst)) (length lst))"
     :invariant "∀ lst ∈ list.  vec/dim(vec/make(lst)) = length(lst)"
     :meta "Length preservation is the constructor's contract. Falsifier: any list where the produced vector's dim differs — indicates the constructor silently truncated. Pattern-name: shape-preserving lift. See book-of-math ch on injective functions.")
    (:eng "Assertion 'dim = length' before vec/make and after must match; automated tests can gate."
     :math "The constructor is a bijection between lists of length n and vectors of dimension n."
     :cs "Constructor bijections are what make round-tripping (list → vec → list) sound."))
  :row-5-emergence (
    (:base "vec/make lifts a list of numbers into a vector object."
     :composition "(define raw-samples '((1 2) (3 4) (5 6)))\n(define (fold-left f init xs) (if (null? xs) init (fold-left f (f init (car xs)) (cdr xs))))\n(define centroid\n  (let* ((vecs (map vec/make raw-samples))\n         (sum (fold-left vec/+ '(0 0) vecs))\n         (n (length vecs)))\n    (list (/ (car sum) n) (/ (cadr sum) n))))\ncentroid"
     :emergent "batch-preprocess-then-summarize — a small ETL pipeline emerges from vec/make + vec/+ + division."
     :meta "Family: lift-then-fold, the standard functional-batch-pipeline. Analog: map-then-reduce in Spark. See book-of-composition ch on ETL patterns.")
    (:eng "Data-import scripts use this shape every time."
     :math "map ∘ vec/+ ∘ scale is a linear estimator of the mean."
     :cs "Batching: map is embarrassingly parallel; fold is associative and hence tree-reducible.")))

(verb
  :name "vec/norm"
  :library "vec"
  :kind "meta"
  :signature "(vec/norm v) -> number"
  :summary "Compute the Euclidean length (magnitude) ‖v‖ = √(v·v)."
  :explanation "Returns the Euclidean norm of a vector as a non-negative real number. Computed as the square root of the dot product of the vector with itself: ‖v‖ = √(Σ vᵢ²). For a 2-D vector [3, 4], the norm is 5. The norm is always non-negative and is zero only for the zero vector. It is used to measure distance, normalize vectors, and compute vector magnitude."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define v (vec/make (list 3 4)))\n(vec/norm v)" :note "A 2-D vector; norm is √(9+16) = 5.")
    (:dialect "motoi" :tier "intermediate" :code "(define v (vec/make (list 1 2 2)))\n(define n (vec/norm v))\n(define unit-v (vec/scale (/ 1 n) v))\n(vec/norm unit-v)" :note "Computes the norm, then manually normalizes by scaling, then verifies the result has norm 1.")
    (:dialect "motoi" :tier "expert" :code "(define (distance u v)\n  (vec/norm (vec/- u v)))\n(define (within-tolerance? p1 p2 tol)\n  (< (distance p1 p2) tol))\n(let ((target (vec/make (list 1.0 1.0)))\n      (candidate (vec/make (list 1.01 0.99))))\n  (within-tolerance? target candidate 0.02))" :note "Uses vec/norm to compute Euclidean distance and implement a tolerance-based comparison for spatial proximity.")
  )
  :caveats ("Floating-point rounding in the dot product and sqrt can introduce errors; for very large or very small components, the result may be inaccurate." "Zero vector has norm 0; division by norm (as in normalization) requires a zero check." "The norm is always non-negative; negative norms are impossible." "High-dimensional vectors accumulate rounding errors in the dot product summation.")
  :drawbacks ("sqrt is computationally expensive; avoid calling vec/norm repeatedly in tight loops. Cache or use vec/dot(v, v) if you only need the squared norm." "Not suitable for sorting or ranking without external criteria; norms alone do not provide a total order on vectors." "Overflow/underflow risk for very large (≫ 1e308) or very small (≪ 1e-308) components.")
  :usecases ("Normalization: computing the magnitude before scaling to unit length (vec/normalize)." "Distance: measuring Euclidean distance between points (distance = ‖p2 - p1‖)." "Magnitude-based filtering: selecting vectors or points that exceed a threshold size.")
  :related ("vec/dot" "vec/normalize" "vec/scale" "vec/angle-between" "geom/distance")
  :learn (:concept "The Euclidean norm as a measure of vector magnitude and the foundation of normalization." :prerequisites ("vec/make" "vec/dot") :progression "After vec/norm, learn vec/normalize (which divides by norm) and use both in distance/similarity calculations.")
  :row-2-audit (
    (:problem "A collision system needs to check whether an entity is within a firing range of the player."
     :program "(define player '(100 100))\n(define enemy '(103 104))\n(define diff (vec/- enemy player))\n(define range (vec/norm diff))\n(if (< range 10) 'in-range 'out-of-range)"
     :explanation "diff is the displacement between entity centers; vec/norm returns its Euclidean length (5.0 here). The predicate then classifies range vs threshold."
     :meta "vec/norm is the audit answer for distance. A sibling like vec/dot(diff, diff) returns squared distance — faster but less human-readable in the log line.")
    (:eng "Log 'range = 5.0' is unit-labeled and comparable to level-design constants."
     :math "Euclidean norm ‖v‖ = sqrt(v·v)."
     :cs "One dot product plus one sqrt; O(d)."))
  :row-3-dimension (
    (:setup "Length/magnitude query: 'how big is this quantity?'"
     :rungs (
       (:domain "vec" :code "(vec/norm '(3 4))  ;; 5")
       (:domain "complex" :code "(complex/modulus (complex/make 3 4))  ;; 5 — same shape on 2 components")
       (:domain "L2 norm" :code "‖v‖_2 = sqrt(Σ v_i²) — one of many norms, this one Euclidean"))
     :explanation "Rung 1 measures a real-vector length. Rung 2 measures a complex number's modulus (same formula on real and imag parts). Rung 3 is the general L2 norm; other norms (L1, L∞) exist but this verb is L2."
     :meta "Shape transfers because norms are the standard 'how big' primitive on any normed space.")
    (:eng "Distance thresholds in game AI, physics, and network reachability all use this shape."
     :math "Any L^p norm satisfies ‖v‖ ≥ 0, ‖v‖ = 0 ⟺ v = 0, triangle inequality; see book-of-math ch on norms."
     :cs "Euclidean norm is O(d); other norms have same big-O but different constants."))
  :row-4-proof (
    (:claim "vec/norm is homogeneous: scaling a vector by k scales its norm by |k|."
     :program "(define v '(3 4))\n(= (vec/norm (vec/scale v 2)) (* 2 (vec/norm v)))"
     :invariant "∀ v ∈ R^d, k ∈ R.  vec/norm(vec/scale(v, k)) = |k| · vec/norm(v)"
     :meta "Homogeneity (positive scalar case here) is one of the three defining norm laws. Falsifier: any v, k where the identity fails beyond ULP tolerance. Pattern-name: 1-homogeneous seminorm. See book-of-math ch on normed vector spaces.")
    (:eng "Scaling laws mean unit conversions in physics compose cleanly with distance calculations."
     :math "The three norm laws: nonnegativity, homogeneity, triangle inequality."
     :cs "Homogeneity holds bitwise for exact rationals; float roundoff at last-place possible."))
  :row-5-emergence (
    (:base "vec/norm returns the Euclidean length of a vector."
     :composition "(define waypoints (list '(0 0) '(3 0) '(3 4) '(0 4)))\n(define (path-length ps)\n  (let loop ((rest (cdr ps)) (prev (car ps)) (acc 0))\n    (if (null? rest) acc\n        (loop (cdr rest) (car rest) (+ acc (vec/norm (vec/- (car rest) prev)))))))\n(path-length waypoints)"
     :emergent "path-length / polyline-arc-length — a total-distance metric emerges from vec/norm + vec/- + sum-fold."
     :meta "Family: sum-of-per-edge, same pattern as total-signal-energy or total-elapsed-time. See book-of-composition ch on cumulative metrics.")
    (:eng "Route planners compute this over navigation meshes."
     :math "Arc length as a discrete approximation to a curve's integral length."
     :cs "Sliding-window fold; O(n·d).")))

(verb
  :name "vec/normalize"
  :library "vec"
  :kind "meta"
  :signature "(vec/normalize v) -> vector"
  :summary "Produce a unit vector in the direction of v; the zero vector returns the symbol 'zero-vector."
  :explanation "Normalization scales a vector to length 1 while preserving its direction. It divides each component by the vector's Euclidean norm ‖v‖. This is essential for creating direction-only quantities in physics, graphics, and navigation. The zero vector cannot be normalized (no direction), so it returns the symbol 'zero-vector rather than raising an error."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define v (list 3 4))\n(vec/normalize v)" :note "Scales (3, 4) with norm 5 to (0.6, 0.8), a unit vector.")
    (:dialect "motoi" :tier "intermediate" :code "(define speed 'speed)\n(define pos-y 'pos-y)\n(define target-y 'target-y)\n(define pos-x 'pos-x)\n(define target-x 'target-x)\n(define direction (vec/normalize (list (- target-x pos-x) (- target-y pos-y))))\n(define velocity (vec/scale direction speed))" :note "Normalize the difference to get a direction, then scale by speed to get a velocity of fixed magnitude.")
    (:dialect "motoi" :tier "expert" :code "(define (aim-at-target entity target-pos)\n  (let* ((delta (list (- (entity/x target-pos) (entity/x entity))\n                      (- (entity/y target-pos) (entity/y entity))))\n         (direction (vec/normalize delta)))\n    (entity/set-vel! entity (vec/scale direction (entity/ref entity 'max-speed)))))" :note "Normalize the vector from entity to target, then apply it as a velocity at max speed, keeping direction exact.")
  )
  :caveats ("Passing a zero vector (all components 0) returns the symbol 'zero-vector; check for this before assuming a valid vector." "Result is deterministic only within device-level floating-point precision; comparing normalized vectors for exact equality will often fail." "The normalized vector has magnitude approximately 1, but not exactly 1 due to rounding.")
  :drawbacks ("Computing the norm (via sqrt) is moderately expensive; if you only need direction comparison, use vec/angle-between instead." "Normalizing a very small vector may lose precision; clip to a minimum magnitude if this is critical." "Does not modify the input vector; if you need in-place normalization, you must rebind the name.")
  :usecases ("Convert a displacement into a direction for movement or aiming." "Create a unit normal for surface reflections or lighting." "Decouple speed from direction in steering or animation." "Standardize vectors before geometric comparison or transformation.")
  :related ("vec/norm" "vec/scale" "vec/angle-between" "vec/dot" "entity/move!")
  :learn (:concept "Unit vectors and normalization as a way to separate direction from magnitude." :prerequisites ("vec/norm" "vec/make" "vec/scale") :progression "After mastering normalization, study vec/angle-between to compare directions without normalizing, and vec/cross for oriented geometry.")
  :row-2-audit (
    (:problem "Steering AI wants to convert a heading-delta (a raw displacement vector) into a pure direction of fixed unit length so speed can be applied separately."
     :program "(define heading-delta '(3 4))\n(define dir (vec/normalize heading-delta))\n(define speed 5)\n(vec/scale dir speed)"
     :explanation "vec/normalize divides each component by the norm, yielding (0.6, 0.8). vec/scale multiplies by speed 5, producing velocity (3, 4) — same direction as the input, but now controlled by explicit speed."
     :meta "vec/normalize is honest because it FACTORS out magnitude, exposing direction as a distinct thing to reason about. A sibling like vec/scale-to-unit alias would be identical but obscures the polar-decomposition intent.")
    (:eng "Steering logs 'dir = (0.6 0.8)' — a unit vector — cleanly separate from speed."
     :math "Normalization = v / ‖v‖."
     :cs "Norm + component-scale; O(d)."))
  :row-3-dimension (
    (:setup "Magnitude-strip: leave only the pure direction, discarding scale."
     :rungs (
       (:domain "vec" :code "(vec/normalize '(3 4))  ;; (0.6 0.8)")
       (:domain "signal envelope" :code "signal / |signal| — pull-out amplitude, keep waveform shape")
       (:domain "projective space P^n" :code "equivalence class of v ∼ kv — direction as a projective point"))
     :explanation "Rung 1 unitizes a vector. Rung 2 normalizes a signal's amplitude, keeping shape. Rung 3 is the projective quotient — treating any two vectors as equal iff they point the same way."
     :meta "Shape transfers wherever magnitude is separable from orientation.")
    (:eng "Audio compressors and image-normalizers use this shape."
     :math "Projective equivalence; see book-of-math ch on projective geometry."
     :cs "Zero-magnitude case is a genuine singularity — Motoi returns 'zero-vector to force a decision."))
  :row-4-proof (
    (:claim "vec/normalize is idempotent (for nonzero vectors): normalizing a unit vector yields the same unit vector."
     :program "(define v (vec/normalize '(3 4)))\n(equal? v (vec/normalize v))"
     :invariant "∀ v ∈ R^d with ‖v‖ > 0.  vec/normalize(vec/normalize(v)) = vec/normalize(v)"
     :meta "Idempotence encodes 'this operation reaches a fixed point after one step'. Falsifier: any v where second normalize drifts more than ULP. Pattern-name: idempotent operator / projection. See book-of-math ch on idempotents.")
    (:eng "Repeated normalize in a loop is safe (won't drift under exact arithmetic)."
     :math "vec/normalize is a retraction onto the unit sphere in R^d."
     :cs "Under floats, second call may drift 1 ULP; safe within tolerance."))
  :row-5-emergence (
    (:base "vec/normalize returns a unit-length vector in the same direction as the input."
     :composition "(define (seek-force pos target max-speed)\n  (let* ((delta (vec/- target pos))\n         (dir (vec/normalize delta)))\n    (vec/scale dir max-speed)))\n(seek-force '(10 10) '(20 20) 5)"
     :emergent "seek-behavior / steering-force — a Reynolds-style AI steering primitive emerges from vec/- + vec/normalize + vec/scale."
     :meta "Family: steering-behavior, same pattern as boids' seek/flee/arrive. Cross-book cite: game-AI classic. See book-of-composition ch on behavior primitives.")
    (:eng "Motoi's ai/steer verbs internally use this exact chain."
     :math "Constant-speed seek: direction · speed."
     :cs "O(d) per invocation; called once per tick per steering entity.")))

(verb
  :name "vec/ref"
  :library "vec"
  :kind "meta"
  :signature "(vec/ref v i) -> number"
  :summary "Extract the i-th component of vector v (0-based indexing)."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Positional lookup on the underlying list. Out-of-range index returns () (empty list), NOT the 'nan symbol earlier docs promised. Guard with (vec/dim v) first if a signaled miss matters."
  :explanation "Vectors in Motoi Scheme are sequences of numeric components. vec/ref provides positional access by index, like car and cdr on lists. Index 0 is the first component, 1 the second, and so on."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/ref '(10 20 30) 0)" :note "First component. Returns 10.")
    (:dialect "motoi" :tier "apprentice" :code "(vec/ref '(10 20 30) 2)" :note "Third component (index 2). Returns 30.")
    (:dialect "motoi" :tier "intermediate" :code "(define center '(320 240))\n(list (vec/ref center 0) (vec/ref center 1))" :note "Extract x and y from a 2-D position vector. Returns (320 240).")
    (:dialect "motoi" :tier "expert" :code "(define (component-wise-op v f)\n  (let loop ((i 0) (result '()))\n    (if (>= i (vec/dim v))\n        (reverse result)\n        (loop (+ i 1)\n              (cons (f (vec/ref v i)) result)))))\n(component-wise-op '(2 3 4) (lambda (x) (* x x)))" :note "Iterate all components using vec/ref and vec/dim to build a new result. Returns (4 9 16) — component squares.")
    (:dialect "motoi" :tier "master" :code "(define (dot-via-ref u v)\n  (let loop ((i 0) (acc 0))\n    (if (>= i (vec/dim u))\n        acc\n        (loop (+ i 1)\n              (+ acc (* (vec/ref u i) (vec/ref v i)))))))\n(dot-via-ref '(1 2 3) '(4 5 6))" :note "Hand-rolled dot product via vec/ref + vec/dim. Returns 32. Prefer the built-in vec/dot in real code; this shows the pattern.")
  )
  :caveats ("Indices are 0-based." "Out-of-range indices return () (empty list), not 'nan or an error. Guard with (vec/dim v) if a signaled miss matters." "vec/ref does not modify the vector; it is read-only.")
  :drawbacks ("For bulk operations (e.g., scaling all components), it is more efficient to use vec/scale, vec/+, or vec/- rather than looping with vec/ref." "No bounds checking exception; relies on the 'nan sentinel, which may hide logic errors if not tested explicitly.")
  :usecases ("Extract a single coordinate (x, y, or z) from a position or velocity vector." "Implement custom component-wise logic not covered by vec/+, vec/-, vec/scale, etc." "Validate or log individual vector components for debugging." "Iterate through vector components in a custom map or fold.")
  :related ("vec/dim" "vec/make" "vec/+" "vec/-" "vec/scale")
  :learn (:concept "Component access and iteration as building blocks for generic vector algorithms." :prerequisites ("vec/make" "vec/dim") :progression "After learning vec/ref, study vec/dim to understand vector size, then explore higher-level operations like vec/scale and vec/dot that combine ref patterns.")
  :row-2-audit (
    (:problem "A frame drawer needs the x and y coordinates of an entity's position to feed sprite/draw!."
     :program "(define pos '(320 240))\n(define x (vec/ref pos 0))\n(define y (vec/ref pos 1))\n(list 'x x 'y y)"
     :explanation "vec/ref returns the i-th component; here index 0 is x and 1 is y. Returned scalars go into a labeled record for the drawer."
     :meta "vec/ref is the audit answer for named-axis access when working with 2-D or 3-D positions. Siblings like car/cadr work but discard the domain intent ('reading a vector coordinate').")
    (:eng "Log 'draw @ (320, 240)' composed from explicit vec/ref calls documents intent."
     :math "Projection onto the i-th basis axis."
     :cs "O(i) list-nth on the underlying list."))
  :row-3-dimension (
    (:setup "Indexed access: reach into a compound value and pull out one piece by position."
     :rungs (
       (:domain "vec" :code "(vec/ref '(10 20 30) 1)  ;; 20")
       (:domain "matrix" :code "(matrix/ref M 0 1)  ;; access row 0, column 1")
       (:domain "projection function" :code "π_i : R^d → R  where  π_i(v) = v_i"))
     :explanation "Rung 1 is vector component access. Rung 2 is matrix cell access — same shape at higher rank. Rung 3 is the projection function π_i, a linear map from R^d to R."
     :meta "Shape transfers wherever a compound has indexable pieces.")
    (:eng "Every log-parser that reads structured records uses indexed access as its bread and butter."
     :math "π_i is a linear functional; see book-of-math ch on dual spaces."
     :cs "Random access is what distinguishes arrays from linked lists (Motoi vectors are lists → O(i))."))
  :row-4-proof (
    (:claim "vec/ref is inverse to vec/make on lists: (vec/ref (vec/make lst) i) = (list-ref lst i)."
     :program "(define lst '(10 20 30 40))\n(and (= (vec/ref (vec/make lst) 0) (list-ref lst 0))\n     (= (vec/ref (vec/make lst) 2) (list-ref lst 2)))"
     :invariant "∀ lst ∈ list, i < length(lst).  vec/ref(vec/make(lst), i) = list-ref(lst, i)"
     :meta "Round-trip preservation: constructor + indexed accessor recover original elements. Falsifier: any index where the values disagree. Pattern-name: bijection with indexed access. See book-of-code ch on data-abstraction laws.")
    (:eng "Round-trip laws mean vec/make is safe to use as a boxing wrapper."
     :math "π_i ∘ vec/make = list-ref at position i — a commutative square."
     :cs "Data-abstraction: the constructor and observer form an adjoint pair."))
  :row-5-emergence (
    (:base "vec/ref returns the i-th component of a vector (0-indexed)."
     :composition "(define (extract-axis vs axis)\n  (map (lambda (v) (vec/ref v axis)) vs))\n(extract-axis (list '(1 2 3) '(4 5 6) '(7 8 9)) 1)"
     :emergent "column-extractor — a per-axis slicing operation emerges from vec/ref mapped over a list of vectors."
     :meta "Family: axial-projection / column-select, same pattern as SQL SELECT ONE-COLUMN or pandas df['x']. See book-of-composition ch on slicing patterns.")
    (:eng "Data analysis extracts axes routinely with this shape."
     :math "Map of a linear functional over a batch."
     :cs "Batch-projection; O(n·i) for n vectors accessing index i.")))

(verb
  :name "vec/scale"
  :library "vec"
  :kind "meta"
  :signature "(vec/scale v k) -> vector"
  :summary "Multiply every component of vector v by scalar k, returning a new vector."
  :explanation "Scaling a vector uniformly (all components by the same factor) is one of the most fundamental operations in linear algebra and physics. It changes magnitude while preserving direction. Scaling by 0 produces the zero vector; scaling by 1 returns an equivalent vector; negative scales reverse direction. This is the bridge between direction (normalized vectors) and magnitude."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define direction (list 1 0))\n(vec/scale direction 50)" :note "Scales the unit vector (1, 0) by 50 to get (50, 0), a magnitude-50 vector pointing right.")
    (:dialect "motoi" :tier "intermediate" :code "(define player 'player)\n(define velocity (list 3 4))\n(define dt 0.016)\n(define displacement (vec/scale velocity dt))\n(entity/move! player displacement)" :note "Multiply a velocity by time delta to get a small displacement per frame.")
    (:dialect "motoi" :tier "expert" :code "(define (physics-step entity dt gravity-scale)\n  (let* ((gravity (list 0 (- (* gravity-scale 9.8))))\n         (accel-this-frame (vec/scale gravity dt))\n         (new-vel (vec/+ (entity/vel entity) accel-this-frame)))\n    (entity/set-vel! entity new-vel)))" :note "Accumulate gravitational acceleration over a time step using vec/scale, composing with vec/+ for realistic motion.")
  )
  :caveats ("Scaling by 0 produces the zero vector, which cannot be normalized later (vec/normalize will return 'zero-vector)." "Scaling by a negative value reverses the vector's direction; check sign if direction matters." "Result is a new vector; the original v is not modified.")
  :drawbacks ("For 2-component or 3-component vectors, manual component multiplication is not significantly faster; use vec/scale for clarity." "Scaling by very large or very small factors may cause floating-point underflow or overflow; clamp magnitudes if needed." "No special handling for NaN or infinity; propagates them as-is.")
  :usecases ("Apply a time delta to a velocity or acceleration to compute displacement." "Adjust the magnitude of a direction vector without changing direction." "Dampen or amplify a force or acceleration in physics simulations." "Implement smooth easing by scaling a delta over time.")
  :related ("vec/normalize" "vec/+" "vec/-" "vec/norm" "entity/set-vel!")
  :learn (:concept "Scalar multiplication as a way to adjust magnitude while preserving direction." :prerequisites ("vec/make" "vec/normalize") :progression "After mastering vec/scale, learn vec/+ and vec/- to combine multiple scaled vectors, then explore vec/dot for projection and vec/cross for orientation.")
  :row-2-audit (
    (:problem "The physics tick converts an acceleration vector (m/s²) into a per-tick velocity delta by multiplying by dt (the tick duration)."
     :program "(define accel '(0 -9.8))\n(define dt 0.016)\n(define dv (vec/scale accel dt))\ndv"
     :explanation "vec/scale multiplies each component by 0.016. Result: (0 -0.1568). Adding dv to current velocity yields the new velocity."
     :meta "vec/scale is the honest operator; it announces 'I am rescaling the whole vector'. A hand-written map (lambda (x) (* x dt)) works but obscures intent.")
    (:eng "Log 'dv/tick = (0 -0.157)' explains why velocity crept in the y direction."
     :math "Scalar multiplication in R^d."
     :cs "O(d) component walk; new list allocated."))
  :row-3-dimension (
    (:setup "Uniform stretch: multiply every piece of a compound value by the same factor."
     :rungs (
       (:domain "vec" :code "(vec/scale '(1 2 3) 10)  ;; (10 20 30)")
       (:domain "audio/gain" :code "waveform · gain — same shape at sample level")
       (:domain "R-module action" :code "k · v where k ∈ R and v ∈ R^d"))
     :explanation "Rung 1 stretches a vector. Rung 2 applies a gain to an audio sample stream — same shape. Rung 3 is the general scalar action of R on any R-module."
     :meta "Shape transfers wherever a scalar can act on a compound uniformly.")
    (:eng "Volume knobs, mixer faders, image brightness sliders — all this shape."
     :math "R-module action; see book-of-math ch on modules and vector spaces."
     :cs "SIMD accelerators exploit this shape (broadcast multiplication)."))
  :row-4-proof (
    (:claim "vec/scale is distributive over vec/+: k·(u + v) = k·u + k·v."
     :program "(define u '(1 2 3))\n(define v '(4 5 6))\n(define k 3)\n(equal? (vec/scale (vec/+ u v) k) (vec/+ (vec/scale u k) (vec/scale v k)))"
     :invariant "∀ u v ∈ R^d, k ∈ R.  vec/scale(vec/+(u, v), k) = vec/+(vec/scale(u, k), vec/scale(v, k))"
     :meta "Distributivity is a defining axiom of a vector space. Falsifier: any triple where lhs ≠ rhs. Pattern-name: bilinear scalar action. See book-of-math ch on vector-space axioms.")
    (:eng "Distributivity means an optimizer can rewrite k·u + k·v as k·(u+v) safely, saving one multiply."
     :math "One of the vector-space axioms."
     :cs "Under floats, both sides may differ by 1 ULP; strict equality only for exact rationals."))
  :row-5-emergence (
    (:base "vec/scale multiplies every component by a scalar k."
     :composition "(define (blend a b t)\n  (vec/+ (vec/scale a (- 1 t)) (vec/scale b t)))\n(blend '(0 0) '(10 10) 0.3)"
     :emergent "linear-interpolation (lerp) — a blending primitive emerges from two vec/scale calls plus vec/+."
     :meta "Family: convex-combination, the shape of vec/lerp, easing, and shader mixing. See book-of-composition ch on combinators; book-of-ml ch on convex combinations.")
    (:eng "Every animation tween and camera-easing uses this three-verb chain."
     :math "Convex combination (1-t)·a + t·b with t ∈ [0,1]."
     :cs "Standard lerp used in graphics; O(d).")))

(verb
  :name "vec/add"
  :library "vec"
  :kind "pure"
  :dialect "motoi"
  :signature "(vec/add a b) -> vector"
  :arity "2"
  :contract "a and b are lists of numbers (treated componentwise; missing components in b coerce to 0)"
  :summary "Componentwise addition of two vectors."
  :doc "Returns a fresh list. Dimension is that of the first argument; missing components in b are taken as 0 (asymmetric — supply matching dimensions to avoid surprises)."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/add '(1 2) '(3 4))" :note "Returns (4 6).")
    (:dialect "motoi" :tier "intermediate" :code "(vec/add '(1 2 3) '(10 10 10))" :note "3-D. Returns (11 12 13).")
    (:dialect "motoi" :tier "expert" :code "(define (translate points offset)\n  (map (lambda (p) (vec/add p offset)) points))\n(translate '((0 0) (1 0) (0 1)) '(5 5))" :note "Translate a set of points by a shared offset. Returns ((5 5) (6 5) (5 6)).")
  )
  :related ("vec/sub" "vec/scale" "vec/lerp" "linalg/vec-add")
  :row-2-audit (
    (:problem "A batch geometry translator applies an offset to a list of polygon vertices; the operator wants a shared displacement added to each point."
     :program "(define pts (list '(0 0) '(1 0) '(1 1) '(0 1)))\n(define offset '(5 5))\n(map (lambda (p) (vec/add p offset)) pts)"
     :explanation "map applies vec/add to each vertex with the shared offset. The result is the translated polygon at ((5 5) (6 5) (6 6) (5 6))."
     :meta "vec/add is the honest verb because 'translation' semantically is point + vector = new point. A sibling like vec/lerp would blend, which is wrong.")
    (:eng "Sprite-atlas translations use this every frame."
     :math "Point-plus-vector = point in affine geometry."
     :cs "Same O(d) as vec/+; exists as a strict binary form."))
  :row-3-dimension (
    (:setup "Combine-with-shared-shift: apply the same offset to every element of a batch."
     :rungs (
       (:domain "vec" :code "(map (lambda (p) (vec/add p '(5 5))) pts)")
       (:domain "date arithmetic" :code "add-days(each date, 7) — shift a batch of dates by one week")
       (:domain "affine translation" :code "T_v(x) = x + v as a group action"))
     :explanation "Rung 1 shifts vectors. Rung 2 shifts dates. Rung 3 is the abstract translation-group action; all three are the same idiom."
     :meta "Shape transfers wherever an additive group acts on a set of elements uniformly.")
    (:eng "Batch shifts are ubiquitous in analytics, UI layout, and animation."
     :math "Group action of the translation subgroup on the affine space."
     :cs "Map is embarrassingly parallel; each vec/add is independent."))
  :row-4-proof (
    (:claim "vec/add is associative when combined into a fold: order of pairwise adds does not affect the final sum."
     :program "(define a '(1 0)) (define b '(0 1)) (define c '(1 1))\n(equal? (vec/add (vec/add a b) c) (vec/add a (vec/add b c)))"
     :invariant "∀ a b c ∈ R^d.  vec/add(vec/add(a, b), c) = vec/add(a, vec/add(b, c))"
     :meta "Associativity is inherited from + on numbers. Falsifier: any triple where reparenthesization changes result beyond ULP. Pattern-name: associative binary op. See book-of-math ch on semigroups.")
    (:eng "Associativity means fold-left and fold-right yield the same result — parallel workers can shard freely."
     :math "Vector addition forms an associative monoid."
     :cs "Under exact rationals, bit-exact; under floats, ULP-level drift possible."))
  :row-5-emergence (
    (:base "vec/add takes two vectors and returns their component-wise sum."
     :composition "(define (fold-left f init xs) (if (null? xs) init (fold-left f (f init (car xs)) (cdr xs))))\n(define (centroid pts)\n  (let ((sum (fold-left vec/add '(0 0) pts))\n        (n (length pts)))\n    (list (/ (car sum) n) (/ (cadr sum) n))))\n(centroid '((0 0) (2 0) (2 2) (0 2)))"
     :emergent "centroid computation — same pattern as vec/+, showing that the alias participates in the same emergent behaviors."
     :meta "Family: fold-reduce-then-scale, the mean/centroid family. See book-of-composition ch on aggregators.")
    (:eng "Centroids power camera-follow logic (average of party positions)."
     :math "Arithmetic mean in R^d."
     :cs "One O(n·d) fold plus O(d) scale.")))

(verb
  :name "vec/sub"
  :library "vec"
  :kind "pure"
  :dialect "motoi"
  :signature "(vec/sub a b) -> vector"
  :arity "2"
  :contract "a and b are lists of numbers → componentwise a - b"
  :summary "Componentwise subtraction of two vectors."
  :doc "Returns a fresh list. Missing components in b are treated as 0. For distance between points, prefer vec/distance which returns a scalar."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/sub '(5 5) '(1 2))" :note "Returns (4 3).")
    (:dialect "motoi" :tier "intermediate" :code "(vec/sub '(10 20 30) '(1 2 3))" :note "3-D. Returns (9 18 27).")
    (:dialect "motoi" :tier "expert" :code "(define (delta from to) (vec/sub to from))\n(delta '(0 0) '(3 4))" :note "Displacement vector from one point to another. Returns (3 4).")
  )
  :related ("vec/add" "vec/distance" "vec/norm")
  :row-2-audit (
    (:problem "A follower entity computes the vector from itself to the leader so the AI can steer along it."
     :program "(define leader '(100 100))\n(define follower '(90 95))\n(define to-leader (vec/sub leader follower))\nto-leader"
     :explanation "vec/sub returns leader − follower = (10 5). This is the 'toward-leader' vector; normalizing it gives a heading direction."
     :meta "vec/sub is honest for 'directed difference'. A sibling like vec/distance would collapse to a scalar, losing direction.")
    (:eng "Log 'to-leader = (10 5)' documents follower AI decisions."
     :math "Point − point = vector in affine space."
     :cs "O(d); binary form of vec/-."))
  :row-3-dimension (
    (:setup "State-to-state arrow: given two states, produce the vector connecting them."
     :rungs (
       (:domain "vec" :code "(vec/sub b a)  ;; the vector from a to b")
       (:domain "time" :code "(- t-end t-start)  ;; duration between events")
       (:domain "affine space" :code "b − a = tangent vector"))
     :explanation "Rung 1: geometric arrow. Rung 2: elapsed time. Rung 3: general affine subtraction."
     :meta "Same as vec/-; this alias-family shares the shape.")
    (:eng "State-arrows appear in every distributed system tracking events between states."
     :math "Affine subtraction; see book-of-math ch on affine spaces."
     :cs "The tangent-vs-point distinction is what makes affine typing possible."))
  :row-4-proof (
    (:claim "vec/sub is the inverse of vec/add on the second slot: (vec/add a (vec/sub b a)) = b."
     :program "(define a '(1 2)) (define b '(4 6))\n(equal? (vec/add a (vec/sub b a)) b)"
     :invariant "∀ a b ∈ R^d.  vec/add(a, vec/sub(b, a)) = b"
     :meta "Round-trip identity — same as vec/-. Falsifier: any pair where the identity fails. Pattern: group inverse. See book-of-math ch on abelian groups.")
    (:eng "Delta-encoding (send only b − a and reconstruct at destination) relies on this identity."
     :math "Group-inverse relation in ⟨R^d, +⟩."
     :cs "Bit-exact under rationals; ULP-close under floats."))
  :row-5-emergence (
    (:base "vec/sub returns the component-wise difference of two vectors."
     :composition "(define (velocity from to dt)\n  (map (lambda (x) (/ x dt)) (vec/sub to from)))\n(velocity '(0 0) '(6 8) 2)"
     :emergent "instantaneous velocity — a rate-of-change primitive emerges from vec/sub + scalar division."
     :meta "Family: finite-difference derivative, the shape of numerical differentiation. See book-of-composition ch on discretized derivatives.")
    (:eng "Motion-capture pipelines compute per-frame velocity with this chain."
     :math "First-order forward-difference approximation to a derivative."
     :cs "O(d) per pair.")))

(verb
  :name "vec/distance"
  :library "vec"
  :kind "pure"
  :dialect "motoi"
  :signature "(vec/distance a b) -> number"
  :arity "2"
  :contract "a and b are same-dimension lists of numbers → nonnegative real"
  :summary "Euclidean distance between two vectors: √(Σ(aᵢ − bᵢ)²)."
  :doc "Alias for vec/dist. Missing components in b coerce to 0. For a squared-distance (avoids the sqrt), compute vec/dot on the difference instead."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/distance '(0 0) '(3 4))" :note "Classic 3-4-5. Returns 5.")
    (:dialect "motoi" :tier "intermediate" :code "(vec/distance '(1 1 1) '(4 5 1))" :note "3-D. Returns 5.")
    (:dialect "motoi" :tier "expert" :code "(define (nearest-of p points)\n  (car (sort points\n              (lambda (a b) (< (vec/distance p a) (vec/distance p b))))))\n(nearest-of '(0 0) '((3 4) (1 1) (5 0)))" :note "Nearest of a candidate set. Returns (1 1) — closest to origin.")
  )
  :related ("vec/norm" "vec/sub" "math/hypot")
  :row-2-audit (
    (:problem "A proximity trigger asks whether the player is close enough to a checkpoint to activate it."
     :program "(define player '(120 84))\n(define checkpoint '(100 80))\n(if (< (vec/distance player checkpoint) 25) 'activate 'wait)"
     :explanation "vec/distance returns 20.4 (sqrt of 400+16). Since 20.4 < 25, the trigger activates."
     :meta "vec/distance is the honest verb for a scalar distance check; sibling vec/norm on (a − b) is equivalent but requires an extra step.")
    (:eng "Trigger logs 'distance = 20.4 : ACTIVATE' — a one-liner audit trail."
     :math "Euclidean distance d(a,b) = sqrt(Σ (a_i − b_i)²)."
     :cs "One vec/sub + one norm; O(d)."))
  :row-3-dimension (
    (:setup "Metric between two states: the scalar 'how far apart'."
     :rungs (
       (:domain "vec" :code "(vec/distance a b)")
       (:domain "clock skew" :code "|t1 − t2|  — distance in time")
       (:domain "metric space" :code "d: X × X → R with nonneg, symmetric, triangle-inequality"))
     :explanation "Rung 1: Euclidean distance. Rung 2: time-distance. Rung 3: general metric-space distance."
     :meta "Shape transfers to every metric space.")
    (:eng "Reachability probes in networked systems use this shape (RTT distance)."
     :math "Metric-space axioms; see book-of-math ch on metric spaces."
     :cs "Different norms give different metrics (L1 Manhattan, L∞ Chebyshev)."))
  :row-4-proof (
    (:claim "vec/distance is symmetric: distance from a to b equals distance from b to a."
     :program "(define a '(3 4)) (define b '(0 0))\n(= (vec/distance a b) (vec/distance b a))"
     :invariant "∀ a b ∈ R^d.  vec/distance(a, b) = vec/distance(b, a)"
     :meta "Symmetry is a metric axiom. Falsifier: any pair where swap gives a different value. Pattern-name: symmetric metric. See book-of-math ch on metric axioms.")
    (:eng "Symmetric distance means order-independence in the trigger-check log."
     :math "One of three metric-space axioms (nonneg, symmetric, triangle)."
     :cs "Bit-exact under rationals; ULP-close under floats."))
  :row-5-emergence (
    (:base "vec/distance returns the Euclidean distance between two vectors."
     :composition "(define (nearest-of query candidates)\n  (let loop ((rest (cdr candidates))\n             (best (car candidates))\n             (best-d (vec/distance query (car candidates))))\n    (if (null? rest) best\n        (let ((d (vec/distance query (car rest))))\n          (if (< d best-d) (loop (cdr rest) (car rest) d)\n              (loop (cdr rest) best best-d))))))\n(nearest-of '(0 0) (list '(3 4) '(1 1) '(5 0)))"
     :emergent "nearest-neighbor / k=1 search — a proximity search emerges from vec/distance + min-reduce."
     :meta "Family: min-by-metric, the shape of k-NN. See book-of-composition ch on search patterns; book-of-ml ch on nearest-neighbor.")
    (:eng "Snap-to-grid, autocomplete, and image retrieval all use this shape."
     :math "argmin over a finite set with a distance function."
     :cs "O(n·d) linear scan; k-d trees would speed to O(log n) average.")))

(verb
  :name "vec/lerp"
  :library "vec"
  :kind "pure"
  :dialect "motoi"
  :signature "(vec/lerp a b t) -> vector"
  :arity "3"
  :contract "a and b are same-dimension lists of numbers, t is a number → componentwise linear interpolation"
  :summary "Linear interpolation between two vectors. At t=0 returns a, at t=1 returns b."
  :doc "Componentwise math/lerp. Missing components in b coerce to 0. Values of t outside [0,1] extrapolate."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/lerp '(0 0) '(10 10) 0.5)" :note "Midpoint of a line. Returns (5 5).")
    (:dialect "motoi" :tier "intermediate" :code "(vec/lerp '(0 0 0) '(100 50 25) 0.2)" :note "20% along a 3-D vector. Returns (20 10 5).")
    (:dialect "motoi" :tier "expert" :code "(define (path-sample p0 p1 n)\n  (map (lambda (i) (vec/lerp p0 p1 (/ i n))) (range 0 (+ n 1))))\n(path-sample '(0 0) '(10 0) 4)" :note "Sample n+1 points along a segment. Returns ((0 0) (2.5 0) (5 0) (7.5 0) (10 0)).")
  )
  :related ("vec/add" "vec/scale" "math/lerp" "motion/lerp")
  :row-2-audit (
    (:problem "A camera animates smoothly from start to end position over a tween's t-parameter [0,1]."
     :program "(define start '(0 0))\n(define end '(100 50))\n(define t 0.4)\n(vec/lerp start end t)"
     :explanation "vec/lerp at t = 0.4 returns (40 20) — 40% along the segment. At t=0 it's start; at t=1 it's end."
     :meta "vec/lerp is the honest verb for parametric position along a segment; splitting into scale+add works but obscures the segment-parametrization intent.")
    (:eng "Tween logs 'camera-t = 0.4, pos = (40 20)' — visible progress."
     :math "Convex combination (1-t)·a + t·b."
     :cs "One vec/scale + one vec/+; O(d)."))
  :row-3-dimension (
    (:setup "Parametric-blend: a scalar t picks a point along a segment or a blend of two values."
     :rungs (
       (:domain "vec" :code "(vec/lerp a b 0.5)  ;; midpoint")
       (:domain "color" :code "color-lerp red blue 0.5  ;; purple")
       (:domain "convex combination" :code "(1-t)·a + t·b"))
     :explanation "Rung 1: vector interpolation. Rung 2: color blending — same convex combination. Rung 3: general convex-combination formula."
     :meta "Shape transfers wherever a linear structure allows parametric blend.")
    (:eng "Every UI transition, cross-fade, and shader mix uses this shape."
     :math "Barycentric coordinates with two points; see book-of-math ch on convex combinations."
     :cs "Foundation of animation systems and interpolation kernels."))
  :row-4-proof (
    (:claim "vec/lerp at t=0 returns start; at t=1 returns end."
     :program "(define a '(1 2))\n(define b '(3 4))\n(and (equal? (vec/lerp a b 0) a) (equal? (vec/lerp a b 1) b))"
     :invariant "∀ a b ∈ R^d.  vec/lerp(a, b, 0) = a  ∧  vec/lerp(a, b, 1) = b"
     :meta "Endpoint identities are the anchor of any interpolation contract. Falsifier: either endpoint failing. Pattern-name: interpolation contract. See book-of-math ch on interpolation.")
    (:eng "Endpoint law is what makes users trust that t=0 means 'start now' and t=1 means 'done'."
     :math "Formally: lerp(a, b, ·) is a path R → R^d with lerp(a,b,0)=a."
     :cs "For floats, the endpoints are bit-exact by construction (multiply by 0 or 1)."))
  :row-5-emergence (
    (:base "vec/lerp interpolates between two vectors by a scalar t."
     :composition "(define (bezier2 p0 p1 p2 t)\n  (let ((q0 (vec/lerp p0 p1 t))\n        (q1 (vec/lerp p1 p2 t)))\n    (vec/lerp q0 q1 t)))\n(bezier2 '(0 0) '(1 2) '(3 0) 0.5)"
     :emergent "quadratic Bézier curve — De Casteljau's construction emerges from nested vec/lerps."
     :meta "Family: iterated-interpolation, the shape of Bézier and spline evaluation. See book-of-composition ch on nested combinators; book-of-motion ch on curves.")
    (:eng "Every curve editor and font renderer computes points this way."
     :math "De Casteljau's algorithm for polynomial curves."
     :cs "Recursion depth = degree; O(d·n²) for degree-n curve of dimension d.")))

(verb
  :name "vec/zero"
  :library "vec"
  :kind "pure"
  :dialect "motoi"
  :signature "(vec/zero n) -> vector"
  :arity "1"
  :contract "n is a nonnegative integer → a length-n list of 0s"
  :summary "Construct a zero-vector of the given length."
  :doc "Cheap and canonical. For non-zero fills, use (make-list n v) instead."
  :since "1.0"
  :examples (
    (:dialect "motoi" :tier "novice" :code "(vec/zero 5)" :note "Returns (0 0 0 0 0).")
    (:dialect "motoi" :tier "intermediate" :code "(vec/zero 0)" :note "Empty vector. Returns ().")
    (:dialect "motoi" :tier "expert" :code "(define (accumulate steps)\n  (let loop ((acc (vec/zero 3)) (rest steps))\n    (if (null? rest) acc (loop (vec/add acc (car rest)) (cdr rest)))))\n(accumulate '((1 0 0) (0 1 0) (0 0 1)))" :note "Sum a list of 3-vectors from a zero start. Returns (1 1 1).")
  )
  :related ("vec/make" "vec/add" "linalg/zeros")
  :row-2-audit (
    (:problem "An accumulator initializes a running-sum vector before folding force samples over a physics tick."
     :program "(define (fold-left f init xs) (if (null? xs) init (fold-left f (f init (car xs)) (cdr xs))))\n(define samples (list '(1 0) '(0 1) '(-1 -1)))\n(fold-left vec/add (vec/zero 2) samples)"
     :explanation "vec/zero 2 produces (0 0) — the additive identity for 2-D vectors. It is the seed for the fold; final result is (0 0) here (samples cancel)."
     :meta "vec/zero is the honest seed for an additive fold. Constructing '(0 0) inline works but hides the intent 'this is the additive identity of the correct dimension'.")
    (:eng "Log 'seed = vec/zero 2' documents the accumulator's shape."
     :math "Additive identity 0 ∈ R^d."
     :cs "O(d) allocation."))
  :row-3-dimension (
    (:setup "Neutral element: the value that leaves the binary op unchanged."
     :rungs (
       (:domain "vec" :code "(vec/zero 3)  ;; (0 0 0)")
       (:domain "matrix" :code "matrix of zeros, additive identity for matrix/+")
       (:domain "monoid identity" :code "e such that op(e, x) = x = op(x, e)"))
     :explanation "Rung 1: zero-vector. Rung 2: zero-matrix. Rung 3: monoid identity in the abstract sense."
     :meta "Shape transfers wherever there's a binary op with an identity element.")
    (:eng "Fold-seed patterns rely on identity elements to make single-element and empty inputs correct."
     :math "Every monoid has an identity; see book-of-math ch on monoids."
     :cs "Fold(op, id, xs) is the canonical structure; id makes empty-list handling clean."))
  :row-4-proof (
    (:claim "vec/zero is the identity for vec/add: adding it to any vector returns that vector unchanged."
     :program "(define v '(3 4 5))\n(equal? (vec/add v (vec/zero (length v))) v)"
     :invariant "∀ v ∈ R^d.  vec/add(v, vec/zero(d)) = v"
     :meta "Identity-law is what makes ⟨R^d, vec/add, vec/zero⟩ a monoid. Falsifier: any v whose sum-with-zero differs from v. Pattern-name: monoid identity law. See book-of-math ch on monoid axioms.")
    (:eng "Identity means the seed of any accumulator fold is invisible in the answer."
     :math "Left and right identity in the abelian group ⟨R^d, +⟩."
     :cs "Bit-exact under rationals; under floats, holds exactly for finite v."))
  :row-5-emergence (
    (:base "vec/zero n returns the length-n zero vector."
     :composition "(define (fold-left f init xs) (if (null? xs) init (fold-left f (f init (car xs)) (cdr xs))))\n(define (sum-of vecs)\n  (if (null? vecs) '()\n      (fold-left vec/add (vec/zero (length (car vecs))) vecs)))\n(sum-of '((1 2) (3 4) (5 6)))"
     :emergent "polymorphic-sum-of-vectors — a shape-adaptive fold emerges from vec/zero + length + vec/add."
     :meta "Family: shape-inferred fold-seed, the pattern of adaptive-accumulator initialization. See book-of-composition ch on shape-driven folds.")
    (:eng "Sum-utilities in stats libraries use this shape."
     :math "Fold over a semigroup with detected identity."
     :cs "The seed is inferred from the first element's shape.")))

