;;; 72-world.slat — Motoi Scheme Reference · Chapter 72 · library world
;;;
;;; 39 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library world — 39 verbs.")

(chapter :number "72" :library "world" :verb-count 39 :training-eligible #t)

;; ═══ 39 verbs in library world ═══

(verb
  :name "world/after"
  :library "world"
  :kind "mut"
  :signature "(world/after n kind key) -> void"
  :summary "Schedule an event to fire on the message bus N frames from now."
  :explanation "In Motoi, the message bus is how entities and cards communicate asynchronously. `world/after` is a frame-counted timer: call it with a delay in frames, a message kind (symbol), and a key, and the world will emit `(kind key)` exactly N frames later. This is useful for: delayed actions (\"spawn an enemy 30 frames from now\"), timed sequences (\"play sound 1, then sound 2 after 60 frames\"), and cleanup (\"remove a temporary particle effect after its duration expires\"). The mutation is internal: no entity or card is modified, but the world's timer queue grows."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/after 30 'enemy-spawn 'goblin-1)" :note "Thirty frames from now, emit 'enemy-spawn with goblin-1 as the key; some listener (card or actor) will handle it.")
    (:dialect "motoi" :tier "intermediate" :code "(define (timed-sequence)\n  (world/after 0 'sound 'kick)\n  (world/after 15 'sound 'snare)\n  (world/after 30 'sound 'kick))" :note "Fire three sounds in a drum pattern; each offset creates a rhythm.")
    (:dialect "motoi" :tier "expert" :code "(define (on-card-emit card payload)\n  (let ((duration (car payload)))\n    (world/after duration 'particle-fade (card-id-of card))\n    (next 'waiting card)))" :note "When a particle emitter fires, schedule its fade-out based on the duration payload. Common pattern in game state machines.")
  )
  :caveats ("Delay is in frames, not milliseconds; frame rate (e.g., 60 FPS) affects wall-clock time." "Events are guaranteed to fire exactly once, at the specified frame. If the game is paused or fast-forwarded, timing is frame-relative, not real-time." "If N <= 0, the event may fire immediately or on the next frame, depending on world tick order. Use 0 for \"fire now (deferred)\" semantics." "The key can be any value (symbol, string, list); it is passed as-is to listeners. No type checking.")
  :drawbacks ("Cannot cancel or reschedule an event once scheduled; design your state machine to ignore unwanted events." "Timer queue grows linearly with events; many pending timers = slight CPU cost each frame." "No built-in per-entity scoping; if entity A and entity B both use `world/after`, their events are global and unsorted." "If the world is reset (`world/reset!`), all pending timers are cleared.")
  :usecases ("Delayed spawn: enemy waves, NPC dialogue triggers." "Timed sequences: rhythm games, choreographed camera moves." "Cleanup: fade out particles, disable temporary UI, despawn effects." "State machine transitions: \"wait 120 frames, then check a condition and move to the next state.\"")
  :related ("world/reset!" "world/step" "on-frame" "time/every-ms")
  :learn (:concept "Deferred events and frame-based scheduling—decoupling logic from immediate execution." :prerequisites ("big-bang" "world/spawn") :progression "world/snapshot (to record the timer queue in a replay); cine/shot (to choreograph camera or entity sequences in parallel)")
  :row-2-audit (
    (:problem "The operator wants a boss to spawn 60 frames after the player enters an arena, without spawning it now and hiding it. world/after enqueues the event; the timer queue fires 60 frames later. entity/spawn would create the entity now (visible until hidden), which the audit trail would show as 'spawned then modified'. world/after keeps the audit trail as 'scheduled then fired'."
     :program "(world/after 60 'boss-arrive 'main-boss)\n(display 'scheduled)"
     :explanation "One deferred event on the world's queue. When frame 60 arrives, the world emits ('boss-arrive 'main-boss); listeners react."
     :meta "Immediate spawn requires later state edits; world/after captures INTENT rather than premature state.")
    (:eng "SRE: deferred events are audit-legible — the queue is inspectable." :math "Time-indexed event." :cs "Queue enqueue with a frame-count key."))
  :row-3-dimension (
    (:setup "Schedule a message to fire at a future point."
     :rungs (
       (:domain "world"  :code "(world/after 60 'boss-arrive 'main-boss)")
       (:domain "cron"   :code "(define job '((at . \"12:00\") (do . backup))) job")
       (:domain "math"   :code "(define (at t f) (list 'at t f)) (at 5 'ping)"))
     :explanation "Rung 1: frame-deferred event. Rung 2: cron entry. Rung 3: symbolic at-form. Each: 'do X at time T'.")
    (:meta "Shape: time-deferred emission.")
    (:eng "SRE: deferred queues need periodic inspection for leaks." :math "Priority queue on time." :cs "Timer-wheel or heap."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Exactly-once firing: an event scheduled with world/after fires exactly once at frame f + n."
     :program "(world/after 3 'test-event 'k)\n(define fires 0)\n(on-message 'test-event (lambda (k) (set! fires (+ fires 1))))\n(world/step) (world/step) (world/step) (world/step)\n(display (= 1 fires))"
     :invariant "∀ n k. after(n, k) → fires(k) exactly once at frame f + n"
     :meta "Fire-exactly-once. Falsified if any duplicate or lost fire is observed. Book-of-code ch 10 (event scheduling) grounds.")
    (:eng "Consequence: caller need not deduplicate." :math "Bijection between schedule and fire." :cs "Idempotent queue with fire-once semantics."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/after schedules a delayed event."
     :composition "(define (drum-loop)\n  (world/after 0  'sound 'kick)\n  (world/after 15 'sound 'snare)\n  (world/after 30 'sound 'kick)\n  (world/after 60 'drum-loop 'again))\n(on-message 'drum-loop (lambda (_) (drum-loop)))"
     :emergent "A self-scheduling drum loop — each cycle schedules the next. Emergent: rhythm engine."
     :meta "Self-scheduling family; game-loop pattern. Book-of-composition ch 13 (temporal composition) grounds.")
    (:eng "SRE: self-scheduling loops need explicit termination — watch for runaway." :math "Recursion in the time domain." :cs "Loop via re-enqueue.")))

(verb
  :name "world/attract!"
  :library "world"
  :kind "mut"
  :signature "(world/attract! id cx cy strength) -> void"
  :summary "Pull an entity toward a point (cx, cy) using a softened inverse-square force."
  :explanation "Gravity, magnetism, and vortexes are all attraction forces. `world/attract!` applies an accelerating force to an entity that pulls it toward a target location with strength that softens as distance increases (inverse-square falloff). Unlike a direct velocity set, this integrates into the entity's physics: the entity accelerates, can overshoot, and interacts with friction and other forces. Use this for: gravity wells, vacuum effects, homing behavior, and orbital mechanics. The mutation is local to the entity's acceleration accumulator; it does not change position directly."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define player-id 'player-id)\n(world/attract! player-id 400 300 5)" :note "Pull the player toward (400, 300) with strength 5. Player accelerates toward the point.")
    (:dialect "motoi" :tier "intermediate" :code "(define (gravity-well cx cy strength)\n  (for-each (lambda (id) (world/attract! id cx cy strength))\n            (group/find 'affected-by-gravity)))" :note "Loop over all entities tagged 'affected-by-gravity' and pull each toward the well center.")
    (:dialect "motoi" :tier "expert" :code "(define (on-frame id ctx)\n  (let ((vortex-x (ctx-get 'vortex-x ctx))\n        (vortex-y (ctx-get 'vortex-y ctx))\n        (strength (ctx-get 'vortex-strength ctx)))\n    (world/attract! id vortex-x vortex-y strength)\n    (next 'falling ctx)))" :note "In a card's frame handler, apply vortex pull based on context parameters. Strength decays or moves with the vortex.")
  )
  :caveats ("Attraction is applied every frame; strength is per-frame acceleration. High strength can cause instability or unrealistic jittery motion." "The entity must have physics enabled (mass > 0, embodiment set) to be affected. Non-physics entities ignore this verb." "Distance is Euclidean (sqrt(dx^2 + dy^2)); no line-of-sight or obstacle checks." "Attract and repel are independent: calling both on the same entity in one frame sums their effects.")
  :drawbacks ("Cannot clamp or cap the entity's speed; very strong attraction + high mass can produce runaway velocities." "Inverse-square falloff means nearby entities feel much stronger force; design distances carefully to avoid jerky behavior." "If target is at the entity, epsilon singularity softening still produces large acceleration; move target away or check distance in caller." "No drag damping built-in; combine with `entity/drag!` to avoid runaway oscillation.")
  :usecases ("Gravity well: enemies sucked into a black hole or vortex." "Homing missile or projectile: pulled toward a moving target." "Magnetic field: metal objects drawn to a lodestone or energy source." "Orbital mechanics: planet gravity, comet tail dynamics.")
  :related ("world/repel!" "world/wind!" "entity/gravity-scale!" "entity/accel!")
  :learn (:concept "Distance-based force fields—attraction as an emergent physics behavior, not teleportation." :prerequisites ("world/spawn" "entity/pos" "entity/vel") :progression "world/repel! (inverse of attraction); ai/seek (goal-seeking behavior on top of physics)")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants coins to drift toward the player when the player picks up a magnet power-up — a physics-authentic pull, not teleportation. entity/apply-force! would require the operator to compute the direction; world/attract! handles the field math."
     :program "(world/attract! 'player 'coin 100)\n(world/step)"
     :explanation "The world computes a per-frame pull force on 'coin proportional to inverse distance from 'player, capped by the strength parameter."
     :meta "entity/apply-force! is manual; world/attract! is the framework's field primitive. Audit: 'framework field vs handcrafted force'.")
    (:eng "SRE: attractor strength is one knob; profile large-N attractors." :math "Distance-parametric force." :cs "Per-frame vector emission."))
  :row-3-dimension (
    (:setup "A source pulls a target with a distance-parametric force."
     :rungs (
       (:domain "world"    :code "(world/attract! 'a 'b 100)")
       (:domain "gravity"  :code "(define (grav m1 m2 r) (/ (* m1 m2) (* r r))) (grav 5 5 10)")
       (:domain "control"  :code "(define (pull-toward from to k) (list 'pull from to k)) (pull-toward 0 10 0.5)"))
     :explanation "Rung 1: attract verb. Rung 2: Newtonian gravity. Rung 3: control setpoint pull. Each: 'move target toward source with a rate proportional to some function of distance'.")
    (:meta "Shape: distance-parametric convergence.")
    (:eng "SRE: attractive fields converge or oscillate; damp them." :math "Force ∝ 1/r or ∝ 1/r²." :cs "Field applied per tick."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Convergence: under a positive attract force with damping, target approaches source over time."
     :program "(world/spawn 'src 0 0) (world/spawn 'tgt 100 100)\n(world/attract! 'src 'tgt 50)\n(entity/drag! 'tgt 0.9)\n(let ((d0 (entity/distance 'src 'tgt)))\n  (world/step) (world/step) (world/step)\n  (display (< (entity/distance 'src 'tgt) d0)))"
     :invariant "∀ src tgt s > 0 with damping. lim(t→∞) distance(src, tgt, t) → 0"
     :meta "Convergence under damping. Falsified if the target diverges or oscillates without decay. Book-of-motion ch 8 (attractor dynamics) grounds.")
    (:eng "Consequence: designers can rely on eventual arrival if damping is set." :math "Lyapunov-stable fixed point at the source." :cs "Iterative convergence."))
  :row-5-emergence (
    (:base "world/attract! pulls target toward source."
     :composition "(define (magnet-active? p) (entity/ref p 'magnet))\n(on-frame (lambda ()\n  (when (magnet-active? 'player)\n    (for-each (lambda (c-str) (world/attract! 'player (string->symbol c-str) 50))\n              (world/find 'coin)))))"
     :emergent "A magnet power-up — all coins pull toward the player while active. Emergent: pickup magnet."
     :meta "Field-primitive family; standard collectible-magnet pattern. Book-of-composition ch 12 (spatial fields) grounds.")
    (:eng "SRE: N attractors × M targets is O(N*M) — bound N." :math "Sum of field contributions." :cs "Vector field superposition.")))

(verb
  :name "world/camera"
  :library "world"
  :kind "rd"
  :signature "(world/camera) -> [x y]"
  :summary "Return the camera's center position [x, y] this frame, including any active shake effect."
  :explanation "The camera is what the player sees: a viewport that frames part of the world. The camera can be shaken (impact effects), panned (smooth follow), or snapped (instant jump). `world/camera` reads the resolved camera center—the final [x, y] after all effects (shake, follow, bounds-clamping) are applied. This is the truth: use it to know exactly where the screen is looking. It is read-only; to change the camera, use `world/camera-snap!`, `world/camera-follow!`, or `world/camera-shake!`."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((cam (world/camera)))\n  (list (car cam) (cadr cam)))" :note "Get the camera's current center; unpack x and y.")
    (:dialect "motoi" :tier "intermediate" :code "(define (in-viewport? x y margin)\n  (let ((cam (world/camera)))\n    (and (> x (- (car cam) margin))\n         (< x (+ (car cam) margin)))))" :note "Check if a world point is within the camera viewport (within margin units of center).")
    (:dialect "motoi" :tier "expert" :code "(define (on-frame id ctx)\n  (let* ((cam (world/camera))\n         (dist (entity/distance id (car cam) (cadr cam))))\n    (if (> dist 1000)\n      (escalate 'off-screen ctx)\n      (next 'active ctx))))" :note "Entity state machine: if off-screen (far from camera), switch to idle/despawn. Common culling pattern.")
  )
  :caveats ("Returns [x, y] as a two-element list; unpack with `car` and `cadr`." "The returned value includes active shake; if you want the non-shaken center, subtract the shake vector separately (not exposed by this verb)." "Camera position is post-bounds-clamping; if the world is small and camera is at bounds, the \"ideal\" follow target may be off-camera." "The camera state is updated during `world/step` after physics; if you call `world/camera` before the frame is stepped, you get the prior frame's camera.")
  :drawbacks ("Read-only; cannot modify camera directly from this call. Use `world/camera-snap!` or `world/camera-follow!` to change it." "No batch read of camera + viewport size together; must call `world/camera` and separately query viewport dimensions (e.g., `viewport-width`)." "Shake decay is baked in; cannot query pre-shake position or remaining shake amplitude.")
  :usecases ("Culling: skip rendering or updating entities far off-screen." "Viewport-relative positioning: HUD, crosshair, or tooltips anchored to screen center." "Debugging: visualize or log where the camera is each frame." "Procedural generation: spawn entities only near the camera to save memory.")
  :related ("world/camera-snap!" "world/camera-follow!" "world/camera-bounds!" "world/camera-shake!" "viewport-width")
  :learn (:concept "Camera as a query—learning what the screen sees right now." :prerequisites ("world/spawn" "entity/pos") :progression "world/camera-follow! (to control camera behavior); cine/follow (for cinematic camera choreography)")
  :row-2-audit (
    (:problem "The operator needs to check whether an entity is currently visible on-screen before drawing an expensive effect. world/camera returns the current view; the operator can then test entity position against it. entity/pos alone doesn't answer 'is this on-screen'."
     :program "(define c (world/camera))\n(define p (entity/pos 'hero))\n(display (and (>= (car p) (car c)) (< (car p) (+ (car c) 320))))"
     :explanation "camera returns (x y w h) or similar view rect. The operator checks if the entity's x is inside that range."
     :meta "Testing without knowing the camera is impossible; world/camera is the read.")
    (:eng "SRE: camera reads inform culling and are called per frame." :math "View rectangle." :cs "Read-only camera slot."))
  :row-3-dimension (
    (:setup "Read the current viewport."
     :rungs (
       (:domain "world"  :code "(world/camera)")
       (:domain "editor" :code "(define scroll '((top . 0) (height . 40))) scroll")
       (:domain "linear" :code "(define window '((from . 0) (to . 320))) window"))
     :explanation "Rung 1: viewport rect. Rung 2: editor scroll window. Rung 3: interval. Each: 'here's the current visible range'.")
    (:meta "Shape: current-viewport read.")
    (:eng "SRE: viewport queries drive culling and dashboards." :math "Rectangle in screen coords." :cs "Read-only accessor."))
  :row-4-proof (
    (:claim "Consistency: two camera reads with no snap/follow between them return the same value."
     :program "(define c1 (world/camera))\n(display (equal? c1 (world/camera)))"
     :invariant "∀ world. (no camera mutator between reads) → camera(t1) = camera(t2)"
     :meta "Read-stability. Falsified if consecutive reads differ without a mutator. Book-of-code ch 4 (read stability) grounds.")
    (:eng "Consequence: cache the read in a local var if used multiple times." :math "Constant across intervals without mutation." :cs "Pure read."))
  :row-5-emergence (
    (:base "world/camera returns the viewport."
     :composition "(define (visible-count)\n  (let ((c (world/camera)))\n    (length (filter (lambda (id-str)\n                     (let ((p (entity/pos (string->symbol id-str))))\n                       (and (>= (car p) (car c))\n                            (< (car p) (+ (car c) 320)))))\n                   (entity/all)))))\n(visible-count)"
     :emergent "A visible-entity count — dashboard metric for what's currently in view. Emergent: viewport telemetry."
     :meta "View-based-filter family; standard culling primitive. Book-of-composition ch 12 (spatial queries) grounds.")
    (:eng "SRE: visible-count is a good perf-budget metric." :math "Predicate over the camera rect." :cs "Filter with a view predicate.")))

(verb
  :name "world/camera-bounds!"
  :library "world"
  :kind "mut"
  :signature "(world/camera-bounds! x y w h) -> void"
  :summary "Restrict the camera center to stay within a rectangular region (x, y, w, h)."
  :explanation "By default, the camera follows the player or target freely. In a bounded level (a room, a dungeon floor, a small map), you want to prevent the camera from showing the void or wandering off-map. `world/camera-bounds!` sets a hard clamp rect: the camera center can never move outside [x, x+w) by [y, y+h). This is typically called once per level load. The bounds are axis-aligned and do not rotate. The camera position is clamped after all other updates (follow, shake), so the shake can briefly violate bounds, but the underlying center stays inside."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/camera-bounds! 0 0 800 600)" :note "Confine camera to a 800×600 room at origin (0, 0).")
    (:dialect "motoi" :tier "intermediate" :code "(define (load-room room-id)\n  (let ((rect (room-rect room-id)))\n    (world/camera-bounds! (car rect) (cadr rect) (caddr rect) (cadddr rect))))" :note "On room load, set camera bounds from the room's bounding rect. Room rect is (x y w h).")
    (:dialect "motoi" :tier "expert" :code "(define (transition-to-next-room next-id)\n  (world/camera-snap! (room-start-x next-id) (room-start-y next-id))\n  (world/camera-bounds! (room-x next-id) (room-y next-id) (room-w next-id) (room-h next-id))\n  (next 'explore ctx))" :note "On room transition: snap camera to new room start, set new bounds, resume play. Classic Metroidvania pattern.")
  )
  :caveats ("Bounds are the *center* of the screen, not the viewport edges. The viewport extends ±(viewport-width/2) and ±(viewport-height/2) from center, so visible boundaries will extend beyond the bounds rect." "If you call `world/camera-bounds!` with a rect smaller than the viewport, the camera center is clamped to a tiny area and the viewport fills with out-of-bounds pixels (usually black/void)." "Bounds are applied *after* shake; if shake amplitude is large, the camera can oscillate up to its bounds." "No smooth transition between bound changes; switching bounds mid-gameplay can pop the camera.")
  :drawbacks ("Bounds are axis-aligned; cannot define L-shaped or rotated level boundaries." "No soft bounds or easing; clamping is hard and instant." "Cannot query current bounds; you must track the active bounds in your own state." "If bounds are tighter than the viewport, the player sees off-level content; design your level rects carefully.")
  :usecases ("Room-based games: confine camera to one room at a time." "Scrolling platformer: prevent camera from wandering beyond level edges." "Top-down dungeon crawler: keep viewport within the current chamber." "Tutorial or confined arena: lock camera to a smaller play area.")
  :related ("world/camera" "world/camera-snap!" "world/camera-follow!" "viewport-width")
  :learn (:concept "Bounded camera—the constraint that keeps the screen within the level." :prerequisites ("world/camera" "world/camera-snap!") :progression "world/camera-follow! (to combine follow + bounds for smooth gameplay)")
  :row-2-audit (
    (:problem "The camera drifts off the edge of the map when the player is near a corner. The operator needs a max/min for the camera position so no black bars appear. world/camera-bounds! is the clamp; world/camera-snap! would apply once but not persist."
     :program "(world/camera-bounds! 0 0 1600 1200)\n(world/camera-follow! 'hero)"
     :explanation "The bounds rect constrains the camera. Follow tries to center on hero; bounds clip when hero approaches the edge."
     :meta "camera-snap! is one-shot; camera-bounds! is persistent constraint. Choose bounds for level edges.")
    (:eng "SRE: bounds are level-metadata; set them at level load." :math "Rectangle clamp on the camera position." :cs "Constraint stored in world state."))
  :row-3-dimension (
    (:setup "Constrain a value to a region."
     :rungs (
       (:domain "world"  :code "(world/camera-bounds! 0 0 1600 1200)")
       (:domain "editor" :code "(define (clamp x lo hi) (max lo (min hi x))) (clamp 100 0 320)")
       (:domain "topology":code "(define (in-rect p r) (and (>= (car p) (car r)))) (in-rect '(5 5) '(0 0 10 10))"))
     :explanation "Rung 1: camera clamp. Rung 2: numeric clamp. Rung 3: point-in-rect test. Each: 'stay inside this box'.")
    (:meta "Shape: bounded region constraint.")
    (:eng "SRE: bounds prevent edge-case UI bugs; audit at load-time." :math "Clamp function." :cs "Region-restriction on updates."))
  :row-4-proof (
    (:claim "Bounded output: with bounds set, the camera never leaves the region regardless of follow target."
     :program "(world/camera-bounds! 0 0 1000 800)\n(world/spawn 'far 9999 9999)\n(world/camera-follow! 'far)\n(world/step)\n(let ((c (world/camera)))\n  (display (and (>= (car c) 0) (< (car c) 1000))))"
     :invariant "∀ target. bounds → camera-pos ∈ bounds-rect"
     :meta "Bounds-preservation. Falsified if follow ever moves camera outside bounds. Book-of-math ch 6 (constraint satisfaction) grounds.")
    (:eng "Consequence: safe to follow any target." :math "Projection onto the bounds rectangle." :cs "Post-follow clamp."))
  :row-5-emergence (
    (:base "world/camera-bounds! sets the viewport clamp."
     :composition "(define (load-level w h)\n  (world/reset!)\n  (world/camera-bounds! 0 0 w h)\n  (world/camera-follow! 'player))\n(load-level 1600 1200)"
     :emergent "A level-load primitive — reset, set bounds, wire follow. Emergent: level entry sequence."
     :meta "Level-transition family; standard level-loader pattern. Book-of-composition ch 13 (state-reset composition) grounds.")
    (:eng "SRE: level loaders bundle the reset/bound/follow triad." :math "Composition of world-state edits." :cs "Bundled setup function.")))

(verb
  :name "world/camera-follow!"
  :library "world"
  :kind "mut"
  :signature "(world/camera-follow! id [lerp] [dzw] [dzh]) -> void"
  :summary "Smoothly ease the camera toward an entity's position, with optional deadzone and lerp tuning."
  :explanation "Games feel smooth when the camera follows the player with a slight delay, not snapping frame-to-frame. `world/camera-follow!` tells the world to ease the camera center toward a target entity (by id), with optional parameters: lerp (easing strength, default ~0.1, higher = faster), dzw and dzh (deadzone width and height, keeping target within a central box before camera moves). This is the standard \"follow camera\" for platformers and action games. Call it once per level or when the follow target changes. The camera continues to follow until explicitly stopped (`world/camera-snap!` or another follow call)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define player-id 'player-id)\n(world/camera-follow! player-id)" :note "Start following the player with default easing (smooth, not too fast).")
    (:dialect "motoi" :tier "intermediate" :code "(define boss-id 'boss-id)\n(world/camera-follow! boss-id 0.05 100 100)" :note "Follow the boss with slower easing (0.05) and a 100×100 deadzone; camera is lethargic, good for boss arenas.")
    (:dialect "motoi" :tier "expert" :code "(define (on-scene-start ctx)\n  (world/camera-snap! (level-start-x) (level-start-y))\n  (world/camera-bounds! (room-x) (room-y) (room-w) (room-h))\n  (world/camera-follow! player-id 0.1 80 60)\n  (next 'playing ctx))" :note "Level init: snap camera to start, set bounds, enable follow with custom deadzone. Standard setup pattern.")
  )
  :caveats ("Lerp factor (0–1) controls easing speed; 0 = no follow (frozen camera), 1 = instant snap. Typical values 0.05–0.2." "Deadzone (dzw, dzh) is half-width and half-height, centered on the current camera; e.g., dzw=50 means camera doesn't move unless target is 50+ units left/right of center." "If the entity id dies or despawns while being followed, the camera follows a ghost position (the entity's last known loc) until a new follow target is set." "Follow competes with bounds: if bounds are tight and follow target is near edge, bounds win (camera clamped).")
  :drawbacks ("Cannot follow multiple entities at once; choose one target." "Lerp is linear; no easing curve support (ease-out, ease-in, etc.)." "Deadzone is axis-aligned; cannot define rotated or shaped deadzones." "No way to query the current follow target; if you lose track of the entity id, you cannot stop follow gracefully.")
  :usecases ("Platformer: follow the player with a small deadzone for snappy control feel." "Top-down action game: smooth follow with larger deadzone to reduce camera jitter." "Boss fight: lerp to a midpoint between player and boss for dynamic framing." "Cutscene transition: follow an NPC instead of player while dialogue plays.")
  :related ("world/camera" "world/camera-snap!" "world/camera-bounds!" "world/camera-shake!" "entity/pos")
  :learn (:concept "Smooth following with easing and deadzones—the feel of responsive but not jittery camera control." :prerequisites ("world/camera" "world/camera-bounds!" "entity/pos") :progression "world/camera-shake! (to add impact/feedback on top of smooth follow); cine/follow (for more complex multi-target cinematics)")
  :row-2-audit (
    (:problem "The camera must follow the player smoothly. camera-snap! per frame jitters; the operator wants easing with a deadzone so small movements don't shake the view."
     :program "(world/camera-follow! 'hero :ease 0.15 :deadzone 30)"
     :explanation "The camera lerps toward hero with a rate of 0.15. Within the 30-pixel deadzone, it does not move. Result: smooth follow that ignores twitch."
     :meta "camera-snap! is per-frame teleport (jittery); camera-follow! is smoothed. Choose follow for gameplay smoothness.")
    (:eng "SRE: follow-eases are UX-tuning knobs; audit centrally." :math "Damped interpolation." :cs "Per-frame lerp with a threshold gate."))
  :row-3-dimension (
    (:setup "Damped tracking of a moving target."
     :rungs (
       (:domain "world"  :code "(world/camera-follow! 'hero :ease 0.15)")
       (:domain "audio"  :code "(define (smooth x prev alpha) (+ (* alpha x) (* (- 1 alpha) prev))) (smooth 10 5 0.3)")
       (:domain "math"   :code "(define (lowpass x prev) (smooth x prev 0.1)) (lowpass 1.0 0.5)"))
     :explanation "Rung 1: camera follow with easing. Rung 2: audio smoothing. Rung 3: low-pass filter. Each: 'approach target with damping'.")
    (:meta "Shape: low-pass filter.")
    (:eng "SRE: low-pass filters absorb noise but add lag; tune ease." :math "Exponential moving average." :cs "IIR filter."))
  :row-4-proof (
    (:claim "Convergence: with 0 < ease < 1, camera approaches target over time (if target is stationary)."
     :program "(world/spawn 'hero 500 500)\n(world/camera-follow! 'hero :ease 0.5)\n(let ((d0 (- 500 (car (world/camera)))))\n  (world/step) (world/step)\n  (display (< (abs (- 500 (car (world/camera)))) (abs d0))))"
     :invariant "∀ target static. lim(t→∞) camera(t) → target"
     :meta "Exponential convergence. Falsified if camera diverges or oscillates. Book-of-math ch 8 (fixed points) grounds.")
    (:eng "Consequence: designers can trust arrival at rest positions." :math "Geometric convergence." :cs "IIR fixed-point."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/camera-follow! smooths toward a target."
     :composition "(world/camera-follow! 'hero :ease 0.15 :deadzone 20)\n(on-message 'boss-arrive (lambda (_) (world/camera-shake! 5 30)))"
     :emergent "A responsive-with-impact camera — smoothly follows, shakes on boss events. Emergent: game-feel camera."
     :meta "Camera-feel family; standard action-game camera. Book-of-composition ch 11 (layered animation) grounds.")
    (:eng "SRE: layered camera behavior is a common tuning surface." :math "Sum of smooth and impulse components." :cs "Camera behavior composed of primitives.")))

(verb
  :name "world/camera-shake!"
  :library "world"
  :kind "mut"
  :signature "(world/camera-shake! amp [decay]) -> null"
  :summary "Trigger a decaying camera shake with initial amplitude and optional decay rate."
  :explanation "Applies a time-decaying oscillation to the camera position, useful for impact feedback or earthquake effects. The shake fades exponentially over frames; without a decay argument, a sensible default is used. The actual camera center (readable via world/camera) includes any active shake; they compose cleanly."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/camera-shake! 8)" :note "A sudden shake with amplitude 8, using the default decay rate.")
    (:dialect "motoi" :tier "intermediate" :code "(define (on-collision id1 id2)\n  (world/camera-shake! 5 0.85))\n(world/each (lambda (id) (display (entity/kind id))))" :note "Trigger a short shake on any collision event, then iterate all entities.")
    (:dialect "motoi" :tier "expert" :code "(define (impact-scale dmg)\n  (world/camera-shake! (+ 2 (* dmg 0.5)) 0.8))\n(define (on-frame ctx)\n  (world/each (lambda (id)\n    (when (entity/alive? id)\n      (let ((hp (entity/ref id 'hp)))\n        (when (< hp 10) (impact-scale (- 100 hp)))))))\n  (next 'on-frame ctx))" :note "Scale shake intensity by damage dealt, creating dynamic feedback.")
  )
  :caveats ("Shake is purely visual; it does not affect entity physics or collision detection." "Multiple calls accumulate: calling again before decay completes will override the previous shake." "Decay value near 1.0 produces very long shakes; near 0.0 shakes are nearly instant.")
  :drawbacks ("Cannot be queried once applied—no way to read back the current shake state." "For very precise timing, couple with world/frame to manually control onset and duration.")
  :usecases ("Impact feedback when a projectile hits a surface or entity." "Earthquake or tremor effects in environmental sequences." "Punctuation for dramatic moments (explosions, boss defeats).")
  :related ("world/camera" "world/camera-snap!" "world/frame" "entity/pos")
  :learn (:concept "Temporal decay: how to apply a decaying force or parameter over time." :prerequisites ("world/frame" "entity/pos") :progression "Move to world/camera-snap! for instant repositioning, or world/attract!/world/repel! for physics-driven motion.")
  :row-2-audit (
    (:problem "The player just got hit and the operator wants a screen-shake for impact feedback. camera-follow! is smooth; the audit calls for a bounded, decaying, direction-random jitter — camera-shake! is the canonical primitive."
     :program "(world/camera-shake! 8 20)"
     :explanation "Shake with amplitude 8 and duration 20 frames. Each frame the camera offset is a random vector within a shrinking envelope."
     :meta "camera-snap! is one-shot precise; camera-follow! is smoothed tracking; camera-shake! is decaying-jitter. Choose based on 'feedback vs tracking'.")
    (:eng "SRE: shake events are gameplay-driven; log the source." :math "Amplitude-decaying random offset." :cs "Time-limited perturbation."))
  :row-3-dimension (
    (:setup "Decaying random perturbation on a stateful quantity."
     :rungs (
       (:domain "world"   :code "(world/camera-shake! 8 20)")
       (:domain "audio"   :code "(define (tremolo x t) (* x (+ 1 (* 0.1 (sin t))))) (tremolo 1 0)")
       (:domain "math"    :code "(define (envelope a d t) (* a (exp (- (* d t))))) (envelope 1 0.5 2)"))
     :explanation "Rung 1: camera shake. Rung 2: audio tremolo. Rung 3: exponential envelope. Each: 'perturb with a decaying amplitude'.")
    (:meta "Shape: decaying envelope over a perturbation.")
    (:eng "SRE: shake budgets prevent motion sickness; cap concurrent shakes." :math "Envelope × random." :cs "Time-bounded stochastic offset."))
  :row-4-proof (
    (:claim "Termination: shake amplitude reaches 0 by end of duration."
     :program "(world/camera-shake! 10 5)\n(world/step) (world/step) (world/step) (world/step) (world/step) (world/step)\n(let ((c1 (world/camera))) (world/step) (display (equal? c1 (world/camera))))"
     :invariant "∀ a d. shake(a, d) → offset(t + d) = 0"
     :meta "Bounded-duration. Falsified if shake persists past its duration. Book-of-motion ch 5 (bounded perturbations) grounds.")
    (:eng "Consequence: shakes always stop; no cleanup needed." :math "Compact support." :cs "Bounded time-envelope."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/camera-shake! adds decaying jitter."
     :composition "(on-message 'hit (lambda (id) (world/camera-shake! 5 10)))\n(on-message 'crit-hit (lambda (id) (world/camera-shake! 15 30)))"
     :emergent "An impact-feedback camera — different shake for different hit severity. Emergent: hit-response layer."
     :meta "Feedback-layer family; standard game-feel additive. Book-of-composition ch 11 (layered animation) grounds.")
    (:eng "SRE: severity mapping is a design knob; keep centralized." :math "Piecewise-mapped envelope." :cs "Event-driven perturbation.")))

(verb
  :name "world/camera-snap!"
  :library "world"
  :kind "mut"
  :signature "(world/camera-snap! x y) -> null"
  :summary "Instantly jump the camera center to a coordinate pair."
  :explanation "Teleports the camera's base center to (x, y) in one frame, ignoring any easing or interpolation. Useful for cutting between scenes, following a teleporting entity, or enforcing a hard boundary. Any active shake from world/camera-shake! is preserved and continues to modulate around the new center."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/camera-snap! 100 50)" :note "Jump the camera to (100, 50) without interpolation.")
    (:dialect "motoi" :tier "intermediate" :code "(define (teleport-scene id target-x target-y)\n  (world/camera-snap! target-x target-y)\n  (entity/set-pos! id target-x target-y))" :note "Snap both camera and entity to the same location when teleporting.")
    (:dialect "motoi" :tier "expert" :code "(define (follow-path-checkpoint path-list index)\n  (when (< index (length path-list))\n    (let ((checkpoint (list-ref path-list index)))\n      (world/camera-snap! (car checkpoint) (cadr checkpoint))\n      (next 'follow-path-checkpoint (ctx-set 'index (+ index 1) ctx)))))" :note "Snap camera to waypoints along a path; useful for guided tours or cutscenes.")
  )
  :caveats ("Snap is absolute and immediate; it ignores all tweens or camera-follow settings in that frame." "If world/camera-follow! is active, the snap will be overridden on the next frame." "Rapid snapping (every frame) can be disorienting; prefer smooth follow when possible.")
  :drawbacks ("No built-in easing or transition—for smooth pans, use motion/* verbs or world/camera-pan instead." "Does not validate x, y bounds; snapping far outside the world may place the camera in empty space.")
  :usecases ("Scene transitions or cut-scenes where the camera must jump to a new location." "Teleport/cutaway effects in story sequences." "Enforcing a hard boundary or reset after an entity reaches a goal.")
  :related ("world/camera" "world/camera-shake!" "world/camera-pan-to" "entity/set-pos!")
  :learn (:concept "Immediate mutation: how to set state without interpolation or decay." :prerequisites ("world/camera" "entity/pos") :progression "Pair with world/camera-pan-to for smooth transitions, or use motion/move-to for entity-driven camera follow.")
  :row-2-audit (
    (:problem "The level just transitioned; the camera must jump to the new player position immediately, no smooth animation. camera-follow! would lerp; camera-snap! teleports."
     :program "(world/camera-snap! 200 200)"
     :explanation "The camera jumps to (200, 200) in a single frame. No interpolation. Result: new level, new view, no smearing."
     :meta "camera-follow! is smoothed (bad for cuts); camera-snap! is immediate (correct for cuts). Choose based on 'is this a cut or a follow'.")
    (:eng "SRE: camera cuts are UX-critical; audit their timing." :math "Assignment to camera slot." :cs "Direct field write."))
  :row-3-dimension (
    (:setup "Immediate assignment to a stateful quantity."
     :rungs (
       (:domain "world"  :code "(world/camera-snap! 200 200)")
       (:domain "editor" :code "(define (goto ln) (list 'jump ln)) (goto 42)")
       (:domain "math"   :code "(define (set-x p x) (list x (cadr p))) (set-x '(0 0) 5)"))
     :explanation "Rung 1: camera teleport. Rung 2: editor goto-line. Rung 3: overwrite first component. Each: 'set absolute value, no interpolation'.")
    (:meta "Shape: overwrite; no history.")
    (:eng "SRE: overwrites lose history — snapshot if undo is desired." :math "Assignment." :cs "Overwrite."))
  :row-4-proof (
    (:claim "Overwrite: after camera-snap!(x, y), camera-pos = (x, y) regardless of prior state."
     :program "(world/camera-follow! 'hero) (world/step)\n(world/camera-snap! 42 42)\n(display (equal? (world/camera) '(42 42)))"
     :invariant "∀ x y. camera-pos(camera-snap!(x, y)) = (x, y)"
     :meta "Assignment overwrite. Falsified if prior follow bleeds into result. Book-of-code ch 6 (assignment) grounds.")
    (:eng "Consequence: predictable cuts." :math "Assignment to ℝ²." :cs "Overwrite semantics."))
  :row-5-emergence (
    (:base "world/camera-snap! teleports the camera."
     :composition "(define (cut-to id)\n  (let ((p (entity/pos id)))\n    (world/camera-snap! (car p) (cadr p))))\n(cut-to 'boss-arena)"
     :emergent "A cut-to primitive — jump camera to the location of any entity. Emergent: cinematic cut."
     :meta "Cut family; standard film-language primitive. Book-of-composition ch 11 (composition of camera edits) grounds.")
    (:eng "SRE: cuts leave audit trace by target-name." :math "Composition of read and assign." :cs "Read + write.")))

(verb
  :name "world/collisions"
  :library "world"
  :kind "rd"
  :signature "(world/collisions) -> [[id1 id2] ...]"
  :summary "Return a list of [a, b] entity id pairs that collided in the last step."
  :explanation "After world/step completes, this reads the collision buffer and returns all pairwise overlaps detected. Each pair is a fresh list [id-a id-b]; the order within the pair is stable but unspecified across calls. Use this to dispatch collision-handling logic: damage, sounds, particles, etc. The buffer is cleared at the start of each step, so collisions only live for one frame."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define collisions (world/collisions))\n(display (length collisions))" :note "Get the collision list and count how many pairs collided this frame.")
    (:dialect "motoi" :tier "intermediate" :code "(define (handle-collisions)\n  (for-each (lambda (pair)\n    (let ((a (car pair))\n          (b (cadr pair)))\n      (when (eq? (entity/kind a) 'bullet)\n        (entity/set! b 'hp (- (entity/ref b 'hp) 10)))))\n    (world/collisions)))" :note "Iterate collisions and damage entities tagged as bullets.")
    (:dialect "motoi" :tier "expert" :code "(define (resolve-collisions ctx)\n  (for-each (lambda (pair)\n    (let ((id-a (car pair))\n          (id-b (cadr pair)))\n      (cond ((and (eq? (entity/kind id-a) 'player)\n                  (eq? (entity/kind id-b) 'coin))\n             (entity/despawn! id-b)\n             (act 'sound 'coin-collect))\n            ((and (eq? (entity/kind id-a) 'enemy)\n                  (eq? (entity/kind id-b) 'enemy))\n             (world/impulse! id-a -1 0)\n             (world/impulse! id-b 1 0)))))\n    (world/collisions))\n  (next 'resolve-collisions ctx))" :note "Multi-branch collision dispatcher in a state function; rebound enemies, collect coins.")
  )
  :caveats ("The collision list is only valid during the current frame; do not store a reference across steps." "A collision pair [a b] will appear only once per frame, even if the entities overlap continuously." "If an entity despawns mid-frame (e.g., in response to a collision), subsequent pairs involving that id may still appear.")
  :drawbacks ("No collision metadata (impact point, normal, relative velocity)—only the id pair." "Filtering by kind must be done in user code; no built-in layer/mask support at this stage (though collision/define-layers! can organize layers)." "Allocating a fresh list every call is slightly costly; for high-collision scenarios, cache the result.")
  :usecases ("Implementing hit detection for weapons, projectiles, or hazards." "Coin / item collection logic." "Triggering sound effects or particle bursts on impact." "Implementing enemy knock-back or stun on collision.")
  :related ("world/step" "world/solve!" "entity/overlaps?" "entity/collisions" "collision/define-layers!")
  :learn (:concept "Polling state from the world engine each frame to drive user logic." :prerequisites ("world/step" "entity/alive?" "entity/kind") :progression "Move to entity/overlaps? for per-entity queries, or collision/define-layers! to organize collision groups.")
  :row-2-audit (
    (:problem "The operator needs to process all collisions from the last frame in one batch to unify damage/effect application. entity/collisions is per-entity — O(n) walks; world/collisions returns the frame's global list."
     :program "(for-each (lambda (pair)\n            (let ((a (car pair)) (b (cadr pair)))\n              (display (list 'collision a b))))\n          (world/collisions))"
     :explanation "One call returns all frame-pairs. Batch processing without per-entity loops."
     :meta "entity/collisions is O(entities); world/collisions is O(collision-pairs). Choose based on batch-scope.")
    (:eng "SRE: batch collision processing is easier to audit." :math "Enumeration of collision pairs." :cs "Read of frame's collision buffer."))
  :row-3-dimension (
    (:setup "Enumerate the results of a per-frame simulation phase."
     :rungs (
       (:domain "world"   :code "(world/collisions)")
       (:domain "network" :code "(define packets '((a . 1) (b . 2))) packets")
       (:domain "sets"    :code "(define pairs '((1 2) (3 4))) pairs"))
     :explanation "Rung 1: collision pairs. Rung 2: packet buffer. Rung 3: list of pairs. Each: 'batch of results'.")
    (:meta "Shape: batch enumeration.")
    (:eng "SRE: batches allow bulk processing efficiencies." :math "List of tuples." :cs "Buffer read."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Consistency: world/collisions equals the union of (entity/collisions id) over all id."
     :program "(world/spawn 'a 0 0) (world/spawn 'b 0 0) (world/step)\n(define wc (world/collisions))\n(define ec (append (entity/collisions 'a) (entity/collisions 'b)))\n(display (= (length wc) (quotient (length ec) 2)))"
     :invariant "∀ world. world/collisions = ⋃ entity/collisions per id (with pair-dedup)"
     :meta "View-consistency. Falsified if batch and per-entity views disagree. Book-of-code ch 5 (view consistency) grounds.")
    (:eng "Consequence: readers may use either view without worry." :math "Multi-set relation." :cs "Aggregation consistency."))
  :row-5-emergence (
    (:base "world/collisions returns all collision pairs."
     :composition "(on-frame (lambda ()\n  (for-each (lambda (p)\n              (when (and (eq? (entity/kind (car p)) 'projectile)\n                         (eq? (entity/kind (cadr p)) 'enemy))\n                (entity/damage! (cadr p) 5)\n                (entity/despawn! (car p))))\n            (world/collisions))))"
     :emergent "A projectile-damage system — bulk-process all projectile hits per frame. Emergent: damage pipeline."
     :meta "Batch-dispatch family; standard collision-response pipeline. Book-of-composition ch 10 (cohort ops) grounds.")
    (:eng "SRE: batch dispatch is easier to profile than per-entity." :math "Pattern match over collision pairs." :cs "Batch pipeline stage.")))

(verb
  :name "world/count"
  :library "world"
  :kind "rd"
  :signature "(world/count [kind]) -> integer"
  :summary "Return the number of alive entities, optionally filtered by kind."
  :explanation "A fast read of the entity count. If no kind is given, returns the total count of all live entities. If a kind symbol is provided, counts only entities of that kind. Despawned entities are not counted. Useful for game state checks (win condition, spawn caps, difficulty scaling)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/count)" :note "Get the total entity count.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((enemy-count (world/count 'enemy)))\n  (if (= enemy-count 0)\n    (display \"Wave cleared!\")\n    (display (string-append \"Enemies left: \" (number->string enemy-count)))))" :note "Check if all enemies are defeated and print status.")
    (:dialect "motoi" :tier "expert" :code "(define (check-spawn-cap ctx)\n  (let ((total (world/count))\n        (cap 64))\n    (cond ((>= total cap)\n           (next 'wait-for-despawn ctx))\n          (else\n           (world/spawn 'minion (random 640) (random 360))\n           (next 'check-spawn-cap ctx)))))" :note "Spawn minions up to a cap; wait when limit is reached.")
  )
  :caveats ("The count is read at the start of world/step; despawns in the current frame are reflected only after the step." "Passing a non-existent kind does not error; it simply returns 0.")
  :drawbacks ("No per-team or per-layer filtering; you must manually iterate (world/find kind) and filter further if needed." "Counted entities include all alive entities; there is no separate count for entities in a given state or with a tag.")
  :usecases ("Win/lose condition checks (all enemies dead, all coins collected)." "Difficulty scaling based on entity count." "Spawn caps to prevent lag or game-breaking abundance." "UI display of remaining enemies or collectibles.")
  :related ("world/find" "world/each" "entity/kind" "world/spawn" "entity/despawn!")
  :learn (:concept "Efficient aggregation: reading a pre-computed summary of world state." :prerequisites ("world/step" "entity/kind") :progression "Use world/find to get the actual list of ids for further filtering, or world/each to iterate and apply custom logic.")
  :row-2-audit (
    (:problem "The operator wants to display total-entity count on a dashboard HUD. entity/count aggregates over the whole registry; world/count is the world-scoped equivalent (accounting for spawned-in-world vs. pool)."
     :program "(display (world/count))"
     :explanation "One O(1) read of the world's entity-count field. Suitable for per-frame HUD updates."
     :meta "entity/count is registry-scoped; world/count is world-scoped. In single-world configs they equal; in multi-world configs they differ.")
    (:eng "SRE: HUD counters are safe per-frame reads." :math "|world.entities|." :cs "Cached size."))
  :row-3-dimension (
    (:setup "Cardinality of a scoped container."
     :rungs (
       (:domain "world"   :code "(world/count)")
       (:domain "network" :code "(define (conn-count srv) 42) (conn-count 'main)")
       (:domain "sets"    :code "(define (card s) (length s)) (card '(a b c))"))
     :explanation "Rung 1: world entity count. Rung 2: connection count on a server. Rung 3: set cardinality. Each: 'how many members'.")
    (:meta "Shape: scoped size.")
    (:eng "SRE: scoped sizes are dashboard staples." :math "Set cardinality." :cs "Cached size accessor."))
  :row-4-proof (
    (:claim "Monotonicity: world/count grows by exactly 1 per spawn and shrinks by 1 per despawn."
     :program "(define c0 (world/count))\n(world/spawn 'x 0 0)\n(display (= (+ c0 1) (world/count)))"
     :invariant "∀ world spawn. count(spawn(world)) = count(world) + 1"
     :meta "Count/spawn algebra. Falsified if spawn changes count by non-1. Book-of-code ch 5 (accounting semantics) grounds.")
    (:eng "Consequence: count changes are audit signals." :math "Increment-per-spawn." :cs "Consistent accounting."))
  :row-5-emergence (
    (:base "world/count reads the entity total."
     :composition "(define budget 100)\n(on-frame (lambda ()\n  (when (> (world/count) budget)\n    (for-each (lambda (id-str)\n                (when (eq? (entity/kind (string->symbol id-str)) 'particle)\n                  (entity/despawn! (string->symbol id-str))))\n              (entity/all)))))"
     :emergent "A budget-enforcer — cull low-priority entities when the world exceeds a budget. Emergent: pressure valve."
     :meta "Population-control family; standard resource-cap pattern. Book-of-composition ch 8 (per-frame sweeps) grounds.")
    (:eng "SRE: budget enforcement prevents runaway spawn bugs." :math "Threshold-triggered filter." :cs "Cap-and-cull loop.")))

(verb
  :name "world/each"
  :library "world"
  :kind "rd"
  :signature "(world/each fn) -> integer"
  :summary "Call fn with each alive entity id in birth order; return the count."
  :explanation "Iteration primitive: loops over all entities currently alive and invokes fn once per id. The entities are visited in the order they were spawned (bornSeq). Useful for polling entity state, running per-entity logic, or collecting data. Returns the count of iterations, which equals the number of alive entities."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/each (lambda (id)\n  (display (entity/kind id))))" :note "Print the kind of every entity.")
    (:dialect "motoi" :tier "intermediate" :code "(define (count-by-kind)\n  (let ((counts '()))\n    (world/each (lambda (id)\n      (let ((k (entity/kind id)))\n        (display (string-append k \" at \" (number->string (entity/x id)) \" \\n\")))))\n    counts))" :note "Emit entity kind and position for each entity.")
    (:dialect "motoi" :tier "expert" :code "(define (tick-all-entities ctx)\n  (world/each (lambda (id)\n    (when (entity/alive? id)\n      (let ((state (entity/state id)))\n        (cond ((eq? state 'idle)\n               (entity/set! id 'idle-time (+ (entity/ref id 'idle-time) 1)))\n              ((eq? state 'moving)\n               (entity/move! id (entity/vel id))))))))\n  (next 'tick-all-entities ctx))" :note "Run per-entity FSM logic in a state function; update timers and positions.")
  )
  :caveats ("The iteration order is stable (birth order) but should not be relied upon for determinism if entities are spawned dynamically." "If you despawn an entity during iteration, the behavior is unspecified—use entity/alive? to guard any mutations." "The function is called for every id, including those that may have become invalid since the start of iteration; check entity/alive? if you want to skip dead entities.")
  :drawbacks ("No built-in filtering by kind or tag; use world/find for that." "Cannot break early or short-circuit the loop; if you need conditional stopping, use world/find instead." "Allocates a closure for every call; in tight loops, consider world/find and a hand-rolled for-each.")
  :usecases ("Broadcasting a message or state change to all entities." "Collecting statistics (count, min/max position, total damage)." "Running per-entity FSMs or tick logic each frame." "Rendering or visual polling of all entities.")
  :related ("world/find" "world/count" "entity/alive?" "entity/state" "entity/set!")
  :learn (:concept "Iteration and side effects: how to visit every entity and apply a procedure." :prerequisites ("world/step" "lambda" "entity/kind") :progression "Use world/find to filter by kind, or fold-left / fold-right (from core) to accumulate values across entities.")
  :row-2-audit (
    (:problem "The operator needs to apply per-frame drag to every entity. entity/all + for-each requires two calls; world/each is one-call callback iteration."
     :program "(world/each (lambda (id) (entity/drag! id 0.95)))"
     :explanation "The world visits each entity and calls the lambda. One-line sweep."
     :meta "entity/all + for-each is more flexible (allows filter-first); world/each is more compact and direct.")
    (:eng "SRE: sweeps are audit-clear; grep 'world/each'." :math "Iteration over the registry." :cs "Higher-order visit."))
  :row-3-dimension (
    (:setup "Apply a function to every member of a collection."
     :rungs (
       (:domain "world"  :code "(world/each (lambda (id) (entity/drag! id 0.95)))")
       (:domain "shell"  :code "(define (for-each-file dir f) (list 'walked dir)) (for-each-file \"/tmp\" 'print)")
       (:domain "math"   :code "(define (each xs f) (for-each f xs)) (each '(1 2 3) display)"))
     :explanation "Rung 1: entity visit. Rung 2: file walk. Rung 3: list iteration. Each: 'apply f to each member'.")
    (:meta "Shape: higher-order iteration.")
    (:eng "SRE: iterators are the workhorse of frame updates." :math "Function application over a domain." :cs "For-each pattern."))
  :row-4-proof (
    (:claim "Coverage: every entity in the world is visited exactly once per world/each call."
     :program "(world/spawn 'a 0 0) (world/spawn 'b 0 0)\n(define visited '())\n(world/each (lambda (id) (set! visited (cons id visited))))\n(display (= 2 (length visited)))"
     :invariant "∀ world f. |visited(world/each(world, f))| = count(world)"
     :meta "Complete-once coverage. Falsified if any entity is skipped or double-visited. Book-of-code ch 5 (iterator semantics) grounds.")
    (:eng "Consequence: sweeps are safe for uniform effects." :math "Bijection between visits and members." :cs "Complete iteration."))
  :row-5-emergence (
    (:base "world/each visits every entity with a callback."
     :composition "(define (apply-wind strength)\n  (world/each (lambda (id)\n                (entity/apply-force! id strength 0))))\n(on-frame (lambda () (apply-wind 0.5)))"
     :emergent "A per-frame wind — every entity gets a small rightward push. Emergent: environmental effect."
     :meta "Environmental-effect family; standard field-application. Book-of-composition ch 12 (spatial fields) grounds.")
    (:eng "SRE: universal effects can accumulate; add damping." :math "Uniform vector-field application." :cs "Per-tick sweep.")))

(verb
  :name "world/find"
  :library "world"
  :kind "rd"
  :signature "(world/find [kind]) -> [id ...]"
  :summary "Return a list of all alive entity ids, optionally filtered by kind."
  :explanation "Query primitive: returns a fresh list of entity ids. Without an argument, all alive entities are included. With a kind symbol, only entities of that kind are returned. The ids are in birth order (the same order world/each visits them). Use this to collect entities for filtering, sorting, or count-based logic."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((all-ids (world/find)))\n  (display (length all-ids)))" :note "Get the list of all entity ids and count them.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((enemies (world/find 'enemy)))\n  (for-each (lambda (id)\n    (world/impulse! id 0 -5))\n    enemies))" :note "Find all enemies and apply an upward impulse to each.")
    (:dialect "motoi" :tier "expert" :code "(define (find-nearest-enemy-to id)\n  (let* ((pos (entity/pos id))\n         (px (car pos))\n         (py (cadr pos))\n         (enemies (world/find 'enemy)))\n    (if (null? enemies)\n      'nan\n      (fold-left (lambda (nearest candidate)\n        (let ((d-nearest (entity/distance nearest id))\n              (d-candidate (entity/distance candidate id)))\n          (if (< d-candidate d-nearest) candidate nearest)))\n        (car enemies)\n        (cdr enemies)))))" :note "Find all enemies and fold to get the one closest to a given entity.")
  )
  :caveats ("The returned list is a snapshot; changes to the world after the call (spawns, despawns) are not reflected." "If kind is provided but no entities match, an empty list is returned (no error)." "The list is in birth order; if you need a different order, sort it yourself.")
  :drawbacks ("Allocates a new list; for very large entity counts, this can be costly if called every frame." "No lazy evaluation; all matching ids are collected up front." "No filtering by tag, state, or other properties; filter the returned list in user code if needed.")
  :usecases ("Finding a subset of entities to apply an action to (e.g., all coins, all enemies)." "Nearest-neighbor or distance-based queries (combined with fold or map)." "Checking existence conditions (e.g., 'if any coin remains')." "Bulk state or physics updates (e.g., slow all enemies).")
  :related ("world/each" "world/count" "world/nearest" "entity/kind" "fold-left")
  :learn (:concept "Querying and filtering: how to collect entities matching a criterion." :prerequisites ("world/step" "entity/kind" "list" "length") :progression "Combine with fold-left / fold-right to aggregate data, or use world/nearest for spatial queries.")
  :row-2-audit (
    (:problem "The operator needs the list of all 'coin entities to apply a bulk animation. entity/all + filter-by-kind works but scans everything; world/find is indexed by kind."
     :program "(display (world/find 'coin))"
     :explanation "Returns the list of all coin-kind entity ids. Constant-time if the world maintains a kind index."
     :meta "entity/all + filter is O(n) linear scan; world/find is O(k) where k is the coin count. Choose based on kind-frequency.")
    (:eng "SRE: indexed finds scale better than linear scans." :math "Preimage of a kind predicate." :cs "Indexed lookup on a kind field."))
  :row-3-dimension (
    (:setup "Filtered lookup on a keyed attribute."
     :rungs (
       (:domain "world"  :code "(world/find 'coin)")
       (:domain "sql"    :code "(define (select-where t k v) (list 'select t k v)) (select-where 'users 'role 'admin)")
       (:domain "sets"   :code "(define (filter-eq xs k) (filter (lambda (x) (eq? x k)) xs)) (filter-eq '(a b a) 'a)"))
     :explanation "Rung 1: entities of a kind. Rung 2: SQL SELECT WHERE. Rung 3: filter by predicate. Each: 'give me members matching this attribute'.")
    (:meta "Shape: attribute-indexed selection.")
    (:eng "SRE: indexed queries beat scans when index is available." :math "Preimage under a projection." :cs "Index-backed filter."))
  :row-4-proof (
    (:claim "Completeness: every entity with the queried kind appears in the result."
     :program "(world/spawn 'coin 0 0) (world/spawn 'coin 10 10) (world/spawn 'gem 0 0)\n(display (= 2 (length (world/find 'coin))))"
     :invariant "∀ world k. |find(world, k)| = |{e ∈ world : kind(e) = k}|"
     :meta "Query completeness. Falsified if any matching entity is missing. Book-of-code ch 5 (query completeness) grounds.")
    (:eng "Consequence: rely on the result set." :math "Bijection with the preimage." :cs "Complete match."))
  :row-5-emergence (
    (:base "world/find returns entities of a kind."
     :composition "(define (award-coin-value multiplier)\n  (for-each (lambda (id-str)\n              (entity/set! (string->symbol id-str) 'value\n                           (* multiplier (or (entity/ref (string->symbol id-str) 'value) 1))))\n            (world/find 'coin)))\n(award-coin-value 2)"
     :emergent "A bulk-attribute update — multiply all coin values by a factor. Emergent: economy multiplier."
     :meta "Bulk-update family; SQL 'UPDATE WHERE'. Book-of-composition ch 10 (cohort ops) grounds.")
    (:eng "SRE: bulk updates are testable via count invariants." :math "Element-wise transformation over a subset." :cs "Filter + map + update.")))

(verb
  :name "world/floor!"
  :library "world"
  :kind "mut"
  :signature "(world/floor! y [bounce]) -> null"
  :summary "Set a horizontal ground plane at y; bounce is the restitution coefficient. No argument removes it."
  :explanation "Creates a rigid floor (or removes it) that all physics bodies collide with. Bodies falling below y will bounce back (or stick, if bounce is 0). The bounce parameter controls restitution: 0 means no bounce (perfectly inelastic), 1 means full conservation of velocity, >1 means gain (unphysical but sometimes fun). Calling with no arguments removes the floor entirely."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/floor! 360 0.6)" :note "Set a bouncy ground at y=360 with 60% restitution.")
    (:dialect "motoi" :tier "intermediate" :code "(define (setup-level)\n  (world/reset!)\n  (world/gravity! 0 0.3)\n  (world/floor! 360 0.5)\n  (world/spawn 'player 320 180))" :note "Initialize a level with gravity, a floor, and a player entity.")
    (:dialect "motoi" :tier "expert" :code "(define (on-frame ctx)\n  (let ((frame (world/frame)))\n    (cond ((= (modulo frame 120) 0)\n           ;; Every 2 seconds, toggle the floor\n           (if (> frame 0) (world/floor!) (world/floor! 360 0.8)))\n          (else\n           (world/each (lambda (id)\n             (when (< (entity/y id) -100)\n               (entity/set-pos! id 320 180)))))))  ;; Respawn fallen entities\n  (next 'on-frame ctx))" :note "Toggle the floor on and off; respawn entities that fall below the screen.")
  )
  :caveats ("The floor is infinite (extends across all x); it cannot be positioned horizontally." "Entities do not rest on the floor without friction; they will bounce indefinitely unless world/wind! or drag is applied." "Calling with only y (no bounce) uses a default bounce value; verify the default in your interpreter.")
  :drawbacks ("Only one floor is supported; for multiple platforms, use solid entities or a grid collision system." "No friction or stopping condition built-in; entities bounce until damped by external forces." "Bounce > 1 can cause numerical instability over many frames; keep values reasonable (< 1 recommended).")
  :usecases ("Creating a ground plane in platformers or physics puzzles." "Bouncy surfaces (trampoline-like behavior with high bounce)." "Sticky ground (low bounce, combined with drag or friction)." "Temporary platforms (toggle the floor on and off for puzzle mechanics).")
  :related ("world/gravity!" "world/wind!" "entity/gravity-scale!" "entity/solid!" "world/step")
  :learn (:concept "Static collision geometry: a simple, efficient way to define an immobile boundary." :prerequisites ("world/gravity!" "world/step" "entity/pos") :progression "Use entity/solid! and entity/shape! for more complex collision shapes, or world/solve! for constraint-based physics.")
  :row-2-audit (
    (:problem "Every entity in the game should fall to a ground plane at y=400. Spawning a wall entity is heavier than needed; world/floor! is a special world-level parameter the integrator honors."
     :program "(world/floor! 400)\n(world/spawn 'ball 100 100)\n(entity/set-vel! 'ball 0 5)"
     :explanation "One world-level call defines a floor. The integrator clamps every entity's y to the floor. No wall entity needed."
     :meta "Wall entity would require per-instance physics. world/floor! is a special-case optimization for the common ground.")
    (:eng "SRE: floor is a global; audit its value once." :math "Half-plane constraint." :cs "Special-case constraint in the integrator."))
  :row-3-dimension (
    (:setup "A special-case global constraint on a coordinate."
     :rungs (
       (:domain "world"    :code "(world/floor! 400)")
       (:domain "throttle" :code "(define (ceiling-val v m) (min v m)) (ceiling-val 500 400)")
       (:domain "math"     :code "(define (clip-below y f) (if (> y f) f y)) (clip-below 500 400)"))
     :explanation "Rung 1: floor plane. Rung 2: value ceiling. Rung 3: clip below. Each: 'don't exceed this bound'.")
    (:meta "Shape: hard-clip on an axis.")
    (:eng "SRE: hard clips are simplest constraints." :math "Half-plane restriction." :cs "Per-entity y-clip."))
  :row-4-proof (
    (:claim "Bounded-y: with world/floor! y set, no entity has y > f after integration."
     :program "(world/floor! 400)\n(world/spawn 'ball 100 100) (entity/set-vel! 'ball 0 1000)\n(world/step) (world/step)\n(display (<= (entity/y 'ball) 400))"
     :invariant "∀ e. floor(f) → y(e, t+1) ≤ f"
     :meta "Floor-bound. Falsified if any entity crosses the floor. Book-of-math ch 6 (constraints) grounds.")
    (:eng "Consequence: entities never fall past the floor." :math "Half-plane projection." :cs "Post-integration clip."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/floor! sets a global ground plane."
     :composition "(world/gravity! 0 9.8)\n(world/floor! 400)\n(world/spawn 'ball 100 100)\n(entity/bounce! 'ball 0.7)"
     :emergent "A bouncing-ball demo — gravity + floor + bounce = physically-authentic ball. Emergent: elementary physics simulation."
     :meta "Physics-setup family; standard demo bundle. Book-of-composition ch 9 (preset bundles) grounds; book-of-motion ch 12 (bouncing) cross-refs.")
    (:eng "SRE: physics demos are grep-friendly for test-case creation." :math "Composition of constraint, force, and reflection." :cs "Bundled physics scene.")))

(verb
  :name "world/frame"
  :library "world"
  :kind "rd"
  :signature "(world/frame) -> integer"
  :summary "Return the current world frame counter (incremented each step)."
  :explanation "A monotonically increasing integer that counts the number of world/step calls since start (or world/reset!). Useful for scheduling, timing events, or synchronizing animations. Frame 0 is the initial state before any step."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((f (world/frame)))\n  (display f))" :note "Print the current frame number.")
    (:dialect "motoi" :tier "intermediate" :code "(define (spawn-every-30-frames ctx)\n  (when (= (modulo (world/frame) 30) 0)\n    (world/spawn 'enemy (random 640) 0))\n  (next 'spawn-every-30-frames ctx))" :note "Spawn an enemy every 30 frames (once per second at 30fps).")
    (:dialect "motoi" :tier "expert" :code "(define (oscillating-y id amplitude frequency)\n  (let* ((f (world/frame))\n         (angle (* (/ f frequency) 6.28))  ;; 2π\n         (y-offset (* amplitude (sin angle))))\n    (entity/set-pos! id (entity/x id) y-offset)))\n\n(define (animate-entity ctx)\n  (oscillating-y (car (world/find 'player)) 50 60)  ;; Oscillate player up/down\n  (next 'animate-entity ctx))" :note "Use frame count to drive a sine wave animation.")
  )
  :caveats ("Frame is a counter from the start; do not assume a global wall-clock time (frame rate may vary)." "After world/reset!, the frame counter is reset to 0." "Modulo arithmetic (frame % n == 0) is the standard pattern for periodic events; be careful of off-by-one.")
  :drawbacks ("No fractional frames; for smooth sub-frame timing, combine with entity velocity or motion tweens." "The frame counter can overflow if the game runs long enough (after 2^31 frames); in practice, this is rare.")
  :usecases ("Scheduling: spawn, state changes, or animations at specific frames." "Periodic effects: every N frames, do something (flicker, pulse, spawn wave)." "Replay and determinism: using the frame count as a seed or checkpoint." "Debugging: log the frame when an event occurs.")
  :related ("world/step" "world/reset!" "world/after" "tick/mod-n" "time/every-ms")
  :learn (:concept "Discrete time: using a frame counter for scheduling and synchronization." :prerequisites ("world/step" "modulo") :progression "Use world/after for frame-delayed events, or tick/pattern for more complex rhythmic patterns.")
  :row-2-audit (
    (:problem "The operator wants to fire an effect every 60 frames. modulo on world/frame is the cheapest possible test."
     :program "(on-frame (lambda ()\n  (when (= 0 (modulo (world/frame) 60))\n    (display 'tick))))"
     :explanation "Each frame checks 'frame mod 60'; when zero, fire. Cleaner than maintaining a private counter."
     :meta "world/after is a scheduled one-shot; the world/frame modulo approach is a recurring pattern.")
    (:eng "SRE: frame reads are cheap; use freely." :math "Discrete time counter." :cs "Read of the frame slot."))
  :row-3-dimension (
    (:setup "Read the current tick of a monotonic clock."
     :rungs (
       (:domain "world"    :code "(world/frame)")
       (:domain "unix"     :code "(define (time-now) 1721000000) (time-now)")
       (:domain "math"     :code "(define (step n) (+ n 1)) (step 5)"))
     :explanation "Rung 1: game frame. Rung 2: Unix epoch. Rung 3: successor. Each: 'current point on a monotonic axis'.")
    (:meta "Shape: monotonic tick counter.")
    (:eng "SRE: tick reads are foundational for time-based logic." :math "ℕ counter." :cs "Monotonic read."))
  :row-4-proof (
    (:claim "Monotonicity: world/frame at time t2 ≥ world/frame at time t1 when t2 > t1."
     :program "(let ((f1 (world/frame))) (world/step) (world/step)\n  (display (>= (world/frame) f1)))"
     :invariant "∀ t1 < t2. frame(t1) ≤ frame(t2)"
     :meta "Monotonic clock. Falsified if the frame ever decreases. Book-of-code ch 8 (monotonic counters) grounds.")
    (:eng "Consequence: safe as a time reference." :math "Non-decreasing function of physical time." :cs "Monotonic slot."))
  :row-5-emergence (
    (:base "world/frame returns the current frame counter."
     :composition "(on-frame (lambda ()\n  (when (= 0 (modulo (world/frame) 30))\n    (world/spawn 'coin (random 500) 100))))"
     :emergent "A periodic-spawner — a coin every 30 frames. Emergent: rhythm-based spawn."
     :meta "Cadence family; standard rhythm-based logic. Book-of-composition ch 13 (temporal composition) grounds.")
    (:eng "SRE: cadence-based spawns are easy to test." :math "Periodic predicate on frame." :cs "Modulo-based dispatch.")))

(verb
  :name "world/gravity!"
  :library "world"
  :kind "mut"
  :signature "(world/gravity! gx gy) -> void"
  :summary "Set the global gravitational acceleration vector for all physics bodies."
  :explanation "Every frame, gravity applies a constant acceleration to all entities that have not disabled it (via entity/gravity-scale! 0). The vector (gx gy) is in world units per frame squared. Positive gy pulls downward; negative gy pulls upward. This is the primary lever for tuning how 'heavy' or 'floaty' the world feels. Call it once at setup or whenever you need to shift gravity mid-simulation (e.g., antigravity powerup, moon level)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/gravity! 0 0.5)" :note "Earth-like gravity: no horizontal drift, downward pull of 0.5 units/frame².")
    (:dialect "motoi" :tier "intermediate" :code "(define (apply-antigravity? active)\n  (if active\n    (world/gravity! 0 -0.3)\n    (world/gravity! 0 0.5)))\n(apply-antigravity? #t)" :note "Toggle gravity direction based on powerup state; negative gy flips the pull.")
    (:dialect "motoi" :tier "expert" :code "(define (setup-level-physics level-name)\n  (cond\n    ((equal? level-name 'moon) (world/gravity! 0 0.1))\n    ((equal? level-name 'space) (world/gravity! 0 0))\n    (else (world/gravity! 0 0.5))))\n(setup-level-physics 'moon)" :note "Level-specific gravity tuning; zero gravity is valid and used for free-floating zones.")
  )
  :caveats ("Gravity applies to ALL entities unless individually disabled (entity/gravity-scale! id 0)." "Does not take effect on entities spawned with no physics body." "Setting to (0 0) disables gravity but does not stop momentum; entities keep their velocity." "Changes apply on the NEXT world/step, not immediately within the same frame.")
  :drawbacks ("Global only; you cannot have per-entity custom gravity directions without using world/attract! or world/repel! instead." "No automatic 'bounce' on gravity reversal; entities in flight will invert smoothly but may feel unresponsive if changed mid-jump.")
  :usecases ("Initial level setup: define the physics feel before spawning entities." "Powerup activation: antigravity boots, low-g zones, null-g chambers." "Environmental transitions: moving from Earth to Moon or space." "Arcade tuning: adjust gravity to make platforming feel snappy or floaty.")
  :related ("entity/gravity-scale!" "world/impulse!" "world/attract!" "world/repel!" "world/wind!")
  :learn (:concept "Global acceleration applied uniformly to all physics bodies; the baseline force model." :prerequisites ("entity/alive?" "world/step") :progression "After setting gravity, learn entity/gravity-scale! to fine-tune per-body weight, then world/impulse! to apply instant kicks.")
  :row-2-audit (
    (:problem "The operator wants downward gravity to apply to every entity uniformly. Applying gravity per-entity would require 100 calls; world/gravity! is the world-level parameter every entity picks up."
     :program "(world/gravity! 0 9.8)"
     :explanation "One call defines a global acceleration; every physics-participating entity accelerates downward at 9.8/frame². No per-entity setup."
     :meta "entity/accel! is per-entity (heavy for uniform gravity); world/gravity! is the global one-liner.")
    (:eng "SRE: gravity is a global; grep for it and reason about level start." :math "Constant vector added to every velocity." :cs "Global acceleration slot."))
  :row-3-dimension (
    (:setup "A global parameter that affects every member."
     :rungs (
       (:domain "world"    :code "(world/gravity! 0 9.8)")
       (:domain "linux"    :code "(define ambient '((tz . \"UTC\") (locale . \"en\"))) ambient")
       (:domain "math"     :code "(define (add-to-each xs c) (map (lambda (x) (+ x c)) xs)) (add-to-each '(1 2 3) 10)"))
     :explanation "Rung 1: global gravity. Rung 2: ambient environment. Rung 3: uniform offset. Each: 'apply this to every member'.")
    (:meta "Shape: universal parameter.")
    (:eng "SRE: globals need one clear owner." :math "Global constant of the system." :cs "Ambient parameter."))
  :row-4-proof (
    (:claim "Universality: every physics-participating entity's velocity increases by (gx, gy)/step in the direction of gravity."
     :program "(world/gravity! 0 10)\n(world/spawn 'e 0 0)\n(let ((v0 (entity/vel 'e))) (world/step)\n  (display (> (cadr (entity/vel 'e)) (cadr v0))))"
     :invariant "∀ e. participates(e) → vy(e, t+1) = vy(e, t) + gy"
     :meta "Uniform-application. Falsified if any participating entity misses gravity. Book-of-math ch 9 (uniform fields) grounds.")
    (:eng "Consequence: predictable falls." :math "Global vector-field application." :cs "Uniform per-tick delta."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/gravity! sets global downward force."
     :composition "(world/gravity! 0 9.8)\n(world/floor! 400)\n(world/spawn 'ball 100 100)\n(entity/bounce! 'ball 0.6)\n(entity/drag! 'ball 0.99)"
     :emergent "A bouncing-with-loss ball — gravity, floor, elasticity, drag. Emergent: physically-authentic bouncing."
     :meta "Physics-preset family; foundational demo. Book-of-composition ch 9 (preset bundles) grounds.")
    (:eng "SRE: presets bundle safety-critical settings." :math "Sum of forces converging to zero." :cs "Bundled setup.")))

(verb
  :name "world/hash"
  :library "world"
  :kind "rd"
  :signature "(world/hash) -> integer"
  :summary "Return a 32-bit deterministic digest of the current world's numeric state."
  :explanation "This hash is computed from the positions, velocities, and other numeric properties of all live entities. If you run the same sequence of actions and get the same hash at a given frame, the worlds are byte-for-byte identical. Used to verify replay fidelity: if a recorded game replays with the same hash at each frame, the replay is true. The hash is unaffected by entity names, tags, or scratch-data keys; only numeric simulation state matters."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define h1 (world/hash))\n(world/step)\n(define h2 (world/hash))\n(not (= h1 h2))" :note "After a step, the hash changes (unless world is empty or paused). Two hashes are never equal mid-simulation.")
    (:dialect "motoi" :tier "intermediate" :code "(define (frame-0-hash)\n  (let ((snap (world/snapshot)))\n    (world/hash)))\n(define h-before (frame-0-hash))\n(world/step)\n(define h-after (world/hash))\n(list h-before h-after)" :note "Capture hash before and after a step; later, restore the snapshot and verify it hashes to the same value.")
    (:dialect "motoi" :tier "expert" :code "(define (verify-replay frames)\n  (let ((record '()))\n    (for-each\n      (lambda (frame)\n        (world/step)\n        (set! record (cons (world/hash) record)))\n      frames)\n    (reverse record)))\n(define hashes (verify-replay (list 1 2 3 4 5)))\nhashes" :note "Build a hash sequence during live play; later, load a replay, step through it, and compare hashes frame-by-frame to verify no divergence.")
  )
  :caveats ("Hash is deterministic only if physics is fully deterministic; floating-point rounding can cause minor divergence on different CPU architectures or compile flags." "The hash does NOT include render state, camera position, or timing; only the physics simulation." "Does not hash input history or RNG state; you must track those separately if you want full replay verification." "Hash changes on EVERY frame, even if no entity moves (integration always happens).")
  :drawbacks ("Hashing every frame is a cost; if you only check hashes at sparse frames, you may miss divergence points." "A hash collision (two different states producing the same hash) is astronomically unlikely but theoretically possible; use multiple hashes or full snapshots for critical verification." "Does not help debug *why* a hash differs, only that it does; you need entity/pos queries to find the diverged entity.")
  :usecases ("Replay assertion: confirm that a recorded game replays identically." "Regression testing: detect if a code change altered the physics engine behavior." "Determinism validation: ensure a multiplayer game stays in sync across clients." "Frame-by-frame debugging: narrow down the exact frame where two simulations diverge.")
  :related ("world/snapshot" "world/restore!" "world/step" "world/reset!")
  :learn (:concept "A lightweight signature of numeric state for drift detection and replay verification." :prerequisites ("world/step" "entity/pos") :progression "Learn world/hash for verification, then world/snapshot + world/restore! to save and load full state.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants to detect determinism drift between two replay runs. A full snapshot compare is expensive; world/hash returns a small signature that can be quickly compared."
     :program "(define h1 (world/hash))\n(world/step) (world/step)\n(display (list h1 (world/hash)))"
     :explanation "The hash summarizes the world state in one small number. Two runs should produce the same sequence."
     :meta "world/snapshot preserves everything (expensive); world/hash is a compact witness. Choose hash for cheap-check.")
    (:eng "SRE: hashes power determinism CI; log them per test." :math "Hash of state." :cs "Content-derived signature."))
  :row-3-dimension (
    (:setup "Compact signature of a large state."
     :rungs (
       (:domain "world"  :code "(world/hash)")
       (:domain "git"    :code "(define (sha content) 'abc123) (sha 'content)")
       (:domain "math"   :code "(define (h xs) (apply + xs)) (h '(1 2 3))"))
     :explanation "Rung 1: world hash. Rung 2: git commit hash. Rung 3: sum digest. Each: 'small witness for a large content'.")
    (:meta "Shape: content-derived witness.")
    (:eng "SRE: hashes are audit gold; use them liberally." :math "Hash function." :cs "One-way summary."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Determinism: identical state produces identical hash."
     :program "(world/reset!)\n(world/spawn 'a 0 0)\n(define h1 (world/hash))\n(world/reset!)\n(world/spawn 'a 0 0)\n(display (equal? h1 (world/hash)))"
     :invariant "∀ world1 world2. state(world1) = state(world2) → hash(world1) = hash(world2)"
     :meta "Deterministic hash. Falsified if identical states produce different hashes. Book-of-code ch 11 (hash determinism) grounds.")
    (:eng "Consequence: hash comparison is a valid state equality test." :math "Hash function determinism." :cs "Pure function of state."))
  :row-5-emergence (
    (:base "world/hash returns a signature."
     :composition "(define expected-hashes '())\n(on-frame (lambda ()\n  (let ((h (world/hash)))\n    (set! expected-hashes (cons h expected-hashes))\n    (when (> (length expected-hashes) 100)\n      (set! expected-hashes (take expected-hashes 100))))))"
     :emergent "A replay-check log — record hash per frame for later diff. Emergent: determinism CI signal."
     :meta "Signature-log family; standard determinism-check. Book-of-composition ch 6 (snapshot streams) grounds.")
    (:eng "SRE: hash logs are the cheapest determinism check." :math "Time-series of hashes." :cs "Log + compare pattern.")))

(verb
  :name "world/impulse!"
  :library "world"
  :kind "mut"
  :signature "(world/impulse! id dvx dvy) -> void"
  :summary "Apply an instant velocity change to an entity; the primitive one-frame kick."
  :explanation "Instead of accelerating an entity over time, an impulse adds directly to its current velocity. If an entity is at velocity [vx vy] and you call (world/impulse! id 3 0), it becomes [vx+3 vy]. Impulses are the fastest way to change an entity's motion: a jump, a bullet hit, a knockback. They are also the foundation for constraint solving (world/link!, world/solve!) which uses impulses internally to satisfy distance constraints."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define player-id 'player-id)\n(world/impulse! player-id 0 -15)" :note "Jump: add upward velocity (negative gy) to the player entity without changing x-velocity.")
    (:dialect "motoi" :tier "intermediate" :code "(define player-x 'player-x)\n(define enemy 'enemy)\n(define (knockback-on-hit victim attacker-x dmg)\n  (let ((dx (- (entity/x victim) attacker-x)))\n    (world/impulse! victim (* (if (< dx 0) -1 1) 8) 5)))\n(knockback-on-hit enemy player-x 10)" :note "Knockback: impulse away from attacker, mixing horizontal and vertical kick. Direction is based on relative position.")
    (:dialect "motoi" :tier "expert" :code "(define e2 'e2)\n(define e1 'e1)\n(define (solve-constraint-once a b rest)\n  (let* ((pa (entity/pos a))\n         (pb (entity/pos b))\n         (gap (- (entity/distance a b) rest))\n         (dir-x (/ (- (car pb) (car pa)) (+ (entity/distance a b) 0.001)))\n         (dir-y (/ (- (cadr pb) (cadr pa)) (+ (entity/distance a b) 0.001))))\n    (world/impulse! a (* gap 0.5 dir-x) (* gap 0.5 dir-y))\n    (world/impulse! b (* gap -0.5 dir-x) (* gap -0.5 dir-y))))\n(solve-constraint-once e1 e2 20)" :note "Manual constraint iteration: compute gap, compute direction, apply equal-and-opposite impulses to both bodies. (Real constraint solving uses world/link! + world/solve!.)")
  )
  :caveats ("Impulse takes effect on the NEXT world/step, not immediately; velocity reads in the current frame will not reflect it." "Multiple impulses in the same frame accumulate; there is no 'only the largest' logic." "Impulse does NOT respect max-speed; you can use it to exceed entity/max-speed! if needed (useful for knockback)." "Impulse bypasses gravity; it is a pure velocity delta, not subject to gravity scale.")
  :drawbacks ("Easy to create unrealistic motion if impulses are too large; use world/attract! or world/repel! for softer, physics-based forces." "Does not integrate over time; if you want a gradual push, use world/wind! or apply impulses over multiple frames." "Repeated frame-by-frame impulses are more expensive than a single force call; batch them if possible.")
  :usecases ("Jump input: instant upward velocity on button press." "Knockback: reaction to collision, explosion, or attack hit." "Sliding/dashing: horizontal kick moves." "Constraint solving: internal use by world/link! + world/solve!." "Arcade physics: arcade games often use impulses for snappy, responsive feel.")
  :related ("world/gravity!" "world/attract!" "world/repel!" "world/wind!" "world/link!" "world/solve!" "entity/max-speed!")
  :learn (:concept "Instant velocity change; the atomic primitive for impact and constraint forces." :prerequisites ("entity/vel" "world/step") :progression "Master impulse for basic pushes, then learn world/link! + world/solve! to see how impulses build distance constraints.")
  :row-2-audit (
    (:problem "The operator needs to send an entity flying from an explosion — a discrete kick, not a continuous force. world/impulse! is instant Δv; world/attract! is continuous."
     :program "(world/impulse! 'hero 5 -20)"
     :explanation "Adds an immediate delta of (5, -20) to hero's velocity. One-shot; unlike attract/repel, no continuous computation."
     :meta "attract/repel are continuous fields; impulse! is discrete. Choose based on 'moment vs field'.")
    (:eng "SRE: impulses are gameplay-authorable events; log them." :math "Instantaneous velocity delta." :cs "Direct velocity add."))
  :row-3-dimension (
    (:setup "Discrete kick to a stateful quantity."
     :rungs (
       (:domain "world"  :code "(world/impulse! 'e 5 -20)")
       (:domain "control":code "(define (bump s) (+ s 5)) (bump 10)")
       (:domain "math"   :code "(define (add-delta v d) (map + v d)) (add-delta '(0 0) '(5 -20))"))
     :explanation "Rung 1: velocity impulse. Rung 2: bump setpoint. Rung 3: vector add. Each: 'instantaneous change'.")
    (:meta "Shape: discrete delta.")
    (:eng "SRE: kicks are discrete events; timeline-friendly." :math "Dirac-delta force." :cs "Additive delta."))
  :row-4-proof (
    (:claim "Additivity: two impulses applied in a frame equal one impulse with their sum."
     :program "(world/spawn 'a 0 0)\n(world/impulse! 'a 3 4) (world/impulse! 'a 5 6)\n(world/spawn 'b 0 0)\n(world/impulse! 'b 8 10)\n(display (equal? (entity/vel 'a) (entity/vel 'b)))"
     :invariant "∀ e Δ1 Δ2. impulse(impulse(e, Δ1), Δ2) = impulse(e, Δ1 + Δ2)"
     :meta "Additive group. Falsified if impulses don't sum. Book-of-math ch 10 (vector-space actions) grounds.")
    (:eng "Consequence: multiple impulses stack predictably." :math "Group action of translations." :cs "Commutative accumulator."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/impulse! adds a discrete kick."
     :composition "(on-message 'explosion (lambda (payload)\n  (let ((x (car payload)) (y (cadr payload)) (r (caddr payload)))\n    (for-each (lambda (id-str)\n                (let* ((p (entity/pos (string->symbol id-str)))\n                       (dx (- (car p) x)) (dy (- (cadr p) y))\n                       (d (sqrt (+ (* dx dx) (* dy dy)))))\n                  (when (< d r)\n                    (world/impulse! (string->symbol id-str) (/ dx d) (/ dy d)))))\n              (entity/all)))))"
     :emergent "An explosion — kicks every nearby entity outward. Emergent: physics explosion."
     :meta "Discrete-field family; classical 'explosion' pattern. Book-of-composition ch 12 (spatial fields) grounds; book-of-motion ch 15 (impulse response) cross-refs.")
    (:eng "SRE: explosion is a well-known pattern; audit radius." :math "Point-source discrete field." :cs "Radial impulse dispatch.")))

(verb
  :name "world/link!"
  :library "world"
  :kind "mut"
  :signature "(world/link! a b [rest] [stiff]) -> void"
  :summary "Create or update a distance constraint between two entities; a rigid or elastic rope."
  :explanation "A link forces the distance between entity a and entity b to stay near a target length (rest). If rest is omitted, it defaults to the current gap between them at the moment of the call. Stiffness stiff ranges from 0 (no constraint, entities ignore each other) to 1 (rigid rod). Higher stiffness requires more constraint-solving iterations (world/solve!) to stabilize. Links are the basis for ropes, chains, ragdoll joints, and cloth."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define e2 'e2)\n(define e1 'e1)\n(world/link! e1 e2)" :note "Link e1 and e2 at their current distance; they will try to stay this far apart (like a rope with no slack).")
    (:dialect "motoi" :tier "intermediate" :code "(define ball-entity 'ball-entity)\n(define fixed-point '(0 0))\n(define (rope-setup anchor-id ball-id)\n  (world/link! anchor-id ball-id 30 0.9))\n(rope-setup fixed-point ball-entity)\n(world/solve! 3)" :note "Create a fairly stiff rope (stiff=0.9) of length 30 between an anchor and a ball; solve 3 times per step to keep it stable.")
    (:dialect "motoi" :tier "expert" :code "(define hip 'hip)\n(define torso 'torso)\n(define neck 'neck)\n(define (build-ragdoll root segments)\n  (let loop ((prev root) (rest-segs segments))\n    (if (null? rest-segs)\n      #t\n      (let ((curr (car rest-segs)))\n        (world/link! prev curr 15 0.8)\n        (loop curr (cdr rest-segs))))))\n(build-ragdoll head (list neck torso hip))\n(world/solve! 5)" :note "Build a chain of linked bodies (neck→torso→hip) by recursively linking adjacent segments; solve with more iterations for stability.")
  )
  :caveats ("Links are not automatically removed when an entity dies; use world/find or manual tracking if you need to clean up orphaned links." "Stiffness of exactly 1.0 can be unstable if iterations are too low; values 0.8–0.95 are usually safer." "Links create no collision response by themselves; if entities overlap, they will pass through unless you handle collision separately." "Changing rest length mid-simulation: use world/link-rest! rather than re-calling world/link!.")
  :drawbacks ("Constraint solving is expensive; each iteration costs time. Real-time limits may force you to use fewer iterations." "Stiff links with low iteration counts feel laggy and bouncy; tuning is required per use case." "Broken links: once created, a link persists until one entity dies. No built-in 'break on impact' behavior." "Cycles in link graphs (e.g., A→B→C→A) can cause instability if you over-constrain; keep graphs acyclic or use low stiffness.")
  :usecases ("Ropes and cables: bridge, swing, hanging decoration." "Ragdoll physics: limbs held together by joint constraints." "Cloth simulation: grid of particles linked to neighbors." "Elastic bands: loose links with low stiffness." "Puzzle mechanics: move one piece and others follow (like tangled chain puzzles).")
  :related ("world/link-rest!" "world/solve!" "world/impulse!" "entity/alive?")
  :learn (:concept "Distance constraint: two bodies pulled toward a target separation by repeated impulses." :prerequisites ("entity/pos" "entity/distance" "world/step") :progression "Create simple links, then use world/solve! to stabilize them, then world/link-rest! to animate rest length (e.g., rope shortening).")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator needs a rope between two entities that keeps them at a fixed distance. Continuous force is unstable; world/link! creates a distance constraint the solver honors."
     :program "(world/link! 'a 'b 50 0.9)"
     :explanation "Sets a distance constraint between 'a and 'b at rest-length 50 with stiffness 0.9. The solver enforces the constraint per step."
     :meta "Continuous forces (attract/repel) oscillate; constraints are stable. Choose link for rigid connections.")
    (:eng "SRE: constraints are more stable than force-only; use them for rigid connections." :math "Distance constraint on the entity pair." :cs "Constraint entry in the solver's list."))
  :row-3-dimension (
    (:setup "Bind two variables to a target relationship."
     :rungs (
       (:domain "world"  :code "(world/link! 'a 'b 50 0.9)")
       (:domain "law"    :code "(define (nda a b) (list 'nda a b)) (nda 'alice 'bob)")
       (:domain "math"   :code "(define (linked a b d) (= (- a b) d)) (linked 3 1 2)"))
     :explanation "Rung 1: physics distance link. Rung 2: legal binding. Rung 3: algebraic relation. Each: 'these two must maintain this relationship'.")
    (:meta "Shape: relationship constraint.")
    (:eng "SRE: constraints capture invariants directly." :math "Equation over two variables." :cs "Constraint edge in a graph."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Rest-distance convergence: under enough solve iterations, distance approaches the rest length."
     :program "(world/spawn 'a 0 0) (world/spawn 'b 100 0)\n(world/link! 'a 'b 50 1.0)\n(let loop ((i 20)) (when (> i 0) (world/solve!) (loop (- i 1))))\n(display (< (abs (- (entity/distance 'a 'b) 50)) 5))"
     :invariant "∀ a b d s. lim(iter→∞) distance(a, b) → d"
     :meta "Convergence to constraint. Falsified if distance doesn't approach d. Book-of-math ch 8 (fixed points) grounds.")
    (:eng "Consequence: iterate enough for tight ropes." :math "Iterative projection onto constraint." :cs "Solver iteration convergence."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/link! creates a distance constraint."
     :composition "(define (make-chain nodes)\n  (let loop ((ns nodes))\n    (if (null? (cdr ns)) 'done\n        (begin (world/link! (car ns) (cadr ns) 10 0.9)\n               (loop (cdr ns))))))\n(make-chain '(a b c d))"
     :emergent "A chain — sequential links between nodes. Emergent: rope, chain, cloth."
     :meta "Constraint-chain family; the classic PBD rope. Book-of-composition ch 15 (constraint chains) grounds.")
    (:eng "SRE: chain length affects stability; keep short or increase iterations." :math "Sequential composition of constraints." :cs "Linked-list of solver participants.")))

(verb
  :name "world/link-rest!"
  :library "world"
  :kind "mut"
  :signature "(world/link-rest! a b rest) -> integer"
  :summary "Retarget the rest (resting) length of the link between two entities; returns the count of links changed."
  :explanation "Once a link exists between a and b, you can change its target length without destroying and recreating the link. This is the way to animate a rope shortening (a winch or pulleys), a spring extending and compressing, or a chain being reeled in. The return value is the count of how many links were updated; normally 0 or 1 (0 if no link between a and b exists, 1 if it does)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define payload-id 'payload-id)\n(define winch-id 'winch-id)\n(world/link-rest! winch-id payload-id 20)" :note "Shorten the rope between winch and payload to 20 units; payload will be drawn upward over the next few solve iterations.")
    (:dialect "motoi" :tier "intermediate" :code "(define target 'target)\n(define payload 'payload)\n(define winch 'winch)\n(define (animate-rope-pull id from to steps)\n  (let loop ((step 0))\n    (if (< step steps)\n      (begin\n        (world/link-rest! id target (+ from (* (/ (- to from) steps) step)))\n        (world/step)\n        (loop (+ step 1))))))\n(animate-rope-pull winch payload 50 10 20)" :note "Linearly interpolate rest length over 20 frames; payload rises smoothly as the rope shortens.")
    (:dialect "motoi" :tier "expert" :code "(define ball 'ball)\n(define fixed-point '(0 0))\n(define (spring-animation anchor mass rest-min rest-max period)\n  (let loop ((t 0))\n    (let* ((phase (/ (* 2 3.14159 t) period))\n           (rest (+ rest-min (* 0.5 (+ (- rest-max rest-min) (* (- rest-max rest-min) (sin phase)))))))\n      (world/link-rest! anchor mass rest)\n      (world/solve! 2)\n      (world/step)\n      (if (< t 100) (loop (+ t 1))))))\n(spring-animation fixed-point ball 15 25 20)" :note "Spring oscillation: vary rest length sinusoidally; the constraint chases the moving target, creating oscillatory motion.")
  )
  :caveats ("Does not check if the link exists; silently returns 0 if a and b were never linked." "Change takes effect on the NEXT world/solve! call, not immediately." "Rapid changes to rest (e.g., every frame by large amounts) can cause jittering if solve iterations are low." "Negative rest length is allowed but meaningless; entities will fight to stay inside each other (use 0 if you want them to collide at a point).")
  :drawbacks ("No 'smooth transition' built in; if you jump rest from 50 to 10, the constraint will be violated until it solves. Use interpolation for smooth motion." "Not useful if the link is already stiff (stiff≈1); lowering rest length on a nearly-rigid link can create bounce or oscillation." "No return value feedback on whether the change succeeded; rely on the return count to detect missing links if you need to react.")
  :usecases ("Winching: pull a payload upward by reducing rope length." "Spring oscillation: animate a springy object by varying rest length." "Extensible constraints: ropes that can shorten and lengthen dynamically." "Puzzle mechanics: shorten a link to trigger a mechanism." "Tether animation: link that shortens or lengthens on demand.")
  :related ("world/link!" "world/solve!" "world/impulse!")
  :learn (:concept "Mutable constraint target; animate link length to create pulleys, springs, and dynamic tethers." :prerequisites ("world/link!" "world/solve!") :progression "After linking, use world/link-rest! to animate the target; use high solve iterations (≥3) for smooth motion.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The rope must shorten as the winch turns. The link's rest-length was set at world/link! time; changing it requires world/link-rest!."
     :program "(world/link! 'winch 'weight 100 0.9)\n(world/link-rest! 'winch 'weight 10)"
     :explanation "The rest-length changes from 100 to 10; the solver pulls the weight up over subsequent frames."
     :meta "Removing and re-linking loses solver history; link-rest! is the in-place mutator.")
    (:eng "SRE: rest-length changes are visible in the solver's residuals." :math "Parameter update on a constraint." :cs "Mutation of a constraint parameter."))
  :row-3-dimension (
    (:setup "Mutate a target parameter of a running constraint."
     :rungs (
       (:domain "world"    :code "(world/link-rest! 'a 'b 10)")
       (:domain "control"  :code "(define (set-setpoint p x) (list 'setpoint p x)) (set-setpoint 'temp 60)")
       (:domain "math"     :code "(define (retune-eq a b d) (list a b '= d)) (retune-eq 'x 'y 5)"))
     :explanation "Rung 1: rest-length change. Rung 2: control setpoint. Rung 3: retune equation. Each: 'change the target the constraint is aiming at'.")
    (:meta "Shape: parameter mutation on a running system.")
    (:eng "SRE: parameter changes should be smooth to avoid solver shocks." :math "Continuous parameter path." :cs "In-place mutation."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Convergence to new target: after link-rest!(a, b, d'), distance approaches d' under further solves."
     :program "(world/spawn 'a 0 0) (world/spawn 'b 100 0)\n(world/link! 'a 'b 50 1.0)\n(world/link-rest! 'a 'b 20)\n(let loop ((i 30)) (when (> i 0) (world/solve!) (loop (- i 1))))\n(display (< (abs (- (entity/distance 'a 'b) 20)) 5))"
     :invariant "∀ a b d'. lim(iter→∞ after link-rest!(a, b, d')) distance(a, b) → d'"
     :meta "Retargeted convergence. Falsified if the constraint doesn't converge to the new value. Book-of-math ch 8 (fixed points) grounds.")
    (:eng "Consequence: rest-length animations are stable." :math "Reparameterized fixed point." :cs "Solver retargeting."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/link-rest! mutates a link's target distance."
     :composition "(define (winch id-a id-b speed)\n  (let loop ((d 100))\n    (world/link-rest! id-a id-b d)\n    (world/after 3 'winch-tick (list id-a id-b (- d speed)))))\n(winch 'winch 'weight 2)"
     :emergent "A winch — rest length shortens over time. Emergent: mechanical winch."
     :meta "Animated-constraint family; standard mechanical simulation. Book-of-composition ch 15 (constraint chains) grounds.")
    (:eng "SRE: winch speeds are one knob; audit the target rate." :math "Time-varying constraint parameter." :cs "Coroutine mutating a constraint.")))

(verb
  :name "world/nearest"
  :library "world"
  :kind "rd"
  :signature "(world/nearest id [kind]) -> id | 'nan"
  :summary "Return the id of the nearest OTHER entity to the given entity; optionally filter by kind."
  :explanation "Useful for AI targeting, proximity checks, and spatial queries. If kind is given, only entities of that kind are considered. If no other entity exists (or no entity of the given kind exists), returns 'nan. The search includes all alive entities except id itself; distance is Euclidean and computed using entity/distance internally."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define player-id 'player-id)\n(define nearest-foe (world/nearest player-id 'enemy))\n(if (not (eq? nearest-foe 'nan))\n  (world/impulse! player-id 5 0))" :note "Find the nearest enemy; if one exists, kick the player toward it (simple pursuit setup).")
    (:dialect "motoi" :tier "intermediate" :code "(define monster-id 'monster-id)\n(define (seek-target seeker-id search-kind max-range)\n  (let ((target (world/nearest seeker-id search-kind)))\n    (if (not (eq? target 'nan))\n      (let ((dist (entity/distance seeker-id target)))\n        (if (<= dist max-range)\n          target\n          'out-of-range))\n      'not-found)))\n(seek-target monster-id 'player 100)" :note "Find nearest entity of a kind AND check if it is within max-range; return the target or a reason code.")
    (:dialect "motoi" :tier "expert" :code "(define npc-id 'npc-id)\n(define guard-id 'guard-id)\n(define (pick-threat npc threat-kinds)\n  (let loop ((kinds threat-kinds) (best 'nan) (best-dist 999999))\n    (if (null? kinds)\n      best\n      (let* ((cand (world/nearest npc-id (car kinds)))\n             (dist (if (eq? cand 'nan) 999999 (entity/distance npc-id cand))))\n        (loop (cdr kinds)\n              (if (< dist best-dist) cand best)\n              (if (< dist best-dist) dist best-dist))))))\n(pick-threat guard-id '(player intruder))" :note "Find the nearest threat of multiple kinds (player or intruder); return whichever is closer. Useful for NPC threat prioritization.")
  )
  :caveats ("Returns 'nan, not null or #f; always check with (eq? result 'nan)." "Does not check visibility or line-of-sight; only straight-line distance matters." "Slightly expensive for large entity counts (O(n) per call); cache the result if you query multiple times per frame." "Returns the id itself if id is dead (entity/alive? returns #f), but that's rare because dead entities are soon garbage-collected.")
  :drawbacks ("No distance returned; you must call entity/distance again if you need the actual distance." "No tie-breaking for entities at exactly the same distance; one is chosen arbitrarily." "Kind filter is an exact symbol match; no wildcards or parent classes.")
  :usecases ("AI targeting: NPC picks nearest enemy to attack." "Proximity checks: trigger a script when player gets close to an object." "Social mechanics: NPC finds nearest friend or enemy." "Spatial queries: 'who is closest to me of type X?'.")
  :related ("world/find" "world/count" "entity/distance" "entity/kind" "group/find")
  :learn (:concept "Spatial query: O(n) search for the closest entity, optionally filtered by kind." :prerequisites ("entity/alive?" "entity/kind" "entity/distance") :progression "Use world/nearest for simple proximity; then learn world/find to get all entities of a kind (not just the nearest).")
  :row-2-audit (
    (:problem "An AI needs to know the closest player. entity/distance-per-id loops are O(n); world/nearest is the framework's spatial primitive."
     :program "(define target (world/nearest 'orc 'player))\n(display target)"
     :explanation "Returns the id of the closest player-kind entity to 'orc. Ready for chase logic."
     :meta "Manual loop with entity/distance is verbose; world/nearest is the direct answer.")
    (:eng "SRE: nearest is O(n); build a spatial hash if performance matters." :math "argmin of distance." :cs "Nearest-neighbor query."))
  :row-3-dimension (
    (:setup "Nearest match in a metric space."
     :rungs (
       (:domain "world"  :code "(world/nearest 'orc 'player)")
       (:domain "gps"    :code "(define (nearest-neighbor p) 'ny) (nearest-neighbor '(40 -74))")
       (:domain "math"   :code "(define (argmin xs f) (car xs)) (argmin '(1 2 3) abs)"))
     :explanation "Rung 1: nearest player. Rung 2: geographic nearest neighbor. Rung 3: argmin. Each: 'return the member with minimum distance/metric'.")
    (:meta "Shape: nearest-neighbor lookup.")
    (:eng "SRE: nearest queries drive steering and hit-select." :math "argmin under a metric." :cs "1-NN query."))
  :row-4-proof (
    (:claim "Nearness: for the returned id, no other candidate is closer."
     :program "(world/spawn 'orc 0 0)\n(world/spawn 'player 10 0)\n(world/spawn 'player 100 0)\n(display (eq? 'player (entity/kind (world/nearest 'orc 'player))))"
     :invariant "∀ src k. ∀ other in kind(k). distance(src, nearest(src, k)) ≤ distance(src, other)"
     :meta "Minimum-distance guarantee. Falsified if a closer candidate exists. Book-of-math ch 7 (metric spaces) grounds.")
    (:eng "Consequence: the returned target is always the tightest." :math "Global minimum on the domain." :cs "Complete linear scan."))
  :row-5-emergence (
    (:base "world/nearest finds the closest entity."
     :composition "(on-frame (lambda ()\n  (world/each (lambda (id)\n    (when (eq? (entity/kind id) 'orc)\n      (let ((target (world/nearest id 'player)))\n        (when target (world/attract! target id 30))))))))"
     :emergent "A chase-AI — orcs pursue the nearest player. Emergent: aggressive-mob behavior."
     :meta "Steering-behavior family; standard AI pursue. Book-of-composition ch 17 (behavior composition) grounds.")
    (:eng "SRE: chase behaviors bound target search per frame; profile." :math "Attractive field with mobile source." :cs "Per-tick 1-NN + apply.")))

(verb
  :name "world/render"
  :library "world"
  :kind "null"
  :signature "(world/render [pitch]) -> void"
  :summary "Draw all entities to the canvas at their current world positions, scaled by pitch (default 1)."
  :explanation "Iterates through all alive entities in the world, looks up their shape (stored as __shape in entity data), and paints that shape to the dot-matrix surface. The pitch parameter scales the world-to-canvas conversion (pitch=2 draws each entity at half size). Each entity's draw uses its rotation (__spin), scale (__sx, __sy), and vertical offset (__dy). Flower shapes are painted using the internal flower painting routines; other shapes are skipped."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/render)" :note "Draw all entities at their world position with pitch=1 (one world unit = one canvas pixel).")
    (:dialect "motoi" :tier "intermediate" :code "(world/render 2)" :note "Draw all entities at half scale (pitch=2); useful for zooming out to see a large world on a small screen.")
    (:dialect "motoi" :tier "expert" :code "(define (render-with-camera pitch cam-x cam-y)\n  (camera-pan-to cam-x cam-y)\n  (world/render pitch))\n(render-with-camera 1 100 100)" :note "Pan camera to (100, 100), then render world. (In practice, camera/render is built in; this shows the composition pattern.)")
  )
  :caveats ("Pitch must be positive; negative or zero pitch produces undefined behavior." "Only entities with a __shape in their data are drawn; any entity without a shape is invisible." "Does not handle transparency, depth sorting, or layer culling; all shapes are drawn in birth order." "Render happens *after* a step (or independently), so entities drawn are at their current frame position, not next frame.")
  :drawbacks ("Performance degrades with entity count; O(n) render cost per frame." "No built-in frustum culling; off-screen entities are still processed (use a view-limiting camera or manual culling if needed)." "Pitch is global; you cannot draw different regions at different scales in one call." "No return value; no way to count how many entities were actually drawn.")
  :usecases ("Main game loop: render the world each frame after stepping." "Zoom effect: vary pitch to zoom in and out." "Multi-scale rendering: render the world twice at different pitches to different canvases." "Replay playback: render each saved world state.")
  :related ("world/step" "entity/set!" "camera-pan-to" "surface-paint-dots" "world/snapshot")
  :learn (:concept "Draw all entities to canvas using their shape data; pitch scales the view." :prerequisites ("world/spawn" "entity/set!") :progression "Render a simple world, then use pitch to zoom, then use camera-* verbs to pan and follow.")
  :row-2-audit (
    (:problem "The operator needs to draw the world to the framebuffer once per frame. Per-entity drawing loops are heavy; world/render is the framework's batched paint call."
     :program "(on-frame (lambda () (world/step) (world/render)))"
     :explanation "One call per frame: step physics, render. The renderer traverses all entities and paints them in one pass."
     :meta "Manual per-entity draw is slower and easier to leave incomplete; world/render is complete and one-line.")
    (:eng "SRE: render costs scale with entity count; profile." :math "Traversal of the entity set." :cs "Batch paint."))
  :row-3-dimension (
    (:setup "Full-pass rendering of a scene."
     :rungs (
       (:domain "world"  :code "(world/render)")
       (:domain "browser":code "(define (paint dom) 'painted) (paint 'body)")
       (:domain "math"   :code "(define (project scene camera) 'image) (project '() 'cam)"))
     :explanation "Rung 1: framebuffer paint. Rung 2: browser paint. Rung 3: scene projection. Each: 'produce output from all sources'.")
    (:meta "Shape: full-pass output production.")
    (:eng "SRE: full-pass renders bound frame-rate; profile." :math "Function from scene to image." :cs "Rendering pipeline."))
  :row-4-proof (
    (:claim "Idempotence within a frame: two consecutive renders without state change produce the same image."
     :program "(world/render) (world/render)\n(display 'rendered-twice-equal)"
     :invariant "∀ world. (no state change between renders) → image(t1) = image(t2)"
     :meta "Deterministic renderer. Falsified if two renders differ without a state change. Book-of-code ch 4 (referential transparency) grounds.")
    (:eng "Consequence: renders are safe to repeat for debugging." :math "Pure function of state." :cs "Deterministic paint."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/render paints all entities."
     :composition "(define (game-loop)\n  (world/step)\n  (world/render)\n  (world/after 1 'game-loop 'again))\n(on-message 'game-loop (lambda (_) (game-loop)))\n(game-loop)"
     :emergent "A game loop — step, render, schedule next. Emergent: main loop."
     :meta "Game-loop family; foundational pattern. Book-of-composition ch 13 (temporal composition) grounds.")
    (:eng "SRE: loop pacing is the frame-budget knob." :math "Fixed-point iteration in the time domain." :cs "Repeat: update + render.")))

(verb
  :name "world/repel!"
  :library "world"
  :kind "mut"
  :signature "(world/repel! id cx cy strength) -> void"
  :summary "Push an entity away from a point (cx, cy) with a softened inverse-square force; like an explosion or repulsor field."
  :explanation "Applies a force to entity id in the direction away from the point (cx, cy), with magnitude that decreases with distance (inverse-square law, softened to avoid singularities). The force is accumulated in the world's acceleration buffer and applied during the next world/step. High strength values create a strong push; low values create a gentle force field. This is the complement to world/attract!: repel pushes, attract pulls."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define explosion-y 'explosion-y)\n(define explosion-x 'explosion-x)\n(define enemy-id 'enemy-id)\n(world/repel! enemy-id explosion-x explosion-y 100)" :note "Push enemy away from an explosion at (explosion-x, explosion-y) with strength 100.")
    (:dialect "motoi" :tier "intermediate" :code "(define player 'player)\n(define (push-back-on-hit victim attacker-pos strength)\n  (world/repel! victim (car attacker-pos) (cadr attacker-pos) strength))\n(push-back-on-hit player '(50 50) 50)" :note "Unpack attacker position from a pair and repel the player away from it.")
    (:dialect "motoi" :tier "expert" :code "(define (repulsor-field entities field-center field-strength)\n  (for-each\n    (lambda (id)\n      (world/repel! id (car field-center) (cadr field-center) field-strength))\n    entities))\n(repulsor-field (group/find 'projectile) '(200 150) 75)" :note "Apply repulsion to all projectiles in a group, pushing them away from a field center (like a shield).")
  )
  :caveats ("Force is added to acceleration, not velocity; it takes a frame to manifest as motion." "Very close to the point (cx, cy), the repulsion is capped (softened); there is no infinite force at distance 0." "Strength can be negative; negative repel is identical to attract. (Use world/attract! for clarity.)" "Applies EVERY frame while the entity and the point exist; to apply once, use world/impulse! instead.")
  :drawbacks ("Multiple repulsor fields (multiple calls) accumulate; you must manage total force to avoid runaway acceleration." "Inverse-square softening can feel artificial; if you want linear falloff, use world/impulse! scaled by distance manually." "Does not respect max-speed; repulsion can push an entity beyond its speed limit." "Expensive in tight loops; repelling 100 entities from 10 sources is 1000 force calcs per step.")
  :usecases ("Explosions: push nearby entities outward." "Repulsor shields: field that pushes enemies away." "Boss arenas: central repulsor forces enemies to the edges." "Crowd control: push multiple entities away from a point." "Environmental hazards: hot spots or radiation zones that push entities away.")
  :related ("world/attract!" "world/impulse!" "world/wind!" "world/gravity!" "entity/gravity-scale!")
  :learn (:concept "Softened inverse-square force away from a point; the basis for explosion and repulsor effects." :prerequisites ("world/step" "entity/pos") :progression "Use world/repel! for simple explosions, then combine with world/attract! to create balanced force fields or orbital mechanics.")
  :row-2-audit (
    (:problem "The player carries a repel-field power-up that pushes enemies away. The operator needs a continuous outward force from the player position; world/repel! is the mirror of world/attract!."
     :program "(on-frame (lambda ()\n  (for-each (lambda (id-str)\n              (world/repel! 'player (string->symbol id-str) 40))\n            (world/find 'enemy))))"
     :explanation "Each frame, every enemy gets a push AWAY from the player. Force scales with distance."
     :meta "world/attract! pulls; world/repel! pushes. Choose based on direction of the force.")
    (:eng "SRE: repellers can eject entities out-of-world; add bounds." :math "Repulsive vector field." :cs "Per-tick push force."))
  :row-3-dimension (
    (:setup "A source pushes a target away with a distance-parametric force."
     :rungs (
       (:domain "world"    :code "(world/repel! 'a 'b 40)")
       (:domain "physics"  :code "(define (coulomb q1 q2 r) (/ (* q1 q2) (* r r))) (coulomb 1 1 2)")
       (:domain "control"  :code "(define (push-away from to k) (list 'push from to k)) (push-away 0 10 0.5)"))
     :explanation "Rung 1: repel verb. Rung 2: Coulomb repulsion. Rung 3: push setpoint. Each: 'move target AWAY from source proportional to distance function'.")
    (:meta "Shape: distance-parametric divergence.")
    (:eng "SRE: repulsors diverge without bounds; clip velocity or region." :math "Repulsive field." :cs "Vector-field emitter."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Divergence: under repel with positive strength, distance grows over time."
     :program "(world/spawn 'a 0 0) (world/spawn 'b 30 0)\n(world/repel! 'a 'b 50)\n(let ((d0 (entity/distance 'a 'b)))\n  (world/step) (world/step)\n  (display (> (entity/distance 'a 'b) d0)))"
     :invariant "∀ src tgt s > 0. distance(src, tgt, t+1) > distance(src, tgt, t)"
     :meta "Monotonic divergence. Falsified if distance decreases or stays flat. Book-of-motion ch 9 (repulsor dynamics) grounds.")
    (:eng "Consequence: repellers eventually eject targets." :math "Repulsive dynamics." :cs "Positive velocity delta radially outward."))
  :row-5-emergence (
    (:base "world/repel! pushes target from source."
     :composition "(define (place-repellers)\n  (world/spawn 'obstacle-1 200 200)\n  (world/spawn 'obstacle-2 400 400))\n(on-frame (lambda ()\n  (for-each (lambda (id-str)\n              (let ((id (string->symbol id-str)))\n                (world/repel! 'obstacle-1 id 30)\n                (world/repel! 'obstacle-2 id 30)))\n            (world/find 'enemy))))"
     :emergent "A path-of-least-resistance — enemies naturally route around obstacles. Emergent: implicit pathfinding."
     :meta "Potential-field family; classical robotics steering. Book-of-composition ch 12 (spatial fields) grounds.")
    (:eng "SRE: superposition of repellers creates emergent paths; audit for local minima." :math "Sum of repulsive fields." :cs "Field superposition.")))

(verb
  :name "world/reset!"
  :library "world"
  :kind "mut"
  :signature "(world/reset!) → void"
  :summary "Clears all entities, timers, tweens, and input state from the world."
  :explanation "world/reset! wipes the entire simulation clean: every spawned entity is despawned, all pending frame-timers are cancelled, all active tweens are halted, and input history is flushed. Use this to transition between scenes, restart a level, or reset after a game-over. The world frame counter does NOT reset (it accumulates for replay integrity)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/reset!)\n(world/spawn 'player 100 100)" :note "Reset clears everything, then spawn a fresh player.")
    (:dialect "motoi" :tier "intermediate" :code "(define (restart-level)\n  (world/reset!)\n  (world/gravity! 0 9.8)\n  (world/spawn 'player 200 50)\n  (world/spawn 'goal 400 50))\n(restart-level)" :note "Helper to reset and rebuild a level from scratch.")
    (:dialect "motoi" :tier "expert" :code "(define ctx '())\n(define (game-over-handler ctx)\n  (let ((score (ctx-result ctx)))\n    (world/reset!)\n    (display (list \"Final score:\" score))\n    (next 'show-menu ctx)))\n(game-over-handler ctx)" :note "Reset within a state transition; clean slate before moving to menu.")
  )
  :caveats ("Invalidates ALL entity ids in flight; holding an id after reset() and querying it will yield 'entity-not-found." "Does not reset the world frame counter; frame numbering continues for determinism." "Input buffer is flushed; no lingering keypresses after reset." "Synchronous; blocks until all cleanup is done (usually fast).")
  :drawbacks ("Nuclear option; there is no selective entity despawn. Use entity/despawn! if you need fine-grained cleanup." "Camera state is NOT reset; call camera-home or camera-set! to reposition." "Custom per-entity data stored via entity/set! is lost; pre-save with world/snapshot if needed.")
  :usecases ("Level restart after player death." "Transition between game scenes or menus." "Testing or demo reset in interactive development." "Clearing a sandbox world for a fresh simulation run.")
  :related ("world/snapshot" "world/restore!" "entity/despawn!" "world/step")
  :learn (:concept "Total world state flush; the reset primitive." :prerequisites ("world/spawn" "entity/alive?") :progression "Learn world/snapshot and world/restore! for selective state capture; then study world/step for frame-by-frame simulation.")
  :row-2-audit (
    (:problem "The level ended; the operator needs to wipe every entity, timer, and camera setting to prepare for the next level. Iterating and despawning is tedious; world/reset! is the atomic flush."
     :program "(world/reset!)\n(display (world/count))"
     :explanation "Every entity, timer, camera setting is cleared in one call. Count reads zero after."
     :meta "Manual cleanup misses timer queues and camera state; world/reset! wipes them all.")
    (:eng "SRE: reset is safety-critical; log the event." :math "State identity: current → initial." :cs "Full state flush."))
  :row-3-dimension (
    (:setup "Flush all state of a container."
     :rungs (
       (:domain "world"    :code "(world/reset!)")
       (:domain "shell"    :code "(define (reboot) (list 'system 'restarted)) (reboot)")
       (:domain "math"     :code "(define (empty s) '()) (empty '(1 2 3))"))
     :explanation "Rung 1: world flush. Rung 2: reboot. Rung 3: empty set. Each: 'return to the initial state'.")
    (:meta "Shape: total flush.")
    (:eng "SRE: flushes are events; log them." :math "Identity mapping to the initial state." :cs "State reset."))
  :row-4-proof (
    (:claim "Post-reset invariant: entity count is zero after reset."
     :program "(world/spawn 'a 0 0) (world/spawn 'b 0 0)\n(world/reset!)\n(display (= 0 (world/count)))"
     :invariant "∀ world. count(reset!(world)) = 0"
     :meta "Zero-after-reset. Falsified if any entity persists. Book-of-code ch 6 (reset semantics) grounds.")
    (:eng "Consequence: reliable state cleanup." :math "Absorbing element in the state monoid." :cs "Zero-state."))
  :row-5-emergence (
    (:base "world/reset! clears world state."
     :composition "(define (load-level n)\n  (world/reset!)\n  (world/gravity! 0 9.8)\n  (world/floor! 400)\n  (world/spawn 'player 100 100)\n  (display (list 'level n 'loaded)))\n(load-level 1)"
     :emergent "A level-loader — reset then rebuild. Emergent: level transition."
     :meta "State-machine-transition family; standard level transitions. Book-of-composition ch 13 (state-reset composition) grounds.")
    (:eng "SRE: level loaders are level-designer surface." :math "Composition of flush + spawn." :cs "State transition function.")))

(verb
  :name "world/restore!"
  :library "world"
  :kind "mut"
  :signature "(world/restore! snapshot) → void"
  :summary "Replace the entire world state from a prior snapshot; malformed snapshot → 'bad-arg."
  :explanation "world/restore! reverts the simulation to a saved checkpoint. You capture a snapshot with world/snapshot (an opaque blob), then pass it to restore! to roll back all entities, forces, timers, and frame counter. This is the twin of snapshot: together they form a checkpoint–restore pair. Use this for replays, undo, or branching exploration. If the snapshot is corrupted or from an incompatible world version, the verb returns the symbol 'bad-arg and does not mutate."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define snap (world/snapshot))\n(world/spawn 'enemy 300 200)\n(world/restore! snap)\n(world/count)" :note "Snapshot before spawning, restore erases the enemy; count is back to zero.")
    (:dialect "motoi" :tier "intermediate" :code "(define player-id 'player-id)\n(define (try-move-player id dx dy)\n  (let ((before (world/snapshot)))\n    (entity/set-pos! id (+ (entity/x id) dx) (+ (entity/y id) dy))\n    (if (world/count 'obstacle)\n      (world/restore! before)  ;; revert if collision\n      (display \"Moved OK\"))))\n(try-move-player player-id 10 0)" :note "Speculative move: snapshot, test, restore if invalid.")
    (:dialect "motoi" :tier "expert" :code "(define (rewind-to-checkpoint key)\n  (let ((snap (entity/ref (world/find 'checkpoint-store) key)))\n    (cond ((equal? snap 'nan) (escalate 'no-checkpoint-saved '()))\n          (else (world/restore! snap)\n                (next 'continue-play ctx)))))\n(rewind-to-checkpoint 'level-2-halfway)" :note "Retrieve a saved checkpoint from an entity's data store and restore the world.")
  )
  :caveats ("Snapshot is opaque; you cannot inspect or merge two snapshots." "Frame counter is restored; if you restore an old snapshot, frame numbering jumps backward (affects any age-based logic)." "Bad snapshot argument returns 'bad-arg but does NOT throw; check the return value." "Restoring inside a world/step is undefined; only restore between frames.")
  :drawbacks ("Snapshots are memory-heavy (include all entity state); storing many is expensive." "No incremental snapshots or delta compression; each is a full copy." "Restoring flushes the undo stack; you cannot redo after a restore.")
  :usecases ("Undo/redo in puzzle or strategy games." "Checkpoint save/load for long campaigns." "Replaying a recorded game from a saved point." "Testing branching behavior without replaying the whole sequence.")
  :related ("world/snapshot" "world/reset!" "world/tape-save" "world/tape-replay")
  :learn (:concept "State checkpoint and restore; reversal without redo." :prerequisites ("world/snapshot" "world/spawn" "entity/alive?") :progression "Combine with world/tape-save for full replay infrastructure; study world/hash for determinism validation.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The player died; the operator wants to rewind to the last checkpoint. world/snapshot captured the state; world/restore! reinstates it."
     :program "(define save-state (world/snapshot))\n(world/step) (world/step)\n(world/restore! save-state)\n(display 'restored)"
     :explanation "Snapshot captures; restore reinstates. The world reverts to the exact prior state."
     :meta "world/reset! goes to initial state; world/restore! goes to a saved state. Choose based on target-state.")
    (:eng "SRE: restore is safety-critical for save systems." :math "Assign world = snapshot." :cs "Full state deserialization."))
  :row-3-dimension (
    (:setup "Reinstate a captured state."
     :rungs (
       (:domain "world"  :code "(world/restore! save)")
       (:domain "vm"     :code "(define (load-snapshot s) (list 'restored s)) (load-snapshot 'save-1)")
       (:domain "math"   :code "(define (rollback state prev) prev) (rollback 'now 'past)"))
     :explanation "Rung 1: world restore. Rung 2: VM snapshot load. Rung 3: rollback. Each: 'set the state to the captured value'.")
    (:meta "Shape: state reinstatement.")
    (:eng "SRE: restores must be tested end-to-end." :math "Assignment from snapshot." :cs "State deserialize."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Round-trip: after snapshot then restore, the world state equals the snapshot."
     :program "(world/spawn 'a 100 100)\n(define s (world/snapshot))\n(world/spawn 'b 200 200)\n(world/restore! s)\n(display (= 1 (world/count)))"
     :invariant "∀ world. restore!(snapshot(world), world) yields state = snapshot"
     :meta "Round-trip fidelity. Falsified if restore doesn't match snapshot. Book-of-code ch 11 (snapshot semantics) grounds.")
    (:eng "Consequence: saves are trustworthy." :math "Inverse operation to snapshot." :cs "Serialization round-trip."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/restore! reinstates a snapshot."
     :composition "(define checkpoint #f)\n(on-message 'checkpoint (lambda (_) (set! checkpoint (world/snapshot))))\n(on-message 'death (lambda (_) (when checkpoint (world/restore! checkpoint))))"
     :emergent "A checkpoint/rewind system — save on checkpoint, restore on death. Emergent: save/reload."
     :meta "Save-state family; standard game save mechanism. Book-of-composition ch 6 (snapshot streams) grounds.")
    (:eng "SRE: save systems need integrity testing; hash compare." :math "State-machine with backup transitions." :cs "Checkpoint + rollback pattern.")))

(verb
  :name "world/snapshot"
  :library "world"
  :kind "rd"
  :signature "(world/snapshot) → snapshot"
  :summary "Capture an opaque, restorable copy of the entire world state."
  :explanation "world/snapshot freezes the world at this instant: all entity positions, velocities, FSM states, collision state, timers, and forces are encoded into an opaque blob. Pass this blob to world/restore! later to roll back. Snapshots are immutable once created; they do not change if the world evolves. Use snapshots to implement checkpoints, undo, branching exploration, or determinism validation (paired with world/hash)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define snap1 (world/snapshot))\n(display \"Snapshot taken\")" :note "Capture the world; snapshot is now a referenceable value.")
    (:dialect "motoi" :tier "intermediate" :code "(define (safe-simulation steps)\n  (let ((snap (world/snapshot)))\n    (for-each (lambda (_) (world/step)) (map (lambda (i) i) (list steps)))\n    (display (world/hash))  ;; log hash for replay\n    snap))\n(define s (safe-simulation 10))" :note "Snapshot before a batch of steps; record hash; snapshot is still valid.")
    (:dialect "motoi" :tier "expert" :code "(define (explore-branch option-id)\n  (let ((branch-point (world/snapshot)))\n    (define (revert) (world/restore! branch-point))\n    (define (commit) (revert))  ;; no-op; changes persist\n    (case option-id\n      ((1) (world/spawn 'path-a 100 100) (list 'committed (world/hash)))\n      ((2) (revert) (world/spawn 'path-b 100 100) (list 'committed (world/hash)))\n      (else (revert) (list 'cancelled (world/hash))))))\n(explore-branch 1)" :note "Use snapshot as a branch point; selectively revert to explore alternatives.")
  )
  :caveats ("Snapshot is a deep copy; creating many snapshots in a loop will consume memory quickly." "The snapshot is NOT invalidated if the world is later reset or restored; it captures a fixed point in time." "Snapshot does not capture user-defined entity data stored outside the entity record (though entity/ref data IS included)." "Snapshots are not portable across world resets or interpreter restarts.")
  :drawbacks ("Memory overhead; each snapshot includes all live entities and state." "No compression or delta snapshots; each is independent." "Opaque to Scheme; you cannot inspect or selectively restore parts.")
  :usecases ("Checkpoint systems in roguelike or permadeath games." "Undo stacks for turn-based games." "Determinism testing (snapshot, step, hash; compare replays)." "Branch exploration in puzzle solvers.")
  :related ("world/restore!" "world/reset!" "world/hash" "world/tape-save")
  :learn (:concept "Immutable world state capture; the read half of snapshot–restore." :prerequisites ("world/spawn" "world/step") :progression "Learn world/restore! to complete the pair; then study world/hash for determinism assertions.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants a save-file the player can reload. world/snapshot serializes the current world state to a value the operator can store."
     :program "(define save (world/snapshot))\n(display save)"
     :explanation "One call captures every entity, timer, and camera value. The value is now safe to persist."
     :meta "world/hash is a signature (verification); world/snapshot is a full capture (restoration).")
    (:eng "SRE: snapshots cost memory ∝ world size; audit at capture." :math "Full state serialization." :cs "Serialize world."))
  :row-3-dimension (
    (:setup "Full-fidelity capture of state."
     :rungs (
       (:domain "world"  :code "(world/snapshot)")
       (:domain "db"     :code "(define (backup db) (list 'backup db)) (backup 'main)")
       (:domain "math"   :code "(define (freeze x) x) (freeze '(1 2 3))"))
     :explanation "Rung 1: world snapshot. Rung 2: db backup. Rung 3: freeze. Each: 'capture the current state as a value'.")
    (:meta "Shape: state capture.")
    (:eng "SRE: snapshots are the foundation of save systems." :math "Full state read." :cs "Serialize."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Independence: two snapshots taken with no state change produce equal values."
     :program "(define s1 (world/snapshot))\n(define s2 (world/snapshot))\n(display (equal? s1 s2))"
     :invariant "∀ world. (no state change) → snapshot(t1) = snapshot(t2)"
     :meta "Read stability. Falsified if snapshots differ without state change. Book-of-code ch 4 (read stability) grounds.")
    (:eng "Consequence: snapshot is safe to test/repeat." :math "Pure function of state." :cs "Deterministic capture."))
  :row-5-emergence (
    (:base "world/snapshot captures full state."
     :composition "(define history '())\n(on-frame (lambda ()\n  (set! history (cons (world/snapshot) history))\n  (when (> (length history) 300)\n    (set! history (take history 300)))))"
     :emergent "A rewind buffer — snapshot every frame; the newest 300 snapshots enable rewind. Emergent: time-scrub."
     :meta "Snapshot-buffer family; standard time-scrub mechanism. Book-of-composition ch 6 (snapshot streams) grounds.")
    (:eng "SRE: snapshot buffers cost memory linear in frames; bound them." :math "Time-indexed sequence of states." :cs "Ring buffer of snapshots.")))

(verb
  :name "world/solve!"
  :library "world"
  :kind "mut"
  :signature "(world/solve! [iters]) → frame"
  :summary "Project all constraint links to satisfy distance and rest goals; optional iteration count (1–64) → current frame."
  :explanation "world/solve! iteratively relaxes all active links (distance constraints, pin joints, rest links) toward their target lengths and configurations. Each call to solve! runs a fixed number of constraint-projection passes (default 1, max 64) to push linked entities toward equilibrium. This is typically called once per world/step as part of the physics pipeline, but you can call it explicitly for multi-step constraint solving or interactive deformation. Returns the current frame number."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/spawn 'anchor 100 100)\n(world/spawn 'bob 150 100)\n(world/link! (world/find 'anchor) (world/find 'bob) 50)\n(world/solve!)" :note "Create a linked pair and solve constraints once.")
    (:dialect "motoi" :tier "intermediate" :code "(define (multi-step-solve steps iters)\n  (for-each (lambda (_) \n              (world/step)\n              (world/solve! iters))\n            (list steps)))\n(multi-step-solve 5 4)" :note "Each frame: step physics, then solve constraints with 4 iterations for stiffness.")
    (:dialect "motoi" :tier "expert" :code "(define (input-pressed? btn) #f)\n(define user-input '())\n(define (interactive-constraint-relax user-input)\n  (let ((id (world/find 'cursor)))\n    (when (input-pressed? 'mouse-drag)\n      (entity/set-pos! id (input/x) (input/y))))\n  (world/step)\n  (world/solve! 8)  ;; high iteration count for real-time feel\n  (world/frame))\n(interactive-constraint-relax user-input)" :note "Move a constrained node interactively; high solver iterations keep links tight.")
  )
  :caveats ("solve! must be called AFTER world/step in the frame to resolve new constraints." "Iteration count > 64 is clamped to 64; you cannot request unbounded iterations." "Links must be created with world/link! or world/link-rest! before solve! can affect them." "Solving does not advance time or apply forces; it only corrects positions.")
  :drawbacks ("High iteration counts (>16) add noticeable CPU cost per frame." "Constraint chains (A–B–C) require multiple iterations to converge; deep chains are slow." "Conflicting constraints (impossible link geometry) may oscillate or jitter instead of settling." "solve! does not handle all constraint types; some require entity/set-pos! or manual impulse application.")
  :usecases ("Physics-based ropes, chains, and soft-body deformation." "Pin-joint interactive manipulation (dragging nodes)." "Cloth or fabric simulation with distance constraints." "Real-time mechanical linkages (gears, levers, joints).")
  :related ("world/step" "world/link!" "world/link-rest!" "world/impulse!" "entity/set-pos!")
  :learn (:concept "Iterative constraint projection; the solver phase of the physics pipeline." :prerequisites ("world/spawn" "world/link!" "world/step") :progression "Combine with world/link-rest! for rest angles; study world/impulse! for direct force control.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The rope is stretchy — the operator needs to run additional solver iterations per frame to tighten it. world/step runs one solve pass; world/solve! is the raw call the operator can repeat."
     :program "(world/step)\n(world/solve!)\n(world/solve!)"
     :explanation "After step, two extra solves tighten the constraints further. Rope appears more rigid."
     :meta "world/step is the standard tick; world/solve! is the manual iteration knob.")
    (:eng "SRE: solve iterations trade CPU for constraint tightness." :math "Iterative constraint projection." :cs "One Gauss-Seidel pass."))
  :row-3-dimension (
    (:setup "One iteration of a convergent process."
     :rungs (
       (:domain "world"  :code "(world/solve!)")
       (:domain "linear" :code "(define (jacobi-step x A b) x) (jacobi-step '(0) '((1)) '(1))")
       (:domain "math"   :code "(define (newton-step x f g) (- x (/ (f x) (g x)))) (newton-step 1 (lambda (x) x) (lambda (x) 1))"))
     :explanation "Rung 1: constraint solve pass. Rung 2: Jacobi iteration. Rung 3: Newton step. Each: 'one step of a convergent iteration'.")
    (:meta "Shape: single iterative step.")
    (:eng "SRE: iterative solvers approach a fixed point; monitor residuals." :math "Iteration step." :cs "Convergent-loop primitive."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Monotone tightening: after solve!, constraint residual is ≤ residual before."
     :program "(world/spawn 'a 0 0) (world/spawn 'b 100 0)\n(world/link! 'a 'b 50 1.0)\n(let ((d0 (entity/distance 'a 'b))) (world/solve!)\n  (display (<= (abs (- (entity/distance 'a 'b) 50)) (abs (- d0 50)))))"
     :invariant "∀ world. residual(solve!(world)) ≤ residual(world)"
     :meta "Non-expansive iteration. Falsified if solve increases residual. Book-of-math ch 8 (contraction mappings) grounds.")
    (:eng "Consequence: safe to iterate solve!." :math "Contraction toward fixed point." :cs "Non-expansive step."))
  :row-5-emergence (
    (:base "world/solve! applies one solver iteration."
     :composition "(on-frame (lambda ()\n  (world/step)\n  (let loop ((i 4))\n    (when (> i 0) (world/solve!) (loop (- i 1))))))"
     :emergent "A tight-rope simulation — extra solves keep the rope from stretching. Emergent: rigid rope."
     :meta "Iterative-refinement family; standard PBD stiffness. Book-of-composition ch 15 (constraint chains) grounds.")
    (:eng "SRE: iteration counts are performance knobs." :math "Fixed-point iteration." :cs "Loop of solver steps.")))

(verb
  :name "world/spawn"
  :library "world"
  :kind "mut"
  :signature "(world/spawn kind x y [w] [h]) → id"
  :summary "Create a new entity of a given kind at (x, y) with optional width/height → entity id; bad coordinate → 'bad-arg."
  :explanation "world/spawn instantiates a new actor (entity) in the simulation. The kind is a symbol naming the entity type; x and y are the starting position. Optional width and height define the entity's AABB (bounding box); if omitted, a default 1×1 box is used. The verb returns a unique id that can be used with entity/* verbs to query or modify the entity. Bad coordinates (NaN, Infinity, out-of-bounds) return 'bad-arg instead. Spawned entities start alive, untagged, and in a neutral FSM state."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define p (world/spawn 'player 100 100))\n(display p)" :note "Spawn a player at (100, 100); p is now a valid entity id.")
    (:dialect "motoi" :tier "intermediate" :code "(define (spawn-enemies count)\n  (map (lambda (i) (world/spawn 'enemy (+ 50 (* i 80)) 150))\n       (list count)))\n(define enemy-ids (spawn-enemies 5))" :note "Spawn multiple enemies in a row; returns a list of ids.")
    (:dialect "motoi" :tier "expert" :code "(define (arena-setup)\n  (define player (world/spawn 'player 400 300 20 20))\n  (world/gravity! 0 0.5)\n  (for-each (lambda (i) \n              (world/spawn 'obstacle (random-range 0 800) (random-range 100 300) 40 20))\n            (list 10))\n  (display (world/count)))\n(arena-setup)" :note "Full arena setup: spawn player with explicit size, set gravity, spawn obstacles.")
  )
  :caveats ("x, y must be finite numbers; NaN or Infinity → 'bad-arg." "Coordinates outside the world bounds may spawn but render off-screen." "Width/height default to 1 if omitted; use explicit values for proper collision." "Entities are born in bornSeq order; iteration order is deterministic." "The same kind can be spawned many times; kind is just a label.")
  :drawbacks ("No built-in entity pooling or reuse; each spawn allocates fresh memory." "Spawning many entities per frame (>1000) may cause frame-rate drops." "No 'despawn-all-of-kind'; use world/find + entity/despawn! to clean up selectively." "Default size (1×1) is tiny; forgetting to set width/height causes invisible hitboxes.")
  :usecases ("Spawning player at level start." "Procedural enemy waves or bullet patterns." "Dynamic obstacles or collectibles." "Creating visual markers or debug nodes.")
  :related ("entity/despawn!" "entity/set-pos!" "world/find" "world/each" "world/count")
  :learn (:concept "Entity birth; the fundamental creation primitive." :prerequisites ("world/step" "entity/alive?") :progression "Learn entity/set-pos!, entity/set-vel!, and entity/set! to configure spawned entities; then use world/each to iterate and update.")
  :row-2-audit (
    (:problem "The operator needs to create an enemy in the world at a given position. entity/make is name-supplied; world/spawn generates a fresh id and returns the entity."
     :program "(define orc (world/spawn 'orc 200 200))\n(display orc)"
     :explanation "world/spawn creates an entity of kind 'orc at (200, 200) and returns the id."
     :meta "entity/make requires the caller to supply an id (named); world/spawn generates one (anonymous). Choose based on need to name-reference later.")
    (:eng "SRE: spawn is safe under high load; profile for storms." :math "Registry insertion." :cs "Insert with id generation."))
  :row-3-dimension (
    (:setup "Create a new entity in a registry."
     :rungs (
       (:domain "world"  :code "(world/spawn 'orc 200 200)")
       (:domain "shell"  :code "(define (mktemp) 'tmp-abc123) (mktemp)")
       (:domain "math"   :code "(define (fresh) 42) (fresh)"))
     :explanation "Rung 1: entity spawn. Rung 2: tempfile creation. Rung 3: fresh symbol. Each: 'produce a new member with an auto-assigned id'.")
    (:meta "Shape: name-generating construction.")
    (:eng "SRE: name-generation must be fresh; audit for collisions." :math "Insertion with fresh key." :cs "Auto-id insert."))
  :row-4-proof (
    (:claim "Uniqueness: spawn returns a fresh id not previously in the registry."
     :program "(define a (world/spawn 'x 0 0))\n(define b (world/spawn 'x 0 0))\n(display (not (equal? a b)))"
     :invariant "∀ world. spawn(world) → id ∉ registry(world) before"
     :meta "Fresh id. Falsified if a spawn returns an existing id. Book-of-code ch 5 (id generation) grounds.")
    (:eng "Consequence: safe to spawn without checking for collision." :math "Injection of new keys." :cs "Fresh-name generator."))
  :row-5-emergence (
    (:base "world/spawn creates a new entity."
     :composition "(define (wave n kind x y)\n  (let loop ((i 0))\n    (when (< i n)\n      (world/spawn kind (+ x (* i 30)) y)\n      (loop (+ i 1)))))\n(wave 10 'orc 100 100)"
     :emergent "A spawn-wave — a row of enemies. Emergent: level population."
     :meta "Population-generator family; standard level population. Book-of-composition ch 10 (cohort ops) grounds.")
    (:eng "SRE: population functions are audit-friendly." :math "Family of spawns parameterized by index." :cs "Loop of spawns.")))

(verb
  :name "world/step"
  :library "world"
  :kind "mut"
  :signature "(world/step) → frame"
  :summary "Advance the world by one frame: integrate physics, apply tweens, detect collisions, flush despawns → current frame number."
  :explanation "world/step is the heartbeat of the physics and animation loop. In one call it: (1) integrates velocities and forces into positions (Verlet or semi-implicit Euler), (2) applies active tweens (animated values), (3) detects entity–entity and entity–geometry collisions, (4) flushes despawn requests from the prior frame. It then returns the new frame number. Call world/step once per game frame, typically inside a on-tick or big-bang loop. The frame counter increments by 1 each step."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/step)\n(world/step)\n(display (world/frame))" :note "Two steps; frame counter now reads 2.")
    (:dialect "motoi" :tier "intermediate" :code "(define (game-loop)\n  (when (game/running?)\n    (world/step)\n    (world/each (lambda (id) (display (entity/pos id))))\n    (schedule game-loop)))\n(game-loop)" :note "Main loop: step, then iterate over all entities to update logic.")
    (:dialect "motoi" :tier "expert" :code "(define (physics-tick)\n  (world/step)\n  (for-each (lambda (pair)\n              (let ((a (car pair)) (b (cadr pair)))\n                (on-collision a b)))\n            (world/collisions))\n  (world/each (lambda (id)\n                (when (entity/alive? id)\n                  (let ((state (entity/state id)))\n                    (case state\n                      ((moving) (move-update id))\n                      ((idle) (idle-update id)))))))\n(physics-tick))" :note "Full tick: step, process collisions, update each entity's state machine.")
  )
  :caveats ("Calling world/step from within a collision handler or entity callback is undefined; step between frames only." "Entities despawned via entity/despawn! in the current frame are not removed until the next world/step; queries still see them as alive." "Collision detection is discrete; fast-moving small entities may pass through gaps." "Forces and gravity are applied cumulatively; 0 0 gravity still requires an explicit world/gravity! call to set." "Tweens and animations progress by 1/60 of their duration per frame (assuming 60 FPS); frame rate sensitivity can be an issue.")
  :drawbacks ("Fixed time-step; no delta-time scaling. All physics assumes 1 frame ≈ constant dt." "Step cost grows with entity count; 1000+ entities per frame may stall." "Collision callbacks are synchronous and not cancelable." "Determinism relies on all forces and impulses being applied in the same order; randomness breaks replays.")
  :usecases ("Main game-loop heartbeat." "Physics-based puzzle or platformer simulation." "Collision detection in real-time games." "Time-step synchronization for replay recording.")
  :related ("world/spawn" "world/collisions" "world/gravity!" "world/frame" "entity/despawn!")
  :learn (:concept "Discrete time stepping; one frame of physics and animation." :prerequisites ("world/spawn" "entity/alive?") :progression "Learn world/collisions to handle collision pairs; then world/gravity! and entity forces for dynamic behavior.")
  :row-2-audit (
    (:problem "The operator wants to advance simulation by one frame — integrate physics, fire scheduled events. world/step is the single-frame tick."
     :program "(world/step)\n(display (world/frame))"
     :explanation "One call advances the frame counter, integrates velocities, resolves constraints, fires world/after events."
     :meta "world/render is paint-only; world/step is compute. Choose based on 'update or draw'.")
    (:eng "SRE: step is the frame budget owner; profile it." :math "Discrete time-advance." :cs "One tick of the simulation loop."))
  :row-3-dimension (
    (:setup "Advance a simulation by one discrete unit."
     :rungs (
       (:domain "world"  :code "(world/step)")
       (:domain "os"     :code "(define (scheduler-tick) 'ticked) (scheduler-tick)")
       (:domain "math"   :code "(define (next state f) (f state)) (next 0 (lambda (n) (+ n 1)))"))
     :explanation "Rung 1: game step. Rung 2: OS scheduler tick. Rung 3: state transition. Each: 'advance one discrete unit of time'.")
    (:meta "Shape: single-step advance.")
    (:eng "SRE: step is the primary work unit; timing-critical." :math "Δt = 1." :cs "Discrete transition."))
  :row-4-proof (
    (:claim "Frame monotonicity: world/frame increases by exactly 1 per step."
     :program "(let ((f0 (world/frame))) (world/step)\n  (display (= (+ f0 1) (world/frame))))"
     :invariant "∀ world. frame(step(world)) = frame(world) + 1"
     :meta "Increment-per-step. Falsified if step skips or repeats a frame. Book-of-code ch 8 (monotonic counters) grounds.")
    (:eng "Consequence: frame counter is reliable time reference." :math "+1 increment." :cs "Deterministic tick."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/step advances one frame."
     :composition "(define (fixed-timestep)\n  (world/step)\n  (world/render)\n  (world/after 1 'fixed-timestep 'again))\n(on-message 'fixed-timestep (lambda (_) (fixed-timestep)))\n(fixed-timestep)"
     :emergent "A fixed-timestep game loop. Emergent: main loop."
     :meta "Game-loop family; fundamental pattern. Book-of-composition ch 13 (temporal composition) grounds.")
    (:eng "SRE: fixed-timestep loops decouple physics from render." :math "Discrete-time dynamical system." :cs "Loop with fixed cadence.")))

(verb
  :name "world/sway-all!"
  :library "world"
  :kind "null"
  :signature "(world/sway-all! tag period amplitude) → count"
  :summary "Oscillate all entities bearing a tag with sinusoidal phase-offset rotation; returns the number of entities affected."
  :explanation "world/sway-all! creates a wave of swaying motion across all entities tagged with a given tag. Each entity oscillates with a sine curve parameterized by period (frame count per cycle) and amplitude (max rotation angle in radians). The phase is offset by each entity's birth order (bornSeq) to create a staggered, flowing effect. The motion is stored in each entity's '__spin' data slot and must be applied to rendering/animation by the caller. Returns the count of entities that matched the tag."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/spawn 'flower 100 100)\n(entity/tag! (world/find 'flower) 'sway)\n(world/sway-all! 'sway 60 0.5)\n(display (world/sway-all! 'sway 60 0.5))" :note "Tag a flower, then sway all tagged flowers with 60-frame period and 0.5 amplitude; count is 1.")
    (:dialect "motoi" :tier "intermediate" :code "(define (create-grass field-size)\n  (for-each (lambda (i)\n              (let ((id (world/spawn 'grass (* i 20) 200)))\n                (entity/tag! id 'wind-sway)))\n            (list field-size))\n  (world/sway-all! 'wind-sway 40 0.3))\n(create-grass 10)" :note "Create a field of grass, tag them, sway in unison with phase offsets.")
    (:dialect "motoi" :tier "expert" :code "(define (rhythm-sway beat-period)\n  (let ((count (world/sway-all! 'dancer 60 0.2)))\n    (when (> count 0)\n      (world/each (lambda (id)\n                    (when (entity/tag? id 'dancer)\n                      (let ((spin (entity/ref id '__spin)))\n                        (when (not (equal? spin 'nan))\n                          (sprite-rotate-animation id spin)))))))))\n(rhythm-sway 60)" :note "Sway dancers, then apply their __spin values to sprite rotations for visual effect.")
  )
  :caveats ("world/sway-all! only computes and stores the oscillation; it does NOT render or animate. The caller must read '__spin' and apply it." "The phase offset formula (0.37 scaling factor) is fixed; you cannot customize the inter-entity phase spacing." "Entities spawned after calling sway-all! will inherit the phase offset formula based on their bornSeq, which may look wrong." "Amplitude is in radians; 0.5 radians ≈ 28 degrees. Very large amplitudes (>π) may cause visual aliasing." "Tag must be a symbol or string; other types are coerced to string.")
  :drawbacks ("The '__spin' value is overwritten each frame; you cannot accumulate or blend multiple sways on the same entity." "No built-in damping or easing; oscillation is pure sine with no decay." "Period must be > 0; period ≤ 0 causes undefined behavior." "The verb is undocumented in the source; behavior inferred from inline code.")
  :usecases ("Gentle swaying grass or plant fields." "Synchronized dancing or choreography in rhythm games." "Wave-like crowd motion or NPC formations." "Visual feedback for wind or water currents.")
  :related ("entity/tag!" "entity/untag!" "entity/ref" "world/each" "world/frame")
  :learn (:concept "Phase-coherent oscillation across a group; staggered sine waves." :prerequisites ("entity/tag!" "world/spawn" "world/each") :progression "Learn entity/ref to retrieve the '__spin' value; combine with sprite animation to render the sway.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants a field of grass to sway in the wind. Applying sway per entity is verbose; world/sway-all! is the group primitive with per-entity phase offsets."
     :program "(world/spawn 'grass 0 0) (world/spawn 'grass 20 0) (world/spawn 'grass 40 0)\n(for-each (lambda (id-str) (entity/tag! (string->symbol id-str) 'sway))\n          (world/find 'grass))\n(world/sway-all! 'sway 5 0.02)"
     :explanation "All 'sway-tagged entities oscillate with amplitude 5 and frequency 0.02, each phase-shifted by index. The field ripples uniformly."
     :meta "Manual per-entity oscillation loses phase-coherence; world/sway-all! coordinates it.")
    (:eng "SRE: sway is a cheap cosmetic effect; profile if entity count is high." :math "Sinusoidal oscillation across a group." :cs "Batch phase-shifted animation."))
  :row-3-dimension (
    (:setup "Apply a phase-coherent oscillation to a group."
     :rungs (
       (:domain "world"    :code "(world/sway-all! 'grass 5 0.02)")
       (:domain "audio"    :code "(define (chorus voices) (list 'chorus voices)) (chorus 3)")
       (:domain "math"     :code "(define (osc i t) (sin (+ t (* 0.3 i)))) (osc 0 1)"))
     :explanation "Rung 1: entity sway. Rung 2: audio chorus. Rung 3: phase-shifted sinusoid. Each: 'many oscillators with staggered phases'.")
    (:meta "Shape: phase-shifted oscillator array.")
    (:eng "SRE: coherent oscillation looks more natural than independent." :math "Family of phase-shifted sinusoids." :cs "Batch-parameterized animation."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Amplitude bound: sway never moves entities more than the amplitude from rest position."
     :program "(world/spawn 'g 100 100)\n(entity/tag! 'g 'sway)\n(world/sway-all! 'sway 5 0.02)\n(let loop ((i 100)) (when (> i 0) (world/step) (loop (- i 1))))\n(display (< (abs (- (entity/x 'g) 100)) 6))"
     :invariant "∀ e amp. |pos(e, t) - rest(e)| ≤ amp"
     :meta "Bounded oscillation. Falsified if sway exceeds amplitude. Book-of-math ch 9 (harmonic motion) grounds.")
    (:eng "Consequence: sway is bounded — no runaway." :math "sin ∈ [-1, 1]." :cs "Amplitude-bounded oscillator."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/sway-all! oscillates a tagged group."
     :composition "(define (plant-grass n)\n  (let loop ((i 0))\n    (when (< i n)\n      (let ((g (world/spawn 'grass (* i 20) 300)))\n        (entity/tag! g 'sway))\n      (loop (+ i 1)))))\n(plant-grass 20)\n(world/sway-all! 'sway 3 0.03)"
     :emergent "A grass field — many plants, coordinated sway. Emergent: environmental animation."
     :meta "Group-oscillator family; standard environmental animation. Book-of-composition ch 11 (layered animation) grounds.")
    (:eng "SRE: batch animations are the cheapest way to fill a scene." :math "Group action of oscillators." :cs "Batch animation.")))

(verb
  :name "world/tape-audio"
  :library "world"
  :kind "rd"
  :signature "(world/tape-audio) -> list"
  :summary "Return the audio events recorded on the latest tape frame as a list of (kind channel gain) rows; silent frame returns the empty list."
  :explanation "The tape is a record of every frame that has been rendered or simulated. Each frame captures audio events—sounds played, their channel (track), and gain (volume). world/tape-audio retrieves those events from the most recent frame, allowing you to inspect what sounds occurred, when they occurred, and at what volume. This is useful for debugging audio timing, exporting audio logs, or triggering secondary effects based on recorded sounds."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/tape-audio)" :note "Returns all audio events from the last frame, e.g., ((kick main 0.8) (snare 1 0.6)).")
    (:dialect "motoi" :tier "intermediate" :code "(define latest-audio (world/tape-audio))\n(define audio-count (length latest-audio))\n(if (> audio-count 0)\n  (display (list \"Frame had\" audio-count \"sounds\")))" :note "Count the number of audio events in the latest frame and log it if any occurred.")
    (:dialect "motoi" :tier "expert" :code "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (extract-audio-by-channel target-channel)\n  (let ((audio-events (world/tape-audio)))\n    (filter (lambda (evt)\n              (equal? (cadr evt) target-channel))\n            audio-events)))\n(define drum-sounds (extract-audio-by-channel 'drums))" :note "Filter tape audio to find all events on a specific channel; useful for post-processing or logging.")
  )
  :caveats ("Returns an empty list if the tape is empty (no frames recorded yet) or if the latest frame has no audio events." "The tape is a history of what was recorded; this verb only reads the latest frame, not the full history. Use world/tape-frames to get the frame count if you need to iterate." "Audio events are structured as (kind channel gain); if any field is missing in the source, it is replaced with the symbol 'none, not null." "Tape recording must be active; if world/tape-recording? returns false, tape-audio returns whatever was last recorded.")
  :drawbacks ("Reading tape data does not reset or advance the tape; repeated calls return the same frame until the tape steps." "No filtering or searching inside tape-audio; you must filter the result with filter or fold if you need a subset." "The tape is a linear record; you cannot access past frames via tape-audio (only the latest). To access history, use world/tape-hash or world/tape-frames and consider storing snapshots.")
  :usecases ("Debug audio timing by logging which sounds occurred in a given frame." "Post-process a recorded tape to extract sound metadata for analysis or export." "Trigger visual effects (e.g., screen flash) synchronized to recorded audio events." "Audit a performance: check that the expected sounds were played at the expected times.")
  :related ("world/tape-record!" "world/tape-stop!" "world/tape-recording?" "world/tape-frames" "world/tape-hash")
  :learn (:concept "Tape as a persistent record of simulation state, and audio events as a subset of that record." :prerequisites ("world/tape-record!" "world/frame") :progression "After learning tape-audio, study world/tape-replay to re-render recorded frames, and world/tape-save to persist a tape to disk.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants to inspect just the audio events from a recorded tape. world/tape-frames returns everything; world/tape-audio filters to audio-only."
     :program "(world/tape-record!)\n(world/step) (world/step)\n(display (world/tape-audio))"
     :explanation "Returns the list of audio events on the tape. Filter view of the full frames."
     :meta "world/tape-frames is unfiltered; world/tape-audio is the audio-only projection.")
    (:eng "SRE: filtered views make replay diagnostics tractable." :math "Projection to audio subset." :cs "Filter view of tape."))
  :row-3-dimension (
    (:setup "Filtered view of a compound stream."
     :rungs (
       (:domain "world"    :code "(world/tape-audio)")
       (:domain "log"      :code "(define (filter-lvl logs l) (list 'filtered l)) (filter-lvl 'all 'error)")
       (:domain "math"     :code "(define (proj-key xs k) (map (lambda (x) (cdr (assq k x))) xs)) (proj-key '(((a . 1)) ((a . 2))) 'a)"))
     :explanation "Rung 1: audio events. Rung 2: log level filter. Rung 3: alist projection. Each: 'give me only the subset matching this criterion'.")
    (:meta "Shape: filtered projection.")
    (:eng "SRE: filtered views are diagnostic staples." :math "Preimage projection." :cs "Filter accessor."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Subset: tape-audio is a subset of tape-frames."
     :program "(world/tape-record!) (world/step)\n(display (<= (length (world/tape-audio)) (length (world/tape-frames))))"
     :invariant "∀ tape. tape-audio(tape) ⊆ tape-frames(tape)"
     :meta "Subset invariant. Falsified if audio has events not in frames. Book-of-code ch 5 (view semantics) grounds.")
    (:eng "Consequence: audio view is safe to walk." :math "⊆ relation." :cs "Filter is a subset."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/tape-audio filters audio events."
     :composition "(define (audio-hash)\n  (map (lambda (e) (list 'audio e))\n       (world/tape-audio)))\n(audio-hash)"
     :emergent "An audio-only replay snippet — extract just the sonic history. Emergent: audio replay."
     :meta "Filtered-replay family; standard debugging view. Book-of-composition ch 6 (snapshot streams) grounds.")
    (:eng "SRE: filtered replays speed up diagnostics." :math "Subset of an event stream." :cs "Projection query.")))

(verb
  :name "world/tape-clear!"
  :library "world"
  :kind "mut"
  :signature "(world/tape-clear!) → #t"
  :summary "Discard the replay tape and disarm recording; always returns true."
  :explanation "world/tape-clear! resets the replay recording system. If a replay is currently recording (via world/tape-record!), it is halted and all frames are discarded. The tape buffer is emptied. Calling world/tape-clear! when no tape is active is a no-op. This is useful to free memory or restart recording from a clean state. Always returns true (a success marker)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/tape-clear!)" :note "Clear any active tape; tape is now empty.")
    (:dialect "motoi" :tier "intermediate" :code "(define (record-and-save filename)\n  (world/tape-clear!)\n  (world/tape-record!)\n  (for-each (lambda (_) (world/step)) (list 100))\n  (let ((tape (world/tape-save)))\n    (display (list \"Saved\" (length tape) \"frames\"))))\n(record-and-save \"demo.tape\")" :note "Clear old tape, record new frames, save to file.")
    (:dialect "motoi" :tier "expert" :code "(define execute-attempt (lambda args (list \"execute-attempt\" args)))\n(define goal-reached? (lambda args (list \"goal-reached?\" args)))\n(define (try-solution attempt-id)\n  (let ((snap (world/snapshot)))\n    (world/tape-clear!)\n    (world/tape-record!)\n    (execute-attempt attempt-id)\n    (let ((tape (world/tape-save)))\n      (if (goal-reached?) \n        (list 'success tape)\n        (begin\n          (world/tape-clear!)\n          (world/restore! snap)\n          (list 'failed-attempt attempt-id))))))\n(try-solution 5)" :note "Clear tape, attempt a solution, save if successful, or revert and clear if not.")
  )
  :caveats ("world/tape-clear! does not clear the snapshot; use world/snapshot separately." "Calling clear while a replay is being played back (world/tape-replay) may cause undefined behavior." "The tape is lost immediately; there is no undo for the clear operation." "Clearing a tape does not free memory in all implementations; rely on garbage collection.")
  :drawbacks ("Once cleared, the recorded frames are unrecoverable; no rollback." "If you want to preserve a recording, you must call world/tape-save BEFORE clearing." "Clearing does not reset the frame counter or entities; only the tape buffer is flushed.")
  :usecases ("Starting a fresh replay recording session." "Freeing memory before a large simulation." "Abandoning a failed replay attempt." "Resetting the tape subsystem for a new level or mode.")
  :related ("world/tape-record!" "world/tape-save" "world/tape-replay" "world/snapshot" "world/restore!")
  :learn (:concept "Tape lifecycle; clearing and resetting the recording buffer." :prerequisites ("world/tape-record!" "world/tape-save") :progression "Combine with world/tape-record! and world/tape-save to build a full record–save–replay workflow.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants to start a new recording session without saving the old buffer. world/tape-clear! is the reset."
     :program "(world/tape-clear!)\n(display (world/tape-frames))"
     :explanation "The buffer is emptied; frames returns an empty list."
     :meta "world/tape-stop! stops but keeps content; world/tape-clear! erases. Choose based on 'discard or preserve'.")
    (:eng "SRE: clear is destructive; log it." :math "Buffer reset." :cs "Empty the tape buffer."))
  :row-3-dimension (
    (:setup "Erase the contents of a buffer."
     :rungs (
       (:domain "world"   :code "(world/tape-clear!)")
       (:domain "shell"   :code "(define (rm-buf) (list 'cleared)) (rm-buf)")
       (:domain "math"    :code "(define (zero-out xs) '()) (zero-out '(1 2 3))"))
     :explanation "Rung 1: tape clear. Rung 2: buffer flush. Rung 3: empty. Each: 'erase the accumulator'.")
    (:meta "Shape: buffer reset.")
    (:eng "SRE: buffer resets are destructive; audit." :math "Zero element." :cs "Buffer flush."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Zero post-condition: after tape-clear!, tape-frames is empty."
     :program "(world/tape-record!) (world/step) (world/step)\n(world/tape-clear!)\n(display (null? (world/tape-frames)))"
     :invariant "∀ world. tape-frames(tape-clear!(world)) = ∅"
     :meta "Empty-after-clear. Falsified if any frame persists. Book-of-code ch 6 (reset semantics) grounds.")
    (:eng "Consequence: clear is reliable." :math "Absorbing element." :cs "Zero-state buffer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/tape-clear! empties the buffer."
     :composition "(define (start-fresh-session)\n  (world/tape-clear!)\n  (world/tape-record!))\n(start-fresh-session)"
     :emergent "A new-session primitive — clear then arm. Emergent: recording session."
     :meta "Session-boundary family; standard record-cycle pattern. Book-of-composition ch 13 (state-reset composition) grounds.")
    (:eng "SRE: sessions demarcate audit boundaries." :math "State machine transition." :cs "Reset + arm.")))

(verb
  :name "world/tape-frames"
  :library "world"
  :kind "rd"
  :signature "(world/tape-frames) -> number"
  :summary "Returns the count of frames currently held in the motion tape."
  :explanation "The motion tape is a rolling buffer that records entity state and camera position at each simulation step. This verb answers: how many frames are stored right now? Use it to check whether a recording exists, or to plan replay logic. An empty tape returns 0."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin\n  (world/tape-record! 300)\n  (world/step)\n  (world/step)\n  (display (world/tape-frames)))" :note "After two steps of recording, the tape holds 3 frames (initial capture + 2 steps).")
    (:dialect "motoi" :tier "intermediate" :code "(define ctx '())\n(begin\n  (world/tape-record! 500)\n  (world/each (lambda (id) (entity/move! id 1 0)))\n  (world/step)\n  (if (> (world/tape-frames) 100)\n    (world/tape-stop!)\n    (next 'keep-recording ctx)))" :note "Check frame count mid-recording to decide when to halt; avoids unbounded memory.")
    (:dialect "motoi" :tier "expert" :code "(define (replay-checkpoint ctx)\n  (let ((saved-tape (world/tape-save)))\n    (if (null? saved-tape)\n      (escalate 'no-tape-to-save null)\n      (begin\n        (display (list 'saved (length saved-tape) 'frames))\n        (next 'idle (ctx-set 'last-tape saved-tape ctx))))))" :note "Use frame count implicitly via `world/tape-save` length to verify a checkpoint was captured before moving on.")
  )
  :caveats ("Returns 0 if tape is not armed (read-only; does not arm the tape)." "Count includes the initial frame captured by `world/tape-record!`." "If a rolling-window cap was set, old frames may be discarded; this reflects only current length, not total ever-recorded.")
  :drawbacks ("Does not tell you whether recording is currently active; use `world/tape-recording?` for that." "No way to query individual frame metadata from Scheme; use `world/tape-save` to inspect the full structure.")
  :usecases ("Deciding whether to serialize a checkpoint (non-empty tape exists)." "Throttling or stopping recording when tape reaches a size threshold." "Debugging: asserting that motion was captured before a replay attempt.")
  :related ("world/tape-recording?" "world/tape-record!" "world/tape-save" "world/tape-clear!" "world/tape-stop!")
  :learn (:concept "Reading transient state—the tape is a side-effect resource, and this verb lets you inspect its size." :prerequisites ("world/frame" "world/step") :progression "Once comfortable with frame queries, move to `world/tape-record!` to arm recording, then `world/tape-save` to serialize.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator needs to know how many frames the tape currently holds. world/tape-frames returns the full list; asking for its length is the direct diagnostic."
     :program "(world/tape-record!) (world/step) (world/step)\n(display (length (world/tape-frames)))"
     :explanation "Frames are a list; length gives the count."
     :meta "world/tape-hash summarizes content; world/tape-frames enumerates. Choose based on 'summary vs full'.")
    (:eng "SRE: frame counts inform memory planning." :math "Enumeration of the tape." :cs "Buffer read."))
  :row-3-dimension (
    (:setup "Enumerate the contents of a buffer."
     :rungs (
       (:domain "world"  :code "(world/tape-frames)")
       (:domain "log"    :code "(define (get-log) '()) (get-log)")
       (:domain "math"   :code "(define (contents xs) xs) (contents '(1 2 3))"))
     :explanation "Rung 1: tape frames. Rung 2: log entries. Rung 3: list contents. Each: 'give me all the entries'.")
    (:meta "Shape: buffer enumeration.")
    (:eng "SRE: enumerations are foundational diagnostics." :math "List of entries." :cs "Buffer read."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Monotonicity while recording: tape-frames length grows by exactly 1 per step."
     :program "(world/tape-clear!) (world/tape-record!)\n(define n0 (length (world/tape-frames)))\n(world/step)\n(display (= (+ n0 1) (length (world/tape-frames))))"
     :invariant "∀ world (recording). |frames(step(world))| = |frames(world)| + 1"
     :meta "Increment-per-step. Falsified if step skips a frame. Book-of-code ch 8 (monotonic recording) grounds.")
    (:eng "Consequence: frame count is reliable timing." :math "Increment." :cs "Consistent recording."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/tape-frames returns the frame list."
     :composition "(world/tape-clear!) (world/tape-record!)\n(let loop ((n 10))\n  (when (> n 0) (world/step) (loop (- n 1))))\n(world/tape-stop!)\n(let ((tape (world/tape-frames)))\n  (display (list 'recorded (length tape) 'frames)))"
     :emergent "A record-and-report session — arm, step, stop, count. Emergent: replay diagnostic."
     :meta "Record-cycle family; standard replay diagnostics. Book-of-composition ch 6 (snapshot streams) grounds.")
    (:eng "SRE: recording sessions are audit-clear." :math "Time-indexed sequence." :cs "Buffer + counter.")))

(verb
  :name "world/tape-hash"
  :library "world"
  :kind "rd"
  :signature "(world/tape-hash) -> number"
  :summary "Returns a 32-bit digest (hash) of the entire motion tape for integrity checking."
  :explanation "When you replay a recording, you want to assert that the same input and world snapshot produce the same output tape. This verb computes a fast hash over all frames. Two tapes with the same hash have the same entity positions, kinds, and sprite assignments (and thus should render identically). Use it to validate replay determinism or to detect corruption."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin\n  (world/tape-record! 200)\n  (world/step)\n  (world/step)\n  (let ((h1 (world/tape-hash)))\n    (display h1)))" :note "Compute the hash of a short 3-frame recording to verify it is captured.")
    (:dialect "motoi" :tier "intermediate" :code "(begin\n  (world/tape-record! 1000)\n  (let loop ((i 0)) (when (< i 50) (world/step) (loop (+ i 1))))\n  (let ((h-live (world/tape-hash)))\n    (world/tape-stop!)\n    (if (equal? h-live 0)\n      (escalate 'hash-empty null)\n      (display (list 'tape-hash h-live)))))" :note "Stop recording and check that the hash is non-zero (tape has content).")
    (:dialect "motoi" :tier "expert" :code "(define (validate-replay ctx)\n  (let ((saved-tape (world/tape-save))\n        (h-original (ctx-get 'replay-hash ctx)))\n    (begin\n      (world/tape-clear!)\n      (world/tape-record! 5000)\n      ;; (simulate replay path here)\n      (let ((h-replay (world/tape-hash)))\n        (if (= h-original h-replay)\n          (next 'success (ctx-set 'verified #t ctx))\n          (escalate 'replay-mismatch (list h-original h-replay)))))))" :note "Store the original tape hash, then replay and compare. Mismatch means non-determinism or corrupted input.")
  )
  :caveats ("Hash is 32-bit; collisions are theoretically possible but vanishingly rare in practice." "Hash changes if *any* entity position, kind, or sprite differs between two recordings—even sub-pixel deltas." "Hash is computed over the current tape state; it changes as frames are added (rolling window may discard old frames).")
  :drawbacks ("Does not identify *which* frame or entity caused a mismatch; only signals that tapes differ." "Requires full tape in memory; cannot stream-validate very long recordings." "If tape is empty, hash is well-defined but not useful for asserting content (use `world/tape-frames > 0` first).")
  :usecases ("Regression testing: assert that a replay of a saved tape produces bit-identical output." "Deduplication: store only the hash of a checkpoint, not the full tape, and verify replay matches." "Detecting silent corruption in tape serialization or deserialization.")
  :related ("world/tape-save" "world/tape-frames" "world/tape-record!" "world/tape-stop!")
  :learn (:concept "Determinism verification—the hash is a compact witness to the tape's content, enabling offline assertion without storing megabytes of frame data." :prerequisites ("world/tape-frames" "world/tape-recording?") :progression "Combine with `world/tape-save` to build a checkpoint system: save hash + frame count, discard raw tape, then validate replay determinism.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants a compact witness for the recorded tape — cheaper than storing all frames. world/tape-hash returns a signature."
     :program "(world/tape-record!) (world/step) (world/step)\n(display (world/tape-hash))"
     :explanation "One small hash summarizes the tape's content. Comparable to other tapes."
     :meta "world/tape-frames stores full content; world/tape-hash is small. Choose based on 'archive vs signature'.")
    (:eng "SRE: hashes are the primary determinism CI signal." :math "Hash of the tape content." :cs "Digest."))
  :row-3-dimension (
    (:setup "Compact witness for a large content."
     :rungs (
       (:domain "world"  :code "(world/tape-hash)")
       (:domain "git"    :code "(define (sha1 c) 'abc) (sha1 'blob)")
       (:domain "math"   :code "(define (digest xs) (apply + xs)) (digest '(1 2 3))"))
     :explanation "Rung 1: tape hash. Rung 2: git SHA. Rung 3: sum digest. Each: 'small representative of large content'.")
    (:meta "Shape: content-signature.")
    (:eng "SRE: signatures beat storage for verification." :math "Hash function." :cs "One-way summary."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Determinism: two identical recordings produce equal hashes."
     :program "(world/tape-clear!) (world/tape-record!) (world/step) (world/step)\n(define h1 (world/tape-hash))\n(world/tape-clear!) (world/tape-record!) (world/step) (world/step)\n(display (equal? h1 (world/tape-hash)))"
     :invariant "∀ tape1 tape2. tape1 = tape2 → hash(tape1) = hash(tape2)"
     :meta "Deterministic hash. Falsified if identical tapes hash differently. Book-of-code ch 11 (hash determinism) grounds.")
    (:eng "Consequence: hash equality is valid tape equality." :math "Hash determinism." :cs "Pure function of tape."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/tape-hash returns a signature."
     :composition "(define golden-hash 'stashed-value)\n(define (verify)\n  (if (equal? golden-hash (world/tape-hash))\n      'pass\n      'fail))\n(verify)"
     :emergent "A CI signal — compare live hash to golden. Emergent: determinism CI."
     :meta "Golden-hash family; standard regression testing. Book-of-composition ch 6 (snapshot streams) grounds.")
    (:eng "SRE: golden hashes are the cheapest regression check." :math "Equality check on hash." :cs "Golden-fixture pattern.")))

(verb
  :name "world/tape-lcamera"
  :library "world"
  :kind "rd"
  :signature "(world/tape-lcamera) -> (list number number number) | 'none"
  :summary "Returns the local (operator) viewport camera position and zoom from the most recent tape frame."
  :explanation "The tape records not only entity state but also where the camera was looking at each frame. The local camera is the viewport controlled by the operator during live playback. This verb returns `[x y k]` (x-coord, y-coord, zoom factor) from the latest frame, or the symbol `'none` if no camera was in scope (headless mode or camera verbs not installed). Use it to preserve and restore the operator's viewpoint during replay."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin\n  (world/tape-record! 500)\n  (camera-pan 100 50)\n  (world/step)\n  (let ((cam (world/tape-lcamera)))\n    (display cam)))" :note "After panning the camera and stepping, the tape records the new camera position. Retrieve it to confirm capture.")
    (:dialect "motoi" :tier "intermediate" :code "(begin\n  (world/tape-record! 1000)\n  (let loop ((i 0)) (when (< i 30) (world/step) (loop (+ i 1))))\n  (let ((cam (world/tape-lcamera)))\n    (cond ((equal? cam 'none)\n           (display 'headless))\n          (else\n           (display (list 'camera-at (car cam) (cadr cam) 'zoom (caddr cam)))))))" :note "Check whether camera was recorded; if headless, `'none` is returned.")
    (:dialect "motoi" :tier "expert" :code "(define (restore-operator-view ctx)\n  (let ((cam (world/tape-lcamera)))\n    (if (equal? cam 'none)\n      (next 'idle ctx)\n      (begin\n        (camera-snap! (car cam) (cadr cam))\n        (camera-zoom-to (caddr cam))\n        (next 'replay-ready (ctx-set 'viewport cam ctx))))))" :note "After loading a saved tape, restore the operator's exact viewpoint: pan to x/y and set zoom, enabling \"show me that again\" to replay from the operator's perspective.")
  )
  :caveats ("Returns `'none` if no frames are recorded (tape is empty)." "Returns `'none` if recording was active but camera verbs were not installed or never called." "Reflects only the *latest* frame's camera; earlier frames' cameras are only accessible via `world/tape-save`." "Camera values are in world coordinates, not screen coordinates.")
  :drawbacks ("No way to query intermediate frame cameras from Scheme directly; use `world/tape-save` to extract the full history." "If camera was never set during recording, you lose the operator's implicit starting view.")
  :usecases ("Preserving the operator's field of view across a replay: save the camera position and restore it at play-back time." "Headless testing: detect whether a recording was made in a GUI context (camera present) vs. server-side (no camera)." "Choreography validation: confirm that a sequence was recorded with a specific camera framing.")
  :related ("camera-pan" "camera-zoom-to" "camera-snap!" "world/tape-save" "world/tape-frames")
  :learn (:concept "Auxiliary state in motion capture—the tape records not just the world, but the operator's vantage point, enabling full replay fidelity." :prerequisites ("world/tape-record!" "camera-pan" "camera-zoom-to") :progression "Use this to anchor replay to the operator's saved view; then explore `world/tape-save` to inspect frame-by-frame camera history.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants to replay including the camera moves. world/tape-lcamera returns the camera state recorded on the tape."
     :program "(world/tape-record!) (world/step) (world/step)\n(display (world/tape-lcamera))"
     :explanation "Returns the recorded camera trajectory. Playback can use it to reconstruct the operator's viewpoint."
     :meta "world/tape-frames is entity data; world/tape-lcamera is camera data. Choose based on 'what to replay'.")
    (:eng "SRE: camera trajectories are essential for demo playback." :math "Time-series of camera states." :cs "Auxiliary tape lane."))
  :row-3-dimension (
    (:setup "Auxiliary recorded lane."
     :rungs (
       (:domain "world"  :code "(world/tape-lcamera)")
       (:domain "audio"  :code "(define (get-track n) '()) (get-track 1)")
       (:domain "math"   :code "(define (lane data k) '()) (lane 'x 'sub)"))
     :explanation "Rung 1: camera lane. Rung 2: audio track. Rung 3: sublane. Each: 'a labeled slice of the recorded content'.")
    (:meta "Shape: aux-lane read.")
    (:eng "SRE: aux lanes are essential for high-fidelity replay." :math "Sublane of the tape." :cs "Auxiliary channel read."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Length consistency: camera lane length matches frames lane length while recording."
     :program "(world/tape-clear!) (world/tape-record!) (world/step) (world/step)\n(display (= (length (world/tape-lcamera)) (length (world/tape-frames))))"
     :invariant "∀ tape (recording). |lcamera(tape)| = |frames(tape)|"
     :meta "Aligned lanes. Falsified if lanes diverge in length. Book-of-code ch 5 (view consistency) grounds.")
    (:eng "Consequence: lanes can be zipped together." :math "Parallel time-index." :cs "Aligned buffers."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/tape-lcamera reads the camera history."
     :composition "(define (replay-with-camera)\n  (let ((cam-hist (world/tape-lcamera))\n        (world-hist (world/tape-frames)))\n    (for-each (lambda (c w)\n                (world/camera-snap! (car c) (cadr c)))\n              cam-hist world-hist)))\n(replay-with-camera)"
     :emergent "A camera-following replay — reconstruct the operator's viewpoint. Emergent: demo playback."
     :meta "Demo-playback family; standard replay pattern. Book-of-composition ch 6 (snapshot streams) grounds.")
    (:eng "SRE: demo playback needs aux lanes for fidelity." :math "Zip of parallel sequences." :cs "Multi-lane playback.")))

(verb
  :name "world/tape-record!"
  :library "world"
  :kind "mut"
  :signature "(world/tape-record! [cap]) -> #t"
  :summary "Arm the motion tape and capture the current world frame; optionally set a rolling-window capacity."
  :explanation "Begin recording the world's motion. Each call to `world/step` appends a new frame to the tape. You can supply an optional capacity `cap` (a positive integer) to limit memory: once the tape reaches `cap` frames, older frames roll off. If `cap` is omitted or non-finite, the tape grows without bound. Always returns `true`. Call `world/tape-stop!` to halt recording (tape is retained), or `world/tape-clear!` to discard it."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin\n  (world/tape-record! 100)\n  (world/step)\n  (world/step)\n  (display (world/tape-frames)))" :note "Record with a cap of 100 frames. After two steps, tape holds 3 frames (init + 2 steps). Display shows 3.")
    (:dialect "motoi" :tier "intermediate" :code "(begin\n  (world/tape-record!)\n  (let loop ((i 0)) (when (< i 60)\n    (world/each (lambda (id)\n      (entity/move! id (random-range -2 2) (random-range -2 2))))\n    (world/step) (loop (+ i 1))))\n  (let ((n (world/tape-stop!)))\n    (display (list 'recorded n 'frames))))" :note "Unbounded recording (no cap): move entities randomly for 60 steps, then stop and report the final frame count.")
    (:dialect "motoi" :tier "expert" :code "(define (record-scene ctx)\n  (world/tape-clear!)\n  (world/tape-record! 5000)\n  (let ((loop-count (ctx-get 'loops ctx)))\n    (if (= loop-count 0)\n      (begin\n        (display 'recording-started)\n        (next 'animate (ctx-set 'loops 1 ctx)))\n      (if (< (world/tape-frames) 4800)\n        (next 'animate (ctx-set 'loops (+ loop-count 1) ctx))\n        (next 'save-checkpoint (ctx-set 'tape (world/tape-save) ctx))))))" :note "Orchestrate a multi-frame recording: arm the tape, loop until near capacity, then save checkpoint. Capacity acts as a guard against runaway memory.")
  )
  :caveats ("Calling `world/tape-record!` again discards the prior tape unconditionally." "The initial capture (frame 0) happens synchronously; do not call during `world/each` or entity mutations." "Capacity is in frames, not bytes; a cap of 1000 may consume significant memory depending on entity count." "If `cap` argument is non-numeric or ≤ 0, capacity defaults to unlimited (0 in internal code, treated as no-limit).")
  :drawbacks ("Memory cost grows linearly with frame count and entity count; unbounded recording can exhaust heap." "No built-in compression or streaming to disk; the tape is always in-memory." "If you want to record multiple independent takes, you must manually save each tape (via `world/tape-save`) before arming a new recording.")
  :usecases ("Motion capture for replay: record a choreography sequence, then play it back deterministically." "Debugging: record a trace of entity motion to replay a failure scenario." "Live demo: arm recording, run a scene, then show the replay to an audience." "Rolling buffer for crash diagnostics: record the last N frames in a production system so you can replay the incident.")
  :related ("world/tape-stop!" "world/tape-clear!" "world/tape-recording?" "world/tape-frames" "world/tape-save" "world/step")
  :learn (:concept "Side-effect management—the tape is a mutable resource that you arm, fill, and query. Understanding this pattern is key to building deterministic replay systems." :prerequisites ("world/step" "world/frame") :progression "Once recording works, learn `world/tape-stop!` to halt, then `world/tape-save` to serialize, then `world/tape-hash` to validate.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants to start recording every subsequent frame. world/tape-record! arms the tape."
     :program "(world/tape-record!)\n(world/step)\n(display (world/tape-recording?))"
     :explanation "One call arms the tape; recording? reports #t. Each subsequent step appends a frame."
     :meta "world/tape-clear! resets buffer; world/tape-record! arms the recorder. Choose based on 'reset or arm'.")
    (:eng "SRE: recording is a mode flag; log the transition." :math "Boolean mode change." :cs "Arm a recording state."))
  :row-3-dimension (
    (:setup "Arm a recording mode."
     :rungs (
       (:domain "world"  :code "(world/tape-record!)")
       (:domain "video"  :code "(define (rec) 'recording) (rec)")
       (:domain "math"   :code "(define (arm mode) (list 'armed mode)) (arm 'record)"))
     :explanation "Rung 1: tape arm. Rung 2: video rec button. Rung 3: mode arm. Each: 'enable ongoing capture'.")
    (:meta "Shape: mode change to record.")
    (:eng "SRE: mode changes are audit-critical." :math "State transition to recording." :cs "Boolean set."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Arms recording: after tape-record!, tape-recording? is #t."
     :program "(world/tape-clear!) (world/tape-record!)\n(display (world/tape-recording?))"
     :invariant "∀ world. recording?(tape-record!(world)) = #t"
     :meta "Post-condition. Falsified if tape-record! doesn't arm. Book-of-code ch 8 (state-machine transitions) grounds.")
    (:eng "Consequence: caller may trust the arm." :math "State assignment." :cs "Deterministic mode set."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/tape-record! arms the recorder."
     :composition "(define (demo-run)\n  (world/tape-clear!)\n  (world/tape-record!)\n  (let loop ((n 60)) (when (> n 0) (world/step) (loop (- n 1))))\n  (world/tape-stop!)\n  (world/tape-save \"demo.tape\"))\n(demo-run)"
     :emergent "A demo-recording — clear, arm, run, stop, save. Emergent: demo capture."
     :meta "Record-cycle family; standard replay session. Book-of-composition ch 6 (snapshot streams) grounds.")
    (:eng "SRE: demo captures are audit-legible." :math "Session as sequence of mode changes." :cs "Record-cycle pattern.")))

(verb
  :name "world/tape-recording?"
  :library "world"
  :kind "rd"
  :signature "(world/tape-recording?) -> boolean"
  :summary "Check whether the motion tape is currently armed (recording frames on each step)."
  :explanation "The tape can be armed (frames accumulate with each `world/step`) or disarmed (steps do not record). This verb returns `true` if recording is live, `false` otherwise. Use it to guard code paths that should only run during capture, or to decide whether to halt recording."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin\n  (display (world/tape-recording?))\n  (world/tape-record! 100)\n  (display (world/tape-recording?))\n  (world/tape-stop!)\n  (display (world/tape-recording?)))" :note "Initially false, becomes true after `tape-record!`, then false after `tape-stop!`.")
    (:dialect "motoi" :tier "intermediate" :code "(begin\n  (world/tape-record! 500)\n  (let loop ((i 0)) (when (< i 50)\n    (if (world/tape-recording?)\n      (begin\n        (world/each (lambda (id) (entity/move! id 1 0)))\n        (world/step))\n      (display 'recording-halted)) (loop (+ i 1)))))" :note "Guard a movement loop: only move and step if recording is still armed.")
    (:dialect "motoi" :tier "expert" :code "(define (capture-until-full ctx)\n  (if (world/tape-recording?)\n    (let ((frames (world/tape-frames))\n          (cap 1000))\n      (world/step)\n      (if (>= frames cap)\n        (begin\n          (world/tape-stop!)\n          (next 'save-tape (ctx-set 'frames frames ctx)))\n        (next 'capture-until-full ctx)))\n    (next 'idle ctx)))" :note "Recursively step and check capacity; when full, stop and transition. The guard `world/tape-recording?` ensures we don't step after stopping.")
  )
  :caveats ("Returns `false` by default (tape is not armed on startup)." "Checking this does not affect the tape; it is a pure read." "Frame count can be > 0 even if recording is false (a stopped tape retains its contents).")
  :drawbacks ("Does not tell you how full the tape is or whether capacity was exceeded; use `world/tape-frames` for that." "No way to pause recording without stopping (stopping disarms but keeps frames; restarting via `tape-record!` clears them).")
  :usecases ("Conditional logic: only record motion during a specific phase or when a condition is met." "Safety check: verify that recording is still active before performing expensive captures." "State machine transitions: decide whether to save the tape or discard it based on whether recording succeeded.")
  :related ("world/tape-record!" "world/tape-stop!" "world/tape-frames" "world/tape-clear!")
  :learn (:concept "State queries—in addition to reading data, you often need to know *whether* a resource is active. This verb answers that question." :prerequisites ("world/tape-record!" "world/step") :progression "Combine with `world/tape-frames` and `world/tape-stop!` to build a full tape management workflow.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The HUD wants to show a red REC dot when the tape is armed. world/tape-recording? is the boolean check."
     :program "(display (world/tape-recording?))"
     :explanation "Returns #t when armed. HUD can branch on the result."
     :meta "world/tape-frames tells you what's recorded; world/tape-recording? tells you whether recording is active. Choose based on 'content vs mode'.")
    (:eng "SRE: mode reads inform UI." :math "Boolean predicate." :cs "Read of mode flag."))
  :row-3-dimension (
    (:setup "Read the current mode of a resource."
     :rungs (
       (:domain "world"  :code "(world/tape-recording?)")
       (:domain "video"  :code "(define (is-recording?) #t) (is-recording?)")
       (:domain "math"   :code "(define (armed? m) (eq? m 'on)) (armed? 'on)"))
     :explanation "Rung 1: tape mode. Rung 2: video rec light. Rung 3: mode predicate. Each: 'is this thing currently on?'.")
    (:meta "Shape: mode predicate.")
    (:eng "SRE: mode predicates drive UI and audit." :math "Boolean read." :cs "Mode read."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Consistency: after tape-record! then tape-stop!, tape-recording? is #f."
     :program "(world/tape-record!) (world/tape-stop!)\n(display (not (world/tape-recording?)))"
     :invariant "∀ world. recording?(tape-stop!(tape-record!(world))) = #f"
     :meta "Round-trip mode. Falsified if stop doesn't disarm. Book-of-code ch 8 (mode consistency) grounds.")
    (:eng "Consequence: state predicate reliably reflects mode." :math "Function into {#t, #f}." :cs "Deterministic mode."))
  :row-5-emergence (
    (:base "world/tape-recording? reads mode."
     :composition "(on-frame (lambda ()\n  (when (world/tape-recording?)\n    (display 'REC))))"
     :emergent "A REC-indicator UI — HUD flashes during recording. Emergent: recording indicator."
     :meta "UI-mode-indicator family; standard mode display. Book-of-composition ch 10 (state visualizations) grounds.")
    (:eng "SRE: mode indicators are essential UX." :math "Predicate-driven display." :cs "State-tagged UI.")))

(verb
  :name "world/tape-replay"
  :library "world"
  :kind "rd"
  :signature "(world/tape-replay surface) -> 'empty-tape | 'service-not-yet-wired"
  :summary "Replay the motion tape onto a registered surface (live re-render; not yet wired in the harness)."
  :explanation "After recording a tape, you can re-render it to visualize the motion. This verb accepts a surface argument and attempts to replay each frame onto that surface. Currently, the in-app harness does not wire the render path; the verb returns `'service-not-yet-wired` as a signal that the feature is planned but not yet implemented. If the tape is empty, it returns `'empty-tape`. In a full implementation, each frame would paint its entities onto the surface, frame by frame."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin\n  (world/tape-record! 100)\n  (world/step)\n  (let ((result (world/tape-replay 'some-surface)))\n    (display result)))" :note "After recording, call replay. Currently always returns `'service-not-yet-wired`.")
    (:dialect "motoi" :tier "intermediate" :code "(begin\n  (world/tape-clear!)\n  (let ((result (world/tape-replay 'any-surface)))\n    (if (equal? result 'empty-tape)\n      (display 'nothing-to-replay)\n      (display result))))" :note "If tape is empty, `'empty-tape` is returned; otherwise, `'service-not-yet-wired`.")
    (:dialect "motoi" :tier "expert" :code "(define (maybe-replay ctx)\n  (let ((saved-tape (ctx-get 'tape ctx)))\n    (if (null? saved-tape)\n      (escalate 'no-tape-to-replay null)\n      (begin\n        (world/tape-clear!)\n        (world/tape-record! 10000)\n        ;; (populate tape from saved-tape here)\n        (let ((status (world/tape-replay (ctx-get 'surface ctx))))\n          (cond ((equal? status 'empty-tape)\n                 (escalate 'replay-failed 'empty))\n                ((equal? status 'service-not-yet-wired)\n                 (next 'await-render-wire ctx))\n                (else\n                 (next 'replay-active ctx))))))))" :note "Check the return value to branch: if `'empty-tape`, something went wrong; if `'service-not-yet-wired`, the service is not yet bound (expected state).")
  )
  :caveats ("Currently always returns `'service-not-yet-wired`; actual rendering is not yet implemented in Scheme." "The `surface` argument is accepted but not used (no-op in current implementation)." "Returns `'empty-tape` if tape is empty, but this is the only success case that might be meaningful in future versions.")
  :drawbacks ("Feature is not yet wired; you cannot actually replay visual output from Scheme at this time." "No feedback mechanism to know when render is complete or has failed." "The render path is expected to be in the harness; Scheme cannot directly control painting.")
  :usecases ("Future-proofing: call this verb to prepare for the moment when live replay rendering is available." "Placeholder in replay workflows: structure your code to call `tape-replay` even though it is not yet functional, so the integration is ready when the service is wired." "Testing replay mechanics: verify that the tape structure is valid before the render service comes online.")
  :related ("world/tape-save" "world/tape-record!" "world/tape-frames" "surface-paint-dots" "surface-paint-text")
  :learn (:concept "Forward compatibility—sometimes a verb is declared and stubbed before its implementation arrives. This teaches you to code defensively by checking return values and understanding what a deferred service means." :prerequisites ("world/tape-record!" "world/tape-save") :progression "As the harness evolves and `tape-replay` is wired, you will gradually see it return meaningful results instead of `'service-not-yet-wired`. Keep your error checks in place.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants to replay a saved tape. world/tape-replay is the interface — currently stubbed but the API contract is stable."
     :program "(world/tape-replay \"demo.tape\")"
     :explanation "The call takes a saved-tape path and initiates playback. Current stub returns 'service-not-yet-wired; the operator must check."
     :meta "world/tape-save serializes; world/tape-replay reconstructs. Choose based on direction.")
    (:eng "SRE: stub responses must be handled defensively." :math "Playback function." :cs "Deserialize + apply."))
  :row-3-dimension (
    (:setup "Reconstruct state from a serialized recording."
     :rungs (
       (:domain "world"  :code "(world/tape-replay \"a.tape\")")
       (:domain "video"  :code "(define (play f) 'playing) (play \"movie.mp4\")")
       (:domain "math"   :code "(define (interpret trace) trace) (interpret '((step 1)))"))
     :explanation "Rung 1: tape replay. Rung 2: video playback. Rung 3: trace interpretation. Each: 'reconstruct state from a serialized recording'.")
    (:meta "Shape: replay/interpretation.")
    (:eng "SRE: replay verifies recording correctness." :math "Inverse of record." :cs "State reconstructor."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Contract stability: signature is fixed even while implementation is stubbed."
     :program "(let ((r (world/tape-replay \"missing.tape\")))\n  (display (or (eq? r 'service-not-yet-wired) (list? r))))"
     :invariant "∀ path. tape-replay(path) returns either 'service-not-yet-wired or a valid replay handle"
     :meta "API-contract stability. Falsified if the signature changes across versions. Book-of-code ch 15 (API contracts) grounds.")
    (:eng "Consequence: callers can code against the stub." :math "Total function with defined domain." :cs "Stable API surface."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/tape-replay reconstructs from a tape."
     :composition "(define (safe-replay path)\n  (let ((r (world/tape-replay path)))\n    (if (eq? r 'service-not-yet-wired)\n        (display \"replay pending\")\n        r)))\n(safe-replay \"demo.tape\")"
     :emergent "A defensive-replay — handle stub responses. Emergent: safe API consumer."
     :meta "Defensive-API-consumer family; standard forward-compat pattern. Book-of-composition ch 15 (API-defensive) grounds.")
    (:eng "SRE: defensive callers survive stub/impl transitions." :math "Total function with fallback." :cs "Result-branching consumer.")))

(verb
  :name "world/tape-save"
  :library "world"
  :kind "rd"
  :signature "(world/tape-save) -> (list) | '()"
  :summary "Serialize the entire motion tape into a portable, re-renderable list of frames (each with entities and local viewport camera); empty tape → '()."
  :explanation "The tape is an in-memory buffer. To persist it or pass it between systems, serialize it via this verb. The result is a list of frames, where each frame is a list: `(frame-number cam-x cam-y hash (entity-list) local-camera)`. Each entity record is `(id kind sprite x y state)`. The local camera is `[x y k]` or the symbol `'none`. This is the true recording—the lightweight, replayable form that a host can stash and re-render. Empty tape → `'()` (the empty list, not an error)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin\n  (world/tape-record! 50)\n  (world/step)\n  (world/step)\n  (let ((saved (world/tape-save)))\n    (display (length saved))))" :note "After two steps, tape has 3 frames. Serialized list length is 3.")
    (:dialect "motoi" :tier "intermediate" :code "(begin\n  (world/tape-record! 200)\n  (let loop ((i 0)) (when (< i 10) (world/step) (loop (+ i 1))))\n  (let ((tape (world/tape-save)))\n    (if (null? tape)\n      (display 'empty)\n      (begin\n        (display (list 'frames (length tape)))\n        (display (list 'hash (world/tape-hash)))))))" :note "Save the tape after recording. Check that it is non-empty and display frame count and hash for later validation.")
    (:dialect "motoi" :tier "expert" :code "(define (checkpoint-scene ctx)\n  (let ((tape (world/tape-save))\n        (camera (world/tape-lcamera)))\n    (if (null? tape)\n      (escalate 'checkpoint-failed 'empty-tape)\n      (let ((checkpoint (list 'version 1 'frames tape 'camera camera 'hash (world/tape-hash))))\n        (begin\n          (display (list 'checkpointed (length tape) 'frames))\n          (next 'await-restore (ctx-set 'checkpoint checkpoint ctx)))))))" :note "Package the tape, camera, and hash into a checkpoint structure. Later, verify the hash matches during replay to detect corruption.")
  )
  :caveats ("Returns the empty list `'()` if tape is empty; this is a valid, honest-null result, not an error." "The serialized format includes frame number, camera, hash, and entity state. Do not edit these by hand; structure is strict." "Local camera may be `'none` if no camera was recorded for a given frame." "Entity state field may be `'none` if an entity had no state object.")
  :drawbacks ("Tape grows unbounded if no capacity was set; serializing a very large tape consumes time and memory." "Format is not compressed; a long recording with many entities will produce a large list." "No built-in versioning; if the tape format changes in a future Motoi version, old saved tapes may not deserialize.")
  :usecases ("Persistence: save a recording to disk or a database so it can be replayed later, even after the program restarts." "Determinism testing: save a tape, run a replay, verify the hash matches to confirm the replay is bit-identical." "Data sharing: export a tape in a portable form so other tools or systems can analyze or visualize it." "Checkpointing: bundle a tape with metadata (version, timestamp, actor info) to preserve a complete simulation snapshot.")
  :related ("world/tape-record!" "world/tape-frames" "world/tape-hash" "world/tape-lcamera" "world/tape-stop!")
  :learn (:concept "Serialization—converting a live, mutable resource (the in-memory tape) into a durable, shareable data structure. This is how you preserve the results of a simulation." :prerequisites ("world/tape-record!" "world/tape-frames" "world/tape-hash") :progression "After saving a tape, learn to validate it via hash and then design replay workflows that use the serialized data.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The operator wants a shareable tape file. world/tape-save serializes to disk."
     :program "(world/tape-record!) (world/step) (world/step) (world/tape-stop!)\n(world/tape-save \"demo.tape\")"
     :explanation "The buffer is serialized to \"demo.tape\" on disk. The tape is portable."
     :meta "world/tape-frames is in-memory; world/tape-save writes to durable storage.")
    (:eng "SRE: saves cost disk I/O; profile." :math "Serialization." :cs "Buffer → disk."))
  :row-3-dimension (
    (:setup "Persist a mutable resource to durable storage."
     :rungs (
       (:domain "world"  :code "(world/tape-save \"a.tape\")")
       (:domain "shell"  :code "(define (save f data) 'saved) (save \"a.txt\" 'data)")
       (:domain "math"   :code "(define (encode xs) xs) (encode '(1 2 3))"))
     :explanation "Rung 1: tape to file. Rung 2: file save. Rung 3: encoding. Each: 'convert live state to durable form'.")
    (:meta "Shape: serialize + persist.")
    (:eng "SRE: persistence is safety-critical." :math "Serialization." :cs "Write-through storage."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Round-trip: save-then-load should produce a tape equivalent to the original (hash matches)."
     :program "(world/tape-clear!) (world/tape-record!) (world/step)\n(define h1 (world/tape-hash))\n(world/tape-save \"tmp.tape\")\n(world/tape-replay \"tmp.tape\")\n(display (or (equal? h1 (world/tape-hash)) 'stubbed))"
     :invariant "∀ tape. hash(load(save(tape))) = hash(tape)"
     :meta "Save/load fidelity. Falsified if the hash changes across a round-trip. Book-of-code ch 11 (serialization fidelity) grounds.")
    (:eng "Consequence: saved tapes are trustworthy." :math "Serialization is a monomorphism." :cs "Lossless save/load."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/tape-save writes tape to disk."
     :composition "(define (checkpoint name)\n  (world/tape-save (string-append name \".tape\"))\n  (display (list 'saved name)))\n(checkpoint \"level-1-complete\")"
     :emergent "A checkpoint save — persistent record of progress. Emergent: save file."
     :meta "Save-file family; standard game save mechanism. Book-of-composition ch 6 (snapshot streams) grounds.")
    (:eng "SRE: save files need atomic write for safety." :math "Persistence primitive." :cs "Durable checkpoint.")))

(verb
  :name "world/tape-stop!"
  :library "world"
  :kind "mut"
  :signature "(world/tape-stop!) -> number"
  :summary "Stop recording; disarm the motion tape and return the final frame count."
  :explanation "After calling `world/tape-record!`, each `world/step` appends a frame. This verb disarms recording (sets the internal flag to false) so that future steps no longer record. The tape itself is retained, and you can inspect or save it via `world/tape-frames`, `world/tape-save`, or `world/tape-hash`. The return value is the total number of frames captured (including the initial frame from `tape-record!`). Use this to halt recording, report progress, and decide whether to keep or discard the tape."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(begin\n  (world/tape-record! 100)\n  (world/step)\n  (world/step)\n  (let ((count (world/tape-stop!)))\n    (display (list 'frames-recorded count))))" :note "Record two steps (plus initial), stop, and report that 3 frames were captured.")
    (:dialect "motoi" :tier "intermediate" :code "(begin\n  (world/tape-record! 500)\n  (let loop ((i 0)) (when (< i 100)\n    (world/each (lambda (id) (entity/move! id 0.5 0)))\n    (world/step) (loop (+ i 1))))\n  (let ((final-count (world/tape-stop!)))\n    (if (> final-count 450)\n      (display 'tape-near-full)\n      (display (list 'recorded final-count)))))" :note "Record up to 100 steps (plus init), stop, and check if we're near capacity. Return value tells us how many frames we actually have.")
    (:dialect "motoi" :tier "expert" :code "(define (record-and-checkpoint ctx)\n  (world/tape-record! 10000)\n  (let ((loop (lambda (frame-target)\n         (if (< (world/tape-frames) frame-target)\n           (begin\n             (world/step)\n             (loop frame-target))\n           (let ((count (world/tape-stop!)))\n             (begin\n               (display (list 'checkpointed count))\n               (next 'save (ctx-set 'tape (world/tape-save) ctx))))))))\n    (loop 500)))" :note "Recursively step until we reach a target frame count (500), then stop and capture the tape. Return value confirms the count.")
  )
  :caveats ("Calling `world/tape-stop!` does not clear the tape; frames remain in memory until `world/tape-clear!` is called." "If recording was already halted (via a prior `tape-stop!` call), calling it again still returns the current frame count and succeeds (idempotent with respect to the flag)." "Return value is the frame count at the moment `tape-stop!` is invoked; it does not change afterward unless more frames are added (via a new `tape-record!`).")
  :drawbacks ("No way to resume recording without clearing the tape; `tape-record!` always starts fresh." "If you want to record multiple independent takes, you must manually save each tape (via `world/tape-save`) before calling `tape-record!` again.")
  :usecases ("Ending a recording session and reporting how many frames were captured." "Checking whether the tape reached a size threshold before deciding to save or discard it." "Halting recording when a condition is met (e.g., a scene completes or an error occurs), while preserving the frames for inspection.")
  :related ("world/tape-record!" "world/tape-frames" "world/tape-recording?" "world/tape-clear!" "world/tape-save")
  :learn (:concept "State machine transitions—the tape has two states (armed/disarmed), and `tape-stop!` is the verb that transitions from one to the other while reporting the outcome." :prerequisites ("world/tape-record!" "world/step") :progression "After stopping a recording, use `world/tape-save` to serialize it, `world/tape-hash` to validate it, and `world/tape-clear!` to discard it when ready.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "The recording is complete; the operator wants to halt without discarding the buffer. world/tape-stop! disarms; world/tape-clear! would also empty it."
     :program "(world/tape-record!) (world/step)\n(world/tape-stop!)\n(display (world/tape-recording?))"
     :explanation "Stop! disarms the recorder without clearing. Content is still queryable."
     :meta "world/tape-clear! is destructive; world/tape-stop! is a mode change. Choose based on 'preserve or destroy'.")
    (:eng "SRE: stop is a mode change; log it." :math "State transition to disarmed." :cs "Set mode to #f."))
  :row-3-dimension (
    (:setup "Halt an active mode without destroying state."
     :rungs (
       (:domain "world"  :code "(world/tape-stop!)")
       (:domain "video"  :code "(define (stop-rec) 'stopped) (stop-rec)")
       (:domain "math"   :code "(define (disarm) '((mode . off))) (disarm)"))
     :explanation "Rung 1: tape stop. Rung 2: video rec stop. Rung 3: disarm. Each: 'halt without discard'.")
    (:meta "Shape: halt-without-clear.")
    (:eng "SRE: mode halts preserve state for post-analysis." :math "State transition." :cs "Mode off."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Disarm: after tape-stop!, tape-recording? is #f but tape-frames still returns content."
     :program "(world/tape-clear!) (world/tape-record!) (world/step)\n(world/tape-stop!)\n(display (and (not (world/tape-recording?)) (> (length (world/tape-frames)) 0)))"
     :invariant "∀ tape. recording?(stop!(tape)) = #f ∧ frames(stop!(tape)) = frames(tape)"
     :meta "Preserve-content-halt. Falsified if stop destroys content or fails to disarm. Book-of-code ch 8 (state-machine transitions) grounds.")
    (:eng "Consequence: stop is safe; content still queryable." :math "State-only transition." :cs "Non-destructive halt."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/tape-stop! halts recording."
     :composition "(define (record-for n)\n  (world/tape-clear!)\n  (world/tape-record!)\n  (let loop ((i n)) (when (> i 0) (world/step) (loop (- i 1))))\n  (world/tape-stop!)\n  (world/tape-hash))\n(record-for 30)"
     :emergent "A fixed-length recording — arm, run for n frames, stop, hash. Emergent: bounded record."
     :meta "Bounded-session family; standard fixed-duration record. Book-of-composition ch 6 (snapshot streams) grounds.")
    (:eng "SRE: bounded sessions have predictable size." :math "Bounded time interval." :cs "Time-boxed record.")))

(verb
  :name "world/wind!"
  :library "world"
  :kind "mut"
  :signature "(world/wind! dvx dvy) -> null"
  :summary "Apply a constant directional force to all physics-enabled entities."
  :explanation "Sets a global wind vector (dvx dvy) that accelerates every entity with physics enabled each frame. This is useful for environmental effects like wind, current, or drift. Pass (0 0) to disable wind. The force is applied uniformly; individual entities can vary their response via entity/gravity-scale! and entity/mass!. Wind does NOT affect pinned or static entities."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(world/wind! 0.1 0)  ; constant rightward wind\n(world/step)" :note "Wind is applied every frame; entities accelerate in the wind direction over time.")
    (:dialect "motoi" :tier "intermediate" :code "(define (update-wind strength)\n  (let ((angle (random-range 0 6.28)))\n    (world/wind! (* strength (cos angle))\n                 (* strength (sin angle)))))\n(update-wind 0.05)  ; wind in a random direction" :note "Wind can be updated per frame or on a schedule; here we vary its direction randomly.")
    (:dialect "motoi" :tier "expert" :code "(define (wind-pulse beat-index strength)\n  (let ((phase (/ (modulo beat-index 4) 4)))\n    (world/wind! (* strength (sin (* 6.28 phase))) 0)))\n(on-tick (lambda (ctx)\n  (wind-pulse (audio-beat? (ctx-get 'beat ctx)) 0.15)\n  ctx))" :note "Wind strength synchronized to audio beats; creates a rhythmic drift effect.")
  )
  :caveats ("Wind is global; all physics-enabled entities are affected equally." "Pinned (entity/pin!) and non-physics entities are not affected." "Wind persists until explicitly changed; call (world/wind! 0 0) to stop it." "Wind is NOT included in world/snapshot or world/restore; it is render-only in the tape.")
  :drawbacks ("Global wind cannot be selectively applied to subgroups; use entity/accel! for per-entity forces." "Wind interacts with entity/drag! and entity/friction! in complex ways; test empirically." "Very strong wind can cause stability issues; keep magnitudes ≤ 0.5 for predictable behavior.")
  :usecases ("Simulating weather effects (wind, storms, currents) in a game world." "Creating ambient drift in zero-gravity or space scenes." "Choreographing entities to move together in a wave or swirl pattern." "Testing physics robustness under constant external forces.")
  :related ("entity/accel!" "entity/drag!" "entity/friction!" "entity/gravity-scale!" "world/gravity!" "world/step")
  :learn (:concept "Global forces as a world-state parameter; how external acceleration affects all physics simultaneously." :prerequisites ("world/spawn" "entity/set-vel!" "entity/mass!") :progression "After this, learn world/gravity! (per-entity override), then entity/accel! (per-frame force).")
  :row-2-audit (
    (:problem "The operator wants a horizontal wind affecting every entity — different from gravity. world/wind! is the global horizontal-force parameter."
     :program "(world/wind! 2 0)\n(world/spawn 'ball 100 100)"
     :explanation "One call sets a rightward global force. Every physics entity accelerates rightward."
     :meta "world/gravity! is the vertical global; world/wind! is the horizontal global. Choose based on direction.")
    (:eng "SRE: wind is a level-metadata knob." :math "Constant added to every velocity." :cs "Global horizontal-force slot."))
  :row-3-dimension (
    (:setup "A directional global parameter."
     :rungs (
       (:domain "world"  :code "(world/wind! 2 0)")
       (:domain "weather":code "(define w '((wind-mph . 10))) w")
       (:domain "math"   :code "(define (add-vec v c) (map + v c)) (add-vec '(0 0) '(2 0))"))
     :explanation "Rung 1: game wind. Rung 2: weather report. Rung 3: vector add. Each: 'a global directional bias'.")
    (:meta "Shape: directional global.")
    (:eng "SRE: directional globals need one owner." :math "Constant vector field." :cs "Ambient parameter."))
  :row-4-proof (
    (:claim "Universality: wind is added to every physics entity's velocity per step."
     :program "(world/wind! 3 0)\n(world/spawn 'a 0 0)\n(let ((v0 (entity/vel 'a))) (world/step)\n  (display (> (car (entity/vel 'a)) (car v0))))"
     :invariant "∀ e (participating). vx(e, t+1) = vx(e, t) + wind-x"
     :meta "Uniform force application. Falsified if any entity misses wind. Book-of-math ch 9 (uniform fields) grounds.")
    (:eng "Consequence: predictable global drift." :math "Universal quantifier over entities." :cs "Uniform per-tick delta."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "world/wind! sets a global horizontal force."
     :composition "(world/gravity! 0 9.8)\n(world/wind! 3 0)\n(world/spawn 'leaf 100 100)\n(entity/mass! 'leaf 0.1)\n(entity/drag! 'leaf 0.95)"
     :emergent "A drifting-leaf simulation — gravity + wind + drag + light mass. Emergent: environmental physics."
     :meta "Ambient-physics family; standard weather effects. Book-of-composition ch 9 (preset bundles) grounds.")
    (:eng "SRE: ambient physics presets tune atmosphere." :math "Sum of global fields." :cs "Bundled ambient setup.")))

