(verb
  :name "calc/directional-derivative"
  :library "calc"
  :kind "meta"
  :signature "(calc/directional-derivative f point direction) -> number"
  :summary "Computes the rate of change of a multivariable function along a specified direction vector."
  :explanation "The directional derivative Dᵤf measures how fast f changes at a point when moving in the direction of unit vector u. It is the dot product of the gradient ∇f with u. This generalises the notion of slope to multivariable functions: instead of asking 'how fast does f change along x?', you ask 'how fast along this arbitrary direction?' Use it to find the steepest direction or the rate of change perpendicular to a constraint."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define f (lambda (pt) (+ (car pt) (cadr pt))))\n(calc/directional-derivative f (list 0 0) (list 1 0))" :note "f(x,y)=x+y; direction (1,0) is along x-axis; rate of change is 1")
    (:dialect "motoi" :tier "intermediate" :code "(define terrain (lambda (pt)\n  (+ (* (car pt) (car pt)) (* (cadr pt) (cadr pt)))))\n(let ((pt (list 1 1))\n      (dir-northeast (list (/ 1 (sqrt 2)) (/ 1 (sqrt 2)))))\n  (calc/directional-derivative terrain pt dir-northeast))" :note "f(x,y)=x²+y²; at (1,1), slope toward northeast is √2·(2+2)/√2 = 4")
    (:dialect "motoi" :tier "expert" :code "(define point '(0 0))\n(define f (lambda (pt) (* (car pt) (cadr pt))))\n(let ((point (list 2 3))\n      (grad (calc/gradient f point)))\n  (let ((magnitude (sqrt (+ (* (car grad) (car grad))\n                            (* (cadr grad) (cadr grad))))))\n    (let ((unit-grad (list (/ (car grad) magnitude)\n                           (/ (cadr grad) magnitude))))\n      (calc/directional-derivative f point unit-grad))))" :note "Manual steepest-ascent direction: normalize gradient, then compute directional derivative along it (equals gradient magnitude)")
  )
  :caveats ("Direction vector is assumed to be normalized (unit length); non-unit vectors give scaled results." "Computed numerically; accuracy depends on gradient estimation, which uses finite differences." "Does not check that the function is actually differentiable at the point.")
  :drawbacks ("More expensive than a single partial derivative: requires computing the full gradient." "For many directions at one point, compute gradient once and dot-product manually." "Limited to numeric evaluation; symbolic directional derivatives require symbolic gradient.")
  :usecases ("Optimisation: finding steepest-ascent or steepest-descent direction." "Sensitivity analysis: measuring sensitivity of output to changes along a constraint surface." "Level-set flow: computing flux across contour lines in a scalar field.")
  :related ("calc/gradient" "calc/hessian" "calc/total-differential" "vec/dot")
  :learn (:concept "Gradient as vector of all slopes; directional derivative as projection onto a direction." :prerequisites ("calc/gradient" "vec/dot") :progression "calc/hessian → calc/critical-points-1d → calc/extrema-1d")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A gradient-descent step needs the rate of change along a specific direction, not along an axis; the operator wants ∇f · v."
     :program "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))\n(calc/directional-derivative f (list 1 0) (list 1 0))"
     :explanation "∇f = (2x, 2y); at (1, 0), direction (1, 0), derivative = 2; operator sees ≈ 2."
     :meta "partial takes an axis-aligned direction; directional-derivative accepts any unit vector. Same shape, more general.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-nd; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'rate along a chosen direction'"
     :rungs (
       (:domain "calc native" :code "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))")
       (:domain "slope of terrain in a walking direction" :code "(terrain/slope-in-direction map p dir)")
       (:domain "∇f · v" :code "(∇f)(x) · v"))
     :explanation "Rung 1 is calc/directional-derivative in its native library. Rung 2 shows the same ''rate along a chosen direction'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''rate along a chosen direction'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/directional-derivative."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Directional derivative is a linear function of direction: D_{av+bw} f = a D_v f + b D_w f."
     :program "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))\n(define p (list 1 1))\n(define v (list 1 0)) (define w (list 0 1))\n(< (abs (- (calc/directional-derivative f p (list 2 3))\n           (+ (* 2 (calc/directional-derivative f p v))\n              (* 3 (calc/directional-derivative f p w))))) 0.01)"
     :invariant "D_{av+bw} f = a D_v f + b D_w f"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch15-multivariable-linear-algebra.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-nd category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/directional-derivative — see :summary."
     :composition "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))\n(define p (list 1 1))\n(define g (calc/gradient f p))\n(list g (calc/directional-derivative f p (list 1 0)))"
     :emergent "steepest-descent-direction"
     :meta "The emergent steepest-descent-direction belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Directional derivative maximized along ∇f gives steepest descent. See book-of-ml ch-06.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-nd operations close into the steepest-descent-direction pattern."
     :cs "The emergent steepest-descent-direction is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/divergence"
  :library "calc"
  :kind "meta"
  :signature "(calc/divergence F) -> scalar | (escalate 'diverged)"
  :summary "Computes the divergence (∇·F) of a vector field at a point via central finite differences."
  :explanation "Divergence measures the net outflow or inflow of a vector field at a point. For a field F = [Fx, Fy, Fz], divergence is ∂Fx/∂x + ∂Fy/∂y + ∂Fz/∂z. calc/divergence takes a field representation and returns the divergence (a scalar). If the field produces non-finite values (NaN, infinity), the verb escalates 'diverged. Use this to analyze field behavior in fluid dynamics, electromagnetism, or source/sink configurations."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define radial (lambda (x y z) (list x y z)))\n(define div-result (calc/divergence radial))\n(display div-result)" :note "Divergence of radial field (x, y, z) is 3 everywhere")
    (:dialect "motoi" :tier "intermediate" :code "(define F (lambda (x y z) (list (/ 1 (+ (abs x) 0.01)) y z)))\n(let ((div (calc/divergence F)))\n  (cond ((eq? div 'diverged) (display \"Field has singularities\"))\n        (else (display (list \"Divergence:\" div)))))" :note "Field with a near-singularity; check for divergence before using result")
    (:dialect "motoi" :tier "expert" :code "(define (analyze-field-behavior F name)\n  (let ((div (calc/divergence F))\n        (curl (calc/curl F)))\n    (cond ((eq? div 'diverged) (escalate 'singular-field name))\n          ((eq? (car curl) 'error) (escalate 'malformed-field name))\n          (else (begin\n            (display (list name \"div:\" div \"curl:\" curl))\n            (list name div curl))))))\n(analyze-field-behavior (lambda (x y z) (list x y z)) 'radial)" :note "Combine divergence and curl analysis for a complete field characterization")
  )
  :caveats ("Field must return finite values; infinities, NaNs, or complex numbers cause escalation." "Central-difference approximation requires the field to be smooth; discontinuities or steep gradients reduce accuracy." "Dimension inference is implicit; mismatched field dimension (2-D vs 3-D) may produce garbage." "Result is deterministic within the device but subject to floating-point rounding.")
  :drawbacks ("Finite differences are approximate; grid spacing is fixed and not user-configurable." "No symbolic simplification; expensive to call repeatedly for the same field." "Does not indicate whether divergence is 'high' or 'low'—only returns the scalar value.")
  :usecases ("Fluid mechanics: verify incompressibility (∇·v = 0) in a velocity field." "Electrostatics: estimate charge density from an electric field (∇·E ∝ ρ)." "Source/sink detection: identify regions of outflow or inflow.")
  :related ("calc/curl" "calc/line-integral" "calc/surface-integral" "num/nintegrate-3d")
  :learn (:concept "Divergence is a scalar measure of field expansion/contraction; high positive divergence = outflow (source), negative = inflow (sink), zero = conservative." :prerequisites ("calculus / multivariable functions" "lambda (to define fields)") :progression "After calc/divergence, learn calc/curl to understand the rotational part of a field, then use both in calc/surface-integral.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A conservation-law check needs the divergence of a vector field; the audit is 'does mass conservation hold in this simulation snapshot?'"
     :program "(calc/divergence (lambda (p) (list (car p) (cadr p))) (list 1 2))"
     :explanation "F = (x, y); div F = 2; operator sees ≈ 2."
     :meta "Curl measures rotation; divergence measures expansion. Both apply to vector fields; use both to characterize the field.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-nd; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'expansion density of a vector field'"
     :rungs (
       (:domain "calc native" :code "(calc/divergence (lambda (p) (list (car p) (cadr p))) (list 1 2))")
       (:domain "flow-out of a fluid cell" :code "(motion/flux-out cell)")
       (:domain "∇ · F" :code "(∂F_1/∂x + ∂F_2/∂y)"))
     :explanation "Rung 1 is calc/divergence in its native library. Rung 2 shows the same ''expansion density of a vector field'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''expansion density of a vector field'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/divergence."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "For any C^2 vector field F, div(curl F) = 0."
     :program "(define F (lambda (p) (list (- (cadr p)) (car p))))\n(define curlF (lambda (p) (list 0 0 (calc/curl F p))))\n(< (abs (calc/divergence curlF (list 0.5 0.3))) 0.05)"
     :invariant "∀ F ∈ C^2. div(curl F) = 0"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch15-multivariable-linear-algebra.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-nd category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/divergence — see :summary."
     :composition "(define F (lambda (p) (list (car p) (cadr p))))\n(list (calc/divergence F (list 1 1)) (calc/curl F (list 1 1)))"
     :emergent "conservation-check"
     :meta "The emergent conservation-check belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Divergence + boundary integral = Divergence theorem. See book-of-ml ch-01.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-nd operations close into the conservation-check pattern."
     :cs "The emergent conservation-check is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/extrema-1d"
  :library "calc"
  :kind "meta"
  :signature "(calc/extrema-1d f a b) -> list"
  :summary "Finds critical points in [a, b] and classifies each as a local max, min, or saddle using the second derivative test."
  :explanation "Extrema are peaks and valleys—where a function reaches local maxima or minima. To find them: locate critical points (where f'(x) ≈ 0), then use the second derivative test: if f''(x) > 0 it's a min, if f''(x) < 0 it's a max, if f''(x) ≈ 0 it's inconclusive (saddle or inflection). This verb combines calc/critical-points-1d and calc/second-derivative to return a list of classified critical points."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define f (lambda (x) (- (* x x) (* 4 x))))\n(calc/extrema-1d f -1 5)" :note "f(x)=x²−4x; minimum at x=2 (where f'=2x−4=0, and f''=2>0); returns ((2 'min −4))")
    (:dialect "motoi" :tier "intermediate" :code "(define cubic (lambda (x) (- (* x x x) (* 3 x))))\n(let ((extrema (calc/extrema-1d cubic -2 2)))\n  (map (lambda (e) (list (car e) (cadr e) (round (* 100 (caddr e))))) extrema))" :note "f(x)=x³−3x has max at x=−1 and min at x=1; round values for readability")
    (:dialect "motoi" :tier "expert" :code "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define objective (lambda (x) (+ (* 2 (cos x)) x)))\n(let ((candidates (calc/extrema-1d objective 0 (* 4 3.14159))))\n  (let ((minima (filter (lambda (e) (eq? (cadr e) 'min)) candidates))\n        (maxima (filter (lambda (e) (eq? (cadr e) 'max)) candidates)))\n    (list (length minima) (length maxima))))" :note "Count local minima and maxima of a mixed trigonometric-linear function over [0, 4π]")
  )
  :caveats ("Second derivative test is inconclusive (returns 'saddle) when f''(x) ≈ 0; higher derivatives needed." "Requires f to be twice differentiable; corners or discontinuities break classification." "Numeric: does not distinguish global max/min from local; must compare values manually." "Endpoints (a, b) are not classified; check them separately if needed.")
  :drawbacks ("Two passes of finite-difference: one for f', one for f''; numeric errors compound." "Expensive for functions with many critical points or narrow intervals." "Symbolic extrema (via calc/critical-points-1d) can be more reliable if f is known.")
  :usecases ("Optimisation: finding local maxima/minima for curve fitting or control." "Physics: locating energy extrema or equilibrium points." "Data analysis: identifying peaks and valleys in sampled signals.")
  :related ("calc/critical-points-1d" "calc/second-derivative" "calc/derivative" "calc/differentiable?")
  :learn (:concept "Second derivative test; how concavity (f'' > 0 vs < 0) classifies critical points." :prerequisites ("calc/derivative" "calc/critical-points-1d" "calc/second-derivative") :progression "calc/gradient → calc/hessian (for multivariate extrema)")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "An optimization needs both max and min of a smooth function on a bounded interval — not just critical points but classified extrema."
     :program "(calc/extrema-1d (lambda (x) (* x x)) -2 2)"
     :explanation "Min at x=0 (value 0), max at x=±2 (value 4); operator sees the classified extrema."
     :meta "critical-points-1d returns all f'=0 candidates; extrema-1d additionally checks endpoints and classifies. Use extrema-1d when you want the answer, not the candidates.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-1d; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'max/min of a continuous function on a compact interval'"
     :rungs (
       (:domain "calc native" :code "(calc/extrema-1d (lambda (x) (* x x)) -2 2)")
       (:domain "brightest/darkest pixel in a scanline" :code "(image/scanline-extrema line)")
       (:domain "extreme value theorem application" :code "attained at boundary or where f\\' = 0"))
     :explanation "Rung 1 is calc/extrema-1d in its native library. Rung 2 shows the same ''max/min of a continuous function on a compact interval'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''max/min of a continuous function on a compact interval'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/extrema-1d."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "A continuous function on [a, b] attains its max and min in [a, b]."
     :program "(define f (lambda (x) (- (* x x) x)))\n(define ext (calc/extrema-1d f 0 1))\n(pair? ext)"
     :invariant "f continuous on [a, b] ⇒ ∃ M m. ∀ x ∈ [a, b]. f(m) ≤ f(x) ≤ f(M)"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch13-calculus-1 and ch14-calculus-2.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-1d category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/extrema-1d — see :summary."
     :composition "(define f (lambda (x) (* x x x)))\n(list (calc/extrema-1d f -1 1) (calc/critical-points-1d f -1 1))"
     :emergent "optimum-finder"
     :meta "The emergent optimum-finder belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Extremum finding + gradient descent = classical vs numerical optimization. See book-of-ml ch-06.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-1d operations close into the optimum-finder pattern."
     :cs "The emergent optimum-finder is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/gradient"
  :library "calc"
  :kind "meta"
  :signature "(calc/gradient f point) -> vector"
  :summary "Computes the gradient ∇f, the vector of all partial derivatives of a multivariable function at a point."
  :explanation "The gradient is the multivariable analogue of the derivative. For a function f(x, y, z, ...), the gradient ∇f is the vector (∂f/∂x, ∂f/∂y, ∂f/∂z, ...). It points in the direction of steepest ascent and is perpendicular to level sets. Use the gradient to find search directions in optimisation, to compute directional derivatives, and to analyse how output changes with each input."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define f (lambda (pt) (+ (* 2 (car pt)) (* 3 (cadr pt)))))\n(calc/gradient f (list 1 1))" :note "f(x,y)=2x+3y; gradient is (2, 3) everywhere (constant)")
    (:dialect "motoi" :tier "intermediate" :code "(define f (lambda (pt) (* (car pt) (cadr pt))))\n(let ((grad (calc/gradient f (list 2 3))))\n  (list (car grad) (cadr grad)))" :note "f(x,y)=xy; gradient at (2,3) is (∂f/∂x=y, ∂f/∂y=x) = (3, 2)")
    (:dialect "motoi" :tier "expert" :code "(define point '(0 0))\n(define f (lambda (pt) (+ (* (car pt) (car pt)) (* (cadr pt) (cadr pt)))))\n(let ((point (list 1 1))\n      (grad (calc/gradient f point)))\n  (let ((mag (sqrt (+ (* (car grad) (car grad)) (* (cadr grad) (cadr grad))))))\n    (list 'direction (list (/ (car grad) mag) (/ (cadr grad) mag))\n          'magnitude mag)))" :note "f(x,y)=x²+y²; at (1,1), gradient is (2,2), magnitude 2√2; normalise for steepest-ascent direction")
  )
  :caveats ("Numeric; finite-difference errors compound if f is noisy or oscillatory." "Point must be in the interior of the domain; behaviour near boundaries may be unreliable." "Does not verify that f is differentiable; may return nonsense at corners or discontinuities." "Linear functions have constant gradient; very expensive to compute many gradients if used repeatedly.")
  :drawbacks ("Each call requires n+1 function evaluations for n-dimensional f; quadratic in dimension for Hessian." "For functions with known symbolic gradient, compute once and store." "Scales poorly to very high-dimensional problems; use algorithmic differentiation if available.")
  :usecases ("Gradient descent: iteratively move in direction of negative gradient to minimise f." "Sensitivity: quantify dependence of output on each input at a point." "Contour analysis: compute normal direction perpendicular to level sets.")
  :related ("calc/directional-derivative" "calc/hessian" "calc/jacobian" "calc/laplacian")
  :learn (:concept "Gradient as vector of all partial derivatives; direction of steepest ascent; perpendicularity to level sets." :prerequisites ("calc/derivative" "basic multivariable calculus") :progression "calc/directional-derivative → calc/hessian → calc/jacobian")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A neural-network training step needs ∇L(w) — the gradient of loss with respect to parameters — as a plain vector to feed into an SGD update."
     :program "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))\n(calc/gradient f (list 1 2))"
     :explanation "∇f = (2x, 2y); at (1, 2), gradient = (2, 4); operator sees (2 4)."
     :meta "partial gives one component; gradient bundles all of them into a vector. Use gradient when you want to update all parameters at once.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-nd; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'vector of partial derivatives'"
     :rungs (
       (:domain "calc native" :code "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))")
       (:domain "per-pixel light-vector" :code "(shader/normal-map p)")
       (:domain "∇f = (∂_1 f, ∂_2 f, …, ∂_n f)" :code "∇f(x)"))
     :explanation "Rung 1 is calc/gradient in its native library. Rung 2 shows the same ''vector of partial derivatives'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''vector of partial derivatives'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/gradient."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "The gradient points in the direction of steepest ascent of f."
     :program "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))\n(define p (list 1 1))\n(define g (calc/gradient f p))\n(define g-mag (sqrt (+ (* (car g) (car g)) (* (cadr g) (cadr g)))))\n(> (calc/directional-derivative f p (list (/ (car g) g-mag) (/ (cadr g) g-mag)))\n   (calc/directional-derivative f p (list 1 0)))"
     :invariant "∀ unit v. D_v f(x) ≤ |∇f(x)|, equality at v = ∇f/|∇f|"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch15-multivariable-linear-algebra. Also book-of-ml ch-06 (gradient descent) — this is the primitive of gradient descent.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-nd category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/gradient — see :summary."
     :composition "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))\n(define lr 0.1)\n(define step (lambda (p) (let ((g (calc/gradient f p)))\n  (list (- (car p) (* lr (car g))) (- (cadr p) (* lr (cadr g)))))))\n(let loop ((n 0) (cur (list 3 3)))\n  (cond ((= n 5) cur) (else (loop (+ n 1) (step cur)))))"
     :emergent "gradient-descent-step"
     :meta "The emergent gradient-descent-step belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Gradient + learning rate = one SGD step; the universal ML primitive. See book-of-ml ch-06 and ch-10.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-nd operations close into the gradient-descent-step pattern."
     :cs "The emergent gradient-descent-step is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/hessian"
  :library "calc"
  :kind "meta"
  :signature "(calc/hessian f point) -> matrix"
  :summary "Computes the Hessian matrix, a symmetric matrix of all second partial derivatives at a point."
  :explanation "The Hessian is the Jacobian of the gradient: it contains all mixed partial derivatives ∂²f/∂xᵢ∂xⱼ. For a twice-differentiable function, the Hessian is symmetric. It encodes how the gradient itself is changing: its eigenvalues determine the curvature of the function along different directions. Use the Hessian to classify critical points (saddle, min, max) and to design second-order optimisation algorithms."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define f (lambda (pt) (+ (* (car pt) (car pt)) (* 2 (cadr pt) (cadr pt)))))\n(calc/hessian f (list 0 0))" :note "f(x,y)=x²+2y²; Hessian is [[2, 0], [0, 4]] everywhere (diagonal, constant curvature)")
    (:dialect "motoi" :tier "intermediate" :code "(define f (lambda (pt) (* (car pt) (cadr pt))))\n(let ((h (calc/hessian f (list 1 1))))\n  h)" :note "f(x,y)=xy; Hessian is [[0, 1], [1, 0]] everywhere (saddle point signature)")
    (:dialect "motoi" :tier "expert" :code "(define f (lambda (pt) (+ (* (car pt) (car pt) (car pt)) (cadr pt))))\n(let ((h (calc/hessian f (list 2 3))))\n  (let ((trace (+ (car (car h)) (cadr (cadr h)))))\n    (if (< trace 0) 'likely-max (if (> trace 0) 'likely-min 'inconclusive))))" :note "Use trace of Hessian (sum of eigenvalues) as rough concavity heuristic; preferable: compute eigenvalues via linalg/eigenvalues")
  )
  :caveats ("Numeric: expensive (O(n²) function evaluations for n dimensions) and prone to noise." "Assumes continuity of mixed partials (Schwarz's theorem); may be asymmetric if violated." "At critical points with f'' ≈ 0, eigenvalue classification becomes unreliable." "Does not check that f is twice differentiable.")
  :drawbacks ("Slow for high-dimensional functions; quadratic scaling in number of variables." "If only eigenvalues needed (for classification), use symbolic computation or linalg/eigenvalues-2x2 for small cases." "Numeric Hessian becomes very ill-conditioned for nearly-linear functions.")
  :usecases ("Newton's method: use Hessian inverse to accelerate optimisation." "Classification of critical points: eigenvalues determine whether min/max/saddle." "Second-order sensitivity: quantify curvature of objective function.")
  :related ("calc/gradient" "calc/directional-derivative" "calc/jacobian" "calc/laplacian" "calc/extrema-1d" "linalg/eigenvalues")
  :learn (:concept "Hessian as Jacobian of gradient; eigenvalues as principal curvatures; second-derivative test." :prerequisites ("calc/gradient" "calc/second-derivative" "basic linear algebra") :progression "linalg/eigenvalues → optimisation algorithms (beyond this library)")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A second-order optimizer (Newton, quasi-Newton) needs the Hessian matrix of second partials at a point."
     :program "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))\n(calc/hessian f (list 0 0))"
     :explanation "Hessian of x^2 + y^2 is [[2, 0], [0, 2]]; operator sees that matrix."
     :meta "Gradient is first-order; Hessian is second-order. Newton needs the Hessian to invert; SGD needs only the gradient.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-nd; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'second-derivative tensor'"
     :rungs (
       (:domain "calc native" :code "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))")
       (:domain "local curvature of a terrain" :code "(terrain/local-curvature map p)")
       (:domain "Hessian matrix" :code "H_{ij} = ∂²f / ∂x_i ∂x_j"))
     :explanation "Rung 1 is calc/hessian in its native library. Rung 2 shows the same ''second-derivative tensor'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''second-derivative tensor'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/hessian."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "For f ∈ C^2, the Hessian is symmetric: H_{ij} = H_{ji} (Schwarz)."
     :program "(define f (lambda (p) (+ (* (car p) (cadr p)) (* (car p) (car p)))))\n(define H (calc/hessian f (list 1 1)))\n(< (abs (- (list-ref (list-ref H 0) 1) (list-ref (list-ref H 1) 0))) 0.01)"
     :invariant "f ∈ C^2 ⇒ ∂²f/∂x_i ∂x_j = ∂²f/∂x_j ∂x_i"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch15-multivariable-linear-algebra.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-nd category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/hessian — see :summary."
     :composition "(define f (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))\n(define p (list 1 1))\n(define g (calc/gradient f p))\n(define H (calc/hessian f p))\n(list g H)"
     :emergent "newton-step-input"
     :meta "The emergent newton-step-input belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Gradient + Hessian = Newton step; see book-of-ml appendix-a (math prereqs).")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-nd operations close into the newton-step-input pattern."
     :cs "The emergent newton-step-input is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/integral"
  :library "calc"
  :kind "meta"
  :signature "(calc/integral f a b) -> number"
  :summary "Computes the definite integral ∫ₐᵇ f(x) dx using composite Simpson's rule."
  :explanation "The integral measures the signed area under a curve. Rather than compute symbolically, this verb numerically estimates the area by dividing [a, b] into intervals and summing parabolic approximations (Simpson's rule is more accurate than simple rectangles). Use it to compute total quantities (distance, work, probability) or to invert derivatives when a symbolic antiderivative is unavailable."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define f (lambda (x) 1))\n(calc/integral f 0 5)" :note "Integral of constant 1 from 0 to 5 is exactly 5 (area of rectangle)")
    (:dialect "motoi" :tier "intermediate" :code "(define f (lambda (x) (* x x)))\n(let ((approx (calc/integral f 0 3))\n      (exact (/ 27 3)))\n  (list 'approx approx 'exact exact))" :note "∫₀³ x² dx = x³/3|₀³ = 9; Simpson's rule should be very close")
    (:dialect "motoi" :tier "expert" :code "(define exp-x (lambda (x) (exp x)))\n(let ((a 0) (b 1))\n  (let ((area (calc/integral exp-x a b)))\n    (let ((average (/ area (- b a))))\n      (list 'integral area 'average-value average))))" :note "Compute integral, then divide by interval width to get calc/average-value directly")
  )
  :caveats ("Numeric; accuracy depends on smoothness of f and interval width." "Fails on discontinuities, singularities, or oscillations with period smaller than step size." "Integration over very wide intervals may accumulate rounding error." "Simpson's rule assumes f is smooth; highly oscillatory functions need finer subdivision (not exposed here).")
  :drawbacks ("No adaptive subdivision: fixed-size intervals mean coarse functions may be under-sampled." "Much slower than symbolic antiderivative if one exists." "Not suitable for improper integrals (infinite bounds); use mathematical transformation first.")
  :usecases ("Physics: computing work, displacement, or total charge from rates of change." "Probability: computing cumulative distribution or expected value numerically." "Engineering: area under experimental curves or signal processing.")
  :related ("calc/average-value" "calc/riemann-sum" "calc/arc-length" "calc/volume-revolution" "calc/surface-revolution")
  :learn (:concept "Definite integral as signed area; Simpson's rule as piecewise parabolic approximation." :prerequisites ("calc/derivative" "basic integral calculus") :progression "calc/average-value → calc/riemann-sum → calc/arc-length")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A total-area or accumulated-quantity computation needs ∫ f dx over an interval; analytic antiderivatives are often unavailable, so numerical integration is the honest tool."
     :program "(calc/integral (lambda (x) (* x x)) 0 1)"
     :explanation "∫₀¹ x² dx = 1/3; operator sees ≈ 0.333."
     :meta "riemann-sum exposes the mesh; integral hides it behind an adaptive method. For pedagogy, use riemann-sum; for production, integral.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-1d; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'accumulated area under a curve'"
     :rungs (
       (:domain "calc native" :code "(calc/integral (lambda (x) (* x x)) 0 1)")
       (:domain "total volume-samples of an audio window" :code "(audio/window-energy w)")
       (:domain "Riemann integral" :code "∫_a^b f(x) dx"))
     :explanation "Rung 1 is calc/integral in its native library. Rung 2 shows the same ''accumulated area under a curve'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''accumulated area under a curve'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/integral."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "The integral is linear and additive over intervals: ∫_a^c f = ∫_a^b f + ∫_b^c f for a ≤ b ≤ c."
     :program "(define f (lambda (x) (* x x)))\n(< (abs (- (calc/integral f 0 2) (+ (calc/integral f 0 1) (calc/integral f 1 2)))) 0.01)"
     :invariant "∀ a ≤ b ≤ c. ∫_a^c f = ∫_a^b f + ∫_b^c f"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch13-calculus-1 and ch14-calculus-2. Also ch-advanced-10 (Numerical Methods) for adaptive quadrature.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-1d category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/integral — see :summary."
     :composition "(define f (lambda (x) (* x x)))\n(list (calc/integral f 0 1) (calc/average-value f 0 1) (calc/arc-length f 0 1))"
     :emergent "definite-integral"
     :meta "The emergent definite-integral belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Integral + step + accumulate = the fundamental theorem of calculus workflow.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-1d operations close into the definite-integral pattern."
     :cs "The emergent definite-integral is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/jacobian"
  :library "calc"
  :kind "meta"
  :signature "(calc/jacobian fields point) -> matrix"
  :summary "Computes the Jacobian matrix, containing the gradient of each scalar field in a list of functions."
  :explanation "The Jacobian generalises the derivative to vector-valued functions: for a map F = (f₁, f₂, ..., fₘ) from ℝⁿ to ℝᵐ, the Jacobian is an m × n matrix where row i is ∇fᵢ. It encodes the linear approximation of F near a point. Use the Jacobian to analyse how a multivariable map behaves, to compute directional derivatives of each component, and to detect degeneracies (singular Jacobian means the map is not locally invertible)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define f1 (lambda (pt) (car pt)))\n(define f2 (lambda (pt) (cadr pt)))\n(calc/jacobian (list f1 f2) (list 1 2))" :note "Identity map (x, y) → (x, y); Jacobian is 2×2 identity matrix [[1,0],[0,1]]")
    (:dialect "motoi" :tier "intermediate" :code "(define fx (lambda (pt) (* (car pt) (cadr pt))))\n(define fy (lambda (pt) (+ (car pt) (cadr pt))))\n(let ((j (calc/jacobian (list fx fy) (list 2 3))))\n  (list 'row1 (car j) 'row2 (cadr j)))" :note "F(x,y)=(xy, x+y); Jacobian at (2,3) is [[∂xy/∂x, ∂xy/∂y], [∂(x+y)/∂x, ∂(x+y)/∂y]] = [[3,2],[1,1]]")
    (:dialect "motoi" :tier "expert" :code "(define u (lambda (pt) (* (car pt) (car pt))))\n(define v (lambda (pt) (* (cadr pt) (cadr pt))))\n(let ((fields (list u v))\n      (point (list 1 1)))\n  (let ((j (calc/jacobian fields point)))\n    (let ((det (- (* (car (car j)) (cadr (cadr j)))\n                   (* (cadr (car j)) (car (cadr j))))))\n      (if (< (abs det) 0.01) 'singular 'invertible))))" :note "Check if Jacobian is singular by testing determinant; F(x,y)=(x², y²) is singular at origin")
  )
  :caveats ("Numeric; each field's gradient is subject to finite-difference error." "Assumes fields are listed in order matching the matrix rows." "Does not compute determinant or rank; check those separately (linalg/determinant, linalg/rank)." "Very expensive for many fields or high-dimensional domains.")
  :drawbacks ("O(m·n) function evaluations for m fields and n-dimensional input; scales poorly." "If determinant or eigenvalues are needed, extract Jacobian and use linalg/* separately." "Numeric Jacobian becomes ill-conditioned near singularities.")
  :usecases ("Change of variables: verify invertibility and compute Jacobian determinant for integrals." "Implicit function theorem: check when a system can be locally solved." "Nonlinear systems: Newton's method for F(x) = 0 (vs scalar Newton with calc/newton).")
  :related ("calc/gradient" "calc/hessian" "calc/laplacian" "linalg/determinant" "linalg/rank")
  :learn (:concept "Jacobian as stacked gradients; linear approximation of vector-valued functions; invertibility." :prerequisites ("calc/gradient" "calc/directional-derivative" "linalg basics") :progression "linalg/determinant → linalg/rank → implicit function theorem (beyond this library)")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A change-of-variables integration or a nonlinear-solver linearization needs the Jacobian matrix of a vector-valued function."
     :program "(define f (lambda (p) (list (+ (car p) (cadr p)) (- (car p) (cadr p)))))\n(calc/jacobian f (list 1 1))"
     :explanation "J = [[1, 1], [1, -1]]; operator sees that matrix."
     :meta "gradient is for scalar-valued functions; jacobian generalizes to vector-valued. Use jacobian when the output is a vector.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-nd; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'best linear approximation of a vector map'"
     :rungs (
       (:domain "calc native" :code "(define f (lambda (p) (list (+ (car p) (cadr p)) (- (car p) (cadr p)))))")
       (:domain "local warp matrix at a pixel" :code "(shader/local-warp p)")
       (:domain "Jacobian matrix" :code "J_{ij} = ∂f_i / ∂x_j"))
     :explanation "Rung 1 is calc/jacobian in its native library. Rung 2 shows the same ''best linear approximation of a vector map'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''best linear approximation of a vector map'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/jacobian."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "For a diffeomorphism f, the volume element transforms via |det J|."
     :program "(define f (lambda (p) (list (+ (car p) (cadr p)) (- (car p) (cadr p)))))\n(define J (calc/jacobian f (list 0 0)))\n(number? (list-ref (list-ref J 0) 0))"
     :invariant "dV(y) = |det J_f(x)| dV(x)"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch15-multivariable-linear-algebra. Also book-of-ml ch-03 for matrix side.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-nd category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/jacobian — see :summary."
     :composition "(define f (lambda (p) (list (* (car p) (cadr p)) (+ (car p) (cadr p)))))\n(define J (calc/jacobian f (list 1 2)))\nJ"
     :emergent "linearization"
     :meta "The emergent linearization belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Jacobian = best linear approximation; the multivariate analog of the tangent line.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-nd operations close into the linearization pattern."
     :cs "The emergent linearization is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/laplacian"
  :library "calc"
  :kind "meta"
  :signature "(calc/laplacian f point) -> number"
  :summary "Computes the Laplacian of a scalar field: the trace of the Hessian matrix, or sum of all second partial derivatives."
  :explanation "The Laplacian ∇²f = ∑ᵢ ∂²f/∂xᵢ² is a fundamental differential operator measuring how a function's value at a point differs from its average in a neighborhood. It appears in heat diffusion, wave equations, and electrostatics. Numerically, it is computed as the sum of all unmixed second partials using central differences with step h≈1e-5."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define f (lambda (p) (+ (expt (car p) 2) (expt (cadr p) 2))))\n(calc/laplacian f '(1 2))" :note "f(x,y) = x² + y² has Laplacian ∇²f = 4 everywhere; the result should be close to 4")
    (:dialect "motoi" :tier "intermediate" :code "(define f (lambda (p) (let ((x (car p)) (y (cadr p)))\n  (- (* x x) (* y y)))))\n(calc/laplacian f '(0 0))\n(calc/laplacian f '(3 4))" :note "f(x,y) = x² − y² has ∇²f = 2 − 2 = 0 everywhere; both calls should return ~0")
    (:dialect "motoi" :tier "expert" :code "(define (field-info f region-pts)\n  (map (lambda (pt) (list pt (calc/laplacian f pt)))\n       region-pts))\n(define f (lambda (p) (expt (math/exp 1) (- (+ (expt (car p) 2) (expt (cadr p) 2))))))\n(field-info f '((0 0) (1 0) (0 1)))" :note "Computes Laplacian at multiple grid points; useful for detecting smoothness or singularities in a scalar field")
  )
  :caveats ("Requires a function that takes a list (point in ℝⁿ) and returns a scalar" "Numeric approximation; accuracy depends on step size h and function smoothness" "If f is not smooth, results may be noisy or unreliable near discontinuities" "Assumes dimension of point matches what f expects")
  :drawbacks ("Finite-difference approximation introduces truncation error O(h²)" "Expensive for high-dimensional spaces (requires 2n+1 function evaluations)" "No symbolic simplification; use calc/hessian if you need the full matrix")
  :usecases ("Detecting critical points and saddle regions in optimization" "Solving Poisson equation ∇²u = f in PDE applications" "Measuring smoothness of a neural network or interpolant" "Heat diffusion and wave equation solvers")
  :related ("calc/hessian" "calc/gradient" "calc/partial" "calc/directional-derivative" "calc/jacobian")
  :learn (:concept "The Laplacian as the sum of unmixed second derivatives; geometric meaning of curvature in all directions" :prerequisites ("calc/partial" "calc/hessian") :progression "Use calc/laplacian to understand multivariate curvature, then explore calc/jacobian for vector fields and calc/gradient for optimization")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A heat-equation or Poisson-solve step needs Δf = ∇·∇f at a point; the operator wants a single call rather than composing gradient and divergence."
     :program "(calc/laplacian (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))) (list 0 0))"
     :explanation "Δ(x² + y²) = 4; operator sees ≈ 4."
     :meta "divergence takes a vector field; laplacian takes a scalar. The two compose (Δf = div ∇f) but the direct verb is cleaner.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-nd; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'trace of the Hessian'"
     :rungs (
       (:domain "calc native" :code "(calc/laplacian (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))) (list 0 0))")
       (:domain "image smoothing / blur kernel" :code "(image/laplacian-blur img)")
       (:domain "Δf = Σ ∂²f/∂x_i²" :code "Δf = ∇·∇f"))
     :explanation "Rung 1 is calc/laplacian in its native library. Rung 2 shows the same ''trace of the Hessian'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''trace of the Hessian'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
