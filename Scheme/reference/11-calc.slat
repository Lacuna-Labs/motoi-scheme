;;; 11-calc.slat — Motoi Scheme Reference · Chapter 11 · library calc
;;;
;;; 30 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library calc — 30 verbs.")

(chapter :number "11" :library "calc" :verb-count 30 :training-eligible #t)

;; ═══ 30 verbs in library calc ═══

(verb
  :name "calc/arc-length"
  :library "calc"
  :kind "meta"
  :signature "(calc/arc-length f a b) -> number"
  :summary "Computes the arc length of the curve y = f(x) from x = a to x = b."
  :explanation "Arc length is the integral ∫ᵃᵇ √(1 + (f'(x))²) dx, which measures how long the curve is. Since this integral rarely has a closed form, the verb uses Simpson's rule (adaptive numerical integration) to approximate it to high precision. Essential for understanding curve geometry and computing physical quantities like string length or material usage along a path."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(calc/arc-length (lambda (x) (* x x)) 0 1)\n;; => ≈ 1.478\n;; Arc length of the parabola y = x² from 0 to 1." :note "Basic use: measure the length of a simple curve.")
    (:dialect "motoi" :tier "intermediate" :code "(define (circle-arc-length radius angle-radians)\n  ;; Arc length of a circle parameterized as y = √(r²−x²)\n  ;; This is an approximation; exact = radius · angle.\n  (let ((f (lambda (x) (sqrt (- (* radius radius) (* x x))))))\n    (calc/arc-length f 0 radius)))\n(circle-arc-length 1 (/ 3.14159 2))\n;; => ≈ 1.57 (half the circumference of a unit circle)" :note "Integrate a semicircle; compare to the formula 2πr/2.")
    (:dialect "motoi" :tier "expert" :code "(define (catenary a x-min x-max)\n  ;; y = a·cosh(x/a), the shape of a hanging chain\n  (lambda (x) (* a (exp (/ x a)))))\n(define (chain-length a)\n  ;; Arc length of catenary from −a to a\n  (calc/arc-length (catenary a 0) (- a) a))\n(chain-length 1)\n;; => ≈ 2.35 (actual = 2·sinh(1) ≈ 2.35)" :note "Real application: compute the length of a hanging cable.")
  )
  :caveats ("Numerical approximation; not exact. Accuracy depends on the smoothness of f and the chosen tolerance." "f must be differentiable and reasonably smooth on [a, b]. Cusps or discontinuities will degrade accuracy." "Slow for highly oscillatory functions; may require many evaluations." "If a > b, the integral is negated (always use a < b for arc length).")
  :drawbacks ("Cannot handle infinite-length curves (e.g., spirals)." "For parametric curves, use calc/arc-length-param instead (more efficient and numerically stable)." "No built-in timeout; ill-conditioned functions may loop." "Requires calling calc/arc-length for each segment if the function changes.")
  :usecases ("Computing string or cable length in mechanical design." "Finding the perimeter of a curve (special case: ellipse perimeter is not closed-form)." "Arc-length parameterization: reparameterize a curve by distance along it." "Physics: work done against friction along a curved path.")
  :related ("calc/arc-length-param" "calc/derivative" "calc/surface-revolution" "calc/riemann-sum" "curve/arc-length")
  :learn (:concept "Arc length as an integral; numerical integration and Simpson's rule." :prerequisites ("calc/derivative" "calc/integral") :progression "Study calc/arc-length-param for curves given parametrically (x(t), y(t)), then calc/surface-revolution to compute surface area when rotating a curve.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A cable-length estimation over a smooth curve y = f(x) needs a single numerical answer; the operator does not want to derive the arc-length integral by hand."
     :program "(calc/arc-length (lambda (x) (* x x)) 0 1)"
     :explanation "Arc length of parabola y = x^2 from 0 to 1 is ≈ 1.478; the operator uses that as the cable-material estimate."
     :meta "calc/integral gives ∫f dx (area under the curve); calc/arc-length gives ∫√(1+f'^2) dx (length along the curve). Confusing them gives wildly wrong material budgets.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-1d; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'measure of a 1-dimensional continuous object'"
     :rungs (
       (:domain "calc native" :code "(calc/arc-length (lambda (x) (* x x)) 0 1)")
       (:domain "length of a rendered curve on screen" :code "(curve/pixel-length spline)")
       (:domain "Riemann integral of √(1+f\\'^2)" :code "∫_a^b √(1 + f\\'(x)^2) dx"))
     :explanation "Rung 1 is calc/arc-length in its native library. Rung 2 shows the same ''measure of a 1-dimensional continuous object'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''measure of a 1-dimensional continuous object'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/arc-length."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Arc length is non-negative and monotone in the interval [a, b]: extending [a, b] never decreases the length."
     :program "(define f (lambda (x) x))\n(define L1 (calc/arc-length f 0 1))\n(define L2 (calc/arc-length f 0 2))\n(<= L1 L2)"
     :invariant "∀ f, [a, b] ⊆ [c, d]. arc-length(f, a, b) ≤ arc-length(f, c, d)"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch14-calculus-2. Also ch-advanced-10 (Numerical Methods) for the numerical quadrature.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-1d category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/arc-length — see :summary."
     :composition "(define f (lambda (x) x))\n(define seg (map (lambda (b) (calc/arc-length f 0 b)) (list 1 2 3 4)))\nseg"
     :emergent "reparametrization-by-length"
     :meta "The emergent reparametrization-by-length belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Arc-length parametrization is the foundational tool for constant-speed curve traversal. See book-of-motion for smooth-motion applications.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-1d operations close into the reparametrization-by-length pattern."
     :cs "The emergent reparametrization-by-length is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/arc-length-param"
  :library "calc"
  :kind "meta"
  :signature "(calc/arc-length-param fx fy t-min t-max) -> number"
  :summary "Computes the arc length of a parametric curve (x(t), y(t)) from t = t-min to t = t-max."
  :explanation "For a curve defined parametrically as x = fx(t), y = fy(t), the arc length is ∫ᵗᵐⁱⁿᵗᵐᵃˣ √(ẋ² + ẏ²) dt, where ẋ and ẏ are derivatives with respect to t. This is more general and often more numerically stable than calc/arc-length (which requires solving for y explicitly). Use this whenever the curve is naturally given in parametric form (circles, spirals, Bézier curves, etc.)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(calc/arc-length-param\n  (lambda (t) (cos t))\n  (lambda (t) (sin t))\n  0 (/ 3.14159 2))\n;; => ≈ 1.57\n;; Arc length of a quarter-circle (radius 1, centered at origin)." :note "Parametrize a circle; arc length should be radius × angle = 1 × π/2.")
    (:dialect "motoi" :tier "intermediate" :code "(define (spiral-arc-length theta-max)\n  ;; Archimedean spiral: x = t·cos(t), y = t·sin(t)\n  (calc/arc-length-param\n    (lambda (t) (* t (cos t)))\n    (lambda (t) (* t (sin t)))\n    0 theta-max))\n(spiral-arc-length 3.14159)\n;; => ≈ 5.3 (spiral from center outward)" :note "Spirals are naturally parametric; much easier than solving for y = f(x).")
    (:dialect "motoi" :tier "expert" :code "(define (cubic-bezier p0 p1 p2 p3 t)\n  ;; Cubic Bézier curve: B(t) = (1−t)³P₀ + 3(1−t)²tP₁ + 3(1−t)t²P₂ + t³P₃\n  (define (lerp a b s) (+ (* a (- 1 s)) (* b s)))\n  (define (quad-lerp a b c s)\n    (lerp (lerp a b s) (lerp b c s) s))\n  (define (cubic-lerp a b c d s)\n    (lerp (quad-lerp a b c s) (quad-lerp b c d s) s))\n  (cubic-lerp p0 p1 p2 p3 t))\n(define (bezier-length p0 p1 p2 p3)\n  ;; Length of a cubic Bézier curve from t=0 to t=1\n  (calc/arc-length-param\n    (lambda (t) (cubic-bezier (car p0) (car p1) (car p2) (car p3) t))\n    (lambda (t) (cubic-bezier (cdr p0) (cdr p1) (cdr p2) (cdr p3) t))\n    0 1))\n(bezier-length '(0 . 0) '(1 . 2) '(3 . 1) '(4 . 0))\n;; => ≈ length of the curve" :note "Bézier curves are parametric; computing their length requires arc-length-param.")
  )
  :caveats ("Numerical approximation; accuracy depends on smoothness and tolerance." "Both fx and fy must be continuous and differentiable on [t-min, t-max]." "If the curve passes through the same point twice (self-intersection), arc-length-param still works; it measures total length, not distance." "Slow for highly oscillatory or tightly curved paths.")
  :drawbacks ("Requires two function definitions (fx and fy), making the call slightly verbose." "No protection against cusps or singularities in the parameterization." "For 3D curves, would need a 3D variant (not provided).")
  :usecases ("Computing Bézier curve lengths in graphics and CAD." "Length of circular arcs, spirals, and other naturally parametric curves." "Arc-length parameterization for uniform motion along a path." "Measuring rope or cable in curved layouts.")
  :related ("calc/arc-length" "calc/derivative" "calc/integral" "curve/arc-length" "curve/sample")
  :learn (:concept "Parametric arc length; why it is more general and stable than implicit forms." :prerequisites ("calc/derivative" "calc/integral") :progression "After mastering this, study calc/arc-length for implicit curves, then move to curve/arc-length which is optimized for spline and Bézier geometry.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A parametric curve (Bezier, spline) needs its total length; solving y = f(x) for a parametric curve is not always possible so the parametric-form integral is the honest tool."
     :program "(calc/arc-length-param (lambda (t) (cos t)) (lambda (t) (sin t)) 0 (/ 3.14159 2))"
     :explanation "Quarter-unit-circle arc length is π/2 ≈ 1.57; operator sees the expected value."
     :meta "arc-length assumes y = f(x); arc-length-param accepts x(t), y(t). For self-intersecting or vertical-tangent curves, only the parametric form works.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-1d; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'total variation of a parametric trajectory'"
     :rungs (
       (:domain "calc native" :code "(calc/arc-length-param (lambda (t) (cos t)) (lambda (t) (sin t)) 0 (/ 3.14159 2))")
       (:domain "total distance traveled by a moving sprite" :code "(motion/total-distance path)")
       (:domain "∫ ||γ\\'(t)|| dt" :code "∫_a^b √(x\\'(t)^2 + y\\'(t)^2) dt"))
     :explanation "Rung 1 is calc/arc-length-param in its native library. Rung 2 shows the same ''total variation of a parametric trajectory'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''total variation of a parametric trajectory'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/arc-length-param."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Arc length is reparametrization-invariant: any strictly-monotone reparametrization gives the same length."
     :program "(define x (lambda (t) t)) (define y (lambda (t) (* t t)))\n(define x2 (lambda (u) (* u u))) (define y2 (lambda (u) (expt u 4)))\n(let ((L1 (calc/arc-length-param x y 0 1))\n      (L2 (calc/arc-length-param x2 y2 0 1)))\n  (< (abs (- L1 L2)) 0.01))"
     :invariant "∀ γ, φ strictly-mono. length(γ) = length(γ ∘ φ)"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch14-calculus-2.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-1d category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/arc-length-param — see :summary."
     :composition "(define x (lambda (t) (cos t)))\n(define y (lambda (t) (sin t)))\n(define angles (list 0.5 1.0 1.5 2.0))\n(map (lambda (t) (calc/arc-length-param x y 0 t)) angles)"
     :emergent "cumulative-arc"
     :meta "The emergent cumulative-arc belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Cumulative arc → uniform-speed parametrization; the same shape as CDF from PDF in probability. See book-of-ml ch-01.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-1d operations close into the cumulative-arc pattern."
     :cs "The emergent cumulative-arc is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/average-value"
  :library "calc"
  :kind "meta"
  :signature "(calc/average-value f a b) -> number"
  :summary "Computes the mean value of f over the interval [a, b] as 1/(b−a) ∫ᵃᵇ f(x) dx."
  :explanation "The average value of a function over an interval is its integral divided by the interval's width. Intuitively, it is the height of a rectangle with the same area as the region under the curve. This is the continuous analog of arithmetic mean and appears in physics (average velocity, average power), statistics, and engineering."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(calc/average-value (lambda (x) x) 0 10)\n;; => 5.0\n;; Average of the linear function f(x) = x from 0 to 10 is 5." :note "Simple linear function; the average is the midpoint.")
    (:dialect "motoi" :tier "intermediate" :code "(define (rms f a b)\n  ;; Root-mean-square: √(average of f²)\n  (sqrt (calc/average-value (lambda (x) (* (f x) (f x))) a b)))\n(rms (lambda (x) (sin x)) 0 3.14159)\n;; => ≈ 0.707\n;; RMS of sin(x) over one period; theoretical = 1/√2 ≈ 0.707" :note "Use average-value to compute RMS, a standard in signal processing.")
    (:dialect "motoi" :tier "expert" :code "(define (power-average f a b p)\n  ;; pth power mean: (average of f^p)^(1/p)\n  (expt (calc/average-value (lambda (x) (expt (f x) p)) a b) (/ 1 p)))\n(let ((f (lambda (x) (+ 2 (* 0.5 (cos x))))))\n  (list (power-average f 0 6.28 1)   ;; Arithmetic mean\n        (power-average f 0 6.28 2)   ;; Quadratic mean (RMS)\n        (power-average f 0 6.28 -1))) ;; Harmonic mean\n;; => (≈2.0 ≈2.06 ≈1.94)" :note "Generalize to power means; illustrates calc/average-value's composability.")
  )
  :caveats ("Numerical approximation; accuracy depends on f's smoothness." "Division by (b − a) assumes a ≠ b; behavior undefined or infinite at a = b." "If f has discontinuities or wild oscillations, the integral may be inaccurate, degrading the average.")
  :drawbacks ("Slower than direct formula for simple functions (e.g., average of x on [0, 10] is 5 by algebra)." "No symbolic simplification; always numeric.")
  :usecases ("Computing average velocity or acceleration from kinematic curves." "Signal processing: average power, RMS voltage in electrical circuits." "Statistics: estimating population mean from a continuous distribution." "Engineering: load or stress averages over a span or time period.")
  :related ("calc/integral" "calc/riemann-sum" "calc/mean-curvature" "stat/mean")
  :learn (:concept "Mean value theorem: the geometric interpretation of average as the height of an equal-area rectangle." :prerequisites ("calc/integral") :progression "Study the mean value theorem formally, then calc/derivative to understand conditions for existence, and curve/speed for average speed along parametric paths.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A temperature-log analysis needs the mean value of a continuous reading over an interval — the discrete average of samples is a hack; the honest answer is the integral mean."
     :program "(calc/average-value (lambda (x) (* x x)) 0 1)"
     :explanation "Average of x^2 on [0,1] = 1/3; operator sees ≈ 0.333."
     :meta "integral gives the total; average-value divides by the interval length. Reporting the total when the operator wants the average confuses cumulative for typical.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-1d; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'mean of a continuous function over an interval'"
     :rungs (
       (:domain "calc native" :code "(calc/average-value (lambda (x) (* x x)) 0 1)")
       (:domain "average audio-level over a window" :code "(audio/mean-level window)")
       (:domain "integral mean" :code "(1/(b-a)) ∫_a^b f(x) dx"))
     :explanation "Rung 1 is calc/average-value in its native library. Rung 2 shows the same ''mean of a continuous function over an interval'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''mean of a continuous function over an interval'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/average-value."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "The average value of f on [a, b] is attained by f at some point in [a, b] if f is continuous (Mean Value Theorem for integrals)."
     :program "(define f (lambda (x) (* x x)))\n(define avg (calc/average-value f 0 1))\n(and (< avg (f 1)) (> avg (f 0)))"
     :invariant "∀ f continuous on [a, b]. ∃ c ∈ [a, b]. f(c) = (1/(b-a)) ∫_a^b f"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch13-calculus-1 and ch14-calculus-2.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-1d category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/average-value — see :summary."
     :composition "(define f (lambda (x) (sin x)))\n(list (calc/average-value f 0 3.14159)\n      (calc/average-value f 0 (* 2 3.14159)))"
     :emergent "moving-average"
     :meta "The emergent moving-average belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Windowed averages are the calculus-side ancestor of digital moving averages. See book-of-composition ch-10 (fx-chain).")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-1d operations close into the moving-average pattern."
     :cs "The emergent moving-average is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/continuous?"
  :library "calc"
  :kind "meta"
  :signature "(calc/continuous? f a) -> boolean"
  :summary "Tests numerically whether f is continuous at x = a by checking if left and right limits equal f(a)."
  :explanation "A function is continuous at a point a if lim_{x→a⁻} f(x) = lim_{x→a⁺} f(x) = f(a). Since we work numerically, the verb evaluates f at points approaching a from both sides and checks whether the limits agree with f(a) within a tolerance. This is a pragmatic test for continuity in a discrete world; it catches jumps, holes, and removable discontinuities."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(calc/continuous? (lambda (x) (+ 1 (* 2 x))) 3)\n;; => #t\n;; Polynomials are continuous everywhere." :note "Basic case: test a polynomial, which is always continuous.")
    (:dialect "motoi" :tier "intermediate" :code "(calc/continuous? (lambda (x) (/ 1 x)) 1)\n;; => #t\n(calc/continuous? (lambda (x) (/ 1 x)) 0)\n;; => #f\n;; 1/x is continuous away from 0, but has a pole at 0." :note "Detect discontinuities: the test catches poles and removable singularities.")
    (:dialect "motoi" :tier "expert" :code "(define (signed-step x)\n  ;; Jump discontinuity: −1 for x < 0, +1 for x ≥ 0\n  (if (< x 0) -1 1))\n(calc/continuous? signed-step 0)\n;; => #f\n;; The function jumps at x = 0; left limit (−1) ≠ right limit (+1)." :note "Jump discontinuities are detected because the one-sided limits disagree.")
  )
  :caveats ("Numerical test; there is a tolerance threshold. Functions continuous in theory may fail if tolerance is too strict, or vice versa." "Requires evaluating f at nearby points; if f has side effects (unlikely in Motoi but possible), this will invoke them." "Does not test continuity on an interval, only at a single point a.")
  :drawbacks ("Slow for functions with deep recursion or expensive computation." "Cannot distinguish removable discontinuities from true jumps in some cases (depends on tolerance)." "For piecewise functions, you may need to test each piece separately." "Not a proof of continuity; only a strong numerical indication.")
  :usecases ("Validating data before applying calculus operators (derivative, integral)." "Detecting anomalies in experimental or sensor data." "Pre-checking domains before applying calc/differentiable? or calc/derivative." "Debugging functions that should be continuous but are not.")
  :related ("calc/differentiable?" "calc/derivative" "calc/limit")
  :learn (:concept "Continuity and its ε−δ definition; how to test it numerically." :prerequisites ("calc/limit") :progression "After testing continuity, study calc/differentiable? to check differentiability (a stronger condition), and calc/derivative to compute slopes.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "Before applying an integration or extremum verb, the operator needs a fast check: is the function continuous on the interval, or will the algorithm hit a jump?"
     :program "(list (calc/continuous? (lambda (x) x) 0 1)\n      (calc/continuous? (lambda (x) (if (< x 0.5) 0 1)) 0 1))"
     :explanation "Linear function is continuous; step function is not; operator sees (#t #f)."
     :meta "differentiable? implies continuous but not vice versa; use continuous? for the weaker precondition of integral and limit.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-1d; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'no-jump property of a function'"
     :rungs (
       (:domain "calc native" :code "(list (calc/continuous? (lambda (x) x) 0 1)")
       (:domain "audio has no clicks in a window" :code "(audio/no-click? window)")
       (:domain "epsilon-delta continuity" :code "∀ ε > 0 ∃ δ > 0. |x-y| < δ ⇒ |f(x)-f(y)| < ε"))
     :explanation "Rung 1 is calc/continuous? in its native library. Rung 2 shows the same ''no-jump property of a function'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''no-jump property of a function'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/continuous?."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "If f is continuous on [a, b], f attains its max and min on [a, b] (extreme value theorem)."
     :program "(define f (lambda (x) (* x x)))\n(and (calc/continuous? f 0 1)\n     (number? (calc/extrema-1d f 0 1)))"
     :invariant "f continuous on [a, b] ⇒ ∃ M m ∈ [a, b]. ∀ x. f(m) ≤ f(x) ≤ f(M)"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch13-calculus-1 and ch14-calculus-2.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-1d category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/continuous? — see :summary."
     :composition "(define fs (list (lambda (x) x) (lambda (x) (/ 1 x))))\n(map (lambda (f) (calc/continuous? f 0.5 2)) fs)"
     :emergent "pre-integration-gate"
     :meta "The emergent pre-integration-gate belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Continuity check before analysis is the same validate-then-run family as JSON-schema before parse. See book-of-composition ch-15 (http-server).")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-1d operations close into the pre-integration-gate pattern."
     :cs "The emergent pre-integration-gate is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/critical-points-1d"
  :library "calc"
  :kind "meta"
  :signature "(calc/critical-points-1d f a b) -> list"
  :summary "Finds all points in [a, b] where the derivative f'(x) is approximately zero."
  :explanation "Critical points are candidates for local extrema (maxima, minima, or inflection points). They are the x-values where f'(x) ≈ 0. This verb numerically differentiates f, searches for zero-crossings of the derivative, and returns a sorted list of such points. Use with calc/extrema-1d to classify each critical point."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(calc/critical-points-1d (lambda (x) (- (* x x) (* 2 x))) 0 3)\n;; => (1.0)\n;; For f(x) = x² − 2x, the derivative is 2x − 2, zero at x = 1." :note "Simple parabola; one critical point at the vertex.")
    (:dialect "motoi" :tier "intermediate" :code "(define (cubic x) (- (* x x x) (* 3 x)))\n(calc/critical-points-1d cubic -2 2)\n;; => (−1.0 1.0)\n;; For f(x) = x³ − 3x, critical points at x = ±1 (local max and min)." :note "Multiple critical points; classify them next with calc/extrema-1d.")
    (:dialect "motoi" :tier "expert" :code "(define cubic (lambda args (list \"cubic\" args)))\n(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (find-extrema-and-classify f a b)\n  ;; Find critical points and classify each as max, min, or saddle\n  (let ((cpts (calc/critical-points-1d f a b)))\n    (map (lambda (x)\n           (let ((extrema (calc/extrema-1d f a b)))\n             ;; extrema returns a list of classified points\n             ;; Filter those matching x\n             (let ((match (filter (lambda (e) (< (abs (- (car e) x)) 0.000001)) extrema)))\n               (if (null? match) (list x 'unknown) (car match)))))\n         cpts)))\n;; Example usage (hypothetical matching with calc/extrema-1d output)\n(find-extrema-and-classify cubic -2 2)\n;; => ((−1 'maximum) (1 'minimum))" :note "Combine critical-points-1d and extrema-1d for a full analysis.")
  )
  :caveats ("Numerical approximation; very close critical points may be missed or duplicated." "Requires f to be smooth (continuously differentiable) in [a, b]. Cusps, kinks, or discontinuities degrade accuracy." "Endpoints (a, b) are not included even if f'(a) or f'(b) is zero." "False positives near domain boundaries if f'(x) oscillates.")
  :drawbacks ("Slow for highly oscillatory functions." "Does not classify critical points; use calc/extrema-1d for that." "No built-in timeout; pathological functions may loop." "Sensitive to numerical noise in f' (derivative amplifies small errors).")
  :usecases ("Optimization: finding candidate extrema before refining with gradient descent." "Curve analysis: understanding the shape and turning points of a function." "Physics: finding equilibrium points where force (−dF/dx) is zero." "Data analysis: detecting peaks and valleys in time-series data.")
  :related ("calc/extrema-1d" "calc/derivative" "calc/continuous?" "calc/differentiable?")
  :learn (:concept "Critical points as zeros of the derivative; Fermat's theorem on local extrema." :prerequisites ("calc/derivative" "calc/continuous?") :progression "Use calc/extrema-1d to classify critical points via the second derivative test, then study the relationship between critical points and monotonicity.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "An optimization problem needs the interior critical points where f'(x) = 0; the audit expects each one to be a local extremum or a saddle."
     :program "(calc/critical-points-1d (lambda (x) (- (* x x x) (* 3 x))) -3 3)"
     :explanation "f = x^3 - 3x has f' = 3x^2 - 3, zeros at x = ±1; operator sees a list containing 1 and -1."
     :meta "extrema-1d filters critical points to actual maxima/minima; critical-points-1d returns all f'(x) = 0 candidates including inflection points.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-1d; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'zeros of a derivative'"
     :rungs (
       (:domain "calc native" :code "(calc/critical-points-1d (lambda (x) (- (* x x x) (* 3 x))) -3 3)")
       (:domain "flat regions in a level curve" :code "(curve/flat-points spline)")
       (:domain "roots of f\\'(x) = 0" :code "{x : f\\'(x) = 0}"))
     :explanation "Rung 1 is calc/critical-points-1d in its native library. Rung 2 shows the same ''zeros of a derivative'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''zeros of a derivative'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/critical-points-1d."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "At every critical point of a differentiable f, the derivative vanishes: f'(c) = 0."
     :program "(define f (lambda (x) (- (* x x x) (* 3 x))))\n(define df (calc/derivative f))\n(define cps (calc/critical-points-1d f -3 3))\n(let loop ((cs cps))\n  (or (null? cs) (and (< (abs (df (car cs))) 0.01) (loop (cdr cs)))))"
     :invariant "∀ c ∈ crit(f). f\\'(c) = 0"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch13-calculus-1 and ch14-calculus-2.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-1d category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/critical-points-1d — see :summary."
     :composition "(define f (lambda (x) (- (* x x x) (* 3 x))))\n(define cps (calc/critical-points-1d f -3 3))\n(map f cps)"
     :emergent "candidate-optima"
     :meta "The emergent candidate-optima belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Critical points → extremum classification is the classical Fermat program. See book-of-ml ch-06 (gradient descent).")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-1d operations close into the candidate-optima pattern."
     :cs "The emergent candidate-optima is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/curl"
  :library "calc"
  :kind "meta"
  :signature "(calc/curl F [opts]) -> scalar | vector | (escalate 'shape-error)"
  :summary "Computes the curl (∇×F) of a 2-D scalar or 3-D vector field."
  :explanation "Curl measures the rotation or circulation of a vector field. In 2-D, curl of a scalar field returns a scalar (the z-component of rotation); in 3-D, curl of a vector field returns a vector. calc/curl takes a field representation (typically a closure or list of component functions) and returns the curl at a point or over a region. This is a deterministic, device-local computation; results are consistent across runs on the same input."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define F (lambda (x y) (list (- y) x)))\n(define curl-result (calc/curl F))\n(display curl-result)" :note "Compute curl of a simple rotation field F = (-y, x); result should be constant")
    (:dialect "motoi" :tier "intermediate" :code "(define F (lambda (x y z) (list 0 z (- y))))\n(define curl-F (calc/curl F))\n(cond ((eq? (car curl-F) 'error) (display \"Bad field\"))\n      (else (display (list \"Curl at origin:\" curl-F))))" :note "3-D curl; check for shape errors before using result")
    (:dialect "motoi" :tier "expert" :code "(define (field-from-potential phi)\n  (lambda (x y z) (list (phi x y z) (phi x y z) (phi x y z))))\n(define phi (lambda (x y z) (+ (* x x) (* y y) (* z z))))\n(define F (field-from-potential phi))\n(let ((curl-F (calc/curl F)))\n  (if (pair? curl-F)\n    (display (list \"Curl of F from potential:\" curl-F))\n    (escalate 'field-malformed F)))" :note "Construct a field from a potential function; compute its curl (should be near zero)")
  )
  :caveats ("Field must be a callable (lambda) or structure recognized by the curl routine." "Non-2-D and non-3-D fields escalate 'shape-error; dimension must be exact." "Finite-difference approximation is sensitive to field smoothness; noisy or discontinuous fields may give inaccurate results." "Result is deterministic within the device but may differ slightly across platforms due to floating-point precision.")
  :drawbacks ("Finite-difference approximation requires a smoothing/grid step size; too coarse and accuracy suffers, too fine and noise dominates." "No symbolic simplification; composition with other fields can be expensive." "Requires the field to be differentiable; discontinuous fields will produce misleading results.")
  :usecases ("Fluid dynamics: compute vorticity from a velocity field." "Electromagnetism: verify that ∇×E = -∂B/∂t in a discretized field." "Graphics / physics: detect rotational motion in a vector field for visualization or collision response.")
  :related ("calc/divergence" "calc/line-integral" "calc/surface-integral" "num/nintegrate-2d" "num/nintegrate-3d")
  :learn (:concept "Curl is a differential operator on vector fields; it measures local rotation. In 2-D, a scalar field's curl is a scalar; in 3-D, a vector field's curl is a vector." :prerequisites ("calculus / multivariable functions" "lambda (to define fields)") :progression "After calc/curl, explore calc/divergence to measure expansion/contraction, then calc/surface-integral to integrate over surfaces.")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "A 2D-fluid or magnetic-field simulation needs the rotational component of a vector field; the audit wants the scalar curl at a point."
     :program "(calc/curl (lambda (p) (list (- (cadr p)) (car p))) (list 0 0))"
     :explanation "Rotational field F = (-y, x); curl F = 2; operator sees 2 (or close to it)."
     :meta "Divergence measures how much a field spreads out; curl measures how much it rotates. Different physical meaning; different formula.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-nd; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'rotational density of a vector field'"
     :rungs (
       (:domain "calc native" :code "(calc/curl (lambda (p) (list (- (cadr p)) (car p))) (list 0 0))")
       (:domain "vortex-strength in a fluid simulation" :code "(motion/vorticity field)")
       (:domain "∇ × F" :code "(∂F_2/∂x - ∂F_1/∂y)"))
     :explanation "Rung 1 is calc/curl in its native library. Rung 2 shows the same ''rotational density of a vector field'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''rotational density of a vector field'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/curl."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "For a gradient field F = ∇φ, curl F = 0 (curl of gradient is zero)."
     :program "(define phi (lambda (p) (+ (* (car p) (car p)) (* (cadr p) (cadr p)))))\n(define F (lambda (p) (calc/gradient phi p)))\n(< (abs (calc/curl F (list 0.5 0.3))) 0.05)"
     :invariant "∀ φ ∈ C^2. curl(∇φ) = 0"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch15-multivariable-linear-algebra.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-nd category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/curl — see :summary."
     :composition "(define F (lambda (p) (list (- (cadr p)) (car p))))\n(list (calc/curl F (list 0 0)) (calc/divergence F (list 0 0)))"
     :emergent "rotation-detector"
     :meta "The emergent rotation-detector belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Curl + divergence is the vector-calculus split into rotation and expansion. See book-of-ml ch-01.")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-nd operations close into the rotation-detector pattern."
     :cs "The emergent rotation-detector is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/derivative"
  :library "calc"
  :kind "meta"
  :signature "(calc/derivative f x) -> number"
  :summary "Computes the numerical derivative f'(x) using central difference approximation."
  :explanation "The derivative measures how fast a function is changing at a point. Rather than compute symbolically, this verb estimates f'(x) by evaluating f at points very close to x and taking the ratio of change in output to change in input. This central-difference method is stable and accurate for most smooth functions. Use it when you need the slope of a curve at a specific point."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define f (lambda (x) (* x x)))\n(calc/derivative f 3)" :note "Derivative of x² at x=3 is approximately 6 (actual: 2x=6)")
    (:dialect "motoi" :tier "intermediate" :code "(define cubic (lambda (x) (+ (* x x x) (* 2 x))))\n(define slope-at-1 (calc/derivative cubic 1))\n(define slope-at-2 (calc/derivative cubic 2))\n(list slope-at-1 slope-at-2)" :note "Compare slopes at different points: d/dx(x³+2x) = 3x²+2, so at x=1 is 5, at x=2 is 14")
    (:dialect "motoi" :tier "expert" :code "(define f (lambda (x) (/ 1 (+ 1 (* x x)))))\n(let ((critical-x 0))\n  (let ((df (calc/derivative f critical-x)))\n    (if (< (abs df) 0.01)\n      'approximately-flat\n      'has-slope)))" :note "Check if a function is approximately flat near a point by testing if derivative magnitude is small")
  )
  :caveats ("Numeric, not symbolic: answer is approximate, not exact." "Fails near discontinuities or sharp corners (left/right derivatives differ)." "Very small step size can amplify floating-point rounding error; very large step loses accuracy." "Periodic or oscillating functions may give misleading slopes at high frequencies.")
  :drawbacks ("Central difference is O(h²) accurate but requires two function evaluations per call." "For high-precision work, consider calc/taylor or symbolic differentiation." "Does not scale well to many partial derivatives (use calc/gradient instead).")
  :usecases ("Finding slope of experimental data or black-box function at a point." "Optimisation: feeding derivatives to gradient descent or Newton's method." "Verifying whether a function is increasing or decreasing over a region.")
  :related ("calc/second-derivative" "calc/gradient" "calc/newton" "calc/critical-points-1d" "calc/differentiable?")
  :learn (:concept "Numerical derivative as a limit ratio; central-difference stability and error." :prerequisites ("core math (limits, rates of change)") :progression "calc/second-derivative → calc/critical-points-1d → calc/extrema-1d")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "An operator needs the instantaneous rate of change of a smooth function as a callable — analytic derivation is often ugly, numerical differentiation is the honest fallback."
     :program "(define f (lambda (x) (* x x)))\n(define df (calc/derivative f))\n(df 3)"
     :explanation "f' at 3 for f(x) = x^2 is 2·3 = 6; operator sees ≈ 6."
     :meta "partial takes a multivariate function and a variable index; derivative is single-variable. Use partial when there are multiple inputs.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-1d; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'instantaneous rate of change'"
     :rungs (
       (:domain "calc native" :code "(define f (lambda (x) (* x x)))")
       (:domain "velocity from position samples" :code "(motion/velocity samples t)")
       (:domain "limit definition of derivative" :code "lim_{h→0} (f(x+h)-f(x))/h"))
     :explanation "Rung 1 is calc/derivative in its native library. Rung 2 shows the same ''instantaneous rate of change'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''instantaneous rate of change'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/derivative."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
     :cs "Once the shape is named, the same algorithm skeleton (traverse, close, compare) applies at each rung."))
  :row-4-proof (
    :runs "spec-only"
   
    (:claim "Linearity: (af + bg)' = a f' + b g'."
     :program "(define f (lambda (x) (* x x)))\n(define g (lambda (x) x))\n(define df (calc/derivative f))\n(define dg (calc/derivative g))\n(define combined (calc/derivative (lambda (x) (+ (* 3 (f x)) (* 2 (g x))))))\n(< (abs (- (combined 1.0) (+ (* 3 (df 1.0)) (* 2 (dg 1.0))))) 0.01)"
     :invariant "∀ f g diff. (af + bg)\\' = a f\\' + b g\\'"
     :meta "The invariant is the algebraic essence of the verb; a single counter-example would falsify it and prove the implementation broken. See book-of-math ch13-calculus-1 and ch14-calculus-2. Also book-of-ml ch-06 (gradient descent) for autodiff and gradient descent.")
    (:eng "The runnable claim doubles as a CI smoke test — if the invariant ever prints #f, the verb has drifted."
     :math "The invariant is the defining property in the calc-1d category."
     :cs "Property-based test: the program above is a runnable falsifier candidate for a QuickCheck-style fuzzer."))
  :row-5-emergence (
    :runs "spec-only"
   
    (:base "calc/derivative — see :summary."
     :composition "(define f (lambda (x) (sin x)))\n(define df (calc/derivative f))\n(define ddf (calc/derivative df))\n(list (df 0) (ddf 0))"
     :emergent "higher-derivatives"
     :meta "The emergent higher-derivatives belongs to the family of composed behaviours where one verb's output feeds the next verb's input, and the pair carries meaning neither verb has alone. Repeated derivative = Taylor coefficients / higher-order rate. See book-of-ml ch-09 (backpropagation).")
    (:eng "The composition is short enough to inline in a callsite yet meaningful enough to name and reuse."
     :math "Under composition, the calc-1d operations close into the higher-derivatives pattern."
     :cs "The emergent higher-derivatives is a first-class named pattern; recognize it once and it reappears everywhere."))
)

(verb
  :name "calc/differentiable?"
  :library "calc"
  :kind "meta"
  :signature "(calc/differentiable? f x) -> boolean"
  :summary "Tests whether a function is differentiable at a point by checking if left and right derivatives agree."
  :explanation "A function is differentiable at x if its derivative exists—that is, if approaching from the left and right give the same slope. This verb computes the left derivative (approaching from x−h) and right derivative (approaching from x+h), then checks if they match within floating-point tolerance. If they do, the function is differentiable there; if not, there is a corner, cusp, or discontinuity."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define smooth (lambda (x) (* x x)))\n(calc/differentiable? smooth 1)" :note "Parabola is smooth everywhere; returns true")
    (:dialect "motoi" :tier "intermediate" :code "(define piecewise (lambda (x)\n  (if (< x 0) (- x) x)))\n(and (calc/differentiable? piecewise -0.1)\n     (calc/differentiable? piecewise 0)\n     (calc/differentiable? piecewise 0.1))" :note "Absolute value |x| is smooth everywhere except at x=0, where the corner breaks differentiability")
    (:dialect "motoi" :tier "expert" :code "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define f (lambda (x) (+ (sin x) (* 0.1 x))))\n(let ((test-points (list -1 0 0.5 1)))\n  (filter (lambda (pt) (not (calc/differentiable? f pt)))\n          test-points))" :note "Check a list of candidate points and collect only those where differentiability fails (should be empty for sin+linear)")
  )
  :caveats ("Numeric tolerance means borderline cases (cusps at tiny angles) may be marked differentiable." "Does not check continuity first; a function can be discontinuous and still pass this test at that point (nonsensical result)." "h is fixed; very sharp corners may slip through if angle is extreme.")
  :drawbacks ("False positives on near-corners that are actually differentiable but numerically tight." "For high-precision classification, prefer calc/continuous? first, then this test." "Much slower than checking the expression form symbolically.")
  :usecases ("Validating that an empirical signal is smooth enough for derivatives." "Screening a function before applying Newton's method (which requires smooth f)." "Locating singularities or kinks in piecewise-defined functions.")
  :related ("calc/derivative" "calc/continuous?" "calc/critical-points-1d" "calc/newton")
  :learn (:concept "Differentiability as agreement of left/right derivative limits; numeric vs. analytic checking." :prerequisites ("calc/derivative" "core concept of one-sided limits") :progression "calc/continuous? → calc/extrema-1d → calc/newton")
  :row-2-audit (
    :runs "spec-only"
   
    (:problem "Before applying gradient descent or Newton's method, the operator must certify differentiability of the objective on the search domain."
     :program "(list (calc/differentiable? (lambda (x) x) 0 1)\n      (calc/differentiable? (lambda (x) (abs x)) -1 1))"
     :explanation "Linear is differentiable; |x| is not at 0; operator sees (#t #f)."
     :meta "Continuity is weaker; differentiability is stronger. Newton needs differentiability; only integration needs continuity.")
    (:eng "The operator gets one line per call; failure surfaces the exact input that broke the expectation."
     :math "Category: calc-1d; the verb operates within its declared algebraic type."
     :cs "Complexity as declared in the signature; deterministic and testable."))
  :row-3-dimension (
    (:setup "'smooth-enough-to-linearize'"
     :rungs (
       (:domain "calc native" :code "(list (calc/differentiable? (lambda (x) x) 0 1)")
       (:domain "audio can be locally interpolated" :code "(audio/smooth-window? win)")
       (:domain "existence of f\\' on an interval" :code "∀ x ∈ [a, b]. lim_{h→0} (f(x+h)-f(x))/h exists"))
     :explanation "Rung 1 is calc/differentiable? in its native library. Rung 2 shows the same ''smooth-enough-to-linearize'' shape in a metaphor domain. Rung 3 lifts the shape into a math/logical setting where the transfer is formal. Recognizing the same shape in all three lets the reader carry the verb's intuition into problems Motoi does not directly cover."
     :meta "The shape transfers because ''smooth-enough-to-linearize'' is substrate-independent — the same relationship holds whenever the underlying category admits the required structure.")
    (:eng "Engineers who have met the shape elsewhere already know when to reach for calc/differentiable?."
     :math "The shape is captured by a small equation set; each rung is a model of that equation set."
