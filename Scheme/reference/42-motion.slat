;;; 42-motion.slat — Motoi Scheme Reference · Chapter 42 · library motion
;;;
;;; 14 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library motion — 14 verbs.")

(chapter :number "42" :library "motion" :verb-count 14 :training-eligible #t)

;; ═══ 14 verbs in library motion ═══

(verb
  :name "motion/anchor-to-input"
  :library "motion"
  :kind "null"
  :signature "(motion/anchor-to-input target sensor param transform) -> null"
  :summary "Drive a target parameter via sensor input through a transform function. Open-loop or closed-loop."
  :explanation "Motion/anchor-to-input binds a single numeric parameter of a target entity to a live sensor field. The sensor's value is passed through a transform function, and the result is written to the parameter each frame. This is the foundation for input-responsive motion: a joystick axis can drive position, a button can drive rotation, etc. The verb is non-deterministic because sensor input is unpredictable."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((player (world/spawn 'hero 100 100)))\n  (motion/anchor-to-input player 'joystick-x 'x (lambda (v) (+ 100 (* v 200)))))" :note "Anchor the player's x-position to the joystick's x-axis, scaled and offset; moving the stick moves the player.")
    (:dialect "motoi" :tier "intermediate" :code "(define camera-follow! (lambda args (list \"camera-follow!\" args)))\n(let ((camera-target (world/spawn 'dummy 0 0)))\n  (motion/anchor-to-input camera-target 'mouse-x 'x (lambda (mx) mx))\n  (motion/anchor-to-input camera-target 'mouse-y 'y (lambda (my) my))\n  (camera-follow! (world/camera) camera-target))" :note "Anchor a dummy entity to mouse position, then have the camera follow it; dual anchors for 2D tracking.")
    (:dialect "motoi" :tier "expert" :code "(define sentry-turret 'sentry-turret)\n(define (make-input-responsive-turret turret)\n  (define (angle-from-axis val) (* val 3.14159))\n  (define (clamp-speed val) (min 1.0 (max -1.0 val)))\n  (motion/anchor-to-input turret 'button-right 'rotation angle-from-axis)\n  (motion/anchor-to-input turret 'joystick-magnitude 'fire-rate (lambda (mag) (* (clamp-speed mag) 10))))\n(make-input-responsive-turret sentry-turret)" :note "Bind rotation to a button and fire-rate to joystick magnitude; multiple anchors on different params allow parallel control.")
  )
  :caveats ("The target must support the parameter being anchored; anchoring to a non-existent parameter silently does nothing." "The transform function receives a raw sensor value (typically 0–1 or -1 to 1) and must return a number." "Anchoring the same parameter twice overwrites the previous anchor." "Non-deterministic: sensor input varies; recordings of motion/anchor-to-input code will not replay identically.")
  :drawbacks ("No dead-zone or smoothing built-in; the transform must handle those if needed." "Cannot query the current anchor mapping; you must track it yourself if you need to inspect or remove it." "Slow sensors (e.g., noisy mouse movement) may cause jittery motion; use a filter or damper in the transform.")
  :usecases ("Map joystick input to character movement in real-time games." "Bind keyboard modifier keys to entity properties (e.g., sprint speed)." "Drive camera or viewport parameters from mouse or sensor input." "Create interactive installations where motion follows a live data stream.")
  :related ("motion/follow-input" "motion/with-pace" "motion/with-feel" "motion-anchor-to-input" "input/buttons" "input/down?")
  :learn (:concept "Sensor-to-parameter binding; open-loop control and transform pipelines." :prerequisites ("world/spawn" "entity/set!" "lambda") :progression "Learn motion/anchor-to-input, then motion/follow-input for target-tracking, then motion/with-pace for timing-aware motion.")
  :row-2-audit ((:problem "The operator has a hero sprite and wants its horizontal position driven directly by the joystick x-axis, with a scale factor and a dead-zone to reject small jitter."
                 :program "(define player (world/spawn 'hero 100 100))\n(define (jitter-guard v) (if (< (abs v) 0.05) 0 (* v 200)))\n(motion/anchor-to-input player 'joystick-x 'x jitter-guard)"
                 :explanation "Line 1 spawns a hero entity. Line 2 defines a transform that returns 0 for small joystick values (dead-zone) and scales larger values by 200. Line 3 wires the joystick x-axis to the player's x parameter through that transform. The player moves only when the operator meaningfully deflects the stick; noise is discarded. The audit trail is a single verb call plus a named transform."
                 :meta "Reaching for motion/follow-input would give straight tracking with no dead-zone; motion/anchor-to-input is the honest answer because it exposes the transform slot for exactly this kind of shaping.")
                (:eng "Sensor noise handled at the binding point, not downstream; the log line records only the transformed value." :math "Continuous composition sensor → transform → parameter; dead-zone is a piecewise-linear filter." :cs "Effect kind: mutable side-effect on the entity; the transform is a pure procedure."))
  :row-3-dimension ((:setup "Live-input binding through a shaping function."
                     :rungs ((:domain "motion" :code "(motion/anchor-to-input 'hero 'joystick-x 'x (lambda (v) (* v 200)))")
                             (:domain "signal chain in a modular synth (metaphor)" :code "(define (patch-cable source-cv scale offset target-param)\n  (lambda () (target-param (+ offset (* scale (source-cv))))))\n((patch-cable (lambda () 0.5) 200 0 (lambda (x) x)))")
                             (:domain "continuous function composition R → R → R" :code "(define (compose-io read transform write)\n  (lambda () (write (transform (read)))))\n((compose-io (lambda () 0.5) (lambda (v) (* v 200)) display))"))
                     :explanation "In motion, a sensor drives an entity parameter through a transform. In the modular-synth metaphor, a patch cable routes a control voltage through a shaper into a target parameter — exactly the same three-piece pipeline. In the math rung, function composition read ∘ transform ∘ write formalizes it. All three are the same signal-chain shape."
                     :meta "The shape transfers because it is the paradigmatic source → shaper → sink pattern; whether the substrate is joystick + sprite, CV + oscillator, or read + write, the composition is identical.")
                    (:eng "The same shape covers game input, analog synthesis, and functional pipelines." :math "Composition R → R → R; the transform mediates two probability spaces (sensor and effector)." :cs "Composition of a mutation with two pure functions; O(1) per frame."))
  :row-4-proof ((:claim "For any transform t that satisfies t(0) = c (a constant), the parameter equals c whenever the sensor returns exactly 0. This is the zero-fidelity invariant that guarantees rest-state predictability."
                 :program "(define (mock-anchor sensor-value transform)\n  (transform sensor-value))\n(define (approx a b) (< (abs (- a b)) 0.0001))\n(define t1 (lambda (v) (* v 200)))\n(define t2 (lambda (v) (+ 100 (* v 200))))\n(and (approx (mock-anchor 0 t1) 0)\n     (approx (mock-anchor 0 t2) 100))"
                 :invariant "∀ sensor s, transform t . if s(x)=0 then param(x) = t(0)"
                 :meta "A binding that drifted when the sensor was neutral would cause the player to slowly wander even when the stick was centered. Falsification is any t and s where a zero sensor produces a non-t(0) parameter. CS pattern: 'pure-function invariance at zero-input'. Book-of-code ch 6 covers pure functions.")
                (:eng "The zero-fidelity property means players can leave their thumb off the stick and expect stillness." :math "The transform is a total function; its value at 0 is uniquely determined." :cs "The binding does not maintain hidden state; the parameter is a pure function of the sensor snapshot."))
  :row-5-emergence ((:base "motion/anchor-to-input binds an entity parameter to a sensor through a transform."
                     :composition "(define (twin-stick-shooter player)\n  (motion/anchor-to-input player 'left-x 'x (lambda (v) (+ (entity/x player) (* v 5))))\n  (motion/anchor-to-input player 'right-x 'aim (lambda (v) (* v 6.28))))\n(twin-stick-shooter 'hero)"
                     :emergent "A twin-stick control scheme — chaining two motion/anchor-to-input calls on different parameters produces classic twin-stick shooter movement (left stick = walk, right stick = aim), which no single call has."
                     :meta "This is the same family as classic twin-stick shooters (Robotron, Geometry Wars) or a musical MIDI-modmatrix routing. Cross-reference book-of-composition ch 8 (parallel bindings). Familiar analog: Ableton's MIDI mapping to multiple parameters at once.")
                    (:eng "Two calls = a whole control scheme; adding a third stick is one more line." :math "Parallel composition of two independent signal chains; no coupling." :cs "Two mutable bindings on the same entity; each independent.")))

(verb
  :name "motion/arc"
  :library "motion"
  :kind "null"
  :signature "(motion/arc tensor-id) -> {kind: 'arc', ok: bool, phrase-arc: list, duration-ms: num, ...}"
  :summary "Extract phrase-arc timing (intensity peaks) from a timing tensor. Used to apply learned motion curves."
  :explanation "Motion/arc takes a timing tensor ID (a reference to a previously computed or loaded motion-timing analysis) and returns a structure containing phrase-arc: a list of intensity values (0–1) sampled across the motion phrase, and duration-ms. The phrase-arc is typically applied to modulate animation intensity frame-by-frame. This verb bridges motion planning and music-aligned choreography."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define arc-curve (motion/arc 'learned-walk-22))\n(if (hash-ref arc-curve 'ok)\n  (display (hash-ref arc-curve 'phrase-arc))\n  (display 'tensor-not-ready))" :note "Load a motion arc by tensor ID; check ok status and retrieve the curve if ready.")
    (:dialect "motoi" :tier "intermediate" :code "(define dancer 'dancer)\n(define (apply-arc-to-motion entity arc-tensor)\n  (let ((arc (motion/arc arc-tensor)))\n    (if (hash-ref arc 'ok)\n      (let ((curve (hash-ref arc 'phrase-arc))\n            (dur (hash-ref arc 'duration-ms)))\n        (motion/with-pace entity 100 100 dur (lambda (t) (* 1.0 (list-ref curve (quotient (* t (length curve)) dur))))))\n      (display 'arc-not-ready))))\n(apply-arc-to-motion dancer 'recorded-bounce-arc)" :note "Unpack the arc curve and duration, then apply it as a pacing function over the motion duration.")
    (:dialect "motoi" :tier "expert" :code "(define dancers 'dancers)\n(define (iota n)\n  (let loop ((i 0) (acc '()))\n    (if (= i n) (reverse acc) (loop (+ i 1) (cons i acc)))))\n(define (choreograph-group entities arc-id offset-ms)\n  (define arc (motion/arc arc-id))\n  (if (hash-ref arc 'ok)\n    (let ((curve (hash-ref arc 'phrase-arc))\n          (base-dur (hash-ref arc 'duration-ms)))\n      (for-each (lambda (e idx)\n        (let ((staggered-start (+ offset-ms (* idx 100))))\n          (time/when staggered-start (lambda ()\n            (motion/with-pace e 50 50 base-dur (lambda (t)\n              (let ((phase (/ t base-dur)))\n                (* (list-ref curve (min (- (length curve) 1) (quotient (* phase (length curve)) 1.0))) 1.0))))))))\n        entities (iota (length entities))))\n    (escalate 'arc-not-ready '())))\n(choreograph-group dancers 'group-bounce-arc 0)" :note "Distribute a group across an arc curve with staggered timing offsets; each dancer phases through the same motion curve at different times.")
  )
  :caveats ("The tensor ID must refer to a valid, previously loaded or computed tensor; invalid IDs return {ok: false}." "If the timing tensor is still being computed, motion/arc returns {ok: false, reason: 'pending-timing-tensor'}; you must retry or poll." "The phrase-arc list is indexed 0–length; bounds checking is your responsibility if sampling at arbitrary positions." "Motion/arc does not perform the motion itself; it returns data for you to apply via motion/with-pace or similar.")
  :drawbacks ("Requires a pre-computed or learned timing tensor; there is no direct arc generation from parameters." "If the tensor is garbage-collected before you call motion/arc, the result is undefined." "Large tensors may have long lists; iterating or indexing them many times per frame is expensive.")
  :usecases ("Extract learned motion curves from a recorded dance or choreography." "Apply music-beat-aligned intensity modulation to dance moves." "Generate staggered group choreography from a single master arc.")
  :related ("motion/cadence" "motion/drop" "motion/with-pace" "motion/with-feel" "tick/pattern")
  :learn (:concept "Phrase-arc intensity curves; motion timing as data and as application." :prerequisites ("motion/with-pace" "lambda" "list-ref") :progression "Learn motion/cadence and motion/drop for rhythm-based timing, then motion/arc to extract learned curves, then motion/with-pace to apply them.")
  :row-2-audit ((:problem "The operator has a learned tensor 'walk-arc-42 with a recorded phrase-arc curve. They need to apply that curve to a dancer's motion, but only after confirming the tensor is ready."
                 :program "(define arc (motion/arc 'walk-arc-42))\n(if (hash-ref arc 'ok)\n    (list 'ready (hash-ref arc 'duration-ms))\n    'tensor-not-ready)"
                 :explanation "Line 1 fetches the arc structure. Line 2 checks the ok flag. If the tensor is ready, returns duration; otherwise reports the pending state. The audit trail includes both the tensor id and the ok status, so an SRE can trace whether the arc was ready at any given tick."
                 :meta "Reaching directly for motion/with-pace would skip the readiness check and could apply a stale or missing arc; motion/arc gates access with the ok flag. That is the honest checkpoint.")
                (:eng "The ok flag is the operational contract: never apply an arc that isn't ready." :math "A partial function on tensor-id → arc; the ok flag encodes 'defined here.'" :cs "Lookup + boolean guard; O(1)."))
  :row-3-dimension ((:setup "Read-from-tensor with a readiness gate."
                     :rungs ((:domain "motion" :code "(motion/arc 'walk-arc-42)")
                             (:domain "DNS lookup with cache-miss handling (metaphor)" :code "(define (lookup-with-guard cache key)\n  (let ((v (assq key cache)))\n    (if v (list 'ok (cdr v)) 'not-cached)))\n(lookup-with-guard '((a . 1) (b . 2)) 'a)")
                             (:domain "partial function on a keyed store" :code "(define (partial store k)\n  (let ((v (assq k store)))\n    (if v (list 'defined (cdr v)) 'undefined)))\n(partial '((k1 . v1)) 'k1)"))
                     :explanation "In motion, tensor-id → arc with an ok flag. In the DNS metaphor, a lookup returns either a resolved address or a cache-miss signal — same shape. In the math rung, a partial function returns either a value or 'undefined.' All three are the same lookup-with-defined-gate pattern."
                     :meta "The shape transfers because 'lookup a key in a store, return value or a signal that the key is not present' is universal: DNS, caches, databases, and partial functions all wear the same signature.")
                    (:eng "One shape covers tensor fetch, DNS, cache reads, and partial function evaluation." :math "Partial function on a keyed set." :cs "O(1) with hash, O(n) with list; either way, the guard pattern is the same."))
  :row-4-proof ((:claim "For any tensor-id that is registered and ready, calling motion/arc twice returns arcs with identical phrase-arc lists (referential stability). This is the tensor-immutability invariant."
                 :program "(define (check-stability id)\n  (let ((a (motion/arc id))\n        (b (motion/arc id)))\n    (and (hash-ref a 'ok)\n         (equal? (hash-ref a 'phrase-arc)\n                 (hash-ref b 'phrase-arc)))))\n(check-stability 'walk-arc-42)"
                 :invariant "∀ id : registered ∧ ready . motion/arc(id).phrase-arc = motion/arc(id).phrase-arc"
                 :meta "A tensor that mutated between reads would make choreography non-reproducible. Falsification is one id where the two reads disagree. CS pattern: 'immutable cached read'. Book-of-composition ch 10 covers immutable data.")
                (:eng "Reproducibility of choreography depends on this; replays must be identical." :math "The tensor is a fixed point in the arc-store; the read function is a pure lookup." :cs "Cached data returned by reference; consumers should not mutate."))
  :row-5-emergence ((:base "motion/arc extracts a phrase-arc curve from a tensor id."
                     :composition "(define (apply-arc-with-pace entity tensor-id duration)\n  (let ((arc (motion/arc tensor-id)))\n    (if (hash-ref arc 'ok)\n        (motion/with-pace entity 100 100 duration\n          (lambda (t)\n            (let ((curve (hash-ref arc 'phrase-arc)))\n              (list-ref curve (min (- (length curve) 1)\n                                   (quotient (* t (length curve)) duration))))))\n        'skip)))\n(apply-arc-with-pace 'dancer 'walk-arc-42 2000)"
                     :emergent "A learned-choreography player — chaining motion/arc with motion/with-pace produces a pipeline that consumes a recorded arc and applies it to a live entity, which neither verb has alone."
                     :meta "This is the same family as an audio-plugin loading a recorded envelope and playing it against a new signal. Cross-reference book-of-composition ch 14 (data-driven playback). Familiar analog: Ableton clip-envelopes applied to instrument parameters.")
                    (:eng "Two verbs = a learned-choreography playback; adding a second dancer is one more call." :math "Composition of arc-lookup and pace-application." :cs "O(N) in curve length per frame for list-ref; convert to vector for O(1).")))

(verb
  :name "motion/cadence"
  :library "motion"
  :kind "null"
  :signature "(motion/cadence bpm [division]) -> {kind: 'cadence', ok: bool, bpm: num, division: str, periodMs: num, beatPeriodMs: num}"
  :summary "Compute period (in ms) for a beat or subdivision at a given BPM. Returns cadence metadata."
  :explanation "Motion/cadence converts a tempo (beats-per-minute) and a beat subdivision (e.g., 'q' for quarter note, '8' for eighth) into a period in milliseconds. It returns a structure holding the BPM, division string, the computed periodMs for that subdivision, and beatPeriodMs (the period of a single beat). Use this to synchronize motion timing with audio or to generate rhythm-aware choreography timing."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define cad (motion/cadence 120 'q))\n(if (hash-ref cad 'ok)\n  (display (hash-ref cad 'periodMs))\n  (display 'bad-cadence))" :note "Compute the period of a quarter note at 120 BPM (~500 ms); check ok before using.")
    (:dialect "motoi" :tier "intermediate" :code "(define dancer 'dancer-1)\n(define (tempo-aware-step entity bpm)\n  (let ((cad (motion/cadence bpm '8)))\n    (if (hash-ref cad 'ok)\n        (let ((step-time (hash-ref cad 'periodMs)))\n          (define (walk steps)\n            (if (> steps 0)\n                (begin (motion-move-to entity (+ (entity/x entity) 50) (entity/y entity))\n                       (time/when step-time (lambda () (walk (- steps 1)))))))\n          (walk 8))\n        (display 'tempo-error))))\n(tempo-aware-step dancer 130)" :note "Generate an 8-step walk synchronized to the beat subdivision; each step takes one 8th-note period.")
    (:dialect "motoi" :tier "expert" :code "(define dancers-a '())\n(define dancers-b '())\n(define (polyrhythmic-group-dance group-a group-b bpm)\n  (let ((cad-a (motion/cadence bpm 'q))\n        (cad-b (motion/cadence bpm '8)))\n    (if (and (hash-ref cad-a 'ok) (hash-ref cad-b 'ok))\n        (begin\n          (define (repeat-group entities period count)\n            (define (one-cycle idx)\n              (if (< idx count)\n                  (begin (for-each (lambda (e) (motion/drop e 3 4)) entities)\n                         (time/when period (lambda () (one-cycle (+ idx 1)))))))\n            (one-cycle 0))\n          (repeat-group group-a (hash-ref cad-a 'periodMs) 8)\n          (repeat-group group-b (hash-ref cad-b 'periodMs) 16))\n        (escalate 'cadence-error '()))))\n(polyrhythmic-group-dance dancers-a dancers-b 120)" :note "Choreograph two groups at different beat subdivisions; group-a moves on quarter notes, group-b on 8th-notes.")
  )
  :caveats ("The division string must be a valid Motoi beat subdivision ('w', 'h', 'q', '8', '16', etc.); invalid strings return ok: false." "BPM must be a positive number; zero or negative values return ok: false." "The returned periodMs is in floating-point milliseconds; rounding may be needed for timer precision." "Motion/cadence does not start any timer or motion; it returns data for you to use with time/when or motion/with-pace.")
  :drawbacks ("No default division; you must always specify one or it may error." "Does not handle tempo changes or accelerandos; it assumes a constant BPM." "Rounding drift can accumulate if you chain many cadence-driven timers back-to-back.")
  :usecases ("Synchronize dance steps to an audio track's BPM." "Generate polyrhythmic choreography (group A on quarter notes, group B on 8ths)." "Compute timing for beat-aligned visual effects.")
  :related ("motion/drop" "motion/arc" "motion/with-pace" "time/when" "time/every-ms" "audio-bpm")
  :learn (:concept "Tempo-to-period conversion; beat subdivisions and rhythm as data." :prerequisites ("audio-bpm" "time/when" "lambda") :progression "Learn motion/cadence to convert tempo to timing, then motion/drop for beat-aligned articulation, then motion/arc for learned curves.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "The operator has a song at 130 BPM and wants to time dance steps to 8th notes. They need the millisecond period for each step, computed from BPM and subdivision — not hardcoded."
                 :program "(define cad (motion/cadence 130 '8))\n(if (hash-ref cad 'ok)\n    (hash-ref cad 'periodMs)\n    'invalid-cadence)"
                 :explanation "Line 1 asks for cadence at 130 BPM, 8th-note subdivision. Line 2 guards ok, then extracts periodMs. At 130 BPM, a quarter note is 461.5 ms; an 8th note is half that, ~230.8 ms. The operator gets a precise number without doing the arithmetic. If BPM changes, one edit updates every step timing."
                 :meta "Reaching for (/ 60000 130 2) works but hardcodes the subdivision math; motion/cadence names the subdivision symbolically ('8, 'q, '16), which is the vocabulary a musician actually uses.")
                (:eng "One call from BPM to ms; audit trail is BPM and subdivision symbol." :math "period = 60000 / (BPM · subdivision-factor); subdivision-factor is 2 for '8, 1 for 'q." :cs "Symbol dispatch + arithmetic; O(1)."))
  :row-3-dimension ((:setup "Converting a tempo + subdivision into a concrete period."
                     :rungs ((:domain "motion" :code "(motion/cadence 130 '8)")
                             (:domain "gear ratio (metaphor)" :code "(define (gear-period engine-rpm gear-ratio)\n  (/ 60000.0 (* engine-rpm gear-ratio)))\n(gear-period 3000 4)")
                             (:domain "reciprocal frequency" :code "(define (period freq) (/ 1.0 freq))\n(period 4.33)"))
                     :explanation "In motion, BPM + subdivision → ms/step. In the gear-ratio metaphor, engine RPM + gear ratio → wheel rotation period — same shape. In the math rung, period is the reciprocal of frequency. All three share the reciprocal structure."
                     :meta "The shape transfers because all three are the same computation: frequency times a multiplier gives an event rate, and the reciprocal gives the interval between events.")
                    (:eng "One primitive covers music timing, mechanical engineering, and signal processing." :math "T = 1/f; multiplicative structure preserved by reciprocation." :cs "O(1) arithmetic."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "For any BPM > 0 and any valid subdivision, motion/cadence produces a periodMs that satisfies periodMs · beats-per-ms = 1/subdivision-factor. This is the frequency-period reciprocity invariant."
                 :program "(define (approx a b) (< (abs (- a b)) 0.5))\n(define (check-reciprocity bpm sub factor)\n  (let* ((cad (motion/cadence bpm sub))\n         (p (hash-ref cad 'periodMs))\n         (expected (/ 60000.0 (* bpm factor))))\n    (approx p expected)))\n(and (check-reciprocity 120 'q 1)\n     (check-reciprocity 120 '8 2)\n     (check-reciprocity 130 '16 4))"
                 :invariant "periodMs(BPM, sub) = 60000 / (BPM · factor(sub))"
                 :meta "A cadence that returned inconsistent periods would drift synced motion out of tempo. Falsification is one BPM/sub pair with the wrong period. CS pattern: 'frequency-period reciprocity'. Book-of-sound ch 4 covers BPM math.")
                (:eng "This invariant is why synced-to-audio motion stays synced." :math "T = 60000 / (BPM · f); f encodes the subdivision." :cs "Property test with various BPM/sub pairs."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "motion/cadence maps BPM + subdivision to a millisecond period."
                     :composition "(define (metronome-tick handler bpm sub)\n  (let ((cad (motion/cadence bpm sub)))\n    (if (hash-ref cad 'ok)\n        (time/every-ms (hash-ref cad 'periodMs) handler)\n        'invalid)))\n(metronome-tick (lambda () (display 'tick)) 120 'q)"
                     :emergent "A metronome — chaining motion/cadence with time/every-ms produces a beat clock that fires a handler at exactly the requested subdivision, which no single verb has."
                     :meta "This is the same family as a hardware clock in a modular synth, or a MIDI-clock generator. Cross-reference book-of-sound ch 4 (BPM clocks). Familiar analog: Ableton's global tempo emitting MIDI clock.")
                    (:eng "Two verbs = a metronome; the tempo is one variable." :math "Composition of period-computation and periodic-timer." :cs "One timer per metronome; O(1) per tick.")))

(verb
  :name "motion/drop"
  :library "motion"
  :kind "null"
  :example-drift #t
  :signature "(motion/drop [targetBeat] [totalBeats]) -> {kind: 'drop', ok: #t, targetBeat: num, totalBeats: num, articulation: list}"
  :summary "Generate a beat-aligned articulation curve: high intensity on a target beat, lower elsewhere."
  :explanation "Motion/drop creates an articulation pattern (a list of intensity values, typically 0–1) over a given number of beats, with emphasis (intensity ~0.95) on a target beat and lower intensity (~0.35) on others. The pattern repeats every 4 beats by default. Use this to generate rhythm-aware emphasis in motion: a dancer hits hard on beat 3, moves softly on the others."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define drop-pattern (motion/drop 2 8))\n(display (hash-ref drop-pattern 'articulation))" :note "Generate an 8-beat pattern with emphasis on beat 2; outputs something like (0.35 0.95 0.35 0.35 0.35 0.95 0.35 0.35).")
    (:dialect "motoi" :tier "intermediate" :code "(define hero 'hero)\n(define (dance-with-drop dancer target-beat)\n  (let ((drop (motion/drop target-beat 16)))\n    (if (hash-ref drop 'ok)\n      (let ((curve (hash-ref drop 'articulation)))\n        (motion/with-pace dancer 0 0 4000 (lambda (t)\n          (let ((beat-idx (quotient (* t (length curve)) 4000)))\n            (* 100 (list-ref curve (min (- (length curve) 1) beat-idx)))))))\n      (display 'drop-error))))\n(dance-with-drop hero 3)" :note "Generate a drop pattern, then apply it as a position/scale amplitude over 4 seconds; beat 3 gets maximum movement.")
    (:dialect "motoi" :tier "expert" :code "(define dancers '())\n(define (iota n)\n  (let loop ((i 0) (acc '()))\n    (if (= i n) (reverse acc) (loop (+ i 1) (cons i acc)))))\n(define (group-drop-dance group bpm target-beat total-beats)\n  (let ((drop (motion/drop target-beat total-beats))\n        (cad (motion/cadence bpm 'q)))\n    (if (and (hash-ref drop 'ok) (hash-ref cad 'ok))\n        (let ((curve (hash-ref drop 'articulation))\n              (beat-period (hash-ref cad 'periodMs)))\n          (define (apply-to-group)\n            (for-each (lambda (member idx)\n                        (let ((intensity (list-ref curve idx)))\n                          (time/when (* beat-period idx) (lambda ()\n                                                          (motion/with-pace member 0 0 beat-period (lambda (t) (* 200 intensity)))))))\n                      group (iota (min (length group) (length curve)))))\n          (apply-to-group))\n        (escalate 'drop-error '()))))\n(group-drop-dance dancers 120 1 8)" :note "Assign each group member a beat from the drop pattern, staggered in time at the BPM; each dancer hits on their assigned beat.")
  )
  :caveats ("targetBeat is 1-indexed (beat 1 is the first beat); internally it wraps modulo 4." "The articulation list length equals totalBeats; accessing beyond that requires bounds checking." "The values (0.95 and 0.35) are hardcoded; there is no way to customize the emphasis/low intensity levels." "Motion/drop does not perform motion; it returns an articulation curve for you to apply.")
  :drawbacks ("No way to specify custom intensity levels or multiple emphasis beats." "The pattern repeats every 4 beats regardless of totalBeats; patterns that are not multiples of 4 may feel irregular." "Does not handle polyrhythmic patterns (e.g., emphasizing every 3rd beat in a 16-beat measure).")
  :usecases ("Animate dance moves with beat emphasis." "Create stepping patterns where certain beats are stronger than others." "Drive visual feedback (scale, glow, bounce) synchronized to musical rhythm.")
  :related ("motion/cadence" "motion/arc" "motion/with-pace" "tick/pattern" "pattern/clave")
  :learn (:concept "Beat-aligned articulation curves; rhythm patterns as intensity data." :prerequisites ("motion/cadence" "motion/with-pace" "list-ref") :progression "Learn motion/drop for basic beat patterns, then motion/cadence for tempo-aware timing, then combine them for synchronized group choreography.")
  :row-2-audit ((:problem "The operator wants a dancer to accent beat 3 of every 8-beat measure — big move on beat 3, small moves elsewhere. They need an articulation curve to feed into with-pace."
                 :program "(define drop (motion/drop 3 8))\n(if (hash-ref drop 'ok)\n    (hash-ref drop 'articulation)\n    '())"
                 :explanation "Line 1 generates a drop pattern with target beat 3 over 8 total beats. Line 2 extracts the articulation list — a sequence of intensity values with ~0.95 at position 2 (0-indexed beat 3) and ~0.35 elsewhere. That list feeds directly into a motion/with-pace intensity function. The operator's audit is one call and a symbol; the beat-3 emphasis is expressed as data, not as scattered conditionals."
                 :meta "Rolling your own list of 0.95/0.35 values by hand is error-prone (miscounting a position ruins the emphasis). motion/drop is the honest answer because it puts the emphasis in exactly one place, at exactly the specified beat, every time.")
                (:eng "One symbol names the emphasis; changing beat 3 to beat 4 is one number." :math "Discrete indicator function on Z/n with a single peak; convolvable with intensity kernels." :cs "Data-driven; the list is the machine."))
  :row-3-dimension ((:setup "A per-beat articulation curve with emphasis on a chosen beat."
                     :rungs ((:domain "motion" :code "(motion/drop 3 8)")
                             (:domain "drummer's accent pattern (metaphor)" :code "(define (accent-pattern target n)\n  (let loop ((i 1) (acc '()))\n    (if (> i n) (reverse acc)\n        (loop (+ i 1) (cons (if (= i target) 'accent 'ghost) acc)))))\n(accent-pattern 3 8)")
                             (:domain "delta function on Z/n" :code "(define (delta n at)\n  (let loop ((i 0) (acc '()))\n    (if (>= i n) (reverse acc)\n        (loop (+ i 1) (cons (if (= i at) 1 0) acc)))))\n(delta 8 2)"))
                     :explanation "In motion, drop produces an accented pattern. In the drummer metaphor, an accent pattern names one beat and marks it as loud; the others are ghost notes — same shape. In the math rung, a delta function on Z/n has a spike at one position and zero elsewhere. All three are a peaked-pattern shape."
                     :meta "The shape transfers because it is the discrete delta pattern; wherever emphasis-on-one-instant is needed, this shape appears.")
                    (:eng "One shape covers motion, percussion, and discrete signal processing." :math "Discrete delta at target beat; convolvable with intensity kernel." :cs "O(n) list construction; the list is the emit."))
  :row-4-proof ((:claim "The articulation list produced by motion/drop has exactly one peak (the target beat's value strictly exceeds all others). This is the single-peak invariant."
                 :program "(define (find-max-index xs)\n  (let loop ((i 0) (xs xs) (best-i 0) (best-v (car xs)))\n    (if (null? xs) best-i\n        (if (> (car xs) best-v)\n            (loop (+ i 1) (cdr xs) i (car xs))\n            (loop (+ i 1) (cdr xs) best-i best-v)))))\n(define drop (motion/drop 3 8))\n(if (hash-ref drop 'ok)\n    (list 'peak-at (find-max-index (hash-ref drop 'articulation)))\n    'error)"
                 :invariant "articulation[target - 1] > articulation[i] for all i ≠ target - 1"
                 :meta "A drop with two peaks would produce a double-accent, changing the character of the pattern. Falsification is one target where the peak is not unique. CS pattern: 'unique-max discrete sequence'. Book-of-sound ch 5 covers accent patterns.")
                (:eng "The single-peak invariant means the emphasis is unambiguous; a rhythm section can rely on it." :math "argmax is unique." :cs "Property test; O(n)."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "motion/drop produces a beat-emphasized articulation list."
                     :composition "(define (choreograph-with-drop dancer target-beat bpm)\n  (let ((drop (motion/drop target-beat 8))\n        (cad (motion/cadence bpm 'q)))\n    (if (and (hash-ref drop 'ok) (hash-ref cad 'ok))\n        (let ((curve (hash-ref drop 'articulation))\n              (period (hash-ref cad 'periodMs)))\n          (motion/with-pace dancer 0 0 (* period 8)\n            (lambda (t)\n              (let ((i (quotient (* t 8) (* period 8))))\n                (* 100 (list-ref curve (min 7 i)))))))\n        'error)))\n(choreograph-with-drop 'dancer 3 120)"
                     :emergent "A beat-synced choreography — chaining motion/drop, motion/cadence, and motion/with-pace produces a dancer that moves in time with a tempo and emphasizes the chosen beat, which no single verb can express."
                     :meta "This is the same family as a MIDI-driven step sequencer with velocity accents, or a rhythm-game step chart. Cross-reference book-of-composition ch 13; book-of-sound ch 5. Familiar analog: Ableton's velocity-controlled drum rack.")
                    (:eng "Three verbs = a beat-synced dancer; tempo is one parameter." :math "Composition of accent pattern, period lookup, and pace application." :cs "O(1) per frame once curves are built; the curves are data.")))

(verb
  :name "motion/follow-input"
  :library "motion"
  :kind "null"
  :signature "(motion/follow-input target sensor-field) -> null"
  :summary "Bind target to a sensor field. Live input tracking, open-loop at planner."
  :explanation "Motion/follow-input creates a dynamic link between a target entity and a sensor field (e.g., mouse position, joystick vector, or another entity). The target's position is updated each frame to match (or follow toward) the sensor's value. This is the simpler cousin of motion/anchor-to-input: no custom transform, just direct tracking. The verb is non-deterministic because sensor input is live and unpredictable."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((cursor (world/spawn 'marker 0 0)))\n  (motion/follow-input cursor 'mouse-position))" :note "Create a marker entity and make it track the mouse in real-time; cursor follows smoothly.")
    (:dialect "motoi" :tier "intermediate" :code "(define black-hole 'black-hole)\n(define hero 'hero)\n(define (player-dragged-by-attractor player attractor)\n  (motion/follow-input player 'attractor-field)\n  (on-frame (lambda ()\n    (when (entity/overlaps? player attractor)\n      (entity/damage! player 1)\n      (motion/halt player)))))\n(player-dragged-by-attractor hero black-hole)" :note "Make the player follow an attractor field; halt motion if they collide with the source.")
    (:dialect "motoi" :tier "expert" :code "(define minions '())\n(define (multi-leader-group-follow group-entities leader-sensors)\n  (define (assign-follower follower leader-id)\n    (motion/follow-input follower (list 'leader leader-id))\n    (on-frame (lambda ()\n      (when (< (entity/distance follower (car (world/find (lambda (e) (eq? (entity/tag! e 'leader-id) leader-id))))) 50)\n        (motion/halt follower)\n        (entity/set! follower 'state 'idle)))))\n  (for-each (lambda (f l) (assign-follower f l)) group-entities leader-sensors))\n(multi-leader-group-follow minions '(leader-1 leader-2))" :note "Assign each minion to follow a specific leader sensor; minions halt when they reach the leader.")
  )
  :caveats ("The sensor-field must be a valid, registered sensor; invalid sensor names silently do nothing." "Motion/follow-input does not guarantee the target reaches the sensor value, only that it moves toward it." "Calling motion/follow-input again updates the tracked sensor; the old one is replaced." "Non-deterministic: sensor input varies; code using motion/follow-input will not replay identically.")
  :drawbacks ("No built-in damping or smoothing; jittery sensors produce jittery motion (use motion/anchor-to-input with a filter if you need smoothing)." "Cannot query which sensor is being tracked." "If the sensor goes away or becomes invalid, the target may freeze or behave unpredictably.")
  :usecases ("Make NPCs follow the player or other entities." "Bind a UI element (tooltip, crosshair) to the mouse." "Create gravitational or magnetic field effects where entities are attracted to a location.")
  :related ("motion/anchor-to-input" "motion-follow-input" "motion/halt" "motion/move-to" "entity/distance")
  :learn (:concept "Live sensor tracking; open-loop following and input-responsiveness." :prerequisites ("world/spawn" "entity/pos" "motion/halt") :progression "Learn motion/follow-input for direct tracking, then motion/anchor-to-input for parameterized transforms, then motion/move-to for goal-based travel.")
  :row-2-audit ((:problem "The operator wants a UI reticle to track the mouse cursor exactly. No shaping, no dead-zone — pure follow."
                 :program "(define reticle (world/spawn 'reticle 0 0))\n(motion/follow-input reticle 'mouse-position)"
                 :explanation "Line 1 spawns the reticle. Line 2 binds it to the mouse-position sensor. Every frame, the reticle's position matches the mouse. No transform, no lag, no filter. The audit is one call; a reviewer sees follow-input and knows this is direct tracking."
                 :meta "Reaching for motion/anchor-to-input would require an identity transform (lambda (v) v), which is verbose. motion/follow-input is the honest answer for 'straight tracking, no shaping.'")
                (:eng "No transform means no transform to debug." :math "Identity binding: parameter(t) = sensor(t)." :cs "Mutation per frame; O(1)."))
  :row-3-dimension ((:setup "Direct one-to-one binding of a target to a live source."
                     :rungs ((:domain "motion" :code "(motion/follow-input 'reticle 'mouse-position)")
                             (:domain "shadow following an actor (metaphor)" :code "(define (shadow-position actor-pos) actor-pos)\n(shadow-position '(100 200))")
                             (:domain "identity function on live data" :code "(define (live-id source) (source))\n(live-id (lambda () 'now))"))
                     :explanation "In motion, an entity mirrors a sensor. In the shadow metaphor, a shadow follows its actor with no offset — same 1:1 tracking. In the math rung, identity applied to a source is the source. All three are the identity relation."
                     :meta "The shape transfers because 'follow perfectly' is identity; when no transformation is needed, the machinery becomes invisible.")
                    (:eng "One primitive covers UI reticles, shadow-follow, and pass-through pipelines." :math "Identity morphism." :cs "O(1) mutation per frame."))
  :row-4-proof ((:claim "Under motion/follow-input, the target's position at frame f+1 depends only on the sensor's position at frame f+1, not on any prior frame. This is the memoryless-tracking invariant."
                 :program "(define (simulate-follow sensor-history entity-start)\n  (define entity entity-start)\n  (for-each (lambda (s) (set! entity s)) sensor-history)\n  entity)\n(simulate-follow '(10 20 30 30) 0)\n(simulate-follow '(99 99 30) 0)"
                 :invariant "position(f+1) = sensor(f+1); history irrelevant"
                 :meta "A tracker with memory would drift; the reticle would occasionally jump because of a stale sample. Falsification is any run where the final position depends on prior sensor states. CS pattern: 'memoryless (Markov) tracker'. Book-of-code ch 6 covers stateless functions.")
                (:eng "The memoryless property means the reticle can never be 'stuck' on old data." :math "First-order Markov: state depends only on current input." :cs "No cached state; the binding is a per-frame identity write."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "motion/follow-input keeps a target at the sensor's position."
                     :composition "(define (posse leader followers)\n  (for-each (lambda (f)\n              (motion/follow-input f (list 'leader-position (entity/id leader))))\n            followers))\n(posse 'boss (list 'minion1 'minion2 'minion3))"
                     :emergent "A posse — chaining motion/follow-input across a list of followers with a shared leader-sensor produces a following group that mirrors the leader, which no single call has."
                     :meta "This is the same family as a Pokémon party trailing behind the player, or Diablo's mercenary following. Cross-reference book-of-composition ch 8 (parallel bindings). Familiar analog: NPC party-follow AI.")
                    (:eng "One primitive + one map = a party-follow." :math "Parallel identity bindings; the group is a set of independent trackers." :cs "O(k) per frame for k followers; each independent.")))

(verb
  :name "motion/halt"
  :library "motion"
  :kind "null"
  :signature "(motion/halt target) -> null"
  :summary "Cancel any in-flight motion on target. Idempotent."
  :explanation "Motion/halt is the canonical form for stopping in-flight animation on an entity. It cancels any active motion (from motion/move-to, motion/follow-input, or motion/anchor-to-input) and leaves the entity at its current position. Calling it on a stationary target has no effect (idempotent). Use this to interrupt motion when priorities change or when you need to reset an entity's state."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((sprite (world/spawn 'npc 50 50)))\n  (motion/move-to sprite 300 300)\n  (motion/halt sprite)\n  (display (entity/pos sprite)))" :note "Start moving an NPC, immediately halt it, and check its position; it stays at (50, 50).")
    (:dialect "motoi" :tier "intermediate" :code "(define fox 'fox)\n(define rabbit 'rabbit)\n(define (engaged-chase prey pursuer sight-range)\n  (if (< (entity/distance prey pursuer) sight-range)\n    (motion/move-to pursuer (entity/x prey) (entity/y prey))\n    (motion/halt pursuer))\n  (on-frame (lambda () (engaged-chase prey pursuer sight-range))))\n(engaged-chase rabbit fox 200)" :note "Chase the prey if in range; halt motion if out of sight. Called each frame for responsive behavior.")
    (:dialect "motoi" :tier "expert" :code "(define sentry 'sentry-1)\n(define (state-machine-patrol-combat guard alarm-trigger)\n  (define (patrol waypoints idx)\n    (let ((pt (list-ref waypoints idx)))\n      (motion/move-to guard (car pt) (cadr pt))\n      (on-frame (lambda ()\n        (if (alarm-trigger)\n          (begin (motion/halt guard) (combat guard))\n          (when (< (entity/distance guard (list (car pt) (cadr pt))) 10)\n            (patrol waypoints (modulo (+ idx 1) (length waypoints)))))))))\n  (define (combat guard)\n    (motion/follow-input guard 'target-lock)\n    (on-frame (lambda ()\n      (when (no-targets?) (motion/halt guard) (patrol waypoints 0)))))\n  (patrol '((100 100) (200 200) (150 300)) 0))\n(state-machine-patrol-combat sentry (lambda () (entity/overlaps? sentry player)))" :note "Patrol a waypoint list; on alarm, halt patrol motion and switch to combat (follow-input). When threats clear, halt combat and resume patrol.")
  )
  :caveats ("Calling motion/halt on a non-moving entity is a safe no-op." "Motion/halt does not reset the entity's velocity to zero in the physics engine; use entity/set-vel! if you need to clear inertia." "Does not trigger any callbacks or events; the halt is silent." "If motion/follow-input or motion/anchor-to-input is active, motion/halt stops the sensor binding as well.")
  :drawbacks ("No transition or easing—the stop is instant." "Cannot know if motion was active before halting; if you need to know, track the state yourself." "No return value; you cannot query the final position or distance traveled.")
  :usecases ("Stop NPC movement when scripted events trigger." "Halt a player character when they take damage or are stunned." "Clean up motion state before despawning an entity or changing states.")
  :related ("motion-halt" "motion/move-to" "motion/follow-input" "motion/anchor-to-input" "entity/set-vel!" "entity/move!")
  :learn (:concept "Animation state clearing; idempotence and state transitions." :prerequisites ("world/spawn" "entity/pos" "motion/move-to") :progression "Learn motion/halt to stop motion, then motion/move-to for directional travel, then motion/follow-input for sensor-driven motion, then chain them in state machines.")
  :row-2-audit ((:problem "An NPC was moving to a waypoint but the player just entered its aggro range. The operator needs to abandon the current motion and switch to combat behavior — right now, no fade-out."
                 :program "(define npc 'guard)\n(motion/halt npc)\n(motion/follow-input npc 'player-position)"
                 :explanation "Line 2 cancels whatever motion the NPC currently has. Line 3 begins tracking the player. Halt is instant — no interpolation, no timer to wait for. The audit trail is one call, and it is idempotent: if the NPC wasn't moving, halt is still safe."
                 :meta "Reaching for setting velocity to zero would leave residual physics; motion/halt is the honest answer for 'clear all motion state, safely.' It's the specific verb that clears both timers and bindings.")
                (:eng "Instant stop; no side-effect surprises." :math "Set-to-none operation; idempotent." :cs "Cancels timers and bindings; O(1)."))
  :row-3-dimension ((:setup "Idempotent cancellation of ongoing state."
                     :rungs ((:domain "motion" :code "(motion/halt 'guard)")
                             (:domain "shell kill -TERM (metaphor)" :code "(define (terminate-process pid)\n  (list 'send-TERM pid))\n(terminate-process 4242)")
                             (:domain "reset element in a monoid" :code "(define (reset-state _s) 'idle)\n(reset-state 'walking)"))
                     :explanation "In motion, halt clears motion state. In the shell metaphor, kill -TERM signals a process to stop — same interruption semantics. In the math rung, the reset function maps any state to a canonical idle state. All three are the idempotent-cancel shape."
                     :meta "The shape transfers because idempotent cancellation is universal: process management, motion, and state machines all need a 'set to nothing' primitive.")
                    (:eng "One primitive covers motion, process control, and state machines." :math "Constant function to 'no motion'; f(f(x)) = f(x)." :cs "O(1) cancellation."))
  :row-4-proof ((:claim "motion/halt is idempotent: calling it twice is equivalent to calling it once. This is the idempotence invariant."
                 :program "(define (mock-state) 'moving)\n(define (mock-halt s) 'still)\n(equal? (mock-halt (mock-halt (mock-state)))\n        (mock-halt (mock-state)))"
                 :invariant "∀ e . halt(halt(e)) = halt(e)"
                 :meta "A halt that partially cancelled and left residue would leak into subsequent frames. Falsification is any e where a double-halt differs from a single halt. CS pattern: 'idempotent operation'. Book-of-code ch 8 covers idempotence.")
                (:eng "Idempotence is what makes halt safe in defensive-programming: call it in cleanup without checking state." :math "Idempotence: h ∘ h = h; the fixed set is 'no motion'." :cs "Property test on state cancellation."))
  :row-5-emergence ((:base "motion/halt cancels any in-flight motion on the target."
                     :composition "(define (patrol-and-combat guard)\n  (motion/move-to guard 200 200 500 'ease-out-cubic)\n  (on-frame (lambda ()\n    (when (< (entity/distance guard 'player) 50)\n      (motion/halt guard)\n      (motion/follow-input guard 'player-position)))))\n(patrol-and-combat 'guard)"
                     :emergent "A state-machine transition — chaining motion/halt with motion/follow-input inside an on-frame guard produces a patrol-to-combat transition that neither verb has alone."
                     :meta "This is the same family as a behavior-tree transition, or a Unity FSM state-exit-then-enter. Cross-reference book-of-composition ch 15 (state transitions). Familiar analog: any FSM library's transition function.")
                    (:eng "Halt + follow-input inside on-frame = a live state transition; no allocation." :math "Composition of a cancel operation with a bind operation." :cs "The transition is O(1); on-frame guards it with distance check.")))

(verb
  :name "motion/move-to"
  :library "motion"
  :kind "null"
  :signature "(motion/move-to target x y duration easing-name) -> descriptor"
  :summary "Animate a card or entity to (x, y) over a duration with an easing curve."
  :explanation "motion/move-to is the universal travel verb: it creates a smooth animation from any drawable's current position to a target (x, y) over a specified time with a named easing curve (e.g. 'ease-in-quad', 'linear'). The verb returns a descriptor object; the host applies it to the target. Use this whenever you need fluent, choreographed movement—it works equally well on cards, entities, and camera viewports. The :ms and :curve arguments are optional; defaults are typically 300ms and 'ease-out-cubic'."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define my-card 'my-card)\n(motion/move-to my-card 150 200 500 'ease-out-cubic)" :note "Move my-card to (150, 200) over 500 ms with ease-out-cubic easing.")
    (:dialect "motoi" :tier "intermediate" :code "(define my-card 'my-card)\n(card-do my-card 'animate\n  (motion/move-to my-card 300 100 800 'ease-in-sine))" :note "Queue a motion animation on my-card; the easing curve shapes the speed profile.")
    (:dialect "motoi" :tier "expert" :code "(define ctx '())\n(define (sweep-across ctx)\n  (let* ((target (card-find-by-kind 'selector ctx))\n         (x (+ (card-x target) 40))\n         (y (card-y target)))\n    (card-do target 'animate\n      (motion/move-to target x y 400 'ease-out-cubic))))\n(next 'idle ctx)" :note "Choreograph a sweep: compute target position relative to a found card, then animate there.")
  )
  :caveats ("The verb returns a descriptor; it does not immediately move the target. The host must dispatch it (e.g. via card-do or on a card/transition)." "x and y must be finite numbers. Non-numeric or infinite values may be silently rejected by the host." "If :ms is omitted, the host uses a sensible default (typically 300ms); if :curve is omitted, a default easing is applied." "Movement is relative to the target's local coordinate space unless the host specifies otherwise.")
  :drawbacks ("Cannot chain multiple moves on the same target in a single call; use multiple card-do calls or motion/arc for multi-waypoint paths." "No built-in collision detection during motion; entities may pass through obstacles if gravity/physics is not enabled." "If the target is destroyed or goes out of scope before the motion completes, the animation is cancelled silently.")
  :usecases ("Sliding a card into place during UI transitions." "Smoothly panning the camera to focus on a point of interest." "Choreographing entity movement in a game (e.g., enemy patrol paths)." "Animating a modal or panel entrance/exit.")
  :related ("motion/arc" "motion/follow-input" "motion/halt" "motion/with-pace" "motion/with-feel" "motion/cadence" "card-do" "card-transition")
  :learn (:concept "Descriptive motion — separate the intent (move to x, y) from the execution (the host animates on each frame)." :prerequisites ("card/transition" "card-do") :progression "After mastering motion/move-to, explore motion/arc for multi-point paths and motion/with-pace to modulate speed via timing tensors.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A card should slide to a new position over 400 ms with an ease-out curve. The operator wants declarative motion — describe the destination and let the runtime handle interpolation."
                 :program "(define descriptor (motion/move-to 'card 200 100 400 'ease-out-cubic))\n(card-do 'card 'animate descriptor)"
                 :explanation "Line 1 builds a motion descriptor: target, coordinates, duration, easing. Line 2 dispatches it to the host, which will interpolate each frame. The descriptor is data; the animation is the host's job. The operator's audit trail is one descriptor per animation, versioned and inspectable."
                 :meta "Reaching for a hand-written interpolation loop would work but reinvent the runtime's animation dispatcher. motion/move-to is the honest answer because it separates intent (destination + duration + shape) from execution (per-frame interpolation).")
                (:eng "Descriptor is a value; can be logged, replayed, compared." :math "Parametric line: p(t) = start + (target − start) · e(t/duration)." :cs "Data-oriented: descriptor is data, animation is dispatched."))
  :row-3-dimension ((:setup "Declarative motion: describe destination + shape."
                     :rungs ((:domain "motion" :code "(motion/move-to 'card 200 100 400 'ease-out-cubic)")
                             (:domain "SQL UPDATE (metaphor)" :code "(define (update-descriptor table where set-clauses) (list 'update table 'where where 'set set-clauses))\n(update-descriptor 'cards '(id 5) '((x . 200) (y . 100)))")
                             (:domain "morphism in a category" :code "(define (make-morphism source target easing)\n  (list source '-> target 'via easing))\n(make-morphism '(50 50) '(200 100) 'ease-out-cubic)"))
                     :explanation "In motion, the descriptor describes where to go. In the SQL metaphor, an UPDATE describes what to change and to what — same declarative shape. In the math rung, a morphism specifies a source, a target, and the transformation between. All three describe intent, not mechanism."
                     :meta "The shape transfers because 'describe intent, let the substrate execute' is universal: SQL, category theory, and animation all use this separation.")
                    (:eng "One shape covers motion, database mutation, and category theory." :math "Morphism triple (source, target, arrow)." :cs "Data-oriented: the descriptor is a value."))
  :row-4-proof ((:claim "For any duration d>0 and any registered easing e, at time t=0 the animated position equals the start position, and at time t=d it equals the target. This is the endpoint-honesty invariant."
                 :program "(define start '(50 50))\n(define target '(200 100))\n(define (interpolate-at t d easing)\n  (map (lambda (s g)\n         (+ s (* (tick/ease easing (/ t d)) (- g s))))\n       start target))\n(and (equal? (interpolate-at 0 400 'ease-out-cubic) start)\n     (equal? (interpolate-at 400 400 'ease-out-cubic) target))"
                 :invariant "position(0) = start ∧ position(duration) = target"
                 :meta "An animation that missed its target by any margin would leak into the next frame's start, causing accumulated drift. Falsification is any run where the final position differs from the target. CS pattern: 'endpoint-honest interpolation'. Book-of-motion ch 3 covers move-to semantics.")
                (:eng "The invariant is what makes chained animations composable; each ends exactly where the next starts." :math "e(0)=0, e(1)=1 propagates through affine interpolation." :cs "Property test on two boundary times."))
  :row-5-emergence ((:base "motion/move-to builds a descriptor for a single animated segment."
                     :composition "(define (rectangle-path entity size duration)\n  (motion/move-to entity (+ (entity/x entity) size) (entity/y entity) duration 'ease-in-out-cubic)\n  (motion/on-settle entity (lambda (_)\n    (motion/move-to entity (entity/x entity) (+ (entity/y entity) size) duration 'ease-in-out-cubic)\n    (motion/on-settle entity (lambda (_)\n      (motion/move-to entity (- (entity/x entity) size) (entity/y entity) duration 'ease-in-out-cubic)\n      (motion/on-settle entity (lambda (_)\n        (motion/move-to entity (entity/x entity) (- (entity/y entity) size) duration 'ease-in-out-cubic))))))))\n(rectangle-path 'square 100 300)"
                     :emergent "A rectangle path — chaining move-to with on-settle four times produces motion around a rectangle that neither verb has alone. The composition creates a state-machine of four segments."
                     :meta "This is the same family as an animation graph in Unity, or a Rive state machine. Cross-reference book-of-composition ch 12 (chained segments). Familiar analog: a UIView animation-chain via .onCompletion.")
                    (:eng "Move-to + on-settle = a path-following state machine; adding a segment is one nested lambda." :math "Composition of four affine interpolations sequenced by completion." :cs "O(1) per segment; the chain is bounded by the depth of nesting.")))

(verb
  :name "motion/pocket"
  :library "motion"
  :kind "null"
  :signature "(motion/pocket :tolerance-ms tolerance :count n) -> descriptor"
  :summary "Quantize motion timing into discrete 'pockets' (offsets) to snap animations to a rhythmic grid."
  :explanation "motion/pocket generates a set of deterministic timing offsets (in milliseconds) symmetric around zero. This is used to snap motion timings to a rhythmic pulse—like a quantize grid in a DAW. You specify a tolerance window (±tolerance-ms) and how many discrete pockets to divide it into. The verb returns a descriptor with the offsets list; the host uses it to nudge animation start/end times onto nearby \"safe\" grid points, ensuring visual cohesion with music or a beat clock. Use this when you want motion to feel locked to a tempo."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(motion/pocket 16 3)" :note "Create 3 timing pockets within ±16 ms: [-16, 0, 16].")
    (:dialect "motoi" :tier "intermediate" :code "(define my-card 'my-card)\n(let ((pockets (motion/pocket 24 5)))\n  (card-do my-card 'animate (motion/move-to my-card 200 300 400)))" :note "Generate a 5-pocket grid, then use it implicitly as the animation snaps to the nearest grid point.")
    (:dialect "motoi" :tier "expert" :code "(define ctx '())\n(define (sync-sweep ctx)\n  (let* ((beat (audio-beat?))\n         (next-beat-ms (if beat (+ beat 500) (+ (audio-time) 500)))\n         (pockets (motion/pocket 12 4)))\n    (card-do (card-find-by-kind 'selector ctx) 'animate\n      (motion/move-to (card-find-by-kind 'selector ctx) 150 100 350 'ease-out-cubic))))\n(next 'idle ctx)" :note "Compute a motion duration that aligns to the beat; the pocket descriptor helps snap timing to a grid.")
  )
  :caveats ("motion/pocket returns a descriptor, not a direct timing effect. The host or a downstream motion verb (e.g. motion/with-pace) must consume it." "Offsets are returned in milliseconds; they must be applied by the animator or motion composition layer." "If count is 0 or negative, it is clamped to 1 (single pocket at offset 0)." "tolerance-ms is clamped to ≥ 0; negative values become 0.")
  :drawbacks ("The pocket descriptor alone does not change timing—it must be passed to or composed with other motion verbs to take effect." "Pockets are symmetric; if you need asymmetric quantization, use a different approach." "Creating many pockets (large count) with small tolerance may result in very fine-grained offsets that offer little practical benefit.")
  :usecases ("Snap card animations to a musical beat grid for a rhythm-game UI." "Quantize entity movement to a tempo so characters feel synchronized." "Align motion timing with a drum pattern or metronome." "Reduce jitter in animation timing by grouping possible times into discrete buckets.")
  :related ("motion/with-pace" "motion/cadence" "motion/move-to" "audio-beat?" "audio-tempo" "tick/pulse" "tick/lissajous")
  :learn (:concept "Quantization — rounding continuous time into discrete grid buckets to achieve rhythmic alignment." :prerequisites ("motion/move-to" "audio-beat?" "audio-tempo") :progression "Combine motion/pocket with motion/with-pace for full temporal control: pocket defines the grid, with-pace modulates speed.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "Animations should snap to a beat clock within a ±16 ms tolerance to avoid visible drift from the audio. The operator needs the discrete grid points for the quantizer."
                 :program "(define pockets (motion/pocket 16 3))\n(display pockets)"
                 :explanation "Line 1 requests 3 pockets within ±16ms: [-16, 0, +16]. Line 2 shows the descriptor. Downstream, the animator uses these to pull the animation's start-time toward the nearest one. The audit trail is a single call producing a small list of offsets."
                 :meta "Rolling your own list of offsets (e.g. (list -16 0 16)) works for a specific case; motion/pocket generalizes it to any (tolerance, count) pair. It is the honest answer when the operator wants the grid to be a parameter, not a constant.")
                (:eng "Named parameters (tolerance, count) instead of magic numbers." :math "Symmetric arithmetic progression on integers." :cs "O(count) list allocation."))
  :row-3-dimension ((:setup "Symmetric quantization grid around zero."
                     :rungs ((:domain "motion" :code "(motion/pocket 16 3)")
                             (:domain "video-frame drop tolerance (metaphor)" :code "(define (frame-drops max-drift n)\n  (let loop ((i (- n)) (acc '()))\n    (if (> i n) (reverse acc)\n        (loop (+ i 1) (cons (* i (/ max-drift n)) acc)))))\n(frame-drops 16 1)")
                             (:domain "arithmetic progression -a..a" :code "(define (ap-symmetric a n)\n  (let ((step (/ (* 2.0 a) (- n 1))))\n    (let loop ((i 0) (acc '()))\n      (if (= i n) (reverse acc)\n          (loop (+ i 1) (cons (+ (- a) (* i step)) acc))))))\n(ap-symmetric 16 3)"))
                     :explanation "In motion, pockets give timing snap points. In video-frame-drop, allowed drift produces symmetric offsets — same shape. In the math rung, a symmetric arithmetic progression around zero is the archetype. All three produce equally-spaced integers around a center."
                     :meta "The shape transfers because it is a symmetric arithmetic progression; wherever quantization around zero is needed, this shape appears.")
                    (:eng "One shape covers motion, video timing, and time-series analysis." :math "Symmetric AP with step 2·tolerance/(count-1)." :cs "O(count) list construction."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "The set of offsets produced by motion/pocket is symmetric about zero: for every offset o in the set, −o is also in the set. This is the pockets-are-symmetric invariant."
                 :program "(define pockets (motion/pocket 16 5))\n(define (all-mirrored? xs)\n  (let ((s xs))\n    (let loop ((xs xs))\n      (if (null? xs) #t\n          (if (member (- (car xs)) s) (loop (cdr xs)) #f)))))\n(all-mirrored? pockets)"
                 :invariant "∀ o ∈ pockets . −o ∈ pockets"
                 :meta "A non-symmetric quantizer would bias the animation's start time toward one direction (early or late). Falsification is any offset without its mirror. CS pattern: 'symmetric quantization grid'. Book-of-motion ch 8 covers timing quantization.")
                (:eng "Symmetry means the quantizer does not systematically pull animations early or late." :math "Symmetric AP; sum of elements is zero." :cs "Membership check + loop; O(n²) naive, O(n) with a set."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "motion/pocket produces a symmetric quantization grid of offsets."
                     :composition "(define (quantize-motion-to-beat entity target-x target-y duration)\n  (let ((pockets (motion/pocket 12 4))\n        (beat-time (audio-time)))\n    (motion/move-to entity target-x target-y duration 'ease-out-cubic)))\n(quantize-motion-to-beat 'card 200 100 350)"
                     :emergent "A beat-locked animation — combining motion/pocket with motion/move-to produces motion whose start time snaps to the beat grid, which move-to alone cannot deliver."
                     :meta "This is the same family as a DAW's audio-clip quantize, or a rhythm-game's input-timing window. Cross-reference book-of-sound ch 7 (quantization). Familiar analog: Ableton's clip-quantize feature.")
                    (:eng "Two verbs = beat-locked motion; adjusting tolerance is one number." :math "Composition of a snap-to-grid operation with an animation dispatch." :cs "O(1) start-time snap; motion cost unchanged.")))

(verb
  :name "motion/with-feel"
  :library "motion"
  :kind "null"
  :signature "(motion/with-feel tensor-id :articulation style) -> descriptor"
  :summary "Apply an articulation style (legato, staccato, marcato) to motion, shaping how a movement is phrased."
  :explanation "motion/with-feel wraps a timing tensor (a reusable set of articulation ratios) and applies a named articulation style to motion. Articulation controls how smoothly or percussively a movement unfolds: 'legato' is connected and fluid, 'staccato' is short and clipped, 'marcato' is accented. The verb recalls a timing tensor by ID (cached in the host) and returns a descriptor that carries both the tensor and the articulation choice. Use this when you want movement to match the phrasing of the music or to create a particular character feel (bouncy, heavy, deliberate)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(motion/with-feel 'my-tensor-42 'legato)" :note "Apply legato (smooth, connected) phrasing to a timing tensor.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((feel (motion/with-feel 'sweep-tensor 'staccato)))\n  (if (equal? (feel 'ok) #t)\n    (card-do my-card 'animate feel)\n    (escalate 'timing-not-ready null)))" :note "Check if the tensor is ready before using it; escalate if pending.")
    (:dialect "motoi" :tier "expert" :code "(define ctx '())\n(define (choreograph-bounce ctx)\n  (let ((light-feel (motion/with-feel 'light-bounce 'staccato))\n        (heavy-feel (motion/with-feel 'heavy-bounce 'marcato)))\n    (card-do (card-find-by-kind 'light ctx) 'animate light-feel)\n    (card-do (card-find-by-kind 'heavy ctx) 'animate heavy-feel)))\n(next 'idle ctx)" :note "Apply different articulations to different cards to create a composite animation feel.")
  )
  :caveats ("Requires a timing tensor to be pre-cached in the host. If the tensor ID is unknown or not yet loaded, the verb returns { ok: false }." "If :articulation is not recognized, it defaults to 'legato'." "The descriptor is lazy; the actual phrasing is applied only when the host animates using this descriptor." "Changing the articulation style after animation starts has no effect on in-flight motion.")
  :drawbacks ("Timing tensors must be pre-loaded or registered; there is no inline way to define custom articulation ratios within motion/with-feel." "The verb cannot validate that the tensor will be ready at animation time; mismatches are caught late (at render)." "Limited to predefined articulation styles (legato, staccato, marcato); custom phrasing requires defining a new tensor.")
  :usecases ("Animate UI elements with a staccato feel for sharp, punchy transitions." "Move characters with legato phrasing to suggest fluidity or grace." "Combine motion/with-feel with motion/with-pace to create expressive choreography (pace controls speed, feel controls smoothness)." "Match motion phrasing to musical articulation in a choreographed scene.")
  :related ("motion/with-pace" "motion/cadence" "motion/move-to" "motion/arc" "card/transition" "tick/pattern")
  :learn (:concept "Articulation — the subtle phrasing and attack/decay of a gesture, independent of its speed or path." :prerequisites ("motion/move-to" "motion/with-pace") :progression "Combine motion/with-feel and motion/with-pace in sequence or composition for full expressive control over motion.")
  :row-2-audit ((:problem "A dance move should feel staccato — short, clipped attacks with silences between motions. The operator has a tensor 'sweep-tensor and wants to apply a staccato articulation."
                 :program "(define feel (motion/with-feel 'sweep-tensor 'staccato))\n(card-do 'card 'animate feel)"
                 :explanation "Line 1 wraps the tensor with a staccato articulation, producing a descriptor. Line 2 dispatches the animation. Staccato has short attacks and clear separations; legato is smooth; marcato is accented. The audit is one call plus a named articulation symbol."
                 :meta "Reaching for motion/with-pace would only change speed, not the attack character. motion/with-feel is the honest answer because 'phrasing' is orthogonal to 'tempo' — it needs its own knob.")
                (:eng "Phrasing and tempo are independent concerns; audit trail is one symbol per." :math "The articulation shapes the ratio of attack-time to hold-time within a segment." :cs "Descriptor is data; the animator applies it."))
  :row-3-dimension ((:setup "Applying an articulation shape to a temporal envelope."
                     :rungs ((:domain "motion" :code "(motion/with-feel 'sweep-tensor 'staccato)")
                             (:domain "musical articulation (metaphor)" :code "(define (articulate note-length style)\n  (case style\n    ((staccato) (list note-length (* note-length 0.5)))\n    ((legato) (list note-length note-length))\n    ((marcato) (list note-length (* note-length 0.9)))))\n(articulate 500 'staccato)")
                             (:domain "ADSR envelope selection" :code "(define (adsr-preset style)\n  (case style\n    ((staccato) '((attack . 10) (decay . 50) (sustain . 0.3) (release . 20)))\n    ((legato) '((attack . 100) (decay . 20) (sustain . 0.8) (release . 200)))))\n(adsr-preset 'staccato)"))
                     :explanation "In motion, articulation shapes phrasing. In music, staccato/legato/marcato control note attacks — same phrasing vocabulary. In synthesis, ADSR envelopes shape amplitude — same shape at a lower level. All three carry the phrasing signal."
                     :meta "The shape transfers because 'articulation' is a semantic vocabulary that predates its substrates: musicians named it long before animators or synth designers, and the shape maps cleanly.")
                    (:eng "One shape covers motion, music, and synthesis." :math "Articulation reshapes the envelope's attack-hold-release proportions." :cs "Case dispatch on symbol; O(1) descriptor build."))
  :row-4-proof ((:claim "For a fixed tensor, applying motion/with-feel with 'staccato and then converting to 'legato produces two different envelopes, and both are strictly bounded by the tensor's total duration. This is the articulation-shapes-attack invariant with duration preservation."
                 :program "(define t (motion/with-feel 'sweep-tensor 'staccato))\n(define l (motion/with-feel 'sweep-tensor 'legato))\n(define (envelope-total desc) (hash-ref desc 'duration))\n(and (equal? (envelope-total t) (envelope-total l))\n     (not (equal? (hash-ref t 'articulation)\n                  (hash-ref l 'articulation))))"
                 :invariant "duration(feel(τ, a)) = duration(feel(τ, b)) for all articulations a, b"
                 :meta "A feel that changed total duration would break beat sync. Falsification is any two articulations that produce different total times. CS pattern: 'invariant-under-articulation duration'. Book-of-motion ch 9 covers articulation.")
                (:eng "Total duration invariance is what keeps articulated motion locked to the beat." :math "Articulation permutes attack-hold-release within a fixed span." :cs "Property test on descriptor duration."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "motion/with-feel binds an articulation style to a tensor's envelope."
                     :composition "(define (expressive-scene light-cards heavy-cards)\n  (for-each (lambda (c)\n              (card-do c 'animate (motion/with-feel 'light-bounce 'staccato)))\n            light-cards)\n  (for-each (lambda (c)\n              (card-do c 'animate (motion/with-feel 'heavy-bounce 'marcato)))\n            heavy-cards))\n(expressive-scene '(a b) '(c d))"
                     :emergent "A layered articulation composition — chaining with-feel across two groups produces a scene where light elements pop and heavy elements accent, giving the ensemble a musical character."
                     :meta "This is the same family as an orchestral arrangement where sections play different articulations, or a mixing console with per-track effects. Cross-reference book-of-composition ch 13. Familiar analog: a DAW mix with different insert-effects per track.")
                    (:eng "One primitive + two groups = a two-voice articulation arrangement." :math "Parallel application of different articulations to a partition of the elements." :cs "O(k) for k elements; each independent.")))

(verb
  :name "motion/with-pace"
  :library "motion"
  :kind "null"
  :signature "(motion/with-pace tensor-id :intensity level) -> descriptor"
  :summary "Modulate the speed and energy of motion by scaling a timing tensor's inter-onset interval (IoI)."
  :explanation "motion/with-pace takes a timing tensor (a cached set of temporal ratios) and an intensity value (0.0 to 1.0) and returns a descriptor that will scale the motion's speed. Intensity 0.0 is slowest, 1.0 is fastest; the verb clamps out-of-range values. The descriptor carries the tensor ID and intensity, allowing the host's animator to apply speed modulation proportional to the intensity. Use this to make motion feel urgent (high intensity) or languorous (low intensity), or to respond to real-time conditions like energy level or urgency."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(motion/with-pace 'default-tensor 0.7)" :note "Apply 70% speed (slower than normal) using a timing tensor.")
    (:dialect "motoi" :tier "intermediate" :code "(define target-card 'target-card)\n(define urgency 'urgency)\n(let ((urgency 0.9)\n      (pace (motion/with-pace 'action-tensor urgency)))\n  (card-do target-card 'animate pace))" :note "Compute intensity from context (e.g., urgency level) and pass it to with-pace.")
    (:dialect "motoi" :tier "expert" :code "(define ctx '())\n(define (respond-to-energy ctx)\n  (let* ((energy (ctx-get 'energy-level ctx))\n         (intensity (/ (- energy 0) (- 100 0))))\n    (card-do (card-find-by-kind 'player ctx) 'animate\n      (motion/with-pace 'player-tensor (min 1.0 intensity)))))\n(next 'idle ctx)" :note "Map a context variable (energy) to intensity, then modulate motion speed dynamically.")
  )
  :caveats ("Requires a pre-cached timing tensor; if the tensor is not ready, the verb returns { ok: false }." "Intensity values outside [0.0, 1.0] are silently clamped; no error is raised." "The descriptor is lazy; speed modulation is applied only when the host animates using it." "Changing intensity after animation starts has no effect on in-flight motion.")
  :drawbacks ("Timing tensors must be pre-loaded; no inline tensor definition is possible." "Speed modulation is a multiplicative scaling; very low intensity may result in imperceptibly slow motion." "No way to specify non-linear intensity curves (e.g., exponential acceleration); intensity is linear." "The verb does not validate that the tensor will be ready at animation time; failures are caught late.")
  :usecases ("Slow down motion when a character is exhausted or in stealth mode." "Speed up motion in response to urgency, alarm, or a musical crescendo." "Create responsive UI animations that feel snappier or more languid based on app state." "Compose motion/with-pace with motion/move-to for dynamic, state-driven choreography.")
  :related ("motion/with-feel" "motion/cadence" "motion/move-to" "motion/pocket" "audio-tempo" "audio-beat?")
  :learn (:concept "Tempo and energy — scaling motion speed as a function of context (urgency, energy, tempo)." :prerequisites ("motion/move-to" "motion/with-feel" "ctx-get") :progression "Combine motion/with-pace with motion/with-feel and motion/move-to to achieve full expressive control: path, phrasing, and speed.")
  :row-2-audit ((:problem "A hero character is exhausted and moves should slow down. The operator has an energy value in [0,100]; they want to map it to an intensity in [0,1] and use it to modulate pace."
                 :program "(define energy 30)\n(define intensity (/ energy 100.0))\n(define pace-desc (motion/with-pace 'hero-tensor intensity))\n(card-do 'hero 'animate pace-desc)"
                 :explanation "Line 1 sets an energy value. Line 2 normalizes to [0,1]. Line 3 builds a pace descriptor at 30% intensity — slower motion. Line 4 dispatches. When energy drops to 10, pace becomes 0.1; the hero moves visibly slower. The audit trail is one intensity number tied to game state."
                 :meta "Reaching for slowing motion by manually multiplying duration is fragile — every motion call has to know about the energy. motion/with-pace centralizes speed control in a descriptor that stays coherent as game state evolves.")
                (:eng "One intensity variable drives all motion; a single edit propagates." :math "Scalar multiplication of inter-onset intervals." :cs "Descriptor build is O(1)."))
  :row-3-dimension ((:setup "Scaling temporal spacing by a single intensity parameter."
                     :rungs ((:domain "motion" :code "(motion/with-pace 'hero-tensor 0.3)")
                             (:domain "video playback speed (metaphor)" :code "(define (playback-time real-time speed) (/ real-time speed))\n(playback-time 60 0.3)")
                             (:domain "affine scaling of time domain" :code "(define (affine-time t scale) (* t (/ 1.0 scale)))\n(affine-time 60 0.3)"))
                     :explanation "In motion, intensity scales inter-onset intervals. In video playback, speed scales frame times — same operation. In the math rung, affine scaling of the time axis is the general form. All three scale time by a single factor."
                     :meta "The shape transfers because all three are the same: multiply time by a scalar. Whether the substrate is animation, video, or a math abstraction, the operation is identical.")
                    (:eng "One shape covers game motion, video, and general time manipulation." :math "Time-axis scaling; preserves shape while stretching/compressing." :cs "O(1) descriptor build; the animator handles per-frame."))
  :row-4-proof ((:claim "The average speed of motion scaled by intensity i is proportional to i: doubling i halves the total duration. This is the pace-intensity-linearity invariant."
                 :program "(define (mock-duration base-duration intensity)\n  (/ base-duration intensity))\n(define d1 (mock-duration 1000 0.5))\n(define d2 (mock-duration 1000 1.0))\n(define d3 (mock-duration 1000 0.25))\n(and (= d1 (* d2 2))\n     (= d3 (* d2 4)))"
                 :invariant "duration(intensity) · intensity = constant (base duration)"
                 :meta "A pace scaling that was non-linear would make the intensity knob feel wrong: doubling it wouldn't halve the duration, and the player's sense of urgency wouldn't map to visible speed. Falsification is one intensity where duration·intensity ≠ constant. CS pattern: 'linear time scaling'. Book-of-motion ch 10 covers pacing.")
                (:eng "Linearity is what makes the intensity knob feel natural." :math "duration = base / intensity is a hyperbolic map with linear inverse." :cs "Property test on scaled durations."))
  :row-5-emergence ((:base "motion/with-pace scales the pace of a tensor by intensity."
                     :composition "(define (energy-driven-behavior entity)\n  (on-frame (lambda ()\n    (let ((energy (entity/get entity 'energy)))\n      (card-do entity 'animate (motion/with-pace 'player-tensor (min 1.0 (/ energy 100.0))))))))\n(energy-driven-behavior 'hero)"
                     :emergent "Live pace-response — chaining motion/with-pace with on-frame and entity state produces motion whose speed tracks a game variable, which the descriptor alone cannot."
                     :meta "This is the same family as adaptive-audio ducking, or a video game's difficulty-scaling. Cross-reference book-of-composition ch 14 (state-driven motion). Familiar analog: Elden Ring's stamina-scaled dodge speed.")
                    (:eng "Every frame the motion's pace reflects current state; game-feel emerges from one loop." :math "Time-varying scalar composition." :cs "O(1) descriptor build per frame; motion dispatch is amortized.")))

(verb
  :name "bounce"
  :library "motion"
  :kind "io"
  :signature "(bounce target [:height h] [:easing e] [:duration ms] [:at (x y)]) -> tween"
  :status "landed"
  :since "2026-07-16"
  :dialect "motoi"
  :audience "kid"
  :provenance "motoi-scheme/lib/graphics/animation.js"
  :training-eligible #t
  :confidentiality "open"
  :summary "One-liner: make anything bounce in place — text, emoji, sprites, cards."
  :explanation "bounce is the kid-shaped shortcut for the most common motion effect. Given any drawable (an entity id, a card, a string of text or emoji), it launches the target upward by :height pixels, then lets it fall back to its original y with a small settle. Defaults: height 40, duration 700ms, easing easing/spring, origin (40, 40). :easing accepts either a symbol (easing/spring, easing/emphasized, etc.) or a curve procedure returned by bezier-ease / named-ease / spring-ease — uniform dispatch across all motion verbs. Returns the tween record so callers can chain motion/on-settle for completion callbacks."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(bounce \"🎉\")" :note "Make a party popper emoji bounce with defaults.")
    (:dialect "motoi" :tier "intermediate" :code "(bounce 'hero :height 40 :duration 800 :easing easing/spring)" :note "Make the hero sprite bounce higher and slower with an explicit spring easing.")
    (:dialect "motoi" :tier "expert" :code "(define custom (bezier-ease 0.4 0.0 0.2 1.0))\n(define (celebrate-hits n)\n  (let loop ((i 0))\n    (cond ((= i n) 'ok)\n          (else (bounce \"⭐\" :height (+ 20 (* i 5)) :easing custom)\n                (loop (+ i 1))))))\n(celebrate-hits 5)" :note "Cascade of star bounces using a hand-tuned bezier curve as the easing value.")
  )
  :caveats ("For a string, bounce paints the text at its current cursor and bounces the painted region." ":easing accepts symbols OR procedures; unknown symbols fall back to linear (no throw).")
  :drawbacks ("No horizontal component; use slide for that." "Fixed sin-arc path — use motion/move-to for arbitrary trajectories.")
  :usecases ("Celebrations, achievements, +1 pops." "Making an emoji react to input." "First-day-of-Motoi hello-world motion.")
  :related ("slide" "fade" "motion/move-to" "motion/on-settle" "easing/spring")
  :learn (:concept "One-liner motion: a verb the kid can type from memory." :prerequisites ("fb/text") :progression "Learn bounce for vertical, slide for horizontal, fade for opacity — then combine them for effects that layer.")
  :row-2-audit ((:problem "The operator (an 11-year-old learning Motoi) just typed 'hello world' and wants the character to celebrate — something visible and fun in one line."
                 :program "(bounce \"🎉\")"
                 :explanation "One call. bounce takes the string and animates a bounce with defaults (40px height, 700ms, spring easing). No parameters, no configuration file. The kid types the verb and sees the emoji jump — the whole motion library reveals itself through one action."
                 :meta "Reaching for motion/move-to and manual keyframes would work but requires understanding tweens and easings, which are stack-deep for a beginner. bounce is the honest first-motion verb because it needs no arguments and produces a visible result.")
                (:eng "Zero-config motion; the kid gets a win in one line." :math "sin-arc trajectory: y(t) = y0 − height · sin(π · t/duration)." :cs "Effect kind: paints and animates; the return value is a tween record."))
  :row-3-dimension ((:setup "A zero-config verb producing a familiar physical action."
                     :rungs ((:domain "motion" :code "(bounce \"🎉\")")
                             (:domain "rubber ball dropping (metaphor)" :code "(define (ball-drop-height t duration height g)\n  (max 0 (- height (* 0.5 g t t))))\n(ball-drop-height 0.3 1.0 40 -9.8)")
                             (:domain "sine half-cycle" :code "(define (half-sine t period height)\n  (* height (sin (* 3.14159 (/ t period)))))\n(half-sine 350 700 40)"))
                     :explanation "In motion, bounce paints and animates. In the ball-drop metaphor, a rubber ball drops and rebounds under gravity — same physical intuition. In the math rung, a half sine cycle produces the up-and-down trajectory. All three describe the same shape: rise, peak, fall."
                     :meta "The shape transfers because 'bounce' is a physical archetype; whether the substrate is emoji, ball, or math, the trajectory is a half sine (or approximation).")
                    (:eng "One primitive; the shape is familiar from childhood." :math "Half-cycle sine; peak at t = duration/2." :cs "Symbol → trajectory table lookup + interpolation."))
  :row-4-proof ((:claim "For every default bounce, the target ends at its starting y-coordinate: (target-y at t=duration) = (target-y at t=0). This is the return-to-origin invariant that makes bounce reusable without state cleanup."
                 :program "(define (mock-bounce-position t duration height)\n  (let ((phase (/ t duration)))\n    (* height (sin (* 3.14159 phase)))))\n(define (approx a b) (< (abs (- a b)) 0.001))\n(and (approx (mock-bounce-position 0 700 40) 0)\n     (approx (mock-bounce-position 700 700 40) 0)\n     (> (mock-bounce-position 350 700 40) 0))"
                 :invariant "bounce(t=0).y = bounce(t=duration).y ∧ bounce(t=duration/2).y > bounce(t=0).y"
                 :meta "A bounce that didn't return would leave the entity displaced, breaking layout. Falsification is any run where end-y differs from start-y. CS pattern: 'periodic-return trajectory'. Book-of-motion ch 4 covers bounce shapes.")
                (:eng "Return-to-origin is what makes bounce composable — call it repeatedly without cleanup." :math "sin(0) = sin(π) = 0; peak at π/2." :cs "Test on trajectory endpoints."))
  :row-5-emergence ((:base "bounce animates a target upward and back to origin."
                     :composition "(define (celebrate-hits n)\n  (let loop ((i 0))\n    (cond ((= i n) 'ok)\n          (else (bounce \"⭐\" :height (+ 20 (* i 5)) :easing easing/spring)\n                (loop (+ i 1))))))\n(celebrate-hits 5)"
                     :emergent "A cascading celebration — chaining bounce with a loop produces a series of stars each bouncing higher than the last, which reads as an achievement-cascade."
                     :meta "This is the same family as a rocket-league goal celebration, or a Slack reaction storm. Cross-reference book-of-composition ch 6 (repeated actions). Familiar analog: Slack's confetti-burst on a milestone message.")
                    (:eng "One primitive + a loop = a celebration; adjusting per-bounce height is one arg." :math "Sequence of half-sine trajectories with monotonically-increasing amplitude." :cs "O(n) bounces; each independent.")))

(verb
  :name "slide"
  :library "motion"
  :kind "io"
  :signature "(slide target :from-side side [:distance d] [:duration ms] [:easing e] [:at (x y)]) -> tween"
  :status "landed"
  :since "2026-07-16"
  :dialect "motoi"
  :audience "kid"
  :provenance "motoi-scheme/lib/graphics/animation.js"
  :training-eligible #t
  :confidentiality "open"
  :summary "One-liner: slide anything in from an edge — 'left, 'right, 'top, or 'bottom."
  :explanation "slide is the kid-shaped shortcut for sliding a drawable in from an edge. :from-side is one of 'left, 'right, 'top, or 'bottom. The target starts off-screen (or offset by :distance pixels) on the named side and glides to its target position. Defaults: distance 100, duration 400ms, easing easing/emphasized, origin (40, 40). :easing accepts symbols OR curve procedures (from bezier-ease / named-ease / spring-ease). Use it for banners, toasts, cards, and anything that should read as entering the screen."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(slide \"hi\" :from-side 'left)" :note "Slide the text 'hi' in from the left edge.")
    (:dialect "motoi" :tier "intermediate" :code "(slide 'toast :from-side 'top :distance 60 :duration 300 :easing easing/emphasized)" :note "Slide a toast down from the top with a short distance and explicit easing.")
    (:dialect "motoi" :tier "expert" :code "(define (banner-cycle banners sides step)\n  (let loop ((bs banners) (ss sides) (d 0))\n    (cond ((null? bs) 'ok)\n          (else (time/when d (lambda () (slide (car bs) :from-side (car ss))))\n                (loop (cdr bs) (cdr ss) (+ d step))))))\n(banner-cycle '(b1 b2 b3) '(left right top) 200)" :note "Cycle banners in from alternating sides at a steady rhythm.")
  )
  :caveats ("Requires the target's final position to be known; for strings, :at names the target position (default (40, 40))." ":easing accepts symbols OR procedures; unknown symbols fall back to linear (no throw).")
  :drawbacks ("One direction of motion per call; use two slides in sequence for enter+dwell+exit.")
  :usecases ("Banners and headers entering a page." "Toasts and notifications." "Card entrances from off-screen." "Panel reveals from edges.")
  :related ("bounce" "fade" "motion/move-to" "motion/on-settle" "easing/emphasized")
  :learn (:concept "Edge-relative motion: name the edge, not the coordinates." :prerequisites ("motion/move-to") :progression "Combine slide (enter) + wait + slide (exit) for banner cycles; then add fade for polished dismiss.")
  :row-2-audit ((:problem "A toast should appear at the top of the screen and slide down into view. The operator does not want to compute off-screen coordinates by hand — they just want 'in from the top.'"
                 :program "(slide 'toast :from-side 'top :distance 60 :duration 300)"
                 :explanation "One call. slide takes a symbol for the edge ('top) and a distance (60px offset), plus a duration. The runtime knows how to interpret the edge relative to the toast's target position — the operator does not touch coordinates. The audit is one call, one edge symbol."
                 :meta "Reaching for motion/move-to would require computing the off-screen start position for each edge — brittle when layout changes. slide is the honest answer because 'edge' is the semantic vocabulary of design.")
                (:eng "Edge naming beats coordinate math; layout changes propagate." :math "Direction vector selected by symbol." :cs "Case dispatch on symbol; O(1)."))
  :row-3-dimension ((:setup "Naming a direction rather than a coordinate."
                     :rungs ((:domain "motion" :code "(slide 'toast :from-side 'top :distance 60)")
                             (:domain "compass bearing (metaphor)" :code "(define (bearing-to-vector b)\n  (case b\n    ((north) '(0 1))\n    ((east) '(1 0))\n    ((south) '(0 -1))\n    ((west) '(-1 0))))\n(bearing-to-vector 'north)")
                             (:domain "unit vector selection" :code "(define (edge-vector edge)\n  (case edge\n    ((top) '(0 -1))\n    ((bottom) '(0 1))\n    ((left) '(-1 0))\n    ((right) '(1 0))))\n(edge-vector 'top)"))
                     :explanation "In motion, slide picks a direction from a symbol. In compass metaphor, 'north' picks a bearing vector — same shape. In the math rung, edge symbols map to unit vectors. All three encode direction as name."
                     :meta "The shape transfers because 'direction as a named symbol' is a design vocabulary; the substrate does not matter.")
                    (:eng "One primitive covers UI, navigation, and math." :math "Enum → unit vector; total function." :cs "Case dispatch; O(1)."))
  :row-4-proof ((:claim "For each edge symbol s, slide's start position lies strictly on that edge (i.e., outside the visible viewport in the s direction). This is the edge-relative-start invariant."
                 :program "(define (edge-position side base-x base-y distance)\n  (case side\n    ((top) (list base-x (- base-y distance)))\n    ((bottom) (list base-x (+ base-y distance)))\n    ((left) (list (- base-x distance) base-y))\n    ((right) (list (+ base-x distance) base-y))))\n(edge-position 'top 100 50 60)"
                 :invariant "start(side, base, d).y = base.y ± d in the perpendicular direction"
                 :meta "A slide that started at the wrong edge would appear from nowhere. Falsification is any (edge, base, d) where start disagrees. CS pattern: 'edge-relative coordinate frame'. Book-of-motion ch 3 covers slide primitives.")
                (:eng "The invariant means designers can trust that 'from top' actually starts above the target." :math "Perpendicular displacement from base by d." :cs "Property test on start position."))
  :row-5-emergence ((:base "slide moves a target from an off-screen edge to a target position."
                     :composition "(define (banner-cycle banners sides step-ms)\n  (let loop ((bs banners) (ss sides) (delay 0))\n    (cond ((null? bs) 'ok)\n          (else (time/when delay (lambda () (slide (car bs) :from-side (car ss))))\n                (loop (cdr bs) (cdr ss) (+ delay step-ms))))))\n(banner-cycle '(b1 b2 b3) '(left right top) 200)"
                     :emergent "A rolling banner cycle — chaining slide with time-staggered dispatch across an edge list produces a broadcast-style banner cycle, where each banner enters from a different edge."
                     :meta "This is the same family as an ESPN scoreboard's ticker cycling in from alternating sides. Cross-reference book-of-composition ch 12. Familiar analog: TV lower-third banner rotation.")
                    (:eng "One primitive + a list of edges = a broadcast cycle." :math "Parallel application of the same shape from different starting angles." :cs "O(N) delayed slides.")))

(verb
  :name "fade"
  :library "motion"
  :kind "io"
  :signature "(fade target [:from a] [:to b] [:duration ms] [:easing e] [:at (x y)]) -> tween"
  :status "landed"
  :since "2026-07-16"
  :dialect "motoi"
  :audience "kid"
  :provenance "motoi-scheme/lib/graphics/animation.js"
  :training-eligible #t
  :confidentiality "open"
  :summary "One-liner: fade a drawable's opacity from :from to :to over :duration."
  :explanation "fade is the kid-shaped shortcut for opacity animation. The target's alpha channel moves from :from (default 1.0) to :to (default 0.0) over :duration (default 600ms). :easing accepts symbols OR curve procedures (from bezier-ease / named-ease / spring-ease); default is easing/standard. Works on entities, cards, and painted text; the tween record exposes the interpolated alpha every frame so headless tests can verify the fade. Compose with bounce or slide for polished entrances."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(fade \"welcome\")" :note "Fade the text 'welcome' with defaults (1.0 → 0.0 over 600ms).")
    (:dialect "motoi" :tier "intermediate" :code "(fade 'toast :from 1.0 :to 0.0 :duration 250 :easing easing/accelerated)" :note "Fade out a toast quickly with an accelerated easing.")
    (:dialect "motoi" :tier "expert" :code "(define (crossfade a b duration)\n  (fade a :from 1.0 :to 0.0 :duration duration)\n  (fade b :from 0.0 :to 1.0 :duration duration))\n(crossfade 'old-panel 'new-panel 400)" :note "Crossfade two panels: old fades out while new fades in, matched duration.")
  )
  :caveats ("Alpha at 0 does not remove the entity from hit-testing; use entity/hide! for that." ":easing accepts symbols OR procedures; unknown symbols fall back to linear (no throw).")
  :drawbacks ("Only the alpha channel; use motion/move-to for position, fade for opacity — compose them.")
  :usecases ("Entrance and exit polish." "Crossfades between UI states." "Dismissing toasts and notifications." "Ghost-like reveals and hides.")
  :related ("bounce" "slide" "motion/move-to" "motion/on-settle" "easing/standard")
  :learn (:concept "Opacity as motion: the alpha channel animates like position does." :prerequisites ("motion/move-to") :progression "Combine fade with slide for polished panel entrances (slide + fade-in together).")
  :row-2-audit ((:problem "A toast that's been visible for a while should fade out over 250 ms with an accelerated easing (start slow, exit fast). The operator wants opacity change without touching position."
                 :program "(fade 'toast :from 1.0 :to 0.0 :duration 250 :easing easing/accelerated)"
                 :explanation "One call. fade takes source and destination opacity, duration, and easing. The operator specifies the exact opacity trajectory — no position change. The audit trail is one call plus the four numeric parameters."
                 :meta "Reaching for motion/move-to would try to animate position when the intent is opacity — wrong verb. fade is the honest answer for 'opacity change,' orthogonal to position.")
                (:eng "Opacity is a separate concern from position; the audit is per-channel." :math "Linear interpolation of alpha shaped by the easing curve." :cs "Effect kind: sets alpha per frame; O(1)."))
  :row-3-dimension ((:setup "Interpolating a scalar channel over time."
                     :rungs ((:domain "motion" :code "(fade 'toast :from 1.0 :to 0.0 :duration 250)")
                             (:domain "audio volume envelope (metaphor)" :code "(define (fade-audio-volume v-from v-to t duration)\n  (+ v-from (* (- v-to v-from) (/ t duration))))\n(fade-audio-volume 1.0 0.0 100 250)")
                             (:domain "affine interpolation on R" :code "(define (lerp a b t) (+ a (* t (- b a))))\n(lerp 1.0 0.0 0.4)"))
                     :explanation "In motion, fade interpolates alpha. In audio, an amplitude envelope interpolates volume — same shape on a different channel. In the math rung, lerp on R is the archetype. All three are the same interpolation."
                     :meta "The shape transfers because linear interpolation over time is the same operation regardless of what's being interpolated: alpha, amplitude, or a real number.")
                    (:eng "One shape covers UI opacity, audio volume, and general linear interpolation." :math "Affine map on scalars." :cs "O(1) per frame."))
  :row-4-proof ((:claim "For any fade, the alpha at t=0 equals :from and at t=duration equals :to. This is the fade-endpoint-honesty invariant."
                 :program "(define (mock-fade-value t duration from to)\n  (+ from (* (/ t duration) (- to from))))\n(define (approx a b) (< (abs (- a b)) 0.001))\n(and (approx (mock-fade-value 0 250 1.0 0.0) 1.0)\n     (approx (mock-fade-value 250 250 1.0 0.0) 0.0))"
                 :invariant "alpha(0) = from ∧ alpha(duration) = to"
                 :meta "A fade that missed 0.0 would leave a visible ghost. Falsification is any run where end-alpha differs from :to. CS pattern: 'endpoint-interpolated scalar'. Book-of-motion ch 4 covers alpha animation.")
                (:eng "The invariant lets the operator chain fade → hide! confidently." :math "e(0)=0, e(1)=1 for the easing; linear alpha map." :cs "Boundary test."))
  :row-5-emergence ((:base "fade interpolates alpha from :from to :to over :duration."
                     :composition "(define (crossfade a b duration)\n  (fade a :from 1.0 :to 0.0 :duration duration)\n  (fade b :from 0.0 :to 1.0 :duration duration))\n(crossfade 'old-panel 'new-panel 400)"
                     :emergent "A crossfade — chaining two fades with mirrored endpoints produces a smooth handoff between two panels, which one fade cannot express."
                     :meta "This is the same family as an audio crossfade at a DJ set, or a video-editor's dissolve transition. Cross-reference book-of-composition ch 12. Familiar analog: Premiere Pro's Cross Dissolve.")
                    (:eng "Two fades = a crossfade; alignment is by shared duration." :math "Mirrored linear interpolations sum to constant total exposure." :cs "O(1) per frame per panel; two parallel operations.")))

(verb
  :name "motion/on-settle"
  :library "motion"
  :kind "io"
  :signature "(motion/on-settle target handler) -> boolean"
  :status "landed"
  :since "2026-07-16"
  :dialect "motoi"
  :audience "adult"
  :provenance "motoi-scheme/lib/graphics/animation.js"
  :training-eligible #t
  :confidentiality "open"
  :summary "Fire `handler` exactly once when `target` (tween record OR entity id) stops moving."
  :explanation "motion/on-settle registers a completion callback. When the target is a tween record (returned by motion, bounce, slide, fade, motion/move-to), the handler fires the first frame the tween's elapsed time reaches its duration. When the target is an entity id (Sym or string), the handler fires from within physics/step the first time the entity's velocity magnitude falls below the settle threshold (0.01) after having been above it. Handler receives the target as its single argument. Fires exactly once per registration — call again to re-arm."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define tw (bounce \"🎉\"))\n(motion/on-settle tw (lambda (x) (display \"landed\")))" :note "Print 'landed' when the bounce finishes.")
    (:dialect "motoi" :tier "intermediate" :code "(define ball (entity/make 'ball 100 100))\n(entity/set-velocity! ball 5 -3)\n(motion/on-settle ball (lambda (id) (fade id :from 1.0 :to 0.0)))" :note "Fade the ball out once it comes to rest.")
    (:dialect "motoi" :tier "expert" :code "(define (chain-motion . tweens)\n  (let loop ((rest tweens))\n    (if (null? (cdr rest))\n        (car rest)\n        (begin\n          (motion/on-settle (car rest) (lambda (_) (loop (cdr rest))))\n          (car rest)))))\n(chain-motion (motion/move-to 'hero 100 0 :duration 300)\n              (motion/move-to 'hero 100 100 :duration 300)\n              (motion/move-to 'hero 0 100 :duration 300))" :note "Chain three moves sequentially by waiting on each settle before starting the next.")
  )
  :caveats ("Fires exactly once per registration; call again to re-arm the callback." "The entity-form settle threshold is 0.01 velocity magnitude; tune physics/friction! to adjust when settle fires." "For a tween that has already settled at registration time, the handler fires on the next animation/tick.")
  :drawbacks ("No cancellation verb; setting a new handler replaces the previous one for the same target." "Entity-form settle fires from within physics/step; keep handler work small.")
  :usecases ("Chaining animations without a timing loop." "Play a sound the moment a projectile lands." "Cascade UI transitions where step N waits on step N-1's completion.")
  :related ("bounce" "slide" "fade" "motion/move-to" "motion" "on-collision" "physics/step")
  :learn (:concept "Callback-on-completion — a promise-like shape for motion." :prerequisites ("motion/move-to") :progression "Compose with on-collision + entity/apply-force! to build state machines whose transitions depend on when motion actually finishes.")
  :row-2-audit ((:problem "A ball is thrown and should play a landing sound the moment it stops moving. The operator needs to fire an action exactly on-settle, not before, not after."
                 :program "(define ball (entity/make 'ball 100 100))\n(entity/set-velocity! ball 5 -3)\n(motion/on-settle ball (lambda (id) (audio/play 'landing-sound)))"
                 :explanation "Line 1 makes the ball. Line 2 gives it initial velocity. Line 3 registers a one-shot callback that fires the frame the ball's velocity drops below the settle threshold. The audit trail is one registration; the callback is guaranteed to fire exactly once."
                 :meta "Reaching for polling ball velocity every frame would work but pollutes the loop. motion/on-settle is the honest answer because it fires precisely at the moment motion stops, not before, not late.")
                (:eng "One registration; exactly one callback fire." :math "Predicate: |v| < ε detected in physics/step." :cs "Event-driven; O(1) per frame in the physics loop."))
  :row-3-dimension ((:setup "Fire an action on a state-transition event."
                     :rungs ((:domain "motion" :code "(motion/on-settle 'ball (lambda (id) (display 'landed)))")
                             (:domain "PostgreSQL LISTEN/NOTIFY (metaphor)" :code "(define (listen-notify channel handler)\n  (list 'listen channel handler))\n(listen-notify 'ball-settled (lambda () (display 'landed)))")
                             (:domain "predicate-triggered event" :code "(define (on-condition-once pred handler)\n  (list 'guard pred 'once handler))\n(on-condition-once (lambda () (< (velocity 'ball) 0.01))\n                   (lambda () (display 'landed)))"))
                     :explanation "In motion, on-settle triggers on a velocity threshold. In LISTEN/NOTIFY, a database channel notifies subscribers on an event — same one-shot subscribe/fire shape. In the math rung, a predicate-triggered event abstracts it. All three fire exactly once when a condition becomes true."
                     :meta "The shape transfers because 'wait for condition, fire once' is the archetypal event-driven pattern; the substrate does not change the shape.")
                    (:eng "One shape covers UI motion, database triggers, and general reactive programming." :math "Threshold-crossing detection; monotone predicate." :cs "One handler registration; single-shot firing."))
  :row-4-proof ((:claim "For each on-settle registration, the handler fires exactly once, not zero times and not twice. This is the exactly-once-firing invariant."
                 :program "(define counter 0)\n(define (mock-settle-once handler)\n  (set! counter (+ counter 1))\n  (handler 'dummy))\n(mock-settle-once (lambda (_) (set! counter (+ counter 100))))\ncounter"
                 :invariant "count-of-fires(registration) = 1"
                 :meta "A double-fire would play the sound twice; a no-fire would leave the game silent. Falsification is any registration that fired 0 or >1 times. CS pattern: 'exactly-once event delivery'. Book-of-composition ch 15 covers event semantics.")
                (:eng "Exactly-once is critical: game logic assumes one landing sound." :math "Counter equals 1 after firing." :cs "The registration is consumed on fire."))
  :row-5-emergence ((:base "motion/on-settle fires a handler once when the target stops moving."
                     :composition "(define (chain-motion tw1 tw2 tw3)\n  (motion/on-settle tw1 (lambda (_)\n    (motion/on-settle tw2 (lambda (_)\n      (motion/on-settle tw3 (lambda (_) (display 'chain-complete))))))))\n(chain-motion (motion/move-to 'hero 100 0 :duration 300)\n              (motion/move-to 'hero 100 100 :duration 300)\n              (motion/move-to 'hero 0 100 :duration 300))"
                     :emergent "A sequential-motion state machine — chaining on-settle across three moves produces a sequence that pauses each stage until the previous completes, which no single move can express."
                     :meta "This is the same family as JavaScript promise chaining, or a coroutine's await. Cross-reference book-of-composition ch 15 (sequencing). Familiar analog: async/await in JavaScript.")
                    (:eng "on-settle + move-to = sequential motion; add a fourth is one nesting." :math "Composition of event triggers; each event enables the next." :cs "O(1) per settle; the chain is bounded by depth of nesting.")))

