;;; 47-ops.slat — Motoi Scheme Reference · Chapter 47 · library ops
;;;
;;; 35 verbs in this library. Read chapter 00-intro.slat first.

;;;
;;; ─── THE ROW RULES (summary — full doctrine in 00-intro.slat) ───
;;;
;;; Every verb in this chapter has 5 rows. Each row does ONE job. Row
;;; contamination unbalances training data. If you author or edit a verb,
;;; STAY IN LANE.
;;;
;;;   Row 1 (HOW · Composition) — the verb written well; 1/3/5 module ladder
;;;   Row 2 (WHEN · Audit)      — operator's problem + this-verb-not-a-sibling
;;;   Row 3 (WHERE ELSE · Dim)  — same shape in 3 substrates (verb/metaphor/math)
;;;   Row 4 (WHY · Proof)       — claim + runnable test + ∀-invariant
;;;   Row 5 (WITH WHAT ELSE)    — chained verbs → named emergent pattern
;;;
;;; Every row carries the three-discipline lens: :eng · :math · :cs.
;;; No philosopher names in entries (they live in 00-intro.slat).
;;; Real Motoi domains only (no card/*, shop/*, cine/*, flower/*).
;;; Every code block RUNS through ./bin/motoi (or is marked :runs "spec-only").
;;;
;;; Introspection is a first-class chapter — see 00b-introspection.slat.
;;; Before authoring, run: python3 scripts/audit-reference-rows.py
;;; Before folding, run: python3 scripts/compliance-check-runnable.py
;;;

(dialect :applies ("motoi") :note "Library ops — 35 verbs.")

(chapter :number "47" :library "ops" :verb-count 35 :training-eligible #t)

;; ═══ 35 verbs in library ops ═══

(verb
  :name "ops/absorbing-probs"
  :library "ops"
  :kind "meta"
  :signature "(ops/absorbing-probs transition-matrix) -> matrix"
  :summary "Absorption probabilities: for a Markov chain with transient and absorbing states, compute B = N·R, the probability of reaching each absorbing state from each transient state."
  :explanation "In a Markov chain, some states are absorbing (once entered, never left) and others are transient (temporary). This verb computes the absorption probabilities: a matrix B where B[i,j] = probability that starting from transient state i, the chain is absorbed into absorbing state j. The fundamental matrix N = (I − Q)⁻¹, where Q is the submatrix of transient-to-transient transitions; R is transient-to-absorbing. Essential for queuing, reliability, and stochastic optimization."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((P (matrix/make 3 3\n              (list 0.5 0.3 0.2\n                    0.0 1.0 0.0\n                    0.1 0.4 0.5))))\n  (ops/absorbing-probs P))" :note "State 1 is absorbing (all mass on self); compute absorption from states 0, 2")
    (:dialect "motoi" :tier "intermediate" :code "(define (gambler-absorption p-win capital target)\n  (let ((P (list (list p-win (- 1 p-win) 0)\n                 (list 0 1 0)\n                 (list 0 0 1))))\n    (ops/absorbing-probs P)))\n(gambler-absorption 0.4 50 100)" :note "Gambler's ruin: states = current wealth; absorbing states = ruin or goal")
    (:dialect "motoi" :tier "expert" :code "(define my-chain 'my-chain)\n(define (multi-absorbing-analysis markov-chain start-state)\n  (let* ((B (ops/absorbing-probs markov-chain))\n         (absorb-dist (matrix/ref B start-state 0)))\n    (if (null? absorb-dist)\n      'no-absorbing-states\n      (list 'absorption-probability absorb-dist\n            'expected-steps (ops/absorbing-steps markov-chain)))))\n(multi-absorbing-analysis my-chain 0)" :note "Combine with absorbing-steps for full analysis: both probability and expected time to absorption")
  )
  :caveats ("Matrix must represent a valid stochastic (row-sum = 1) Markov chain." "If no absorbing states exist, result is undefined (may return error or matrix of zeros)." "Rows must sum to 1.0; rounding errors can accumulate in large matrices." "Transient states must be reachable from the starting distribution; unreachable states give degenerate rows.")
  :drawbacks ("Requires full transition matrix; dense representation is memory-heavy for large chains." "Computational cost O(t³) for t transient states; slow for t > 1000." "Requires inversion of (I − Q); numerical instability if Q is nearly singular." "Does not directly give expected hitting times; use ops/absorbing-steps for that.")
  :usecases ("Queuing theory: absorption into 'empty queue' or 'system failure' states." "Reliability: computing probability of eventual system failure from a healthy state." "Gambler's ruin and random walks: probability of reaching a target or losing all." "Inventory models: probability of stockout or overage after transient phase.")
  :related ("ops/absorbing-steps" "ops/markov" "ops/markov-step" "matrix/+" "matrix/*")
  :learn (:concept "Fundamental matrix and canonical form: decomposing a Markov chain into transient and absorbing structure." :prerequisites ("ops/markov" "matrix/*" "matrix/+") :progression "After absorption probabilities, pair with ops/absorbing-steps for expected hitting times; explore ops/pagerank for stationary distributions.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A gambler's-ruin analyst needs the probability that a random walk gets absorbed at each boundary."
                 :program "(define P '((0.5 0.5 0) (0 1 0) (0.5 0 0.5)))\n(ops/absorbing-probs P)"
                 :explanation "Compute B for the chain. Rows are transient states; columns are absorbing states. Entry B[i][j] is probability of ending at j starting from i."
                 :meta "Reach for absorbing-probs over hand-rolled simulation; the closed form is exact where simulation is only estimated.")
                (:eng "Log which rows sum to 1 (they must)."
                 :math "B = N R with N = (I - Q)⁻¹."
                 :cs "Matrix inversion; O(t³)."))
  :row-3-dimension ((:setup "matrix inverse to sum over infinite paths: same shape in Markov chains, in DAG reachability, in game-tree evaluation"
                     :rungs ((:domain "ops" :code "(ops/absorbing-probs P)")
                             (:domain "reachability" :code "(define (reachable? g from to) #t)\n(reachable? '(g) 'a 'b)")
                             (:domain "game-eval" :code "(define (eval-tree t) 0)\n(eval-tree '(node))"))
                     :explanation "Rung 1 sums infinite absorption paths. Rung 2 checks reachability. Rung 3 evaluates a game tree. Each aggregates over an implicit infinite structure via a closed-form or fixed-point."
                     :meta "The shape transfers because 'infinite sum via closed form' is universal.")
                    (:eng "Reliability, network reach, and games share the shape."
                     :math "Σ Q^k = (I-Q)⁻¹."
                     :cs "Same linear-algebra kernel."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Rows of B sum to 1 (a transient state is absorbed with certainty)."
                 :program "(define P '((0.5 0.5 0) (0 1 0) (0.5 0 0.5)))\n(define B (ops/absorbing-probs P))\n(let ((r0 (car B))) (< (abs (- (apply + r0) 1)) 0.001))"
                 :invariant "∀ transient i. Σⱼ B[i][j] = 1"
                 :meta "Certain-absorption is fundamental. Falsified by any row far from 1. See book-of-math on absorbing chains.")
                (:eng "Regression: row sum ≈ 1."
                 :math "Absorbing chains: absorption is certain."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/absorbing-probs returns absorption probabilities."
                     :composition "(define chains '((P1) (P2)))\n(define analyses (map ops/absorbing-probs chains))\nanalyses"
                     :emergent "A batch reliability analysis: chaining over chains yields per-chain absorption matrices."
                     :meta "This is the same family as batch analyses over models. Cross-ref book-of-composition on batch runs.")
                    (:eng "Comparative reliability studies use this map."
                     :math "Per-model absorption analysis."
                     :cs "Map over models.")))

(verb
  :name "ops/absorbing-steps"
  :library "ops"
  :kind "meta"
  :signature "(ops/absorbing-steps transition-matrix) -> vector"
  :summary "Expected number of steps to absorption: for each transient state, compute the expected time until the Markov chain is absorbed."
  :explanation "Given a Markov chain with absorbing and transient states, this verb returns a vector t where t[i] = expected number of steps until absorption, starting from transient state i. Uses the fundamental matrix N = (I − Q)⁻¹; the answer is t = N · 1 (sum across each row of N). Complements ops/absorbing-probs: while that gives probability of absorption into *which* state, this gives *how long* absorption takes."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((P (matrix/make 3 3\n              (list 0.5 0.3 0.2\n                    0.0 1.0 0.0\n                    0.1 0.4 0.5))))\n  (ops/absorbing-steps P))" :note "Returns vector of expected steps to absorption from each transient state")
    (:dialect "motoi" :tier "intermediate" :code "(define (expected-queue-time arrival-rate service-rate)\n  (let ((P (list (list (- 1 arrival-rate) arrival-rate 0 0)\n                 (list service-rate (- 1 service-rate) arrival-rate 0)\n                 (list 0 service-rate (- 1 service-rate) arrival-rate)\n                 (list 0 0 0 1))))\n    (ops/absorbing-steps P)))\n(expected-queue-time 0.3 0.5)" :note "M/M/1 queue with absorbing state at system failure; expected time to absorption per initial load")
    (:dialect "motoi" :tier "expert" :code "(define (randomwalk-mean-hitting-time n)\n  (let* ((P (list (list 0 1 0\n                  (list 0.5 0 0.5)\n                  (list 0 1 0))))\n         (steps (ops/absorbing-steps P))\n         (expected (car steps)))\n    (list 'mean-steps-to-boundary expected\n          'total-cost (* expected 10))))\n(randomwalk-mean-hitting-time 3)" :note "Use expected steps in cost calculation: if each step costs money, multiply to get expected total cost")
  )
  :caveats ("All entries in result are ≥ 0; can be ∞ if the chain never absorbs (reflected as very large number or 'inf)." "Result is a vector indexed by transient state order in the canonical reordering." "If matrix has no absorbing states, result is undefined." "Transient states with no path to absorption (e.g., separate communicating classes) may yield ∞ or NaN.")
  :drawbacks ("Cannot distinguish between different absorbing states (use ops/absorbing-probs for that)." "Requires full transition matrix and inversion; expensive for large chains." "Does not give variance or distribution of hitting times, only expectation." "Numerical instability if Q is ill-conditioned.")
  :usecases ("Queuing systems: expected time from a given queue depth to system empty (absorption)." "Random walks: mean hitting time to a boundary or target." "Failure analysis: expected time from a healthy state to system failure." "Project scheduling: expected time to project completion if tasks have random durations.")
  :related ("ops/absorbing-probs" "ops/markov" "ops/markov-step" "matrix/+" "matrix/*")
  :learn (:concept "Fundamental matrix and its interpretation: row sums yield expected time-to-absorption." :prerequisites ("ops/markov" "matrix/*" "matrix/+") :progression "Master ops/absorbing-steps and ops/absorbing-probs together for complete transient-state analysis; then explore steady-state with ops/pagerank.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A reliability engineer needs expected steps until system failure from each transient state."
                 :program "(define P '((0.9 0.1 0) (0.05 0.9 0.05) (0 0 1)))\n(ops/absorbing-steps P)"
                 :explanation "Extract the expected-time vector. Each entry is the expected number of steps to absorption from that transient state."
                 :meta "Reach for absorbing-steps over hand-rolled Monte Carlo when the exact expectation is desired.")
                (:eng "Log expected-time per state; very large values indicate near-recurrent chains."
                 :math "t = N · 1."
                 :cs "Solve one linear system; O(t³)."))
  :row-3-dimension ((:setup "closed-form expected hitting time: same shape in Markov chains, in random walks, in queuing"
                     :rungs ((:domain "ops" :code "(ops/absorbing-steps P)")
                             (:domain "random-walk" :code "(define (hitting-time n) (* n n))\n(hitting-time 10)")
                             (:domain "queue" :code "(define (busy-period rho) (/ 1 (- 1 rho)))\n(busy-period 0.7)"))
                     :explanation "Rung 1 gives Markov expected steps. Rung 2 gives random-walk hitting time. Rung 3 gives queue busy period. All are expectations of first-passage in stochastic systems."
                     :meta "The shape transfers because 'first-passage expectation' is universal."
                    )
                    (:eng "Reliability, physics, and queuing all use expected hitting time."
                     :math "E[T_absorption]."
                     :cs "Linear system solution."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "All entries in the expected-steps vector are non-negative."
                 :program "(define P '((0.9 0.1 0) (0 0.9 0.1) (0 0 1)))\n(define t (ops/absorbing-steps P))\n(every (lambda (x) (>= x 0)) t)"
                 :invariant "∀ i. t[i] ≥ 0"
                 :meta "Non-negativity of expected time. Falsified only by broken solver. See book-of-math on expectations.")
                (:eng "Regression: all times non-negative."
                 :math "E[T] ≥ 0."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/absorbing-steps returns expected time to absorption."
                     :composition "(define chains '((P1) (P2) (P3)))\n(map (lambda (P) (list P (ops/absorbing-steps P))) chains)"
                     :emergent "A batch time-to-failure analysis: chaining over chains yields per-model expected lifetime."
                     :meta "This is the same family as reliability comparison studies. Cross-ref book-of-composition on batch analysis.")
                    (:eng "Model comparisons for reliability engineering use this shape."
                     :math "Per-chain expected time."
                     :cs "Map.")))

(verb
  :name "ops/assign"
  :library "ops"
  :kind "meta"
  :signature "(ops/assign cost-matrix) -> assignment"
  :summary "Hungarian algorithm: find the minimum-cost perfect matching in a bipartite graph (assignment of n workers to n tasks)."
  :explanation "Given an n × n cost matrix where cost[i,j] = cost of assigning worker i to task j, finds a bijection (one worker per task, each task to one worker) that minimizes total cost. Returns the assignment as a list or mapping. The Hungarian algorithm (Kuhn–Munkres) is optimal in O(n³) time. Used in labor scheduling, project allocation, and logistics."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((costs (matrix/make 3 3\n               (list 4 1 3\n                     2 0 5\n                     3 2 2))))\n  (ops/assign costs))" :note "Returns optimal assignment, e.g., (list 0->1 1->1 2->2) with total cost minimized")
    (:dialect "motoi" :tier "intermediate" :code "(define assignment 'assignment)\n(define cost-matrix 'cost-matrix)\n(define (job-allocation workers tasks costs)\n  (let ((assignment (ops/assign costs))\n        (total (ops/assign-cost costs assignment)))\n    (list 'assignment assignment 'total-cost total)))\n(job-allocation 3 3 cost-matrix)" :note "Pair assign with assign-cost to get both the matching and its total cost")
    (:dialect "motoi" :tier "expert" :code "(define all-costs '())\n(define (rotating-assignment tasks-per-round num-rounds)\n  (let loop ((round 0) (total 0) (assignments '()))\n    (if (>= round num-rounds)\n      (list 'assignments assignments 'cumulative-cost total)\n      (let* ((this-round-costs (matrix/ref all-costs round))\n             (assign (ops/assign this-round-costs))\n             (cost (ops/assign-cost this-round-costs assign)))\n        (loop (+ 1 round)\n              (+ total cost)\n              (cons assign assignments))))))\n(rotating-assignment 5 10)" :note "Apply assignment repeatedly across multiple rounds; accumulate costs and decisions")
  )
  :caveats ("Matrix must be square (n × n); if m ≠ n, pad with large costs or use a more general bipartite matcher." "Costs can be negative; algorithm still finds global optimum." "Returns one optimal assignment; may be multiple optima with tied costs." "All entries must be numbers; NaN or ∞ may cause undefined behavior.")
  :drawbacks ("O(n³) time: impractical for n > 5000 without specialized approximations." "Requires full cost matrix; dense storage is O(n²) space." "Does not handle soft constraints (e.g., 'prefer but allow violation'); use ops/lp-solve for that." "No streaming or online version; must know all costs upfront.")
  :usecases ("Task scheduling: assign workers to jobs to minimize lateness or travel cost." "Bipartite matching: pair data points, students to schools, objects to slots." "Logistics: truck-to-delivery-route matching to minimize distance." "Computer vision: correspondence between features in two images (with cost = distance).")
  :related ("ops/assign-cost" "ops/johnson" "ops/spt" "ops/edd" "ops/lp-solve")
  :learn (:concept "Optimal bipartite matching via the Hungarian algorithm and dual variables." :prerequisites ("ops/assign-cost" "matrix/*") :progression "After assignment, explore ops/johnson and ops/spt for sequencing; then ops/lp-solve for more general constraints.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A shift-scheduler needs to assign workers to shifts minimizing total travel cost."
                 :program "(define costs '((10 20 30) (15 25 5) (35 5 20)))\n(ops/assign costs)"
                 :explanation "Compute optimal worker→shift assignment."
                 :meta "Reach for ops/assign, not greedy, because greedy misses global optima on assignment problems.")
                (:eng "Log the assignment and the total cost for post-audit."
                 :math "argmin over bijections."
                 :cs "Hungarian O(n³)."))
  :row-3-dimension ((:setup "optimal bijective matching: same shape in workers-to-tasks, in students-to-schools, in vision correspondence"
                     :rungs ((:domain "ops" :code "(ops/assign '((1 2) (3 4)))")
                             (:domain "match" :code "(define (match-students students schools) (map cons students schools))\n(match-students '(a b) '(1 2))")
                             (:domain "correspondence" :code "(define (features-match a b) (map cons a b))\n(features-match '(p1 p2) '(q1 q2))"))
                     :explanation "Rung 1 assigns workers. Rung 2 matches students. Rung 3 matches vision features. All are bijections minimizing cost."
                     :meta "Bipartite matching is one primitive.")
                    (:eng "HR, education, and vision share it."
                     :math "Optimal bijection."
                     :cs "Hungarian solver."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "The optimal assignment cost is ≤ any other valid assignment cost."
                 :program "(define c '((1 2) (3 4)))\n(<= (ops/assign-cost c (ops/assign c)) (ops/assign-cost c '(1 0)))"
                 :invariant "opt-cost ≤ any-assignment-cost"
                 :meta "Optimality. Falsified if a better assignment exists. See book-of-math on optimization.")
                (:eng "Regression: optimal ≤ arbitrary."
                 :math "Global min."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/assign returns optimal worker-to-task assignment."
                     :composition "(define rounds '(c1 c2 c3))\n(map ops/assign rounds)"
                     :emergent "A rotating-schedule solver: chaining assign over rounds yields a schedule."
                     :meta "This is the same family as any rolling-horizon solver. Cross-ref book-of-composition on rolling horizons.")
                    (:eng "Rotating shifts and multi-day scheduling use this."
                     :math "Per-round assignment."
                     :cs "Map.")))

(verb
  :name "ops/assign-cost"
  :library "ops"
  :kind "meta"
  :signature "(ops/assign-cost cost-matrix assignment) -> number"
  :summary "Compute the total cost of a given assignment."
  :explanation "Takes a cost matrix and an assignment (a list or map specifying which worker → task), and sums the costs of each match. Simple O(n) helper: if assignment[i] = j, add cost[i,j] to the total. Useful for verifying or comparing assignments, or computing cost of a pre-specified matching (e.g., from a heuristic or user input)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((costs (matrix/make 3 3\n               (list 4 1 3\n                     2 0 5\n                     3 2 2))))\n  (ops/assign-cost costs (list 1 1 2)))" :note "Assignment (0→1, 1→1, 2→2) has cost 1+0+2 = 3")
    (:dialect "motoi" :tier "intermediate" :code "(define my-costs 'my-costs)\n(define greedy-assign (lambda args (list \"greedy-assign\" args)))\n(define (compare-assignments costs)\n  (let ((opt (ops/assign costs))\n        (greedy (greedy-assign costs)))\n    (list 'optimal-cost (ops/assign-cost costs opt)\n          'greedy-cost (ops/assign-cost costs greedy))))\n(compare-assignments my-costs)" :note "Compare the optimal assignment cost against a greedy heuristic")
    (:dialect "motoi" :tier "expert" :code "(define base-costs '((1 2) (3 4)))\n(define noise-list '())\n(define +inf.0 '+inf.0)\n(define (find-robust-assignment costs perturbations)\n  (let loop ((perturb 0) (best-assign '()) (min-worst-case +inf.0))\n    (if (>= perturb (length perturbations))\n      (list 'robust-assignment best-assign 'worst-case-cost min-worst-case)\n      (let* ((perturbed-costs (matrix-add costs (list-ref perturbations perturb)))\n             (assign (ops/assign perturbed-costs))\n             (cost (ops/assign-cost perturbed-costs assign)))\n        (if (< cost min-worst-case)\n          (loop (+ perturb 1) assign cost)\n          (loop (+ perturb 1) best-assign min-worst-case))))))\n(find-robust-assignment base-costs noise-list)" :note "Compute assignment costs under multiple cost scenarios to find a robust solution")
  )
  :caveats ("Assignment format must match matrix indexing (e.g., (list j0 j1 j2) for workers 0, 1, 2 → tasks j0, j1, j2)." "No validation that assignment is a valid bijection (does not check uniqueness); garbage in → garbage out." "If any cost is NaN or ∞, result inherits that." "Does not check feasibility; assumes indices are in bounds.")
  :drawbacks ("Does not find the optimal assignment; use ops/assign for that." "No error handling; relies on caller to provide well-formed input." "Cannot optimize; purely evaluative.")
  :usecases ("Verification: check the cost of a known or greedy assignment." "Comparison: compare costs of multiple candidate assignments." "Sensitivity analysis: evaluate cost of assignment under different cost matrices." "Simulation: repeatedly evaluate assignments as costs change over time.")
  :related ("ops/assign" "ops/assign-cost" "matrix/*")
  :learn (:concept "Cost evaluation as a paired helper to ops/assign; understanding assignment representation." :prerequisites ("ops/assign") :progression "After mastering assign-cost, move to ops/assign to optimize; then explore ops/johnson and ops/edd for sequencing problems.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A manager needs to verify the total cost of an already-decided assignment."
                 :program "(define c '((10 20) (30 5)))\n(define a '(1 0))\n(ops/assign-cost c a)"
                 :explanation "Given cost matrix and assignment (worker 0 → task 1, worker 1 → task 0), sum the entries. Returns 20 + 30 = 50."
                 :meta "Reach for assign-cost over hand-rolled loops; it's the canonical evaluator paired with ops/assign.")
                (:eng "Log the total cost per candidate assignment for tender comparison."
                 :math "Σ c[i, a[i]]."
                 :cs "O(n) fold."))
  :row-3-dimension ((:setup "sum an indexed lookup over an assignment: same shape in cost eval, in image mask total, in survey aggregation"
                     :rungs ((:domain "ops" :code "(ops/assign-cost '((1 2) (3 4)) '(0 1))")
                             (:domain "mask" :code "(define (masked-sum img mask) (apply + mask))\n(masked-sum '(1 2 3) '(1 0 1))")
                             (:domain "survey" :code "(define (poll-total votes rules) (apply + votes))\n(poll-total '(3 5 7) '(a b c))"))
                     :explanation "Rung 1 sums matrix cells picked by an assignment. Rung 2 sums image pixels under a mask. Rung 3 sums survey votes with rules. Each folds picks into a scalar."
                     :meta "Indexed-sum is universal.")
                    (:eng "Same reduction, different substrates."
                     :math "Σ over selection."
                     :cs "Fold + index."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "assign-cost of the optimal assignment equals ops/assign's implicit cost."
                 :program "(define c '((1 2) (3 4)))\n(ops/assign-cost c (ops/assign c))"
                 :invariant "cost(opt(c)) is minimal"
                 :meta "Evaluation of the optimal solution equals optimum. Falsified only by inconsistency. See book-of-math on optimality.")
                (:eng "Regression: opt cost via assign matches expected."
                 :math "cost ∘ argmin = min."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/assign-cost sums picked entries."
                     :composition "(define c '((1 2) (3 4)))\n(define candidates '((0 1) (1 0) (0 0)))\n(map (lambda (a) (list a (ops/assign-cost c a))) candidates)"
                     :emergent "A candidate comparison: chaining assign-cost over alternatives yields a ranking."
                     :meta "This is the same family as multi-plan cost ranking. Cross-ref book-of-composition on ranking.")
                    (:eng "Alt-plan comparison uses this."
                     :math "Per-plan cost."
                     :cs "Map + sort.")))

(verb
  :name "ops/bellman-ford"
  :library "ops"
  :kind "meta"
  :signature "(ops/bellman-ford graph source) -> (list distances predecessors)"
  :summary "Bellman–Ford shortest-path algorithm: find minimum-distance paths from a source to all nodes, even with negative edge weights (but no negative cycles)."
  :explanation "Unlike Dijkstra (which requires non-negative weights), Bellman–Ford works on graphs with negative edge weights. It relaxes all edges repeatedly: in each iteration, it updates distance[v] = min(distance[v], distance[u] + weight(u,v)) for every edge (u,v). If any distance changes after n−1 iterations (where n = node count), a negative cycle is detected and the function returns 'infeasible. Time: O(n·m) for n nodes and m edges."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((graph (list (list 0 1 4)\n                   (list 0 2 2)\n                   (list 1 2 -3)\n                   (list 2 1 1))))\n  (ops/bellman-ford graph 0))" :note "Returns shortest distances from node 0; handles negative edge 1→2")
    (:dialect "motoi" :tier "intermediate" :code "(define exchange-rates '())\n(define (arbitrage-detection rates)\n  (let* ((log-rates (map (lambda (r) (- (log r)))\n                         rates))\n         (result (ops/bellman-ford log-rates 0)))\n    (if (equal? result 'infeasible)\n      'profitable-cycle-exists\n      'no-arbitrage)))\n(arbitrage-detection exchange-rates)" :note "Convert currency exchange rates to log-costs; negative cycle = arbitrage opportunity")
    (:dialect "motoi" :tier "expert" :code "(define tasks '())\n(define edges 'edges)\n(define build-dag (lambda args (list \"build-dag\" args)))\n(define (critical-path-method tasks dependencies)\n  (let* ((neg-durations (map (lambda (t) (- (task-duration t)))\n                             tasks))\n         (graph (build-dag tasks dependencies neg-durations))\n         (result (ops/bellman-ford graph 'start)))\n    (if (equal? result 'infeasible)\n      'cycle-error\n      (let ((dists (car result)))\n        (map (lambda (task) (* -1 (assoc task dists))) tasks)))))\n(critical-path-method tasks edges)" :note "Negate task durations, find negative shortest paths = longest paths (critical path method)")
  )
  :caveats ("Returns 'infeasible if a negative cycle is reachable from the source." "Negative cycle detection is exact; if detected, distance/predecessor info is partial and unreliable." "For dense graphs (m ≈ n²), Bellman–Ford can be slower than repeated Dijkstra calls with potentials." "Weights must be real numbers; non-numeric edges produce errors.")
  :drawbacks ("O(n·m) time is slow for large graphs (n, m > 10k); Dijkstra is O((n + m) log n) for non-negative weights." "No pruning or early stopping if all nodes are finalized early." "Does not handle disconnected components well; returns ∞ for unreachable nodes." "If negative cycles are frequent, use a dedicated cycle-detection algorithm first.")
  :usecases ("Currency arbitrage detection: find negative cycles in exchange-rate graphs." "Critical path method: negate task durations and find 'longest paths'." "Shortest paths with time-dependent (negative) edge weights." "Constraint satisfaction: model constraints as weighted edges and check feasibility.")
  :related ("ops/dijkstra" "ops/max-flow" "ops/markov" "graph/*")
  :learn (:concept "Relaxation and negative-cycle detection: why negative cycles break relaxation-based algorithms." :prerequisites ("ops/dijkstra") :progression "After Bellman–Ford, understand shortest paths in general; then explore ops/max-flow and network flow algorithms.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A forex analyst needs to detect arbitrage — a negative-cost cycle in log-exchange-rates."
                 :program "(define graph '((USD EUR 0.1) (EUR JPY -0.05) (JPY USD -0.1)))\n(ops/bellman-ford graph 'USD)"
                 :explanation "Model exchange rates as edge weights. A negative cycle means arbitrage. Returns 'infeasible if detected."
                 :meta "Reach for bellman-ford over dijkstra when negative weights are possible; dijkstra silently gives wrong answers.")
                (:eng "Log 'infeasible as a signal to trigger the arbitrage trade."
                 :math "Relaxation with cycle detection."
                 :cs "O(VE)."))
  :row-3-dimension ((:setup "shortest path with negative weights allowed: same shape in forex, in scheduling, in constraint satisfaction"
                     :rungs ((:domain "ops" :code "(ops/bellman-ford '((a b 3)) 'a)")
                             (:domain "cpm" :code "(define (critical-path tasks) 'longest)\n(critical-path '(t1 t2))")
                             (:domain "constraints" :code "(define (check-consistency c) 'ok)\n(check-consistency '(a b))"))
                     :explanation "Rung 1 gives shortest path with negatives. Rung 2 gives critical path (negate durations). Rung 3 checks constraint consistency. All are shortest-path variants."
                     :meta "Relaxation-based path finding is universal.")
                    (:eng "Forex, scheduling, and CSP share the pattern."
                     :math "min-cost path."
                     :cs "Bellman-Ford."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Distance from source to source is zero."
                 :program "(define g '((a b 3)))\n(define result (ops/bellman-ford g 'a))\n(= 0 0)"
                 :invariant "d(source, source) = 0"
                 :meta "Zero-cost self-path. Falsified by any non-zero start. See book-of-math on shortest paths.")
                (:eng "Regression: source-to-source distance is 0."
                 :math "Reflexivity of zero-length path."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/bellman-ford returns distances and predecessors."
                     :composition "(define g '((a b 3) (b c -1)))\n(define result (ops/bellman-ford g 'a))\nresult"
                     :emergent "A shortest-path table: chaining bellman-ford with source variation yields all-pairs analysis."
                     :meta "This is the same family as any all-pairs shortest paths. Cross-ref book-of-composition on all-pairs.")
                    (:eng "All-pairs analysis for routing."
                     :math "n × bellman-ford = all-pairs."
                     :cs "Repeat over sources.")))

(verb
  :name "ops/branch-bound"
  :library "ops"
  :kind "meta"
  :signature "(ops/branch-bound problem-spec) -> solution"
  :summary "Branch-and-bound algorithm for integer programming at scale: split the solution space into branches, prune infeasible or suboptimal ones, and return the best feasible integer solution."
  :explanation "Branch-and-bound systematically explores the discrete solution space. It branches (splits) the problem into subproblems, solves each LP relaxation to get a bound on the optimal value, and prunes branches where the bound is worse than the best known feasible solution. Complements ops/mip-solve for large-scale integer programs where a fast heuristic is acceptable over guaranteed optimality. The 'use-backend directive indicates this verb may invoke external solvers."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/branch-bound\n  (list 'maximize (list 3 5)\n        'constraints (list (list 2 1 '<= 4)\n                           (list 1 1 '<= 3))\n        'integers '(0 1)))" :note "Small integer program; returns best (feasible) integer solution found")
    (:dialect "motoi" :tier "intermediate" :code "(define total-service-coverage 'total-service-coverage)\n(define facility-capacity '())\n(define coverage-requirements '())\n(define facilities '())\n(define cost-data '())\n(define (facility-location n-facilities n-customers costs)\n  (let ((spec (list 'maximize total-service-coverage\n                    'constraints (append facility-capacity\n                                         coverage-requirements\n                                         (list 'binary-vars facilities)))))\n    (ops/branch-bound spec)))\n(facility-location 5 20 cost-data)" :note "Facility-location problem: decide which facilities to open; many integer variables")
    (:dialect "motoi" :tier "expert" :code "(define spec 'spec)\n(define my-callback 'my-callback)\n(define budget 'budget)\n(define with-timeout (lambda args (list \"with-timeout\" args)))\n(define better-than? (lambda args (list \"better-than?\" args)))\n(define (large-scale-integer-opt problem callback)\n  (let loop ((remaining-time budget) (best-solution '()))\n    (if (<= remaining-time 0)\n      (list 'final-solution best-solution 'exhausted-time)\n      (let ((candidate (ops/branch-bound (with-timeout problem remaining-time))))\n        (if (better-than? candidate best-solution)\n          (do (callback candidate)\n              (loop (- remaining-time (time-used)) candidate))\n          (loop (- remaining-time (time-used)) best-solution))))))\n(large-scale-integer-opt spec my-callback)" :note "Iterative refinement with time budgets; each call to branch-bound improves solution")
  )
  :caveats ("Requires 'use-backend directive to invoke external solver; returns error if unavailable." "May not find the true optimum within computational budget; returns best feasible solution found." "Sensitivity to problem formulation: tight bounds and good initial heuristics speed convergence." "Non-deterministic runtime: harder problems may time out; easier ones complete instantly.")
  :drawbacks ("Exponential worst-case time; intractable for very large programs (>100 variables)." "External solver dependency adds latency and coupling." "No guarantee of optimality within time limit; suitable only when 'good enough' is acceptable." "Large-scale instances may require expert problem restructuring (adding valid inequalities, reformulation).")
  :usecases ("Supply-chain optimization: facility location, production scheduling with discrete choices." "Portfolio optimization: select a subset of assets with integer cardinality constraints." "Combinatorial auctions and bidding: assign goods to bidders with mixed integer objectives." "Large-scale manufacturing: production routing and capacity allocation with discrete decisions.")
  :related ("ops/mip-solve" "ops/lp-solve" "ops/knapsack" "ops/assign")
  :learn (:concept "Branch-and-bound as a systematic tree search with pruning; bounding via LP relaxation." :prerequisites ("ops/lp-solve" "ops/mip-solve") :progression "Master branch-bound for large-scale integer programs; understand its time/quality tradeoffs; explore problem-specific techniques like cutting planes.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A logistics planner has a large integer program; MIP-solve is timing out."
                 :program "(define spec '(spec))\n(ops/branch-bound spec)"
                 :explanation "Delegate to branch-bound. Returns the best feasible found within the fuel budget."
                 :meta "Reach for branch-bound over mip-solve when heuristic-good-enough beats optimal-but-timed-out.")
                (:eng "Log solution quality if returned."
                 :math "Tree search with LP relaxation bounds."
                 :cs "May escalate 'use-backend."))
  :row-3-dimension ((:setup "prune a search tree via bounds: same shape in optimization, in alpha-beta search, in SAT solving"
                     :rungs ((:domain "ops" :code "(ops/branch-bound '(spec))")
                             (:domain "alpha-beta" :code "(define (ab-search node) 'best)\n(ab-search 'root)")
                             (:domain "sat" :code "(define (dpll cnf) 'sat)\n(dpll '(clauses))"))
                     :explanation "Rung 1 branch-and-bound on IP. Rung 2 alpha-beta in chess. Rung 3 DPLL for SAT. Each prunes a search tree via bounds/consistency."
                     :meta "Tree-search-with-pruning is universal."
                    )
                    (:eng "Combinatorial optimization and games share it."
                     :math "Prune branches with worse bound."
                     :cs "Recursive branch."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Branch-bound returns a feasible solution or an escalation."
                 :program "(define r (ops/branch-bound '(spec)))\n(or (pair? r) (symbol? r))"
                 :invariant "result is feasible or an escalation symbol"
                 :meta "No-silent-failure contract. Falsified by any silent garbage. See book-of-code on escalations.")
                (:eng "Regression: contracted return type."
                 :math "Feasible or fail-loud."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/branch-bound solves large IPs heuristically."
                     :composition "(define specs '(s1 s2 s3))\n(map ops/branch-bound specs)"
                     :emergent "A portfolio of scenario runs: chaining over spec variants yields solutions per scenario."
                     :meta "This is the same family as scenario analysis. Cross-ref book-of-composition on scenarios.")
                    (:eng "Multi-scenario optimization uses this."
                     :math "Per-scenario result."
                     :cs "Map.")))

(verb
  :name "ops/dijkstra"
  :library "ops"
  :kind "meta"
  :signature "(ops/dijkstra graph start) -> path-table"
  :summary "Computes shortest paths from a start node to all reachable nodes using nonnegative edge weights."
  :explanation "Dijkstra's algorithm solves the single-source shortest-path problem on a directed graph with nonnegative weights. It builds a table of minimum distances and predecessor pointers, allowing you to reconstruct the shortest path to any node. Use this when all edge weights are ≥ 0; if your graph has negative weights, use ops/bellman-ford instead. The algorithm runs in deterministic time and is widely used in routing, network planning, and game pathfinding."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((g '((A . ((B . 1) (C . 4)))\n           (B . ((C . 2) (D . 5)))\n           (C . ((D . 1)))\n           (D . ()))))\n  (ops/dijkstra g 'A))" :note "Returns shortest distances from A: B→1, C→3 (via B), D→4 (via B,C)")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((graph '((start . ((mid . 3) (far . 10)))\n                 (mid . ((far . 2) (end . 4)))\n                 (far . ((end . 1)))\n                 (end . ())))\n       (paths (ops/dijkstra graph 'start))\n       (end-dist (car (assoc 'end paths))))\n  (if (number? end-dist)\n      (list 'shortest-to-end end-dist)\n      'unreachable))" :note "Extracts the shortest distance to a specific destination; returns 7 (start→mid→far→end)")
    (:dialect "motoi" :tier "expert" :code "(define my-graph 'my-graph)\n(define (route-from-distances graph start goal)\n  (let ((paths (ops/dijkstra graph start)))\n    (let loop ((node goal) (path (list goal)))\n      (let ((entry (assoc node paths)))\n        (if (or (null? entry) (eq? node start))\n            (if (eq? node start) (reverse (cons start path)) 'no-route)\n            (let ((pred (cdr entry)))\n              (if (pair? pred)\n                  (loop (car pred) (cons (car pred) path))\n                  'broken-trace)))))))\n  (route-from-distances my-graph 'A 'Z)" :note "Reconstructs the full shortest path by backtracking through predecessor pointers; returns list of nodes from A to Z")
  )
  :caveats ("Requires nonnegative edge weights; negative weights give incorrect results" "Graph must be represented as an alist of node → alist of neighbors and weights" "Unreachable nodes do not appear in the result table" "Running time is deterministic within the device (no randomness)" "Very large graphs may trigger fuel budget limits")
  :drawbacks ("Cannot handle negative edge weights (use ops/bellman-ford if needed)" "Slower than ops/bellman-ford on sparse graphs with very few nodes, but dominates on large dense graphs" "Requires explicit graph representation in memory; not lazy" "Does not detect or report on graph structure anomalies (e.g., self-loops)")
  :usecases ("Network routing: find lowest-cost paths in a router or delivery planner" "Game AI pathfinding on a weighted terrain or graph" "Social network analysis: find minimum-distance connections between people" "Supply-chain optimization: locate lowest-cost supplier paths")
  :related ("ops/bellman-ford" "ops/max-flow" "ops/markov-step" "ai/path")
  :learn (:concept "Greedy single-source shortest paths with nonnegative weights" :prerequisites ("Basic graph representation (adjacency lists)" "Understanding of edge weights and path cost") :progression "After mastering Dijkstra, learn ops/bellman-ford (handles negative weights) and ops/max-flow (flow problems on graphs)")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A navigation app needs the shortest driving distance from one city to all others."
                 :program "(define g '((A . ((B . 3) (C . 5))) (B . ((C . 2))) (C . ())))\n(ops/dijkstra g 'A)"
                 :explanation "Compute shortest paths from A. Returns table of distances and predecessors."
                 :meta "Reach for dijkstra when weights are non-negative; bellman-ford is slower but handles negatives.")
                (:eng "Log unreachable nodes."
                 :math "Greedy relaxation with priority queue."
                 :cs "O((V+E) log V)."))
  :row-3-dimension ((:setup "greedy shortest path on non-negative weights: same shape in routing, in social distance, in delivery"
                     :rungs ((:domain "ops" :code "(ops/dijkstra '((A . ((B . 1))) (B . ())) 'A)")
                             (:domain "social" :code "(define (min-degrees u v) 2)\n(min-degrees 'a 'b)")
                             (:domain "delivery" :code "(define (route-cost cities) 100)\n(route-cost '(a b c))"))
                     :explanation "Rung 1 routes graphs. Rung 2 computes social distance. Rung 3 computes delivery cost. All are min-path over weighted graphs."
                     :meta "Shortest-path is universal.")
                    (:eng "Networks, social graphs, and logistics share it."
                     :math "min-path with ≥0 weights."
                     :cs "Priority-queue relaxation."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Distance to source is 0."
                 :program "(define g '((A . ())))\n(define t (ops/dijkstra g 'A))\n#t"
                 :invariant "d(source) = 0"
                 :meta "Reflexivity. Falsified by broken initialization. See book-of-math on shortest paths.")
                (:eng "Regression: self-distance zero."
                 :math "Base case."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/dijkstra returns a shortest-path table."
                     :composition "(define g '((A . ((B . 3))) (B . ())))\n(define table (ops/dijkstra g 'A))\ntable"
                     :emergent "A route reconstruction: chaining dijkstra with predecessor-trace yields the actual path."
                     :meta "This is the same family as any BFS reconstruction. Cross-ref book-of-composition on route reconstruction.")
                    (:eng "Turn-by-turn navigation uses this composition."
                     :math "Backtrack predecessors."
                     :cs "Follow parent pointers.")))

(verb
  :name "ops/edd"
  :library "ops"
  :kind "meta"
  :signature "(ops/edd jobs) -> ordered-job-list"
  :summary "Orders jobs by earliest due date to minimize maximum lateness on a single machine."
  :explanation "Earliest-due-date (EDD) scheduling is a simple, optimal rule for single-machine scheduling when the goal is to minimize the maximum lateness (or earliness) of any job. Each job has a processing time and a due date. EDD sorts all jobs by due date in ascending order, processes them in that sequence, and guarantees the minimum possible maximum lateness. This is a classic result in scheduling theory and runs in O(n log n) time. Use it for job-shop dispatching, project task ordering, and deadline-driven workflows."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/edd '((j1 . ((processing . 3) (due . 10)))\n            (j2 . ((processing . 2) (due . 5)))\n            (j3 . ((processing . 1) (due . 8)))))" :note "Returns jobs in order j2 (due 5), j3 (due 8), j1 (due 10)")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((jobs '((task-a . ((p . 4) (d . 15)))\n               (task-b . ((p . 2) (d . 8)))\n               (task-c . ((p . 3) (d . 12)))\n               (task-d . ((p . 1) (d . 20)))))\n       (order (ops/edd jobs))\n       (metrics (ops/sequence-metrics order 'processing)))\n  (list 'sequence order 'metrics metrics))" :note "EDD order is task-b, task-c, task-a, task-d; sequence-metrics computes makespan and lateness")
    (:dialect "motoi" :tier "expert" :code "(define my-jobs 'my-jobs)\n(define (schedule-with-edd-fallback job-list backup-rule)\n  (let ((edd-seq (ops/edd job-list)))\n    (let ((metrics (ops/sequence-metrics edd-seq 'processing)))\n      (if (> (car (assoc 'max-lateness metrics)) 50)\n          (list 'edd edd-seq 'metrics metrics 'warning 'high-lateness)\n          (list 'edd edd-seq 'metrics metrics)))))\n  (schedule-with-edd-fallback my-jobs 'spt)" :note "Applies EDD, checks if maximum lateness exceeds threshold; reports risk; could switch to another rule (ops/spt) if needed")
  )
  :caveats ("Job list must be an alist with 'due field (numeric due date)" "EDD is optimal ONLY for minimizing maximum lateness; it does not minimize average flow time or makespan" "If multiple jobs share the same due date, any order among them is equivalent (no tiebreaker specified)" "Assumes all jobs are available at time 0 (no release dates)")
  :drawbacks ("Not optimal for minimizing mean flow time (use ops/spt instead)" "Not optimal for minimizing total tardiness (requires more complex DP)" "Cannot account for machine setup times or job precedence" "Silent no-op if job list is empty or malformed")
  :usecases ("Manufacturing: dispatch jobs to a single machine to meet deadlines with minimum worst-case delay" "Project management: order subtasks by deadline to avoid high lateness" "Service queues: prioritize appointments or requests by due date" "Classroom scheduling: order assignment deadlines to minimize missed dates")
  :related ("ops/spt" "ops/johnson" "ops/sequence-metrics" "ops/eoq")
  :learn (:concept "Greedy scheduling rules and their optimality guarantees" :prerequisites ("Basic job sequencing (processing time, due date, lateness definition)" "Understanding of single-machine scheduling") :progression "After EDD, explore ops/spt (flow time minimization), ops/johnson (two-machine flow shop), and integer-programming approaches (ops/mip-solve) for more complex objectives")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A dispatcher needs to order jobs to minimize the worst-case lateness."
                 :program "(define jobs '((a . ((p . 3) (d . 5))) (b . ((p . 2) (d . 3)))))\n(ops/edd jobs)"
                 :explanation "Sort by due date. Returns jobs in earliest-first order — provably optimal for max-lateness."
                 :meta "Reach for EDD, not FIFO, when deadlines matter; FIFO ignores them.")
                (:eng "Log the sequence and lateness."
                 :math "Sort by due date."
                 :cs "O(n log n)."))
  :row-3-dimension ((:setup "greedy sort by deadline: same shape in EDD scheduling, in classroom assignment sorting, in shipping deadlines"
                     :rungs ((:domain "ops" :code "(ops/edd '((a (p 1) (d 5))))")
                             (:domain "classroom" :code "(define (order-by-due assignments) (sort assignments <))\n(order-by-due '(3 1 5))")
                             (:domain "shipping" :code "(define (order-by-eta packages) (sort packages <))\n(order-by-eta '(2 1 4))"))
                     :explanation "Rung 1 orders jobs by due date. Rung 2 orders homework. Rung 3 orders parcels. All are greedy sort-by-deadline."
                     :meta "Sort by deadline is universal."
                    )
                    (:eng "Same greedy across domains."
                     :math "Sort key = due-date."
                     :cs "Comparator."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "EDD-ordered sequence has minimum max-lateness."
                 :program "(define jobs '((a (p 1) (d 3))))\n(define seq (ops/edd jobs))\n#t"
                 :invariant "max-lateness(EDD) ≤ max-lateness(any-permutation)"
                 :meta "Optimality of EDD. Falsified by any counter-example. See book-of-math on scheduling.")
                (:eng "Regression: EDD is optimal for max-lateness."
                 :math "Jackson's theorem."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/edd returns due-date-ordered job list."
                     :composition "(define jobs '((a (p 1) (d 3))))\n(define seq (ops/edd jobs))\n(ops/sequence-metrics seq)"
                     :emergent "A scheduling report: chaining edd with sequence-metrics yields (makespan, flow, lateness) diagnostics."
                     :meta "This is the same family as any schedule + evaluate pipeline. Cross-ref book-of-composition on schedule-eval.")
                    (:eng "Scheduling dashboards use this pipeline."
                     :math "Order + evaluate."
                     :cs "Sort + metrics.")))

(verb
  :name "ops/eoq"
  :library "ops"
  :kind "meta"
  :signature "(ops/eoq demand order-cost holding-cost) -> Q*"
  :summary "Calculates the economic order quantity (EOQ) that minimizes total annual inventory cost."
  :explanation "The Economic Order Quantity is a classical inventory model result: the lot size Q* that balances ordering cost (fixed cost per order times number of orders per year) against holding cost (per-unit storage cost times average inventory). The formula is Q* = √(2DK/h), where D is annual demand, K is the fixed cost per order, and h is the holding cost per unit per year. EOQ assumes constant demand, instantaneous replenishment, and no stockouts; it is deterministic and runs in O(1) time. Use it as a baseline for inventory planning, even if real conditions diverge."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/eoq 1000 50 5)" :note "D=1000 units/year, K=$50/order, h=$5/unit/year; returns Q*≈447 units per order")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((annual-demand 5000)\n       (order-cost 100)\n       (hold-cost 2)\n       (q-opt (ops/eoq annual-demand order-cost hold-cost))\n       (annual-tc (ops/inventory-cost annual-demand q-opt hold-cost order-cost)))\n  (list 'eoq q-opt 'total-cost annual-tc))" :note "Compute EOQ, then pass to ops/inventory-cost to verify the total annual cost at the optimal quantity")
    (:dialect "motoi" :tier "expert" :code "(define (inventory-sensitivity-analysis demand order-cost hold-cost variance-pct)\n  (let* ((q-base (ops/eoq demand order-cost hold-cost))\n         (q-lo (ops/eoq demand order-cost (* hold-cost (- 1 (/ variance-pct 100)))))\n         (q-hi (ops/eoq demand order-cost (* hold-cost (+ 1 (/ variance-pct 100))))))\n    (list 'q-nominal q-base\n          'q-range (list q-lo q-hi)\n          'sensitivity (/ (- q-hi q-lo) q-base))))\n  (inventory-sensitivity-analysis 2000 75 3 10)" :note "Analyzes how EOQ changes with ±10% variation in holding cost; useful for understanding robustness")
  )
  :caveats ("Assumes constant annual demand (no seasonality or trend)" "Assumes instantaneous replenishment (no lead time)" "Assumes no stockouts allowed and no safety stock needed (deterministic model)" "Order cost K and holding cost h must be positive; zero or negative values give nonsensical results" "Formula assumes a single product (no economies of scale across items)")
  :drawbacks ("Real demand is rarely constant; use ops/newsvendor or stochastic models if demand varies" "Does not account for lead-time variability; use ops/reorder-point and ops/safety-stock for buffers" "Ignores volume discounts and bulk-purchase incentives" "Assumes the holding cost h is correctly estimated; errors here cascade into suboptimal Q*")
  :usecases ("Retail inventory management: determine optimal order size for a high-volume SKU" "Manufacturing: set batch size for production runs to balance setup cost and inventory carrying" "Supply-chain planning: benchmark order quantities before refining with stochastic demand models" "Purchasing: negotiate contract quantities based on cost-minimizing lot size")
  :related ("ops/inventory-cost" "ops/reorder-point" "ops/safety-stock" "ops/newsvendor")
  :learn (:concept "Balancing fixed and variable costs to optimize a continuous quantity" :prerequisites ("Understanding of holding cost and ordering cost in inventory systems" "Basic calculus (derivative of cost function equals zero at optimum)") :progression "After EOQ, learn ops/reorder-point (when to order) and ops/safety-stock (how much buffer); then explore ops/newsvendor (single-period demand uncertainty)")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A retailer needs the optimal batch size to minimize combined ordering + holding cost."
                 :program "(ops/eoq 1000 50 5)"
                 :explanation "D=1000, K=$50, h=$5 → optimal Q* ≈ 141."
                 :meta "Reach for EOQ over intuition; the closed form is exact for the simple model.")
                (:eng "Log Q* alongside assumptions."
                 :math "Q* = √(2DK/h)."
                 :cs "Closed form; O(1)."))
  :row-3-dimension ((:setup "closed-form optimum of a two-cost trade-off: same shape in EOQ, in cache-block sizing, in learning-rate tuning"
                     :rungs ((:domain "ops" :code "(ops/eoq 1000 50 5)")
                             (:domain "cache" :code "(define (opt-block-size fetch-cost hit-rate) 64)\n(opt-block-size 10 0.9)")
                             (:domain "lr" :code "(define (opt-lr grad-var reg) 0.01)\n(opt-lr 0.5 0.1)"))
                     :explanation "Rung 1 balances order vs. hold. Rung 2 balances fetch vs. miss. Rung 3 balances speed vs. stability. Each is a two-cost minimization."
                     :meta "Two-cost trade-off is universal.")
                    (:eng "Inventory, cache, and training share the shape."
                     :math "d/dQ TC = 0."
                     :cs "Analytic solution."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "EOQ is positive when demand, cost, and holding are positive."
                 :program "(> (ops/eoq 1000 50 5) 0)"
                 :invariant "D, K, h > 0 ⟹ Q* > 0"
                 :meta "Positive optimum. Falsified only by broken formula. See book-of-math on optimization.")
                (:eng "Regression: Q* positive."
                 :math "√positive is positive."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/eoq returns optimal batch size."
                     :composition "(define q (ops/eoq 1000 50 5))\n(ops/inventory-cost 1000 q 5 50)"
                     :emergent "A cost-at-optimum verifier: chaining eoq with inventory-cost verifies the model."
                     :meta "This is the same family as any 'compute optimum + evaluate' pipeline. Cross-ref book-of-composition on optimum verification.")
                    (:eng "Model validation for inventory planning."
                     :math "TC(Q*) = min TC."
                     :cs "Verb + verb.")))

(verb
  :name "ops/erlang-b"
  :library "ops"
  :kind "meta"
  :signature "(ops/erlang-b intensity num-channels) -> blocking-prob"
  :summary "Calculates the Erlang B formula: the blocking probability (call rejection rate) in a loss system."
  :explanation "Erlang B models a telephone exchange or call center with a fixed number of channels and no queueing: if all channels are busy, an arriving call is blocked and lost. Given traffic intensity (erlang, the ratio of arrival rate to service rate) and the number of available channels c, Erlang B returns the steady-state probability that a new call will be blocked. This is a classical result in telecom engineering. Use it to dimension call-center trunk lines, configure SIP gateways, and provision radio channels. The formula uses the recursion B(n, u) = u·B(n-1, u) / (1 + u·B(n-1, u))."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/erlang-b 3 5)" :note "Traffic intensity = 3 erlang, 5 channels; returns blocking probability ≈ 0.065 (about 6.5%)")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((call-rate 100)\n       (avg-call-duration 180)\n       (intensity (/ call-rate 60 avg-call-duration))\n       (channels 8)\n       (pb (ops/erlang-b intensity channels))\n       (lost-calls-per-hour (* call-rate pb 60)))\n  (list 'intensity intensity 'channels channels 'blocking-prob pb 'lost-calls-per-hour lost-calls-per-hour))" :note "Models 100 calls/min, 3-min average duration, 8 channels; estimates that ~100 calls/hour get blocked")
    (:dialect "motoi" :tier "expert" :code "(define (find-channels-for-target-blocking intensity target-pb)\n  (let loop ((c 1) (pb 1.0))\n    (if (< pb target-pb)\n        c\n        (let ((pb-next (ops/erlang-b intensity (+ c 1))))\n          (if (or (< pb-next target-pb) (> c 100))\n              (+ c 1)\n              (loop (+ c 1) pb-next))))))\n  (find-channels-for-target-blocking 5.5 0.01)" :note "Binary search (or incremental search) for the minimum channel count that meets a 1% blocking threshold")
  )
  :caveats ("Intensity must be ≥ 0; values ≥ num-channels are degenerate (blocking prob → 1)" "Formula assumes Poisson arrivals and exponential service times (M/M/c/c model)" "Assumes a loss system (blocked calls disappear, no queue)" "Does not account for retry behavior (if blocked callers hang up and try again immediately)" "Channels must be a positive integer")
  :drawbacks ("Not suitable if you have queueing (calls wait); use ops/erlang-c instead" "Erlang B is insensitive to service-time distribution (only moment 1), but real systems may deviate" "Does not model call priority or skill-based routing" "Assumes all channels are identical and always available")
  :usecases ("Telecom: design trunk capacity for a PBX to meet service-level agreements" "Call centers: provision agent channels to achieve a target blocking rate" "Radio systems: allocate spectrum channels to frequency divisions to limit collision probability" "Network gateways: size SIP trunk circuits based on peak traffic")
  :related ("ops/erlang-c" "ops/mmc" "ops/littles-law" "ops/mmc-servers-for")
  :learn (:concept "Queueing theory and the relationship between capacity, traffic load, and service rejection" :prerequisites ("Understanding of erlang (traffic intensity unit)" "Difference between loss systems (Erlang B) and queuing systems (Erlang C)") :progression "After Erlang B, learn ops/erlang-c (queuing with wait), ops/littles-law (flow relationships), and ops/mmc (multi-server queues)")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A PBX designer needs to size trunk lines to keep blocking ≤ 2%."
                 :program "(ops/erlang-b 3 5)"
                 :explanation "3 erlang traffic on 5 trunks. Returns blocking probability."
                 :meta "Reach for Erlang B for loss systems (blocked calls disappear); use Erlang C when calls queue.")
                (:eng "Log the blocking; below SLA threshold means capacity is sufficient."
                 :math "Recursive Erlang B formula."
                 :cs "O(c) recursion."))
  :row-3-dimension ((:setup "steady-state loss probability: same shape in telecom trunks, in radio channels, in cellular blocking"
                     :rungs ((:domain "ops" :code "(ops/erlang-b 3 5)")
                             (:domain "radio" :code "(define (radio-block traffic ch) 0.05)\n(radio-block 5 10)")
                             (:domain "cell" :code "(define (cell-block u c) 0.1)\n(cell-block 2 4)"))
                     :explanation "Rung 1 gives PBX blocking. Rung 2 gives radio blocking. Rung 3 gives cellular blocking. All are Poisson-loss models."
                     :meta "Loss-system blocking is universal."
                    )
                    (:eng "Telecom domains share the shape."
                     :math "B(u, c) formula."
                     :cs "Same solver."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Blocking probability is between 0 and 1."
                 :program "(let ((p (ops/erlang-b 3 5))) (and (>= p 0) (<= p 1)))"
                 :invariant "0 ≤ B ≤ 1"
                 :meta "Probability range. Falsified only by broken formula. See book-of-math on probability.")
                (:eng "Regression: valid probability."
                 :math "Probability axioms."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/erlang-b returns blocking probability."
                     :composition "(define traffic 3)\n(define channel-counts '(4 5 6 7 8))\n(map (lambda (c) (list c (ops/erlang-b traffic c))) channel-counts)"
                     :emergent "A capacity-sensitivity table: chaining erlang-b over channel counts yields blocking vs. capacity trade-off."
                     :meta "This is the same family as any capacity-planning sweep. Cross-ref book-of-composition on planning tables.")
                    (:eng "Trunk sizing decisions use this sweep."
                     :math "B(u, ·) is decreasing."
                     :cs "Map + inspect.")))

(verb
  :name "ops/erlang-c"
  :library "ops"
  :kind "meta"
  :signature "(ops/erlang-c intensity num-servers) -> queue-prob"
  :summary "Calculates the Erlang C formula: the probability an arriving customer must wait in queue."
  :explanation "Erlang C models an M/M/c queue (Poisson arrivals, exponential service, c identical servers) with unlimited queueing. Given traffic intensity (erlang) and number of servers, it returns the steady-state probability that an arriving customer finds all servers busy and must queue. This is a core formula in call-center staffing, customer-service design, and resource planning. Unlike Erlang B (loss system), Erlang C assumes customers wait, and it requires intensity < num-servers (else the queue grows unbounded). Use it to set staffing levels, estimate waiting-time expectations, and balance service quality against cost."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/erlang-c 4 6)" :note "Traffic intensity = 4 erlang, 6 servers; returns queue probability ≈ 0.57 (57% of arrivals must wait)")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((arrival-rate 30)\n       (service-rate 10)\n       (intensity (/ arrival-rate service-rate))\n       (agents 4)\n       (pw (ops/erlang-c intensity agents))\n       (avg-wait-time (/ intensity (* agents (- 1 (/ intensity agents)))))\n       (wq-expected (* avg-wait-time pw (/ 1 service-rate))))\n  (list 'intensity intensity 'pw pw 'expected-wait-time-if-queue wq-expected))" :note "Computes queue probability and expected wait time given arrival and service rates")
    (:dialect "motoi" :tier "expert" :code "(define (erlang-c-staffing arrival-rate service-rate max-queue-prob)\n  (let ((intensity (/ arrival-rate service-rate)))\n    (let loop ((agents (ceiling intensity)) (pw 1.0))\n      (let ((pw-curr (ops/erlang-c intensity agents)))\n        (if (<= pw-curr max-queue-prob)\n            (list 'agents agents 'pw pw-curr 'intensity intensity)\n            (loop (+ agents 1) pw-curr))))))\n  (erlang-c-staffing 50 20 0.1)" :note "Finds the minimum agent count such that queue probability ≤ 10%; iterates upward until threshold met")
  )
  :caveats ("Requires intensity < num-servers; if intensity ≥ servers, the queue is unstable and result is invalid (may escalate 'infeasible)" "Assumes Poisson arrivals and exponential service times" "Assumes unlimited queue capacity (no balking or impatience)" "Does not model abandonment, reneging, or priority classes" "Servers must be a positive integer greater than intensity")
  :drawbacks ("Real call-center traffic often shows non-Poisson patterns and bursty arrivals" "Erlang C is a steady-state formula; it does not capture transient behavior or time-of-day effects" "Does not account for skill-based routing or agent heterogeneity" "Ignores customer impatience (abandonment after a certain wait)")
  :usecases ("Call-center staffing: determine minimum agents needed to keep queue probability below SLA threshold" "Help desks: plan ticket-queue handling staff based on incoming request volume" "Hospital emergency departments: estimate the probability that a patient must wait for a bed" "Retail checkout: design lane capacity to limit the fraction of customers queueing")
  :related ("ops/erlang-b" "ops/mmc" "ops/mmc-servers-for" "ops/littles-law")
  :learn (:concept "Queueing theory and the trade-off between server capacity and waiting probability" :prerequisites ("Understanding of erlang units and traffic intensity" "M/M/c queue model (Poisson arrivals, exponential service, c servers, unlimited queue)") :progression "After Erlang C, learn ops/mmc-servers-for (automate staffing), ops/littles-law (flow relationships), and ops/markov-step (transient queue analysis)")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A call center needs to know the probability an arriving call must wait."
                 :program "(ops/erlang-c 4 6)"
                 :explanation "4 erlang traffic on 6 agents. Returns queue probability."
                 :meta "Reach for Erlang C (queuing) over Erlang B (loss); use B when there's no queue.")
                (:eng "Log Pw; use for SLA verification."
                 :math "Erlang-C formula."
                 :cs "Recursive; requires intensity < c."))
  :row-3-dimension ((:setup "queuing wait probability: same shape in call centers, in hospital triage, in load balancers"
                     :rungs ((:domain "ops" :code "(ops/erlang-c 4 6)")
                             (:domain "triage" :code "(define (wait-prob patients staff) 0.3)\n(wait-prob 10 4)")
                             (:domain "lb" :code "(define (queue-prob req workers) 0.2)\n(queue-prob 20 8)"))
                     :explanation "Rung 1 gives call-wait prob. Rung 2 gives triage-wait prob. Rung 3 gives load-balancer queue prob. All are M/M/c queue models."
                     :meta "Queuing is universal."
                    )
                    (:eng "Same shape across service systems."
                     :math "Erlang-C."
                     :cs "Same solver."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Queue probability is between 0 and 1."
                 :program "(let ((p (ops/erlang-c 4 6))) (and (>= p 0) (<= p 1)))"
                 :invariant "0 ≤ Pw ≤ 1"
                 :meta "Valid probability. Falsified only by broken formula. See book-of-math on probability.")
                (:eng "Regression: valid probability."
                 :math "Probability axioms."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/erlang-c returns queue probability."
                     :composition "(define lam 4)\n(define agent-counts '(5 6 7 8))\n(map (lambda (c) (list c (ops/erlang-c lam c))) agent-counts)"
                     :emergent "A staffing curve: chaining erlang-c over agent counts yields the trade-off."
                     :meta "This is the same family as any staffing analysis. Cross-ref book-of-composition on staffing.")
                    (:eng "Call center capacity planners use this sweep."
                     :math "Pw(λ, ·) is decreasing."
                     :cs "Map.")))

(verb
  :name "ops/interior-point"
  :library "ops"
  :kind "meta"
  :signature "(ops/interior-point lp-instance) -> solution-or-escalation"
  :summary "Solves large-scale linear programming problems using interior-point methods via a backend solver."
  :explanation "Interior-point methods are algorithms that move through the interior of the feasible region (rather than along the boundary, as the simplex method does) to reach the optimal solution. They scale well to very large problems (thousands of variables and constraints) and often outperform simplex on real-world instances. This verb is BACKED, meaning it delegates to an external solver and may escalate special values like 'use-backend if the device solver is unavailable. Use ops/interior-point for large-scale LPs where ops/simplex would be slow or memory-constrained. For small problems, ops/simplex is usually faster."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((lp (ops/lp 'maximize\n                   (list 3 2 1)\n                   (list (list 1 1 1)\n                         (list 2 1 0))\n                   (list 10 8))))\n  (ops/interior-point lp))" :note "Builds a 2-constraint LP and solves it via interior-point; returns optimal value and decision variables")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((c (list 5 4 3 2 1))\n       (A (list (list 1 1 1 1 1)\n                (list 2 1 0 1 0)\n                (list 0 1 2 0 1)))\n       (b (list 20 15 10))\n       (lp (ops/lp 'maximize c A b))\n       (sol (ops/interior-point lp)))\n  (if (pair? sol)\n      (list 'status 'solved 'objective (ops/lp-value sol))\n      (list 'status 'failed 'reason sol)))" :note "5-variable, 3-constraint maximization; checks if solution succeeded or escalated")
    (:dialect "motoi" :tier "expert" :code "(define big-b 'big-b)\n(define big-A 'big-A)\n(define cost-list 'cost-list)\n(define big-demand-list 'big-demand-list)\n(define (production-plan-large num-products num-constraints demand-vec cost-vec constraint-matrix capacity-vec)\n  (let* ((c cost-vec)\n         (A constraint-matrix)\n         (b capacity-vec)\n         (lp (ops/lp 'minimize c A b))\n         (result (ops/interior-point lp)))\n    (if (and (pair? result) (not (eq? result 'use-backend)))\n        (list 'plan result 'obj-value (ops/lp-value result))\n        (list 'fallback 'use-simplex (ops/simplex (ops/lp 'minimize c A b))))))\n  (production-plan-large 100 50 big-demand-list cost-list big-A big-b)" :note "Attempts interior-point on a large instance; falls back to ops/simplex if backend unavailable")
  )
  :caveats ("BACKED: escalates 'use-backend if the backend solver is unavailable or overloaded" "Requires a valid LP artifact (built with ops/lp); malformed LP escalates 'invalid-lp" "Interior-point methods can be sensitive to numerical scaling; very large or very small coefficients may cause convergence issues" "Execution time and memory usage are backend-dependent and may exceed device limits for extremely large problems" "Does not support integer or binary constraints (use ops/mip-solve for mixed-integer problems)")
  :drawbacks ("Slower than simplex on small problems (overhead of backend call)" "Accuracy depends entirely on backend implementation; cannot inspect or debug the solver internals" "May not be available on all devices or deployments (backend dependency)" "Interior-point does not naturally provide constraint duals or sensitivity analysis as easily as simplex")
  :usecases ("Supply-chain planning: optimize sourcing and distribution over hundreds of products and locations" "Portfolio optimization: allocate assets across many investments subject to risk and budget constraints" "Network flow design: plan capacity on large-scale transportation or telecommunications networks" "Power grid optimization: economic dispatch of generators across a large transmission system")
  :related ("ops/lp" "ops/simplex" "ops/lp-solve" "ops/mip-solve")
  :learn (:concept "Scaling algorithms (interior-point vs. simplex) and when to delegate to backend solvers" :prerequisites ("Understanding of linear programming and standard form" "Experience with ops/simplex on small problems" "Knowledge of backend availability and escalation patterns") :progression "After interior-point, explore ops/mip-solve (integer programming at scale) and ops/branch-bound (branch-and-bound methods)")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A supply-chain planner has a 10k-variable LP that ops/simplex can't fit."
                 :program "(define lp '(lp))\n(ops/interior-point lp)"
                 :explanation "Delegate to backend interior-point. Returns solution or 'use-backend."
                 :meta "Reach for interior-point over simplex for large-scale LPs; interior scales polynomially in practice while simplex may struggle.")
                (:eng "Handle 'use-backend by queueing or fallback."
                 :math "Central-path interior-point method."
                 :cs "Backend-delegated."))
  :row-3-dimension ((:setup "delegated large-scale solver: same shape in LP, in ML training, in physics simulation"
                     :rungs ((:domain "ops" :code "(ops/interior-point '(lp))")
                             (:domain "ml" :code "(define (train-on-cluster m d) 'trained)\n(train-on-cluster 'model 'data)")
                             (:domain "physics" :code "(define (run-simulation p) 'result)\n(run-simulation 'params)"))
                     :explanation "Rung 1 delegates LP to backend. Rung 2 delegates ML training. Rung 3 delegates physics. All are backend-delegated compute."
                     :meta "Delegation pattern is universal."
                    )
                    (:eng "Multi-tier compute systems share the pattern."
                     :math "Same solver, more resources."
                     :cs "RPC pattern."))
  :row-4-proof ((:claim "Solution objective is at most simplex's objective (both minimize)."
                 :program "(define lp '(lp))\n#t"
                 :invariant "objective(interior-point) ≈ objective(simplex) at optimality"
                 :meta "Consistency across methods. Falsified by discrepancy beyond numerical tolerance. See book-of-math on LP duality.")
                (:eng "Regression: interior-point and simplex agree."
                 :math "Optimality is unique."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/interior-point solves large LPs via backend."
                     :composition "(define lps '(lp1 lp2))\n(map ops/interior-point lps)"
                     :emergent "A batch large-LP run: chaining interior-point over problems yields solutions per problem."
                     :meta "This is the same family as any batch delegated compute. Cross-ref book-of-composition on batch jobs.")
                    (:eng "Multi-day production planning uses this."
                     :math "Per-problem solution."
                     :cs "Map with retry.")))

(verb
  :name "ops/inventory-cost"
  :library "ops"
  :kind "meta"
  :signature "(ops/inventory-cost demand order-qty holding-cost order-cost) -> total-annual-cost"
  :summary "Calculates the total annual inventory cost as the sum of ordering cost and holding cost."
  :explanation "The inventory cost function combines two competing costs: the ordering (or setup) cost, which is fixed per order and increases with the number of orders per year (D/Q × K), and the holding (or carrying) cost, which depends on average inventory and increases with order size (Q/2 × h). The total annual cost is TC(Q) = (D/Q) × K + (Q/2) × h. This formula is the foundation of the economic order quantity (EOQ) model: EOQ minimizes TC by balancing these two costs. Use ops/inventory-cost to evaluate the cost at any order quantity, compare different policies, or verify optimality after computing the EOQ."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/inventory-cost 1000 100 5 50)" :note "D=1000 units/year, Q=100 units/order, h=$5/unit/year, K=$50/order; returns total cost = (1000/100)×50 + (100/2)×5 = $750")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((demand 5000)\n       (hold-cost 2)\n       (order-cost 100)\n       (q-opt (ops/eoq demand order-cost hold-cost))\n       (q-test-low 200)\n       (q-test-high 800)\n       (cost-opt (ops/inventory-cost demand q-opt hold-cost order-cost))\n       (cost-low (ops/inventory-cost demand q-test-low hold-cost order-cost))\n       (cost-high (ops/inventory-cost demand q-test-high hold-cost order-cost)))\n  (list 'eoq q-opt 'opt-cost cost-opt 'test-costs (list cost-low cost-high)))" :note "Compares total cost at EOQ with two suboptimal quantities; EOQ should yield the minimum")
    (:dialect "motoi" :tier "expert" :code "(define (sensitivity-tornado-inventory demand hold-cost order-cost variance-pct)\n  (let* ((cost-base (ops/inventory-cost demand (ops/eoq demand order-cost hold-cost) hold-cost order-cost))\n         (h-low (* hold-cost (- 1 (/ variance-pct 100))))\n         (h-high (* hold-cost (+ 1 (/ variance-pct 100))))\n         (K-low (* order-cost (- 1 (/ variance-pct 100))))\n         (K-high (* order-cost (+ 1 (/ variance-pct 100))))\n         (cost-h-low (ops/inventory-cost demand (ops/eoq demand order-cost h-low) h-low order-cost))\n         (cost-h-high (ops/inventory-cost demand (ops/eoq demand order-cost h-high) h-high order-cost))\n         (cost-K-low (ops/inventory-cost demand (ops/eoq demand K-low hold-cost) hold-cost K-low))\n         (cost-K-high (ops/inventory-cost demand (ops/eoq demand K-high hold-cost) hold-cost K-high)))\n    (list 'base-cost cost-base\n          'h-sensitivity (list cost-h-low cost-h-high)\n          'K-sensitivity (list cost-K-low cost-K-high))))\n  (sensitivity-tornado-inventory 3000 3 75 15)" :note "Tornado analysis: varies h and K by ±15% and recomputes optimal cost; shows which parameter matters most")
  )
  :caveats ("All parameters must be positive; zero or negative demand, costs, or quantity give nonsensical results" "Formula assumes uniform demand throughout the year (not seasonal or time-varying)" "Assumes instantaneous replenishment (lead time = 0); does not account for safety stock" "Order quantity Q should be positive and realistic; very small Q (e.g., 1) or very large Q may indicate modeling errors" "Does not include stockout or shortage costs")
  :drawbacks ("Highly sensitive to estimates of holding cost h and ordering cost K; small errors cascade into large cost misestimates" "Linear holding cost model ignores warehouse space constraints and bulk-storage discounts" "Does not model quantity discounts or economies of scale" "Assumes a single SKU; multi-item inventory coordination requires more complex models")
  :usecases ("Inventory optimization: evaluate cost trade-offs for different order sizes and choose the best policy" "Budget planning: estimate annual carrying and ordering expenses for SKU management" "Vendor negotiations: use total-cost estimates to justify bulk discounts or alternate suppliers" "Supply-chain education: teach the balance between setup cost and holding cost using realistic scenarios")
  :related ("ops/eoq" "ops/reorder-point" "ops/safety-stock" "ops/newsvendor")
  :learn (:concept "Trade-off optimization: balancing fixed and variable costs" :prerequisites ("Understanding of holding (carrying) cost and ordering (setup) cost" "Basic economics of inventory systems") :progression "After inventory-cost, learn ops/eoq (optimal order quantity), ops/reorder-point (when to order), and ops/newsvendor (stochastic demand)")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A retail manager wants total annual cost for a candidate order quantity."
                 :program "(ops/inventory-cost 1000 100 5 50)"
                 :explanation "Compute TC(Q) = D/Q · K + Q/2 · h."
                 :meta "Reach for inventory-cost, not hand-rolled sum, to keep the arithmetic canonical.")
                (:eng "Log TC per candidate for comparison."
                 :math "TC(Q) = DK/Q + Qh/2."
                 :cs "O(1)."))
  :row-3-dimension ((:setup "sum of two competing costs: same shape in inventory, in batching, in caching"
                     :rungs ((:domain "ops" :code "(ops/inventory-cost 1000 100 5 50)")
                             (:domain "batching" :code "(define (batch-cost n) (+ (/ 100 n) (* n 2)))\n(batch-cost 5)")
                             (:domain "cache" :code "(define (cache-cost b) (+ (/ 10 b) b))\n(cache-cost 3)"))
                     :explanation "Rung 1 sums ordering + holding. Rung 2 sums setup + processing per batch. Rung 3 sums miss + write costs. All are two-cost sums."
                     :meta "Two-cost sum is universal.")
                    (:eng "Retail, computing, and manufacturing share this."
                     :math "TC(Q) = f/Q + g·Q."
                     :cs "One arithmetic."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "TC is minimized at Q = EOQ."
                 :program "(let* ((q (ops/eoq 1000 50 5)) (opt (ops/inventory-cost 1000 q 5 50)) (alt (ops/inventory-cost 1000 (* q 2) 5 50))) (<= opt alt))"
                 :invariant "TC(EOQ) ≤ TC(any other Q)"
                 :meta "Minimality of EOQ. Falsified only by broken formula. See book-of-math on unimodal minimization.")
                (:eng "Regression: EOQ is the min."
                 :math "First-order condition."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/inventory-cost gives TC(Q)."
                     :composition "(define qs '(50 100 141 200 300))\n(map (lambda (q) (list q (ops/inventory-cost 1000 q 5 50))) qs)"
                     :emergent "A cost curve: chaining inventory-cost over Q values yields the U-shaped total-cost plot."
                     :meta "This is the same family as any parameter sweep. Cross-ref book-of-composition on sweeps.")
                    (:eng "Sensitivity analysis walks this sweep."
                     :math "TC(Q) parabolic in Q."
                     :cs "Map + plot.")))

(verb
  :name "ops/johnson"
  :library "ops"
  :kind "meta"
  :signature "(ops/johnson jobs machine1-times machine2-times) -> optimal-sequence"
  :summary "Applies Johnson's rule to find the optimal job sequence for a two-machine flow shop with minimum makespan."
  :explanation "Johnson's rule is a polynomial-time algorithm that solves the two-machine flow-shop scheduling problem optimally. Given a set of jobs, each with processing times on machine 1 and machine 2, it produces a job order that minimizes the makespan (total time to complete all jobs on both machines). The algorithm partitions jobs based on which machine has the shorter processing time and constructs the optimal sequence by prioritizing short-processing-time jobs on machine 1 at the front and on machine 2 at the back. This is a classic result and is widely used in manufacturing, assembly lines, and pipeline scheduling. For more than two machines, the problem becomes NP-hard and requires heuristics."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/johnson '((j1 . ((m1 . 3) (m2 . 6)))\n               (j2 . ((m1 . 8) (m2 . 4)))\n               (j3 . ((m1 . 5) (m2 . 2))))\n            'preprocessing)" :note "Johnson's rule partitions into {j1, j3} (short on m1) and {j2} (short on m2); returns optimal sequence j1, j3, j2")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((jobs '((task-a . ((m1 . 2) (m2 . 8)))\n               (task-b . ((m1 . 5) (m2 . 3)))\n               (task-c . ((m1 . 7) (m2 . 4)))\n               (task-d . ((m1 . 1) (m2 . 9)))))\n       (order (ops/johnson jobs))\n       (metrics (ops/sequence-metrics order 'processing)))\n  (list 'johnson-sequence order 'makespan (car (assoc 'makespan metrics))))" :note "Computes Johnson sequence and immediately verifies makespan via ops/sequence-metrics")
    (:dialect "motoi" :tier "expert" :code "(define my-job-list 'my-job-list)\n(define (flow-shop-analysis jobs)\n  (let* ((johnson-seq (ops/johnson jobs))\n         (johnson-metrics (ops/sequence-metrics johnson-seq 'processing))\n         (spt-seq (ops/spt jobs))\n         (spt-metrics (ops/sequence-metrics spt-seq 'processing)))\n    (list 'johnson-makespan (car (assoc 'makespan johnson-metrics))\n          'spt-makespan (car (assoc 'makespan spt-metrics))\n          'winner (if (< (car (assoc 'makespan johnson-metrics))\n                        (car (assoc 'makespan spt-metrics)))\n                     'johnson\n                     'spt))))\n  (flow-shop-analysis my-job-list)" :note "Compares Johnson's rule (optimal for 2 machines) with SPT heuristic; Johnson dominates when applicable")
  )
  :caveats ("Johnson's rule is ONLY optimal for exactly two machines; results are suboptimal for three or more machines" "Job list must include processing times for both machines (m1 and m2 fields)" "Assumes no job preemption (each job runs to completion on each machine in order)" "Assumes all machines are always available (no downtime or setup delays)" "Jobs cannot have precedence constraints (must be independent)")
  :drawbacks ("Not applicable to job shops (machines visited in different orders by different jobs)" "Does not minimize mean flow time or average lateness; optimizes only makespan" "Very sensitive to processing-time estimates; errors lead to suboptimal results" "Does not account for setup times, transportation delays, or machine breakdowns")
  :usecases ("Manufacturing: sequence parts through two production stages (e.g., cut and fold) to finish as soon as possible" "Assembly lines: order product flow through two workstations to minimize total cycle time" "Batch processing: schedule jobs on two servers or processors to minimize total service time" "Production planning: decide job order to minimize overtime and equipment idle time")
  :related ("ops/spt" "ops/edd" "ops/sequence-metrics" "ops/dijkstra")
  :learn (:concept "Optimal algorithms for restricted scheduling problems and the limits of heuristics" :prerequisites ("Understanding of makespan and flow-shop structure" "Familiarity with job sequencing and performance metrics") :progression "After Johnson's rule, explore ops/spt (heuristic for complex shops) and integer programming (ops/mip-solve) for three+ machines")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A two-stage manufacturing line needs job order to minimize total completion time."
                 :program "(define jobs '((a (m1 3) (m2 6)) (b (m1 8) (m2 4))))\n(ops/johnson jobs)"
                 :explanation "Apply Johnson's rule. Returns optimal sequence for 2-machine flow shop."
                 :meta "Reach for Johnson's rule for exactly 2 machines; for 3+ it becomes NP-hard.")
                (:eng "Log makespan for verification."
                 :math "Sort by min(m1, m2) with placement rule."
                 :cs "O(n log n)."))
  :row-3-dimension ((:setup "polynomial-time optimal for restricted flow shop: same shape in 2-machine scheduling, in 2-phase pipelines, in 2-stage rendering"
                     :rungs ((:domain "ops" :code "(ops/johnson '((a (m1 3) (m2 6))))")
                             (:domain "pipeline" :code "(define (pipe-order jobs) (sort jobs <))\n(pipe-order '(3 1 2))")
                             (:domain "render" :code "(define (render-order stages) 'ok)\n(render-order '(a b))"))
                     :explanation "Rung 1 orders 2-machine flow jobs. Rung 2 orders 2-phase compute jobs. Rung 3 orders 2-stage renders. All are 2-stage flow shops."
                     :meta "2-machine flow shop is universal."
                    )
                    (:eng "Manufacturing, compute, and graphics share it."
                     :math "Johnson's algorithm."
                     :cs "Same solver."))
  :row-4-proof ((:claim "Johnson's rule minimizes makespan for 2-machine flow shop."
                 :program "(define jobs '((a (m1 3) (m2 6))))\n#t"
                 :invariant "makespan(Johnson) ≤ makespan(any other order)"
                 :meta "Optimality theorem. Falsified by counter-example. See book-of-math on Johnson's algorithm.")
                (:eng "Regression: Johnson is optimal."
                 :math "Provable optimality."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/johnson returns optimal 2-machine sequence."
                     :composition "(define jobs '((a (m1 3) (m2 6)) (b (m1 8) (m2 4))))\n(define seq (ops/johnson jobs))\n(ops/sequence-metrics seq)"
                     :emergent "A schedule + metrics report: chaining johnson with sequence-metrics yields diagnostics."
                     :meta "This is the same family as schedule-and-report. Cross-ref book-of-composition on schedule-eval.")
                    (:eng "Manufacturing dashboards use this."
                     :math "Order + evaluate."
                     :cs "Verb chain.")))

(verb
  :name "ops/knapsack"
  :library "ops"
  :kind "meta"
  :signature "(ops/knapsack capacity items) -> solution-or-error"
  :summary "Solves the 0/1 knapsack problem using dynamic programming."
  :explanation "The 0/1 knapsack problem asks: given a weight capacity and a list of items (each with weight and value), which items should you pack to maximize total value without exceeding capacity? This verb uses dynamic programming to find the optimal selection. Each item is either taken or left (hence \"0/1\"). Non-integer weights or values escalate 'no-integer-solution; problems too large to solve within the fuel budget escalate 'fuel-budget."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/knapsack 10 '((2 3) (3 4) (4 5) (5 6)))" :note "Pack items (weight, value) into capacity 10; returns which items to take")
    (:dialect "motoi" :tier "intermediate" :code "(let ((items '((1 2) (2 3) (3 5) (5 7))))\n  (let ((sol (ops/knapsack 7 items)))\n    (apply + (map (lambda (i) (cadr (list-ref items i))) sol))))" :note "Solve the knapsack, then sum the values of selected items to verify optimality")
    (:dialect "motoi" :tier "expert" :code "(define (filter pred xs)\n  (let loop ((xs xs) (acc '()))\n    (cond ((null? xs) (reverse acc))\n          ((pred (car xs)) (loop (cdr xs) (cons (car xs) acc)))\n          (else (loop (cdr xs) acc)))))\n(define (pack-with-budget capacity item-list budget-fn)\n  (let ((filtered (filter (lambda (item) (> (car item) 0)) item-list)))\n    (if (null? filtered) (escalate 'empty-inventory null)\n      (let ((attempt (ops/knapsack capacity filtered)))\n        (cond ((eq? attempt 'no-integer-solution) (escalate 'bad-input null))\n              ((eq? attempt 'fuel-budget) (budget-fn 'reduce-items))\n              (else attempt))))))\n(pack-with-budget 20 '((3 10) (5 15) (7 20)) (lambda (e) '()))" :note "Wrapper that validates input, handles errors (bad weights, timeouts), and delegates budget decisions")
  )
  :caveats ("All weights and values must be non-negative integers; non-integer inputs escalate 'no-integer-solution." "Capacity and item list sizes that lead to DP table size > fuel budget escalate 'fuel-budget." "The verb returns only the set of selected item indices; you must post-process to extract weights/values." "If the capacity is 0 or item list is empty, the solution is the empty selection.")
  :drawbacks ("Time complexity O(n·capacity); space complexity O(capacity). Not suitable for very large capacities (millions) or many items without pruning." "For fractional knapsack (where you can take partial items), use a greedy algorithm instead—ops/knapsack only handles 0/1." "If the item weights are very small relative to capacity, consider grouping or scaling to reduce the DP table size.")
  :usecases ("Truck or container packing: maximize cargo value within weight limit." "Portfolio selection: pick a subset of projects to maximize profit within a budget." "Memory allocation: select which processes to run to maximize utility on a machine with limited RAM." "Cargo manifest planning in logistics.")
  :related ("ops/branch-bound" "ops/mip-solve" "ops/assign" "ops/lp-solve")
  :learn (:concept "Dynamic programming: trade space for time by building up solutions to larger subproblems from smaller ones." :prerequisites ("Understanding of basic list operations (car, cdr, list-ref)" "Familiarity with how DP solves combinatorial optimization") :progression "After mastering ops/knapsack, explore ops/branch-bound (for larger/mixed-integer variants) and ops/mip-solve (for general integer programming).")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A truck loader needs to pick items maximizing value within weight limit."
                 :program "(ops/knapsack 10 '((2 3) (3 4) (4 5) (5 6)))"
                 :explanation "0/1 knapsack DP. Returns which items to take."
                 :meta "Reach for knapsack over greedy; greedy fails on 0/1 knapsack.")
                (:eng "Log the selection for the loader."
                 :math "DP table over (item, weight)."
                 :cs "O(n·W); may escalate."))
  :row-3-dimension ((:setup "0/1 selection under budget: same shape in packing, in portfolio, in memory allocation"
                     :rungs ((:domain "ops" :code "(ops/knapsack 10 '((2 3)))")
                             (:domain "portfolio" :code "(define (pick-assets assets budget) assets)\n(pick-assets '(a b) 100)")
                             (:domain "memory" :code "(define (schedule-jobs jobs mem) jobs)\n(schedule-jobs '(j1) 1024)"))
                     :explanation "Rung 1 packs items. Rung 2 picks assets. Rung 3 admits jobs. All are 0/1 selection under a resource cap."
                     :meta "0/1 knapsack is universal.")
                    (:eng "Logistics, finance, and computing share it."
                     :math "Max Σ vᵢxᵢ s.t. Σ wᵢxᵢ ≤ W, xᵢ ∈ {0,1}."
                     :cs "DP or ILP."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Selection weight ≤ capacity."
                 :program "(define items '((2 3) (4 5)))\n(define sol (ops/knapsack 5 items))\n#t"
                 :invariant "Σ wᵢ · [i ∈ sol] ≤ capacity"
                 :meta "Feasibility. Falsified by any overflow. See book-of-math on knapsack.")
                (:eng "Regression: solution respects capacity."
                 :math "Feasibility constraint."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/knapsack picks max-value subset under capacity."
                     :composition "(define bundles '((c1 items1) (c2 items2)))\n(map (lambda (b) (ops/knapsack (car b) (cadr b))) bundles)"
                     :emergent "A batch pack: chaining knapsack over bundles yields per-scenario packing."
                     :meta "This is the same family as any per-scenario planning. Cross-ref book-of-composition on scenarios.")
                    (:eng "Multi-truck routing walks this map."
                     :math "Per-scenario selection."
                     :cs "Map.")))

(verb
  :name "ops/littles-law"
  :library "ops"
  :kind "meta"
  :signature "(ops/littles-law lambda W) -> L"
  :summary "Applies Little's Law (L = λ·W) to compute average number in system given arrival rate and residence time."
  :explanation "Little's Law is a foundational result in queueing theory: the long-run average number of entities in a system L equals the arrival rate λ times the average time each entity spends in the system W. This holds for any stable queueing system (M/M/1, M/M/c, M/D/1, etc.) regardless of arrival or service distributions. Given λ (arrivals per unit time) and W (average time in system), the verb computes L (average occupancy). This verb applies the law deterministically—it does not model the queue itself."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/littles-law 5 2)" :note "5 arrivals per hour, average stay 2 hours → 10 people in the system on average")
    (:dialect "motoi" :tier "intermediate" :code "(let ((lambda 10) (service-time 0.1) (wait-time 0.4))\n  (let ((W (+ service-time wait-time)))\n    (ops/littles-law lambda W)))" :note "Decompose residence time W into service time (0.1h) and queueing delay (0.4h); compute L")
    (:dialect "motoi" :tier "expert" :code "(define (queue-capacity-check lambda W max-capacity)\n  (let ((L (ops/littles-law lambda W)))\n    (cond ((> L max-capacity) (escalate 'overload (list 'L L 'max max-capacity)))\n          ((< L (* 0.2 max-capacity)) (escalate 'underutilized L))\n          (else (list 'lambda lambda 'W W 'L L)))))\n(queue-capacity-check 8 1.5 15)" :note "Wrapper that checks whether queue occupancy is within safe bounds (20%-100% capacity)")
  )
  :caveats ("Little's Law applies only to stable systems in steady state; transient or unstable systems violate the assumption." "The law gives no information about individual queue disciplines (FIFO, priority, etc.) or the shape of wait-time distributions." "λ must be the long-run average arrival rate, not a snapshot; W must be the long-run average residence time." "If λ ≤ 0 or W < 0, the result is meaningless; the verb does not validate these conditions.")
  :drawbacks ("Provides only one scalar output L; does not give percentiles, variance, or tail behavior." "Does not model the queue dynamics; you cannot use it to simulate transient behavior or response to load spikes." "Does not tell you whether the system is actually stable (i.e., whether λ < μ·c in an M/M/c queue)." "For more detailed analysis (wait-time distribution, blocking probability), use ops/mm1, ops/mmc, or ops/erlang-b.")
  :usecases ("Quick sanity check: given arrival rate and average time-in-system, estimate typical occupancy." "Capacity planning: if occupancy L exceeds facility capacity, the system is overloaded." "Service-level analysis: if W is growing but λ is constant, investigate service bottlenecks." "Reverse calculation: given target L and measured λ, infer required W (average speed) to meet it.")
  :related ("ops/mm1" "ops/mmc" "ops/mmc-servers-for" "ops/erlang-b" "ops/erlang-c")
  :learn (:concept "Little's Law: a model-free relationship between arrival rate, occupancy, and residence time. Holds universally in steady state." :prerequisites ("Basic understanding of arrival rate (λ) and residence time (W)" "Familiarity with queueing notation (L, λ, W)") :progression "After ops/littles-law, learn ops/mm1 and ops/mmc to model queue dynamics including wait-time distributions and service capacity.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A restaurant manager measures arrival rate and average stay, needs average occupancy."
                 :program "(ops/littles-law 5 2)"
                 :explanation "5 arrivals/hour, 2 hours stay → L = 10 average customers."
                 :meta "Reach for Little's Law when only λ and W are known; no queue-model assumption needed.")
                (:eng "Log L for occupancy planning."
                 :math "L = λW."
                 :cs "O(1)."))
  :row-3-dimension ((:setup "product of rate and time gives quantity: same shape in queues, in orbital analysis, in supply chain"
                     :rungs ((:domain "ops" :code "(ops/littles-law 5 2)")
                             (:domain "orbital" :code "(define (orbit-time period revs) (* period revs))\n(orbit-time 90 5)")
                             (:domain "supply" :code "(define (avg-inv rate leadtime) (* rate leadtime))\n(avg-inv 100 3)"))
                     :explanation "Rung 1 gives queue occupancy. Rung 2 gives orbital total. Rung 3 gives average inventory. All are rate × time = quantity."
                     :meta "Little's Law is universal."
                    )
                    (:eng "Queues, orbits, and inventory share the identity."
                     :math "quantity = rate × time."
                     :cs "One multiply."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Little's Law holds trivially for zero-arrival rate."
                 :program "(= (ops/littles-law 0 5) 0)"
                 :invariant "λ = 0 ⟹ L = 0"
                 :meta "No arrivals, no occupancy. Falsified by any residual. See book-of-math on Little's Law.")
                (:eng "Regression: idle system has zero L."
                 :math "λW = 0 when λ = 0."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/littles-law computes L from λ and W."
                     :composition "(define scenarios '((3 1) (5 2) (10 0.5)))\n(map (lambda (s) (ops/littles-law (car s) (cadr s))) scenarios)"
                     :emergent "A scenario sweep: chaining littles-law over cases yields per-scenario L."
                     :meta "This is the same family as any parameter sweep. Cross-ref book-of-composition on sweeps.")
                    (:eng "Capacity planning sweeps this."
                     :math "L = λW per scenario."
                     :cs "Map.")))

(verb
  :name "ops/lp"
  :library "ops"
  :kind "meta"
  :signature "(ops/lp c A b) -> lp-artifact"
  :summary "Builds a standard-form linear programming artifact: maximize c·x subject to Ax ≤ b, x ≥ 0."
  :explanation "A linear program (LP) is an optimization problem where the objective and all constraints are linear. The standard form used here is: maximize the inner product c·x, where x is a vector of decision variables, subject to the constraint Ax ≤ b (matrix-vector inequality) and x ≥ 0 (non-negativity). This verb accepts the cost vector c (what you maximize), the constraint matrix A (rows are constraints), and the right-hand side vector b (constraint bounds), and returns an artifact that encodes the problem. You can then pass this artifact to ops/simplex to solve it, or query its structure. The artifact itself is not solved; ops/lp just validates and stores the problem."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/lp '(3 2) '((1 1) (2 1) (1 2)) '(4 5 3))" :note "Maximize 3x₁ + 2x₂ subject to x₁+x₂≤4, 2x₁+x₂≤5, x₁+2x₂≤3, x₁,x₂≥0")
    (:dialect "motoi" :tier "intermediate" :code "(define (diet-lp proteins fats carbs max-protein max-fat max-carb)\n  (ops/lp '(1 1 1) (list (list proteins 0 0) (list 0 fats 0) (list 0 0 carbs)) (list max-protein max-fat max-carb)))\n(diet-lp 4 9 5 2000 800 1200)" :note "Diet optimization: maximize grams of protein+fat+carb subject to daily limits per macronutrient")
    (:dialect "motoi" :tier "expert" :code "(define (portfolio-lp expected-returns covariance-sqrt budget max-concentration)\n  (let ((n (length expected-returns)))\n    (let ((A (append (list (make-list n 1) (map (lambda (i) (list-ref covariance-sqrt i)) (range n)))))\n          (b (append (list budget) (make-list n max-concentration))))\n      (ops/lp expected-returns A b))))\n(portfolio-lp '(0.05 0.08 0.06) '((0.1) (0.15) (0.12)) 10000 3000)" :note "Portfolio selection: maximize expected return subject to budget and concentration limits (simplified)")
  )
  :caveats ("ops/lp only constructs the artifact; it does not solve the problem. Pass the result to ops/simplex or ops/lp-solve." "The problem is in standard form (≤ inequalities, ≥ non-negativity). If your problem has equalities or ≥ constraints, you must transform them first (e.g., introduce slack/surplus variables)." "If A or b contain non-numeric values, the verb may escalate an error." "The artifact is deterministic within the device; changes to c, A, or b require creating a new artifact.")
  :drawbacks ("Does not check for infeasibility or unboundedness until ops/simplex is applied." "No support for integer constraints; for integer LP, use ops/mip-solve." "For very large problems (thousands of variables, millions of constraints), the artifact may consume significant memory." "Manual transformation of non-standard-form problems is error-prone; consider using ops/lp-solve if you want to solve immediately.")
  :usecases ("Resource allocation: distribute limited resources (budget, time, capacity) to maximize profit." "Production planning: decide how much of each product to make given resource constraints." "Portfolio optimization: choose asset weights to maximize expected return subject to risk and budget." "Blending problems: mix raw materials to meet quality specifications at minimum cost.")
  :related ("ops/lp-solve" "ops/simplex" "ops/lp-value" "ops/interior-point" "ops/mip-solve")
  :learn (:concept "Standard-form linear programming: expressing optimization as matrix inequality Ax≤b. Enables solvers like the simplex method." :prerequisites ("Understanding of vectors and matrices" "Familiarity with linear inequalities and optimization") :progression "After ops/lp, use ops/simplex to solve it, then ops/lp-value to extract the objective value. For integrated solve, use ops/lp-solve instead.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A planner wants to build an LP artifact to solve later with different solvers."
                 :program "(ops/lp '(3 2) '((1 1) (2 1)) '(4 5))"
                 :explanation "Construct LP artifact. Pass to ops/simplex or ops/interior-point."
                 :meta "Reach for ops/lp (constructor) over ops/lp-solve when the artifact will be solved multiple times or with different solvers.")
                (:eng "Log the LP dimensions for later inspection."
                 :math "LP = (c, A, b)."
                 :cs "Pure constructor."))
  :row-3-dimension ((:setup "constructor for a solvable problem: same shape in LP, in ODE spec, in query builder"
                     :rungs ((:domain "ops" :code "(ops/lp '(1 1) '((1 1)) '(1))")
                             (:domain "ode" :code "(define (ode f y0 t) (list f y0 t))\n(ode 'rate 1 5)")
                             (:domain "query" :code "(define (make-query select from where) (list select from where))\n(make-query '(*) 'users '(active))"))
                     :explanation "Rung 1 builds an LP. Rung 2 builds an ODE spec. Rung 3 builds a SQL query. All construct a solvable/executable artifact."
                     :meta "Constructor + separate solver is universal.")
                    (:eng "LP, DE, and DB share the pattern."
                     :math "Problem specification."
                     :cs "Immutable data."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "LP artifact preserves inputs."
                 :program "(let ((lp (ops/lp '(1 2) '((1 1)) '(3)))) (pair? lp))"
                 :invariant "artifact retrievably contains c, A, b"
                 :meta "Artifact fidelity. Falsified by data loss. See book-of-code on immutable artifacts.")
                (:eng "Regression: artifact roundtrips."
                 :math "Encoding is a section."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/lp constructs an LP artifact."
                     :composition "(define lp (ops/lp '(1 1) '((1 1)) '(2)))\n(ops/simplex lp)"
                     :emergent "Build + solve: chaining lp with simplex separates specification from method."
                     :meta "This is the same family as any factory + engine pattern. Cross-ref book-of-composition on factories.")
                    (:eng "Solver-agnostic code uses this split."
                     :math "Specification separated from solution method."
                     :cs "Two-step pipeline.")))

(verb
  :name "ops/lp-solve"
  :library "ops"
  :kind "meta"
  :signature "(ops/lp-solve c A b) -> solution-or-error"
  :summary "Builds and solves a standard-form linear program in a single call."
  :explanation "This verb combines ops/lp (problem construction) and ops/simplex (solving) into one step. Given cost vector c, constraint matrix A, and bound vector b, it returns the optimal solution vector x that maximizes c·x subject to Ax ≤ b and x ≥ 0. If the problem is infeasible, unbounded, or runs out of fuel, the verb escalates an error ('infeasible, 'unbounded, 'fuel-budget). This is a convenience when you don't need to inspect or reuse the problem artifact."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/lp-solve '(3 2) '((1 1) (2 1) (1 2)) '(4 5 3))" :note "Maximize 3x₁ + 2x₂ subject to three constraints; returns the optimal x")
    (:dialect "motoi" :tier "intermediate" :code "(let ((sol (ops/lp-solve '(5 4 3) '((2 1 1) (1 2 1) (1 1 3)) '(10 8 6))))\n  (if (number? (car sol)) (apply + (map * '(5 4 3) sol)) (escalate sol '())))" :note "Solve, then compute the objective value c·x by hand-folding the dot product")
    (:dialect "motoi" :tier "expert" :code "(define (robust-solve c A b tol fallback)\n  (let ((attempt (ops/lp-solve c A b)))\n    (cond ((pair? attempt) attempt)  ;; solution is a list\n          ((eq? attempt 'infeasible) (fallback 'infeasible))\n          ((eq? attempt 'unbounded) (fallback 'unbounded))\n          ((eq? attempt 'fuel-budget) (fallback 'reduce-problem-size))\n          (else (escalate 'unknown-error null)))))\n(robust-solve '(1 1) '((1 -1) (-1 1)) '(1 1) 0.000001 (lambda (err) (list 'error err)))" :note "Wrapper that intercepts errors and delegates fallback logic (e.g., relax constraints or simplify)")
  )
  :caveats ("Returns only the primal solution x, not the dual solution or shadow prices. For sensitivity analysis, use ops/lp + ops/simplex and inspect the artifact." "If the problem is infeasible or unbounded, escalates 'infeasible or 'unbounded respectively; there is no solution vector." "All elements of c, A, b must be numeric; non-numeric entries cause errors." "The problem must be in standard form (≤ inequalities, x ≥ 0); transformation of ≥ or = constraints is the caller's responsibility.")
  :drawbacks ("Does not return the constraint matrix or cost vector; if you need to reuse the problem with different right-hand sides, use ops/lp to construct once and ops/simplex multiple times." "For mixed-integer programming, use ops/mip-solve instead." "Large-scale LPs may hit the fuel budget; consider ops/interior-point for very large problems." "No support for warm-starts or basis reuse.")
  :usecases ("One-off optimization: solve a specific LP and move on." "Quick feasibility check: verify whether a set of constraints is satisfiable by trying to optimize any objective." "Prototyping: test LP formulations before scaling up." "Embedded optimization: call ops/lp-solve inside a larger algorithm (e.g., column generation).")
  :related ("ops/lp" "ops/simplex" "ops/lp-value" "ops/interior-point" "ops/mip-solve")
  :learn (:concept "One-call LP solving: convenience over flexibility. Useful when you don't need the problem artifact itself." :prerequisites ("Understanding of standard-form LP (Ax≤b, x≥0)" "Familiarity with feasibility and unboundedness") :progression "If you need to solve multiple problems with the same A and b but different c, use ops/lp once + ops/simplex multiple times. For integer programs, move to ops/mip-solve.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A quick prototype needs to build + solve an LP in one call."
                 :program "(ops/lp-solve '(3 2) '((1 1) (2 1)) '(4 5))"
                 :explanation "Build + solve. Returns solution vector x or escalation."
                 :meta "Reach for ops/lp-solve for one-shots; use ops/lp + ops/simplex when the artifact is reused.")
                (:eng "Log solution or escalation."
                 :math "Solve one-shot."
                 :cs "Constructor + simplex combined."))
  :row-3-dimension ((:setup "one-call convenience wrapper: same shape in LP, in SQL run-query, in fetch-and-parse"
                     :rungs ((:domain "ops" :code "(ops/lp-solve '(1 1) '((1 1)) '(2))")
                             (:domain "sql" :code "(define (run-sql q) 'rows)\n(run-sql \"SELECT *\")")
                             (:domain "fetch" :code "(define (fetch-json url) '(json))\n(fetch-json \"/api\")"))
                     :explanation "Rung 1 build + solve LP. Rung 2 parses + executes SQL. Rung 3 fetches + parses JSON. Each combines construction and execution."
                     :meta "One-shot wrapper is universal."
                    )
                    (:eng "Convenience APIs share this shape."
                     :math "Compose construct + execute."
                     :cs "Convenience wrapper."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "For feasible bounded LPs, returns a solution vector."
                 :program "(pair? (ops/lp-solve '(1) '((1)) '(1)))"
                 :invariant "feasible bounded LP ⟹ solution is a list"
                 :meta "Return contract. Falsified by any garbage return. See book-of-code on contracts.")
                (:eng "Regression: returns a list on success."
                 :math "Contract preservation."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/lp-solve builds and solves an LP."
                     :composition "(define cs '((1 2) (3 4)))\n(map (lambda (c) (ops/lp-solve c '((1 1)) '(1))) cs)"
                     :emergent "A cost-sensitivity sweep: chaining lp-solve over varying c yields solutions per cost vector."
                     :meta "This is the same family as any parameter sweep. Cross-ref book-of-composition on sweeps.")
                    (:eng "Solution sensitivity for pricing."
                     :math "Sol vs. c."
                     :cs "Map.")))

(verb
  :name "ops/lp-value"
  :library "ops"
  :kind "meta"
  :signature "(ops/lp-value c solution) -> scalar"
  :summary "Computes the objective value c·x for a given cost vector and solution vector."
  :explanation "After solving an LP, you have the solution vector x. The objective value is the inner product of the cost vector c and x, i.e., c·x. This verb computes that dot product. It is a convenience for extracting the 'quality' of a solution without manually folding over vectors. Given c (the cost/profit coefficients) and the solution vector x, ops/lp-value returns the scalar objective value."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/lp-value '(3 2 1) '(1 2 3))" :note "Objective = 3·1 + 2·2 + 1·3 = 10")
    (:dialect "motoi" :tier "intermediate" :code "(let ((c '(5 4 3)))\n  (let ((sol (ops/lp-solve c '((2 1 1) (1 2 1)) '(10 8))))\n    (if (pair? sol) (ops/lp-value c sol) (escalate sol null))))" :note "Solve an LP, then compute the objective value of the solution")
    (:dialect "motoi" :tier "expert" :code "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(define (compare-solutions c solutions)\n  (let ((values (map (lambda (sol) (ops/lp-value c sol)) solutions)))\n    (let ((best-val (fold-left max (car values) (cdr values))))\n      (let ((best-sol (list-ref solutions (fold-left (lambda (i v) (if (= v best-val) i (+ i 1))) 0 values))))\n        (list 'best-value best-val 'best-solution best-sol)))))\n(compare-solutions '(2 3) '((1 0) (0 1.5) (1 1)))" :note "Compare multiple candidate solutions and pick the one with the highest objective value")
  )
  :caveats ("The verb does not validate that the solution actually satisfies the constraints Ax ≤ b. It computes the objective regardless." "If the solution vector and c have different lengths, the behavior is undefined or may escalate an error." "The verb is deterministic within the device; the same c and solution always yield the same output." "Non-numeric entries in c or the solution cause errors.")
  :drawbacks ("Provides only the objective value, not the solution feasibility or optimality status." "For batch evaluation of many solutions, consider using fold-left with a dot-product lambda to avoid repeated verb calls." "If the solution is infeasible, the objective value is meaningless; always verify feasibility first." "Not useful for the problem construction phase; use only after you have a candidate or optimal solution.")
  :usecases ("Verify the quality of an LP solution after ops/lp-solve returns it." "Compare two candidate solutions and pick the better one (higher objective for maximization)." "Compute the objective value for a heuristic or approximate solution to estimate solution quality." "Extract the optimal cost/profit from the solution of a resource-allocation or production-planning problem.")
  :related ("ops/lp-solve" "ops/lp" "ops/simplex" "ops/assign-cost")
  :learn (:concept "Objective value extraction: after solving, compute the goal quantity (profit, cost, etc.) using the cost vector and the solution." :prerequisites ("Understanding of dot product (inner product)" "Familiarity with LP solutions (vectors of variable values)") :progression "Use ops/lp-value after ops/lp-solve to assess solution quality. For detailed sensitivity analysis, explore ops/lp + ops/simplex directly.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A reviewer needs the objective value of a proposed LP solution."
                 :program "(ops/lp-value '(3 2 1) '(1 2 3))"
                 :explanation "Compute c · x = 3·1 + 2·2 + 1·3 = 10."
                 :meta "Reach for lp-value over manual dot; the verb is canonical.")
                (:eng "Log the objective for comparison."
                 :math "c · x."
                 :cs "O(n) fold."))
  :row-3-dimension ((:setup "dot product of cost and solution: same shape in LP, in weighted sum, in expected value"
                     :rungs ((:domain "ops" :code "(ops/lp-value '(3 2) '(1 2))")
                             (:domain "weighted-sum" :code "(define (wsum ws xs) (apply + (map * ws xs)))\n(wsum '(0.5 0.5) '(2 4))")
                             (:domain "expectation" :code "(define (ex probs vals) (apply + (map * probs vals)))\n(ex '(0.3 0.7) '(10 5))"))
                     :explanation "Rung 1 gives LP objective. Rung 2 gives weighted average. Rung 3 gives expected value. All are inner products."
                     :meta "Inner product is universal."
                    )
                    (:eng "Same fold across substrates."
                     :math "⟨c, x⟩."
                     :cs "Fold + multiply."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "lp-value is bilinear in c and x."
                 :program "(let ((v1 (ops/lp-value '(1 2) '(3 4))) (v2 (ops/lp-value '(2 4) '(3 4)))) (= v2 (* 2 v1)))"
                 :invariant "value(αc, x) = α · value(c, x)"
                 :meta "Bilinearity. Falsified only by nonlinear implementation. See book-of-math on inner products.")
                (:eng "Regression: scaling c scales value."
                 :math "Linearity of inner product."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/lp-value computes c · x."
                     :composition "(define c '(3 2))\n(define candidates '((2 0) (0 3) (1 1)))\n(map (lambda (sol) (list sol (ops/lp-value c sol))) candidates)"
                     :emergent "A candidate ranking: chaining lp-value over solutions yields objective per candidate."
                     :meta "This is the same family as any solution ranking. Cross-ref book-of-composition on ranking.")
                    (:eng "Solution comparison uses this."
                     :math "Per-solution objective."
                     :cs "Map.")))

(verb
  :name "ops/markov"
  :library "ops"
  :kind "meta"
  :signature "(ops/markov matrix) -> matrix-or-error"
  :summary "Builds and validates a Markov transition matrix; each row must sum to 1."
  :explanation "A Markov chain is a stochastic process where the future state depends only on the current state, not the history. The transition matrix P has entry P[i][j] = probability of moving from state i to state j. Each row is a probability distribution (sums to 1) and all entries are non-negative. This verb takes a candidate matrix, validates that each row sums to 1 (within numerical tolerance), and returns the validated matrix. If any row does not sum to 1, it escalates an error. The matrix is deterministic within the device."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/markov '((0.7 0.3) (0.4 0.6)))" :note "Validate a 2-state Markov chain: row 1 sums to 0.7+0.3=1, row 2 to 0.4+0.6=1 ✓")
    (:dialect "motoi" :tier "intermediate" :code "(define (weather-markov sunny-sunny sunny-rainy rainy-sunny rainy-rainy)\n  (ops/markov (list (list sunny-sunny sunny-rainy)\n                    (list rainy-sunny rainy-rainy))))\n(weather-markov 0.8 0.2 0.3 0.7)" :note "Build a weather Markov chain: sunny→sunny=0.8, sunny→rainy=0.2, rainy→sunny=0.3, rainy→rainy=0.7")
    (:dialect "motoi" :tier "expert" :code "(define weather-markov (lambda args (list \"weather-markov\" args)))\n(define (validate-and-steady lambda markov-fn states)\n  (let ((P (apply markov-fn states)))\n    (if (pair? P) (let ((pi (ops/stationary P)))\n                    (cond ((pair? pi) (list 'steady-state pi))\n                          (else (escalate pi null))))\n                  (escalate P null))))\n(validate-and-steady 3 weather-markov '(0.8 0.2 0.3 0.7))" :note "Validate a Markov chain, then compute its long-run steady-state distribution")
  )
  :caveats ("All entries must be non-negative (probabilities cannot be negative). Non-negative entries are assumed; the verb does not enforce this explicitly." "Each row must sum to 1 within numerical tolerance (typically ±1e-10). Rows summing to exactly 1.0 due to floating-point rounding may pass or fail depending on tolerance." "The verb validates structure only, not ergodicity or aperiodicity; a valid Markov chain may not have a unique steady state." "Non-numeric entries in the matrix cause errors.")
  :drawbacks ("Does not check whether the chain is irreducible, aperiodic, or has other convergence properties. A valid matrix may not converge to a steady state." "No support for sparse matrices; large, dense transition matrices consume memory." "Does not detect if the chain contains absorbing states or communicating classes; use ops/absorbing-steps for that analysis." "For very large matrices, validation may be slow.")
  :usecases ("Build a Markov chain model from domain knowledge (e.g., customer behavior, weather patterns)." "Validate user-supplied transition probabilities before running further analysis (ops/stationary, ops/markov-step)." "Construct multi-state systems: weather, stock prices, inventory levels, customer lifetime value." "Foundation for ops/pagerank, ops/absorbing-probs, and other Markov-based analyses.")
  :related ("ops/markov-step" "ops/stationary" "ops/pagerank" "ops/absorbing-steps" "ops/absorbing-probs")
  :learn (:concept "Markov transition matrix: a square stochastic matrix where rows are probability distributions over next states, encoding memoryless transitions." :prerequisites ("Understanding of probability distributions (row sums to 1)" "Familiarity with matrix indexing and row operations") :progression "After ops/markov, use ops/markov-step to simulate state evolution, ops/stationary to find long-run behavior, or ops/pagerank to rank states by importance.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A modeler builds a transition matrix from data; needs validation that rows sum to 1."
                 :program "(ops/markov '((0.7 0.3) (0.4 0.6)))"
                 :explanation "Validate and store the Markov matrix. Rows must sum to 1."
                 :meta "Reach for ops/markov before running any Markov analysis; downstream verbs assume validity.")
                (:eng "Log invalid rows for correction."
                 :math "Stochastic matrix condition."
                 :cs "One pass validation."))
  :row-3-dimension ((:setup "typed constructor with validation: same shape in Markov, in JSON schema, in typed struct"
                     :rungs ((:domain "ops" :code "(ops/markov '((0.5 0.5) (0.5 0.5)))")
                             (:domain "schema" :code "(define (validate-json j) 'ok)\n(validate-json '(json))")
                             (:domain "struct" :code "(define (make-point x y) (list 'point x y))\n(make-point 3 4)"))
                     :explanation "Rung 1 validates + tags Markov. Rung 2 validates JSON. Rung 3 tags a point. Each combines validation with type tagging."
                     :meta "Validated constructor is universal."
                    )
                    (:eng "Types, schemas, and models share it."
                     :math "Precondition-enforced constructor."
                     :cs "Wrap + validate."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Each row of ops/markov output sums to 1."
                 :program "(define P (ops/markov '((0.7 0.3) (0.4 0.6))))\n(let ((r0 (car P))) (< (abs (- (apply + r0) 1)) 0.001))"
                 :invariant "∀ i. Σⱼ P[i][j] = 1"
                 :meta "Row-stochasticity. Falsified only by broken validation. See book-of-math on stochastic matrices.")
                (:eng "Regression: rows sum to 1."
                 :math "Row sum = 1."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/markov validates + tags a transition matrix."
                     :composition "(define P (ops/markov '((0.7 0.3) (0.4 0.6))))\n(ops/stationary P)"
                     :emergent "Validate + steady state: chaining markov with stationary yields long-run analysis."
                     :meta "This is the same family as any construct + analyze pipeline. Cross-ref book-of-composition on pipelines.")
                    (:eng "Weather, queuing, and finance models use this pipeline."
                     :math "Model + long-run behavior."
                     :cs "Two verbs.")))

(verb
  :name "ops/markov-step"
  :library "ops"
  :kind "meta"
  :signature "(ops/markov-step pi P k) -> distribution"
  :summary "Advances a state distribution k steps through a Markov transition matrix: π_k = π₀ · P^k."
  :explanation "Given a current probability distribution π (a row vector encoding which states are likely now) and a transition matrix P, the distribution after one step is π · P (matrix-vector multiplication). After k steps, it is π · P^k. This verb computes π · P^k without explicitly forming P^k, using repeated multiplication (or fast exponentiation for large k). The result is the predicted state distribution k steps in the future. This is useful for forecasting or understanding transient behavior of the Markov chain."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/markov-step '(1 0) '((0.7 0.3) (0.4 0.6)) 1)" :note "Start in state 0 (distribution (1,0)), take 1 step: (1,0)·P = (0.7, 0.3)")
    (:dialect "motoi" :tier "intermediate" :code "(let ((pi0 '(0.5 0.5)) (P '((0.8 0.2) (0.3 0.7))))\n  (let ((pi1 (ops/markov-step pi0 P 1))\n        (pi5 (ops/markov-step pi0 P 5))\n        (pi10 (ops/markov-step pi0 P 10)))\n    (list 'step-1 pi1 'step-5 pi5 'step-10 pi10)))" :note "Forecast the state distribution at steps 1, 5, and 10 to observe convergence")
    (:dialect "motoi" :tier "expert" :code "(define (first-passage-estimate pi P target threshold max-steps)\n  (let loop ((pi pi) (step 0))\n    (cond ((>= step max-steps) (escalate 'max-steps-reached step))\n          ((>= (list-ref pi target) threshold) step)\n          (else (loop (ops/markov-step pi P 1) (+ step 1))))))\n(first-passage-estimate '(1 0 0) '((0 0.5 0.5) (0.3 0 0.7) (0.6 0.2 0.1)) 2 0.4 100)" :note "Estimate how many steps until state 2 reaches probability ≥ 0.4, starting from state 0")
  )
  :caveats ("The distribution π must sum to 1; non-normalized distributions produce incorrect results." "The transition matrix P must be valid (rows sum to 1) from ops/markov, not validated here." "k must be non-negative; negative k is undefined or may escalate an error." "For very large k, the distribution may converge to a steady state; further steps produce identical output.")
  :drawbacks ("Time complexity O(n² · k) for naive multiplication (or O(n³ · log k) for matrix exponentiation). Very large k or n can hit the fuel budget." "Does not check for convergence; if you need only the steady state, use ops/stationary instead (more efficient)." "No support for sparse matrices; dense P consumes memory." "If π is not normalized, the output will not be normalized either; callers must handle normalization.")
  :usecases ("Forecast customer state (active, dormant, churned) k months into the future." "Predict inventory level distribution after k periods of stochastic demand and replenishment." "Simulate transient behavior of a random walk or diffusion process." "Estimate time to reach a threshold state (e.g., system failure) in reliability analysis.")
  :related ("ops/markov" "ops/stationary" "ops/pagerank" "ops/absorbing-steps")
  :learn (:concept "Matrix power and distribution evolution: composing transitions to model multi-step futures. π · P^k encodes all paths of length k." :prerequisites ("Comfort with Markov chains (ops/markov)" "Understanding of matrix-vector multiplication" "Concept of probability distributions") :progression "After ops/markov-step, explore ops/stationary for steady-state behavior, or ops/absorbing-steps for absorption-time analysis.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A forecaster needs the state distribution 10 steps into the future."
                 :program "(ops/markov-step '(1 0) '((0.7 0.3) (0.4 0.6)) 10)"
                 :explanation "Advance the initial distribution 10 steps forward through the Markov chain."
                 :meta "Reach for markov-step for forecasts; use stationary for the ultimate steady state.")
                (:eng "Log the distribution at intervals to trace convergence."
                 :math "π_k = π₀ · P^k."
                 :cs "O(n² log k) with fast exponentiation."))
  :row-3-dimension ((:setup "iterate a transition k times: same shape in Markov chains, in cellular automata, in recurrence relations"
                     :rungs ((:domain "ops" :code "(ops/markov-step '(1 0) '((0.7 0.3)) 5)")
                             (:domain "ca" :code "(define (ca-step grid) grid)\n(ca-step '(0 1 0))")
                             (:domain "recurrence" :code "(define (rec f x0 k) (if (zero? k) x0 (rec f (f x0) (- k 1))))\n(rec (lambda (x) (+ x 1)) 0 5)"))
                     :explanation "Rung 1 iterates Markov transitions. Rung 2 iterates cellular automata. Rung 3 iterates a general recurrence. All are k-fold function application."
                     :meta "Iterating a transition is universal."
                    )
                    (:eng "Physical simulations, biology, and math share this."
                     :math "f^k = f ∘ … ∘ f."
                     :cs "Iteration or fast exponentiation."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "After k=0 steps, distribution is unchanged."
                 :program "(equal? (ops/markov-step '(1 0) '((0.7 0.3) (0.4 0.6)) 0) '(1 0))"
                 :invariant "∀ π P. step(π, P, 0) = π"
                 :meta "Zero-step identity. Falsified by any drift. See book-of-math on iteration.")
                (:eng "Regression: 0 steps is no-op."
                 :math "f⁰ = identity."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/markov-step evolves a distribution."
                     :composition "(define P '((0.7 0.3) (0.4 0.6)))\n(define pi0 '(1 0))\n(map (lambda (k) (list k (ops/markov-step pi0 P k))) '(0 1 5 10 50))"
                     :emergent "A convergence trace: chaining markov-step over increasing k yields how distribution approaches steady state."
                     :meta "This is the same family as any convergence-observation. Cross-ref book-of-composition on convergence.")
                    (:eng "Steady-state verification for Markov analysis."
                     :math "π_k → π_stationary."
                     :cs "Map + inspect.")))

(verb
  :name "ops/max-flow"
  :library "ops"
  :kind "meta"
  :signature "(ops/max-flow graph source sink) -> flow-value"
  :summary "Solves the maximum-flow problem using the Ford–Fulkerson method with Edmonds–Karp refinement."
  :explanation "A flow network is a directed graph where each edge has a capacity (maximum amount that can flow through it). The maximum-flow problem asks: what is the largest total flow that can route from a source node to a sink node, respecting all edge capacities? The Ford–Fulkerson algorithm finds augmenting paths (paths from source to sink with available capacity) and pushes flow along them until no augmenting path remains. The Edmonds–Karp variant uses breadth-first search to find augmenting paths, guaranteeing polynomial time. The verb takes a graph (adjacency-list or edge-list representation), a source node, and a sink node, and returns the maximum flow value. By the max-flow min-cut theorem, this value also equals the minimum cut (minimum capacity to remove to disconnect source and sink)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/max-flow '((0 . ((1 . 10) (2 . 5))) (1 . ((2 . 15) (3 . 9))) (2 . ((3 . 10)))) 0 3)" :note "Graph with 4 nodes (0 to 3), edges with capacities. Max flow from source 0 to sink 3 is 19")
    (:dialect "motoi" :tier "intermediate" :code "(define (graph-from-edges edges n)\n  (let ((g (make-vector n '())))\n    (for-each (lambda (e) \n      (let ((u (car e)) (v (cadr e)) (cap (caddr e)))\n        (vector-set! g u (cons (cons v cap) (vector-ref g u))))) edges)\n    (vector->list g)))\n(let ((edges '((0 1 10) (0 2 5) (1 2 15) (1 3 9) (2 3 10))))\n  (ops/max-flow (graph-from-edges edges 4) 0 3))" :note "Build a graph from an edge list, then solve max-flow")
    (:dialect "motoi" :tier "expert" :code "(define (find-bottleneck-edges graph source sink flow-threshold)\n  (let ((max-flow-val (ops/max-flow graph source sink)))\n    (if (< max-flow-val flow-threshold) \n      (escalate 'insufficient-capacity (list 'max-flow max-flow-val 'required flow-threshold))\n      (list 'max-flow max-flow-val 'bottleneck-free (> max-flow-val (* 1.5 flow-threshold))))))\n(find-bottleneck-edges '((0 . ((1 . 10) (2 5))) (1 . ((3 . 9))) (2 . ((3 . 10)))) 0 3 15)" :note "Check whether max-flow meets a threshold; escalate if insufficient")
  )
  :caveats ("Edge capacities must be non-negative; negative or non-numeric capacities cause undefined behavior." "The graph must not have parallel edges (multiple edges between the same pair of nodes). If present, combine their capacities first." "The source and sink must be distinct; source = sink produces 0 flow." "The verb returns the scalar maximum-flow value, not the flow on each edge. To find the actual flow decomposition, you must track the residual graph during the algorithm." "Very large graphs or capacities may hit the fuel budget; the time complexity is O(V·E²) in the worst case.")
  :drawbacks ("Does not return the actual flow on each edge; if you need the flow decomposition, you must implement a custom version." "Edmonds–Karp is slower than faster algorithms like Dinic's or push-relabel, but guarantees polynomial time." "No support for minimum-cost flow, flow with lower bounds, or multi-commodity flow." "If the graph is dense or capacities are very large, memory usage and time can be prohibitive." "No support for weighted edges (capacity only); for minimum-cost variants, use external solvers or implement separately.")
  :usecases ("Network capacity planning: find the maximum amount of data/goods that can flow through a network." "Matching problems: convert to flow (source → people → jobs → sink) to find maximum matching." "Project scheduling: model resource constraints as edges with capacities." "Image segmentation (graph cuts): use max-flow to partition pixels." "Airline routing: find maximum passenger capacity from origin to destination given flight capacities.")
  :related ("ops/markov" "ops/lp-solve" "ops/dijkstra" "ops/bellman-ford")
  :learn (:concept "Maximum flow: augmenting paths and the residual graph. By max-flow min-cut, bottlenecks in the network are revealed." :prerequisites ("Graph basics: nodes, directed edges, adjacency lists" "Understanding of capacity constraints and flow conservation" "Familiarity with breadth-first search (BFS)") :progression "After ops/max-flow, explore matching problems (bipartite matching via flow) or minimum-cost flow for weighted variants. See also ops/dijkstra for shortest-path applications.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A network planner needs the max throughput from source to sink."
                 :program "(define g '((0 . ((1 . 10) (2 . 5))) (1 . ((2 . 15) (3 . 9))) (2 . ((3 . 10)))))\n(ops/max-flow g 0 3)"
                 :explanation "Compute Ford-Fulkerson max flow. Returns bottleneck-limited flow value."
                 :meta "Reach for max-flow over greedy path selection; greedy misses augmenting paths.")
                (:eng "Log flow value alongside network topology hash."
                 :math "Max ∫ = Min cut."
                 :cs "O(VE²) Edmonds-Karp."))
  :row-3-dimension ((:setup "capacity-constrained routing: same shape in networks, in bipartite matching, in image segmentation"
                     :rungs ((:domain "ops" :code "(ops/max-flow '((0 . ((1 . 10)))) 0 1)")
                             (:domain "match" :code "(define (match-count a b) 3)\n(match-count '(a) '(b))")
                             (:domain "segment" :code "(define (segment-cut img) 'cut)\n(segment-cut 'image)"))
                     :explanation "Rung 1 routes network flow. Rung 2 counts bipartite matches. Rung 3 segments an image. All reduce to max-flow."
                     :meta "Max flow is universal."
                    )
                    (:eng "Networks, matching, and vision share it."
                     :math "Max-flow min-cut."
                     :cs "Same solver."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Max flow ≥ 0."
                 :program "(>= (ops/max-flow '((0 . ((1 . 5)))) 0 1) 0)"
                 :invariant "flow ≥ 0"
                 :meta "Non-negativity. Falsified by any negative flow. See book-of-math on flow networks.")
                (:eng "Regression: non-negative flow."
                 :math "Capacity is non-negative."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/max-flow returns the maximum flow value."
                     :composition "(define sources '(0 1 2))\n(define g '((0 . ((1 . 5))) (1 . ((2 . 3))) (2 . ())))\n(map (lambda (s) (list s (ops/max-flow g s 2))) sources)"
                     :emergent "A multi-source analysis: chaining max-flow over sources yields per-source capacities."
                     :meta "This is the same family as any per-source analysis. Cross-ref book-of-composition on network analysis.")
                    (:eng "Multi-source planning uses this."
                     :math "Per-source flow."
                     :cs "Map.")))

(verb
  :name "ops/mip-solve"
  :library "ops"
  :kind "meta"
  :signature "(ops/mip-solve constraints objective [opts]) -> solution"
  :summary "Solves a mixed-integer programming problem: maximize/minimize a linear objective subject to linear constraints where some variables must be integers."
  :explanation "Mixed-integer programming (MIP) extends linear programming by requiring some decision variables to take integer values. This is essential for discrete choices (buy/don't-buy, assign to facility X or Y) combined with continuous quantities. The solver uses branch-and-bound internally: it solves continuous relaxations and recursively branches on fractional integer variables until finding an integer-feasible optimum or proving none exists within the fuel budget. The result is deterministic on a given device."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((soln (ops/mip-solve\n  (list (list 1 1 '<= 5))  ; x + y ≤ 5\n  (list 3 2)               ; maximize 3x + 2y\n  (list ':integers (list 0 1))))) ; x, y are integers\n  (display soln))" :note "Solves a small integer knapsack: maximize profit with integer quantities, total weight ≤ 5.")
    (:dialect "motoi" :tier "intermediate" :code "(define (facility-assign costs demands fixed-cost)\n  (ops/mip-solve\n    (append\n      (map (lambda (d) (list 1 '<= d)) demands)  ; demand constraints\n      (list (list -100 -100 '<= 0)))              ; capacity slack\n    (map (lambda (c) (+ c fixed-cost)) costs)    ; total cost\n    (list ':integers (list 0 1) ':min? #t)))\n(facility-assign (list 50 60) (list 10 15))" :note "Facility location: decide which depots to open (binary 0/1) and size them to meet demand at minimum cost.")
    (:dialect "motoi" :tier "expert" :code "(define (fold-left f init xs)\n  (let loop ((xs xs) (acc init))\n    (if (null? xs) acc (loop (cdr xs) (f acc (car xs))))))\n(define (iota n)\n  (let loop ((i 0) (acc '()))\n    (if (= i n) (reverse acc) (loop (+ i 1) (cons i acc)))))\n(define (production-schedule demand unit-cost holding-cost initial)\n  (let* ((periods (length demand))\n         (produce (map (lambda (i) (list ':int 0 100)) (iota periods)))\n         (inventory (cons initial (map (lambda (i) 0) (iota periods)))))\n    (ops/mip-solve\n      (map (lambda (t)\n             (list 1 1 '= (list-ref demand t)))  ; balance: inventory(t-1) + produce(t) = demand(t) + inventory(t)\n             (iota periods))\n      (fold-left (lambda (cost t)\n                   (+ cost\n                      (* unit-cost (list-ref produce t))\n                      (* holding-cost (list-ref inventory (+ t 1)))))\n                 0 (iota periods))\n      (list ':integers (list-ref produce 0) ':min? #t))))\n(production-schedule (list 10 20 15) 5 2 0)" :note "Multi-period production: decide integer production quantities each period to meet demand while minimizing production + holding costs.")
  )
  :caveats ("Requires some variables to be declared integer; unmarked variables stay continuous." "Escalates 'infeasible if no solution exists (constraints contradict)." "Escalates 'unbounded if objective is unbounded below (minimization) or above (maximization)." "Escalates 'fuel-budget if branch-and-bound exhausts time/memory before proving optimality." "Solution is optimal only if no escalation occurs.")
  :drawbacks ("MIP is NP-hard; very large or dense problems may not solve within fuel budget." "If most variables should be integer, consider using ops/branch-bound directly for more control." "For purely continuous problems, ops/lp-solve is cheaper.")
  :usecases ("Facility location and network design (binary open/close decisions with flows)." "Knapsack and bin-packing (discrete item selection)." "Production scheduling (integer batch sizes or period counts)." "Vehicle routing (integer vehicle assignments, time-window sequencing)." "Portfolio optimization with discrete constraints (buy whole units of assets).")
  :related ("ops/branch-bound" "ops/lp-solve" "ops/simplex" "ops/knapsack")
  :learn (:concept "Branch-and-bound tree search on relaxed linear subproblems to find integer-feasible optima." :prerequisites ("ops/lp" "ops/simplex") :progression "After mastering MIP, explore ops/branch-bound for manual control, or ops/knapsack for specialized discrete problems.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A facility planner must decide which depots to open (0/1) and how much to ship (continuous)."
                 :program "(ops/mip-solve (list (list 1 1 '<= 5)) (list 3 2) (list ':integers (list 0 1)))"
                 :explanation "Solve a mixed-integer program. Returns the integer-feasible optimum."
                 :meta "Reach for mip-solve when some vars must be integer; ops/lp-solve treats them continuous.")
                (:eng "Log the escalations: 'infeasible, 'unbounded, 'fuel-budget."
                 :math "Branch-and-bound with LP relaxation."
                 :cs "NP-hard worst case."))
  :row-3-dimension ((:setup "mixed continuous + discrete optimization: same shape in facility location, in cutting stock, in project selection"
                     :rungs ((:domain "ops" :code "(ops/mip-solve '((1 1 <= 5)) '(3 2) '(:integers (0 1)))")
                             (:domain "cutting" :code "(define (cut-plan lengths) 'plan)\n(cut-plan '(3 5))")
                             (:domain "project" :code "(define (select-projects p budget) 'selection)\n(select-projects '(a b) 100)"))
                     :explanation "Rung 1 solves a general MIP. Rung 2 solves cutting stock. Rung 3 selects projects. All are 0/1 + continuous decisions."
                     :meta "Mixed integer optimization is universal."
                    )
                    (:eng "Logistics, manufacturing, and finance share it."
                     :math "IP + LP relaxation."
                     :cs "Same B&B kernel."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Returns feasible integer or escalation."
                 :program "(define r (ops/mip-solve '((1 <= 5)) '(1) '(:integers (0))))\n(or (pair? r) (symbol? r))"
                 :invariant "result is feasible or escalation"
                 :meta "Contract preservation. Falsified by silent garbage. See book-of-code on total functions.")
                (:eng "Regression: contract type."
                 :math "Fail-loud contract."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/mip-solve returns a mixed-integer optimum."
                     :composition "(define specs '(s1 s2 s3))\n(map ops/mip-solve specs)"
                     :emergent "A scenario portfolio: chaining over specs yields per-scenario decisions."
                     :meta "This is the same family as scenario planning. Cross-ref book-of-composition on scenarios.")
                    (:eng "Multi-region facility planning uses this."
                     :math "Per-scenario optimum."
                     :cs "Map.")))

(verb
  :name "ops/mm1"
  :library "ops"
  :kind "meta"
  :signature "(ops/mm1 lambda mu) -> (list rho L Lq W Wq)"
  :summary "Computes steady-state metrics for an M/M/1 queue: utilization ρ, average customers L, queue length Lq, wait time W, and queueing time Wq."
  :explanation "M/M/1 models a single-server queue with Poisson arrivals (rate λ) and exponential service times (rate μ). It's the simplest queueing model and forms the foundation for understanding congestion. When ρ = λ/μ < 1 (arrival rate less than service capacity), the queue reaches a stable distribution and metrics converge to closed-form formulas: L = ρ/(1−ρ), W = 1/(μ−λ), etc. If ρ ≥ 1, the queue is unstable (grows without bound) and the solver escalates 'infeasible."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define (queue-stats arrival-rate service-rate)\n  (ops/mm1 arrival-rate service-rate))\n(queue-stats 3 5)" :note "3 arrivals/hour, 5 customers served/hour → ρ=0.6, average L≈1.5 customers in system.")
    (:dialect "motoi" :tier "intermediate" :code "(define (check-capacity demand service-rate)\n  (let ((metrics (ops/mm1 demand service-rate)))\n    (let ((rho (list-ref metrics 0))\n          (W (list-ref metrics 3)))\n      (if (> rho 0.8)\n        (list 'overload rho)\n        (list 'ok (round W 2))))))\n(check-capacity 4 6)" :note "Service level check: if utilization > 80%, flag overload; else return average wait time rounded to 2 decimals.")
    (:dialect "motoi" :tier "expert" :code "(define (find-service-rate target-wait-time arrival-rate)\n  (let loop ((mu arrival-rate))\n    (if (>= mu (* 10 arrival-rate))\n      'too-expensive\n      (let ((W (list-ref (ops/mm1 arrival-rate mu) 3)))\n        (if (<= W target-wait-time)\n          (list 'feasible mu)\n          (loop (+ mu 0.1)))))))\n(find-service-rate 2.0 5)" :note "Iterative search: find minimum service rate μ that keeps average wait time W ≤ 2.0 for λ=5 arrivals/hour.")
  )
  :caveats ("Assumes Poisson arrivals and exponential service; real systems often violate these (M/G/1 is more general but not provided)." "Requires λ < μ strictly; escalates 'infeasible if ρ ≥ 1." "Metrics assume steady-state; transient (startup) behavior is ignored." "All times are in the same units as the input rates (e.g., if λ and μ are per hour, W is in hours).")
  :drawbacks ("Single server is restrictive; use ops/mmc for multi-server queues." "Very sensitive to assumption violations; measured data often shows heavier-tailed service times." "Does not model priorities, batch arrivals, or reneging (impatient departures).")
  :usecases ("Estimating wait times at a single checkout lane or service counter." "Baseline capacity planning (what service rate is needed to meet a target wait time?)." "Comparing single-server vs. multi-server configurations (pair with ops/mmc)." "Call center staffing (single-skill agent as 'server', incoming calls as arrivals)." "Disk I/O or network packet processing (one queue per resource).")
  :related ("ops/mmc" "ops/littles-law" "ops/mmc-servers-for" "ops/erlang-c" "ops/erlang-b")
  :learn (:concept "Exponential queues and Little's Law: how arrival rate, service rate, and queue depth inter-relate." :prerequisites ("stat/mean" "stat/variance") :progression "After M/M/1, learn ops/mmc to handle multiple servers, then ops/erlang-c and ops/erlang-b for more realistic models.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A single-server queue analyst needs steady-state ρ, L, W."
                 :program "(ops/mm1 3 5)"
                 :explanation "3 arrivals/hour, 5 service/hour → ρ=0.6, average customers L, wait W."
                 :meta "Reach for M/M/1 for single-server; use M/M/c for multi-server.")
                (:eng "Log ρ; if ≥ 1 the system is unstable."
                 :math "M/M/1 closed forms."
                 :cs "O(1)."))
  :row-3-dimension ((:setup "single-server Poisson queue: same shape in checkout lane, in ticket window, in disk I/O"
                     :rungs ((:domain "ops" :code "(ops/mm1 3 5)")
                             (:domain "checkout" :code "(define (checkout-wait rate service) 2)\n(checkout-wait 3 5)")
                             (:domain "disk" :code "(define (disk-latency rate throughput) 0.05)\n(disk-latency 100 200)"))
                     :explanation "Rung 1 gives queue metrics. Rung 2 estimates checkout wait. Rung 3 estimates disk latency. All are M/M/1 instantiations."
                     :meta "M/M/1 is universal."
                    )
                    (:eng "Same model, different substrate."
                     :math "M/M/1 closed forms."
                     :cs "Same solver."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "For ρ < 1, L is finite."
                 :program "(let ((r (ops/mm1 3 5))) (< (list-ref r 1) 1e6))"
                 :invariant "ρ < 1 ⟹ L finite"
                 :meta "Stability condition. Falsified by unstable-system return. See book-of-math on M/M/1.")
                (:eng "Regression: stable system has finite L."
                 :math "L = ρ/(1-ρ) finite iff ρ<1."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/mm1 returns steady-state queue metrics."
                     :composition "(define lam 3)\n(define mus '(4 5 6 7))\n(map (lambda (mu) (list mu (ops/mm1 lam mu))) mus)"
                     :emergent "A service-rate sensitivity: chaining mm1 over μ yields how metrics respond."
                     :meta "This is the same family as any capacity-planning sweep. Cross-ref book-of-composition on sweeps.")
                    (:eng "Right-sizing a single-server system uses this."
                     :math "Metrics as functions of μ."
                     :cs "Map + inspect.")))

(verb
  :name "ops/mmc"
  :library "ops"
  :kind "meta"
  :signature "(ops/mmc lambda mu c) -> (list rho L Lq W Wq Pw)"
  :summary "Computes steady-state metrics for an M/M/c queue: c parallel servers, Poisson arrivals (rate λ), exponential service (rate μ per server), and returns utilization, customer counts, wait times, and blocking probability Pw."
  :explanation "M/M/c generalizes M/M/1 to c identical parallel servers. Customers arrive as a Poisson stream and join the shortest queue (or any queue equivalently, in steady state). The key new metric is Pw (blocking probability, from Erlang-C formula), which is the probability a newly arriving customer must wait in queue (all servers busy). With multiple servers, much higher utilization is achievable before queueing becomes severe. If ρ = λ/(c·μ) ≥ 1, the system is unstable and the solver escalates 'infeasible."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define (multi-server-queue arrival service servers)\n  (ops/mmc arrival service servers))\n(multi-server-queue 6 4 2)" :note "6 arrivals/hour, 4 customers/hour per server, 2 servers → ρ=0.75, Pw≈0.375 (37.5% wait).")
    (:dialect "motoi" :tier "intermediate" :code "(define (service-level-check lambda mu target-wait)\n  (let loop ((c 1))\n    (if (> c 20)\n      'infeasible\n      (let ((metrics (ops/mmc lambda mu c)))\n        (let ((Wq (list-ref metrics 4)))\n          (if (<= Wq target-wait)\n            (list 'servers c 'Wq (round Wq 3))\n            (loop (+ c 1))))))))\n(service-level-check 10 5 0.5)" :note "Find minimum server count to meet a wait-time SLA (e.g., ≤ 0.5 hours average queueing time).")
    (:dialect "motoi" :tier "expert" :code "(define (cost-optimal-servers lambda mu cost-per-server cost-per-wait-hour)\n  (let loop ((c 1) (best-c 1) (best-cost 999999))\n    (if (> c 50)\n      (list 'optimal best-c 'cost best-cost)\n      (let* ((metrics (ops/mmc lambda mu c))\n             (Wq (list-ref metrics 4))\n             (total-cost (+ (* c cost-per-server) (* lambda cost-per-wait-hour Wq))))\n        (if (< total-cost best-cost)\n          (loop (+ c 1) c total-cost)\n          (loop (+ c 1) best-c best-cost))))))\n(cost-optimal-servers 8 3 20 50)" :note "Balance staffing cost (£20/server) against customer wait cost (£50/hour per customer waiting). Find the c that minimizes total.")
  )
  :caveats ("Assumes Poisson arrivals, exponential service, and ample queue capacity; violations degrade accuracy." "Requires ρ = λ/(c·μ) < 1 strictly; escalates 'infeasible otherwise." "Erlang-C formula is sensitive to rounding; results converge to M/M/1 as c → ∞." "All time units must be consistent (e.g., arrivals and service rates both per hour)." "Pw only models blocking in an infinite-queue system; does not include explicit call-dropping or reneging.")
  :drawbacks ("More costly computationally than ops/mm1 due to factorial terms in Erlang-C." "For very large c or λ/μ close to c, numerical instability may occur." "Does not model skill-based routing (only identical servers); see specialized systems for that." "If you know target Wq and want to find c, use ops/mmc-servers-for instead (faster).")
  :usecases ("Call center capacity planning: arrivals = incoming calls, c = agents, μ = mean handling time." "Hospital triage: arrivals = patients, c = staff, service = medical assessment." "Parallel checkout lanes: arrivals = customers, c = lanes, service = cashier throughput." "Load-balancing across web servers: arrivals = requests, c = servers, service = response time." "IT help desk: arrivals = tickets, c = specialists, service = resolution rate.")
  :related ("ops/mm1" "ops/mmc-servers-for" "ops/erlang-c" "ops/erlang-b" "ops/littles-law")
  :learn (:concept "Multi-server queueing reduces blocking probability but incurs staffing cost; trade-off optimization." :prerequisites ("ops/mm1" "ops/erlang-c") :progression "Use ops/mmc-servers-for to automate the search for optimal c, then explore ops/erlang-b for loss systems (no queue).")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A call-center planner needs ρ, L, wait W for a c-agent operation."
                 :program "(ops/mmc 6 4 2)"
                 :explanation "6 arrivals/hour, 4 service/hour per server, c=2 → returns steady-state metrics."
                 :meta "Reach for M/M/c for multi-server; use M/M/1 for one.")
                (:eng "Log Pw against SLA threshold."
                 :math "M/M/c closed forms."
                 :cs "Recursive Erlang-C."))
  :row-3-dimension ((:setup "multi-server Poisson queue: same shape in call centers, in ER triage, in web servers"
                     :rungs ((:domain "ops" :code "(ops/mmc 4 3 2)")
                             (:domain "triage" :code "(define (triage-wait patients staff) 1)\n(triage-wait 5 3)")
                             (:domain "web" :code "(define (web-wait req workers) 0.1)\n(web-wait 100 8)"))
                     :explanation "Rung 1 gives queue metrics. Rung 2 estimates triage wait. Rung 3 estimates web wait. All are M/M/c."
                     :meta "Multi-server queue is universal."
                    )
                    (:eng "Same model, different substrate."
                     :math "M/M/c."
                     :cs "Same solver."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "For c=1, M/M/c reduces to M/M/1."
                 :program "(let ((m1 (ops/mm1 3 5)) (mc (ops/mmc 3 5 1))) #t)"
                 :invariant "M/M/c with c=1 matches M/M/1"
                 :meta "Special case consistency. Falsified by discrepancy. See book-of-math on queueing.")
                (:eng "Regression: single-server special case."
                 :math "M/M/1 ⊂ M/M/c."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/mmc returns multi-server queue metrics."
                     :composition "(define lam 4) (define mu 3)\n(map (lambda (c) (list c (ops/mmc lam mu c))) '(2 3 4 5))"
                     :emergent "A staffing sweep: chaining mmc over c yields the wait-vs-staff curve."
                     :meta "This is the same family as any staffing sensitivity. Cross-ref book-of-composition on staffing.")
                    (:eng "Call center scoping walks this."
                     :math "Metrics(·, c) decreasing."
                     :cs "Map.")))

(verb
  :name "ops/mmc-servers-for"
  :library "ops"
  :kind "meta"
  :signature "(ops/mmc-servers-for lambda mu target-Wq) -> c"
  :summary "Finds the minimum number of servers c such that average queueing time Wq ≤ target-Wq in an M/M/c system."
  :explanation "Rather than computing metrics for a fixed c (as ops/mmc does), this verb searches for the right c. Given arrival rate λ, per-server service rate μ, and a target average queueing delay (target-Wq), it iteratively increases c until Wq drops to or below the target. This is convenient for capacity planning: specify your service-level goal and get the minimum headcount needed."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define (staff-for-sla arrival service sla)\n  (ops/mmc-servers-for arrival service sla))\n(staff-for-sla 10 4 1.0)" :note "10 arrivals/hour, 4 served/hour each, want Wq ≤ 1 hour → returns e.g. c=3 servers.")
    (:dialect "motoi" :tier "intermediate" :code "(define (budget-feasible arrival service sla cost-per-server budget)\n  (let ((c (ops/mmc-servers-for arrival service sla)))\n    (let ((total (* c cost-per-server)))\n      (if (<= total budget)\n        (list 'feasible c total)\n        (list 'over-budget c total)))))\n(budget-feasible 15 5 0.5 1000)" :note "Find required servers for SLA, check if payroll budget accommodates it.")
    (:dialect "motoi" :tier "expert" :code "(define (adaptive-sla-levels arrival service budgets)\n  (map (lambda (budget)\n         (let loop ((sla 0.1))\n           (if (> sla 10)\n             (list ':budget budget ':infeasible)\n             (let* ((c (ops/mmc-servers-for arrival service sla))\n                    (cost (* c 50)))\n               (if (<= cost budget)\n                 (list ':budget budget ':sla sla ':servers c ':cost cost)\n                 (loop (+ sla 0.1)))))))\n       (list 500 1000 1500 2000)))\n(adaptive-sla-levels 12 4 (list 500 1000))" :note "For each budget tier, find the best SLA (Wq) achievable. Trade tighter wait times against staffing cost.")
  )
  :caveats ("target-Wq must be positive; negative or zero escalates 'infeasible." "If λ ≥ μ (traffic intensity ≥ 1 per server), no finite c satisfies the constraint; escalates 'infeasible." "Returns the minimum c; may be conservative if you prioritize cost over service." "Does not account for non-Poisson or non-exponential distributions (same assumption caveat as ops/mmc).")
  :drawbacks ("Requires solving multiple M/M/c instances; slower than directly computing ops/mmc for a known c." "Only optimizes on Wq; ignores other metrics (utilization, customer count, cost)." "If target-Wq is very tight (e.g., 0.001 hours), c becomes very large and may be impractical." "Does not model diminishing returns (adding one more server to a 20-server team has less benefit).")
  :usecases ("SLA-driven staffing: 'We must answer within 2 minutes'—how many agents?" "Service level agreements: uptime and responsiveness targets translate to c." "Capacity planning for predictable workloads (e.g., seasonal call volumes)." "Comparing cost vs. service: run for multiple budgets to see SLA trade-off." "Baseline for hiring: union contracts or regulations may mandate minimum c.")
  :related ("ops/mmc" "ops/mm1" "ops/erlang-c" "ops/littles-law")
  :learn (:concept "Inverse queueing: specify the service level you want, solve for resource count." :prerequisites ("ops/mmc" "ops/erlang-c") :progression "After finding c with this verb, use ops/mmc to confirm metrics and understand the trade-offs in detail.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A manager needs the minimum agent count to hit an SLA of Wq ≤ 1 hour."
                 :program "(ops/mmc-servers-for 10 4 1.0)"
                 :explanation "Search for minimum c satisfying the wait target."
                 :meta "Reach for mmc-servers-for over hand-rolled iteration; it's the canonical inverse-queue solver.")
                (:eng "Log c and confirm with ops/mmc."
                 :math "Binary search over c."
                 :cs "O(log c · Erlang-C)."))
  :row-3-dimension ((:setup "inverse capacity from service target: same shape in staffing, in throughput sizing, in bandwidth allocation"
                     :rungs ((:domain "ops" :code "(ops/mmc-servers-for 10 4 1.0)")
                             (:domain "throughput" :code "(define (throughput-for-slo rate slo) 8)\n(throughput-for-slo 100 0.05)")
                             (:domain "bandwidth" :code "(define (bandwidth-for-loss target) 100)\n(bandwidth-for-loss 0.01)"))
                     :explanation "Rung 1 finds min c. Rung 2 finds min throughput. Rung 3 finds min bandwidth. All invert a metric-target to a capacity."
                     :meta "Inverse capacity solving is universal."
                    )
                    (:eng "Same shape across capacity planning."
                     :math "arg min c s.t. metric(c) ≤ target."
                     :cs "Bisection."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Increasing target relaxes constraint: c(target₁) ≥ c(target₂) if target₁ < target₂."
                 :program "(define c1 (ops/mmc-servers-for 10 4 0.5))\n(define c2 (ops/mmc-servers-for 10 4 2.0))\n(>= c1 c2)"
                 :invariant "smaller target ⟹ larger c"
                 :meta "Monotonicity. Falsified by any inversion. See book-of-math on inverse monotonicity.")
                (:eng "Regression: tighter target → more servers."
                 :math "Monotone inverse."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/mmc-servers-for returns min c."
                     :composition "(define lam 10) (define mu 4)\n(define targets '(0.1 0.5 1.0 2.0))\n(map (lambda (t) (list t (ops/mmc-servers-for lam mu t))) targets)"
                     :emergent "An SLA-vs-staffing table: chaining servers-for over targets yields the cost-of-service curve."
                     :meta "This is the same family as capacity-cost analysis. Cross-ref book-of-composition on cost curves.")
                    (:eng "Budget-tier planning uses this table."
                     :math "c(target) decreasing."
                     :cs "Map.")))

(verb
  :name "ops/newsvendor"
  :library "ops"
  :kind "meta"
  :signature "(ops/newsvendor mu sigma cost price salvage-value) -> (list Q* profit-expected)"
  :summary "Solves the newsvendor (stochastic inventory) problem: computes the optimal order quantity Q* that maximizes expected profit when demand is uncertain (normally distributed with mean μ and std dev σ), purchase cost is fixed, selling price is known, and unsold units salvage for less."
  :explanation "The newsvendor problem is a classic: buy inventory before demand is known, sell at a higher price, and salvage excess at a loss. Order too little and lose sales; too much and waste money on leftover stock. The optimal Q* = μ + z·σ, where z is the critical-ratio fractile: z = F⁻¹((price − cost) / (price − salvage)). Intuitively, z balances the cost of shortage against the cost of overage. The solver returns Q* and the expected profit under optimal ordering."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define (newsvendor-order mean std cost price salvage)\n  (ops/newsvendor mean std cost price salvage))\n(newsvendor-order 100 20 8 15 2)" :note "Demand ~ N(100, 20); cost £8, sell for £15, salvage £2 → optimal order Q*≈110 units.")
    (:dialect "motoi" :tier "intermediate" :code "(define (seasonal-stock demand-forecast std unit-cost retail salvage)\n  (let* ((result (ops/newsvendor demand-forecast std unit-cost retail salvage))\n         (Q* (list-ref result 0))\n         (profit (list-ref result 1)))\n    (list ':order Q* ':expected-profit (round profit 2))))\n(seasonal-stock 500 80 5 12 1)" :note "Holiday season: expected demand 500 units (σ=80), cost/profit/salvage given. Order Q* to maximize expected profit.")
    (:dialect "motoi" :tier "expert" :code "(define (price-elasticity-optimization demand-mean demand-sigma cost base-price salvage)\n  (let loop ((price base-price) (best-price base-price) (best-profit 0))\n    (if (> price (* 1.5 base-price))\n      (list ':optimal-price best-price ':profit best-profit)\n      (let* ((result (ops/newsvendor demand-mean demand-sigma cost price salvage))\n             (Q* (list-ref result 0))\n             (profit (list-ref result 1)))\n        (if (> profit best-profit)\n          (loop (+ price 0.5) price profit)\n          (loop (+ price 0.5) best-price best-profit))))))\n(price-elasticity-optimization 200 40 10 25 5)" :note "Search over selling prices to find the price that maximizes expected profit (demand may depend on price in reality; here demand is fixed).")
  )
  :caveats ("Assumes demand is normally distributed; real distributions may be skewed, bounded, or multi-modal." "Cost structure must satisfy: salvage < cost < price (otherwise critical ratio is out of (0,1) and escalates 'infeasible)." "Expected profit formula assumes continuous demand; for discrete units, use simulation (not provided)." "Solution is optimal for the single-period newsvendor problem; does not account for future seasons or inventory carry-forward." "σ must be positive; zero std dev (perfectly known demand) is not typical for this problem.")
  :drawbacks ("Very sensitive to the assumed distribution and parameters; forecast errors compound." "Does not model markdowns, stockouts (lost sales or backorders), or perishability explicitly." "If you can adjust price after seeing demand (or order multiple times), more sophisticated models (dynamic programming, Bayesian learning) apply." "For very high σ (high uncertainty), Q* may be unreasonably large; consider ops/eoq for steady-state inventory instead.")
  :usecases ("Newspaper/magazine print runs: title perishes quickly, salvage is scrap value." "Fashion retail: seasonal clothing, markdowns and salvage at season end." "Bake-shop daily orders: bread/pastries perish, unsold units discounted (if modeled via salvage)." "Semiconductor capacity planning: fabs commit to wafer production before final demand known." "Agricultural commodity trading: harvest quantity is fixed, price varies, can sell forward or spot.")
  :related ("ops/newsvendor-fractile" "ops/eoq" "ops/reorder-point" "ops/safety-stock" "ops/inventory-cost")
  :learn (:concept "Balancing shortage and overage costs through a critical-ratio threshold." :prerequisites ("stat/mean" "stat/sd-sample") :progression "After understanding newsvendor, learn ops/eoq for steady-state (recurring) inventory, and ops/reorder-point for multi-period ordering.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A pop-up retailer must order stock once, before demand is known."
                 :program "(ops/newsvendor 100 20 8 15 2)"
                 :explanation "Demand ~ N(100, 20), cost 8, price 15, salvage 2. Returns Q* and expected profit."
                 :meta "Reach for newsvendor over EOQ for single-period stochastic problems; EOQ is for steady-state.")
                (:eng "Log Q* and expected profit for record."
                 :math "Q* = μ + z·σ."
                 :cs "O(1) closed form."))
  :row-3-dimension ((:setup "single-period stochastic decision: same shape in newsvendor, in bidding, in seasonal capacity"
                     :rungs ((:domain "ops" :code "(ops/newsvendor 100 20 8 15 2)")
                             (:domain "bidding" :code "(define (bid-amount value uncertainty) 80)\n(bid-amount 100 10)")
                             (:domain "capacity" :code "(define (peak-capacity demand-forecast) 500)\n(peak-capacity 400)"))
                     :explanation "Rung 1 orders newspapers. Rung 2 sets bid. Rung 3 sets seasonal capacity. All are single-period decisions under uncertainty."
                     :meta "Single-period stochastic is universal."
                    )
                    (:eng "Auctions, retail, and capacity planning share it."
                     :math "Critical-fractile."
                     :cs "Same closed form."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Q* is non-negative."
                 :program "(let ((r (ops/newsvendor 100 20 8 15 2))) (>= (car r) 0))"
                 :invariant "Q* ≥ 0"
                 :meta "Non-negativity. Falsified only by broken formula. See book-of-math on newsvendor.")
                (:eng "Regression: Q* non-negative."
                 :math "Positive order quantity."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/newsvendor returns (Q*, expected profit)."
                     :composition "(define scenarios '((100 20) (200 40)))\n(map (lambda (s) (ops/newsvendor (car s) (cadr s) 8 15 2)) scenarios)"
                     :emergent "A scenario table: chaining newsvendor over forecasts yields per-forecast Q* + profit."
                     :meta "This is the same family as any scenario table. Cross-ref book-of-composition on scenarios.")
                    (:eng "Multi-forecast planning uses this."
                     :math "Per-scenario Q*."
                     :cs "Map.")))

(verb
  :name "ops/newsvendor-fractile"
  :library "ops"
  :kind "meta"
  :signature "(ops/newsvendor-fractile cost price salvage) -> z"
  :summary "Computes the critical-ratio fractile z ∈ (0, 1) that determines optimal stocking in the newsvendor problem: z = (price − cost) / (price − salvage)."
  :explanation "The critical ratio quantifies the trade-off: a higher z (closer to 1) means shortage cost dominates, so order more aggressively; a lower z (closer to 0) means overage cost dominates, so be conservative. The value z is then used as a percentile in the demand distribution to find Q*. If the cost structure is nonsensical (e.g., salvage ≥ cost, or cost ≥ price), z falls outside (0, 1) and the solver escalates 'infeasible."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define (critical-ratio cost price salvage)\n  (ops/newsvendor-fractile cost price salvage))\n(critical-ratio 5 10 1)" :note "Cost £5, sell £10, salvage £1 → z = (10−5)/(10−1) = 5/9 ≈ 0.556.")
    (:dialect "motoi" :tier "intermediate" :code "(define (sensitivity-to-salvage cost price salvage-range)\n  (map (lambda (salvage)\n         (list salvage (ops/newsvendor-fractile cost price salvage)))\n       salvage-range))\n(sensitivity-to-salvage 10 20 (list 1 5 8 15))" :note "As salvage increases (e.g., better resale market), z increases → order more aggressively.")
    (:dialect "motoi" :tier "expert" :code "(define (optimal-markup demand-std cost target-fractile)\n  (let loop ((price cost)\n             (best-price cost)\n             (best-diff 999))\n    (if (> price (* 3 cost))\n      (list ':price best-price ':fractile (ops/newsvendor-fractile cost best-price (/ cost 2)))\n      (let* ((salvage (/ cost 2))\n             (z (ops/newsvendor-fractile cost price salvage))\n             (diff (abs (- z target-fractile))))\n        (if (< diff best-diff)\n          (loop (+ price 0.1) price diff)\n          (loop (+ price 0.1) best-price best-diff))))))\n(optimal-markup 30 10 0.7)" :note "Search for markup (price) such that the critical ratio matches a target (e.g., 0.7 = 70% chance shortage is worse).")
  )
  :caveats ("Requires cost < price and salvage < cost; symmetric violations all escalate 'infeasible." "z is only meaningful in (0, 1); outside this range, the newsvendor problem degenerates (either always buy max or never buy)." "The fractile must be composed with a distribution-inverse function (e.g., normal CDF inverse) to produce Q*; this verb only returns z." "Salvage < cost < price assumes the merchant makes money on sales; if salvage > cost, overstocking is costless (unphysical).")
  :drawbacks ("Very simple algebraic formula; does not validate real-world feasibility of costs." "Does not account for demand correlation, seasonality, or external price movements." "If you want the full solution Q*, use ops/newsvendor directly (which calls this internally)." "Assumes demand is normally distributed; for other distributions, map z to the appropriate quantile yourself.")
  :usecases ("Sensitivity analysis: how does optimal stocking change if we can negotiate better salvage rates?" "Policy analysis: for a given markup, what is the implied risk balance (shortage vs. overage)?" "Benchmarking: compare your cost structure to industry best-practice fractiles (e.g., high-fashion may have z≈0.8, commodity may have z≈0.3)." "Training: teaching the newsvendor problem to non-technical stakeholders (fractile is intuitive: 'We'll stock to the 65th percentile').")
  :related ("ops/newsvendor" "ops/eoq" "stat/sd-sample")
  :learn (:concept "Critical ratio balances two types of cost (shortage vs. overage) into a single scalar threshold." :prerequisites ("ops/newsvendor") :progression "Use ops/newsvendor-fractile to understand the cost structure, then call ops/newsvendor to solve the full problem.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A buyer needs the critical fractile that decides how conservative to be."
                 :program "(ops/newsvendor-fractile 5 10 1)"
                 :explanation "z = (10−5)/(10−1) = 5/9. Order to the 55.5th percentile of demand."
                 :meta "Reach for fractile alone when only the cost-structure signal is needed; ops/newsvendor gives full Q*.")
                (:eng "Log z; z near 1 = aggressive stock."
                 :math "z = (p − c)/(p − s)."
                 :cs "Closed form."))
  :row-3-dimension ((:setup "cost-ratio determines percentile: same shape in newsvendor, in insurance premiums, in trading confidence"
                     :rungs ((:domain "ops" :code "(ops/newsvendor-fractile 5 10 1)")
                             (:domain "insurance" :code "(define (premium-fractile loss retention) 0.7)\n(premium-fractile 100 20)")
                             (:domain "trading" :code "(define (confidence-fractile edge risk) 0.6)\n(confidence-fractile 0.05 0.1)"))
                     :explanation "Rung 1 newsvendor fractile. Rung 2 insurance percentile. Rung 3 trading edge. Each is cost-ratio → fractile."
                     :meta "Cost-ratio→fractile is universal.")
                    (:eng "Finance, insurance, retail share it."
                     :math "Fractile from cost."
                     :cs "Ratio."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "z is between 0 and 1 for valid cost structures."
                 :program "(let ((z (ops/newsvendor-fractile 5 10 1))) (and (> z 0) (< z 1)))"
                 :invariant "salvage < cost < price ⟹ 0 < z < 1"
                 :meta "Bounded. Falsified by out-of-bounds. See book-of-math on critical ratios.")
                (:eng "Regression: z in (0, 1)."
                 :math "Bounded ratio."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/newsvendor-fractile returns z."
                     :composition "(define costs '((5 10 1) (8 20 3)))\n(map (lambda (t) (apply ops/newsvendor-fractile t)) costs)"
                     :emergent "A pricing spectrum: chaining over cost scenarios yields per-scenario fractile."
                     :meta "This is the same family as pricing-sensitivity tables. Cross-ref book-of-composition on pricing.")
                    (:eng "Pricing analysts use this over margin scenarios."
                     :math "z(margins)."
                     :cs "Map.")))

(verb
  :name "ops/pagerank"
  :library "ops"
  :kind "meta"
  :signature "(ops/pagerank edges [damping-factor]) -> (map: node -> score)"
  :summary "Computes PageRank scores over a directed graph, measuring the 'importance' of each node via its incoming link structure: high-authority nodes link from many nodes, especially other high-authority ones."
  :explanation "PageRank models a random walk on a directed graph: a hypothetical surfer follows outgoing edges with equal probability, and occasionally jumps to a random node (damping factor controls jump frequency, default 0.85). Nodes with many high-score predecessors accumulate high score. Mathematically, PageRank is the stationary distribution of this Markov chain, computed by power iteration. This is cheap (O(n·edges) per iteration) and robust, making it ideal for ranking web pages, academic papers, social influence, and other network centrality problems."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define (page-importance edges)\n  (ops/pagerank edges))\n(page-importance (list (list 'a 'b) (list 'b 'c) (list 'c 'a)))" :note "Simple cycle a→b→c→a: all nodes have equal rank (each has one outgoing edge, one incoming).")
    (:dialect "motoi" :tier "intermediate" :code "(define (take xs n)\n  (let loop ((xs xs) (n n) (acc '()))\n    (if (or (zero? n) (null? xs))\n        (reverse acc)\n        (loop (cdr xs) (- n 1) (cons (car xs) acc)))))\n(define (top-pages edges k)\n  (let ((ranks (ops/pagerank edges)))\n    (take (sort (map (lambda (node) (list node (hash-ref ranks node))) (hash-keys ranks))\n                      (lambda (x y) (> (cadr x) (cadr y))))\n          k)))\n(top-pages (list (list 'hub 'a) (list 'hub 'b) (list 'a 'c) (list 'b 'c) (list 'c 'hub)) 3)" :note "Return top 3 nodes by PageRank: hub nodes with many outgoing links and strong feedback score highest.")
    (:dialect "motoi" :tier "expert" :code "(define (damping-sensitivity edges damping-factors)\n  (map (lambda (d)\n         (list ':damping d ':ranks (ops/pagerank edges d)))\n       damping-factors))\n(damping-sensitivity\n  (list (list 'a 'b) (list 'a 'c) (list 'b 'd) (list 'd 'a))\n  (list 0.5 0.75 0.85 0.95))" :note "Compare PageRank under different damping: lower damping → flatter scores (more random jumping); higher → more structure.")
  )
  :caveats ("Requires edges to be a list of (from to) pairs; a node with no outgoing edges is a 'sink' and is handled by damping (random jump)." "Dangling nodes (no outgoing edges) receive rank from teleportation; this is intentional and important (e.g., pages with no external links still matter)." "Power iteration may not converge within fuel budget for very large graphs; check that your solver completes." "PageRank is sensitive to graph structure; adding a single high-authority node can dramatically shift scores." "Damping factor d ∈ [0, 1]: d=0 → uniform scores, d=1 → may not converge. Default d=0.85 is standard.")
  :drawbacks ("Ignores node attributes and edge weights (unweighted, undirected structure only)." "Very large graphs (millions of nodes) require distributed computing beyond this scope." "PageRank can be gamed (artificial link schemes); not suitable for high-stakes ranking without additional safeguards." "Assumes all outgoing edges are equally likely; real users often prefer certain links.")
  :usecases ("Web search: rank pages by link authority (original PageRank use case)." "Academic citations: rank papers by citation graph (more citations from highly-cited papers = higher score)." "Social networks: identify influential users (those followed by other influential users)." "Recommendation: find key products/content that bridge communities." "Network analysis: detect hubs (high out-degree) vs. authorities (high in-PageRank).")
  :related ("ops/markov" "ops/stationary" "ops/absorbing-steps")
  :learn (:concept "Eigenvector centrality via random walk: authority is recursive (high-authority inlinks matter most)." :prerequisites ("ops/markov" "linalg/eigenvalues") :progression "After PageRank, explore ops/absorbing-steps for expected time to absorption in Markov chains, or study HITS (hubs and authorities) for an alternative centrality model.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A search-ranker needs the authority score of each node in a citation graph."
                 :program "(define edges '((a b) (b c) (c a)))\n(ops/pagerank edges)"
                 :explanation "Compute PageRank via power iteration. Returns a per-node score."
                 :meta "Reach for pagerank over degree-count when authority (recursive) matters, not just link count.")
                (:eng "Log convergence residual for large graphs."
                 :math "Stationary distribution of the random walk."
                 :cs "O(iter · E)."))
  :row-3-dimension ((:setup "recursive centrality via power iteration: same shape in web ranking, in citation networks, in social influence"
                     :rungs ((:domain "ops" :code "(ops/pagerank '((a b)))")
                             (:domain "citation" :code "(define (citation-score paper) 0.7)\n(citation-score 'p)")
                             (:domain "social" :code "(define (influencer-score user) 0.9)\n(influencer-score 'u)"))
                     :explanation "Rung 1 ranks web pages. Rung 2 ranks papers. Rung 3 ranks influencers. All are eigenvector centrality on a directed graph."
                     :meta "Recursive centrality is universal.")
                    (:eng "Same algorithm across substrates."
                     :math "PR(u) = (1-d)/N + d·Σ PR(v)/L(v)."
                     :cs "Power iteration."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "PageRank scores sum to 1 (probability distribution)."
                 :program "(let ((r (ops/pagerank '((a b) (b a))))) #t)"
                 :invariant "Σ PR(u) = 1"
                 :meta "Distribution total. Falsified only by broken normalization. See book-of-math on PageRank.")
                (:eng "Regression: scores sum to 1."
                 :math "Stationary distribution."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/pagerank returns per-node authority."
                     :composition "(define edges '((a b) (b c) (c a) (d a)))\n(define ranks (ops/pagerank edges))\nranks"
                     :emergent "A ranked authority list: chaining pagerank with sort yields top influencers."
                     :meta "This is the same family as any influence ranking. Cross-ref book-of-composition on ranking.")
                    (:eng "Search engines and social platforms use this."
                     :math "argmax over PR."
                     :cs "Map + sort.")))

(verb
  :name "ops/reorder-point"
  :library "ops"
  :kind "meta"
  :signature "(ops/reorder-point daily-demand lead-time-days safety-stock) -> ROP"
  :summary "Computes the reorder point (ROP): the inventory level at which to place a new order so that stock arrives just as you run out, accounting for demand during the lead time and a safety buffer."
  :explanation "When you order, delivery takes L days (lead time). During those L days, you continue serving demand at rate d (demand per day). So you need d·L units to arrive when inventory hits zero. But demand can vary, and you want to avoid stockouts, so add a safety stock buffer. Thus ROP = d·L + safety_stock. This simple formula ensures you order before inventory depletes, with a cushion for unexpected demand spikes or delayed shipments."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(define (when-to-reorder demand leadtime safety)\n  (ops/reorder-point demand leadtime safety))\n(when-to-reorder 10 5 20)" :note "Demand 10 units/day, lead time 5 days, safety stock 20 units → ROP = 10·5 + 20 = 70 units. Reorder at 70-unit mark.")
    (:dialect "motoi" :tier "intermediate" :code "(define (reorder-schedule avg-demand lead-days demand-std service-level)\n  (let* ((safety (ops/safety-stock demand-std lead-days service-level))\n         (rop (ops/reorder-point avg-demand lead-days safety)))\n    (list ':reorder-point rop ':safety-stock safety)))\n(reorder-schedule 8 3 2 0.95)" :note "Demand ~ N(8, 2), lead time 3 days, want 95% service level → compute safety stock, then ROP.")
    (:dialect "motoi" :tier "expert" :code "(define (inventory-policy-table avg-demand lead-days demand-scenarios)\n  (let ((base-safety (ops/safety-stock (apply max (map (lambda (d) (caddr d)) demand-scenarios))\n                                        lead-days 0.9)))\n    (map (lambda (scenario)\n           (let* ((scenario-name (car scenario))\n                  (scenario-demand (cadr scenario))\n                  (scenario-std (caddr scenario))\n                  (rop (ops/reorder-point scenario-demand lead-days\n                         (ops/safety-stock scenario-std lead-days 0.9))))\n             (list ':scenario scenario-name ':rop rop)))\n         demand-scenarios)))\n(inventory-policy-table 5 2 (list (list 'low-season 4 1) (list 'peak 8 2)))" :note "Build a reorder policy table for multiple demand scenarios (e.g., seasonal): different ROP for each forecast.")
  )
  :caveats ("Assumes constant daily demand; spiky or seasonal demand requires scenario-based ROPs." "Lead time is fixed; variable lead times require a more sophisticated model (not provided)." "ROP assumes continuous monitoring; if inventory is checked weekly, actual trigger may differ." "Does not account for order batching (economic order quantity); ROP is independent of batch size." "Safety stock must be computed separately (use ops/safety-stock); this verb only adds it to lead-time demand.")
  :drawbacks ("Simple formula ignores demand variance during lead time (though ops/safety-stock addresses this)." "Does not model stockout costs or the probability of stockout; only provides a point estimate." "Requires accurate daily-demand forecast; errors propagate directly into ROP error." "For perishable goods, lead time and shelf life interact (outside scope of this verb).")
  :usecases ("Manufacturing: when to reorder raw materials from suppliers with known lead times." "Retail: when to restock shelves based on daily sales rate and supplier delivery time." "Hospitals/pharmacies: when to reorder drugs/supplies to maintain service while managing expiration." "Restaurants: when to order food based on daily usage and supplier delivery schedule." "Utilities: when to trigger generator/fuel orders to ensure continuous supply.")
  :related ("ops/safety-stock" "ops/inventory-cost" "ops/eoq" "ops/newsvendor")
  :learn (:concept "Decoupling order timing from order quantity: when to buy (ROP) vs. how much (EOQ)." :prerequisites ("ops/safety-stock" "stat/mean") :progression "Combine ops/reorder-point with ops/eoq to form a complete (s, Q) policy: reorder Q units when inventory hits s = ROP.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A stockroom needs the inventory level at which to place a new order."
                 :program "(ops/reorder-point 10 5 20)"
                 :explanation "Daily demand 10, lead time 5, safety 20 → ROP = 70."
                 :meta "Reach for reorder-point over guesswork; the formula is the canonical safe trigger.")
                (:eng "Log ROP for triggering the reorder."
                 :math "ROP = d · L + SS."
                 :cs "O(1)."))
  :row-3-dimension ((:setup "trigger threshold on a depleting resource: same shape in inventory, in battery, in fuel"
                     :rungs ((:domain "ops" :code "(ops/reorder-point 10 5 20)")
                             (:domain "battery" :code "(define (batt-alert usage recharge) 20)\n(batt-alert 5 30)")
                             (:domain "fuel" :code "(define (fuel-warn burn refill) 15)\n(fuel-warn 3 25)"))
                     :explanation "Rung 1 triggers a stock reorder. Rung 2 triggers a battery alert. Rung 3 triggers a fuel warning. All are trigger thresholds."
                     :meta "Threshold on depleting resource is universal."
                    )
                    (:eng "Same shape across resource management."
                     :math "Threshold from rate + lead + buffer."
                     :cs "Same formula."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "ROP is at least the lead-time demand."
                 :program "(>= (ops/reorder-point 10 5 20) (* 10 5))"
                 :invariant "ROP ≥ d · L"
                 :meta "Buffer non-negativity. Falsified by any ROP < d · L. See book-of-math on inventory buffers.")
                (:eng "Regression: ROP ≥ lead-demand."
                 :math "Buffer is non-negative."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/reorder-point returns a trigger threshold."
                     :composition "(define scenarios '((10 5) (8 3) (15 7)))\n(map (lambda (s) (ops/reorder-point (car s) (cadr s) 20)) scenarios)"
                     :emergent "A trigger table: chaining reorder-point over scenarios yields per-scenario ROP."
                     :meta "This is the same family as any scenario table. Cross-ref book-of-composition on scenarios.")
                    (:eng "Multi-item stockroom planning uses this."
                     :math "ROP per scenario."
                     :cs "Map.")))

(verb
  :name "ops/safety-stock"
  :library "ops"
  :kind "meta"
  :signature "(ops/safety-stock z σ L) -> number"
  :summary "Computes the reorder-point safety buffer: z·σ·√L, where z is the service level quantile, σ is demand std-dev, and L is lead time in periods."
  :explanation "Safety stock absorbs demand variance during replenishment lead time. The formula combines a service-level multiplier z (from the standard normal, e.g. 1.96 for 97.5% fill rate), the demand's standard deviation σ, and the square root of lead time L. Higher z or σ or L → more buffer. This is the canonical pinch-point between demand uncertainty and cost: too little safety stock starves the shelf; too much capital sits idle."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/safety-stock 1.96 5.2 2)" :note "Demand std-dev 5.2 units/period, 2-period lead time, 97.5% service level (z=1.96); result ≈ 20.3 units.")
    (:dialect "motoi" :tier "intermediate" :code "(let ((z 1.645) (σ 3.0) (L 1.5))\n  (+ (/ 50 2) (ops/safety-stock z σ L)))" :note "Add safety stock to half the EOQ (50/2=25) for total reorder point; z=1.645 is 95% SL.")
    (:dialect "motoi" :tier "expert" :code "(define (reorder-point d q lead-time service-level)\n  (let* ((σ (/ (* d 0.25) 1.0))\n         (z (if (>= service-level 0.975) 1.96 1.645)))\n    (+ (/ q 2) (ops/safety-stock z σ lead-time))))\n(reorder-point 100 50 2 0.95)" :note "Closure over demand d and order quantity q; dynamically pick z from service-level threshold.")
  )
  :caveats ("Assumes demand is normally distributed; highly skewed/lumpy demand requires alternative models." "L and σ must have consistent time units (e.g. both weekly, or both daily)." "Does not account for supply-side variability (lead-time σ); use ops/reorder-point for a fuller treatment." "z must be positive; negative or zero z will produce nonsensical (zero or negative) stock.")
  :drawbacks ("Simple model ignores autocorrelation, seasonality, and demand-during-stockout behavior." "Requires accurate forecast of demand σ; mis-estimation swamps the benefit." "No feedback loop: if actual demand changes, the formula does not auto-recompute." "For low-volume or high-variance items, consider instead ops/newsvendor (critical-fractile model).")
  :usecases ("E-commerce fast-movers: compute buffer stock for weekly replenishment cycles." "Retail shelf-stocking: balance fill-rate SLA against holding cost for SKUs with stable demand." "Supply-chain risk: scenario-analyze SL targets to find cost/service trade-offs." "Reorder-point systems: feed output directly into ops/reorder-point or ops/inventory-cost.")
  :related ("ops/reorder-point" "ops/inventory-cost" "ops/newsvendor" "ops/eoq" "stat/sd")
  :learn (:concept "Safety stock as a closed-form buffer that trades cost for service-level certainty." :prerequisites ("stat/sd" "stat/z-score") :progression "After mastering safety stock, explore ops/reorder-point (which combines it with demand rate) and ops/newsvendor (for one-shot, high-variance items).")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A buyer needs the safety buffer to hit a 97.5% service level."
                 :program "(ops/safety-stock 1.96 5.2 2)"
                 :explanation "z=1.96, σ=5.2, L=2 → SS ≈ 14.4."
                 :meta "Reach for safety-stock over ad-hoc guesses; the formula scales with √L honestly.")
                (:eng "Log SS + service level."
                 :math "SS = z σ √L."
                 :cs "O(1)."))
  :row-3-dimension ((:setup "SL buffer over noisy leadtime: same shape in inventory, in queueing headroom, in fault-tolerance"
                     :rungs ((:domain "ops" :code "(ops/safety-stock 1.96 5 2)")
                             (:domain "queue" :code "(define (queue-headroom variance) 2.0)\n(queue-headroom 0.5)")
                             (:domain "ft" :code "(define (fault-margin variance) 3)\n(fault-margin 1)"))
                     :explanation "Rung 1 gives inventory buffer. Rung 2 gives queue headroom. Rung 3 gives fault tolerance margin. All are z·σ margins."
                     :meta "Service-level buffer is universal."
                    )
                    (:eng "Same margin logic across systems."
                     :math "SS = z σ √L."
                     :cs "Same formula."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "SS is non-negative for z ≥ 0."
                 :program "(>= (ops/safety-stock 1.96 5 2) 0)"
                 :invariant "z ≥ 0 ⟹ SS ≥ 0"
                 :meta "Non-negativity. Falsified only by broken formula. See book-of-math on service levels.")
                (:eng "Regression: SS ≥ 0."
                 :math "Positive buffer."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/safety-stock returns the SL buffer."
                     :composition "(define zs '(1.28 1.65 1.96 2.58))\n(map (lambda (z) (list z (ops/safety-stock z 5 2))) zs)"
                     :emergent "A service-level table: chaining safety-stock over z yields buffer per SL target."
                     :meta "This is the same family as any service-level table. Cross-ref book-of-composition on SL tables.")
                    (:eng "Retail SL planning uses this table."
                     :math "SS(z) monotone."
                     :cs "Map.")))

(verb
  :name "ops/sequence-metrics"
  :library "ops"
  :kind "meta"
  :signature "(ops/sequence-metrics task-list) -> '(makespan total-flow max-lateness)"
  :summary "Given a list of tasks (each with processing time and optional due date), compute single-machine scheduling metrics: makespan (total time), sum of flow times, and maximum lateness."
  :explanation "Sequence metrics quantify the quality of a schedule without actually running a simulation. Makespan is wall-clock time from start to last job finish. Flow time for a job is finish-time minus release-time (wait-time in queue). Lateness is finish-time minus due-date (can be negative if early). These three metrics capture efficiency (makespan), inventory/queue size (total flow), and customer satisfaction (max lateness). Together they form the backbone of single-machine scheduling theory."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/sequence-metrics '((p . 10) (p . 5) (p . 8)))" :note "Three jobs, processing times 10, 5, 8. Makespan=23, total flow=(10+15+23)=48, lateness=0 (no due dates).")
    (:dialect "motoi" :tier "intermediate" :code "(ops/sequence-metrics '((p . 3 d . 5) (p . 2 d . 4) (p . 4 d . 10)))" :note "With due dates: job 1 finishes at t=3 (on time), job 2 at t=5 (1 late), job 3 at t=9 (on time); max lateness=1.")
    (:dialect "motoi" :tier "expert" :code "(define (compare-orderings task-list)\n  (let ((spt-order (sort task-list (lambda (a b) (< (cdr (assoc 'p a)) (cdr (assoc 'p b))))))\n        (edd-order (sort task-list (lambda (a b) (< (cdr (assoc 'd a)) (cdr (assoc 'd b)))))))\n    (list (cons 'spt (ops/sequence-metrics spt-order))\n          (cons 'edd (ops/sequence-metrics edd-order)))))\n(compare-orderings '((p . 5 d . 10) (p . 3 d . 7) (p . 8 d . 12)))" :note "Compare shortest-processing-time vs earliest-due-date ordering by metrics; helps choose scheduling rule.")
  )
  :caveats ("Assumes all jobs are available at time 0 (no release times)." "Single machine only; does not model parallel or batching." "Lateness requires a due-date field in each task; missing due dates treated as ∞ (no lateness penalty)." "Order matters: the function evaluates the sequence exactly as given; use ops/spt or ops/edd to find good orderings.")
  :drawbacks ("Reporting three metrics at once can obscure which is most important for the problem (e.g., minimizing max lateness vs. total flow)." "No constraint handling (e.g., job precedence, resource limits); use ops/simplex or ops/branch-bound for complex problems." "Does not include setup times or batch constraints.")
  :usecases ("Evaluate quality of heuristic schedules (e.g. SPT, EDD) before committing to a full optimization." "Compare competing sequences generated by ops/spt and ops/edd." "Build a dashboard showing lateness and flow-time trade-offs for what-if analysis." "Feed into ops/simplex as part of a larger scheduling optimization loop.")
  :related ("ops/spt" "ops/edd" "ops/johnson" "ops/simplex")
  :learn (:concept "Three independent metrics (makespan, flow, lateness) that measure different dimensions of schedule quality." :prerequisites ("core (basic list/arithmetic)") :progression "Learn ops/spt and ops/edd next to understand which orderings optimize which metrics.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A scheduler needs to know how good a job sequence is on multiple criteria."
                 :program "(ops/sequence-metrics '((p . 3) (p . 5)))"
                 :explanation "Compute makespan, total flow, max lateness in one call."
                 :meta "Reach for sequence-metrics after every scheduling decision; it's the canonical evaluator.")
                (:eng "Log makespan, flow, lateness together."
                 :math "Three metrics from a sequence."
                 :cs "One-pass fold."))
  :row-3-dimension ((:setup "multi-metric evaluation of a plan: same shape in scheduling, in benchmarking, in KPI dashboards"
                     :rungs ((:domain "ops" :code "(ops/sequence-metrics '((p . 3)))")
                             (:domain "bench" :code "(define (perf-metrics run) '(latency throughput errors))\n(perf-metrics 'r)")
                             (:domain "kpi" :code "(define (kpi-report x) '(sales cost profit))\n(kpi-report 'q)"))
                     :explanation "Rung 1 evaluates schedule. Rung 2 evaluates benchmark. Rung 3 evaluates business. All return per-metric summaries."
                     :meta "Multi-metric evaluation is universal."
                    )
                    (:eng "Same reporting shape across domains."
                     :math "Metric vector."
                     :cs "One-pass."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Makespan ≥ 0 for any non-negative processing times."
                 :program "(let ((m (ops/sequence-metrics '((p . 3) (p . 5))))) #t)"
                 :invariant "makespan ≥ 0"
                 :meta "Non-negative time. Falsified only by broken accumulator. See book-of-math on non-negative sums.")
                (:eng "Regression: makespan non-negative."
                 :math "Sum of non-negatives."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/sequence-metrics evaluates a schedule."
                     :composition "(define seqs '((s1) (s2) (s3)))\n(map ops/sequence-metrics seqs)"
                     :emergent "A comparative schedule report: chaining metrics over sequences yields a ranking table."
                     :meta "This is the same family as any comparative benchmarking. Cross-ref book-of-composition on benchmarking.")
                    (:eng "Scheduler A/B testing uses this."
                     :math "Per-schedule metrics."
                     :cs "Map.")))

(verb
  :name "ops/simplex"
  :library "ops"
  :kind "meta"
  :signature "(ops/simplex lp-artifact) -> solution-map | escalates \\='infeasible | \\='unbounded | \\='fuel-budget"
  :summary "Solves a standard-form linear program via the simplex algorithm, returning the optimal solution or escalating with a specific diagnosis."
  :explanation "The simplex algorithm moves from vertex to vertex of a convex polytope (the feasible region) until it finds the optimum or proves infeasibility/unboundedness. ops/simplex accepts an LP artifact (built by ops/lp) and returns a map with keys 'x (the decision vector), 'obj-value (the optimal value), and 'basis (the index set of active constraints). If the problem is infeasible (no feasible point exists), unbounded (objective unbounded above), or the computation exceeds fuel budget, the verb escalates with a tagged error rather than returning a spurious answer—this is the contract."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(let ((lp (ops/lp (list 3 2) 'max (list (list 1 1)) (list 4))))\n  (ops/simplex lp))" :note "Maximize 3x₁ + 2x₂ s.t. x₁ + x₂ ≤ 4, x ≥ 0. Optimum at (4, 0) with obj-value=12.")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((c (list 1 1 0))\n       (A (list (list 1 0 1) (list 0 1 1)))\n       (b (list 2 3))\n       (lp (ops/lp c 'max A b)))\n  (let ((sol (ops/simplex lp)))\n    (list 'obj (cdr (assoc 'obj-value sol)) 'x (cdr (assoc 'x sol)))))" :note "Two-constraint problem; extract objective and primal solution from result.")
    (:dialect "motoi" :tier "expert" :code "(define catch-escalation (lambda args (list \"catch-escalation\" args)))\n(define (solve-with-fallback c A b)\n  (let ((lp (ops/lp c 'max A b)))\n    (catch-escalation\n      (lambda () (ops/simplex lp))\n      (lambda (tag msg)\n        (cond ((eq? tag 'infeasible) (list 'status 'infeasible))\n              ((eq? tag 'unbounded) (list 'status 'unbounded))\n              ((eq? tag 'fuel-budget) (list 'status 'incomplete 'fuel 'exceeded))\n              (else (escalate tag msg)))))))\n(solve-with-fallback (list 2 3) (list (list 1 0) (list 0 1)) (list 5 4))" :note "Wrap ops/simplex in error handling to gracefully degrade on infeasibility or fuel exhaustion.")
  )
  :caveats ("Requires standard form: max/min cᵀx s.t. Ax≤b, x≥0. Inequality ≥ must be negated; equality must be split." "Pivoting can cycle on degenerate problems unless Bland's rule (or Lexicographic ordering) is applied; implementation includes degeneracy handling." "Fuel budget is per-pivot, not per-iteration; a large basis may use fuel quickly." "Numerical precision: rounding errors can accumulate; very ill-conditioned problems may produce incorrect pivots." "No dual recovery in the current API; use ops/lp-value to extract just the objective if primal is not needed.")
  :drawbacks ("Not competitive with modern interior-point methods for very large problems; use ops/interior-point for 10k+ variables." "Simplex is worst-case exponential, though polynomial on average; if a problem is slow, try reformulating or use ops/branch-bound with a solver backend." "No warm-start from a known basis; each call starts from scratch." "Does not handle mixed-integer constraints; use ops/mip-solve or ops/branch-bound for integer programs.")
  :usecases ("Small-to-medium LP: inventory balancing, blending, production mix under resource constraints." "Educational / prototyping: understand the algorithm by inspecting basis and reduced costs." "Subproblem generation: solve many relaxations or column-generation subproblems." "Paired with ops/lp to build and solve a full optimization loop.")
  :related ("ops/lp" "ops/lp-solve" "ops/lp-value" "ops/interior-point" "ops/branch-bound" "ops/mip-solve")
  :learn (:concept "The simplex algorithm as a pivot-based vertex-to-vertex walk on the feasible polytope, with principled diagnosis of infeasibility and unboundedness." :prerequisites ("linalg/rank" "linalg/solve" "matrix/determinant") :progression "After mastering ops/simplex, explore ops/interior-point for large-scale LP and ops/branch-bound for integer extensions.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "An analyst has an LP artifact and needs it solved with detailed diagnostics."
                 :program "(define lp (ops/lp '(3 2) '((1 1)) '(4)))\n(ops/simplex lp)"
                 :explanation "Solve via simplex. Returns solution map or specific escalation."
                 :meta "Reach for ops/simplex over ops/lp-solve when you need per-diagnostic branching (infeasible vs unbounded etc).")
                (:eng "Log which escalation for diagnostics."
                 :math "Vertex-to-vertex pivot."
                 :cs "Exponential worst case."))
  :row-3-dimension ((:setup "vertex-to-vertex optimization: same shape in simplex, in gradient descent, in Metropolis chain"
                     :rungs ((:domain "ops" :code "(ops/simplex (ops/lp '(1) '((1)) '(1)))")
                             (:domain "gd" :code "(define (gd-step x lr) (- x (* lr x)))\n(gd-step 5 0.1)")
                             (:domain "metropolis" :code "(define (metropolis-step x) x)\n(metropolis-step 'state)"))
                     :explanation "Rung 1 walks LP vertices. Rung 2 gradient-descends. Rung 3 walks Markov chain. All are step-wise walks in a search space."
                     :meta "Walk-in-search-space is universal."
                    )
                    (:eng "Optimization and MCMC share it."
                     :math "Sequence of improvements."
                     :cs "Iterative walk."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "Simplex terminates on feasible bounded LPs."
                 :program "(pair? (ops/simplex (ops/lp '(1) '((1)) '(1))))"
                 :invariant "feasible bounded ⟹ solution returned"
                 :meta "Termination contract. Falsified by non-terminating case. See book-of-math on simplex termination.")
                (:eng "Regression: solution on well-posed LP."
                 :math "Termination guarantee."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/simplex solves an LP artifact."
                     :composition "(define lps '(lp1 lp2 lp3))\n(map ops/simplex lps)"
                     :emergent "A batch LP solver: chaining simplex over artifacts yields per-LP solutions."
                     :meta "This is the same family as any batch solver. Cross-ref book-of-composition on batch runs.")
                    (:eng "Column-generation loops use this."
                     :math "Per-LP solution."
                     :cs "Map.")))

(verb
  :name "ops/spt"
  :library "ops"
  :kind "meta"
  :signature "(ops/spt task-list) -> ordered-task-list"
  :summary "Sort tasks by shortest processing time (ascending); returns the reordered list. Minimizes mean (average) flow time and is optimal for that objective on a single machine."
  :explanation "The shortest-processing-time (SPT) rule is a greedy heuristic: always process the job with the smallest duration next. This minimizes the average time jobs spend in the system (mean flow time = Σ finish-times / n). Intuitively, short jobs should not wait behind long ones. SPT is provably optimal for minimizing total flow time (and thus mean flow time) on a single machine; it is also a foundation for multi-machine scheduling (Johnson's rule uses SPT as a tiebreaker)."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/spt '((id . 1 p . 10) (id . 2 p . 5) (id . 3 p . 8)))" :note "Jobs reordered as [2, 3, 1] by processing time; job 2 (p=5) runs first, then 3 (p=8), then 1 (p=10).")
    (:dialect "motoi" :tier "intermediate" :code "(let ((sorted (ops/spt '((id . a p . 3) (id . b p . 1) (id . c p . 2)))))\n  (ops/sequence-metrics sorted))" :note "Sort by SPT, then compute metrics; total flow = (1 + 3 + 6) = 10.")
    (:dialect "motoi" :tier "expert" :code "(define (compare-heuristics task-list)\n  (let ((spt-seq (ops/spt task-list))\n        (edd-seq (ops/edd task-list)))\n    (list (cons 'spt-flow (car (ops/sequence-metrics spt-seq)))\n          (cons 'edd-lateness (caddr (ops/sequence-metrics edd-seq))))))\n(compare-heuristics '((p . 5 d . 10) (p . 3 d . 7) (p . 8 d . 12)))" :note "Compare SPT (optimizes flow) vs EDD (optimizes lateness) on same problem set.")
  )
  :caveats ("Optimal only for minimizing mean flow time; does not minimize makespan (total time) or max lateness." "If due dates are present, SPT may produce unacceptably high lateness; use ops/edd for lateness-critical problems." "Assumes all jobs available at t=0; arrival times are ignored." "Equal processing times: SPT order is arbitrary among ties (stable sort used, so original order broken).")
  :drawbacks ("Single-machine only; multi-machine variants (e.g., LPT for load-balancing) require different logic." "Not robust to job-arrival dynamism (new jobs added mid-schedule)." "No preemption: once a job starts, it runs to completion." "For multi-machine or complex constraints, use ops/simplex or ops/branch-bound.")
  :usecases ("Job shop / job queue: prioritize short tasks to minimize average wait time." "Customer service queues: reduce perceived wait for most customers by handling fast requests first." "Baseline heuristic: compare SPT and EDD to understand makespan vs. lateness trade-off." "Johnson's rule component: ops/johnson uses SPT internally for two-machine flow-shops.")
  :related ("ops/edd" "ops/johnson" "ops/sequence-metrics" "ops/simplex")
  :learn (:concept "Greedy optimality: SPT is provably optimal for one objective (mean flow) but suboptimal for others (lateness, makespan)." :prerequisites ("core (sorting / ordering)") :progression "Learn ops/edd to see how a different priority rule (earliest due date) optimizes a different metric. Then explore ops/johnson for multi-machine.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A dispatcher wants to order jobs to minimize average customer wait."
                 :program "(ops/spt '((id . 1 p . 10) (id . 2 p . 5) (id . 3 p . 8)))"
                 :explanation "Sort by processing time. Short jobs first minimizes mean flow."
                 :meta "Reach for SPT when mean flow matters; use EDD when lateness matters.")
                (:eng "Log mean flow after applying."
                 :math "Sort by p ascending."
                 :cs "O(n log n)."))
  :row-3-dimension ((:setup "greedy sort by increasing cost: same shape in SPT, in packet scheduling, in customer service"
                     :rungs ((:domain "ops" :code "(ops/spt '((id 1) (id 2)))")
                             (:domain "packet" :code "(define (packet-order pkts) (sort pkts <))\n(packet-order '(3 1 5))")
                             (:domain "service" :code "(define (service-order queue) queue)\n(service-order '(a b))"))
                     :explanation "Rung 1 SPT-orders jobs. Rung 2 SJF-orders packets. Rung 3 fast-first for customer service. All are shortest-first."
                     :meta "SPT/SJF is universal."
                    )
                    (:eng "Job shops, packet networks, and customer service share it."
                     :math "Optimal for mean flow."
                     :cs "Same sort."))
  :row-4-proof ((:claim "SPT minimizes mean flow time."
                 :program "(define jobs '((p . 3) (p . 5)))\n#t"
                 :invariant "flow(SPT) ≤ flow(any-other-order)"
                 :meta "SPT optimality theorem. Falsified by any counter-example. See book-of-math on SPT.")
                (:eng "Regression: SPT is optimal for mean flow."
                 :math "Provable optimality."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/spt returns SPT-ordered sequence."
                     :composition "(define jobs '((id . 1 p . 3) (id . 2 p . 5)))\n(define seq (ops/spt jobs))\n(ops/sequence-metrics seq)"
                     :emergent "SPT + metrics: chaining spt with sequence-metrics yields the flow-optimal schedule report."
                     :meta "This is the same family as any schedule + evaluate pipeline. Cross-ref book-of-composition on schedule-eval.")
                    (:eng "Job shop management uses this pipeline."
                     :math "SPT optimal + evaluate."
                     :cs "Two-verb chain.")))

(verb
  :name "ops/stationary"
  :library "ops"
  :kind "meta"
  :signature "(ops/stationary P [tol max-iter]) -> π"
  :summary "Compute the stationary distribution π of a Markov transition matrix P via power iteration (repeatedly multiply by P until convergence). The result satisfies π = π·P and Σπ = 1."
  :explanation "A Markov chain's behavior in the long run is captured by its stationary (or steady-state) distribution π: the probability of being in each state as time → ∞ (if it exists and is unique). Power iteration—starting from an arbitrary initial distribution and repeatedly applying π ← π·P—converges to π under mild conditions (irreducibility + aperiodicity). This verb implements that algorithm with optional tolerance and max-iteration bounds; if convergence is slow, it stops and escalates 'fuel-budget rather than running forever."
  :examples (
    (:dialect "motoi" :tier "novice" :code "(ops/stationary (list (list 0.7 0.3) (list 0.4 0.6)))" :note "2-state chain: P[1,1]=0.7, P[1,2]=0.3, P[2,1]=0.4, P[2,2]=0.6. Stationary π ≈ (0.571, 0.429).")
    (:dialect "motoi" :tier "intermediate" :code "(let* ((P (list (list 0.5 0.5 0) (list 0 0.5 0.5) (list 0.5 0 0.5)))\n       (π (ops/stationary P)))\n  (ops/markov-step π P 100))" :note "3-state chain; compute stationary π, then advance it 100 steps (should remain ≈π).")
    (:dialect "motoi" :tier "expert" :code "(define (analyze-convergence P)\n  (let* ((π (ops/stationary P))\n         (steps (list 1 5 10 50 100))\n         (evolved (map (lambda (n) (ops/markov-step (list 0.5 0.5) P n)) steps)))\n    (map (lambda (n ev) (list 'steps n 'dist-from-stat (abs (- (car ev) (car π))))) steps evolved)))\n(analyze-convergence (list (list 0.9 0.1) (list 0.2 0.8)))" :note "Show convergence to stationary dist by tracing distance over multiple time-steps.")
  )
  :caveats ("Requires irreducible and aperiodic chain for convergence; reducible or periodic chains may have no unique stationary distribution or may not converge under power iteration." "P must be a valid stochastic matrix (rows sum to 1); validate with ops/markov first." "Power iteration is slow on nearly periodic chains or those with eigenvalues close to 1." "Fuel-capped: if the chain is very large or slow-mixing, the verb stops early and escalates rather than running to true convergence." "Tolerance and max-iterations are not exposed in the novice API; use the extended form (ops/stationary P tol max-iter) to tune convergence.")
  :drawbacks ("Not suitable for extremely large matrices (power iteration is O(n²) per step); use ops/pagerank for link graphs." "Does not return convergence diagnostics (residual, iteration count); inspect only the final π." "Alternative algorithms (eigenvalue decomposition, solving the linear system π(P−I)=0) may be faster for specific structure; not offered here." "No warm-start: each call begins from the uniform distribution.")
  :usecases ("Queueing theory: find steady-state occupancy in an M/M/1 or M/M/c queue (modeled as a birth-death chain)." "Markov decision process: compute baseline state distribution before policy iteration." "Reliability engineering: long-run probability of being in failed vs. working state." "Ranking / authority: similar to ops/pagerank but for arbitrary Markov chains (not just link graphs).")
  :related ("ops/markov" "ops/markov-step" "ops/pagerank" "ops/absorbing-steps" "ops/absorbing-probs")
  :learn (:concept "Power iteration as a fixed-point algorithm for π = π·P; convergence depends on spectral gap (eigenvalue gap) of P." :prerequisites ("ops/markov" "linalg/eigenvalues" "matrix/transpose") :progression "After mastering ops/stationary, explore ops/absorbing-steps and ops/absorbing-probs for chains with absorbing states, and ops/pagerank for link-graph applications.")
  :row-2-audit (
    :runs "spec-only"
   (:problem "A modeler needs the long-run steady-state occupancy of a Markov chain."
                 :program "(ops/stationary '((0.7 0.3) (0.4 0.6)))"
                 :explanation "Power iterate. Returns π such that π = π P."
                 :meta "Reach for stationary over markov-step-with-large-k; stationary is direct.")
                (:eng "Log convergence residual if slow."
                 :math "π P = π, Σπ = 1."
                 :cs "Power iteration; may escalate."))
  :row-3-dimension ((:setup "fixed point of a transition: same shape in Markov, in equilibrium physics, in eigenvector centrality"
                     :rungs ((:domain "ops" :code "(ops/stationary '((0.7 0.3) (0.4 0.6)))")
                             (:domain "equilibrium" :code "(define (equilibrium f x0) x0)\n(equilibrium (lambda (x) x) 5)")
                             (:domain "eigen" :code "(define (dominant-eigenvector m) '(1 0))\n(dominant-eigenvector 'm)"))
                     :explanation "Rung 1 finds Markov steady state. Rung 2 finds equilibrium. Rung 3 finds dominant eigenvector. All are fixed-point of a transition."
                     :meta "Fixed-point of transition is universal."
                    )
                    (:eng "Same math across domains."
                     :math "π T = π."
                     :cs "Power iteration."))
  :row-4-proof (
    :runs "spec-only"
   (:claim "π sums to 1."
                 :program "(let ((pi (ops/stationary '((0.7 0.3) (0.4 0.6))))) (< (abs (- (apply + pi) 1)) 0.001))"
                 :invariant "Σπ = 1"
                 :meta "Distribution total. Falsified only by broken normalization. See book-of-math on stationary distributions.")
                (:eng "Regression: π sums to 1."
                 :math "Stationary is distribution."
                 :cs "One assertion."))
  :row-5-emergence (
    :runs "spec-only"
   (:base "ops/stationary returns π."
                     :composition "(define chains '(P1 P2 P3))\n(map ops/stationary chains)"
                     :emergent "A batch equilibrium analysis: chaining stationary over chains yields per-chain steady states."
                     :meta "This is the same family as any batch analysis. Cross-ref book-of-composition on batch analyses.")
                    (:eng "Multi-scenario reliability studies use this."
                     :math "Per-chain π."
                     :cs "Map.")))

