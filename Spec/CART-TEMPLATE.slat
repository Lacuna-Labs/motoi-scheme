; Spec/CART-TEMPLATE.slat
; Motoi Fantasy-Console Cart Template — canonical bundle shape.
;
; Provenance: 2026-07-19 (Marcus, Wave 4). Formalizes what a Motoi
; "cart" IS at the composer/cart-emit + composer/cart-apply layer.
; Downstream (Sakura's cart consumer, Rosetta's fantasy-console
; variant contract) reads this file to know which section keys are
; canonical, which are optional, and what the round-trip identity
; contract is.
;
; Doctrine: [[fantasy-console-cart-template-2026-07-19]]
;   "cart bundle spec. Round-trip = identity contract."
;
; The cart is an alist (a plain Scheme association list) with a
; fixed key order. Missing sections default to the empty list `()`
; — a well-formed cart with no sprites, no tiles, no music is
; perfectly valid.

(:record :cart-template
 :section :spec
 :doc     "Motoi fantasy-console cart bundle — the on-disk shape."
 :dialect :motoi
 :provenance    (:file "Spec/CART-TEMPLATE.slat" :author :marcus :date "2026-07-19")
 :training-eligible #t
 :confidentiality :public

 ;; ── SECTIONS, in canonical order ─────────────────────────────────
 ;; Every cart is an alist with keys in this order. Ordering is
 ;; load-bearing for the round-trip identity check (composer/apply
 ;; then composer/emit must return the same alist byte-for-byte).
 :sections
 ((:meta     "Cart metadata — title, author, palette-name, w, h.")
  (:palette  "16 RGBA colors. Empty list means the built-in default.")
  (:sprites  "Sprite grid list: (sprite N (bytes ...)) forms.")
  (:tiles    "Tile map cells: ((c r tile-idx) ...) list.")
  (:sounds   "Sound-effect definitions (name + envelope + waveform).")
  (:music    "Song timelines and piano-roll phrases.")
  (:code     "The runnable Scheme program — a list of top-level forms."))

 ;; ── ROUND-TRIP IDENTITY CONTRACT ─────────────────────────────────
 :round-trip
 (:contract "(equal? cart (composer/cart-apply cart (composer/cart-emit cart)))"
  :must-be  #t
  :held-by  :composer
  :tested-in "tests/composer/round-trip.test.js"
  :widget-level  "Every widget class must independently satisfy the
                  same identity — sprite-grid, tile-map, timeline,
                  palette-designer, piano-roll — before the cart-level
                  contract holds.")

 ;; ── EMPTY / DEFAULT CART ─────────────────────────────────────────
 ;; A fresh cart from the IDE's "New Cart" button:
 :empty
 ((:meta    ((:title "untitled") (:author "") (:palette pico-8) (:w 128) (:h 128)))
  (:palette ())
  (:sprites ())
  (:tiles   ())
  (:sounds  ())
  (:music   ())
  (:code    ()))

 ;; ── WIDGET → SECTION MAP ─────────────────────────────────────────
 ;; Which composer widget emits into which section slot. Missing
 ;; widget = empty slot; NEVER omit the key.
 :widget-to-section
 ((sprite-grid       :sprites)
  (tile-map          :tiles)
  (timeline          :music)          ; song timelines
  (timeline-sprite   :sprites)         ; animated sprites
  (palette-designer  :palette)
  (piano-roll        :music)
  (adsr              :sounds)
  (fx-chain          :sounds)
  (instrument-picker :sounds)
  (live-code         :code))

 ;; ── ON-DISK PATH ─────────────────────────────────────────────────
 :on-disk
 (:root  "~/.motoi/carts/"
  :ext   ".scm"
  :name-regex "^[A-Za-z0-9._-]+$"
  :max-name-len 64
  :sandbox "See lib/media/media.js _safeCartPath — Priya doctrine.")

 ;; ── DOWNSTREAM CONSUMERS ─────────────────────────────────────────
 :consumers
 ((:sakura-scheme
    :notes "Sakura reads this exact template. Sakura carts add
            optional :flower :cortex :shop sections at the tail;
            reader must ignore unknown keys silently.")
  (:rosetta-fantasy-console
    :notes "Rosetta compat manifest for Sakura's fantasy-console
            variant references :sections order as :native binding."))

 ;; ── NOTES ────────────────────────────────────────────────────────
 :notes
 "Deterministic. LLM-free. Alfred: 'I want it to be deterministic and
  locked in. Computer science and engineering.'"
)
