{
  "name": "motoi-scheme",
  "version": "0.75.0-beta",
  "description": "Motoi Scheme — a small R7RS-small Scheme with a REPL, a framebuffer, a beat maker, a reference manual, and books that teach the language through runnable examples. Cross-platform (Mac + Linux).",
  "keywords": [
    "scheme",
    "lisp",
    "r7rs",
    "interpreter",
    "repl",
    "cli",
    "language",
    "programming-language",
    "framebuffer",
    "audio",
    "learning",
    "tutorial",
    "motoi"
  ],
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./reader": "./src/reader.js",
    "./interp": "./src/interp.js",
    "./base": "./src/base.js",
    "./macro": "./src/macro.js",
    "./registry": "./src/verbRegistry.js",
    "./dispatch": "./src/dispatch.js",
    "./introspect": "./src/introspect.js",
    "./repl": "./src/repl.js",
    "./cli": "./src/cli.js",
    "./docs-emitter": "./src/docs-emitter.js",
    "./slat": "./src/slat.js"
  },
  "bin": {
    "motoi": "./bin/motoi",
    "motoi-scheme": "./bin/motoi"
  },
  "files": [
    "src",
    "bin",
    "bindings/js",
    "Engineering",
    "Scheme",
    "Words",
    "Spec",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs tests/**/*.test.mjs",
    "test:fast": "node --test --test-reporter=dot tests/*.test.mjs tests/**/*.test.mjs",
    "lint": "eslint src bindings/js",
    "lint:rules": "eslint eslint-rules site",
    "docs:build": "vitepress build site",
    "docs:dev": "vitepress dev site"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=20.16"
  },
  "license": "Apache-2.0",
  "author": "Lacuna Labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lacuna-Labs/motoi-scheme.git"
  },
  "homepage": "https://github.com/Lacuna-Labs/motoi-scheme#readme",
  "bugs": {
    "url": "https://github.com/Lacuna-Labs/motoi-scheme/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
