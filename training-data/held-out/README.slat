;;; README.slat — Motoi Copilot held-out validation set
;;;
;;; :audience         :engineer
;;; :confidentiality  :internal
;;; :training-eligible #f   ; META: describes held-out data — NOT itself training.
;;; :doc              "heldout-2026-07-16-README"
;;; :dialect          "motoi"
;;; :provenance       "the-engineer heldout-carving-lane 2026-07-16"
;;; :owner            "The Engineer"
;;; :tags             (:motoi :training :held-out :validation :don-t-train
;;;                    :qwen2.5-coder-1.5b :wave-3-planning)

(document
  :name          "heldout-2026-07-16-README"
  :date          "2026-07-16"
  :owner         "The Engineer"
  :audience      :engineer
  :confidentiality :internal
  :dialect       "motoi"
  :training-eligible #f
  :inputs
  ("motoi-scheme/training-data/*.jsonl                    ; 10 files, 16,873 pairs total"
   "lacuna-labs/reports/motoi-copilot-coverage-audit-2026-07-16.slat ; verb tiers"
   "lacuna-labs/reports/motoi-copilot-balance-and-sakura-reuse-2026-07-16.slat ; blocker-3: carve held-out before training"
   "lacuna-labs/research/small-model-dsl-teaching-2026-07-16.slat  ; verification-plan section-6 requires held-out probes")
  :outputs
  ("training-data/held-out/heldout-2026-07-16.jsonl      ; 1,000 pairs + provenance header"
   "training-data/*.jsonl                                 ; SAME 1,000 pairs marked in-place with :held_out true; header gets :held_out_marking record")
  :script "motoi-scheme/scratch/carve-heldout-2026-07-16.py"
  :seed 20260716
  :seed-note "Fixed integer seed. Re-running the script on the same source
              files yields the exact same 1,000 pairs. This is the reproducibility
              contract. Note: 'same source files' means the same set of files
              with the same pair contents at the same line numbers — any
              re-generation of source JSONLs invalidates prior held-out
              membership; re-run the carve."
)

;; ==========================================================================
;; THE DON-T-TRAIN CONTRACT
;; ==========================================================================

(don-t-train-contract
  :headline
  "The 1,000 pairs in heldout-2026-07-16.jsonl are VALIDATION-ONLY. Any
   training run — full FT, LoRA, DPO, or any other — MUST exclude these
   pairs from the training loader. Failure to do so contaminates the
   validation signal and invalidates any pass/fail claim from downstream
   verification (verb-recall, composition pass@1, persona voice, refusal
   rate, curriculum literacy)."

  :two-source-of-truth-marking
  "Held-out membership is recorded IN TWO PLACES so a training pipeline
   cannot accidentally include a held-out pair:
     1. The held-out file itself: held-out/heldout-2026-07-16.jsonl.
     2. IN-PLACE on every source JSONL: each carved pair now carries the
        top-level key ``\"held_out\": true``.
   Training loaders MUST filter pairs where held_out is truthy. See
   :recommended-loader-filter below for a one-liner."

  :recommended-loader-filter
  "for line in open(path):\n     rec = json.loads(line)\n     if rec.get(\"_provenance_header\"): continue\n     if rec.get(\"held_out\"): continue    # <-- MANDATORY\n     yield rec"

  :on-conflict
  "If any tool re-generates a source JSONL (e.g. an extractor lane running
   after the carve, as happened with wave-3-refusal and response-shape on
   2026-07-16 evening), the ``held_out\": true`` markings AND the
   ``held_out_marking`` header stamp are LOST. Detection: check for
   ``held_out_marking`` in every source JSONL header before training.
   Recovery: re-run carve-heldout-2026-07-16.py — the seed guarantees
   deterministic re-sampling per input snapshot, so the held-out membership
   for UNCHANGED files stays fixed; only pairs from the changed file are
   re-sampled."

  :no-deletes
  "Held-out pairs are NEVER removed from source JSONLs. They stay in place
   with a marker. This preserves provenance chain and lets us audit train
   / held-out overlap at any later point.")

;; ==========================================================================
;; STRATIFICATION
;; ==========================================================================

(stratification
  :headline
  "Two-pass stratified sample: (1) proportional per (book × extractor)
   cell at ~10% each, min-1-per-cell to keep small hand-curated E4/E5
   cells alive; (2) tier rebalance for STARVED/THIN/THIN-CONTEXT/HEALTHY
   under-representation; (3) uniform-random trim/topup to hit exactly
   1,000 pairs with at least one representative per non-empty cell
   preserved."

  :corpus-snapshot-at-carve
  ((:file "pilot-book-of-scheme-2026-07-16.jsonl"      :pairs  609)
   (:file "wave-1-book-of-extensions-2026-07-16.jsonl" :pairs  528)
   (:file "wave-1-book-of-math-2026-07-16.jsonl"       :pairs 3239)
   (:file "wave-1-book-of-slat-2026-07-16.jsonl"       :pairs  695)
   (:file "wave-2-book-of-animation-2026-07-16.jsonl"  :pairs  444)
   (:file "wave-2-book-of-motion-2026-07-16.jsonl"     :pairs 2861)
   (:file "wave-2-book-of-music-2026-07-16.jsonl"      :pairs 2127)
   (:file "wave-2-book-of-sound-2026-07-16.jsonl"      :pairs 1712)
   (:file "wave-3-refusal-2026-07-16.jsonl"            :pairs 2577)
   (:file "response-shape-2026-07-16.jsonl"            :pairs 2081)
   (:total 16873))

  :axes
  ((:axis "BOOK / SOURCE"
    :method "10 sources (from filename). Proportional at ~6% per source."
    :distribution
    ((:source "book-of-math"        :corpus 3239 :held 203 :pct 6.27)
     (:source "book-of-motion"      :corpus 2861 :held 164 :pct 5.73)
     (:source "wave-3-refusal"      :corpus 2577 :held 157 :pct 6.09)
     (:source "book-of-music"       :corpus 2127 :held 124 :pct 5.83)
     (:source "response-shape"      :corpus 2081 :held 112 :pct 5.38)
     (:source "book-of-sound"       :corpus 1712 :held 107 :pct 6.25)
     (:source "book-of-slat"        :corpus  695 :held  36 :pct 5.18)
     (:source "book-of-scheme"      :corpus  609 :held  34 :pct 5.58)
     (:source "book-of-extensions"  :corpus  528 :held  38 :pct 7.20)
     (:source "book-of-animation"   :corpus  444 :held  25 :pct 5.63)))

   (:axis "EXTRACTOR / BUCKET"
    :method "Inferred from pair SHAPE + source-file identity (source JSONL
             carries no per-pair extractor tag — analyst blocker-2).
             Inference rules:
             R:  source file starts with 'wave-3-refusal-' (hand-authored refusal)
             S:  source file starts with 'response-shape-' (hand-authored persona/response-shape)
             E5: user matches /In Motoi, I want to.*Which verb do I reach for?/
             E4: user string appears in wave-1/wave-2 hand-curated E4_BY_BOOK
             E3: user matches /Show me (a simple|an intermediate|a more elaborate|another) example of .* in Motoi Scheme\\./
             E2: user contains ```motoi fence
             E1: default (paraphrase question, assistant leads with ```motoi)"
    :distribution
    ((:extractor "E1" :corpus 4703 :held 278 :pct 5.91 :note "Explain-then-code extraction from book prose.")
     (:extractor "E2" :corpus 5793 :held 342 :pct 5.90 :note "Code-then-explain extraction from book prose.")
     (:extractor "E3" :corpus 1583 :held  94 :pct 5.94 :note "Variation-pair extraction (a simple / intermediate / elaborate example).")
     (:extractor "E4" :corpus   91 :held   9 :pct 9.89 :note "Small hand-curated pool; min-1-per-cell rule slightly boosts share.")
     (:extractor "E5" :corpus   45 :held   8 :pct 17.78 :note "Very small pool (6 per book × few books had E5); min-1-per-cell rule preserves representation of this important routing shape.")
     (:extractor "R"  :corpus 2577 :held 157 :pct 6.09 :note "Refusal bucket: personal-deferral, out-of-domain, task-refusal, harmful, uncertainty.")
     (:extractor "S"  :corpus 2081 :held 112 :pct 5.38 :note "Response-shape bucket: identity-persona, reward-encouragement, refusal, factoids, game-playing.")))

   (:axis "VERB-COVERAGE TIER"
    :method "Top verb of assistant's first code fence is looked up in the
             coverage-audit's tier map (STARVED/THIN/THIN-CONTEXT/HEALTHY).
             UNTAGGED = pair's top verb is a core-lisp form (define/let/list/…)
             or not present in the audit's 949-verb map, OR the pair has no
             code fence (R/S buckets are largely prose). UNTAGGED share is
             high (~92%) because pairs commonly lead with `define` / plain
             arithmetic / no-code prose. Tier axis EXISTS to guarantee
             rare-verb recall is measurable in held-out even though rare-verb
             pairs are a minority of corpus."
    :distribution
    ((:tier "UNTAGGED"      :corpus 15533 :held 915 :pct 5.89)
     (:tier "THIN-CONTEXT"  :corpus  1154 :held  73 :pct 6.33)
     (:tier "HEALTHY"       :corpus   126 :held  11 :pct 8.73)
     (:tier "THIN"          :corpus    56 :held   1 :pct 1.79
      :note "Small pool; sample size is ~1 pair from rebalance. Consider
             boosting THIN sample manually if fine-grained THIN-verb recall
             becomes a primary eval question.")
     (:tier "STARVED"       :corpus     4 :held   0 :pct 0.00
      :note "STARVED = 0 corpus pairs by definition — the 4 corpus pairs
             mapping to STARVED tier are edge cases where the classifier
             pattern-matched a starved verb in R/S bucket prose. Not a
             valid coverage signal; ignore.")))

   (:axis "LENGTH"
    :method "Combined user+assistant character length; SHORT<200, MEDIUM<800,
             LONG>=800. Approximates token distribution (~4 chars/token)."
    :distribution
    ((:bucket "SHORT"   :corpus 6278 :held 372 :pct 5.93)
     (:bucket "MEDIUM"  :corpus 8868 :held 516 :pct 5.82)
     (:bucket "LONG"    :corpus 1727 :held 112 :pct 6.49))))

  :caveats
  ("Extractor label is INFERRED, not read from source metadata (blocker-2
    in the analyst report). The inference rules match the actual extractor
    code shape in scratch/wave-1-extractor-2026-07-16.py and
    wave-2-extractor-2026-07-16.py at the time of carving. If extractor
    logic changes, re-run infer_extractor() to verify labels."
   "Tier UNTAGGED shows a high share (92%). This is EXPECTED — core-lisp
    forms and arithmetic openers dominate the corpus, and the R/S buckets
    (~28% of corpus) are largely prose without code fences. The tier axis
    ensures NON-UNTAGGED pairs (THIN / THIN-CONTEXT / HEALTHY) are
    proportionally represented so verb-recall on rare verbs is measurable."
   "Per-verb coverage inside the held-out set is NOT guaranteed uniform.
    Held-out is a REPRESENTATIVE sample of the corpus shape at the time
    of carving, not a coverage-balanced probe suite. For a coverage-balanced
    verification suite, author a separate probe set (see verification-plan
    in small-model-dsl-teaching-2026-07-16.slat section 6)."
   "E4/E5 share was BOOSTED by the min-1-per-cell rule. This is deliberate —
    losing all hand-curated pairs from held-out would remove our ability
    to verify routing-pattern accuracy at eval time. Consequence: E4/E5
    recall is somewhat more measurable at the cost of a slight over-sample."
   "Race-condition note: on 2026-07-16 evening, wave-3-refusal-*.jsonl
    and response-shape-*.jsonl were being generated by parallel lanes.
    An initial carve at 19:13 covered only the pre-existing 8 files; a
    re-carve at 19:16 covered all 10 files but a subsequent write to
    wave-3-refusal by a parallel lane wiped the held-out marking. A THIRD
    carve at 19:17 (final) caught the stable state. Verify no lane is
    actively writing before running the carve.")
)

;; ==========================================================================
;; PROVENANCE & REPRODUCIBILITY
;; ==========================================================================

(provenance
  :script            "motoi-scheme/scratch/carve-heldout-2026-07-16.py"
  :seed              20260716
  :python-random     "random.Random(20260716)"
  :sample-timestamp  "2026-07-16T21:00:00Z"

  :header-marker
  "Every source JSONL header now carries:
     \"held_out_marking\": {
        \"applied_at\": \"2026-07-16T21:00:00Z\",
        \"generator\": \"carve-heldout-2026-07-16.py\",
        \"seed\": 20260716,
        \"heldout_file\": \"held-out/heldout-2026-07-16.jsonl\",
        \"note\": ...
     }
   Absence of this key on a source JSONL header = held-out marking has
   NOT been applied; treat the file as unmarked and re-run carving."

  :verified-invariants
  ("All 1,000 held-out pairs are marked ``held_out\": true`` in the
    canonical held-out file."
   "The (source_file, source_line) key of every held-out pair points to
    a pair in the source JSONL that ALSO carries ``held_out\": true``."
   "Source JSONL pair counts equal pre-carve counts (no deletes)."
   "Every source JSONL header carries the ``held_out_marking`` stamp."))

;; ==========================================================================
;; DOWNSTREAM USE
;; ==========================================================================

(downstream-use
  :train-loader
  "Filter EVERY pair by `rec.get(\"held_out\") is not True`. See
   :recommended-loader-filter under don-t-train-contract."

  :eval-loader
  "Load held-out/heldout-2026-07-16.jsonl directly. Each pair has:
     - messages: [{role, content}, ...]
     - held_out: true
     - _source_file: original JSONL filename
     - _source_line: original line number (1-indexed, excludes header)
   The _source_* keys let you trace any held-out pair back to its book
   for per-book scoring."

  :verification-suite-relationship
  "This held-out set is a SAMPLE of the corpus (in-distribution eval).
   For OUT-of-distribution eval and coverage-balanced verb-recall probes,
   author a SEPARATE suite (see verification-plan in
   small-model-dsl-teaching-2026-07-16.slat section 6). Both suites together
   give the full pass/fail picture."

  :first-training-run
  "Recommended first-run flow:
     1. Loader filters held-out pairs → 15,873-pair train stream.
     2. Train per section-6 recipe (full FT, 3 epochs, lr 5e-5, batch 128,
        Qwen2.5-Coder-1.5B-Instruct base).
     3. After training, run held-out eval:
        - assistant-token match / pass@1 for CODE pairs (E1/E2/E3)
        - blind rating by Alfred (or LLM judge) for E4/E5 routing pairs
        - refusal-rate + tone scoring for R pairs
        - persona-voice preservation scoring for S pairs
     4. Compare CODE score to MultiPL-T Racket benchmark (2308.09895): 2.6x
        pass@1 improvement is the floor. Motoi should exceed it (better
        base model, more pairs).")

;; ==========================================================================
;; INVARIANTS THIS FILE PROTECTS
;; ==========================================================================

(invariants
  ("No pair appears in BOTH the train stream (unmarked source-JSONL pairs)
    AND the held-out file. Verified programmatically at carve time by
    (file, line) key equality."
   "Held-out sample is DETERMINISTIC per (seed, corpus snapshot). Same
    seed + same input files = same 1,000 pairs, always."
   "Held-out marking is NON-DESTRUCTIVE. Source JSONLs still contain
    every pair; the only change is a top-level ``held_out\": true`` key
    on the carved subset."
   "Provenance chain is preserved: each held-out pair records its source
    file + source line, so any train/held-out audit can find the original."
   "Header marker on each source JSONL declares that held-out marking has
    been applied — training scripts can assert its presence before running."))

;; ==========================================================================
;; OPEN ITEMS (non-blocking)
;; ==========================================================================

(open-items
  ("Wave-3 CODE authoring (books-of-ai + remaining STARVED-verb pairs) will
    add new source JSONLs. When they land, re-run carve-heldout with the
    same seed to grow the held-out proportionally. Existing held-out
    membership stays fixed for the current files (deterministic per-file);
    NEW files contribute NEW pairs."
   "STARVED-tier verbs have 4 corpus pairs (all noise from R/S bucket
    pattern-matching) → 0 held-out coverage. Real STARVED-verb recall
    signal will not exist until Wave-3 authoring fills STARVED verbs (per
    gap-fill-plan in coverage-audit-2026-07-16.slat)."
   "THIN tier has only 1 held-out pair (from a 56-pair pool). Consider
    boosting the THIN sample manually if fine-grained THIN-verb recall
    becomes a primary eval question."
   "Consider adding per-pair extractor metadata AT extraction time (blocker-2
    in the analyst report). Would let this script read the tag instead of
    inferring — sharper labels, cheaper re-runs, immune to inference-rule
    drift."
   "Concurrent-write hazard: source JSONL generators (extractors,
    hand-authoring scripts) can race with the carve script and wipe
    held-out markings. Mitigation: run carve as the FINAL step of any
    corpus refresh; verify ``held_out_marking`` header stamp on all files
    before training."))

